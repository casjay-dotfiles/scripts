  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); CONTENT=$(printf '%s' \"$INPUT\" | python3 -c 'import json,sys; d=json.load(sys.stdin).get(\"tool_input\",{}); print(d.get(\"content\") or d.get(\"new_string\") or \"\")'); if printf '%s' \"$CONTENT\" | grep -qi 'anthropic\\|claude'; then echo 'BLOCKED: file content contains vendor names (Anthropic/Claude)' >&2; exit 2; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/protect-host.sh"
          }
        ]
      }
    ]
  },
  "preferences": {
    "auto_commit": false
  }
}
