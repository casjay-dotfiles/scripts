      "Bash(rm * /lib*)",
      "Bash(rm /lib32*)",
      "Bash(rm * /lib32*)",
      "Bash(rm /lib64*)",
      "Bash(rm * /lib64*)",
      "Bash(rm /boot*)",
      "Bash(rm * /boot*)",
      "Bash(rm /var*)",
      "Bash(rm * /var*)",
      "Bash(rm /root*)",
      "Bash(rm * /root*)",
      "Bash(rm /opt*)",
      "Bash(rm * /opt*)",
      "Bash(rm /dev*)",
      "Bash(rm * /dev*)",
      "Bash(rm /proc*)",
      "Bash(rm * /proc*)",
      "Bash(rm /sys*)",
      "Bash(rm * /sys*)",
      "Bash(rm /srv*)",
      "Bash(rm * /srv*)",
      "Bash(rm /run*)",
      "Bash(rm * /run*)",
      "Bash(rmd /)",
      "Bash(rmd /*)",
      "Bash(rmd * /)",
      "Bash(rmd * /*)",
      "Bash(rmd /bin*)",
      "Bash(rmd * /bin*)",
      "Bash(rmd /sbin*)",
      "Bash(rmd * /sbin*)",
      "Bash(rmd /etc*)",
      "Bash(rmd * /etc*)",
      "Bash(rmd /usr*)",
      "Bash(rmd * /usr*)",
      "Bash(rmd /lib*)",
      "Bash(rmd * /lib*)",
      "Bash(rmd /lib32*)",
      "Bash(rmd * /lib32*)",
      "Bash(rmd /lib64*)",
      "Bash(rmd * /lib64*)",
      "Bash(rmd /boot*)",
      "Bash(rmd * /boot*)",
      "Bash(rmd /var*)",
      "Bash(rmd * /var*)",
      "Bash(rmd /root*)",
      "Bash(rmd * /root*)",
      "Bash(rmd /opt*)",
      "Bash(rmd * /opt*)",
      "Bash(rmd /dev*)",
      "Bash(rmd * /dev*)",
      "Bash(rmd /proc*)",
      "Bash(rmd * /proc*)",
      "Bash(rmd /sys*)",
      "Bash(rmd * /sys*)",
      "Bash(rmd /srv*)",
      "Bash(rmd * /srv*)",
      "Bash(rmd /run*)",
      "Bash(rmd * /run*)",
      "Bash(rmdir /*)",
      "Bash(rmdir * /*)",
      "Bash(chmod * /etc*)",
      "Bash(chmod * /bin*)",
      "Bash(chmod * /sbin*)",
      "Bash(chmod * /usr*)",
      "Bash(chmod * /lib*)",
      "Bash(chmod * /boot*)",
      "Bash(chmod * /var*)",
      "Bash(chmod * /root*)",
      "Bash(chmod * /dev*)",
      "Bash(chown * /etc*)",
      "Bash(chown * /bin*)",
      "Bash(chown * /sbin*)",
      "Bash(chown * /usr*)",
      "Bash(chown * /lib*)",
