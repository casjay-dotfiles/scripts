      "Bash(mv * /bin*)",
      "Bash(mv * /sbin*)",
      "Bash(mv * /usr*)",
      "Bash(mv * /lib*)",
      "Bash(mv * /boot*)",
      "Bash(cp * /etc*)",
      "Bash(cp * /bin*)",
      "Bash(cp * /sbin*)",
      "Bash(cp * /usr*)",
      "Bash(cp * /lib*)",
      "Bash(cp * /boot*)",
      "Bash(find / *)",
      "Bash(find /etc*)",
      "Bash(find /bin*)",
