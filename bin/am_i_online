APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202207171345-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
[[ "$1" == "--raw" ]] && SHOW_RAW="true" && __printf_color() { printf '%s\n' "$1" | tr -d '\t\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
set -o pipefail

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-minimal.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Options are: devenvmgr_install dfmgr_install dockermgr_install fontmgr_install iconmgr_install pkmgr_install
# system_install systemmgr_install thememgr_install user_install wallpapermgr_install
user_install && __options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__devnull() { tee &>/dev/null; }
__devnull2() { eval "$*" 2>/dev/null; }
__logr() { eval "$*" |& tee -a "${LOGFILE:-$AM_I_ONLINE_LOG_DIR/$APPNAME.log}" |& __devnull; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__cmd_exist() {
  local exitCode=0
  for cmd in "$@"; do builtin command -v "$cmd" |& __devnull && true || exitCode+=1; done
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# output version
__version() { printf_cyan "$VERSION"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  printf '%s\n' "$1"
  printf '%s\n\n' "$2" | sed 's|:||g;s/'$3'/ '$4'/g' 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Help function - Align to 50
__help() {
  __printf_head() { printf_purple "$*"; }
  __printf_opts() { printf_cyan "$*"; }
  __printf_line() { printf_blue "$*"; }
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "am_i_online:  Check for internet connection"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Usage: am_i_online [options] [commands]"
  __printf_line "am_i_online available                             - list all available packages"
  __printf_line "am_i_online list                                  - list installed packages"
  __printf_line "am_i_online search    [package]                   - search for a package"
  __printf_line "am_i_online version   [package]                   - show the version info"
  __printf_line "am_i_online install   [package]                   - install a package"
  __printf_line "am_i_online remove    [package]                   - remove a package"
  __printf_line "am_i_online update    [package]                   - update a package"
  __printf_line "am_i_online download  [package]                   - downloads the source"
  __printf_line ""
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "am_i_online --debug                               - enable debugging"
  __printf_line "am_i_online --config                              - Generate user config file"
  __printf_line "am_i_online --version                             - Show script version"
  __printf_line "am_i_online --help                                - Shows this message"
  __printf_line "am_i_online --options                             - Shows all available options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  printf '\n'
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_blue "Generating the config file in"
  printf_cyan "$AM_I_ONLINE_CONFIG_DIR/$AM_I_ONLINE_CONFIG_FILE"
  [ -d "$AM_I_ONLINE_CONFIG_DIR" ] || mkdir -p "$AM_I_ONLINE_CONFIG_DIR"
  [ -d "$AM_I_ONLINE_CONFIG_BACKUP_DIR" ] || mkdir -p "$AM_I_ONLINE_CONFIG_BACKUP_DIR"
  [ -f "$AM_I_ONLINE_CONFIG_DIR/$AM_I_ONLINE_CONFIG_FILE" ] &&
    cp -Rf "$AM_I_ONLINE_CONFIG_DIR/$AM_I_ONLINE_CONFIG_FILE" "$AM_I_ONLINE_CONFIG_BACKUP_DIR/$AM_I_ONLINE_CONFIG_FILE.$$"
  cat <<EOF >"$AM_I_ONLINE_CONFIG_DIR/$AM_I_ONLINE_CONFIG_FILE"
# Settings for am_i_online
AM_I_ONLINE_TIMEOUT=2
AM_I_ONLINE_PING_COUNT=1
AM_I_ONLINE_TEST_SITE="\${AM_I_ONLINE_TEST_SITE:-1.1.1.1}"
AM_I_ONLINE_TEST_SITE_PING="\${AM_I_ONLINE_TEST_SITE_PING:-1.1.1.1}"
AM_I_ONLINE_TEST_SITE_HTTP="\${AM_I_ONLINE_TEST_SITE_HTTP:-1.1.1.1}"
AM_I_ONLINE_TEST_SITE_HTTP_STATUS="\${AM_I_ONLINE_TEST_SITE_HTTP_STATUS:-[200|301]}"

# Notification settings
AM_I_ONLINE_NOTIFY_ENABLED="${AM_I_ONLINE_NOTIFY_ENABLED:-yes}"
AM_I_ONLINE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-\$APPNAME}"
AM_I_ONLINE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$AM_I_ONLINE_NOTIFY_CLIENT_ICON}"
AM_I_ONLINE_GOOD_MESSAGE="${AM_I_ONLINE_GOOD_MESSAGE:-Everything Went OK}"
AM_I_ONLINE_ERROR_MESSAGE="${AM_I_ONLINE_ERROR_MESSAGE:-Well something seems to have gone wrong}"

# Colorization settings
AM_I_ONLINE_OUTPUT_COLOR="${AM_I_ONLINE_OUTPUT_COLOR:-5}"
AM_I_ONLINE_OUTPUT_COLOR_GOOD="${AM_I_ONLINE_OUTPUT_COLOR_GOOD:-2}"
AM_I_ONLINE_OUTPUT_COLOR_ERROR="${AM_I_ONLINE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$AM_I_ONLINE_CONFIG_DIR/$AM_I_ONLINE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    . "$AM_I_ONLINE_CONFIG_DIR/$AM_I_ONLINE_CONFIG_FILE"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
# ignore any local network devices
__local_network() {
  if [ "$1" = "localhost" ] || [ "$1" = "$(hostname -s)" ] || [ "$1" = "$(hostname -f)" ] || [[ "$1" =~ ."$(hostname -d)" ]] ||
    [[ "$1" =~ 10.*.*.* ]] || [[ "$1" =~ 192.168.*.* ]] || [[ "$1" =~ 172.16.*.* ]] || [[ "$1" =~ 127.*.*.* ]]; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
test_ping() {
  [[ -z "$no_ping" ]] || return
  local definesite="${site:-$AM_I_ONLINE_TEST_SITE_PING}"
  local site="${definesite:-$AM_I_ONLINE_TEST_SITE}"
  local timeout="${AM_I_ONLINE_TIMEOUT:-2}"
  local count="${AM_I_ONLINE_PING_COUNT:-2}"
  timeout $timeout ping -c$count "$site" &>/dev/null && true || false
  pingExit="$?"
  export pingExit
  return $pingExit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
test_site() {
  curl -q --connect-timeout 1 \
    --fail --retry 0 -ILSsf "http://1.1.1.1" --insecure 2>/dev/null |
    grep -q 'server:.*cloudflare'
  siteExit="$?"
  export siteExit
  return $siteExit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
test_http() {
  [[ -z "$no_http" ]] || return
  local timeout="${AM_I_ONLINE_TIMEOUT:-2}"
  local site="${site:-$AM_I_ONLINE_TEST_SITE}"
  local definestatus="${status:-200}"
  local definesite="${site:-$AM_I_ONLINE_TEST_SITE_HTTP}"
  local status="${definestatus:-$AM_I_ONLINE_TEST_SITE_HTTP_STATUS}"
  timeout $timeout curl --disable -LSIs --insecure --max-time ${timeout} "$site" 2>/dev/null |
    grep -e "HTTP/[0123456789]" | grep -qE "${status}" -n1 &>/dev/null && true || false
  httpExit="$?"
  export httpExit
  return $httpExit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__execute_main() {
  pingExit=
  httpExit=
  exitCode="0"
  if [ -n "$AM_I_ONLINE_FORCE_CONNECTION" ] || __local_network "$site"; then
    httpExit=0
    pingExit=0
    AM_I_ONLINE_RUN=no
  fi
  options_used_message="PingSite:${site:-$AM_I_ONLINE_TEST_SITE_PING}|HTTPSite:${site:-$AM_I_ONLINE_TEST_SITE_HTTP}|StatusCode:$AM_I_ONLINE_TEST_SITE_HTTP_STATUS"

  if [ -z "$AM_I_ONLINE_RUN" ]; then
    if test_ping; then
      exitCode=0
    elif test_site; then
      exitCode=0
    elif test_http; then
      exitCode=0
    else
      exitCode=1
    fi
  fi
  if [ "$pingExit" = 0 ] || [ "$httpExit" = 0 ] || [ "$exitCode" = 0 ]; then
    export AM_I_ONLINE_NOTIFY_CLIENT_ICON="connect_established"
    if [ "$AM_I_ONLINE_SHOW" = "yes" ]; then
      printf_green "you seem to be connected to the internet"
      __notifications "$AM_I_ONLINE_GOOD_NAME ${AM_I_ONLINE_MESSAGE:-$AM_I_ONLINE_GOOD_MESSAGE}"
    elif [ "$AM_I_ONLINE_SHOW_CONSOLE" = "yes" ]; then
      printf_green "Options Used - $options_used_message"
      printf_green "you seem to be connected to the internet"
    fi
    exitCode=0
  else
    if [ "$AM_I_ONLINE_SHOW_CONSOLE" = "yes" ]; then
      AM_I_ONLINE_SHOW_ERROR=no
      printf_green "Options Used - $options_used_message"
      printf_red exitCode:$exitCode httpExit:$httpExit pingExit:$pingExit
      printf_red "you appear to be offline" >&2
    fi
    if [ "$AM_I_ONLINE_SHOW_ERROR" = "yes" ]; then
      printf_return 1 1 "${AM_I_ONLINE_MESSAGE:-$AM_I_ONLINE_ERROR_MESSAGE}" >&2
      __notifications "$AM_I_ONLINE_ERROR_NAME ${AM_I_ONLINE_MESSAGE:-$AM_I_ONLINE_ERROR_MESSAGE}"
    fi
    exitCode=1
  fi
  return "${exitCode:-$?}"
}

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Defaults
exitCode=0
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
AM_I_ONLINE_LOG_DIR="${AM_I_ONLINE_LOG_DIR:-$HOME/.local/log/am_i_online}"
AM_I_ONLINE_CACHE_DIR="${AM_I_ONLINE_CACHE_DIR:-$HOME/.cache/am_i_online}"
AM_I_ONLINE_CONFIG_DIR="${AM_I_ONLINE_CONFIG_DIR:-$HOME/.config/myscripts/am_i_online}"
AM_I_ONLINE_CONFIG_BACKUP_DIR="${AM_I_ONLINE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/am_i_online/backups}"
AM_I_ONLINE_TEMP_DIR="${AM_I_ONLINE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/am_i_online}"
AM_I_ONLINE_OPTIONS_DIR="${AM_I_ONLINE_OPTIONS_DIR:-$HOME/.local/share/myscripts/am_i_online/options}"
AM_I_ONLINE_CONFIG_FILE="${AM_I_ONLINE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
AM_I_ONLINE_OUTPUT_COLOR="${AM_I_ONLINE_OUTPUT_COLOR:-4}"
AM_I_ONLINE_OUTPUT_COLOR_2="${AM_I_ONLINE_OUTPUT_COLOR:-6}"
AM_I_ONLINE_OUTPUT_COLOR_GOOD="${AM_I_ONLINE_OUTPUT_COLOR_GOOD:-2}"
AM_I_ONLINE_OUTPUT_COLOR_ERROR="${AM_I_ONLINE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
AM_I_ONLINE_GOOD_NAME="${AM_I_ONLINE_GOOD_NAME:-Great:}"
AM_I_ONLINE_ERROR_NAME="${AM_I_ONLINE_ERROR_NAME:-Error:}"
AM_I_ONLINE_GOOD_MESSAGE="${AM_I_ONLINE_GOOD_MESSAGE:-you seem to be connected to the internet}"
AM_I_ONLINE_ERROR_MESSAGE="${AM_I_ONLINE_ERROR_MESSAGE:-internet appears to be down and I require a working connection}"
AM_I_ONLINE_NOTIFY_ENABLED="${AM_I_ONLINE_NOTIFY_ENABLED:-yes}"
AM_I_ONLINE_NOTIFY_CLIENT_NAME="${AM_I_ONLINE_NOTIFY_CLIENT_NAME:-$APPNAME}"
AM_I_ONLINE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$AM_I_ONLINE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional Variables
AM_I_ONLINE_TIMEOUT="${AM_I_ONLINE_TIMEOUT:-2}"
AM_I_ONLINE_PING_COUNT="${AM_I_ONLINE_PING_COUNT:-2}"
AM_I_ONLINE_TEST_SITE="${AM_I_ONLINE_TEST_SITE:-1.1.1.1}"
AM_I_ONLINE_TEST_SITE_PING="${AM_I_ONLINE_TEST_SITE_PING:-1.1.1.1}"
AM_I_ONLINE_TEST_SITE_HTTP="${AM_I_ONLINE_TEST_SITE_HTTP:-1.1.1.1}"
AM_I_ONLINE_TEST_SITE_HTTP_STATUS="${AM_I_ONLINE_TEST_SITE_HTTP_STATUS:-[200|301]}"
AM_I_ONLINE_SHOW_ERROR="${AM_I_ONLINE_SHOW_ERROR:-}"
AM_I_ONLINE_SHOW="${AM_I_ONLINE_SHOW:-}"
AM_I_ONLINE_MESSAGE="${AM_I_ONLINE_MESSAGE:-}"
AM_I_ONLINE_SHOW_CONSOLE="${AM_I_ONLINE_SHOW_CONSOLE:-}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$AM_I_ONLINE_CONFIG_DIR/$AM_I_ONLINE_CONFIG_FILE" ] ||
  [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$AM_I_ONLINE_CONFIG_DIR/$AM_I_ONLINE_CONFIG_FILE" ] &&
  . "$AM_I_ONLINE_CONFIG_DIR/$AM_I_ONLINE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$AM_I_ONLINE_LOG_DIR" ] ||
  mkdir -p "$AM_I_ONLINE_LOG_DIR" |& __devnull
[ -d "$AM_I_ONLINE_TEMP_DIR" ] ||
  mkdir -p "$AM_I_ONLINE_TEMP_DIR" |& __devnull
[ -d "$AM_I_ONLINE_CACHE_DIR" ] ||
  mkdir -p "$AM_I_ONLINE_CACHE_DIR" |& __devnull
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
AM_I_ONLINE_TEMP_FILE="${AM_I_ONLINE_TEMP_FILE:-$(mktemp $AM_I_ONLINE_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$AM_I_ONLINE_TEMP_FILE" ] && [ -f "$AM_I_ONLINE_TEMP_FILE" ] && rm -Rf "$AM_I_ONLINE_TEMP_FILE" |&__devnull' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$AM_I_ONLINE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${AM_I_ONLINE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${AM_I_ONLINE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_ICON="${AM_I_ONLINE_NOTIFY_CLIENT_ICON}"
    export NOTIFY_CLIENT_NAME="${AM_I_ONLINE_NOTIFY_CLIENT_NAME}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Argument/Option settings
SETARGS="$*"
SHORTOPTS="f,m:,s:,l"
LONGOPTS="config,debug,dir:,help,options,raw,version,error,show,console,force,message:,site:,code:,loop"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --debug)
    shift 1
    set -xo pipefail
    export SCRIPT_OPTS="--debug"
    export _DEBUG="on"
    ;;
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}" |& printf_readline 5
    [ -z "$SHORTOPTS" ] || __list_options "Short Options" "-${SHORTOPTS}" ',' '-' |& printf_readline 4
    [ -z "$LONGOPTS" ] || __list_options "Long Options" "--${LONGOPTS}" ',' '--' |& printf_readline 4
    [ -z "$ARRAY" ] || __list_options "Base Options" "${ARRAY}" ',' '' |& printf_readline 4
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    AM_I_ONLINE_CWD="$2"
    shift 2
    ;;
  --raw)
    shift 1
    SHOW_RAW="true"
    ;;
  -f | --force)
    shift 1
    AM_I_ONLINE_FORCE_CONNECTION="true"
    ;;
  --error)
    shift 1
    AM_I_ONLINE_SHOW_ERROR="yes"
    ;;
  --show)
    shift 1
    AM_I_ONLINE_SHOW="yes"
    AM_I_ONLINE_SHOW_ERROR="yes"
    ;;
  --console)
    shift 1
    AM_I_ONLINE_SHOW_CONSOLE="yes"
    ;;
  -m | --message)
    shift 1
    AM_I_ONLINE_MESSAGE="$1"
    shift 1
    ;;
  -s | --site)
    shift 1
    site="$1"
    shift 1
    ;;
  --code)
    shift 1
    status="$1"
    no_ping="true"
    shift 1
    ;;
  -l | --loop)
    trap '[ -n "$AM_I_ONLINE_CACHE_DIR" ] && [ -f "$AM_I_ONLINE_CACHE_DIR/am_i_online_no" ] && rm -f "$AM_I_ONLINE_CACHE_DIR/am_i_online_no" &>/dev/null' EXIT
    shift $#
    onmess="You appear to be back online at"
    ofmess="You still appear to be offline at"
    printf_blue "Starting loop at $(date +'%H:%M:%S')"
    while :; do
      __run && true || false
      if [[ $? = 0 ]]; then
        printf '\t\t%b%s\n' "${GREEN}" "$onmess $(date +'%H:%M:%S') ${NC}"
        rm -f "$AM_I_ONLINE_CACHE_DIR/am_i_online_no"
        break
      else
        printf '\r\t\t%b%s' "${RED}" "$ofmess $(date +'%H:%M:%S') ${NC}"
        touch "$AM_I_ONLINE_CACHE_DIR/am_i_online_no"
        sleep 10
        continue
      fi
    done
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Redefine functions based on options

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash curl ping || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__execute_main "$@"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
