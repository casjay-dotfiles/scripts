APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202207181340-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"
[[ "$1" == "--raw" ]] && SHOW_RAW="true" && printf_color() { printf '%b' "$1" | tr -d '\t\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
set -o pipefail

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-minimal.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Options are: devenvmgr_install dfmgr_install dockermgr_install fontmgr_install iconmgr_install pkmgr_install
# system_install systemmgr_install thememgr_install user_install wallpapermgr_install
user_install && __options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__devnull() {
  tee &>/dev/null || exitCode=1
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -'
__devnull2() {
  eval "$*" 2>/dev/null || exitCode=1
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -'
__logr() {
  printf_color() { printf '%b' "$1" | tr -d '\t\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
  if [ "$#" -ne 0 ]; then
    eval "$*" 2>>"${LOGFILE:-$AM_I_ONLINE_LOG_DIR/$APPNAME.log}.err" >>"${LOGFILE:-$AM_I_ONLINE_LOG_DIR/$APPNAME.log}" || exitCode=1
  else
    cat - &> >(tee -ia "${LOGFILE:-$AM_I_ONLINE_LOG_DIR/$APPNAME.log}" &>/dev/null) || exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__cmd_exist() {
  local exitCode=0
  for cmd in "$@"; do builtin command -v "$cmd" |& __devnull && true || exitCode+=1; done
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# output version
__version() { printf_blue "$VERSION"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  printf '%s\n' "$1"
  printf '%s\n\n' "$2" | sed 's|:||g;s/'$3'/ '$4'/g' 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Help function - Align to 50
__help() {
  __printf_head() { printf_purple "$*"; }
  __printf_opts() { printf_cyan "$*"; }
  __printf_line() { printf_blue "$*"; }
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "anime-dl:  Search for anime to download or watch"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Usage: anime-dl [options] [query]"
  __printf_line "anime-dl -v                     - use VLC as the media player"
  __printf_line "anime-dl -q                     - set video quality (best|worst|360|480|720|1080)"
  __printf_line "anime-dl -s                     - watch anime together with friends, using Syncplay (mpv only)"
  __printf_line "anime-dl -f                     - use fzf for anime selection"
  __printf_line "anime-dl -a                     - specify episode to watch"
  __printf_line "anime-dl -d                     - download episode"
  __printf_line "anime-dl -p                     - download episode to specified directory"
  __printf_line "anime-dl -c                     - continue watching anime from history"
  __printf_line "anime-dl -r                     - select provider to scrape first [1-7]"
  __printf_line ""
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "anime-dl --help                 - Shows this message"
  __printf_line "anime-dl --config               - Generate user config file"
  __printf_line "anime-dl --version              - Show script version"
  __printf_line "anime-dl --options              - Shows all available options"
  __printf_line "anime-dl --debug                - enable debugging"
  __printf_line "anime-dl --raw                  - removes all formatting on output"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  printf '\n'
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_blue "Generating the config file in"
  printf_cyan "$ANIME_DL_CONFIG_DIR/$ANIME_DL_CONFIG_FILE"
  [ -d "$ANIME_DL_CONFIG_DIR" ] || mkdir -p "$ANIME_DL_CONFIG_DIR"
  [ -d "$ANIME_DL_CONFIG_BACKUP_DIR" ] || mkdir -p "$ANIME_DL_CONFIG_BACKUP_DIR"
  [ -f "$ANIME_DL_CONFIG_DIR/$ANIME_DL_CONFIG_FILE" ] &&
    cp -Rf "$ANIME_DL_CONFIG_DIR/$ANIME_DL_CONFIG_FILE" "$ANIME_DL_CONFIG_BACKUP_DIR/$ANIME_DL_CONFIG_FILE.$$"
  cat <<EOF >"$ANIME_DL_CONFIG_DIR/$ANIME_DL_CONFIG_FILE"
# Settings for anime-dl
ANIME_DL_SAVE_DIR="$HOME/Videos/Anime"
ANIME_DL_SOURCE_FILE="$CASJAYSDEVDIR/sources/ani-cli"
ANIME_DL_UPDATE_URL="https://github.com/pystardust/ani-cli"
ANIME_DL_UPDATE_FILE="ani-cli"
ANIME_DL_DEFAULT_OPTS=""

# Notification settings
ANIME_DL_NOTIFY_ENABLED="${ANIME_DL_NOTIFY_ENABLED:-yes}"
ANIME_DL_NOTIFY_CLIENT_NAME="${ANIME_DL_NOTIFY_CLIENT_NAME:-$APPNAME}"
ANIME_DL_NOTIFY_CLIENT_ICON="${ANIME_DL_NOTIFY_CLIENT_ICON:-video}"
ANIME_DL_GOOD_MESSAGE="${ANIME_DL_GOOD_MESSAGE:-Everything Went OK}"
ANIME_DL_ERROR_MESSAGE="${ANIME_DL_ERROR_MESSAGE:-Well something seems to have gone wrong}"

# Colorization settings
ANIME_DL_OUTPUT_COLOR="${ANIME_DL_OUTPUT_COLOR:-5}"
ANIME_DL_OUTPUT_COLOR_GOOD="${ANIME_DL_OUTPUT_COLOR_GOOD:-2}"
ANIME_DL_OUTPUT_COLOR_ERROR="${ANIME_DL_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$ANIME_DL_CONFIG_DIR/$ANIME_DL_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    . "$ANIME_DL_CONFIG_DIR/$ANIME_DL_CONFIG_FILE"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__update() {
  if sudo -n true; then
    printf_green "Updating $APPNAME"
    git clone -q "$ANIME_DL_UPDATE_URL" "/tmp/anime-cli" &>/dev/null
    if [[ -f "/tmp/anime-cli/bin/ani-cli" ]]; then
      sudo mv -f "/tmp/anime-cli/bin/ani-cli" "$ANIME_DL_SOURCE_FILE"
      if [[ -d "/tmp/anime-cli/lib/ani-cli" ]]; then
        sudo mkdir -p "$CASJAYSDEVDIR/lib/ani-cli" &>/dev/null
        sudo cp -Rf "/tmp/anime-cli/lib/ani-cli/." "$CASJAYSDEVDIR/lib/ani-cli" &>/dev/null
      fi
      exitCode=0
    else
      printf_red "$ANIME_DL_UPDATE_URL"
      exitCode=1
    fi
  else
    printf_red "Updating $APPNAME requires sudo privileges"
    exitCode=1
  fi
  if [ -f "$ANIME_DL_SOURCE_FILE" ] && [ $exitCode = 0 ]; then
    sudo chmod +x "$ANIME_DL_SOURCE_FILE"
    printf_green "Updated $APPNAME"
  else
    printf_red "Failed to update $APPNAME"
    exitCode=1
  fi
  rm -Rf "/tmp/anime-cli" &>/dev/null
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__download() {
  query="$*"
  if [[ $# = 0 ]]; then
    $ANIME_DL_SOURCE_FILE -h
    return 0
  else
    dir="$ANIME_DL_SAVE_DIR/$(basename ${1// /_})"
    __mkd "$dir"
    if ! cd "$dir"; then
      printf_exit "Failed to create $dir"
    else
      $ANIME_DL_SOURCE_FILE -x ${CLI_OPTS:--d -p .} "$query" #2>/dev/null
      return $?
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__aria2c() {
  local exitCode=0
  if cmd_exists aria2 axel; then
    return 0
  elif cmd_exists aria2c axel; then
    return 0
  else
    printf_green "Installing aria2, axel"
    pkmgr silent install axel aria2 &>/dev/null ||
      pkmgr silent install axel aria2c &>/dev/null || exitCode=1
    [[ "$exitCode" = 0 ]] && printf_cyan "aria2,axel has been installed" ||
      printf_red "Aria2 failed to install"
    { cmd_exists axel; } || exit 1
    { cmd_exists aria2 || cmd_exists aria2c; } || exit 1
    return ${exitCode:-$?}
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__execute_ani_cli() {
  __aria2c && __download "$@"
  echo
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Defaults
exitCode=0
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
ANIME_DL_CONFIG_FILE="${ANIME_DL_CONFIG_FILE:-settings.conf}"
ANIME_DL_CONFIG_DIR="${ANIME_DL_CONFIG_DIR:-$HOME/.config/myscripts/anime-dl}"
ANIME_DL_CONFIG_BACKUP_DIR="${ANIME_DL_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/anime-dl/backups}"
ANIME_DL_LOG_DIR="${ANIME_DL_LOG_DIR:-$HOME/.local/log/anime-dl}"
ANIME_DL_TEMP_DIR="${ANIME_DL_TEMP_DIR:-$HOME/.local/tmp/system_scripts/anime-dl}"
ANIME_DL_CACHE_DIR="${ANIME_DL_CACHE_DIR:-$HOME/.cache/anime-dl}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
ANIME_DL_OUTPUT_COLOR="${ANIME_DL_OUTPUT_COLOR:-4}"
ANIME_DL_OUTPUT_COLOR_2="${ANIME_DL_OUTPUT_COLOR:-6}"
ANIME_DL_OUTPUT_COLOR_GOOD="${ANIME_DL_OUTPUT_COLOR_GOOD:-2}"
ANIME_DL_OUTPUT_COLOR_ERROR="${ANIME_DL_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
ANIME_DL_GOOD_NAME="${ANIME_DL_GOOD_NAME:-Great:}"
ANIME_DL_ERROR_NAME="${ANIME_DL_ERROR_NAME:-Error:}"
ANIME_DL_GOOD_MESSAGE="${ANIME_DL_GOOD_MESSAGE:-No errors reported}"
ANIME_DL_ERROR_MESSAGE="${ANIME_DL_ERROR_MESSAGE:-Error reported}"
ANIME_DL_NOTIFY_ENABLED="${ANIME_DL_NOTIFY_ENABLED:-yes}"
ANIME_DL_NOTIFY_CLIENT_NAME="${ANIME_DL_NOTIFY_CLIENT_NAME:-$APPNAME}"
ANIME_DL_NOTIFY_CLIENT_ICON="${ANIME_DL_NOTIFY_CLIENT_ICON:-video}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional Variables
ANIME_DL_SAVE_DIR="${ANIME_DL_SAVE_DIR:-$HOME/Videos/Anime}"
ANIME_DL_SOURCE_FILE="${ANIME_DL_SOURCE_FILE:-$CASJAYSDEVDIR/sources/ani-cli}"
ANIME_DL_UPDATE_URL="${ANIME_DL_UPDATE_URL:-https://github.com/pystardust/ani-cli}"
ANIME_DL_UPDATE_FILE="${ANIME_DL_UPDATE_FILE:-ani-cli}"
ANIME_DL_DEFAULT_OPTS="${ANIME_DL_DEFAULT_OPTS:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$ANIME_DL_CONFIG_DIR/$ANIME_DL_CONFIG_FILE" ] ||
  [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$ANIME_DL_CONFIG_DIR/$ANIME_DL_CONFIG_FILE" ] &&
  . "$ANIME_DL_CONFIG_DIR/$ANIME_DL_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$ANIME_DL_LOG_DIR" ] ||
  mkdir -p "$ANIME_DL_LOG_DIR" |& __devnull
[ -d "$ANIME_DL_TEMP_DIR" ] ||
  mkdir -p "$ANIME_DL_TEMP_DIR" |& __devnull
[ -d "$ANIME_DL_CACHE_DIR" ] ||
  mkdir -p "$ANIME_DL_CACHE_DIR" |& __devnull
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
ANIME_DL_TEMP_FILE="${ANIME_DL_TEMP_FILE:-$(mktemp $ANIME_DL_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$ANIME_DL_TEMP_FILE" ] && [ -f "$ANIME_DL_TEMP_FILE" ] && rm -Rf "$ANIME_DL_TEMP_FILE" |&__devnull' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$ANIME_DL_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${NOTIFY_GOOD_MESSAGE:-$ANIME_DL_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${NOTIFY_ERROR_MESSAGE:-$ANIME_DL_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$ANIME_DL_NOTIFY_CLIENT_ICON}"
    export NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$ANIME_DL_NOTIFY_CLIENT_NAME}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="config,debug,dir:,help,options,raw,version"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --debug)
    shift 1
    set -xo pipefail
    export SCRIPT_OPTS="--debug"
    export _DEBUG="on"
    ;;
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}" |& printf_readline 5
    [ -z "$SHORTOPTS" ] || __list_options "Short Options" "-${SHORTOPTS}" ',' '-' |& printf_readline 4
    [ -z "$LONGOPTS" ] || __list_options "Long Options" "--${LONGOPTS}" ',' '--' |& printf_readline 4
    [ -z "$ARRAY" ] || __list_options "Base Options" "${ARRAY}" ',' '' |& printf_readline 4
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    ANIME_DL_CWD="$2"
    shift 2
    ;;
  --raw)
    shift 1
    SHOW_RAW="true"
    printf_color() {
      printf '%b' "$1" | tr -d '\t\t' |
        sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'
    }
    ;;
  --update)
    shift 1
    __update
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Redefine functions based on options

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
[ -f "$ANIME_DL_SOURCE_FILE" ] || __update
ANIME_DL_SAVE_DIR="${ANIME_DL_CWD:-$ANIME_DL_SAVE_DIR}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
printf_yellow "Sending $* to: $ANIME_DL_SOURCE_FILE"
__execute_ani_cli "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
