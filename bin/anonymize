#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202111051608-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : anonymize --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Friday, Nov 05, 2021 16:08 EDT
# @File          : anonymize
# @Description   : Anonymous web access
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202111051608-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$ANONYMIZE_TEMP_FILE" ] && [ -f "$ANONYMIZE_TEMP_FILE" ] && rm -Rf "$ANONYMIZE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$ANONYMIZE_CONFIG_DIR/$ANONYMIZE_CONFIG_FILE"
  [ -d "$ANONYMIZE_CONFIG_DIR" ] || mkdir -p "$ANONYMIZE_CONFIG_DIR"
  [ -d "$ANONYMIZE_CONFIG_BACKUP_DIR" ] || mkdir -p "$ANONYMIZE_CONFIG_BACKUP_DIR"
  [ -f "$ANONYMIZE_CONFIG_DIR/$ANONYMIZE_CONFIG_FILE" ] &&
    cp -Rf "$ANONYMIZE_CONFIG_DIR/$ANONYMIZE_CONFIG_FILE" "$ANONYMIZE_CONFIG_BACKUP_DIR/$ANONYMIZE_CONFIG_FILE.$$"
  cat <<EOF >"$ANONYMIZE_CONFIG_DIR/$ANONYMIZE_CONFIG_FILE"
# Settings for anonymize
ANONYMIZE_I2P_JAR="${ANONYMIZE_I2P_JAR:-https://download.i2p2.de/releases/1.5.0/i2pinstall_1.5.0.jar}"
ANONYMIZE_FREENET_JAR="${ANONYMIZE_FREENET_JAR:-https://github.com/freenet/fred/releases/download/build01492/new_installer_offline_1492.jar}"
ANONYMIZE_CWD="${ANONYMIZE_CWD:-$HOME/.local/share/anonymize}"

# Notification settings
ANONYMIZE_GOOD_MESSAGE="${ANONYMIZE_GOOD_MESSAGE:-Everything Went OK}"
ANONYMIZE_ERROR_MESSAGE="${ANONYMIZE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
ANONYMIZE_NOTIFY_ENABLED="${ANONYMIZE_NOTIFY_ENABLED:-yes}"
ANONYMIZE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
ANONYMIZE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$ANONYMIZE_NOTIFY_CLIENT_ICON}"

# Colorization settings
ANONYMIZE_OUTPUT_COLOR="${ANONYMIZE_OUTPUT_COLOR:-5}"
ANONYMIZE_OUTPUT_COLOR_GOOD="${ANONYMIZE_OUTPUT_COLOR_GOOD:-2}"
ANONYMIZE_OUTPUT_COLOR_ERROR="${ANONYMIZE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$ANONYMIZE_CONFIG_DIR/$ANONYMIZE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for anonymize has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
ANONYMIZE_LOG_DIR="${ANONYMIZE_LOG_DIR:-$HOME/.local/log/anonymize}"
ANONYMIZE_CACHE_DIR="${ANONYMIZE_CACHE_DIR:-$HOME/.cache/anonymize}"
ANONYMIZE_CONFIG_DIR="${ANONYMIZE_CONFIG_DIR:-$HOME/.config/myscripts/anonymize}"
ANONYMIZE_OPTIONS_DIR="${ANONYMIZE_OPTIONS_DIR:-$HOME/.local/share/myscripts/anonymize/options}"
ANONYMIZE_CONFIG_BACKUP_DIR="${ANONYMIZE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/anonymize/backups}"
ANONYMIZE_TEMP_DIR="${ANONYMIZE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/anonymize}"
ANONYMIZE_TEMP_FILE="${ANONYMIZE_TEMP_FILE:-$(mktemp $ANONYMIZE_TEMP_DIR/XXXXXX 2>/dev/null)}"
ANONYMIZE_CONFIG_FILE="${ANONYMIZE_CONFIG_FILE:-settings.conf}"
ANONYMIZE_GOOD_MESSAGE="${ANONYMIZE_GOOD_MESSAGE:-Everything Went OK}"
ANONYMIZE_ERROR_MESSAGE="${ANONYMIZE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
ANONYMIZE_NOTIFY_ENABLED="${ANONYMIZE_NOTIFY_ENABLED:-yes}"
ANONYMIZE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
ANONYMIZE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$ANONYMIZE_NOTIFY_CLIENT_ICON}"
ANONYMIZE_OUTPUT_COLOR="${ANONYMIZE_OUTPUT_COLOR:-5}"
ANONYMIZE_OUTPUT_COLOR_GOOD="${ANONYMIZE_OUTPUT_COLOR_GOOD:-2}"
ANONYMIZE_OUTPUT_COLOR_ERROR="${ANONYMIZE_OUTPUT_COLOR_ERROR:-1}"
ANONYMIZE_I2P_JAR="${ANONYMIZE_I2P_JAR:-https://download.i2p2.de/releases/1.5.0/i2pinstall_1.5.0.jar}"
ANONYMIZE_FREENET_JAR="${ANONYMIZE_FREENET_JAR:-https://github.com/freenet/fred/releases/download/build01492/new_installer_offline_1492.jar}"
ANONYMIZE_CWD="${ANONYMIZE_CWD:-$HOME/.local/share/anonymize}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$ANONYMIZE_CONFIG_DIR/$ANONYMIZE_CONFIG_FILE" ] && . "$ANONYMIZE_CONFIG_DIR/$ANONYMIZE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$ANONYMIZE_LOG_DIR" ] || mkdir -p "$ANONYMIZE_LOG_DIR" &>/dev/null
[ -d "$ANONYMIZE_TEMP_DIR" ] || mkdir -p "$ANONYMIZE_TEMP_DIR" &>/dev/null
[ -d "$ANONYMIZE_CACHE_DIR" ] || mkdir -p "$ANONYMIZE_CACHE_DIR" &>/dev/null
[ -f "$ANONYMIZE_TEMP_FILE" ] || touch "$ANONYMIZE_TEMP_FILE" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$ANONYMIZE_CONFIG_DIR/$ANONYMIZE_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,i,f,d"
LONGOPTS="options,config,version,help,dir:,freenet,i2p,download,console"
ARRAY="i2p freenet tor"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    ANONYMIZE_CWD="$2"
    shift 2
    ;;
  --console | -c)
    shift 1
    CONSOLE="true"
    ;;
  --i2p | -i)
    shift 1
    OPTS="i2p"
    ;;
  --freenet | -f)
    shift 1
    OPTS=freenet
    ;;
  --download | -d)
    shift 1
    DOWNLOAD="true"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$ANONYMIZE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${ANONYMIZE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${ANONYMIZE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${ANONYMIZE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${ANONYMIZE_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if ! cmd_exists java; then
  printf_green "Installing openjdk"
  pkmgr install jdk-openjdk
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case ${OPTS:-$1} in
tor)
  shift 1
  if cmd_exists tor-browser; then
    tor-browser -new-tab --allow-remote ${LINK:-https://http://imtulbcjer7mohs62lpycyod2c3pnil2x6xjirrojedbluh4d7z2g6ad.onion/} &
  elif cmd_exists torbrowser; then
    torbrowser -new-tab --allow-remote ${LINK:-https://http://imtulbcjer7mohs62lpycyod2c3pnil2x6xjirrojedbluh4d7z2g6ad.onion/} &
  else
    printf_red "Tor browser does not seem to be installed"
  fi
  exit $?
  ;;

i2p)
  shift 1
  if [[ "$DOWNLOAD" = "true" ]] || [[ ! -f "$ANONYMIZE_CWD/i2p/i2p-install.jar" ]]; then
    mkdir -p $ANONYMIZE_CWD/i2p
    wget "$ANONYMIZE_I2P_JAR" -O "$ANONYMIZE_CWD/i2p/i2p-install.jar"
    [[ -f "$ANONYMIZE_CWD/i2p/i2p-install.jar" ]] || printf_exit "failed to download $ANONYMIZE_I2P_JAR"
    if [[ "$CONSOLE" = "true" ]]; then
      java -jar "$ANONYMIZE_CWD/i2p/i2p-install.jar" -console
    else
      java -jar "$ANONYMIZE_CWD/i2p/i2p-install.jar"
    fi
  fi
  if [[ -f "$HOME/.local/share/i2p/i2prouter" ]]; then
    eval "$HOME/.local/share/i2p/i2prouter" start &
    sleep 10
  fi
  netstatg 7657 | grep -q java && $BROWSER "http://localhost:8888" || printf_exit "Freenet does not seem to be running"
  exit $?
  ;;

freenet)
  shift 1
  if [[ "$DOWNLOAD" = "true" ]] || [[ ! -f "$ANONYMIZE_CWD/freenet/freenet-install.jar" ]]; then
    mkdir -p $ANONYMIZE_CWD/freenet
    wget "$ANONYMIZE_FREENET_JAR" -O "$ANONYMIZE_CWD/freenet/freenet-install.jar"
    [[ -f "$ANONYMIZE_CWD/freenet/freenet-install.jar" ]] || printf_exit "failed to download $ANONYMIZE_FREENET_JAR"
    printf_yellow "Install to $HOME/.local/share/Freenet"
    if [[ "$CONSOLE" = "true" ]]; then
      java -jar "$ANONYMIZE_CWD/freenet/freenet-install.jar" -console
    else
      java -jar "$ANONYMIZE_CWD/freenet/freenet-install.jar"
    fi
  fi
  if [[ -f "$HOME/.local/share/Freenet/run.sh" ]]; then
    eval "$HOME/.local/share/Freenet/run.sh" start &
    sleep 10
  fi
  netstatg 8888 | grep -q java && $BROWSER "http://localhost:8888" || printf_exit "Freenet does not seem to be running"
  exit $?
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
