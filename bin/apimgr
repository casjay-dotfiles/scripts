  __printf_line "apimgr verify                   - Verify default provider"
  __printf_line "apimgr repo get                 - Get current repo (auto-detected from git remote)"
  __printf_line "apimgr repo all --user NAME     - All repos for user NAME"
  __printf_line "apimgr repo all --org NAME      - All repos for org NAME"
  __printf_line "apimgr org all --org NAME       - Same as repo all --org"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Flags"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "--repo USER/REPO                - Target repository (otherwise auto-detected from git remote)"
  __printf_line "--user NAME                     - Target user"
  __printf_line "--org NAME                      - Target org"
  __printf_line "--token TOKEN                   - Auth token override (otherwise from env or ~/.config/secure/apimgr.txt)"
  __printf_line "--official                      - Use the public service for the chosen provider (overrides self-host URL)"
  __printf_line "--title TEXT, --body TEXT       - For create-issue / create-pr"
  __printf_line "--state open|closed|all         - Filter for list operations"
  __printf_line "--limit N                       - Cap result count (default 30)"
  __printf_line "--branch NAME                   - Source branch for `pr create` (the branch the PR is from)"
