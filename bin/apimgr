# set -- "${SET_NEW_ARGS[@]}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Set directory to first argument
# [ -d "$1" ] && __is_an_option "$1" && APIMGR_CWD="$1" && shift 1 || APIMGR_CWD="${APIMGR_CWD:-$PWD}"
APIMGR_CWD="$(realpath "${APIMGR_CWD:-$PWD}" 2>/dev/null)"
# if [ -d "$APIMGR_CWD" ] && cd "$APIMGR_CWD"; then
# if [ "$APIMGR_SILENT" != "true" ] && [ "$CWD_SILENCE" != "true" ]; then
# printf_cyan "Setting working dir to $APIMGR_CWD"
# fi
# else
