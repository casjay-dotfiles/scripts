# - - - - - - - - - - - - - - - - - - - - - - - - -
# Send all output to /dev/null
__devnull() {
  tee &>/dev/null && APIMGR_EXIT_STATUS=0 || APIMGR_EXIT_STATUS=1
  return ${APIMGR_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -'
# Send errors to /dev/null
__devnull2() {
  [ -n "$1" ] && local cmd="$1" && shift 1 || return 1
  eval $cmd "$*" 2>/dev/null && APIMGR_EXIT_STATUS=0 || APIMGR_EXIT_STATUS=1
  return ${APIMGR_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -'
# See if the executable exists
__cmd_exists() {
  APIMGR_EXIT_STATUS=0
  [ -n "$1" ] && local APIMGR_EXIT_STATUS="" || return 0
  for cmd in "$@"; do
    builtin command -v "$cmd" &>/dev/null && APIMGR_EXIT_STATUS+=$(($APIMGR_EXIT_STATUS + 0)) || APIMGR_EXIT_STATUS+=$(($APIMGR_EXIT_STATUS + 1))
  done
  [ $APIMGR_EXIT_STATUS -eq 0 ] || APIMGR_EXIT_STATUS=3
  return ${APIMGR_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for a valid internet connection
__am_i_online() {
  local APIMGR_EXIT_STATUS=0
  curl -q -LSsfI --max-time 1 --retry 0 "${1:-https://1.1.1.1}" 2>&1 | grep -qi 'server:.*cloudflare' || APIMGR_EXIT_STATUS=4
  return ${APIMGR_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# colorization
if [ "$SHOW_RAW" = "true" ]; then
  NC=""
  RESET=""
  BLACK=""
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  PURPLE=""
  CYAN=""
  WHITE=""
  ORANGE=""
  LIGHTRED=""
  BG_GREEN=""
  BG_RED=""
  ICON_INFO="[ info ]"
  ICON_GOOD="[ ok ]"
  ICON_WARN="[ warn ]"
  ICON_ERROR="[ error ]"
  ICON_QUESTION="[ ? ]"
  printf_column() { tee | grep '^'; }
  printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[ 0-9;]*[a-zA-Z],,g'; }
else
  printf_color() { printf "%b" "$(tput setaf "${2:-7}" 2>/dev/null)" "$1" "$(tput sgr0 2>/dev/null)"; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional printf_ colors
__printf_head() { printf_blue "$1"; }
__printf_opts() { printf_purple "$1"; }
__printf_line() { printf_cyan "$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# output version
__version() { printf_cyan "$VERSION"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  printf_color "$1: " "$5"
  echo -ne "$2" | sed 's|:||g;s/'$3'/ '$4'/g' | tr '\n' ' '
  printf_newline
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# create the config file
__gen_config() {
  local NOTIFY_CLIENT_NAME="$APPNAME"
  if [ "$INIT_CONFIG" != "TRUE" ]; then
    printf_blue "Generating the config file in"
    printf_cyan "$APIMGR_CONFIG_DIR/$APIMGR_CONFIG_FILE"
  fi
  [ -d "$APIMGR_CONFIG_DIR" ] || mkdir -p "$APIMGR_CONFIG_DIR"
  [ -d "$APIMGR_CONFIG_BACKUP_DIR" ] || mkdir -p "$APIMGR_CONFIG_BACKUP_DIR"
  [ -f "$APIMGR_CONFIG_DIR/$APIMGR_CONFIG_FILE" ] &&
    cp -Rf "$APIMGR_CONFIG_DIR/$APIMGR_CONFIG_FILE" "$APIMGR_CONFIG_BACKUP_DIR/$APIMGR_CONFIG_FILE.$$"
  cat <<EOF >"$APIMGR_CONFIG_DIR/$APIMGR_CONFIG_FILE"
# Settings for apimgr — multi-provider API client.
# Tokens belong in ~/.config/secure/apimgr.txt (mode 0600), which is sourced before this file.
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Default provider when no provider is given and git-remote auto-detect fails.
APIMGR_DEFAULT_PROVIDER="${APIMGR_DEFAULT_PROVIDER:-github}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# URLs and tokens are NOT set here — apimgr maps them at runtime from your existing env vars (see below).
# Resolver precedence per provider:
#   URL (default mode):  APIMGR_<P>_URL  →  <P>_API_URL          (e.g. GITHUB_API_URL, GITLAB_API_URL)
#   URL (--official):    APIMGR_<P>_OFFICIAL_URL  →  <P>_OFFICIAL_API_URL  →  default-mode chain
#   Token:               --token  →  APIMGR_<P>_TOKEN  →  <P>_ACCESS_TOKEN  →  <P>_TOKEN  (DOCKER also tries DOCKER_HUB_API_KEY)
#   Username:            APIMGR_<P>_USERNAME  →  <P>_USERNAME    (e.g. GITHUB_USERNAME)
#
# Set the *_URL/*_TOKEN env vars in your shell rc (or ~/.config/secure/apimgr.txt) — apimgr never hardcodes endpoints.
# Override per-invocation with --token, --official, or APIMGR_<P>_* in this file.
# - - - - - - - - - - - - - - - - - - - - - - - - -
# HTTP behavior
APIMGR_API_TIMEOUT="${APIMGR_API_TIMEOUT:-10}"
APIMGR_API_RETRY="${APIMGR_API_RETRY:-1}"
APIMGR_DEFAULT_LIMIT="${APIMGR_DEFAULT_LIMIT:-30}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
APIMGR_OUTPUT_COLOR_1="${APIMGR_OUTPUT_COLOR_1:-33}"
APIMGR_OUTPUT_COLOR_2="${APIMGR_OUTPUT_COLOR_2:-5}"
APIMGR_OUTPUT_COLOR_GOOD="${APIMGR_OUTPUT_COLOR_GOOD:-2}"
APIMGR_OUTPUT_COLOR_ERROR="${APIMGR_OUTPUT_COLOR_ERROR:-1}"

EOF
  if builtin type -t __gen_config_local | grep -q 'function'; then __gen_config_local; fi
  if [ -f "$APIMGR_CONFIG_DIR/$APIMGR_CONFIG_FILE" ]; then
    [ "$INIT_CONFIG" = "TRUE" ] || printf_green "Your config file for $APPNAME has been created"
    . "$APIMGR_CONFIG_DIR/$APIMGR_CONFIG_FILE"
    APIMGR_EXIT_STATUS=0
  else
    printf_red "Failed to create the config file"
    APIMGR_EXIT_STATUS=1
  fi
  return ${APIMGR_EXIT_STATUS:-0}
}
