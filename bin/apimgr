# - - - - - - - - - - - - - - - - - - - - - - - - -
__grep() { grep "$@" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# check if arg is a builtin option
__is_an_option() { if [[ "$ARRAY" == *"${1:-^}"* ]]; then return 1; else return 0; fi; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  if { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; }; then return 1; else return 0; fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -sh "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$APIMGR_REQUIRE_SUDO" = "yes" ] && [ -z "$APIMGR_REQUIRE_SUDO_RUN" ]; then
    export APIMGR_REQUIRE_SUDO="no"
    export APIMGR_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "${SUDO##*/}" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    APIMGR_EXIT_STATUS=$?
  else
    printf '%s\n' "This requires root to run"
    APIMGR_EXIT_STATUS=1
  fi
  return ${APIMGR_EXIT_STATUS:-0}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - -
__how_long_did_it_take() {
  local retprev=$?
  local retval=${1:-$retprev}
  __cmd_exists bc || return $retval
  [ -n "$APIMGR_START_TIMER" ] || return 0
  local stop_time="$(date +%s.%N)"
  local dt=$(echo "$stop_time - $APIMGR_START_TIMER" | bc)
  local dd=$(echo "$dt/86400" | bc)
  local dt2=$(echo "$dt-86400*$dd" | bc)
  local dh=$(echo "$dt2/3600" | bc)
  local dt3=$(echo "$dt2-3600*$dh" | bc)
  local dm=$(echo "$dt3/60" | bc)
  local ds=$(echo "$dt3-60*$dm" | bc)
  printf_purple "$(LC_NUMERIC=C printf "Total runtime: %d Days, %02d Hours, %02d Minutes, %02.4f Seconds\n" $dd $dh $dm $ds)"
  return $retval
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit_apimgr() {
  APIMGR_EXIT_STATUS=${APIMGR_EXIT_STATUS:-0}
  [ -f "$APIMGR_TEMP_FILE" ] && rm -Rf "$APIMGR_TEMP_FILE" &>/dev/null
  #unset CASJAYSDEV_TITLE_SET && printf '\033]2│;%s\033\\' "${USER}@${HOSTNAME}:${PWD/#$HOME/~} - ${CASJAYSDEV_TITLE_PREV:-$SHELL}"
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $APIMGR_EXIT_STATUS
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Create a --no-* options function
__options_function_no() {
  local options="${1//=*/}"
  local argument="${1//*=/}"
  case "$options" in
  *) echo "${argument:-No argument provided}" && shift ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Create a --yes-* options function
__options_function_yes() {
  local options="${1//=*/}"
  local argument="${1//*=/}"
  case "$options" in
  *) echo "${argument:-No argument provided}" && shift ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
__notifications() {
  __cmd_exists notifications || return
  [ "$APIMGR_SYSTEM_NOTIFY_ENABLED" = "yes" ] || return
  [ "$SEND_NOTIFICATION" = "no" ] && return
  (
    export SCRIPT_OPTS="" _DEBUG=""
    export NOTIFY_GOOD_MESSAGE="${NOTIFY_GOOD_MESSAGE:-$APIMGR_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${NOTIFY_ERROR_MESSAGE:-$APIMGR_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$APIMGR_NOTIFY_CLIENT_ICON}"
    export NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APIMGR_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_URGENCY="${NOTIFY_CLIENT_URGENCY:-$APIMGR_NOTIFY_CLIENT_URGENCY}"
    notifications "$@"
  ) |& __devnull &
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__notify_remote() {
  local cmd="${APIMGR_REMOTE_NOTIFY_COMMAND%% *}"
  if [ "$APIMGR_REMOTE_NOTIFY_ENABLED" = "yes" ]; then
    if [ -n "$(command -v "$cmd")" ]; then
      eval $APIMGR_REMOTE_NOTIFY_COMMAND "$@"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap '__trap_exit_apimgr' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - -
# start timer
APIMGR_START_TIMER="${APIMGR_START_TIMER:-$(date +%s.%N)}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Source per-user token file if present (mode 0600 recommended). Sourced BEFORE settings.conf so settings can override.
[ -f "$HOME/.config/secure/apimgr.txt" ] && . "$HOME/.config/secure/apimgr.txt"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Print message + exit. Uniform error path so callers don't repeat the printf-then-exit pattern.
__apimgr_die() { printf_red "$1" >&2; exit "${2:-1}"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# jq wrapper — silences errors so callers can pipe and check rc without polluting stderr.
__apimgr_jq() { jq "$@" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Base curl wrapper. Single source of truth for timeouts/retries; every API call goes through this.
__apimgr_curl() { curl -q -LSsf --max-time "${APIMGR_API_TIMEOUT:-10}" --retry "${APIMGR_API_RETRY:-1}" "$@"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Provider URL resolver. Pure env-var mapping; nothing is hardcoded. Precedence:
#   default mode:  APIMGR_<P>_URL  →  <P>_API_URL                    (these are your self-host/primary)
#   --official:    APIMGR_<P>_OFFICIAL_URL  →  <P>_OFFICIAL_API_URL  →  default-mode chain
# So if you only have <P>_API_URL set, both modes use it. Add <P>_OFFICIAL_API_URL only when you want them to differ.
__apimgr_provider_url() {
  local provider="${1^^}" url=""
  if [ "$APIMGR_OFFICIAL" = "true" ]; then
    eval "url=\${APIMGR_${provider}_OFFICIAL_URL:-}"
    [ -n "$url" ] || eval "url=\${${provider}_OFFICIAL_API_URL:-}"
  fi
  [ -n "$url" ] || eval "url=\${APIMGR_${provider}_URL:-}"
  [ -n "$url" ] || eval "url=\${${provider}_API_URL:-}"
  [ -n "$url" ] || return 1
  printf '%s' "${url%/}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Provider token resolver. --token <T> wins, then APIMGR_<P>_TOKEN, then user's <P>_ACCESS_TOKEN, then <P>_TOKEN.
# Docker is special-cased because the user's env uses DOCKER_HUB_API_KEY (not DOCKER_ACCESS_TOKEN).
__apimgr_provider_token() {
  local provider="${1^^}" token=""
  if [ -n "$APIMGR_TOKEN_OVERRIDE" ]; then
    printf '%s' "$APIMGR_TOKEN_OVERRIDE"
    return 0
  fi
  eval "token=\${APIMGR_${provider}_TOKEN:-}"
  [ -n "$token" ] || eval "token=\${${provider}_ACCESS_TOKEN:-}"
  [ -n "$token" ] || eval "token=\${${provider}_TOKEN:-}"
  if [ -z "$token" ] && [ "$provider" = "DOCKER" ]; then token="${DOCKER_HUB_API_KEY:-}"; fi
  if [ -z "$token" ] && [ "$provider" = "CLOUDSMITH" ]; then token="${CLOUDSMITH_API_KEY:-}"; fi
  [ -n "$token" ] || return 1
  printf '%s' "$token"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Default-username resolver. For listing self repos and similar, falls back to <P>_USERNAME (e.g. GITHUB_USERNAME).
__apimgr_provider_username() {
  local provider="${1^^}" name=""
  eval "name=\${APIMGR_${provider}_USERNAME:-}"
  [ -n "$name" ] || eval "name=\${${provider}_USERNAME:-}"
  [ -n "$name" ] || return 1
  printf '%s' "$name"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Refuses to make a call when creds aren't set. Returns 0 if both URL and token resolve, 1 otherwise.
__apimgr_require_creds() {
  local provider="$1" P="${1^^}"
  __apimgr_provider_url "$provider" >/dev/null \
    || __apimgr_die "No URL for '$provider' — set ${P}_API_URL or APIMGR_${P}_URL (use --official with ${P}_OFFICIAL_API_URL)"
  __apimgr_provider_token "$provider" >/dev/null \
    || __apimgr_die "No token for '$provider' — set ${P}_ACCESS_TOKEN, APIMGR_${P}_TOKEN, pass --token, or add it to ~/.config/secure/apimgr.txt"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Parse a git remote URL and emit "<provider> <user/repo>". Recognizes github/gitlab/codeberg by hostname,
# any *.gitea.* / *.forgejo.* by substring, and a self-host fallback to APIMGR_GIT_HOST_<host>_PROVIDER mapping.
__apimgr_detect_provider_from_git() {
  local cwd="${1:-$PWD}" remote_url provider="" repo=""
  remote_url="$(git -C "$cwd" remote get-url origin 2>/dev/null)" || return 1
  [ -n "$remote_url" ] || return 1
  case "$remote_url" in
    *github.com*)        provider="github"   ;;
    *gitlab.com*)        provider="gitlab"   ;;
    *codeberg.org*)      provider="codeberg" ;;
    *bitbucket.org*)     provider="bitbucket";;
    *gitee.com*)         provider="gitee"    ;;
    *pagure.io*)         provider="pagure"   ;;
    *sr.ht*|*sourcehut*) provider="sourcehut";;
    *gitea*)             provider="gitea"    ;;
    *forgejo*)           provider="forgejo"  ;;
    *)
      # Self-host hostname lookup: APIMGR_GIT_HOST_git_example_com_PROVIDER=gitea (dots → underscores).
      local host="${remote_url#*://}"; host="${host%%/*}"; host="${host#*@}"; host="${host%%:*}"
      local var="APIMGR_GIT_HOST_${host//./_}_PROVIDER"
      eval "provider=\${$var:-}"
      ;;
  esac
  [ -n "$provider" ] || return 1
  # Normalize remote into "user/repo": strip protocol, host, leading slash, trailing .git.
  repo="${remote_url##*[:/]*[!/:]/}"
  repo="${remote_url#*://*/}"
  repo="${repo#*:}"
  repo="${repo%.git}"
  printf '%s %s' "$provider" "$repo"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Resolve target repo from --repo flag or git-remote of cwd. Sets APIMGR_REPO and APIMGR_PROVIDER.
__apimgr_resolve_repo() {
  if [ -n "$APIMGR_REPO" ]; then return 0; fi
  local detect provider repo
  detect="$(__apimgr_detect_provider_from_git "$APIMGR_CWD")" || return 1
  provider="${detect%% *}"; repo="${detect##* }"
  APIMGR_PROVIDER="${APIMGR_PROVIDER:-$provider}"
  APIMGR_REPO="$repo"
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Resolve provider — explicit arg wins, then --provider flag, then auto-detect from git, then APIMGR_DEFAULT_PROVIDER.
__apimgr_resolve_provider() {
  local explicit="$1"
  if [ -n "$explicit" ]; then APIMGR_PROVIDER="$explicit"; return 0; fi
  if [ -n "$APIMGR_PROVIDER" ]; then return 0; fi
  local detect; detect="$(__apimgr_detect_provider_from_git "$APIMGR_CWD")" 2>/dev/null
  if [ -n "$detect" ]; then APIMGR_PROVIDER="${detect%% *}"; return 0; fi
  APIMGR_PROVIDER="${APIMGR_DEFAULT_PROVIDER:-github}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a list of repo JSON blobs as "name | description | private" rows. Used by every git provider.
__apimgr_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.full_name // .name)\t\(.description // "")\t\(.private // false)"' |
    awk -F'\t' 'BEGIN{OFS=" │ "} {printf "%-45s %-50s %s\n", $1, substr($2,1,48), ($3=="true"?"private":"public")}'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a single repo JSON blob (for `repo get`).
__apimgr_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.full_name // .name)",
    "URL:         \(.html_url // .web_url // .clone_url // "")",
    "Description: \(.description // "")",
    "Visibility:  \(if (.private // false) then "private" else "public" end)",
    "Default:     \(.default_branch // "")",
    "Stars:       \(.stargazers_count // .star_count // 0)",
    "Forks:       \(.forks_count // .forks // 0)",
    "Issues:      \(.open_issues_count // 0)"
  '
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print an issue list. Works for github/gitea (uses .number, .user.login) and gitlab (.iid, .author.username).
__apimgr_print_issue_list() {
  __apimgr_jq -r '.[] | "#\(.number // .iid)\t\(.state)\t\(.user.login // .author.username // "")\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-8s %-20s %s\n", $1, $2, substr($3,1,20), $4}'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a single issue (for `issue get`).
__apimgr_print_issue() {
  __apimgr_jq -r '
    "Number:  #\(.number // .iid)",
    "Title:   \(.title)",
    "State:   \(.state)",
    "Author:  \(.user.login // .author.username // "")",
    "URL:     \(.html_url // .web_url // "")",
    "Created: \(.created_at)",
    "",
    "\(.body // .description // "")"
  '
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Translate apimgr's --state values to provider-specific state names. github/gitea use open|closed|all;
# gitlab uses opened|closed|merged|all; bitbucket-PRs use UPPERCASE (OPEN|MERGED|DECLINED|SUPERSEDED);
# bitbucket-issues use a wholly different vocabulary so we fall through to pass-through there.
# The optional second arg ("issue"|"pr") lets the caller hint which surface they're targeting since
# bitbucket diverges between the two; default is "pr".
__apimgr_state_for() {
  local provider="$1" surface="${2:-pr}" state="${APIMGR_STATE:-open}"
  case "$provider" in
    gitlab)
      case "$state" in open) printf 'opened' ;; closed) printf 'closed' ;; merged) printf 'merged' ;; all) printf 'all' ;; *) printf '%s' "$state" ;; esac ;;
    bitbucket)
      if [ "$surface" = "pr" ]; then
        case "$state" in
          open) printf 'OPEN' ;; closed) printf 'DECLINED' ;; merged) printf 'MERGED' ;;
          all) printf 'OPEN,MERGED,DECLINED,SUPERSEDED' ;; *) printf '%s' "$state" ;;
        esac
      else
        # Bitbucket issues: new/open/resolved/closed/invalid/duplicate/wontfix/on hold. Pass through.
        case "$state" in all) printf '' ;; *) printf '%s' "$state" ;; esac
      fi ;;
    *) printf '%s' "$state" ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a PR list. Schema-tolerant: github/gitea use .number / .head.ref / .base.ref / .user.login;
# gitlab uses .iid / .source_branch / .target_branch / .author.username.
__apimgr_print_pr_list() {
  __apimgr_jq -r '.[] | "#\(.number // .iid)\t\(.state)\t\(.user.login // .author.username // "")\t\(.head.ref // .source_branch)→\(.base.ref // .target_branch)\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-8s %-18s %-30s %s\n", $1, $2, substr($3,1,18), substr($4,1,30), $5}'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a single PR (for `pr get`).
__apimgr_print_pr() {
  __apimgr_jq -r '
    "Number:    #\(.number // .iid)",
    "Title:     \(.title)",
    "State:     \(.state)\(if (.merged // false) then " (merged)" else "" end)",
    "Author:    \(.user.login // .author.username // "")",
    "Branches:  \(.head.ref // .source_branch) → \(.base.ref // .target_branch)",
    "Mergeable: \(.mergeable // .merge_status // "unknown")",
    "URL:       \(.html_url // .web_url // "")",
    "Created:   \(.created_at)",
    "",
    "\(.body // .description // "")"
  '
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a release list. github/gitea use .tag_name + .name + .draft + .prerelease;
# gitlab uses .tag_name + .name + .upcoming_release. Single jq filter handles both.
__apimgr_print_release_list() {
  __apimgr_jq -r '.[] | "\(.tag_name)\t\(.name // .tag_name)\t\(if (.draft // false) then "draft" elif (.prerelease // false) then "prerelease" else "release" end)\t\(.published_at // .released_at // .created_at // "")"' |
    awk -F'\t' '{printf "%-20s %-40s %-12s %s\n", $1, substr($2,1,40), $3, substr($4,1,10)}'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a git-tag list (forges only — registries have their own __<provider>_print_tag_list).
# Schema-tolerant: github (.commit.sha), gitlab (.target/.commit.id), gitea (.id/.commit.sha), bitbucket (.target.hash).
__apimgr_print_git_tag_list() {
  __apimgr_jq -r '.[] | "\(.name)\t\(.commit.sha // .target // .id // .target.hash // "")\t\(.message // "")"' |
    awk -F'\t' '{printf "%-30s %-12s %s\n", $1, substr($2,1,12), substr($3,1,60)}'
}
# Pretty-print a single release (for `release get`).
__apimgr_print_release() {
  __apimgr_jq -r '
    "Tag:       \(.tag_name)",
    "Name:      \(.name // .tag_name)",
    "Type:      \(if (.draft // false) then "draft" elif (.prerelease // false) then "prerelease" else "release" end)",
    "Author:    \(.author.login // .author.username // "")",
    "Target:    \(.target_commitish // .commit.id // "")",
    "URL:       \(.html_url // ._links.self // "")",
    "Published: \(.published_at // .released_at // .created_at // "")",
    "",
    "\(.body // .description // "")"
  '
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Confirmation prompt for destructive ops. Honors --force. Returns 0 if confirmed, 1 otherwise.
__apimgr_confirm() {
  local prompt="$1" reply
  if [ "$APIMGR_FORCE_INSTALL" = "true" ]; then return 0; fi
  if [ ! -t 0 ]; then __apimgr_die "Refusing destructive op in non-interactive mode without --force"; fi
  printf_yellow "$prompt [y/N] "
  read -r reply
  case "$reply" in [yY]|[yY][eE][sS]) return 0 ;; *) return 1 ;; esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== GitHub provider (api.github.com or GitHub Enterprise) ==============
__github_curl() {
  local token; token="$(__apimgr_provider_token github)" || return 1
  __apimgr_curl -H "Authorization: Bearer $token" -H "Accept: application/vnd.github+json" -H "X-GitHub-Api-Version: 2022-11-28" "$@"
}
__github_api()  { local base; base="$(__apimgr_provider_url github)" || return 1; __github_curl -X "${1:-GET}" "$base$2"; }
__github_post() { local base; base="$(__apimgr_provider_url github)" || return 1; __github_curl -X "${1:-POST}" --data "$3" "$base$2"; }

__github_verify() {
  __apimgr_require_creds github
  local resp; resp="$(__github_api GET /user)" || __apimgr_die "GitHub /user call failed"
  __apimgr_jq -r '"Authenticated as \(.login) (\(.name // "no name")) — \(.html_url)"' <<<"$resp"
}
__github_user_get() {
  __apimgr_require_creds github
  local who="${APIMGR_USER:-}" path
  if [ -n "$who" ]; then path="/users/$who"; else path="/user"; fi
  __github_api GET "$path" | __apimgr_jq .
}
__github_org_get() {
  __apimgr_require_creds github
  [ -n "$APIMGR_ORG" ] || __apimgr_die "github org get: --org NAME required"
  __github_api GET "/orgs/$APIMGR_ORG" | __apimgr_jq .
}
__github_org_all() {
  __apimgr_require_creds github
  [ -n "$APIMGR_ORG" ] || __apimgr_die "github org all: --org NAME required"
  __github_api GET "/orgs/$APIMGR_ORG/repos?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_repo_list
}
__github_repo_list() {
  __apimgr_require_creds github
  local path="/user/repos?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  if [ -n "$APIMGR_USER" ]; then path="/users/$APIMGR_USER/repos?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"; fi
  __github_api GET "$path" | __apimgr_print_repo_list
}
__github_repo_get() {
  __apimgr_require_creds github
  __apimgr_resolve_repo || __apimgr_die "github repo get: --repo USER/REPO required (not in a git repo with a recognized remote)"
  __github_api GET "/repos/$APIMGR_REPO" | __apimgr_print_repo
}
__github_repo_create() {
  __apimgr_require_creds github
  local name="${APIMGR_REPO##*/}" owner="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$owner" ] && [ "$owner" != "$name" ] || __apimgr_die "github repo create: --repo OWNER/NAME required"
  local visibility="${APIMGR_VISIBILITY:-public}" privflag="false"
  [ "$visibility" = "private" ] && privflag="true"
  local payload; payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --argjson p "$privflag" '{name:$n, description:$d, private:$p}')"
  # /user/repos creates under the authed user; /orgs/<owner>/repos creates under an org.
  local me; me="$(__github_api GET /user | __apimgr_jq -r '.login')"
  if [ "$owner" = "$me" ]; then
    __github_post POST "/user/repos" "$payload" | __apimgr_print_repo
  else
    __github_post POST "/orgs/$owner/repos" "$payload" | __apimgr_print_repo
  fi
}
__github_repo_delete() {
  __apimgr_require_creds github
  __apimgr_resolve_repo || __apimgr_die "github repo delete: --repo USER/REPO required"
  __apimgr_confirm "Delete $APIMGR_REPO from GitHub? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __github_api DELETE "/repos/$APIMGR_REPO" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__github_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __github_org_all; else __github_repo_list; fi
}
# Helper: every issue action needs the OWNER/REPO either from --repo or git auto-detect.
__github_issue_repo() {
  __apimgr_resolve_repo || __apimgr_die "github issue: --repo USER/REPO required (or run inside the repo's worktree)"
}
__github_issue_list() {
  __apimgr_require_creds github
  __github_issue_repo
  local state; state="$(__apimgr_state_for github)"
  __github_api GET "/repos/$APIMGR_REPO/issues?state=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" |
    __apimgr_jq '[.[] | select(.pull_request | not)]' |
    __apimgr_print_issue_list
}
__github_issue_get() {
  local n="$1"
  __apimgr_require_creds github
  __github_issue_repo
  [ -n "$n" ] || __apimgr_die "github issue get: issue NUMBER required (e.g. apimgr github issue get 42)"
  __github_api GET "/repos/$APIMGR_REPO/issues/$n" | __apimgr_print_issue
}
__github_issue_create() {
  __apimgr_require_creds github
  __github_issue_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "github issue create: --title required"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" '{title:$t, body:$b}')"
  __github_post POST "/repos/$APIMGR_REPO/issues" "$payload" | __apimgr_jq -r '"Created issue #\(.number) — \(.html_url)"'
}
__github_issue_close() {
  local n="$1"
  __apimgr_require_creds github
  __github_issue_repo
  [ -n "$n" ] || __apimgr_die "github issue close: issue NUMBER required"
  __github_post PATCH "/repos/$APIMGR_REPO/issues/$n" '{"state":"closed"}' | __apimgr_jq -r '"Closed issue #\(.number) — \(.html_url)"'
}
__github_issue_comment() {
  local n="$1"
  __apimgr_require_creds github
  __github_issue_repo
  [ -n "$n" ] || __apimgr_die "github issue comment: issue NUMBER required"
  [ -n "$APIMGR_BODY" ] || __apimgr_die "github issue comment: --body required"
  local payload; payload="$(__apimgr_jq -n --arg b "$APIMGR_BODY" '{body:$b}')"
  __github_post POST "/repos/$APIMGR_REPO/issues/$n/comments" "$payload" | __apimgr_jq -r '"Commented on issue #'"$n"' — \(.html_url)"'
}
# Default base branch — read from the repo's metadata. Tiny GET, but cached per-invocation in APIMGR_BASE_RESOLVED
# so a `pr create` doesn't pay for it twice. Honors --base if the user passed one.
__github_resolve_base() {
  if [ -n "$APIMGR_BASE" ]; then printf '%s' "$APIMGR_BASE"; return 0; fi
  if [ -n "$APIMGR_BASE_RESOLVED" ]; then printf '%s' "$APIMGR_BASE_RESOLVED"; return 0; fi
  APIMGR_BASE_RESOLVED="$(__github_api GET "/repos/$APIMGR_REPO" | __apimgr_jq -r '.default_branch // "main"')"
  printf '%s' "$APIMGR_BASE_RESOLVED"
}
__github_pr_repo() {
  __apimgr_resolve_repo || __apimgr_die "github pr: --repo USER/REPO required (or run inside the repo's worktree)"
}
__github_pr_list() {
  __apimgr_require_creds github
  __github_pr_repo
  local state; state="$(__apimgr_state_for github)"
  __github_api GET "/repos/$APIMGR_REPO/pulls?state=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_pr_list
}
__github_pr_get() {
  local n="$1"
  __apimgr_require_creds github
  __github_pr_repo
  [ -n "$n" ] || __apimgr_die "github pr get: PR NUMBER required (e.g. apimgr github pr get 42)"
  __github_api GET "/repos/$APIMGR_REPO/pulls/$n" | __apimgr_print_pr
}
__github_pr_create() {
  __apimgr_require_creds github
  __github_pr_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "github pr create: --title required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "github pr create: --branch SOURCE required (the branch the PR is from)"
  local base; base="$(__github_resolve_base)"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" --arg h "$APIMGR_BRANCH" --arg ba "$base" '{title:$t, body:$b, head:$h, base:$ba}')"
  __github_post POST "/repos/$APIMGR_REPO/pulls" "$payload" | __apimgr_jq -r '"Created PR #\(.number) (\(.head.ref) → \(.base.ref)) — \(.html_url)"'
}
__github_pr_merge() {
  local n="$1"
  __apimgr_require_creds github
  __github_pr_repo
  [ -n "$n" ] || __apimgr_die "github pr merge: PR NUMBER required"
  __apimgr_confirm "Merge PR #$n in $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __github_post PUT "/repos/$APIMGR_REPO/pulls/$n/merge" '{}' | __apimgr_jq -r 'if .merged then "Merged PR #'"$n"' — \(.sha[0:7])" else "Merge refused: \(.message // "unknown")" end'
}
__github_pr_close() {
  local n="$1"
  __apimgr_require_creds github
  __github_pr_repo
  [ -n "$n" ] || __apimgr_die "github pr close: PR NUMBER required"
  __github_post PATCH "/repos/$APIMGR_REPO/pulls/$n" '{"state":"closed"}' | __apimgr_jq -r '"Closed PR #\(.number) — \(.html_url)"'
}
# Release actions for github. `get` accepts either a numeric id or a tag name (resolved via /releases/tags/X).
__github_release_repo() { __apimgr_resolve_repo || __apimgr_die "github release: --repo USER/REPO required"; }
__github_release_list() {
  __apimgr_require_creds github
  __github_release_repo
  __github_api GET "/repos/$APIMGR_REPO/releases?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_release_list
}
__github_release_get() {
  local key="$1"
  __apimgr_require_creds github
  __github_release_repo
  [ -n "$key" ] || __apimgr_die "github release get: TAG or ID required (e.g. apimgr github release get v1.0.0)"
  # Numeric → /releases/<id>; otherwise treat as a tag name.
  case "$key" in
    [0-9]*) __github_api GET "/repos/$APIMGR_REPO/releases/$key" | __apimgr_print_release ;;
    *)      __github_api GET "/repos/$APIMGR_REPO/releases/tags/$key" | __apimgr_print_release ;;
  esac
}
__github_release_create() {
  __apimgr_require_creds github
  __github_release_repo
  [ -n "$APIMGR_TAG" ] || __apimgr_die "github release create: --tag NAME required (the git tag this release points to)"
  local payload; payload="$(__apimgr_jq -n \
    --arg tag "$APIMGR_TAG" \
    --arg name "${APIMGR_TITLE:-$APIMGR_TAG}" \
    --arg body "${APIMGR_BODY:-}" \
    --arg target "${APIMGR_BRANCH:-}" \
    '{tag_name:$tag, name:$name, body:$body} + (if $target == "" then {} else {target_commitish:$target} end)')"
  __github_post POST "/repos/$APIMGR_REPO/releases" "$payload" | __apimgr_jq -r '"Created release \(.tag_name) — \(.html_url)"'
}
__github_release_delete() {
  local key="$1"
  __apimgr_require_creds github
  __github_release_repo
  [ -n "$key" ] || __apimgr_die "github release delete: TAG or ID required"
  __apimgr_confirm "Delete release '$key' from $APIMGR_REPO? (Note: the underlying git tag is NOT removed.)" || { printf_yellow "Aborted"; return 1; }
  # GitHub's DELETE only takes numeric id; resolve the tag first if needed.
  local id="$key"
  case "$key" in
    [0-9]*) ;;
    *)      id="$(__github_api GET "/repos/$APIMGR_REPO/releases/tags/$key" | __apimgr_jq -r '.id // empty')"
            [ -n "$id" ] || __apimgr_die "github release delete: tag '$key' not found" ;;
  esac
  __github_api DELETE "/repos/$APIMGR_REPO/releases/$id" >/dev/null && printf_green "Deleted release '$key' from $APIMGR_REPO"
}
# Git-tag actions for github. GitHub has no direct "create tag" endpoint — go through the lower-level git-refs API.
__github_tag_repo() { __apimgr_resolve_repo || __apimgr_die "github tag: --repo USER/REPO required"; }
__github_tag_list() {
  __apimgr_require_creds github
  __github_tag_repo
  __github_api GET "/repos/$APIMGR_REPO/tags?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_git_tag_list
}
__github_tag_get() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds github
  __github_tag_repo
  [ -n "$tag" ] || __apimgr_die "github tag get: --tag NAME or positional TAG required"
  __github_api GET "/repos/$APIMGR_REPO/git/ref/tags/$tag" | __apimgr_jq .
}
__github_tag_create() {
  __apimgr_require_creds github
  __github_tag_repo
  [ -n "$APIMGR_TAG" ] || __apimgr_die "github tag create: --tag NAME required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "github tag create: --branch SHA-or-branch required (the commit/branch to point the tag at)"
  # If --branch isn't a 40-char hex sha, look it up as a head ref.
  local sha="$APIMGR_BRANCH"
  case "$sha" in
    [a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9][a-f0-9]) ;;
    *) sha="$(__github_api GET "/repos/$APIMGR_REPO/git/ref/heads/$APIMGR_BRANCH" | __apimgr_jq -r '.object.sha // empty')"
       [ -n "$sha" ] || __apimgr_die "github tag create: branch '$APIMGR_BRANCH' not found in $APIMGR_REPO" ;;
  esac
  local payload; payload="$(__apimgr_jq -n --arg ref "refs/tags/$APIMGR_TAG" --arg sha "$sha" '{ref:$ref, sha:$sha}')"
  __github_post POST "/repos/$APIMGR_REPO/git/refs" "$payload" | __apimgr_jq -r '"Created tag \(.ref) → \(.object.sha[0:7])"'
}
__github_tag_delete() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds github
  __github_tag_repo
  [ -n "$tag" ] || __apimgr_die "github tag delete: --tag NAME or positional TAG required"
  __apimgr_confirm "Delete tag '$tag' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __github_api DELETE "/repos/$APIMGR_REPO/git/refs/tags/$tag" >/dev/null && printf_green "Deleted tag '$tag' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Gitea provider (covers Forgejo, Codeberg — same API surface) ==============
# Each subprovider gets its own URL/token resolution but shares the action implementation via __gitea_*.
__gitea_curl() {
  local provider="${1:-gitea}"; shift
  local token; token="$(__apimgr_provider_token "$provider")" || return 1
  __apimgr_curl -H "Authorization: token $token" -H "Accept: application/json" "$@"
}
__gitea_api() {
  local provider="$1" method="$2" path="$3" data="$4"
  local base; base="$(__apimgr_provider_url "$provider")" || return 1
  if [ -n "$data" ]; then
    __gitea_curl "$provider" -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __gitea_curl "$provider" -X "$method" "$base$path"
  fi
}
__gitea_verify() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  local resp; resp="$(__gitea_api "$provider" GET /user)" || __apimgr_die "$provider /user call failed"
  __apimgr_jq -r '"Authenticated as \(.login) (\(.full_name // "no name")) — \(.html_url // "")"' <<<"$resp"
}
__gitea_user_get() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  local who="${APIMGR_USER:-}" path
  if [ -n "$who" ]; then path="/users/$who"; else path="/user"; fi
  __gitea_api "$provider" GET "$path" | __apimgr_jq .
}
__gitea_org_get() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  [ -n "$APIMGR_ORG" ] || __apimgr_die "$provider org get: --org NAME required"
  __gitea_api "$provider" GET "/orgs/$APIMGR_ORG" | __apimgr_jq .
}
__gitea_org_all() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  [ -n "$APIMGR_ORG" ] || __apimgr_die "$provider org all: --org NAME required"
  __gitea_api "$provider" GET "/orgs/$APIMGR_ORG/repos?limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_repo_list
}
__gitea_repo_list() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  local path="/repos/search?limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  [ -n "$APIMGR_USER" ] && path="/users/$APIMGR_USER/repos?limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  __gitea_api "$provider" GET "$path" | __apimgr_jq '.data // .' | __apimgr_print_repo_list
}
__gitea_repo_get() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __apimgr_resolve_repo || __apimgr_die "$provider repo get: --repo USER/REPO required"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO" | __apimgr_print_repo
}
__gitea_repo_create() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  local name="${APIMGR_REPO##*/}" owner="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$owner" ] && [ "$owner" != "$name" ] || __apimgr_die "$provider repo create: --repo OWNER/NAME required"
  local visibility="${APIMGR_VISIBILITY:-public}" privflag="false"
  [ "$visibility" = "private" ] && privflag="true"
  local payload; payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --argjson p "$privflag" '{name:$n, description:$d, private:$p, auto_init:true}')"
  local me; me="$(__gitea_api "$provider" GET /user | __apimgr_jq -r '.login')"
  if [ "$owner" = "$me" ]; then
    __gitea_api "$provider" POST "/user/repos" "$payload" | __apimgr_print_repo
  else
    __gitea_api "$provider" POST "/orgs/$owner/repos" "$payload" | __apimgr_print_repo
  fi
}
__gitea_repo_delete() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __apimgr_resolve_repo || __apimgr_die "$provider repo delete: --repo USER/REPO required"
  __apimgr_confirm "Delete $APIMGR_REPO from $provider? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __gitea_api "$provider" DELETE "/repos/$APIMGR_REPO" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__gitea_repo_all() {
  local provider="$1"
  if [ -n "$APIMGR_ORG" ]; then __gitea_org_all "$provider"; else __gitea_repo_list "$provider"; fi
}
# Issue actions for gitea-family. Same paths as github, just different auth header (handled in __gitea_curl).
__gitea_issue_repo() {
  local provider="$1"
  __apimgr_resolve_repo || __apimgr_die "$provider issue: --repo USER/REPO required"
}
__gitea_issue_list() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_issue_repo "$provider"
  local state; state="$(__apimgr_state_for "$provider")"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/issues?state=$state&type=issues&limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" |
    __apimgr_print_issue_list
}
__gitea_issue_get() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_issue_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider issue get: issue NUMBER required"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/issues/$n" | __apimgr_print_issue
}
__gitea_issue_create() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_issue_repo "$provider"
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "$provider issue create: --title required"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" '{title:$t, body:$b}')"
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/issues" "$payload" | __apimgr_jq -r '"Created issue #\(.number) — \(.html_url)"'
}
__gitea_issue_close() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_issue_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider issue close: issue NUMBER required"
  __gitea_api "$provider" PATCH "/repos/$APIMGR_REPO/issues/$n" '{"state":"closed"}' | __apimgr_jq -r '"Closed issue #\(.number) — \(.html_url)"'
}
__gitea_issue_comment() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_issue_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider issue comment: issue NUMBER required"
  [ -n "$APIMGR_BODY" ] || __apimgr_die "$provider issue comment: --body required"
  local payload; payload="$(__apimgr_jq -n --arg b "$APIMGR_BODY" '{body:$b}')"
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/issues/$n/comments" "$payload" | __apimgr_jq -r '"Commented on issue #'"$n"' — \(.html_url)"'
}
# Gitea PR actions. Same path shape as github (/pulls), different merge endpoint (POST /pulls/N/merge with {Do:"merge"}).
__gitea_resolve_base() {
  local provider="$1"
  if [ -n "$APIMGR_BASE" ]; then printf '%s' "$APIMGR_BASE"; return 0; fi
  if [ -n "$APIMGR_BASE_RESOLVED" ]; then printf '%s' "$APIMGR_BASE_RESOLVED"; return 0; fi
  APIMGR_BASE_RESOLVED="$(__gitea_api "$provider" GET "/repos/$APIMGR_REPO" | __apimgr_jq -r '.default_branch // "main"')"
  printf '%s' "$APIMGR_BASE_RESOLVED"
}
__gitea_pr_repo() {
  local provider="$1"
  __apimgr_resolve_repo || __apimgr_die "$provider pr: --repo USER/REPO required"
}
__gitea_pr_list() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_pr_repo "$provider"
  local state; state="$(__apimgr_state_for "$provider")"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/pulls?state=$state&limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_pr_list
}
__gitea_pr_get() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_pr_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider pr get: PR NUMBER required"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/pulls/$n" | __apimgr_print_pr
}
__gitea_pr_create() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_pr_repo "$provider"
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "$provider pr create: --title required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "$provider pr create: --branch SOURCE required"
  local base; base="$(__gitea_resolve_base "$provider")"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" --arg h "$APIMGR_BRANCH" --arg ba "$base" '{title:$t, body:$b, head:$h, base:$ba}')"
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/pulls" "$payload" | __apimgr_jq -r '"Created PR #\(.number) (\(.head.ref) → \(.base.ref)) — \(.html_url)"'
}
__gitea_pr_merge() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_pr_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider pr merge: PR NUMBER required"
  __apimgr_confirm "Merge PR #$n in $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/pulls/$n/merge" '{"Do":"merge"}' >/dev/null && printf_green "Merged PR #$n"
}
__gitea_pr_close() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_pr_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider pr close: PR NUMBER required"
  __gitea_api "$provider" PATCH "/repos/$APIMGR_REPO/pulls/$n" '{"state":"closed"}' | __apimgr_jq -r '"Closed PR #\(.number) — \(.html_url)"'
}
# Release actions for gitea-family. Same paths as github (/releases, /releases/tags/X).
__gitea_release_repo() { local provider="$1"; __apimgr_resolve_repo || __apimgr_die "$provider release: --repo USER/REPO required"; }
__gitea_release_list() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_release_repo "$provider"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/releases?limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_release_list
}
__gitea_release_get() {
  local provider="$1" key="$2"
  __apimgr_require_creds "$provider"
  __gitea_release_repo "$provider"
  [ -n "$key" ] || __apimgr_die "$provider release get: TAG or ID required"
  case "$key" in
    [0-9]*) __gitea_api "$provider" GET "/repos/$APIMGR_REPO/releases/$key" | __apimgr_print_release ;;
    *)      __gitea_api "$provider" GET "/repos/$APIMGR_REPO/releases/tags/$key" | __apimgr_print_release ;;
  esac
}
__gitea_release_create() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_release_repo "$provider"
  [ -n "$APIMGR_TAG" ] || __apimgr_die "$provider release create: --tag NAME required"
  local payload; payload="$(__apimgr_jq -n \
    --arg tag "$APIMGR_TAG" \
    --arg name "${APIMGR_TITLE:-$APIMGR_TAG}" \
    --arg body "${APIMGR_BODY:-}" \
    --arg target "${APIMGR_BRANCH:-}" \
    '{tag_name:$tag, name:$name, body:$body} + (if $target == "" then {} else {target_commitish:$target} end)')"
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/releases" "$payload" | __apimgr_jq -r '"Created release \(.tag_name) — \(.html_url)"'
}
__gitea_release_delete() {
  local provider="$1" key="$2"
  __apimgr_require_creds "$provider"
  __gitea_release_repo "$provider"
  [ -n "$key" ] || __apimgr_die "$provider release delete: TAG or ID required"
  __apimgr_confirm "Delete release '$key' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  local id="$key"
  case "$key" in
    [0-9]*) ;;
    *)      id="$(__gitea_api "$provider" GET "/repos/$APIMGR_REPO/releases/tags/$key" | __apimgr_jq -r '.id // empty')"
            [ -n "$id" ] || __apimgr_die "$provider release delete: tag '$key' not found" ;;
  esac
  __gitea_api "$provider" DELETE "/repos/$APIMGR_REPO/releases/$id" >/dev/null && printf_green "Deleted release '$key' from $APIMGR_REPO"
}
# Git-tag actions for gitea-family. Direct /tags endpoint (no git-refs detour like github).
__gitea_tag_repo() { local provider="$1"; __apimgr_resolve_repo || __apimgr_die "$provider tag: --repo USER/REPO required"; }
__gitea_tag_list() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_tag_repo "$provider"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/tags?limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_git_tag_list
}
__gitea_tag_get() {
  local provider="$1" tag="${APIMGR_TAG:-$2}"
  __apimgr_require_creds "$provider"
  __gitea_tag_repo "$provider"
  [ -n "$tag" ] || __apimgr_die "$provider tag get: --tag NAME or positional TAG required"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/tags/$tag" | __apimgr_jq .
}
__gitea_tag_create() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_tag_repo "$provider"
  [ -n "$APIMGR_TAG" ] || __apimgr_die "$provider tag create: --tag NAME required"
  local target="${APIMGR_BRANCH:-}"
  [ -n "$target" ] || target="$(__gitea_api "$provider" GET "/repos/$APIMGR_REPO" | __apimgr_jq -r '.default_branch // "main"')"
  local payload; payload="$(__apimgr_jq -n --arg n "$APIMGR_TAG" --arg t "$target" --arg m "${APIMGR_BODY:-}" '{tag_name:$n, target:$t, message:$m}')"
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/tags" "$payload" | __apimgr_jq -r '"Created tag \(.name) → \(.id[0:7] // .commit.sha[0:7] // "")"'
}
__gitea_tag_delete() {
  local provider="$1" tag="${APIMGR_TAG:-$2}"
  __apimgr_require_creds "$provider"
  __gitea_tag_repo "$provider"
  [ -n "$tag" ] || __apimgr_die "$provider tag delete: --tag NAME or positional TAG required"
  __apimgr_confirm "Delete tag '$tag' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __gitea_api "$provider" DELETE "/repos/$APIMGR_REPO/tags/$tag" >/dev/null && printf_green "Deleted tag '$tag' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== GitLab provider (api.v4 — uses PRIVATE-TOKEN header and URL-encoded namespace/path) ==============
# URL-encode a path segment (replace '/' with '%2F'). Used to address GitLab projects by their full path.
__gitlab_urlenc() { printf '%s' "${1//\//%2F}"; }
__gitlab_curl() {
  local token; token="$(__apimgr_provider_token gitlab)" || return 1
  __apimgr_curl -H "PRIVATE-TOKEN: $token" -H "Accept: application/json" "$@"
}
__gitlab_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url gitlab)" || return 1
  if [ -n "$data" ]; then
    __gitlab_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __gitlab_curl -X "$method" "$base$path"
  fi
}
__gitlab_verify() {
  __apimgr_require_creds gitlab
  local resp; resp="$(__gitlab_api GET /user)" || __apimgr_die "GitLab /user call failed"
  __apimgr_jq -r '"Authenticated as \(.username) (\(.name // "no name")) — \(.web_url)"' <<<"$resp"
}
__gitlab_user_get() {
  __apimgr_require_creds gitlab
  if [ -n "$APIMGR_USER" ]; then
    # GitLab's /users endpoint takes ?username= for lookup; returns an array of length 0 or 1.
    __gitlab_api GET "/users?username=$APIMGR_USER" | __apimgr_jq '.[0] // empty'
  else
    __gitlab_api GET /user | __apimgr_jq .
  fi
}
__gitlab_org_get() {
  __apimgr_require_creds gitlab
  [ -n "$APIMGR_ORG" ] || __apimgr_die "gitlab org get: --org NAME required"
  # GitLab "groups" are the equivalent of orgs; addressable by id or full path.
  __gitlab_api GET "/groups/$(__gitlab_urlenc "$APIMGR_ORG")" | __apimgr_jq .
}
__gitlab_org_all() {
  __apimgr_require_creds gitlab
  [ -n "$APIMGR_ORG" ] || __apimgr_die "gitlab org all: --org NAME required"
  __gitlab_api GET "/groups/$(__gitlab_urlenc "$APIMGR_ORG")/projects?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}&include_subgroups=true" |
    __apimgr_jq -r '.[] | "\(.path_with_namespace)\t\(.description // "")\t\(.visibility)"' |
    awk -F'\t' 'BEGIN{OFS=" │ "} {printf "%-45s %-50s %s\n", $1, substr($2,1,48), $3}'
}
__gitlab_repo_list() {
  __apimgr_require_creds gitlab
  local path
  if [ -n "$APIMGR_USER" ]; then
    path="/users/$(__gitlab_urlenc "$APIMGR_USER")/projects?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  else
    # /projects?membership=true returns all repos the authed user has any role in.
    path="/projects?membership=true&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  fi
  __gitlab_api GET "$path" |
    __apimgr_jq -r '.[] | "\(.path_with_namespace)\t\(.description // "")\t\(.visibility)"' |
    awk -F'\t' 'BEGIN{OFS=" │ "} {printf "%-45s %-50s %s\n", $1, substr($2,1,48), $3}'
}
__gitlab_repo_get() {
  __apimgr_require_creds gitlab
  __apimgr_resolve_repo || __apimgr_die "gitlab repo get: --repo USER/REPO required"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")" | __apimgr_jq -r '
    "Name:        \(.path_with_namespace)",
    "URL:         \(.web_url)",
    "Description: \(.description // "")",
    "Visibility:  \(.visibility)",
    "Default:     \(.default_branch // "")",
    "Stars:       \(.star_count // 0)",
    "Forks:       \(.forks_count // 0)",
    "Issues:      \(.open_issues_count // 0)"
  '
}
__gitlab_repo_create() {
  __apimgr_require_creds gitlab
  local name="${APIMGR_REPO##*/}" owner="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$owner" ] && [ "$owner" != "$name" ] || __apimgr_die "gitlab repo create: --repo OWNER/NAME required"
  local visibility="${APIMGR_VISIBILITY:-public}"
  # GitLab's create-project requires a numeric namespace_id when the owner isn't the authed user.
  local me_id me_username payload
  me_username="$(__gitlab_api GET /user | __apimgr_jq -r '.username')"
  if [ "$owner" = "$me_username" ]; then
    payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --arg v "$visibility" '{name:$n, description:$d, visibility:$v, initialize_with_readme:true}')"
  else
    local ns_id; ns_id="$(__gitlab_api GET "/groups/$(__gitlab_urlenc "$owner")" | __apimgr_jq -r '.id // empty')"
    [ -n "$ns_id" ] || __apimgr_die "gitlab repo create: group '$owner' not found or not visible"
    payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --arg v "$visibility" --argjson nid "$ns_id" '{name:$n, description:$d, visibility:$v, namespace_id:$nid, initialize_with_readme:true}')"
  fi
  __gitlab_api POST /projects "$payload" | __apimgr_jq -r '"Created: \(.path_with_namespace) — \(.web_url)"'
}
__gitlab_repo_delete() {
  __apimgr_require_creds gitlab
  __apimgr_resolve_repo || __apimgr_die "gitlab repo delete: --repo USER/REPO required"
  __apimgr_confirm "Delete $APIMGR_REPO from GitLab? This is irreversible (and on gitlab.com, queued for 7 days before hard delete)." || { printf_yellow "Aborted"; return 1; }
  __gitlab_api DELETE "/projects/$(__gitlab_urlenc "$APIMGR_REPO")" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__gitlab_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __gitlab_org_all; else __gitlab_repo_list; fi
}
# GitLab issue actions. Field names differ: .iid (not .number), .description (not .body), state values
# are opened|closed|all (normalized via __apimgr_state_for). Comments live under /notes, not /comments.
__gitlab_issue_repo() {
  __apimgr_resolve_repo || __apimgr_die "gitlab issue: --repo USER/REPO required"
}
__gitlab_issue_list() {
  __apimgr_require_creds gitlab
  __gitlab_issue_repo
  local state; state="$(__apimgr_state_for gitlab)"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/issues?state=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" |
    __apimgr_print_issue_list
}
__gitlab_issue_get() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_issue_repo
  [ -n "$n" ] || __apimgr_die "gitlab issue get: issue IID required"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/issues/$n" | __apimgr_print_issue
}
__gitlab_issue_create() {
  __apimgr_require_creds gitlab
  __gitlab_issue_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "gitlab issue create: --title required"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg d "${APIMGR_BODY:-}" '{title:$t, description:$d}')"
  __gitlab_api POST "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/issues" "$payload" | __apimgr_jq -r '"Created issue #\(.iid) — \(.web_url)"'
}
__gitlab_issue_close() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_issue_repo
  [ -n "$n" ] || __apimgr_die "gitlab issue close: issue IID required"
  __gitlab_api PUT "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/issues/$n" '{"state_event":"close"}' | __apimgr_jq -r '"Closed issue #\(.iid) — \(.web_url)"'
}
__gitlab_issue_comment() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_issue_repo
  [ -n "$n" ] || __apimgr_die "gitlab issue comment: issue IID required"
  [ -n "$APIMGR_BODY" ] || __apimgr_die "gitlab issue comment: --body required"
  local payload; payload="$(__apimgr_jq -n --arg b "$APIMGR_BODY" '{body:$b}')"
  __gitlab_api POST "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/issues/$n/notes" "$payload" | __apimgr_jq -r '"Commented on issue #'"$n"' — \(.web_url // "")"'
}
# GitLab merge-request actions. /merge_requests not /pulls; .iid not .number; source_branch/target_branch instead of head/base;
# merge is PUT /merge_requests/N/merge; close is PUT with state_event=close (not PATCH state=closed).
__gitlab_resolve_base() {
  if [ -n "$APIMGR_BASE" ]; then printf '%s' "$APIMGR_BASE"; return 0; fi
  if [ -n "$APIMGR_BASE_RESOLVED" ]; then printf '%s' "$APIMGR_BASE_RESOLVED"; return 0; fi
  APIMGR_BASE_RESOLVED="$(__gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")" | __apimgr_jq -r '.default_branch // "main"')"
  printf '%s' "$APIMGR_BASE_RESOLVED"
}
__gitlab_pr_repo() { __apimgr_resolve_repo || __apimgr_die "gitlab pr: --repo USER/REPO required"; }
__gitlab_pr_list() {
  __apimgr_require_creds gitlab
  __gitlab_pr_repo
  local state; state="$(__apimgr_state_for gitlab)"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/merge_requests?state=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_pr_list
}
__gitlab_pr_get() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_pr_repo
  [ -n "$n" ] || __apimgr_die "gitlab pr get: MR IID required"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/merge_requests/$n" | __apimgr_print_pr
}
__gitlab_pr_create() {
  __apimgr_require_creds gitlab
  __gitlab_pr_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "gitlab pr create: --title required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "gitlab pr create: --branch SOURCE required"
  local base; base="$(__gitlab_resolve_base)"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg d "${APIMGR_BODY:-}" --arg s "$APIMGR_BRANCH" --arg ta "$base" '{title:$t, description:$d, source_branch:$s, target_branch:$ta}')"
  __gitlab_api POST "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/merge_requests" "$payload" | __apimgr_jq -r '"Created MR #\(.iid) (\(.source_branch) → \(.target_branch)) — \(.web_url)"'
}
__gitlab_pr_merge() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_pr_repo
  [ -n "$n" ] || __apimgr_die "gitlab pr merge: MR IID required"
  __apimgr_confirm "Merge MR !$n in $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __gitlab_api PUT "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/merge_requests/$n/merge" '{}' | __apimgr_jq -r 'if .state == "merged" then "Merged MR !'"$n"' — \(.merge_commit_sha[0:7])" else "Merge refused: state=\(.state)" end'
}
__gitlab_pr_close() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_pr_repo
  [ -n "$n" ] || __apimgr_die "gitlab pr close: MR IID required"
  __gitlab_api PUT "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/merge_requests/$n" '{"state_event":"close"}' | __apimgr_jq -r '"Closed MR !\(.iid) — \(.web_url)"'
}
# Release actions for gitlab. Releases are addressed by tag_name only (no numeric id), and the field is
# `description` not `body`. The optional `ref` field on create lets you tag a non-default branch.
__gitlab_release_repo() { __apimgr_resolve_repo || __apimgr_die "gitlab release: --repo USER/REPO required"; }
__gitlab_release_list() {
  __apimgr_require_creds gitlab
  __gitlab_release_repo
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/releases?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_release_list
}
__gitlab_release_get() {
  local key="$1"
  __apimgr_require_creds gitlab
  __gitlab_release_repo
  [ -n "$key" ] || __apimgr_die "gitlab release get: TAG required"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/releases/$(__gitlab_urlenc "$key")" | __apimgr_print_release
}
__gitlab_release_create() {
  __apimgr_require_creds gitlab
  __gitlab_release_repo
  [ -n "$APIMGR_TAG" ] || __apimgr_die "gitlab release create: --tag NAME required"
  # GitLab requires `ref` for tags that don't yet exist (it'll create the tag). If --branch is given use it,
  # otherwise default to the project's default_branch via the same resolver used by pr-create.
  local ref; ref="$(__gitlab_resolve_base)"
  local payload; payload="$(__apimgr_jq -n \
    --arg tag "$APIMGR_TAG" \
    --arg name "${APIMGR_TITLE:-$APIMGR_TAG}" \
    --arg desc "${APIMGR_BODY:-}" \
    --arg ref "$ref" \
    '{tag_name:$tag, name:$name, description:$desc, ref:$ref}')"
  __gitlab_api POST "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/releases" "$payload" | __apimgr_jq -r '"Created release \(.tag_name) — \(._links.self // "")"'
}
__gitlab_release_delete() {
  local key="$1"
  __apimgr_require_creds gitlab
  __gitlab_release_repo
  [ -n "$key" ] || __apimgr_die "gitlab release delete: TAG required"
  __apimgr_confirm "Delete release '$key' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __gitlab_api DELETE "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/releases/$(__gitlab_urlenc "$key")" >/dev/null && printf_green "Deleted release '$key' from $APIMGR_REPO"
}
# Git-tag actions for gitlab. Different path (/repository/tags) than github/gitea/release.
__gitlab_tag_repo() { __apimgr_resolve_repo || __apimgr_die "gitlab tag: --repo USER/REPO required"; }
__gitlab_tag_list() {
  __apimgr_require_creds gitlab
  __gitlab_tag_repo
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/repository/tags?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_git_tag_list
}
__gitlab_tag_get() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds gitlab
  __gitlab_tag_repo
  [ -n "$tag" ] || __apimgr_die "gitlab tag get: --tag NAME or positional TAG required"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/repository/tags/$(__gitlab_urlenc "$tag")" | __apimgr_jq .
}
__gitlab_tag_create() {
  __apimgr_require_creds gitlab
  __gitlab_tag_repo
  [ -n "$APIMGR_TAG" ] || __apimgr_die "gitlab tag create: --tag NAME required"
  local ref; ref="$(__gitlab_resolve_base)"
  local payload; payload="$(__apimgr_jq -n --arg n "$APIMGR_TAG" --arg r "$ref" --arg m "${APIMGR_BODY:-}" '{tag_name:$n, ref:$r, message:$m}')"
  __gitlab_api POST "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/repository/tags" "$payload" | __apimgr_jq -r '"Created tag \(.name) → \(.target[0:7] // .commit.id[0:7] // "")"'
}
__gitlab_tag_delete() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds gitlab
  __gitlab_tag_repo
  [ -n "$tag" ] || __apimgr_die "gitlab tag delete: --tag NAME or positional TAG required"
  __apimgr_confirm "Delete tag '$tag' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __gitlab_api DELETE "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/repository/tags/$(__gitlab_urlenc "$tag")" >/dev/null && printf_green "Deleted tag '$tag' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Bitbucket Cloud provider (api v2.0 — workspaces/repositories/{slug}, paginated {values:[]} wrappers) ==============
# Auth: Bearer token (workspace/repo access tokens or OAuth). Basic auth with app passwords also works
# but the resolver chain doesn't expose username — users wanting Basic auth should pre-encode and pass via --token.
__bitbucket_curl() {
  local token; token="$(__apimgr_provider_token bitbucket)" || return 1
  __apimgr_curl -H "Authorization: Bearer $token" -H "Accept: application/json" "$@"
}
__bitbucket_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url bitbucket)" || return 1
  if [ -n "$data" ]; then
    __bitbucket_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __bitbucket_curl -X "$method" "$base$path"
  fi
}
# Bitbucket list responses wrap data in {values:[]}; this unwraps so the shared formatters see a bare array.
__bitbucket_unwrap() { __apimgr_jq '.values // .'; }
__bitbucket_repo_check() { __apimgr_resolve_repo || __apimgr_die "bitbucket: --repo WORKSPACE/REPO required"; }
# Bitbucket-shaped repo formatters (different field names: full_name, is_private, links.html.href, mainbranch).
__bitbucket_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.full_name)\t\(.description // "")\t\(.is_private)"' |
    awk -F'\t' '{printf "%-45s %-50s %s\n", $1, substr($2,1,48), ($3=="true"?"private":"public")}'
}
__bitbucket_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.full_name)",
    "URL:         \(.links.html.href // "")",
    "Description: \(.description // "")",
    "Visibility:  \(if .is_private then "private" else "public" end)",
    "Default:     \(.mainbranch.name // "")",
    "Size:        \(.size // 0) bytes",
    "Language:    \(.language // "")"
  '
}
# Issue/PR formatters work on Bitbucket because the shared formatters fall back via // chains, but
# Bitbucket issues use .reporter.display_name and .content.raw — we add an unwrap in the issue/PR list paths.
__bitbucket_print_issue_list() {
  __apimgr_jq -r '.[] | "#\(.id)\t\(.state)\t\(.reporter.display_name // "")\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-12s %-20s %s\n", $1, substr($2,1,12), substr($3,1,20), $4}'
}
__bitbucket_print_pr_list() {
  __apimgr_jq -r '.[] | "#\(.id)\t\(.state)\t\(.author.display_name // "")\t\(.source.branch.name)→\(.destination.branch.name)\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-10s %-18s %-30s %s\n", $1, substr($2,1,10), substr($3,1,18), substr($4,1,30), $5}'
}
__bitbucket_verify() {
  __apimgr_require_creds bitbucket
  local resp; resp="$(__bitbucket_api GET /user)" || __apimgr_die "Bitbucket /user call failed"
  __apimgr_jq -r '"Authenticated as \(.username) (\(.display_name // "no name")) — \(.links.html.href // "")"' <<<"$resp"
}
__bitbucket_user_get() {
  __apimgr_require_creds bitbucket
  if [ -n "$APIMGR_USER" ]; then
    # Bitbucket /users/{name} was deprecated in 2019; the canonical lookup is by UUID (impractical) or
    # via the legacy workspace endpoint. Document the limitation and surface what we can — workspace info.
    __bitbucket_api GET "/workspaces/$APIMGR_USER" | __apimgr_jq .
  else
    __bitbucket_api GET /user | __apimgr_jq .
  fi
}
__bitbucket_org_get() {
  __apimgr_require_creds bitbucket
  [ -n "$APIMGR_ORG" ] || __apimgr_die "bitbucket org get: --org WORKSPACE required"
  __bitbucket_api GET "/workspaces/$APIMGR_ORG" | __apimgr_jq .
}
__bitbucket_org_all() {
  __apimgr_require_creds bitbucket
  [ -n "$APIMGR_ORG" ] || __apimgr_die "bitbucket org all: --org WORKSPACE required"
  __bitbucket_api GET "/repositories/$APIMGR_ORG?pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __bitbucket_unwrap | __bitbucket_print_repo_list
}
__bitbucket_repo_list() {
  __apimgr_require_creds bitbucket
  local path="/repositories?role=member&pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  [ -n "$APIMGR_USER" ] && path="/repositories/$APIMGR_USER?pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  __bitbucket_api GET "$path" | __bitbucket_unwrap | __bitbucket_print_repo_list
}
__bitbucket_repo_get() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  __bitbucket_api GET "/repositories/$APIMGR_REPO" | __bitbucket_print_repo
}
__bitbucket_repo_create() {
  __apimgr_require_creds bitbucket
  local name="${APIMGR_REPO##*/}" owner="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$owner" ] && [ "$owner" != "$name" ] || __apimgr_die "bitbucket repo create: --repo WORKSPACE/REPO required"
  local visibility="${APIMGR_VISIBILITY:-public}" privflag="false"
  [ "$visibility" = "private" ] && privflag="true"
  local payload; payload="$(__apimgr_jq -n --arg d "${APIMGR_BODY:-}" --argjson p "$privflag" '{scm:"git", description:$d, is_private:$p}')"
  __bitbucket_api POST "/repositories/$APIMGR_REPO" "$payload" | __bitbucket_print_repo
}
__bitbucket_repo_delete() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  __apimgr_confirm "Delete $APIMGR_REPO from Bitbucket? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __bitbucket_api DELETE "/repositories/$APIMGR_REPO" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__bitbucket_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __bitbucket_org_all; else __bitbucket_repo_list; fi
}
__bitbucket_issue_list() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  local state; state="$(__apimgr_state_for bitbucket issue)"
  local q=""; [ -n "$state" ] && q="?q=state%3D%22$state%22&"
  __bitbucket_api GET "/repositories/$APIMGR_REPO/issues${q}pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __bitbucket_unwrap | __bitbucket_print_issue_list
}
__bitbucket_issue_get() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket issue get: issue ID required"
  __bitbucket_api GET "/repositories/$APIMGR_REPO/issues/$n" | __apimgr_jq -r '
    "ID:        #\(.id)",
    "Title:     \(.title)",
    "State:     \(.state)",
    "Reporter:  \(.reporter.display_name // "")",
    "URL:       \(.links.html.href // "")",
    "Created:   \(.created_on)",
    "",
    "\(.content.raw // "")"
  '
}
__bitbucket_issue_create() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "bitbucket issue create: --title required"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" '{title:$t, content:{raw:$b}, kind:"task", priority:"minor"}')"
  __bitbucket_api POST "/repositories/$APIMGR_REPO/issues" "$payload" | __apimgr_jq -r '"Created issue #\(.id) — \(.links.html.href)"'
}
__bitbucket_issue_close() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket issue close: issue ID required"
  # Bitbucket issue close = state="resolved". Use PUT with full state field.
  __bitbucket_api PUT "/repositories/$APIMGR_REPO/issues/$n" '{"state":"resolved"}' | __apimgr_jq -r '"Closed issue #\(.id) — \(.links.html.href)"'
}
__bitbucket_issue_comment() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket issue comment: issue ID required"
  [ -n "$APIMGR_BODY" ] || __apimgr_die "bitbucket issue comment: --body required"
  local payload; payload="$(__apimgr_jq -n --arg b "$APIMGR_BODY" '{content:{raw:$b}}')"
  __bitbucket_api POST "/repositories/$APIMGR_REPO/issues/$n/comments" "$payload" >/dev/null && printf_green "Commented on issue #$n"
}
# PR/MR actions for bitbucket. State vocabulary differs (UPPERCASE), and "close" is "decline".
__bitbucket_resolve_base() {
  if [ -n "$APIMGR_BASE" ]; then printf '%s' "$APIMGR_BASE"; return 0; fi
  if [ -n "$APIMGR_BASE_RESOLVED" ]; then printf '%s' "$APIMGR_BASE_RESOLVED"; return 0; fi
  APIMGR_BASE_RESOLVED="$(__bitbucket_api GET "/repositories/$APIMGR_REPO" | __apimgr_jq -r '.mainbranch.name // "main"')"
  printf '%s' "$APIMGR_BASE_RESOLVED"
}
__bitbucket_pr_list() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  local state; state="$(__apimgr_state_for bitbucket pr)"
  __bitbucket_api GET "/repositories/$APIMGR_REPO/pullrequests?state=$state&pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __bitbucket_unwrap | __bitbucket_print_pr_list
}
__bitbucket_pr_get() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket pr get: PR ID required"
  __bitbucket_api GET "/repositories/$APIMGR_REPO/pullrequests/$n" | __apimgr_jq -r '
    "ID:        #\(.id)",
    "Title:     \(.title)",
    "State:     \(.state)",
    "Author:    \(.author.display_name // "")",
    "Branches:  \(.source.branch.name) → \(.destination.branch.name)",
    "URL:       \(.links.html.href // "")",
    "Created:   \(.created_on)",
    "",
    "\(.description // "")"
  '
}
__bitbucket_pr_create() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "bitbucket pr create: --title required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "bitbucket pr create: --branch SOURCE required"
  local base; base="$(__bitbucket_resolve_base)"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg d "${APIMGR_BODY:-}" --arg s "$APIMGR_BRANCH" --arg ta "$base" \
    '{title:$t, description:$d, source:{branch:{name:$s}}, destination:{branch:{name:$ta}}}')"
  __bitbucket_api POST "/repositories/$APIMGR_REPO/pullrequests" "$payload" | __apimgr_jq -r '"Created PR #\(.id) (\(.source.branch.name) → \(.destination.branch.name)) — \(.links.html.href)"'
}
__bitbucket_pr_merge() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket pr merge: PR ID required"
  __apimgr_confirm "Merge PR #$n in $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __bitbucket_api POST "/repositories/$APIMGR_REPO/pullrequests/$n/merge" '{"merge_strategy":"merge_commit"}' | __apimgr_jq -r 'if .state == "MERGED" then "Merged PR #'"$n"'" else "Merge state: \(.state)" end'
}
__bitbucket_pr_close() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket pr close: PR ID required"
  # Bitbucket: close = decline. Separate endpoint, not a state PATCH.
  __bitbucket_api POST "/repositories/$APIMGR_REPO/pullrequests/$n/decline" '{}' | __apimgr_jq -r '"Declined PR #\(.id) — \(.links.html.href)"'
}
# Bitbucket Cloud has no first-class release object — releases are just git tags. Surface a friendly stub
# rather than a generic "not implemented" so the user knows it's a platform limitation, not a missing feature.
__bitbucket_release_unsupported() {
  __apimgr_die "bitbucket has no release API (releases are plain git tags). Use 'apimgr bitbucket tag list' instead."
}
# Git-tag actions for bitbucket. Path is /refs/tags. Bitbucket wraps responses in {values:[]}.
__bitbucket_tag_repo() { __apimgr_resolve_repo || __apimgr_die "bitbucket tag: --repo WORKSPACE/REPO required"; }
__bitbucket_tag_list() {
  __apimgr_require_creds bitbucket
  __bitbucket_tag_repo
  __bitbucket_api GET "/repositories/$APIMGR_REPO/refs/tags?pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __bitbucket_unwrap | __apimgr_print_git_tag_list
}
__bitbucket_tag_get() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds bitbucket
  __bitbucket_tag_repo
  [ -n "$tag" ] || __apimgr_die "bitbucket tag get: --tag NAME or positional TAG required"
  __bitbucket_api GET "/repositories/$APIMGR_REPO/refs/tags/$tag" | __apimgr_jq .
}
__bitbucket_tag_create() {
  __apimgr_require_creds bitbucket
  __bitbucket_tag_repo
  [ -n "$APIMGR_TAG" ] || __apimgr_die "bitbucket tag create: --tag NAME required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "bitbucket tag create: --branch SHA required (the commit hash to tag)"
  local payload; payload="$(__apimgr_jq -n --arg n "$APIMGR_TAG" --arg sha "$APIMGR_BRANCH" --arg m "${APIMGR_BODY:-}" '{name:$n, target:{hash:$sha}, message:$m}')"
  __bitbucket_api POST "/repositories/$APIMGR_REPO/refs/tags" "$payload" | __apimgr_jq -r '"Created tag \(.name) → \(.target.hash[0:7])"'
}
__bitbucket_tag_delete() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds bitbucket
  __bitbucket_tag_repo
  [ -n "$tag" ] || __apimgr_die "bitbucket tag delete: --tag NAME or positional TAG required"
  __apimgr_confirm "Delete tag '$tag' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __bitbucket_api DELETE "/repositories/$APIMGR_REPO/refs/tags/$tag" >/dev/null && printf_green "Deleted tag '$tag' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Gitee provider (gitee.com/api/v5 — github-shaped API with `Authorization: token` auth) ==============
# Gitee is a separate forge (not gitea — the names differ by one letter). The API mirrors github's field names
# and paths very closely, so the implementation parallels __github_* with a different curl wrapper.
__gitee_curl() {
  local token; token="$(__apimgr_provider_token gitee)" || return 1
  __apimgr_curl -H "Authorization: token $token" -H "Accept: application/json" "$@"
}
__gitee_api()  { local base; base="$(__apimgr_provider_url gitee)" || return 1; __gitee_curl -X "${1:-GET}" "$base$2"; }
__gitee_post() { local base; base="$(__apimgr_provider_url gitee)" || return 1; __gitee_curl -X "${1:-POST}" -H "Content-Type: application/json" --data "$3" "$base$2"; }
__gitee_repo_check() { __apimgr_resolve_repo || __apimgr_die "gitee: --repo USER/REPO required"; }
__gitee_verify() {
  __apimgr_require_creds gitee
  local resp; resp="$(__gitee_api GET /user)" || __apimgr_die "Gitee /user call failed"
  __apimgr_jq -r '"Authenticated as \(.login) (\(.name // "no name")) — \(.html_url // "")"' <<<"$resp"
}
__gitee_user_get() {
  __apimgr_require_creds gitee
  if [ -n "$APIMGR_USER" ]; then __gitee_api GET "/users/$APIMGR_USER" | __apimgr_jq .
  else __gitee_api GET /user | __apimgr_jq .
  fi
}
__gitee_org_get() {
  __apimgr_require_creds gitee
  [ -n "$APIMGR_ORG" ] || __apimgr_die "gitee org get: --org NAME required"
  __gitee_api GET "/orgs/$APIMGR_ORG" | __apimgr_jq .
}
__gitee_org_all() {
  __apimgr_require_creds gitee
  [ -n "$APIMGR_ORG" ] || __apimgr_die "gitee org all: --org NAME required"
  __gitee_api GET "/orgs/$APIMGR_ORG/repos?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_repo_list
}
__gitee_repo_list() {
  __apimgr_require_creds gitee
  local path="/user/repos?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  [ -n "$APIMGR_USER" ] && path="/users/$APIMGR_USER/repos?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  __gitee_api GET "$path" | __apimgr_print_repo_list
}
__gitee_repo_get() {
  __apimgr_require_creds gitee
  __gitee_repo_check
  __gitee_api GET "/repos/$APIMGR_REPO" | __apimgr_print_repo
}
__gitee_repo_create() {
  __apimgr_require_creds gitee
  local name="${APIMGR_REPO##*/}" owner="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$owner" ] && [ "$owner" != "$name" ] || __apimgr_die "gitee repo create: --repo OWNER/NAME required"
  local visibility="${APIMGR_VISIBILITY:-public}" privflag="false"
  [ "$visibility" = "private" ] && privflag="true"
  local payload; payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --argjson p "$privflag" '{name:$n, description:$d, private:$p}')"
  local me; me="$(__gitee_api GET /user | __apimgr_jq -r '.login')"
  if [ "$owner" = "$me" ]; then
    __gitee_post POST "/user/repos" "$payload" | __apimgr_print_repo
  else
    __gitee_post POST "/orgs/$owner/repos" "$payload" | __apimgr_print_repo
  fi
}
__gitee_repo_delete() {
  __apimgr_require_creds gitee
  __gitee_repo_check
  __apimgr_confirm "Delete $APIMGR_REPO from Gitee? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __gitee_api DELETE "/repos/$APIMGR_REPO" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__gitee_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __gitee_org_all; else __gitee_repo_list; fi
}
__gitee_issue_repo() { __apimgr_resolve_repo || __apimgr_die "gitee issue: --repo USER/REPO required"; }
__gitee_issue_list() {
  __apimgr_require_creds gitee
  __gitee_issue_repo
  local state; state="$(__apimgr_state_for gitee)"
  __gitee_api GET "/repos/$APIMGR_REPO/issues?state=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_issue_list
}
__gitee_issue_get() {
  local n="$1"
  __apimgr_require_creds gitee
  __gitee_issue_repo
  [ -n "$n" ] || __apimgr_die "gitee issue get: issue NUMBER required"
  # Gitee's issue endpoint uses owner/repo/issues/NUMBER as separate fields in URL: /repos/OWNER/REPO/issues/NUMBER
  __gitee_api GET "/repos/$APIMGR_REPO/issues/$n" | __apimgr_print_issue
}
__gitee_issue_create() {
  __apimgr_require_creds gitee
  __gitee_issue_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "gitee issue create: --title required"
  local owner="${APIMGR_REPO%/*}" repo="${APIMGR_REPO##*/}"
  # Gitee's create-issue endpoint is /repos/OWNER/issues with {repo, title, body}.
  local payload; payload="$(__apimgr_jq -n --arg r "$repo" --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" '{repo:$r, title:$t, body:$b}')"
  __gitee_post POST "/repos/$owner/issues" "$payload" | __apimgr_jq -r '"Created issue #\(.number) — \(.html_url)"'
}
__gitee_issue_close() {
  local n="$1"
  __apimgr_require_creds gitee
  __gitee_issue_repo
  [ -n "$n" ] || __apimgr_die "gitee issue close: issue NUMBER required"
  local owner="${APIMGR_REPO%/*}"
  __gitee_post PATCH "/repos/$owner/issues/$n" '{"state":"closed"}' | __apimgr_jq -r '"Closed issue #\(.number) — \(.html_url)"'
}
__gitee_issue_comment() {
  local n="$1"
  __apimgr_require_creds gitee
  __gitee_issue_repo
  [ -n "$n" ] || __apimgr_die "gitee issue comment: issue NUMBER required"
  [ -n "$APIMGR_BODY" ] || __apimgr_die "gitee issue comment: --body required"
  local payload; payload="$(__apimgr_jq -n --arg b "$APIMGR_BODY" '{body:$b}')"
  __gitee_post POST "/repos/$APIMGR_REPO/issues/$n/comments" "$payload" | __apimgr_jq -r '"Commented on issue #'"$n"' — \(.html_url // "")"'
}
__gitee_resolve_base() {
  if [ -n "$APIMGR_BASE" ]; then printf '%s' "$APIMGR_BASE"; return 0; fi
  if [ -n "$APIMGR_BASE_RESOLVED" ]; then printf '%s' "$APIMGR_BASE_RESOLVED"; return 0; fi
  APIMGR_BASE_RESOLVED="$(__gitee_api GET "/repos/$APIMGR_REPO" | __apimgr_jq -r '.default_branch // "master"')"
  printf '%s' "$APIMGR_BASE_RESOLVED"
}
__gitee_pr_list() {
  __apimgr_require_creds gitee
  __gitee_issue_repo
  local state; state="$(__apimgr_state_for gitee)"
  __gitee_api GET "/repos/$APIMGR_REPO/pulls?state=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_pr_list
}
__gitee_pr_get() {
  local n="$1"
  __apimgr_require_creds gitee
  __gitee_issue_repo
  [ -n "$n" ] || __apimgr_die "gitee pr get: PR NUMBER required"
  __gitee_api GET "/repos/$APIMGR_REPO/pulls/$n" | __apimgr_print_pr
}
__gitee_pr_create() {
  __apimgr_require_creds gitee
  __gitee_issue_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "gitee pr create: --title required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "gitee pr create: --branch SOURCE required"
  local base; base="$(__gitee_resolve_base)"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" --arg h "$APIMGR_BRANCH" --arg ba "$base" '{title:$t, body:$b, head:$h, base:$ba}')"
  __gitee_post POST "/repos/$APIMGR_REPO/pulls" "$payload" | __apimgr_jq -r '"Created PR #\(.number) (\(.head.ref) → \(.base.ref)) — \(.html_url)"'
}
__gitee_pr_merge() {
  local n="$1"
  __apimgr_require_creds gitee
  __gitee_issue_repo
  [ -n "$n" ] || __apimgr_die "gitee pr merge: PR NUMBER required"
  __apimgr_confirm "Merge PR #$n in $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __gitee_post PUT "/repos/$APIMGR_REPO/pulls/$n/merge" '{}' >/dev/null && printf_green "Merged PR #$n"
}
__gitee_pr_close() {
  local n="$1"
  __apimgr_require_creds gitee
  __gitee_issue_repo
  [ -n "$n" ] || __apimgr_die "gitee pr close: PR NUMBER required"
  __gitee_post PATCH "/repos/$APIMGR_REPO/pulls/$n" '{"state":"closed"}' | __apimgr_jq -r '"Closed PR #\(.number) — \(.html_url)"'
}
__gitee_release_list() {
  __apimgr_require_creds gitee
  __gitee_repo_check
  __gitee_api GET "/repos/$APIMGR_REPO/releases?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_release_list
}
__gitee_release_get() {
  local key="$1"
  __apimgr_require_creds gitee
  __gitee_repo_check
  [ -n "$key" ] || __apimgr_die "gitee release get: TAG or ID required"
  case "$key" in
    [0-9]*) __gitee_api GET "/repos/$APIMGR_REPO/releases/$key" | __apimgr_print_release ;;
    *)      __gitee_api GET "/repos/$APIMGR_REPO/releases/tags/$key" | __apimgr_print_release ;;
  esac
}
__gitee_release_create() {
  __apimgr_require_creds gitee
  __gitee_repo_check
  [ -n "$APIMGR_TAG" ] || __apimgr_die "gitee release create: --tag NAME required"
  local payload; payload="$(__apimgr_jq -n --arg tag "$APIMGR_TAG" --arg name "${APIMGR_TITLE:-$APIMGR_TAG}" --arg body "${APIMGR_BODY:-}" --arg target "${APIMGR_BRANCH:-master}" '{tag_name:$tag, name:$name, body:$body, target_commitish:$target}')"
  __gitee_post POST "/repos/$APIMGR_REPO/releases" "$payload" | __apimgr_jq -r '"Created release \(.tag_name) — \(.html_url)"'
}
__gitee_release_delete() {
  local key="$1"
  __apimgr_require_creds gitee
  __gitee_repo_check
  [ -n "$key" ] || __apimgr_die "gitee release delete: TAG or ID required"
  __apimgr_confirm "Delete release '$key' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  local id="$key"
  case "$key" in [0-9]*) ;; *) id="$(__gitee_api GET "/repos/$APIMGR_REPO/releases/tags/$key" | __apimgr_jq -r '.id // empty')"; [ -n "$id" ] || __apimgr_die "gitee release delete: tag '$key' not found" ;; esac
  __gitee_api DELETE "/repos/$APIMGR_REPO/releases/$id" >/dev/null && printf_green "Deleted release '$key'"
}
__gitee_tag_list() {
  __apimgr_require_creds gitee
  __gitee_repo_check
  __gitee_api GET "/repos/$APIMGR_REPO/tags" | __apimgr_print_git_tag_list
}
__gitee_tag_create() {
  __apimgr_require_creds gitee
  __gitee_repo_check
  [ -n "$APIMGR_TAG" ] || __apimgr_die "gitee tag create: --tag NAME required"
  local ref; ref="$(__gitee_resolve_base)"; [ -n "$APIMGR_BRANCH" ] && ref="$APIMGR_BRANCH"
  local payload; payload="$(__apimgr_jq -n --arg n "$APIMGR_TAG" --arg r "$ref" --arg m "${APIMGR_BODY:-}" '{tag_name:$n, refs:$r, tag_message:$m}')"
  __gitee_post POST "/repos/$APIMGR_REPO/tags" "$payload" | __apimgr_jq -r '"Created tag \(.name)"'
}
__gitee_tag_delete() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds gitee
  __gitee_repo_check
  [ -n "$tag" ] || __apimgr_die "gitee tag delete: --tag NAME or positional TAG required"
  __apimgr_confirm "Delete tag '$tag' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __gitee_api DELETE "/repos/$APIMGR_REPO/tags/$tag" >/dev/null && printf_green "Deleted tag '$tag' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Pagure provider (pagure.io/api/0 — Fedora's forge) ==============
# URL paths differ from gitea/github: no /repos/ prefix; project lives at /{namespace}/{repo} directly.
# Issues use /issue/{id} (singular), PRs use /pull-request/{id} (singular, dashed). Auth: Authorization: token X.
__pagure_curl() {
  local token; token="$(__apimgr_provider_token pagure)" || return 1
  __apimgr_curl -H "Authorization: token $token" -H "Accept: application/json" "$@"
}
__pagure_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url pagure)" || return 1
  if [ -n "$data" ]; then
    __pagure_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __pagure_curl -X "$method" "$base$path"
  fi
}
__pagure_repo_check() { __apimgr_resolve_repo || __apimgr_die "pagure: --repo NAMESPACE/REPO required"; }
# Pagure-shaped formatters — different field names: .fullname, .description, .last_updated.
__pagure_print_repo_list() {
  __apimgr_jq -r '.projects[]? // .[]? | "\(.fullname // .name)\t\(.description // "")\t\(.access_users.owner | length // 0)"' |
    awk -F'\t' '{printf "%-45s %-50s %d owner(s)\n", $1, substr($2,1,48), $3}'
}
__pagure_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.fullname // .name)",
    "URL:         \(.url_path // "")",
    "Description: \(.description // "")",
    "Default:     \(.default_branch // "")",
    "Tags:        \((.tags // []) | length) tag(s)",
    "Created:     \(.date_created // "")",
    "Updated:     \(.date_modified // "")"
  '
}
__pagure_print_issue_list() {
  __apimgr_jq -r '.issues[]? // .[]? | "#\(.id)\t\(.status)\t\(.user.name // "")\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-8s %-20s %s\n", $1, substr($2,1,8), substr($3,1,20), $4}'
}
__pagure_print_pr_list() {
  __apimgr_jq -r '.requests[]? // .[]? | "#\(.id)\t\(.status)\t\(.user.name // "")\t\(.branch_from)→\(.branch)\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-8s %-18s %-30s %s\n", $1, substr($2,1,8), substr($3,1,18), substr($4,1,30), $5}'
}
__pagure_verify() {
  __apimgr_require_creds pagure
  local resp; resp="$(__pagure_api GET /-/whoami)" || __apimgr_die "Pagure /-/whoami call failed"
  __apimgr_jq -r '"Authenticated as \(.username)"' <<<"$resp"
}
__pagure_user_get() {
  __apimgr_require_creds pagure
  local who="${APIMGR_USER:-}"
  if [ -z "$who" ]; then
    who="$(__pagure_api GET /-/whoami | __apimgr_jq -r '.username // empty')"
  fi
  [ -n "$who" ] || __apimgr_die "pagure user get: --user NAME required"
  __pagure_api GET "/user/$who" | __apimgr_jq .
}
__pagure_org_get() {
  __apimgr_require_creds pagure
  [ -n "$APIMGR_ORG" ] || __apimgr_die "pagure org get: --org GROUP required"
  __pagure_api GET "/group/$APIMGR_ORG" | __apimgr_jq .
}
__pagure_org_all() {
  __apimgr_require_creds pagure
  [ -n "$APIMGR_ORG" ] || __apimgr_die "pagure org all: --org GROUP required"
  # Pagure: /projects?username=X&owner=group lists projects owned by group.
  __pagure_api GET "/projects?owner=$APIMGR_ORG&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __pagure_print_repo_list
}
__pagure_repo_list() {
  __apimgr_require_creds pagure
  local who="${APIMGR_USER:-${APIMGR_ORG:-}}"
  [ -n "$who" ] || who="$(__pagure_api GET /-/whoami | __apimgr_jq -r '.username // empty')"
  [ -n "$who" ] || __apimgr_die "pagure repo list: --user or --org required"
  __pagure_api GET "/projects?username=$who&fork=false&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __pagure_print_repo_list
}
__pagure_repo_get() {
  __apimgr_require_creds pagure
  __pagure_repo_check
  __pagure_api GET "/$APIMGR_REPO" | __pagure_print_repo
}
__pagure_repo_create() {
  __apimgr_require_creds pagure
  local name="${APIMGR_REPO##*/}" ns="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$ns" ] && [ "$ns" != "$name" ] || __apimgr_die "pagure repo create: --repo NAMESPACE/NAME required"
  # Pagure /new takes form-encoded fields, not JSON. Use --data-urlencode for safety.
  local base; base="$(__apimgr_provider_url pagure)" || return 1
  local token; token="$(__apimgr_provider_token pagure)" || return 1
  __apimgr_curl -X POST -H "Authorization: token $token" -H "Accept: application/json" \
    --data-urlencode "name=$name" \
    --data-urlencode "namespace=$ns" \
    --data-urlencode "description=${APIMGR_BODY:-}" \
    "$base/new" | __apimgr_jq -r '.message // "Created \(.fullname // "")"'
}
__pagure_repo_delete() {
  __apimgr_die "pagure: project deletion is not supported via API. Use the web UI: https://pagure.io/$APIMGR_REPO/settings"
}
__pagure_repo_all() { if [ -n "$APIMGR_ORG" ]; then __pagure_org_all; else __pagure_repo_list; fi; }
__pagure_issue_repo() { __apimgr_resolve_repo || __apimgr_die "pagure issue: --repo NAMESPACE/REPO required"; }
__pagure_issue_list() {
  __apimgr_require_creds pagure
  __pagure_issue_repo
  local state="${APIMGR_STATE:-Open}"
  # Pagure uses Open/Closed (capitalized) for status. Translate apimgr's open/closed.
  case "$state" in open|Open) state="Open" ;; closed|Closed) state="Closed" ;; all|All) state="All" ;; esac
  __pagure_api GET "/$APIMGR_REPO/issues?status=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __pagure_print_issue_list
}
__pagure_issue_get() {
  local n="$1"
  __apimgr_require_creds pagure
  __pagure_issue_repo
  [ -n "$n" ] || __apimgr_die "pagure issue get: issue ID required"
  __pagure_api GET "/$APIMGR_REPO/issue/$n" | __apimgr_jq -r '
    "ID:        #\(.id)",
    "Title:     \(.title)",
    "Status:    \(.status)",
    "Reporter:  \(.user.name // "")",
    "Created:   \(.date_created)",
    "",
    "\(.content // "")"
  '
}
__pagure_issue_create() {
  __apimgr_require_creds pagure
  __pagure_issue_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "pagure issue create: --title required"
  local base; base="$(__apimgr_provider_url pagure)" || return 1
  local token; token="$(__apimgr_provider_token pagure)" || return 1
  __apimgr_curl -X POST -H "Authorization: token $token" -H "Accept: application/json" \
    --data-urlencode "title=$APIMGR_TITLE" \
    --data-urlencode "issue_content=${APIMGR_BODY:-}" \
    "$base/$APIMGR_REPO/new_issue" | __apimgr_jq -r '"Created issue #\(.issue.id // "?") — \(.message // "")"'
}
__pagure_issue_close() {
  local n="$1"
  __apimgr_require_creds pagure
  __pagure_issue_repo
  [ -n "$n" ] || __apimgr_die "pagure issue close: issue ID required"
  local base; base="$(__apimgr_provider_url pagure)" || return 1
  local token; token="$(__apimgr_provider_token pagure)" || return 1
  __apimgr_curl -X POST -H "Authorization: token $token" -H "Accept: application/json" \
    --data-urlencode "status=Closed" \
    "$base/$APIMGR_REPO/issue/$n/status" | __apimgr_jq -r '.message // "Closed issue #'"$n"'"'
}
__pagure_issue_comment() {
  local n="$1"
  __apimgr_require_creds pagure
  __pagure_issue_repo
  [ -n "$n" ] || __apimgr_die "pagure issue comment: issue ID required"
  [ -n "$APIMGR_BODY" ] || __apimgr_die "pagure issue comment: --body required"
  local base; base="$(__apimgr_provider_url pagure)" || return 1
  local token; token="$(__apimgr_provider_token pagure)" || return 1
  __apimgr_curl -X POST -H "Authorization: token $token" -H "Accept: application/json" \
    --data-urlencode "comment=$APIMGR_BODY" \
    "$base/$APIMGR_REPO/issue/$n/comment" >/dev/null && printf_green "Commented on issue #$n"
}
__pagure_pr_list() {
  __apimgr_require_creds pagure
  __pagure_issue_repo
  local state="${APIMGR_STATE:-Open}"
  case "$state" in open|Open) state="Open" ;; closed|Closed) state="Closed" ;; merged|Merged) state="Merged" ;; all|All) state="All" ;; esac
  __pagure_api GET "/$APIMGR_REPO/pull-requests?status=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __pagure_print_pr_list
}
__pagure_pr_get() {
  local n="$1"
  __apimgr_require_creds pagure
  __pagure_issue_repo
  [ -n "$n" ] || __apimgr_die "pagure pr get: PR ID required"
  __pagure_api GET "/$APIMGR_REPO/pull-request/$n" | __apimgr_jq -r '
    "ID:        #\(.id)",
    "Title:     \(.title)",
    "Status:    \(.status)",
    "Author:    \(.user.name // "")",
    "Branches:  \(.branch_from) → \(.branch)",
    "Created:   \(.date_created)",
    "",
    "\(.initial_comment // "")"
  '
}
__pagure_pr_merge() {
  local n="$1"
  __apimgr_require_creds pagure
  __pagure_issue_repo
  [ -n "$n" ] || __apimgr_die "pagure pr merge: PR ID required"
  __apimgr_confirm "Merge PR #$n in $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __pagure_api POST "/$APIMGR_REPO/pull-request/$n/merge" '{}' >/dev/null && printf_green "Merged PR #$n"
}
__pagure_pr_close() {
  local n="$1"
  __apimgr_require_creds pagure
  __pagure_issue_repo
  [ -n "$n" ] || __apimgr_die "pagure pr close: PR ID required"
  __pagure_api POST "/$APIMGR_REPO/pull-request/$n/close" '{}' >/dev/null && printf_green "Closed PR #$n"
}
__pagure_tag_list() {
  __apimgr_require_creds pagure
  __pagure_repo_check
  __pagure_api GET "/$APIMGR_REPO/git/tags" | __apimgr_jq '.tags // []' |
    __apimgr_jq -r '.[] | .' |
    awk '{printf "%s\n", $0}'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Sourcehut provider (sr.ht — multi-service: meta/git/todo/lists/builds at separate subdomains) ==============
# The user sets SOURCEHUT_API_URL to the meta service (e.g. https://meta.sr.ht/api). For repo ops the script
# swaps the subdomain to git.sr.ht. Self-host instances using the same `<service>.<host>` pattern work unchanged;
# anything else needs to set per-service URLs (SOURCEHUT_GIT_URL, SOURCEHUT_TODO_URL, SOURCEHUT_LISTS_URL).
# Issues (tickets) live in todo.sr.ht and PRs are mailing-list patches in lists.sr.ht — both have very different
# data models from github/gitea-style forges and aren't covered here. Use `apimgr sourcehut api PATH` for raw access.
__sourcehut_curl() {
  local token; token="$(__apimgr_provider_token sourcehut)" || return 1
  __apimgr_curl -H "Authorization: Bearer $token" -H "Accept: application/json" "$@"
}
# Resolve the per-service URL. For service "meta" (default), returns SOURCEHUT_API_URL as-is.
# For service "git"/"todo"/"lists", checks SOURCEHUT_<SERVICE>_URL first, else swaps the subdomain in
# SOURCEHUT_API_URL (assumes <service>.<rest> pattern, which holds for sr.ht and most self-host setups).
__sourcehut_service_url() {
  local service="$1"
  local explicit=""
  case "$service" in
    git)   eval "explicit=\${SOURCEHUT_GIT_URL:-\${APIMGR_SOURCEHUT_GIT_URL:-}}" ;;
    todo)  eval "explicit=\${SOURCEHUT_TODO_URL:-\${APIMGR_SOURCEHUT_TODO_URL:-}}" ;;
    lists) eval "explicit=\${SOURCEHUT_LISTS_URL:-\${APIMGR_SOURCEHUT_LISTS_URL:-}}" ;;
    meta|"") explicit="" ;;
  esac
  if [ -n "$explicit" ]; then printf '%s' "${explicit%/}"; return 0; fi
  local base; base="$(__apimgr_provider_url sourcehut)" || return 1
  if [ "$service" = "meta" ] || [ -z "$service" ]; then
    printf '%s' "$base"; return 0
  fi
  # Swap the subdomain. URL form: protocol://<sub>.<rest>
  local proto="${base%%://*}"
  local rest="${base#*://}"
  local sub="${rest%%.*}"
  local tail="${rest#"$sub"}"
  printf '%s://%s%s' "$proto" "$service" "$tail"
}
__sourcehut_api() {
  local service="$1" method="$2" path="$3" data="$4"
  local base; base="$(__sourcehut_service_url "$service")" || return 1
  if [ -n "$data" ]; then
    __sourcehut_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __sourcehut_curl -X "$method" "$base$path"
  fi
}
__sourcehut_print_repo_list() {
  __apimgr_jq -r '.results[]? // .[]? | "~\(.owner.canonical_name // .owner.name)/\(.name)\t\(.description // "")\t\(.visibility)"' |
    awk -F'\t' '{printf "%-45s %-50s %s\n", $1, substr($2,1,48), $3}'
}
__sourcehut_print_repo() {
  __apimgr_jq -r '
    "Name:        ~\(.owner.canonical_name // .owner.name)/\(.name)",
    "Description: \(.description // "")",
    "Visibility:  \(.visibility // "")",
    "Created:     \(.created // "")",
    "Updated:     \(.updated // "")"
  '
}
__sourcehut_verify() {
  __apimgr_require_creds sourcehut
  local resp; resp="$(__sourcehut_api meta GET /user/profile)" || __apimgr_die "Sourcehut /user/profile call failed"
  __apimgr_jq -r '"Authenticated as ~\(.canonical_name // .name) (\(.email // "no email"))"' <<<"$resp"
}
__sourcehut_user_get() {
  __apimgr_require_creds sourcehut
  if [ -n "$APIMGR_USER" ]; then
    # sr.ht usernames carry a leading ~; strip it if present so the user can pass either form.
    __sourcehut_api meta GET "/user/${APIMGR_USER#~}/profile" | __apimgr_jq .
  else
    __sourcehut_api meta GET /user/profile | __apimgr_jq .
  fi
}
__sourcehut_repo_list() {
  __apimgr_require_creds sourcehut
  if [ -n "$APIMGR_USER" ]; then
    __sourcehut_api git GET "/${APIMGR_USER#~}/repos" | __sourcehut_print_repo_list
  else
    __sourcehut_api git GET "/repos" | __sourcehut_print_repo_list
  fi
}
__sourcehut_repo_get() {
  __apimgr_require_creds sourcehut
  __apimgr_resolve_repo || __apimgr_die "sourcehut repo get: --repo USER/REPO required"
  # APIMGR_REPO is "user/repo" (with or without leading ~). Strip ~ if present.
  local owner="${APIMGR_REPO%/*}"; owner="${owner#~}"
  local name="${APIMGR_REPO##*/}"
  __sourcehut_api git GET "/~$owner/repos/$name" | __sourcehut_print_repo
}
__sourcehut_repo_create() {
  __apimgr_require_creds sourcehut
  local name="${APIMGR_REPO##*/}"
  [ -n "$name" ] || __apimgr_die "sourcehut repo create: --repo NAME (or USER/NAME — owner is always you) required"
  local visibility="${APIMGR_VISIBILITY:-unlisted}"
  case "$visibility" in public|unlisted|private) ;; *) __apimgr_die "sourcehut: --visibility must be public|unlisted|private" ;; esac
  local payload; payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --arg v "$visibility" '{name:$n, description:$d, visibility:$v}')"
  __sourcehut_api git POST "/repos" "$payload" | __apimgr_jq -r '"Created ~\(.owner.canonical_name // .owner.name)/\(.name)"'
}
__sourcehut_repo_delete() {
  __apimgr_require_creds sourcehut
  __apimgr_resolve_repo || __apimgr_die "sourcehut repo delete: --repo NAME required"
  local name="${APIMGR_REPO##*/}"
  __apimgr_confirm "Delete ~$(__sourcehut_api meta GET /user/profile | __apimgr_jq -r '.canonical_name // .name')/$name from Sourcehut? Irreversible." || { printf_yellow "Aborted"; return 1; }
  __sourcehut_api git DELETE "/repos/$name" >/dev/null && printf_green "Deleted $name"
}
__sourcehut_tag_list() {
  __apimgr_require_creds sourcehut
  __apimgr_resolve_repo || __apimgr_die "sourcehut tag list: --repo USER/REPO required"
  local owner="${APIMGR_REPO%/*}"; owner="${owner#~}"
  local name="${APIMGR_REPO##*/}"
  __sourcehut_api git GET "/~$owner/repos/$name/refs" |
    __apimgr_jq -r '.results[]? | select(.name | startswith("refs/tags/")) | {name: (.name | sub("refs/tags/"; "")), target: .target} | "\(.name)\t\(.target[0:12])"' |
    awk -F'\t' '{printf "%-30s %-12s\n", $1, $2}'
}
__sourcehut_issue_unsupported() {
  __apimgr_die "sourcehut: tickets live in todo.sr.ht (a separate service decoupled from repos). Use 'apimgr sourcehut api /trackers' for raw access."
}
__sourcehut_pr_unsupported() {
  __apimgr_die "sourcehut: pull requests are mailing-list patches in lists.sr.ht — incompatible with apimgr's PR model. Use git send-email or 'apimgr sourcehut api /lists/...' for raw access."
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== OneDev provider (per-instance /~api — modern self-host forge) ==============
# Auth: Bearer token (OneDev access tokens). URL is per-instance — set ONEDEV_API_URL to your install
# (e.g. https://onedev.example.com/~api). Internally OneDev uses numeric IDs; named lookups go via
# the project-by-name endpoint, then subsequent calls use the resolved id.
__onedev_curl() {
  local token; token="$(__apimgr_provider_token onedev)" || return 1
  __apimgr_curl -H "Authorization: Bearer $token" -H "Accept: application/json" "$@"
}
__onedev_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url onedev)" || return 1
  if [ -n "$data" ]; then
    __onedev_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __onedev_curl -X "$method" "$base$path"
  fi
}
# Resolve a project name (or USER/REPO path) to a numeric id. Cached in APIMGR_ONEDEV_PROJECT_ID for
# the invocation so multiple actions on the same repo only pay one lookup.
__onedev_project_id() {
  if [ -n "$APIMGR_ONEDEV_PROJECT_ID" ]; then printf '%s' "$APIMGR_ONEDEV_PROJECT_ID"; return 0; fi
  __apimgr_resolve_repo || __apimgr_die "onedev: --repo USER/REPO required"
  # OneDev's API takes a path-style query for finding the project. Strip any leading namespace if user
  # passed a github-style "user/repo" — OneDev itself uses path slashes natively.
  local resp; resp="$(__onedev_api GET "/projects?name=$APIMGR_REPO")"
  APIMGR_ONEDEV_PROJECT_ID="$(__apimgr_jq -r 'if type == "array" then .[0].id else .id // empty end' <<<"$resp" 2>/dev/null)"
  [ -n "$APIMGR_ONEDEV_PROJECT_ID" ] || __apimgr_die "onedev: project '$APIMGR_REPO' not found"
  printf '%s' "$APIMGR_ONEDEV_PROJECT_ID"
}
__onedev_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.id)\t\(.name)\t\(.description // "")\t\(.defaultBranch // "")"' |
    awk -F'\t' '{printf "%-6s %-40s %-40s %s\n", $1, $2, substr($3,1,40), $4}'
}
__onedev_print_repo() {
  __apimgr_jq -r '
    "ID:          \(.id)",
    "Name:        \(.name)",
    "Description: \(.description // "")",
    "Default:     \(.defaultBranch // "")",
    "Created:     \(.createDate // "")"
  '
}
__onedev_print_issue_list() {
  __apimgr_jq -r '.[] | "#\(.number)\t\(.state)\t\(.submitter.name // "")\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-8s %-20s %s\n", $1, $2, substr($3,1,20), $4}'
}
__onedev_verify() {
  __apimgr_require_creds onedev
  local resp; resp="$(__onedev_api GET /me)" || __apimgr_die "OneDev /me call failed"
  __apimgr_jq -r '"Authenticated as \(.name) (\(.fullName // "no name"))"' <<<"$resp"
}
__onedev_user_get() {
  __apimgr_require_creds onedev
  if [ -n "$APIMGR_USER" ]; then
    __onedev_api GET "/users?name=$APIMGR_USER" | __apimgr_jq '.[0] // empty'
  else
    __onedev_api GET /me | __apimgr_jq .
  fi
}
__onedev_repo_list() {
  __apimgr_require_creds onedev
  __onedev_api GET "/projects?count=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __onedev_print_repo_list
}
__onedev_repo_get() {
  __apimgr_require_creds onedev
  local id; id="$(__onedev_project_id)"
  __onedev_api GET "/projects/$id" | __onedev_print_repo
}
__onedev_repo_create() {
  __apimgr_require_creds onedev
  local name="${APIMGR_REPO##*/}"
  [ -n "$name" ] || __apimgr_die "onedev repo create: --repo NAME (or PARENT/NAME) required"
  # Note: OneDev project create takes a JSON body with name + optional description + parent. Parent is by id.
  local payload; payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" '{name:$n, description:$d}')"
  __onedev_api POST "/projects" "$payload" | __apimgr_jq -r '"Created project #\(.) — onedev assigns a numeric id"'
}
__onedev_repo_delete() {
  __apimgr_require_creds onedev
  local id; id="$(__onedev_project_id)"
  __apimgr_confirm "Delete OneDev project '$APIMGR_REPO' (id=$id)? Irreversible." || { printf_yellow "Aborted"; return 1; }
  __onedev_api DELETE "/projects/$id" >/dev/null && printf_green "Deleted project '$APIMGR_REPO'"
}
__onedev_issue_list() {
  __apimgr_require_creds onedev
  local id; id="$(__onedev_project_id)"
  local q="?count=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  case "${APIMGR_STATE:-open}" in open) q="$q&state=Open" ;; closed) q="$q&state=Closed" ;; esac
  __onedev_api GET "/projects/$id/issues$q" | __onedev_print_issue_list
}
__onedev_issue_get() {
  local n="$1"
  __apimgr_require_creds onedev
  local id; id="$(__onedev_project_id)"
  [ -n "$n" ] || __apimgr_die "onedev issue get: issue NUMBER required"
  __onedev_api GET "/projects/$id/issues/$n" | __apimgr_jq .
}
__onedev_issue_create() {
  __apimgr_require_creds onedev
  local id; id="$(__onedev_project_id)"
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "onedev issue create: --title required"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" '{title:$t, description:$b}')"
  __onedev_api POST "/projects/$id/issues" "$payload" | __apimgr_jq -r '"Created issue #\(.number)"'
}
__onedev_pr_list() {
  __apimgr_require_creds onedev
  local id; id="$(__onedev_project_id)"
  __onedev_api GET "/projects/$id/pull-requests?count=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" |
    __apimgr_jq -r '.[] | "#\(.number)\t\(.status)\t\(.submitter.name // "")\t\(.sourceBranch)→\(.targetBranch)\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-12s %-18s %-30s %s\n", $1, substr($2,1,12), substr($3,1,18), substr($4,1,30), $5}'
}
__onedev_pr_get() {
  local n="$1"
  __apimgr_require_creds onedev
  local id; id="$(__onedev_project_id)"
  [ -n "$n" ] || __apimgr_die "onedev pr get: PR NUMBER required"
  __onedev_api GET "/projects/$id/pull-requests/$n" | __apimgr_jq .
}
__onedev_tag_list() {
  __apimgr_require_creds onedev
  local id; id="$(__onedev_project_id)"
  __onedev_api GET "/projects/$id/tags" | __apimgr_print_git_tag_list
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Docker Hub provider (hub.docker.com/v2 — JWT auth via login flow) ==============
# Auth model: POST /users/login with {username, password} returns {token: <jwt>}; subsequent calls send
# `Authorization: JWT <token>`. The "password" is your Personal Access Token (DOCKER_HUB_API_KEY).
# JWT is cached in APIMGR_DOCKER_JWT for the duration of one apimgr invocation, then discarded.
__docker_login() {
  [ -n "$APIMGR_DOCKER_JWT" ] && return 0
  local user pass base resp
  base="$(__apimgr_provider_url docker)" || return 1
  user="$(__apimgr_provider_username docker)" || __apimgr_die "docker: no username — set DOCKER_USERNAME or APIMGR_DOCKER_USERNAME"
  pass="$(__apimgr_provider_token docker)" || return 1
  local payload; payload="$(__apimgr_jq -n --arg u "$user" --arg p "$pass" '{username:$u, password:$p}')"
  resp="$(__apimgr_curl -X POST -H "Content-Type: application/json" -H "Accept: application/json" --data "$payload" "$base/users/login/" 2>/dev/null)"
  APIMGR_DOCKER_JWT="$(__apimgr_jq -r '.token // empty' <<<"$resp")"
  [ -n "$APIMGR_DOCKER_JWT" ] || return 1
}
__docker_curl() {
  __docker_login || return 1
  __apimgr_curl -H "Authorization: JWT $APIMGR_DOCKER_JWT" -H "Accept: application/json" "$@"
}
__docker_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url docker)" || return 1
  if [ -n "$data" ]; then
    __docker_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __docker_curl -X "$method" "$base$path"
  fi
}
# Decode the username field from the cached JWT payload. Used as a default namespace for `repo list` / `user get`
# when --user / --org aren't passed. JWT bodies are base64url-encoded; we pad and decode.
__docker_jwt_user() {
  __docker_login >/dev/null || return 1
  local body="${APIMGR_DOCKER_JWT#*.}"; body="${body%%.*}"
  local pad=$(( 4 - ${#body} % 4 )); [ "$pad" -lt 4 ] && body="$body$(printf '=%.0s' $(seq 1 "$pad"))"
  printf '%s' "$body" | tr '_-' '/+' | base64 -d 2>/dev/null | __apimgr_jq -r '.username // .sub // empty'
}
# Docker-shaped formatters.
__docker_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.namespace)/\(.name)\t\(.description // "")\t\(.is_private)\t\(.pull_count // 0)"' |
    awk -F'\t' '{printf "%-40s %-40s %-9s %s pulls\n", $1, substr($2,1,40), ($3=="true"?"private":"public"), $4}'
}
__docker_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.namespace)/\(.name)",
    "Description: \(.description // "")",
    "Visibility:  \(if .is_private then "private" else "public" end)",
    "Pulls:       \(.pull_count // 0)",
    "Stars:       \(.star_count // 0)",
    "Updated:     \(.last_updated // "")",
    "",
    "\(.full_description // "")"
  '
}
__docker_print_tag_list() {
  __apimgr_jq -r '.[] | "\(.name)\t\(.full_size // 0)\t\(.last_updated // "")"' |
    awk -F'\t' '{ size = $2 / 1024 / 1024; printf "%-30s %8.1f MB  %s\n", $1, size, substr($3, 1, 19) }'
}
__docker_verify() {
  __apimgr_require_creds docker
  __docker_login || __apimgr_die "Docker Hub login failed (POST /users/login). Check DOCKER_USERNAME + DOCKER_HUB_API_KEY."
  local who; who="$(__docker_jwt_user)"
  printf 'Authenticated as %s — https://hub.docker.com/u/%s\n' "$who" "$who"
}
__docker_user_get() {
  __apimgr_require_creds docker
  local who="${APIMGR_USER:-$(__docker_jwt_user)}"
  [ -n "$who" ] || __apimgr_die "docker user get: --user NAME required (or login first via verify)"
  __docker_api GET "/users/$who/" | __apimgr_jq .
}
__docker_org_get() {
  __apimgr_require_creds docker
  [ -n "$APIMGR_ORG" ] || __apimgr_die "docker org get: --org NAMESPACE required"
  __docker_api GET "/orgs/$APIMGR_ORG/" | __apimgr_jq .
}
__docker_org_all() {
  __apimgr_require_creds docker
  [ -n "$APIMGR_ORG" ] || __apimgr_die "docker org all: --org NAMESPACE required"
  __docker_api GET "/repositories/$APIMGR_ORG/?page_size=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_jq '.results // .' | __docker_print_repo_list
}
__docker_repo_list() {
  __apimgr_require_creds docker
  local ns="${APIMGR_USER:-${APIMGR_ORG:-$(__docker_jwt_user)}}"
  [ -n "$ns" ] || __apimgr_die "docker repo list: namespace unresolved — pass --user or --org"
  __docker_api GET "/repositories/$ns/?page_size=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_jq '.results // .' | __docker_print_repo_list
}
__docker_repo_get() {
  __apimgr_require_creds docker
  __apimgr_resolve_repo || __apimgr_die "docker repo get: --repo NAMESPACE/NAME required"
  __docker_api GET "/repositories/$APIMGR_REPO/" | __docker_print_repo
}
__docker_repo_delete() {
  __apimgr_require_creds docker
  __apimgr_resolve_repo || __apimgr_die "docker repo delete: --repo NAMESPACE/NAME required"
  __apimgr_confirm "Delete $APIMGR_REPO from Docker Hub? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __docker_api DELETE "/repositories/$APIMGR_REPO/" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__docker_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __docker_org_all; else __docker_repo_list; fi
}
__docker_tag_repo() { __apimgr_resolve_repo || __apimgr_die "docker tag: --repo NAMESPACE/NAME required"; }
__docker_tag_list() {
  __apimgr_require_creds docker
  __docker_tag_repo
  __docker_api GET "/repositories/$APIMGR_REPO/tags/?page_size=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_jq '.results // .' | __docker_print_tag_list
}
__docker_tag_get() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds docker
  __docker_tag_repo
  [ -n "$tag" ] || __apimgr_die "docker tag get: --tag NAME or positional TAG required"
  __docker_api GET "/repositories/$APIMGR_REPO/tags/$tag/" | __apimgr_jq .
}
__docker_tag_delete() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds docker
  __docker_tag_repo
  [ -n "$tag" ] || __apimgr_die "docker tag delete: --tag NAME or positional TAG required"
  __apimgr_confirm "Delete tag '$tag' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __docker_api DELETE "/repositories/$APIMGR_REPO/tags/$tag/" >/dev/null && printf_green "Deleted tag '$tag' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== GitHub Container Registry (ghcr.io — uses GitHub Packages API, not Distribution v2) ==============
# Conceptually a registry, but the management API is the regular GitHub one with /packages/container/* endpoints.
# Resolver chain reuses GHCR_API_URL/GHCR_ACCESS_TOKEN if set; users typically alias to GitHub's:
#   export GHCR_API_URL="$GITHUB_API_URL" GHCR_ACCESS_TOKEN="$GITHUB_ACCESS_TOKEN"
# The token must have read:packages / write:packages / delete:packages scopes.
__ghcr_curl() {
  local token; token="$(__apimgr_provider_token ghcr)" || return 1
  __apimgr_curl -H "Authorization: Bearer $token" -H "Accept: application/vnd.github+json" -H "X-GitHub-Api-Version: 2022-11-28" "$@"
}
__ghcr_api()  { local base; base="$(__apimgr_provider_url ghcr)" || return 1; __ghcr_curl -X "${1:-GET}" "$base$2"; }
__ghcr_post() { local base; base="$(__apimgr_provider_url ghcr)" || return 1; __ghcr_curl -X "${1:-POST}" -H "Content-Type: application/json" --data "$3" "$base$2"; }
# ghcr-shaped formatters (different field names from Hub: .name, .owner.login, .visibility, .updated_at).
__ghcr_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.owner.login)/\(.name)\t\(.visibility)\t\(.version_count // 0)\t\(.updated_at // "")"' |
    awk -F'\t' '{printf "%-45s %-9s %3d versions  %s\n", $1, $2, $3, substr($4,1,19)}'
}
__ghcr_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.owner.login)/\(.name)",
    "URL:         \(.html_url // "")",
    "Visibility:  \(.visibility)",
    "Versions:    \(.version_count // 0)",
    "Updated:     \(.updated_at // "")"
  '
}
__ghcr_print_tag_list() {
  __apimgr_jq -r '.[] | "\(.metadata.container.tags[0] // "untagged")\t\(.id)\t\(.name[0:12])\t\(.updated_at // "")"' |
    awk -F'\t' '{printf "%-30s %12s  %-14s %s\n", $1, $2, $3, substr($4,1,19)}'
}
__ghcr_verify() {
  __apimgr_require_creds ghcr
  # /user works the same on github.com — confirms the token + checks read:packages by listing one container.
  local resp; resp="$(__ghcr_api GET /user)" || __apimgr_die "GHCR /user call failed (token needs read:packages scope)"
  __apimgr_jq -r '"Authenticated as \(.login) (\(.name // "no name")) — packages.scope verified via /user/packages"' <<<"$resp"
}
__ghcr_user_get() {
  __apimgr_require_creds ghcr
  local who="${APIMGR_USER:-}"
  if [ -n "$who" ]; then __ghcr_api GET "/users/$who" | __apimgr_jq .
  else __ghcr_api GET /user | __apimgr_jq .
  fi
}
__ghcr_org_get() {
  __apimgr_require_creds ghcr
  [ -n "$APIMGR_ORG" ] || __apimgr_die "ghcr org get: --org NAME required"
  __ghcr_api GET "/orgs/$APIMGR_ORG" | __apimgr_jq .
}
__ghcr_org_all() {
  __apimgr_require_creds ghcr
  [ -n "$APIMGR_ORG" ] || __apimgr_die "ghcr org all: --org NAME required"
  __ghcr_api GET "/orgs/$APIMGR_ORG/packages?package_type=container&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __ghcr_print_repo_list
}
__ghcr_repo_list() {
  __apimgr_require_creds ghcr
  if [ -n "$APIMGR_ORG" ]; then
    __ghcr_org_all
  elif [ -n "$APIMGR_USER" ]; then
    __ghcr_api GET "/users/$APIMGR_USER/packages?package_type=container&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __ghcr_print_repo_list
  else
    __ghcr_api GET "/user/packages?package_type=container&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __ghcr_print_repo_list
  fi
}
# Resolve OWNER and NAME from --repo OWNER/NAME. Sets GHCR_OWNER and GHCR_NAME for action helpers.
__ghcr_split_repo() {
  __apimgr_resolve_repo || __apimgr_die "ghcr: --repo OWNER/NAME required (where NAME is the container package name)"
  GHCR_OWNER="${APIMGR_REPO%/*}"
  GHCR_NAME="${APIMGR_REPO##*/}"
  [ -n "$GHCR_OWNER" ] && [ -n "$GHCR_NAME" ] && [ "$GHCR_OWNER" != "$GHCR_NAME" ] || __apimgr_die "ghcr: --repo OWNER/NAME required"
}
# Whether the repo owner matches the authed user — different endpoint paths for self-owned vs other.
__ghcr_owner_is_self() {
  local me; me="$(__ghcr_api GET /user | __apimgr_jq -r '.login // empty')"
  [ -n "$me" ] && [ "$GHCR_OWNER" = "$me" ]
}
__ghcr_repo_get() {
  __apimgr_require_creds ghcr
  __ghcr_split_repo
  if __ghcr_owner_is_self; then
    __ghcr_api GET "/user/packages/container/$GHCR_NAME" | __ghcr_print_repo
  else
    # Try as user package, fall back to org. (GitHub's API differs based on whether owner is user or org.)
    __ghcr_api GET "/users/$GHCR_OWNER/packages/container/$GHCR_NAME" 2>/dev/null | __ghcr_print_repo \
      || __ghcr_api GET "/orgs/$GHCR_OWNER/packages/container/$GHCR_NAME" | __ghcr_print_repo
  fi
}
__ghcr_repo_create() {
  __apimgr_die "ghcr: container packages are created by 'docker push ghcr.io/OWNER/NAME:TAG'. There is no API to pre-create a package."
}
__ghcr_repo_delete() {
  __apimgr_require_creds ghcr
  __ghcr_split_repo
  __apimgr_confirm "Delete container package $APIMGR_REPO from GHCR? This deletes ALL versions and is irreversible." || { printf_yellow "Aborted"; return 1; }
  if __ghcr_owner_is_self; then
    __ghcr_api DELETE "/user/packages/container/$GHCR_NAME" >/dev/null && printf_green "Deleted package $APIMGR_REPO"
  else
    # Org package delete uses /orgs path. The docs require admin permission.
    __ghcr_api DELETE "/orgs/$GHCR_OWNER/packages/container/$GHCR_NAME" >/dev/null && printf_green "Deleted package $APIMGR_REPO"
  fi
}
__ghcr_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __ghcr_org_all; else __ghcr_repo_list; fi
}
__ghcr_tag_list() {
  __apimgr_require_creds ghcr
  __ghcr_split_repo
  if __ghcr_owner_is_self; then
    __ghcr_api GET "/user/packages/container/$GHCR_NAME/versions?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __ghcr_print_tag_list
  else
    __ghcr_api GET "/users/$GHCR_OWNER/packages/container/$GHCR_NAME/versions?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" 2>/dev/null | __ghcr_print_tag_list \
      || __ghcr_api GET "/orgs/$GHCR_OWNER/packages/container/$GHCR_NAME/versions?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __ghcr_print_tag_list
  fi
}
# GHCR addresses versions by numeric id, not by tag name. Resolve a tag → id via the versions list.
__ghcr_resolve_version_id() {
  local tag="$1" base_path="$2"
  __ghcr_api GET "$base_path/versions?per_page=100" |
    __apimgr_jq -r --arg t "$tag" '.[] | select((.metadata.container.tags // []) | index($t)) | .id' | head -n1
}
__ghcr_tag_get() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds ghcr
  __ghcr_split_repo
  [ -n "$tag" ] || __apimgr_die "ghcr tag get: --tag NAME or positional TAG required"
  local path="/user/packages/container/$GHCR_NAME"
  __ghcr_owner_is_self || path="/users/$GHCR_OWNER/packages/container/$GHCR_NAME"
  local id; id="$(__ghcr_resolve_version_id "$tag" "$path")"
  [ -n "$id" ] || __apimgr_die "ghcr tag get: tag '$tag' not found in $APIMGR_REPO"
  __ghcr_api GET "$path/versions/$id" | __apimgr_jq .
}
__ghcr_tag_delete() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds ghcr
  __ghcr_split_repo
  [ -n "$tag" ] || __apimgr_die "ghcr tag delete: --tag NAME or positional TAG required"
  __apimgr_confirm "Delete tag '$tag' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  local path="/user/packages/container/$GHCR_NAME"
  __ghcr_owner_is_self || path="/orgs/$GHCR_OWNER/packages/container/$GHCR_NAME"
  local id; id="$(__ghcr_resolve_version_id "$tag" "$path")"
  [ -n "$id" ] || __apimgr_die "ghcr tag delete: tag '$tag' not found in $APIMGR_REPO"
  __ghcr_api DELETE "$path/versions/$id" >/dev/null && printf_green "Deleted tag '$tag' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== GitLab Container Registry (glcr — uses GitLab's project-scoped /registry endpoints) ==============
# Like ghcr, glcr is conceptually a registry but the management API rides on the host forge's REST surface.
# Resolver chain reuses GLCR_API_URL/GLCR_ACCESS_TOKEN if set; users typically alias to GitLab's:
#   export GLCR_API_URL="$GITLAB_API_URL" GLCR_ACCESS_TOKEN="$GITLAB_ACCESS_TOKEN"
# The token must have api or read_registry / write_registry scope. Falls back to gitlab's URL/token if the
# glcr-specific vars aren't set — convenience for the common case where they share creds.
__glcr_curl() {
  local token; token="$(__apimgr_provider_token glcr 2>/dev/null)"
  [ -n "$token" ] || token="$(__apimgr_provider_token gitlab)" || return 1
  __apimgr_curl -H "PRIVATE-TOKEN: $token" -H "Accept: application/json" "$@"
}
__glcr_url() {
  local url; url="$(__apimgr_provider_url glcr 2>/dev/null)"
  [ -n "$url" ] || url="$(__apimgr_provider_url gitlab)" || return 1
  printf '%s' "$url"
}
__glcr_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__glcr_url)" || return 1
  if [ -n "$data" ]; then
    __glcr_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __glcr_curl -X "$method" "$base$path"
  fi
}
__glcr_require_creds() {
  __glcr_url >/dev/null || __apimgr_die "No URL for 'glcr' — set GLCR_API_URL/APIMGR_GLCR_URL or GITLAB_API_URL (the registry rides on GitLab's API)"
  local t; t="$(__apimgr_provider_token glcr 2>/dev/null)"; [ -n "$t" ] || t="$(__apimgr_provider_token gitlab 2>/dev/null)"
  [ -n "$t" ] || __apimgr_die "No token for 'glcr' — set GLCR_ACCESS_TOKEN, APIMGR_GLCR_TOKEN, GITLAB_ACCESS_TOKEN, or pass --token"
}
__glcr_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.id)\t\(.path)\t\(.tags_count // 0)\t\(.location // "")"' |
    awk -F'\t' '{printf "%-6s %-50s %3d tag(s)  %s\n", $1, substr($2,1,50), $3, $4}'
}
__glcr_print_repo() {
  __apimgr_jq -r '
    "ID:          \(.id)",
    "Path:        \(.path)",
    "Project:     \(.project_id)",
    "Location:    \(.location)",
    "Tags count:  \(.tags_count // 0)",
    "Created:     \(.created_at // "")"
  '
}
__glcr_print_tag_list() {
  __apimgr_jq -r '.[] | "\(.name)\t\(.short_revision // .revision[0:12] // "")\t\(.total_size // 0)\t\(.created_at // "")"' |
    awk -F'\t' '{ size = $3 / 1024 / 1024; printf "%-30s %-14s %8.1f MB  %s\n", $1, $2, size, substr($4, 1, 19) }'
}
__glcr_verify() {
  __glcr_require_creds
  # /user works the same on gitlab — confirms the token + (implicitly) the registry scope when listing happens.
  __glcr_api GET /user | __apimgr_jq -r '"Authenticated as \(.username) (\(.name // "no name")) — registry access via project-scoped endpoints"'
}
# Resolve a project's registry repository ID from --repo PROJECT/IMAGE. PROJECT is the gitlab project path
# (group/proj), IMAGE is the registry repo's name within that project. Returns the registry-repo id by
# listing /projects/<enc>/registry/repositories and matching against the trailing path segment.
__glcr_split_repo() {
  __apimgr_resolve_repo || __apimgr_die "glcr: --repo PROJECT_PATH (or PROJECT_PATH/IMAGE) required"
  # The path may have 2 or 3 segments; we use everything except the last as project, last as image (optional).
  if [[ "$APIMGR_REPO" == */*/* ]]; then
    GLCR_PROJECT_PATH="${APIMGR_REPO%/*}"
    GLCR_IMAGE_NAME="${APIMGR_REPO##*/}"
  else
    GLCR_PROJECT_PATH="$APIMGR_REPO"
    GLCR_IMAGE_NAME=""
  fi
}
__glcr_resolve_registry_id() {
  local image="$1"
  local list; list="$(__glcr_api GET "/projects/$(__gitlab_urlenc "$GLCR_PROJECT_PATH")/registry/repositories")"
  if [ -z "$image" ]; then
    __apimgr_jq -r '.[0].id // empty' <<<"$list"
  else
    __apimgr_jq -r --arg n "$image" '.[] | select(.path | endswith("/" + $n) or (. == $n)) | .id' <<<"$list" | head -n1
  fi
}
__glcr_repo_list() {
  __glcr_require_creds
  __glcr_split_repo
  [ -n "$GLCR_PROJECT_PATH" ] || __apimgr_die "glcr repo list: --repo PROJECT_PATH required"
  __glcr_api GET "/projects/$(__gitlab_urlenc "$GLCR_PROJECT_PATH")/registry/repositories?tags=true&tags_count=true&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __glcr_print_repo_list
}
__glcr_repo_get() {
  __glcr_require_creds
  __glcr_split_repo
  [ -n "$GLCR_PROJECT_PATH" ] || __apimgr_die "glcr repo get: --repo PROJECT_PATH/IMAGE required"
  local id; id="$(__glcr_resolve_registry_id "$GLCR_IMAGE_NAME")"
  [ -n "$id" ] || __apimgr_die "glcr repo get: registry repository not found in project '$GLCR_PROJECT_PATH'${GLCR_IMAGE_NAME:+ matching '$GLCR_IMAGE_NAME'}"
  __glcr_api GET "/registry/repositories/$id?tags=true&tags_count=true" | __glcr_print_repo
}
__glcr_repo_delete() {
  __glcr_require_creds
  __glcr_split_repo
  local id; id="$(__glcr_resolve_registry_id "$GLCR_IMAGE_NAME")"
  [ -n "$id" ] || __apimgr_die "glcr repo delete: registry repository not found"
  __apimgr_confirm "Delete GitLab registry repository id=$id from '$GLCR_PROJECT_PATH'? Removes ALL tags. Irreversible." || { printf_yellow "Aborted"; return 1; }
  __glcr_api DELETE "/registry/repositories/$id" >/dev/null && printf_green "Deleted registry repository id=$id"
}
__glcr_tag_list() {
  __glcr_require_creds
  __glcr_split_repo
  local id; id="$(__glcr_resolve_registry_id "$GLCR_IMAGE_NAME")"
  [ -n "$id" ] || __apimgr_die "glcr tag list: registry repository not found"
  __glcr_api GET "/projects/$(__gitlab_urlenc "$GLCR_PROJECT_PATH")/registry/repositories/$id/tags?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __glcr_print_tag_list
}
__glcr_tag_get() {
  local tag="${APIMGR_TAG:-$1}"
  __glcr_require_creds
  __glcr_split_repo
  [ -n "$tag" ] || __apimgr_die "glcr tag get: --tag NAME or positional TAG required"
  local id; id="$(__glcr_resolve_registry_id "$GLCR_IMAGE_NAME")"
  [ -n "$id" ] || __apimgr_die "glcr tag get: registry repository not found"
  __glcr_api GET "/projects/$(__gitlab_urlenc "$GLCR_PROJECT_PATH")/registry/repositories/$id/tags/$tag" | __apimgr_jq .
}
__glcr_tag_delete() {
  local tag="${APIMGR_TAG:-$1}"
  __glcr_require_creds
  __glcr_split_repo
  [ -n "$tag" ] || __apimgr_die "glcr tag delete: --tag NAME or positional TAG required"
  local id; id="$(__glcr_resolve_registry_id "$GLCR_IMAGE_NAME")"
  [ -n "$id" ] || __apimgr_die "glcr tag delete: registry repository not found"
  __apimgr_confirm "Delete tag '$tag' from $GLCR_PROJECT_PATH (registry id=$id)?" || { printf_yellow "Aborted"; return 1; }
  __glcr_api DELETE "/projects/$(__gitlab_urlenc "$GLCR_PROJECT_PATH")/registry/repositories/$id/tags/$tag" >/dev/null && printf_green "Deleted tag '$tag'"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Harbor provider (api/v2.0 — Basic auth or robot tokens; project + repository_name model) ==============
# Auth: Basic <base64(username:password)> when both HARBOR_USERNAME and HARBOR_ACCESS_TOKEN are set;
# falls back to Bearer when only the token is available (some Harbor deployments behind OIDC accept Bearer too).
__harbor_curl() {
  local pass; pass="$(__apimgr_provider_token harbor)" || return 1
  local user; user="$(__apimgr_provider_username harbor 2>/dev/null)"
  if [ -n "$user" ]; then
    local creds; creds="$(printf '%s:%s' "$user" "$pass" | base64 -w0)"
    __apimgr_curl -H "Authorization: Basic $creds" -H "Accept: application/json" "$@"
  else
    __apimgr_curl -H "Authorization: Bearer $pass" -H "Accept: application/json" "$@"
  fi
}
__harbor_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url harbor)" || return 1
  if [ -n "$data" ]; then
    __harbor_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __harbor_curl -X "$method" "$base$path"
  fi
}
# Harbor's repo paths are PROJECT/REPONAME, where REPONAME may itself contain slashes (subgroups). Split on the
# first / and URL-encode the rest. Sets HARBOR_PROJECT and HARBOR_REPO_NAME_ENC.
__harbor_split_repo() {
  __apimgr_resolve_repo || __apimgr_die "harbor: --repo PROJECT/REPONAME required"
  HARBOR_PROJECT="${APIMGR_REPO%%/*}"
  local rest="${APIMGR_REPO#*/}"
  HARBOR_REPO_NAME_ENC="${rest//\//%2F}"
}
__harbor_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.name)\t\(.description // "")\t\(.artifact_count // 0)\t\(.pull_count // 0)"' |
    awk -F'\t' '{printf "%-50s %-40s %4d artifacts  %s pulls\n", $1, substr($2,1,40), $3, $4}'
}
__harbor_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.name)",
    "Project:     \(.project_id)",
    "Description: \(.description // "")",
    "Artifacts:   \(.artifact_count // 0)",
    "Pulls:       \(.pull_count // 0)",
    "Updated:     \(.update_time // "")"
  '
}
# Harbor's tag list is harvested from /artifacts?with_tag=true — each artifact has .tags[] with .name and push_time.
__harbor_print_tag_list() {
  __apimgr_jq -r '.[] | . as $a | (.tags // []) | .[] | "\(.name)\t\($a.size // 0)\t\(.push_time // "")"' |
    awk -F'\t' '{ size = $2 / 1024 / 1024; printf "%-30s %8.1f MB  %s\n", $1, size, substr($3, 1, 19) }'
}
__harbor_verify() {
  __apimgr_require_creds harbor
  local resp; resp="$(__harbor_api GET /users/current)" || __apimgr_die "Harbor /users/current call failed"
  __apimgr_jq -r '"Authenticated as \(.username) (\(.realname // "no name"))"' <<<"$resp"
}
__harbor_user_get() {
  __apimgr_require_creds harbor
  if [ -n "$APIMGR_USER" ]; then
    __harbor_api GET "/users/search?username=$APIMGR_USER" | __apimgr_jq '.[0] // empty'
  else
    __harbor_api GET /users/current | __apimgr_jq .
  fi
}
__harbor_org_get() {
  __apimgr_require_creds harbor
  [ -n "$APIMGR_ORG" ] || __apimgr_die "harbor org get: --org PROJECT required"
  __harbor_api GET "/projects/$APIMGR_ORG" | __apimgr_jq .
}
__harbor_org_all() {
  __apimgr_require_creds harbor
  [ -n "$APIMGR_ORG" ] || __apimgr_die "harbor org all: --org PROJECT required"
  __harbor_api GET "/projects/$APIMGR_ORG/repositories?page_size=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __harbor_print_repo_list
}
__harbor_repo_list() {
  __apimgr_require_creds harbor
  local proj="${APIMGR_ORG:-${APIMGR_USER:-}}"
  [ -n "$proj" ] || __apimgr_die "harbor repo list: --org PROJECT (or --user) required to scope the listing"
  __harbor_api GET "/projects/$proj/repositories?page_size=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __harbor_print_repo_list
}
__harbor_repo_get() {
  __apimgr_require_creds harbor
  __harbor_split_repo
  __harbor_api GET "/projects/$HARBOR_PROJECT/repositories/$HARBOR_REPO_NAME_ENC" | __harbor_print_repo
}
__harbor_repo_delete() {
  __apimgr_require_creds harbor
  __harbor_split_repo
  __apimgr_confirm "Delete $APIMGR_REPO from Harbor? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __harbor_api DELETE "/projects/$HARBOR_PROJECT/repositories/$HARBOR_REPO_NAME_ENC" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__harbor_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __harbor_org_all; else __harbor_repo_list; fi
}
__harbor_tag_list() {
  __apimgr_require_creds harbor
  __harbor_split_repo
  __harbor_api GET "/projects/$HARBOR_PROJECT/repositories/$HARBOR_REPO_NAME_ENC/artifacts?with_tag=true&page_size=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __harbor_print_tag_list
}
__harbor_tag_get() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds harbor
  __harbor_split_repo
  [ -n "$tag" ] || __apimgr_die "harbor tag get: --tag NAME or positional TAG required"
  # Harbor's artifact ref accepts a tag name directly.
  __harbor_api GET "/projects/$HARBOR_PROJECT/repositories/$HARBOR_REPO_NAME_ENC/artifacts/$tag?with_tag=true" | __apimgr_jq .
}
__harbor_tag_delete() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds harbor
  __harbor_split_repo
  [ -n "$tag" ] || __apimgr_die "harbor tag delete: --tag NAME or positional TAG required"
  __apimgr_confirm "Delete tag '$tag' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  # Harbor: DELETE the tag (the artifact itself stays unless no tags remain and GC runs).
  __harbor_api DELETE "/projects/$HARBOR_PROJECT/repositories/$HARBOR_REPO_NAME_ENC/artifacts/$tag/tags/$tag" >/dev/null && printf_green "Deleted tag '$tag' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Quay provider (api/v1 — Bearer auth; namespace + repository model) ==============
__quay_curl() {
  local token; token="$(__apimgr_provider_token quay)" || return 1
  __apimgr_curl -H "Authorization: Bearer $token" -H "Accept: application/json" "$@"
}
__quay_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url quay)" || return 1
  if [ -n "$data" ]; then
    __quay_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __quay_curl -X "$method" "$base$path"
  fi
}
__quay_print_repo_list() {
  __apimgr_jq -r '.repositories[]? // .[]? | "\(.namespace)/\(.name)\t\(.description // "")\t\(.is_public)\t\(.popularity // 0)"' |
    awk -F'\t' '{printf "%-40s %-40s %-9s %s pop\n", $1, substr($2,1,40), ($3=="true"?"public":"private"), $4}'
}
__quay_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.namespace)/\(.name)",
    "Description: \(.description // "")",
    "Visibility:  \(if .is_public then "public" else "private" end)",
    "Trust:       \(.trust_enabled // false)",
    "Updated:     \(.last_modified // "")"
  '
}
__quay_print_tag_list() {
  __apimgr_jq -r '.tags[]? // .[]? | "\(.name)\t\(.size // 0)\t\(.last_modified // "")"' |
    awk -F'\t' '{ size = $2 / 1024 / 1024; printf "%-30s %8.1f MB  %s\n", $1, size, substr($3, 1, 19) }'
}
__quay_verify() {
  __apimgr_require_creds quay
  local resp; resp="$(__quay_api GET /user/)" || __apimgr_die "Quay /user/ call failed"
  __apimgr_jq -r '"Authenticated as \(.username) (\(.email // "no email"))"' <<<"$resp"
}
__quay_user_get() {
  __apimgr_require_creds quay
  if [ -n "$APIMGR_USER" ]; then
    __quay_api GET "/users/$APIMGR_USER" | __apimgr_jq .
  else
    __quay_api GET /user/ | __apimgr_jq .
  fi
}
__quay_org_get() {
  __apimgr_require_creds quay
  [ -n "$APIMGR_ORG" ] || __apimgr_die "quay org get: --org NAMESPACE required"
  __quay_api GET "/organization/$APIMGR_ORG" | __apimgr_jq .
}
__quay_org_all() {
  __apimgr_require_creds quay
  [ -n "$APIMGR_ORG" ] || __apimgr_die "quay org all: --org NAMESPACE required"
  __quay_api GET "/repository?namespace=$APIMGR_ORG&public=true" | __quay_print_repo_list
}
__quay_repo_list() {
  __apimgr_require_creds quay
  local ns="${APIMGR_USER:-${APIMGR_ORG:-}}"
  if [ -z "$ns" ]; then
    # Quay's /user/ response contains username; use it as the default namespace.
    ns="$(__quay_api GET /user/ | __apimgr_jq -r '.username // empty')"
  fi
  [ -n "$ns" ] || __apimgr_die "quay repo list: namespace unresolved"
  __quay_api GET "/repository?namespace=$ns" | __quay_print_repo_list
}
__quay_repo_get() {
  __apimgr_require_creds quay
  __apimgr_resolve_repo || __apimgr_die "quay repo get: --repo NAMESPACE/NAME required"
  __quay_api GET "/repository/$APIMGR_REPO" | __quay_print_repo
}
__quay_repo_delete() {
  __apimgr_require_creds quay
  __apimgr_resolve_repo || __apimgr_die "quay repo delete: --repo NAMESPACE/NAME required"
  __apimgr_confirm "Delete $APIMGR_REPO from Quay? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __quay_api DELETE "/repository/$APIMGR_REPO" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__quay_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __quay_org_all; else __quay_repo_list; fi
}
__quay_tag_repo() { __apimgr_resolve_repo || __apimgr_die "quay tag: --repo NAMESPACE/NAME required"; }
__quay_tag_list() {
  __apimgr_require_creds quay
  __quay_tag_repo
  __quay_api GET "/repository/$APIMGR_REPO/tag/?onlyActiveTags=true&limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __quay_print_tag_list
}
__quay_tag_get() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds quay
  __quay_tag_repo
  [ -n "$tag" ] || __apimgr_die "quay tag get: --tag NAME or positional TAG required"
  __quay_api GET "/repository/$APIMGR_REPO/tag/?specificTag=$tag" | __apimgr_jq .
}
__quay_tag_delete() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds quay
  __quay_tag_repo
  [ -n "$tag" ] || __apimgr_die "quay tag delete: --tag NAME or positional TAG required"
  __apimgr_confirm "Delete tag '$tag' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __quay_api DELETE "/repository/$APIMGR_REPO/tag/$tag" >/dev/null && printf_green "Deleted tag '$tag' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Cloudsmith provider (api.cloudsmith.io/v1 — multi-format SaaS registry) ==============
# Auth: X-Api-Key header (Cloudsmith's canonical scheme; Authorization: Token also accepted but X-Api-Key is
# the documented form). Token resolver picks up CLOUDSMITH_API_KEY in addition to the standard chain.
# Cloudsmith's "tag" maps to package versions: each repo holds many packages, each package has a slug_perm
# that uniquely identifies it. apimgr's tag actions list/get/delete by package slug.
__cloudsmith_curl() {
  local token; token="$(__apimgr_provider_token cloudsmith)" || return 1
  __apimgr_curl -H "X-Api-Key: $token" -H "Accept: application/json" "$@"
}
__cloudsmith_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url cloudsmith)" || return 1
  if [ -n "$data" ]; then
    __cloudsmith_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __cloudsmith_curl -X "$method" "$base$path"
  fi
}
# Cloudsmith-shaped formatters — repos have .name, .namespace, .description, .repository_type_str, .num_packages.
__cloudsmith_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.namespace)/\(.name)\t\(.description // "")\t\(.repository_type_str // "")\t\(.num_packages // 0)"' |
    awk -F'\t' '{printf "%-40s %-40s %-10s %d pkg\n", $1, substr($2,1,40), $3, $4}'
}
__cloudsmith_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.namespace)/\(.name)",
    "Description: \(.description // "")",
    "Type:        \(.repository_type_str // "")",
    "Packages:    \(.num_packages // 0)",
    "Storage:     \(.size // 0) bytes",
    "Created:     \(.created_at // "")"
  '
}
# Cloudsmith packages → apimgr tags. Slug_perm is the addressing key; format is name@version-format.
__cloudsmith_print_tag_list() {
  __apimgr_jq -r '.[] | "\(.name)@\(.version)\t\(.slug_perm)\t\(.format)\t\(.size // 0)\t\(.uploaded_at // "")"' |
    awk -F'\t' '{ size = $4 / 1024 / 1024; printf "%-30s %-22s %-8s %8.1f MB  %s\n", $1, $2, $3, size, substr($5, 1, 19) }'
}
__cloudsmith_repo_check() { __apimgr_resolve_repo || __apimgr_die "cloudsmith: --repo NAMESPACE/REPO required"; }
__cloudsmith_verify() {
  __apimgr_require_creds cloudsmith
  local resp; resp="$(__cloudsmith_api GET /user/self/)" || __apimgr_die "Cloudsmith /user/self/ call failed"
  __apimgr_jq -r '"Authenticated as \(.slug) (\(.name // "no name")) — \(.email // "")"' <<<"$resp"
}
__cloudsmith_user_get() {
  __apimgr_require_creds cloudsmith
  if [ -n "$APIMGR_USER" ]; then
    # Cloudsmith doesn't expose arbitrary-user lookup; fall back to listing their repos.
    __apimgr_die "cloudsmith user get --user X: not exposed by API. Use 'apimgr cloudsmith repo list --user X' instead."
  fi
  __cloudsmith_api GET /user/self/ | __apimgr_jq .
}
__cloudsmith_org_get() {
  __apimgr_require_creds cloudsmith
  [ -n "$APIMGR_ORG" ] || __apimgr_die "cloudsmith org get: --org NAMESPACE required"
  __cloudsmith_api GET "/orgs/$APIMGR_ORG/" | __apimgr_jq .
}
__cloudsmith_org_all() {
  __apimgr_require_creds cloudsmith
  [ -n "$APIMGR_ORG" ] || __apimgr_die "cloudsmith org all: --org NAMESPACE required"
  __cloudsmith_api GET "/repos/$APIMGR_ORG/?page_size=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __cloudsmith_print_repo_list
}
__cloudsmith_repo_list() {
  __apimgr_require_creds cloudsmith
  local ns="${APIMGR_USER:-${APIMGR_ORG:-}}"
  if [ -z "$ns" ]; then
    ns="$(__cloudsmith_api GET /user/self/ | __apimgr_jq -r '.slug // empty')"
  fi
  [ -n "$ns" ] || __apimgr_die "cloudsmith repo list: namespace unresolved"
  __cloudsmith_api GET "/repos/$ns/?page_size=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __cloudsmith_print_repo_list
}
__cloudsmith_repo_get() {
  __apimgr_require_creds cloudsmith
  __cloudsmith_repo_check
  __cloudsmith_api GET "/repos/$APIMGR_REPO/" | __cloudsmith_print_repo
}
__cloudsmith_repo_create() {
  __apimgr_require_creds cloudsmith
  local name="${APIMGR_REPO##*/}" ns="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$ns" ] && [ "$ns" != "$name" ] || __apimgr_die "cloudsmith repo create: --repo NAMESPACE/NAME required"
  local visibility="${APIMGR_VISIBILITY:-public}"
  case "$visibility" in public) visibility="Public" ;; private) visibility="Private" ;; *) __apimgr_die "cloudsmith: --visibility must be public|private" ;; esac
  local payload; payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --arg v "$visibility" '{name:$n, slug:$n, description:$d, repository_type_str:$v}')"
  __cloudsmith_api POST "/repos/$ns/" "$payload" | __cloudsmith_print_repo
}
__cloudsmith_repo_delete() {
  __apimgr_require_creds cloudsmith
  __cloudsmith_repo_check
  __apimgr_confirm "Delete $APIMGR_REPO from Cloudsmith? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __cloudsmith_api DELETE "/repos/$APIMGR_REPO/" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__cloudsmith_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __cloudsmith_org_all; else __cloudsmith_repo_list; fi
}
__cloudsmith_tag_repo() { __apimgr_resolve_repo || __apimgr_die "cloudsmith tag: --repo NAMESPACE/REPO required"; }
__cloudsmith_tag_list() {
  __apimgr_require_creds cloudsmith
  __cloudsmith_tag_repo
  __cloudsmith_api GET "/packages/$APIMGR_REPO/?page_size=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __cloudsmith_print_tag_list
}
__cloudsmith_tag_get() {
  local slug="${APIMGR_TAG:-$1}"
  __apimgr_require_creds cloudsmith
  __cloudsmith_tag_repo
  [ -n "$slug" ] || __apimgr_die "cloudsmith tag get: --tag SLUG_PERM or positional SLUG required (find via 'tag list')"
  __cloudsmith_api GET "/packages/$APIMGR_REPO/$slug/" | __apimgr_jq .
}
__cloudsmith_tag_delete() {
  local slug="${APIMGR_TAG:-$1}"
  __apimgr_require_creds cloudsmith
  __cloudsmith_tag_repo
  [ -n "$slug" ] || __apimgr_die "cloudsmith tag delete: --tag SLUG_PERM or positional SLUG required"
  __apimgr_confirm "Delete package '$slug' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __cloudsmith_api DELETE "/packages/$APIMGR_REPO/$slug/" >/dev/null && printf_green "Deleted package '$slug' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== JFrog Artifactory provider (per-instance .jfrog.io/artifactory/api or self-host) ==============
# Auth: Bearer token (JFrog Access tokens / OAuth). Legacy X-JFrog-Art-Api header still works against older
# Artifactory installs but Bearer is the modern default. URL is per-instance — set ARTIFACTORY_API_URL to your
# org's instance (e.g. https://acme.jfrog.io/artifactory/api). Aliased as 'jfrog' for muscle memory.
__artifactory_curl() {
  local token; token="$(__apimgr_provider_token artifactory)" || return 1
  __apimgr_curl -H "Authorization: Bearer $token" -H "Accept: application/json" "$@"
}
__artifactory_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url artifactory)" || return 1
  if [ -n "$data" ]; then
    __artifactory_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __artifactory_curl -X "$method" "$base$path"
  fi
}
# Artifactory's repo metadata: .key, .description, .type (LOCAL/REMOTE/VIRTUAL), .packageType, .url.
__artifactory_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.key)\t\(.description // "")\t\(.type // "")\t\(.packageType // "")"' |
    awk -F'\t' '{printf "%-35s %-40s %-9s %s\n", $1, substr($2,1,40), $3, $4}'
}
__artifactory_print_repo() {
  __apimgr_jq -r '
    "Key:         \(.key)",
    "Type:        \(.type // "")",
    "Format:      \(.packageType // "")",
    "Description: \(.description // "")",
    "URL:         \(.url // "")",
    "Notes:       \(.notes // "")"
  '
}
__artifactory_verify() {
  __apimgr_require_creds artifactory
  # /system/ping returns "OK" as text/plain when reachable, regardless of auth. /system/version returns JSON
  # only with valid auth, so use that for verify so an invalid token actually fails.
  local resp; resp="$(__artifactory_api GET /system/version)" || __apimgr_die "Artifactory /system/version call failed (token invalid or insufficient scope)"
  __apimgr_jq -r '"Authenticated against Artifactory \(.version) (rev \(.revision // "?"))"' <<<"$resp"
}
__artifactory_user_get() {
  __apimgr_require_creds artifactory
  if [ -n "$APIMGR_USER" ]; then
    # /security/users/{name} requires admin scope. Surface the error rather than failing silently.
    __artifactory_api GET "/security/users/$APIMGR_USER" | __apimgr_jq .
  else
    # No /me endpoint in Artifactory; the closest signal is the version-info call we used in verify.
    __apimgr_die "artifactory user get: --user NAME required (Artifactory has no /me equivalent)"
  fi
}
__artifactory_repo_list() {
  __apimgr_require_creds artifactory
  # Optional ?type=local|remote|virtual filter via APIMGR_TAG (overloaded for now since there's no --type flag).
  local q=""; [ -n "$APIMGR_VISIBILITY" ] && q="?type=$APIMGR_VISIBILITY"
  __artifactory_api GET "/repositories$q" | __artifactory_print_repo_list
}
__artifactory_repo_get() {
  __apimgr_require_creds artifactory
  __apimgr_resolve_repo || __apimgr_die "artifactory repo get: --repo KEY required (Artifactory uses single-segment repo keys; pass it via --repo, e.g. --repo my-docker-local)"
  # APIMGR_REPO might be passed as KEY or NS/KEY; we use the last segment as the key since Artifactory has no namespace.
  local key="${APIMGR_REPO##*/}"
  __artifactory_api GET "/repositories/$key" | __artifactory_print_repo
}
__artifactory_repo_delete() {
  __apimgr_require_creds artifactory
  __apimgr_resolve_repo || __apimgr_die "artifactory repo delete: --repo KEY required"
  local key="${APIMGR_REPO##*/}"
  __apimgr_confirm "Delete Artifactory repo '$key'? Requires admin and is irreversible." || { printf_yellow "Aborted"; return 1; }
  __artifactory_api DELETE "/repositories/$key" >/dev/null && printf_green "Deleted Artifactory repo '$key'"
}
__artifactory_repo_create() {
  __apimgr_die "artifactory repo create: requires a per-format JSON spec (rclass, packageType, etc.) that doesn't fit a generic --visibility flag. Use 'apimgr artifactory api /repositories/<key>' with PUT and a hand-crafted body, or the JFrog UI."
}
# Tag listing for Artifactory's docker repos. Path: /api/docker/<repo-key>/v2/<image>/tags/list — different
# from the generic /repositories/.../tags pattern. Requires --repo REPOKEY/IMAGE (slash-split).
__artifactory_tag_list() {
  __apimgr_require_creds artifactory
  __apimgr_resolve_repo || __apimgr_die "artifactory tag list: --repo REPOKEY/IMAGE required (e.g. --repo docker-local/myapp)"
  local repokey="${APIMGR_REPO%%/*}" image="${APIMGR_REPO#*/}"
  # The /docker endpoint sits at the artifactory root, not /api — so we go a level up.
  local base; base="$(__apimgr_provider_url artifactory)" || return 1
  local root="${base%/api}"
  __artifactory_curl -H "Accept: application/json" "$root/api/docker/$repokey/v2/$image/tags/list" | __apimgr_jq -r '.tags[]? // empty'
}
__artifactory_tag_get() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds artifactory
  __apimgr_resolve_repo || __apimgr_die "artifactory tag get: --repo REPOKEY/IMAGE required"
  [ -n "$tag" ] || __apimgr_die "artifactory tag get: --tag NAME or positional TAG required"
  local repokey="${APIMGR_REPO%%/*}" image="${APIMGR_REPO#*/}"
  local base; base="$(__apimgr_provider_url artifactory)" || return 1
  local root="${base%/api}"
  __artifactory_curl -H "Accept: application/json" "$root/api/docker/$repokey/v2/$image/manifests/$tag" | __apimgr_jq .
}
__artifactory_tag_delete() {
  local tag="${APIMGR_TAG:-$1}"
  __apimgr_require_creds artifactory
  __apimgr_resolve_repo || __apimgr_die "artifactory tag delete: --repo REPOKEY/IMAGE required"
  [ -n "$tag" ] || __apimgr_die "artifactory tag delete: --tag NAME or positional TAG required"
  local repokey="${APIMGR_REPO%%/*}" image="${APIMGR_REPO#*/}"
  __apimgr_confirm "Delete tag '$tag' from $repokey/$image?" || { printf_yellow "Aborted"; return 1; }
  # Artifactory deletes tags by removing the tag's path under the docker repo storage.
  local base; base="$(__apimgr_provider_url artifactory)" || return 1
  local root="${base%/api}"
  __artifactory_curl -X DELETE "$root/$repokey/$image/$tag" >/dev/null && printf_green "Deleted tag '$tag' from $repokey/$image"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Sonatype Nexus provider (per-instance /service/rest/v1 — multi-format enterprise registry) ==============
# Auth: Basic (username:password) when both NEXUS_USERNAME and NEXUS_ACCESS_TOKEN are set; falls back to Bearer
# when only the token is available (some Nexus deployments behind SSO/OAuth accept Bearer).
# Aliased as 'sonatype' so muscle memory works either way. Tags map to components — Nexus's terminology for
# format-specific artifacts (a docker image+tag, an npm name@version, a maven artifact, etc).
__nexus_curl() {
  local pass; pass="$(__apimgr_provider_token nexus)" || return 1
  local user; user="$(__apimgr_provider_username nexus 2>/dev/null)"
  if [ -n "$user" ]; then
    local creds; creds="$(printf '%s:%s' "$user" "$pass" | base64 -w0)"
    __apimgr_curl -H "Authorization: Basic $creds" -H "Accept: application/json" "$@"
  else
    __apimgr_curl -H "Authorization: Bearer $pass" -H "Accept: application/json" "$@"
  fi
}
__nexus_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url nexus)" || return 1
  if [ -n "$data" ]; then
    __nexus_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __nexus_curl -X "$method" "$base$path"
  fi
}
# Nexus repo metadata: .name, .format, .type (hosted/proxy/group), .url, .online.
__nexus_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.name)\t\(.format // "")\t\(.type // "")\t\(.url // "")"' |
    awk -F'\t' '{printf "%-35s %-9s %-7s %s\n", $1, $2, $3, $4}'
}
__nexus_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.name)",
    "Format:      \(.format // "")",
    "Type:        \(.type // "")",
    "URL:         \(.url // "")",
    "Online:      \(.online // false)"
  '
}
# Components are the Nexus name for format-specific artifacts. Schema-tolerant for docker/npm/maven.
__nexus_print_component_list() {
  __apimgr_jq -r '.items[]? // .[]? | "\(.name)\t\(.version // "")\t\(.format // "")\t\(.id)"' |
    awk -F'\t' '{printf "%-35s %-15s %-8s %s\n", $1, $2, $3, $4}'
}
__nexus_verify() {
  __apimgr_require_creds nexus
  # /status/writable returns 200 with auth, 401 without — better verify signal than /status which is open.
  __nexus_api GET /status/writable >/dev/null || __apimgr_die "Nexus /status/writable call failed (token invalid or insufficient scope)"
  # Print the version too if /status returns it.
  __nexus_api GET /status | __apimgr_jq -r '"Authenticated against Nexus" + (if .data then " (version " + .data.version + ")" else "" end)' 2>/dev/null \
    || printf 'Authenticated against Nexus\n'
}
__nexus_user_get() {
  __apimgr_require_creds nexus
  if [ -n "$APIMGR_USER" ]; then
    __nexus_api GET "/security/users?userId=$APIMGR_USER" | __apimgr_jq '.[0] // empty'
  else
    __apimgr_die "nexus user get: --user NAME required (Nexus has no /me endpoint)"
  fi
}
__nexus_repo_list() {
  __apimgr_require_creds nexus
  __nexus_api GET /repositories | __nexus_print_repo_list
}
__nexus_repo_get() {
  __apimgr_require_creds nexus
  __apimgr_resolve_repo || __apimgr_die "nexus repo get: --repo NAME required (Nexus repos have flat names; pass via --repo)"
  local key="${APIMGR_REPO##*/}"
  __nexus_api GET "/repositories/$key" | __nexus_print_repo
}
__nexus_repo_delete() {
  __apimgr_require_creds nexus
  __apimgr_resolve_repo || __apimgr_die "nexus repo delete: --repo NAME required"
  local key="${APIMGR_REPO##*/}"
  __apimgr_confirm "Delete Nexus repo '$key'? Requires admin and is irreversible." || { printf_yellow "Aborted"; return 1; }
  __nexus_api DELETE "/repositories/$key" >/dev/null && printf_green "Deleted Nexus repo '$key'"
}
__nexus_repo_create() {
  __apimgr_die "nexus repo create: requires a per-format JSON spec (rclass, format, storage config) that doesn't fit a generic --visibility flag. Use 'apimgr nexus api /repositories/<format>/hosted' with PUT and a hand-crafted body, or the Nexus UI."
}
# Components (the Nexus tag-equivalent). Listed via /components?repository=X.
__nexus_tag_list() {
  __apimgr_require_creds nexus
  __apimgr_resolve_repo || __apimgr_die "nexus tag list: --repo NAME required"
  local key="${APIMGR_REPO##*/}"
  __nexus_api GET "/components?repository=$key" | __nexus_print_component_list
}
__nexus_tag_get() {
  local cid="${APIMGR_TAG:-$1}"
  __apimgr_require_creds nexus
  [ -n "$cid" ] || __apimgr_die "nexus tag get: --tag COMPONENT_ID or positional ID required (find via 'tag list')"
  __nexus_api GET "/components/$cid" | __apimgr_jq .
}
__nexus_tag_delete() {
  local cid="${APIMGR_TAG:-$1}"
  __apimgr_require_creds nexus
  [ -n "$cid" ] || __apimgr_die "nexus tag delete: --tag COMPONENT_ID or positional ID required"
  __apimgr_confirm "Delete Nexus component '$cid'?" || { printf_yellow "Aborted"; return 1; }
  __nexus_api DELETE "/components/$cid" >/dev/null && printf_green "Deleted Nexus component '$cid'"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Stub providers — print a clear "not yet implemented" so the dispatch surface is honest about what works.
__apimgr_stub_provider() {
  __apimgr_die "Provider '$1' is not implemented yet. Architecture is in place; add __${1}_<action> functions to enable. See bin/apimgr __github_* / __gitea_* for templates."
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Provider dispatcher — routes "<provider> <action> [sub] [extra positionals]" to the right __<provider>_<action>
# function. Extra positionals (e.g. an issue number after `issue get`) are passed through to the action functions.
__apimgr_dispatch_provider() {
  local provider="$1" action="$2" sub="${3:-}"
  shift 3 2>/dev/null || true
  case "$provider" in
    github)
      case "$action" in
        verify)               __github_verify ;;
        user)                 __github_user_get ;;
        org)
          case "$sub" in
            all)              __github_org_all ;;
            *)                __github_org_get ;;
          esac ;;
        repo)
          case "$sub" in
            list)             __github_repo_list ;;
            get|"")           __github_repo_get ;;
            create)           __github_repo_create ;;
            delete|rm)        __github_repo_delete ;;
            all)              __github_repo_all ;;
            *)                __apimgr_die "github repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __github_issue_list ;;
            get|show)         __github_issue_get "$1" ;;
            create|new)       __github_issue_create ;;
            close)            __github_issue_close "$1" ;;
            comment)          __github_issue_comment "$1" ;;
            *)                __apimgr_die "github issue: unknown sub '$sub' (try list|get|create|close|comment)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __github_pr_list ;;
            get|show)         __github_pr_get "$1" ;;
            create|new)       __github_pr_create ;;
            merge)            __github_pr_merge "$1" ;;
            close)            __github_pr_close "$1" ;;
            *)                __apimgr_die "github pr: unknown sub '$sub' (try list|get|create|merge|close)" ;;
          esac ;;
        release|releases|rel)
          case "$sub" in
            list|"")          __github_release_list ;;
            get|show)         __github_release_get "$1" ;;
            create|new)       __github_release_create ;;
            delete|rm)        __github_release_delete "$1" ;;
            *)                __apimgr_die "github release: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __github_tag_list ;;
            get|show)         __github_tag_get "$1" ;;
            create|new)       __github_tag_create ;;
            delete|rm)        __github_tag_delete "$1" ;;
            *)                __apimgr_die "github tag: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "github api: PATH required (e.g. apimgr github api /user)"
          __github_api GET "$sub" ;;
        *)                    __apimgr_die "github: unknown action '$action'. Try: verify|user|org|repo|issue|pr|release|tag|api" ;;
      esac ;;
    gitea|forgejo|codeberg)
      case "$action" in
        verify)               __gitea_verify "$provider" ;;
        user)                 __gitea_user_get "$provider" ;;
        org)
          case "$sub" in
            all)              __gitea_org_all "$provider" ;;
            *)                __gitea_org_get "$provider" ;;
          esac ;;
        repo)
          case "$sub" in
            list)             __gitea_repo_list "$provider" ;;
            get|"")           __gitea_repo_get "$provider" ;;
            create)           __gitea_repo_create "$provider" ;;
            delete|rm)        __gitea_repo_delete "$provider" ;;
            all)              __gitea_repo_all "$provider" ;;
            *)                __apimgr_die "$provider repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __gitea_issue_list "$provider" ;;
            get|show)         __gitea_issue_get "$provider" "$1" ;;
            create|new)       __gitea_issue_create "$provider" ;;
            close)            __gitea_issue_close "$provider" "$1" ;;
            comment)          __gitea_issue_comment "$provider" "$1" ;;
            *)                __apimgr_die "$provider issue: unknown sub '$sub' (try list|get|create|close|comment)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __gitea_pr_list "$provider" ;;
            get|show)         __gitea_pr_get "$provider" "$1" ;;
            create|new)       __gitea_pr_create "$provider" ;;
            merge)            __gitea_pr_merge "$provider" "$1" ;;
            close)            __gitea_pr_close "$provider" "$1" ;;
            *)                __apimgr_die "$provider pr: unknown sub '$sub' (try list|get|create|merge|close)" ;;
          esac ;;
        release|releases|rel)
          case "$sub" in
            list|"")          __gitea_release_list "$provider" ;;
            get|show)         __gitea_release_get "$provider" "$1" ;;
            create|new)       __gitea_release_create "$provider" ;;
            delete|rm)        __gitea_release_delete "$provider" "$1" ;;
            *)                __apimgr_die "$provider release: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __gitea_tag_list "$provider" ;;
            get|show)         __gitea_tag_get "$provider" "$1" ;;
            create|new)       __gitea_tag_create "$provider" ;;
            delete|rm)        __gitea_tag_delete "$provider" "$1" ;;
            *)                __apimgr_die "$provider tag: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "$provider api: PATH required"
          __gitea_api "$provider" GET "$sub" ;;
        *)                    __apimgr_die "$provider: unknown action '$action'. Try: verify|user|org|repo|issue|pr|release|tag|api" ;;
      esac ;;
    gitlab)
      case "$action" in
        verify)               __gitlab_verify ;;
        user)                 __gitlab_user_get ;;
        org)
          case "$sub" in
            all)              __gitlab_org_all ;;
            *)                __gitlab_org_get ;;
          esac ;;
        repo)
          case "$sub" in
            list)             __gitlab_repo_list ;;
            get|"")           __gitlab_repo_get ;;
            create)           __gitlab_repo_create ;;
            delete|rm)        __gitlab_repo_delete ;;
            all)              __gitlab_repo_all ;;
            *)                __apimgr_die "gitlab repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __gitlab_issue_list ;;
            get|show)         __gitlab_issue_get "$1" ;;
            create|new)       __gitlab_issue_create ;;
            close)            __gitlab_issue_close "$1" ;;
            comment)          __gitlab_issue_comment "$1" ;;
            *)                __apimgr_die "gitlab issue: unknown sub '$sub' (try list|get|create|close|comment)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __gitlab_pr_list ;;
            get|show)         __gitlab_pr_get "$1" ;;
            create|new)       __gitlab_pr_create ;;
            merge)            __gitlab_pr_merge "$1" ;;
            close)            __gitlab_pr_close "$1" ;;
            *)                __apimgr_die "gitlab pr: unknown sub '$sub' (try list|get|create|merge|close)" ;;
          esac ;;
        release|releases|rel)
          case "$sub" in
            list|"")          __gitlab_release_list ;;
            get|show)         __gitlab_release_get "$1" ;;
            create|new)       __gitlab_release_create ;;
            delete|rm)        __gitlab_release_delete "$1" ;;
            *)                __apimgr_die "gitlab release: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __gitlab_tag_list ;;
            get|show)         __gitlab_tag_get "$1" ;;
            create|new)       __gitlab_tag_create ;;
            delete|rm)        __gitlab_tag_delete "$1" ;;
            *)                __apimgr_die "gitlab tag: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "gitlab api: PATH required (e.g. apimgr gitlab api /version)"
          __gitlab_api GET "$sub" ;;
        *)                    __apimgr_die "gitlab: unknown action '$action'. Try: verify|user|org|repo|issue|pr|release|tag|api" ;;
      esac ;;
    bitbucket)
      case "$action" in
        verify)               __bitbucket_verify ;;
        user)                 __bitbucket_user_get ;;
        org|workspace)
          case "$sub" in
            all)              __bitbucket_org_all ;;
            *)                __bitbucket_org_get ;;
          esac ;;
        repo)
          case "$sub" in
            list)             __bitbucket_repo_list ;;
            get|"")           __bitbucket_repo_get ;;
            create)           __bitbucket_repo_create ;;
            delete|rm)        __bitbucket_repo_delete ;;
            all)              __bitbucket_repo_all ;;
            *)                __apimgr_die "bitbucket repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __bitbucket_issue_list ;;
            get|show)         __bitbucket_issue_get "$1" ;;
            create|new)       __bitbucket_issue_create ;;
            close)            __bitbucket_issue_close "$1" ;;
            comment)          __bitbucket_issue_comment "$1" ;;
            *)                __apimgr_die "bitbucket issue: unknown sub '$sub' (try list|get|create|close|comment)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __bitbucket_pr_list ;;
            get|show)         __bitbucket_pr_get "$1" ;;
            create|new)       __bitbucket_pr_create ;;
            merge)            __bitbucket_pr_merge "$1" ;;
            close|decline)    __bitbucket_pr_close "$1" ;;
            *)                __apimgr_die "bitbucket pr: unknown sub '$sub' (try list|get|create|merge|close)" ;;
          esac ;;
        release|releases|rel)
          __bitbucket_release_unsupported ;;
        tag|tags)
          case "$sub" in
            list|"")          __bitbucket_tag_list ;;
            get|show)         __bitbucket_tag_get "$1" ;;
            create|new)       __bitbucket_tag_create ;;
            delete|rm)        __bitbucket_tag_delete "$1" ;;
            *)                __apimgr_die "bitbucket tag: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "bitbucket api: PATH required (e.g. apimgr bitbucket api /user)"
          __bitbucket_api GET "$sub" ;;
        *)                    __apimgr_die "bitbucket: unknown action '$action'. Try: verify|user|org|repo|issue|pr|tag|api" ;;
      esac ;;
    gitee)
      case "$action" in
        verify)               __gitee_verify ;;
        user)                 __gitee_user_get ;;
        org)
          case "$sub" in
            all)              __gitee_org_all ;;
            *)                __gitee_org_get ;;
          esac ;;
        repo)
          case "$sub" in
            list)             __gitee_repo_list ;;
            get|"")           __gitee_repo_get ;;
            create)           __gitee_repo_create ;;
            delete|rm)        __gitee_repo_delete ;;
            all)              __gitee_repo_all ;;
            *)                __apimgr_die "gitee repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __gitee_issue_list ;;
            get|show)         __gitee_issue_get "$1" ;;
            create|new)       __gitee_issue_create ;;
            close)            __gitee_issue_close "$1" ;;
            comment)          __gitee_issue_comment "$1" ;;
            *)                __apimgr_die "gitee issue: unknown sub '$sub' (try list|get|create|close|comment)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __gitee_pr_list ;;
            get|show)         __gitee_pr_get "$1" ;;
            create|new)       __gitee_pr_create ;;
            merge)            __gitee_pr_merge "$1" ;;
            close)            __gitee_pr_close "$1" ;;
            *)                __apimgr_die "gitee pr: unknown sub '$sub' (try list|get|create|merge|close)" ;;
          esac ;;
        release|releases|rel)
          case "$sub" in
            list|"")          __gitee_release_list ;;
            get|show)         __gitee_release_get "$1" ;;
            create|new)       __gitee_release_create ;;
            delete|rm)        __gitee_release_delete "$1" ;;
            *)                __apimgr_die "gitee release: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __gitee_tag_list ;;
            create|new)       __gitee_tag_create ;;
            delete|rm)        __gitee_tag_delete "$1" ;;
            *)                __apimgr_die "gitee tag: unknown sub '$sub' (try list|create|delete — gitee has no get-tag endpoint)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "gitee api: PATH required (e.g. apimgr gitee api /user)"
          __gitee_api GET "$sub" ;;
        *)                    __apimgr_die "gitee: unknown action '$action'. Try: verify|user|org|repo|issue|pr|release|tag|api" ;;
      esac ;;
    pagure)
      case "$action" in
        verify)               __pagure_verify ;;
        user)                 __pagure_user_get ;;
        org|group)
          case "$sub" in
            all)              __pagure_org_all ;;
            *)                __pagure_org_get ;;
          esac ;;
        repo)
          case "$sub" in
            list)             __pagure_repo_list ;;
            get|"")           __pagure_repo_get ;;
            create)           __pagure_repo_create ;;
            delete|rm)        __pagure_repo_delete ;;
            all)              __pagure_repo_all ;;
            *)                __apimgr_die "pagure repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __pagure_issue_list ;;
            get|show)         __pagure_issue_get "$1" ;;
            create|new)       __pagure_issue_create ;;
            close)            __pagure_issue_close "$1" ;;
            comment)          __pagure_issue_comment "$1" ;;
            *)                __apimgr_die "pagure issue: unknown sub '$sub' (try list|get|create|close|comment)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __pagure_pr_list ;;
            get|show)         __pagure_pr_get "$1" ;;
            merge)            __pagure_pr_merge "$1" ;;
            close)            __pagure_pr_close "$1" ;;
            create|new)       __apimgr_die "pagure pr create: not yet implemented (Pagure's PR-create has a complex form payload — use the web UI or apimgr pagure api)" ;;
            *)                __apimgr_die "pagure pr: unknown sub '$sub' (try list|get|merge|close)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __pagure_tag_list ;;
            *)                __apimgr_die "pagure tag: only 'list' supported via API (create/delete are not exposed)" ;;
          esac ;;
        release|releases|rel)
          __apimgr_die "pagure has no release API surface; releases are tracked as git tags. Use 'apimgr pagure tag list'." ;;
        api)
          [ -n "$sub" ] || __apimgr_die "pagure api: PATH required (e.g. apimgr pagure api /-/whoami)"
          __pagure_api GET "$sub" ;;
        *)                    __apimgr_die "pagure: unknown action '$action'. Try: verify|user|org|repo|issue|pr|tag|api" ;;
      esac ;;
    sourcehut|sr.ht|srht)
      case "$action" in
        verify)               __sourcehut_verify ;;
        user)                 __sourcehut_user_get ;;
        repo)
          case "$sub" in
            list)             __sourcehut_repo_list ;;
            get|"")           __sourcehut_repo_get ;;
            create)           __sourcehut_repo_create ;;
            delete|rm)        __sourcehut_repo_delete ;;
            *)                __apimgr_die "sourcehut repo: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __sourcehut_tag_list ;;
            *)                __apimgr_die "sourcehut tag: only 'list' supported (sourcehut's API doesn't expose create/delete/get for tags)" ;;
          esac ;;
        issue)                __sourcehut_issue_unsupported ;;
        pr|pull|pulls|mr)     __sourcehut_pr_unsupported ;;
        release|releases|rel) __apimgr_die "sourcehut has no release API — releases are git tags. Use 'apimgr sourcehut tag list'." ;;
        org)                  __apimgr_die "sourcehut has no orgs (~user is the only namespace). Use 'apimgr sourcehut repo list --user NAME' instead." ;;
        api)
          local service="${APIMGR_SERVICE:-meta}"
          [ -n "$sub" ] || __apimgr_die "sourcehut api: PATH required (e.g. apimgr sourcehut api /repos). Use APIMGR_SERVICE=git|todo|lists to switch services."
          __sourcehut_api "$service" GET "$sub" ;;
        *)                    __apimgr_die "sourcehut: unknown action '$action'. Try: verify|user|repo|tag|api" ;;
      esac ;;
    onedev)
      case "$action" in
        verify)               __onedev_verify ;;
        user)                 __onedev_user_get ;;
        repo)
          case "$sub" in
            list)             __onedev_repo_list ;;
            get|"")           __onedev_repo_get ;;
            create)           __onedev_repo_create ;;
            delete|rm)        __onedev_repo_delete ;;
            *)                __apimgr_die "onedev repo: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __onedev_issue_list ;;
            get|show)         __onedev_issue_get "$1" ;;
            create|new)       __onedev_issue_create ;;
            *)                __apimgr_die "onedev issue: unknown sub '$sub' (try list|get|create)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __onedev_pr_list ;;
            get|show)         __onedev_pr_get "$1" ;;
            *)                __apimgr_die "onedev pr: unknown sub '$sub' (try list|get — create/merge need raw api with branch IDs)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __onedev_tag_list ;;
            *)                __apimgr_die "onedev tag: only 'list' supported via apimgr (create/delete need raw api)" ;;
          esac ;;
        org)                  __apimgr_die "onedev has no orgs/namespaces — projects sit at the top level. Use 'repo list' instead." ;;
        release|releases|rel) __apimgr_die "onedev has no first-class release API — use 'apimgr onedev tag list' for tags." ;;
        api)
          [ -n "$sub" ] || __apimgr_die "onedev api: PATH required (e.g. apimgr onedev api /me)"
          __onedev_api GET "$sub" ;;
        *)                    __apimgr_die "onedev: unknown action '$action'. Try: verify|user|repo|issue|pr|tag|api" ;;
      esac ;;
    docker)
      case "$action" in
        verify)               __docker_verify ;;
        user)                 __docker_user_get ;;
        org|namespace)
          case "$sub" in
            all)              __docker_org_all ;;
            *)                __docker_org_get ;;
          esac ;;
        repo|repos|repositories|image|images)
          case "$sub" in
            list)             __docker_repo_list ;;
            get|"")           __docker_repo_get ;;
            delete|rm)        __docker_repo_delete ;;
            all)              __docker_repo_all ;;
            *)                __apimgr_die "docker repo: unknown sub '$sub' (try list|get|delete|all)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __docker_tag_list ;;
            get|show)         __docker_tag_get "$1" ;;
            delete|rm)        __docker_tag_delete "$1" ;;
            *)                __apimgr_die "docker tag: unknown sub '$sub' (try list|get|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "docker api: PATH required (e.g. apimgr docker api /repositories/library/alpine/)"
          __docker_api GET "$sub" ;;
        *)                    __apimgr_die "docker: unknown action '$action'. Try: verify|user|org|repo|tag|api" ;;
      esac ;;
    ghcr)
      case "$action" in
        verify)               __ghcr_verify ;;
        user)                 __ghcr_user_get ;;
        org)
          case "$sub" in
            all)              __ghcr_org_all ;;
            *)                __ghcr_org_get ;;
          esac ;;
        repo|repos|repositories|image|images|package|packages)
          case "$sub" in
            list)             __ghcr_repo_list ;;
            get|"")           __ghcr_repo_get ;;
            create)           __ghcr_repo_create ;;
            delete|rm)        __ghcr_repo_delete ;;
            all)              __ghcr_repo_all ;;
            *)                __apimgr_die "ghcr repo: unknown sub '$sub' (try list|get|delete|all — create is push-only)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __ghcr_tag_list ;;
            get|show)         __ghcr_tag_get "$1" ;;
            delete|rm)        __ghcr_tag_delete "$1" ;;
            *)                __apimgr_die "ghcr tag: unknown sub '$sub' (try list|get|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "ghcr api: PATH required (e.g. apimgr ghcr api /user/packages?package_type=container)"
          __ghcr_api GET "$sub" ;;
        *)                    __apimgr_die "ghcr: unknown action '$action'. Try: verify|user|org|repo|tag|api" ;;
      esac ;;
    glcr)
      case "$action" in
        verify)               __glcr_verify ;;
        repo|repos|repositories|image|images)
          case "$sub" in
            list)             __glcr_repo_list ;;
            get|"")           __glcr_repo_get ;;
            delete|rm)        __glcr_repo_delete ;;
            *)                __apimgr_die "glcr repo: unknown sub '$sub' (try list|get|delete — create is push-only via 'docker push registry.gitlab.com/...')" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __glcr_tag_list ;;
            get|show)         __glcr_tag_get "$1" ;;
            delete|rm)        __glcr_tag_delete "$1" ;;
            *)                __apimgr_die "glcr tag: unknown sub '$sub' (try list|get|delete)" ;;
          esac ;;
        user|org)             __apimgr_die "glcr has no separate user/org endpoints — registry repos belong to gitlab projects. Use 'apimgr gitlab user/org' for those." ;;
        api)
          [ -n "$sub" ] || __apimgr_die "glcr api: PATH required (e.g. apimgr glcr api /projects/<id>/registry/repositories)"
          __glcr_api GET "$sub" ;;
        *)                    __apimgr_die "glcr: unknown action '$action'. Try: verify|repo|tag|api" ;;
      esac ;;
    harbor)
      case "$action" in
        verify)               __harbor_verify ;;
        user)                 __harbor_user_get ;;
        org|project|namespace)
          case "$sub" in
            all)              __harbor_org_all ;;
            *)                __harbor_org_get ;;
          esac ;;
        repo|repos|repositories|image|images)
          case "$sub" in
            list)             __harbor_repo_list ;;
            get|"")           __harbor_repo_get ;;
            delete|rm)        __harbor_repo_delete ;;
            all)              __harbor_repo_all ;;
            *)                __apimgr_die "harbor repo: unknown sub '$sub' (try list|get|delete|all)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __harbor_tag_list ;;
            get|show)         __harbor_tag_get "$1" ;;
            delete|rm)        __harbor_tag_delete "$1" ;;
            *)                __apimgr_die "harbor tag: unknown sub '$sub' (try list|get|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "harbor api: PATH required (e.g. apimgr harbor api /projects)"
          __harbor_api GET "$sub" ;;
        *)                    __apimgr_die "harbor: unknown action '$action'. Try: verify|user|org|repo|tag|api" ;;
      esac ;;
    quay)
      case "$action" in
        verify)               __quay_verify ;;
        user)                 __quay_user_get ;;
        org|namespace|organization)
          case "$sub" in
            all)              __quay_org_all ;;
            *)                __quay_org_get ;;
          esac ;;
        repo|repos|repositories|image|images)
          case "$sub" in
            list)             __quay_repo_list ;;
            get|"")           __quay_repo_get ;;
            delete|rm)        __quay_repo_delete ;;
            all)              __quay_repo_all ;;
            *)                __apimgr_die "quay repo: unknown sub '$sub' (try list|get|delete|all)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __quay_tag_list ;;
            get|show)         __quay_tag_get "$1" ;;
            delete|rm)        __quay_tag_delete "$1" ;;
            *)                __apimgr_die "quay tag: unknown sub '$sub' (try list|get|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "quay api: PATH required (e.g. apimgr quay api /user/)"
          __quay_api GET "$sub" ;;
        *)                    __apimgr_die "quay: unknown action '$action'. Try: verify|user|org|repo|tag|api" ;;
      esac ;;
    nexus|sonatype)
      case "$action" in
        verify)               __nexus_verify ;;
        user)                 __nexus_user_get ;;
        repo|repos|repositories)
          case "$sub" in
            list)             __nexus_repo_list ;;
            get|"")           __nexus_repo_get ;;
            create)           __nexus_repo_create ;;
            delete|rm)        __nexus_repo_delete ;;
            *)                __apimgr_die "nexus repo: unknown sub '$sub' (try list|get|delete — create needs raw api)" ;;
          esac ;;
        tag|tags|component|components)
          case "$sub" in
            list|"")          __nexus_tag_list ;;
            get|show)         __nexus_tag_get "$1" ;;
            delete|rm)        __nexus_tag_delete "$1" ;;
            *)                __apimgr_die "nexus tag/component: unknown sub '$sub' (try list|get|delete)" ;;
          esac ;;
        org)                  __apimgr_die "nexus has no orgs/namespaces — repo names are flat. Use 'repo list' instead." ;;
        api)
          [ -n "$sub" ] || __apimgr_die "nexus api: PATH required (e.g. apimgr nexus api /status)"
          __nexus_api GET "$sub" ;;
        *)                    __apimgr_die "nexus: unknown action '$action'. Try: verify|user|repo|tag|api" ;;
      esac ;;
    artifactory|jfrog)
      case "$action" in
        verify)               __artifactory_verify ;;
        user)                 __artifactory_user_get ;;
        repo|repos|repositories)
          case "$sub" in
            list)             __artifactory_repo_list ;;
            get|"")           __artifactory_repo_get ;;
            create)           __artifactory_repo_create ;;
            delete|rm)        __artifactory_repo_delete ;;
            *)                __apimgr_die "artifactory repo: unknown sub '$sub' (try list|get|delete — create needs raw api)" ;;
          esac ;;
        tag|tags)
          case "$sub" in
            list|"")          __artifactory_tag_list ;;
            get|show)         __artifactory_tag_get "$1" ;;
            delete|rm)        __artifactory_tag_delete "$1" ;;
            *)                __apimgr_die "artifactory tag: unknown sub '$sub' (try list|get|delete)" ;;
          esac ;;
        org)                  __apimgr_die "artifactory has no orgs/namespaces — repo keys are flat. Use 'repo list' instead." ;;
        api)
          [ -n "$sub" ] || __apimgr_die "artifactory api: PATH required (e.g. apimgr artifactory api /system/version)"
          __artifactory_api GET "$sub" ;;
        *)                    __apimgr_die "artifactory: unknown action '$action'. Try: verify|user|repo|tag|api" ;;
      esac ;;
    cloudsmith)
      case "$action" in
        verify)               __cloudsmith_verify ;;
        user)                 __cloudsmith_user_get ;;
        org|namespace)
          case "$sub" in
            all)              __cloudsmith_org_all ;;
            *)                __cloudsmith_org_get ;;
          esac ;;
        repo|repos|repositories)
          case "$sub" in
            list)             __cloudsmith_repo_list ;;
            get|"")           __cloudsmith_repo_get ;;
            create)           __cloudsmith_repo_create ;;
            delete|rm)        __cloudsmith_repo_delete ;;
            all)              __cloudsmith_repo_all ;;
            *)                __apimgr_die "cloudsmith repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        tag|tags|package|packages)
          case "$sub" in
            list|"")          __cloudsmith_tag_list ;;
            get|show)         __cloudsmith_tag_get "$1" ;;
            delete|rm)        __cloudsmith_tag_delete "$1" ;;
            *)                __apimgr_die "cloudsmith tag/package: unknown sub '$sub' (try list|get|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "cloudsmith api: PATH required (e.g. apimgr cloudsmith api /user/self/)"
          __cloudsmith_api GET "$sub" ;;
        *)                    __apimgr_die "cloudsmith: unknown action '$action'. Try: verify|user|org|repo|tag|api" ;;
      esac ;;
    "")
      __apimgr_die "no provider specified — try: apimgr <provider> <action>, or run apimgr --help" ;;
    *)
      __apimgr_die "unknown provider '$provider'. Supported: github gitlab gitea forgejo codeberg gitee pagure sourcehut onedev bitbucket docker ghcr glcr harbor quay cloudsmith artifactory nexus" ;;
  esac
}
