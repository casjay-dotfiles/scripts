APIMGR_GOOD_MESSAGE="${APIMGR_GOOD_MESSAGE:-No errors reported}"
APIMGR_ERROR_MESSAGE="${APIMGR_ERROR_MESSAGE:-Errors were reported}"
APIMGR_NOTIFY_CLIENT_NAME="${APIMGR_NOTIFY_CLIENT_NAME:-$APPNAME}"
APIMGR_NOTIFY_CLIENT_ICON="${APIMGR_NOTIFY_CLIENT_ICON:-notification-new}"
APIMGR_NOTIFY_CLIENT_URGENCY="${APIMGR_NOTIFY_CLIENT_URGENCY:-normal}"
