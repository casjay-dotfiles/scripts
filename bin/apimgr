  __printf_line "pr     [list|get N|create|merge N|close N]"
  __printf_line "                                - PR/MR ops; --branch SOURCE, --base TARGET (default: repo's default_branch)"
  __printf_line "release [list|get TAG|create|delete TAG]"
  __printf_line "                                - Release ops; --tag NAME (required for create), --title, --body, --branch (target ref)"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Top-level shortcuts (no provider — auto-detect or default)"
