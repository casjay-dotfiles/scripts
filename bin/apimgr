# Help function - Align to 50
__help() {
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "apimgr: multi-provider API client - $VERSION"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Usage: apimgr [provider] [action] [sub] [flags]"
  __printf_line "       apimgr [action] [sub] [flags]   (provider auto-detected from git remote or APIMGR_DEFAULT_PROVIDER)"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Providers"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "github                          - GitHub. Reads GITHUB_API_URL + GITHUB_ACCESS_TOKEN from env"
  __printf_line "gitea                           - Gitea (self-host). GITEA_API_URL + GITEA_ACCESS_TOKEN"
  __printf_line "forgejo                         - Forgejo (Gitea API). FORGEJO_API_URL + FORGEJO_ACCESS_TOKEN"
  __printf_line "codeberg                        - Codeberg (Gitea API). CODEBERG_API_URL + CODEBERG_ACCESS_TOKEN"
  __printf_line "gitlab                          - GitLab. GITLAB_API_URL + GITLAB_ACCESS_TOKEN"
  __printf_line "bitbucket                       - Bitbucket Cloud. BITBUCKET_API_URL + BITBUCKET_ACCESS_TOKEN (Bearer)"
  __printf_line "docker                          - Docker Hub / private. DOCKER_API_URL + DOCKER_HUB_API_KEY      [stub]"
  __printf_line "harbor                          - Harbor. HARBOR_API_URL + HARBOR_ACCESS_TOKEN                   [stub]"
  __printf_line "quay                            - Quay. QUAY_API_URL + QUAY_ACCESS_TOKEN                         [stub]"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Actions (per provider)"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "verify                          - Confirm credentials work; print authenticated user"
  __printf_line "user [get]                      - Get user info (defaults to authed user; --user NAME for another)"
  __printf_line "org [get|all]                   - Org info / list all repos in org"
  __printf_line "repo [list|get|create|delete|all]"
  __printf_line "                                - Repo ops; --repo USER/REPO selects target (or auto-detect from cwd)"
  __printf_line "issue [list|get N|create|close N|comment N]"
