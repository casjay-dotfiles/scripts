APIMGR_CONFIG_DIR="${APIMGR_CONFIG_DIR:-$HOME/.config/myscripts/apimgr}"
APIMGR_CONFIG_BACKUP_DIR="${APIMGR_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/apimgr/backups}"
APIMGR_LOG_DIR="${APIMGR_LOG_DIR:-$HOME/.local/log/apimgr}"
APIMGR_RUN_DIR="${APIMGR_RUN_DIR:-$HOME/.local/run/system_scripts/$APIMGR_SCRIPTS_PREFIX}"
APIMGR_TEMP_DIR="${APIMGR_TEMP_DIR:-$HOME/.local/tmp/system_scripts/apimgr}"
APIMGR_CACHE_DIR="${APIMGR_CACHE_DIR:-$HOME/.cache/apimgr}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# File settings
APIMGR_CONFIG_FILE="${APIMGR_CONFIG_FILE:-settings.conf}"
APIMGR_LOG_ERROR_FILE="${APIMGR_LOG_ERROR_FILE:-$APIMGR_LOG_DIR/error.log}"
