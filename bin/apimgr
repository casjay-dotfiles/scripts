[ -d "$APIMGR_LOG_DIR" ] || mkdir -p "$APIMGR_LOG_DIR" |& __devnull
[ -d "$APIMGR_TEMP_DIR" ] || mkdir -p "$APIMGR_TEMP_DIR" |& __devnull
[ -d "$APIMGR_CACHE_DIR" ] || mkdir -p "$APIMGR_CACHE_DIR" |& __devnull
