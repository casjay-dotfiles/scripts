  __printf_line "APIMGR_GIT_HOST_<host>_PROVIDER - Self-host hostname → provider mapping for git auto-detect"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__grep() { grep "$@" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# check if arg is a builtin option
__is_an_option() { if [[ "$ARRAY" == *"${1:-^}"* ]]; then return 1; else return 0; fi; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  if { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; }; then return 1; else return 0; fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -sh "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$APIMGR_REQUIRE_SUDO" = "yes" ] && [ -z "$APIMGR_REQUIRE_SUDO_RUN" ]; then
    export APIMGR_REQUIRE_SUDO="no"
    export APIMGR_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "${SUDO##*/}" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    APIMGR_EXIT_STATUS=$?
  else
    printf '%s\n' "This requires root to run"
    APIMGR_EXIT_STATUS=1
  fi
  return ${APIMGR_EXIT_STATUS:-0}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - -
__how_long_did_it_take() {
  local retprev=$?
  local retval=${1:-$retprev}
  __cmd_exists bc || return $retval
  [ -n "$APIMGR_START_TIMER" ] || return 0
  local stop_time="$(date +%s.%N)"
  local dt=$(echo "$stop_time - $APIMGR_START_TIMER" | bc)
  local dd=$(echo "$dt/86400" | bc)
  local dt2=$(echo "$dt-86400*$dd" | bc)
  local dh=$(echo "$dt2/3600" | bc)
  local dt3=$(echo "$dt2-3600*$dh" | bc)
  local dm=$(echo "$dt3/60" | bc)
  local ds=$(echo "$dt3-60*$dm" | bc)
  printf_purple "$(LC_NUMERIC=C printf "Total runtime: %d Days, %02d Hours, %02d Minutes, %02.4f Seconds\n" $dd $dh $dm $ds)"
  return $retval
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit_apimgr() {
  APIMGR_EXIT_STATUS=${APIMGR_EXIT_STATUS:-0}
  [ -f "$APIMGR_TEMP_FILE" ] && rm -Rf "$APIMGR_TEMP_FILE" &>/dev/null
  #unset CASJAYSDEV_TITLE_SET && printf '\033]2│;%s\033\\' "${USER}@${HOSTNAME}:${PWD/#$HOME/~} - ${CASJAYSDEV_TITLE_PREV:-$SHELL}"
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $APIMGR_EXIT_STATUS
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Create a --no-* options function
__options_function_no() {
  local options="${1//=*/}"
  local argument="${1//*=/}"
  case "$options" in
  *) echo "${argument:-No argument provided}" && shift ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Create a --yes-* options function
__options_function_yes() {
  local options="${1//=*/}"
  local argument="${1//*=/}"
  case "$options" in
  *) echo "${argument:-No argument provided}" && shift ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
__notifications() {
  __cmd_exists notifications || return
  [ "$APIMGR_SYSTEM_NOTIFY_ENABLED" = "yes" ] || return
  [ "$SEND_NOTIFICATION" = "no" ] && return
  (
    export SCRIPT_OPTS="" _DEBUG=""
    export NOTIFY_GOOD_MESSAGE="${NOTIFY_GOOD_MESSAGE:-$APIMGR_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${NOTIFY_ERROR_MESSAGE:-$APIMGR_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$APIMGR_NOTIFY_CLIENT_ICON}"
    export NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APIMGR_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_URGENCY="${NOTIFY_CLIENT_URGENCY:-$APIMGR_NOTIFY_CLIENT_URGENCY}"
    notifications "$@"
  ) |& __devnull &
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__notify_remote() {
  local cmd="${APIMGR_REMOTE_NOTIFY_COMMAND%% *}"
  if [ "$APIMGR_REMOTE_NOTIFY_ENABLED" = "yes" ]; then
    if [ -n "$(command -v "$cmd")" ]; then
      eval $APIMGR_REMOTE_NOTIFY_COMMAND "$@"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap '__trap_exit_apimgr' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - -
# start timer
APIMGR_START_TIMER="${APIMGR_START_TIMER:-$(date +%s.%N)}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Source per-user token file if present (mode 0600 recommended). Sourced BEFORE settings.conf so settings can override.
[ -f "$HOME/.config/secure/apimgr.txt" ] && . "$HOME/.config/secure/apimgr.txt"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Print message + exit. Uniform error path so callers don't repeat the printf-then-exit pattern.
__apimgr_die() { printf_red "$1" >&2; exit "${2:-1}"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# jq wrapper — silences errors so callers can pipe and check rc without polluting stderr.
__apimgr_jq() { jq "$@" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Base curl wrapper. Single source of truth for timeouts/retries; every API call goes through this.
__apimgr_curl() { curl -q -LSsf --max-time "${APIMGR_API_TIMEOUT:-10}" --retry "${APIMGR_API_RETRY:-1}" "$@"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Provider URL resolver. Pure env-var mapping; nothing is hardcoded. Precedence:
#   default mode:  APIMGR_<P>_URL  →  <P>_API_URL                    (these are your self-host/primary)
#   --official:    APIMGR_<P>_OFFICIAL_URL  →  <P>_OFFICIAL_API_URL  →  default-mode chain
# So if you only have <P>_API_URL set, both modes use it. Add <P>_OFFICIAL_API_URL only when you want them to differ.
__apimgr_provider_url() {
  local provider="${1^^}" url=""
  if [ "$APIMGR_OFFICIAL" = "true" ]; then
    eval "url=\${APIMGR_${provider}_OFFICIAL_URL:-}"
    [ -n "$url" ] || eval "url=\${${provider}_OFFICIAL_API_URL:-}"
  fi
  [ -n "$url" ] || eval "url=\${APIMGR_${provider}_URL:-}"
  [ -n "$url" ] || eval "url=\${${provider}_API_URL:-}"
  [ -n "$url" ] || return 1
  printf '%s' "${url%/}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Provider token resolver. --token <T> wins, then APIMGR_<P>_TOKEN, then user's <P>_ACCESS_TOKEN, then <P>_TOKEN.
# Docker is special-cased because the user's env uses DOCKER_HUB_API_KEY (not DOCKER_ACCESS_TOKEN).
__apimgr_provider_token() {
  local provider="${1^^}" token=""
  if [ -n "$APIMGR_TOKEN_OVERRIDE" ]; then
    printf '%s' "$APIMGR_TOKEN_OVERRIDE"
    return 0
  fi
  eval "token=\${APIMGR_${provider}_TOKEN:-}"
  [ -n "$token" ] || eval "token=\${${provider}_ACCESS_TOKEN:-}"
  [ -n "$token" ] || eval "token=\${${provider}_TOKEN:-}"
  if [ -z "$token" ] && [ "$provider" = "DOCKER" ]; then token="${DOCKER_HUB_API_KEY:-}"; fi
  [ -n "$token" ] || return 1
  printf '%s' "$token"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Default-username resolver. For listing self repos and similar, falls back to <P>_USERNAME (e.g. GITHUB_USERNAME).
__apimgr_provider_username() {
  local provider="${1^^}" name=""
  eval "name=\${APIMGR_${provider}_USERNAME:-}"
  [ -n "$name" ] || eval "name=\${${provider}_USERNAME:-}"
  [ -n "$name" ] || return 1
  printf '%s' "$name"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Refuses to make a call when creds aren't set. Returns 0 if both URL and token resolve, 1 otherwise.
__apimgr_require_creds() {
  local provider="$1" P="${1^^}"
  __apimgr_provider_url "$provider" >/dev/null \
    || __apimgr_die "No URL for '$provider' — set ${P}_API_URL or APIMGR_${P}_URL (use --official with ${P}_OFFICIAL_API_URL)"
  __apimgr_provider_token "$provider" >/dev/null \
    || __apimgr_die "No token for '$provider' — set ${P}_ACCESS_TOKEN, APIMGR_${P}_TOKEN, pass --token, or add it to ~/.config/secure/apimgr.txt"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Parse a git remote URL and emit "<provider> <user/repo>". Recognizes github/gitlab/codeberg by hostname,
# any *.gitea.* / *.forgejo.* by substring, and a self-host fallback to APIMGR_GIT_HOST_<host>_PROVIDER mapping.
__apimgr_detect_provider_from_git() {
  local cwd="${1:-$PWD}" remote_url provider="" repo=""
  remote_url="$(git -C "$cwd" remote get-url origin 2>/dev/null)" || return 1
  [ -n "$remote_url" ] || return 1
  case "$remote_url" in
    *github.com*)        provider="github"   ;;
    *gitlab.com*)        provider="gitlab"   ;;
    *codeberg.org*)      provider="codeberg" ;;
    *bitbucket.org*)     provider="bitbucket";;
    *gitea*)             provider="gitea"    ;;
    *forgejo*)           provider="forgejo"  ;;
    *)
      # Self-host hostname lookup: APIMGR_GIT_HOST_git_example_com_PROVIDER=gitea (dots → underscores).
      local host="${remote_url#*://}"; host="${host%%/*}"; host="${host#*@}"; host="${host%%:*}"
      local var="APIMGR_GIT_HOST_${host//./_}_PROVIDER"
      eval "provider=\${$var:-}"
      ;;
  esac
  [ -n "$provider" ] || return 1
  # Normalize remote into "user/repo": strip protocol, host, leading slash, trailing .git.
  repo="${remote_url##*[:/]*[!/:]/}"
  repo="${remote_url#*://*/}"
  repo="${repo#*:}"
  repo="${repo%.git}"
  printf '%s %s' "$provider" "$repo"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Resolve target repo from --repo flag or git-remote of cwd. Sets APIMGR_REPO and APIMGR_PROVIDER.
__apimgr_resolve_repo() {
  if [ -n "$APIMGR_REPO" ]; then return 0; fi
  local detect provider repo
  detect="$(__apimgr_detect_provider_from_git "$APIMGR_CWD")" || return 1
  provider="${detect%% *}"; repo="${detect##* }"
  APIMGR_PROVIDER="${APIMGR_PROVIDER:-$provider}"
  APIMGR_REPO="$repo"
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Resolve provider — explicit arg wins, then --provider flag, then auto-detect from git, then APIMGR_DEFAULT_PROVIDER.
__apimgr_resolve_provider() {
  local explicit="$1"
  if [ -n "$explicit" ]; then APIMGR_PROVIDER="$explicit"; return 0; fi
  if [ -n "$APIMGR_PROVIDER" ]; then return 0; fi
  local detect; detect="$(__apimgr_detect_provider_from_git "$APIMGR_CWD")" 2>/dev/null
  if [ -n "$detect" ]; then APIMGR_PROVIDER="${detect%% *}"; return 0; fi
  APIMGR_PROVIDER="${APIMGR_DEFAULT_PROVIDER:-github}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a list of repo JSON blobs as "name | description | private" rows. Used by every git provider.
__apimgr_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.full_name // .name)\t\(.description // "")\t\(.private // false)"' |
    awk -F'\t' 'BEGIN{OFS=" │ "} {printf "%-45s %-50s %s\n", $1, substr($2,1,48), ($3=="true"?"private":"public")}'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a single repo JSON blob (for `repo get`).
__apimgr_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.full_name // .name)",
    "URL:         \(.html_url // .web_url // .clone_url // "")",
    "Description: \(.description // "")",
    "Visibility:  \(if (.private // false) then "private" else "public" end)",
    "Default:     \(.default_branch // "")",
    "Stars:       \(.stargazers_count // .star_count // 0)",
    "Forks:       \(.forks_count // .forks // 0)",
    "Issues:      \(.open_issues_count // 0)"
  '
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print an issue list. Works for github/gitea (uses .number, .user.login) and gitlab (.iid, .author.username).
__apimgr_print_issue_list() {
  __apimgr_jq -r '.[] | "#\(.number // .iid)\t\(.state)\t\(.user.login // .author.username // "")\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-8s %-20s %s\n", $1, $2, substr($3,1,20), $4}'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a single issue (for `issue get`).
__apimgr_print_issue() {
  __apimgr_jq -r '
    "Number:  #\(.number // .iid)",
    "Title:   \(.title)",
    "State:   \(.state)",
    "Author:  \(.user.login // .author.username // "")",
    "URL:     \(.html_url // .web_url // "")",
    "Created: \(.created_at)",
    "",
    "\(.body // .description // "")"
  '
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Translate apimgr's --state values to provider-specific state names. github/gitea use open|closed|all;
# gitlab uses opened|closed|merged|all; bitbucket-PRs use UPPERCASE (OPEN|MERGED|DECLINED|SUPERSEDED);
# bitbucket-issues use a wholly different vocabulary so we fall through to pass-through there.
# The optional second arg ("issue"|"pr") lets the caller hint which surface they're targeting since
# bitbucket diverges between the two; default is "pr".
__apimgr_state_for() {
  local provider="$1" surface="${2:-pr}" state="${APIMGR_STATE:-open}"
  case "$provider" in
    gitlab)
      case "$state" in open) printf 'opened' ;; closed) printf 'closed' ;; merged) printf 'merged' ;; all) printf 'all' ;; *) printf '%s' "$state" ;; esac ;;
    bitbucket)
      if [ "$surface" = "pr" ]; then
        case "$state" in
          open) printf 'OPEN' ;; closed) printf 'DECLINED' ;; merged) printf 'MERGED' ;;
          all) printf 'OPEN,MERGED,DECLINED,SUPERSEDED' ;; *) printf '%s' "$state" ;;
        esac
      else
        # Bitbucket issues: new/open/resolved/closed/invalid/duplicate/wontfix/on hold. Pass through.
        case "$state" in all) printf '' ;; *) printf '%s' "$state" ;; esac
      fi ;;
    *) printf '%s' "$state" ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a PR list. Schema-tolerant: github/gitea use .number / .head.ref / .base.ref / .user.login;
# gitlab uses .iid / .source_branch / .target_branch / .author.username.
__apimgr_print_pr_list() {
  __apimgr_jq -r '.[] | "#\(.number // .iid)\t\(.state)\t\(.user.login // .author.username // "")\t\(.head.ref // .source_branch)→\(.base.ref // .target_branch)\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-8s %-18s %-30s %s\n", $1, $2, substr($3,1,18), substr($4,1,30), $5}'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a single PR (for `pr get`).
__apimgr_print_pr() {
  __apimgr_jq -r '
    "Number:    #\(.number // .iid)",
    "Title:     \(.title)",
    "State:     \(.state)\(if (.merged // false) then " (merged)" else "" end)",
    "Author:    \(.user.login // .author.username // "")",
    "Branches:  \(.head.ref // .source_branch) → \(.base.ref // .target_branch)",
    "Mergeable: \(.mergeable // .merge_status // "unknown")",
    "URL:       \(.html_url // .web_url // "")",
    "Created:   \(.created_at)",
    "",
    "\(.body // .description // "")"
  '
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a release list. github/gitea use .tag_name + .name + .draft + .prerelease;
# gitlab uses .tag_name + .name + .upcoming_release. Single jq filter handles both.
__apimgr_print_release_list() {
  __apimgr_jq -r '.[] | "\(.tag_name)\t\(.name // .tag_name)\t\(if (.draft // false) then "draft" elif (.prerelease // false) then "prerelease" else "release" end)\t\(.published_at // .released_at // .created_at // "")"' |
    awk -F'\t' '{printf "%-20s %-40s %-12s %s\n", $1, substr($2,1,40), $3, substr($4,1,10)}'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print a single release (for `release get`).
__apimgr_print_release() {
  __apimgr_jq -r '
    "Tag:       \(.tag_name)",
    "Name:      \(.name // .tag_name)",
    "Type:      \(if (.draft // false) then "draft" elif (.prerelease // false) then "prerelease" else "release" end)",
    "Author:    \(.author.login // .author.username // "")",
    "Target:    \(.target_commitish // .commit.id // "")",
    "URL:       \(.html_url // ._links.self // "")",
    "Published: \(.published_at // .released_at // .created_at // "")",
    "",
    "\(.body // .description // "")"
  '
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Confirmation prompt for destructive ops. Honors --force. Returns 0 if confirmed, 1 otherwise.
__apimgr_confirm() {
  local prompt="$1" reply
  if [ "$APIMGR_FORCE_INSTALL" = "true" ]; then return 0; fi
  if [ ! -t 0 ]; then __apimgr_die "Refusing destructive op in non-interactive mode without --force"; fi
  printf_yellow "$prompt [y/N] "
  read -r reply
  case "$reply" in [yY]|[yY][eE][sS]) return 0 ;; *) return 1 ;; esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== GitHub provider (api.github.com or GitHub Enterprise) ==============
__github_curl() {
  local token; token="$(__apimgr_provider_token github)" || return 1
  __apimgr_curl -H "Authorization: Bearer $token" -H "Accept: application/vnd.github+json" -H "X-GitHub-Api-Version: 2022-11-28" "$@"
}
__github_api()  { local base; base="$(__apimgr_provider_url github)" || return 1; __github_curl -X "${1:-GET}" "$base$2"; }
__github_post() { local base; base="$(__apimgr_provider_url github)" || return 1; __github_curl -X "${1:-POST}" --data "$3" "$base$2"; }

__github_verify() {
  __apimgr_require_creds github
  local resp; resp="$(__github_api GET /user)" || __apimgr_die "GitHub /user call failed"
  __apimgr_jq -r '"Authenticated as \(.login) (\(.name // "no name")) — \(.html_url)"' <<<"$resp"
}
__github_user_get() {
  __apimgr_require_creds github
  local who="${APIMGR_USER:-}" path
  if [ -n "$who" ]; then path="/users/$who"; else path="/user"; fi
  __github_api GET "$path" | __apimgr_jq .
}
__github_org_get() {
  __apimgr_require_creds github
  [ -n "$APIMGR_ORG" ] || __apimgr_die "github org get: --org NAME required"
  __github_api GET "/orgs/$APIMGR_ORG" | __apimgr_jq .
}
__github_org_all() {
  __apimgr_require_creds github
  [ -n "$APIMGR_ORG" ] || __apimgr_die "github org all: --org NAME required"
  __github_api GET "/orgs/$APIMGR_ORG/repos?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_repo_list
}
__github_repo_list() {
  __apimgr_require_creds github
  local path="/user/repos?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  if [ -n "$APIMGR_USER" ]; then path="/users/$APIMGR_USER/repos?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"; fi
  __github_api GET "$path" | __apimgr_print_repo_list
}
__github_repo_get() {
  __apimgr_require_creds github
  __apimgr_resolve_repo || __apimgr_die "github repo get: --repo USER/REPO required (not in a git repo with a recognized remote)"
  __github_api GET "/repos/$APIMGR_REPO" | __apimgr_print_repo
}
__github_repo_create() {
  __apimgr_require_creds github
  local name="${APIMGR_REPO##*/}" owner="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$owner" ] && [ "$owner" != "$name" ] || __apimgr_die "github repo create: --repo OWNER/NAME required"
  local visibility="${APIMGR_VISIBILITY:-public}" privflag="false"
  [ "$visibility" = "private" ] && privflag="true"
  local payload; payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --argjson p "$privflag" '{name:$n, description:$d, private:$p}')"
  # /user/repos creates under the authed user; /orgs/<owner>/repos creates under an org.
  local me; me="$(__github_api GET /user | __apimgr_jq -r '.login')"
  if [ "$owner" = "$me" ]; then
    __github_post POST "/user/repos" "$payload" | __apimgr_print_repo
  else
    __github_post POST "/orgs/$owner/repos" "$payload" | __apimgr_print_repo
  fi
}
__github_repo_delete() {
  __apimgr_require_creds github
  __apimgr_resolve_repo || __apimgr_die "github repo delete: --repo USER/REPO required"
  __apimgr_confirm "Delete $APIMGR_REPO from GitHub? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __github_api DELETE "/repos/$APIMGR_REPO" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__github_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __github_org_all; else __github_repo_list; fi
}
# Helper: every issue action needs the OWNER/REPO either from --repo or git auto-detect.
__github_issue_repo() {
  __apimgr_resolve_repo || __apimgr_die "github issue: --repo USER/REPO required (or run inside the repo's worktree)"
}
__github_issue_list() {
  __apimgr_require_creds github
  __github_issue_repo
  local state; state="$(__apimgr_state_for github)"
  __github_api GET "/repos/$APIMGR_REPO/issues?state=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" |
    __apimgr_jq '[.[] | select(.pull_request | not)]' |
    __apimgr_print_issue_list
}
__github_issue_get() {
  local n="$1"
  __apimgr_require_creds github
  __github_issue_repo
  [ -n "$n" ] || __apimgr_die "github issue get: issue NUMBER required (e.g. apimgr github issue get 42)"
  __github_api GET "/repos/$APIMGR_REPO/issues/$n" | __apimgr_print_issue
}
__github_issue_create() {
  __apimgr_require_creds github
  __github_issue_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "github issue create: --title required"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" '{title:$t, body:$b}')"
  __github_post POST "/repos/$APIMGR_REPO/issues" "$payload" | __apimgr_jq -r '"Created issue #\(.number) — \(.html_url)"'
}
__github_issue_close() {
  local n="$1"
  __apimgr_require_creds github
  __github_issue_repo
  [ -n "$n" ] || __apimgr_die "github issue close: issue NUMBER required"
  __github_post PATCH "/repos/$APIMGR_REPO/issues/$n" '{"state":"closed"}' | __apimgr_jq -r '"Closed issue #\(.number) — \(.html_url)"'
}
__github_issue_comment() {
  local n="$1"
  __apimgr_require_creds github
  __github_issue_repo
  [ -n "$n" ] || __apimgr_die "github issue comment: issue NUMBER required"
  [ -n "$APIMGR_BODY" ] || __apimgr_die "github issue comment: --body required"
  local payload; payload="$(__apimgr_jq -n --arg b "$APIMGR_BODY" '{body:$b}')"
  __github_post POST "/repos/$APIMGR_REPO/issues/$n/comments" "$payload" | __apimgr_jq -r '"Commented on issue #'"$n"' — \(.html_url)"'
}
# Default base branch — read from the repo's metadata. Tiny GET, but cached per-invocation in APIMGR_BASE_RESOLVED
# so a `pr create` doesn't pay for it twice. Honors --base if the user passed one.
__github_resolve_base() {
  if [ -n "$APIMGR_BASE" ]; then printf '%s' "$APIMGR_BASE"; return 0; fi
  if [ -n "$APIMGR_BASE_RESOLVED" ]; then printf '%s' "$APIMGR_BASE_RESOLVED"; return 0; fi
  APIMGR_BASE_RESOLVED="$(__github_api GET "/repos/$APIMGR_REPO" | __apimgr_jq -r '.default_branch // "main"')"
  printf '%s' "$APIMGR_BASE_RESOLVED"
}
__github_pr_repo() {
  __apimgr_resolve_repo || __apimgr_die "github pr: --repo USER/REPO required (or run inside the repo's worktree)"
}
__github_pr_list() {
  __apimgr_require_creds github
  __github_pr_repo
  local state; state="$(__apimgr_state_for github)"
  __github_api GET "/repos/$APIMGR_REPO/pulls?state=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_pr_list
}
__github_pr_get() {
  local n="$1"
  __apimgr_require_creds github
  __github_pr_repo
  [ -n "$n" ] || __apimgr_die "github pr get: PR NUMBER required (e.g. apimgr github pr get 42)"
  __github_api GET "/repos/$APIMGR_REPO/pulls/$n" | __apimgr_print_pr
}
__github_pr_create() {
  __apimgr_require_creds github
  __github_pr_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "github pr create: --title required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "github pr create: --branch SOURCE required (the branch the PR is from)"
  local base; base="$(__github_resolve_base)"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" --arg h "$APIMGR_BRANCH" --arg ba "$base" '{title:$t, body:$b, head:$h, base:$ba}')"
  __github_post POST "/repos/$APIMGR_REPO/pulls" "$payload" | __apimgr_jq -r '"Created PR #\(.number) (\(.head.ref) → \(.base.ref)) — \(.html_url)"'
}
__github_pr_merge() {
  local n="$1"
  __apimgr_require_creds github
  __github_pr_repo
  [ -n "$n" ] || __apimgr_die "github pr merge: PR NUMBER required"
  __apimgr_confirm "Merge PR #$n in $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __github_post PUT "/repos/$APIMGR_REPO/pulls/$n/merge" '{}' | __apimgr_jq -r 'if .merged then "Merged PR #'"$n"' — \(.sha[0:7])" else "Merge refused: \(.message // "unknown")" end'
}
__github_pr_close() {
  local n="$1"
  __apimgr_require_creds github
  __github_pr_repo
  [ -n "$n" ] || __apimgr_die "github pr close: PR NUMBER required"
  __github_post PATCH "/repos/$APIMGR_REPO/pulls/$n" '{"state":"closed"}' | __apimgr_jq -r '"Closed PR #\(.number) — \(.html_url)"'
}
# Release actions for github. `get` accepts either a numeric id or a tag name (resolved via /releases/tags/X).
__github_release_repo() { __apimgr_resolve_repo || __apimgr_die "github release: --repo USER/REPO required"; }
__github_release_list() {
  __apimgr_require_creds github
  __github_release_repo
  __github_api GET "/repos/$APIMGR_REPO/releases?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_release_list
}
__github_release_get() {
  local key="$1"
  __apimgr_require_creds github
  __github_release_repo
  [ -n "$key" ] || __apimgr_die "github release get: TAG or ID required (e.g. apimgr github release get v1.0.0)"
  # Numeric → /releases/<id>; otherwise treat as a tag name.
  case "$key" in
    [0-9]*) __github_api GET "/repos/$APIMGR_REPO/releases/$key" | __apimgr_print_release ;;
    *)      __github_api GET "/repos/$APIMGR_REPO/releases/tags/$key" | __apimgr_print_release ;;
  esac
}
__github_release_create() {
  __apimgr_require_creds github
  __github_release_repo
  [ -n "$APIMGR_TAG" ] || __apimgr_die "github release create: --tag NAME required (the git tag this release points to)"
  local payload; payload="$(__apimgr_jq -n \
    --arg tag "$APIMGR_TAG" \
    --arg name "${APIMGR_TITLE:-$APIMGR_TAG}" \
    --arg body "${APIMGR_BODY:-}" \
    --arg target "${APIMGR_BRANCH:-}" \
    '{tag_name:$tag, name:$name, body:$body} + (if $target == "" then {} else {target_commitish:$target} end)')"
  __github_post POST "/repos/$APIMGR_REPO/releases" "$payload" | __apimgr_jq -r '"Created release \(.tag_name) — \(.html_url)"'
}
__github_release_delete() {
  local key="$1"
  __apimgr_require_creds github
  __github_release_repo
  [ -n "$key" ] || __apimgr_die "github release delete: TAG or ID required"
  __apimgr_confirm "Delete release '$key' from $APIMGR_REPO? (Note: the underlying git tag is NOT removed.)" || { printf_yellow "Aborted"; return 1; }
  # GitHub's DELETE only takes numeric id; resolve the tag first if needed.
  local id="$key"
  case "$key" in
    [0-9]*) ;;
    *)      id="$(__github_api GET "/repos/$APIMGR_REPO/releases/tags/$key" | __apimgr_jq -r '.id // empty')"
            [ -n "$id" ] || __apimgr_die "github release delete: tag '$key' not found" ;;
  esac
  __github_api DELETE "/repos/$APIMGR_REPO/releases/$id" >/dev/null && printf_green "Deleted release '$key' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Gitea provider (covers Forgejo, Codeberg — same API surface) ==============
# Each subprovider gets its own URL/token resolution but shares the action implementation via __gitea_*.
__gitea_curl() {
  local provider="${1:-gitea}"; shift
  local token; token="$(__apimgr_provider_token "$provider")" || return 1
  __apimgr_curl -H "Authorization: token $token" -H "Accept: application/json" "$@"
}
__gitea_api() {
  local provider="$1" method="$2" path="$3" data="$4"
  local base; base="$(__apimgr_provider_url "$provider")" || return 1
  if [ -n "$data" ]; then
    __gitea_curl "$provider" -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __gitea_curl "$provider" -X "$method" "$base$path"
  fi
}
__gitea_verify() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  local resp; resp="$(__gitea_api "$provider" GET /user)" || __apimgr_die "$provider /user call failed"
  __apimgr_jq -r '"Authenticated as \(.login) (\(.full_name // "no name")) — \(.html_url // "")"' <<<"$resp"
}
__gitea_user_get() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  local who="${APIMGR_USER:-}" path
  if [ -n "$who" ]; then path="/users/$who"; else path="/user"; fi
  __gitea_api "$provider" GET "$path" | __apimgr_jq .
}
__gitea_org_get() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  [ -n "$APIMGR_ORG" ] || __apimgr_die "$provider org get: --org NAME required"
  __gitea_api "$provider" GET "/orgs/$APIMGR_ORG" | __apimgr_jq .
}
__gitea_org_all() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  [ -n "$APIMGR_ORG" ] || __apimgr_die "$provider org all: --org NAME required"
  __gitea_api "$provider" GET "/orgs/$APIMGR_ORG/repos?limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_repo_list
}
__gitea_repo_list() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  local path="/repos/search?limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  [ -n "$APIMGR_USER" ] && path="/users/$APIMGR_USER/repos?limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  __gitea_api "$provider" GET "$path" | __apimgr_jq '.data // .' | __apimgr_print_repo_list
}
__gitea_repo_get() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __apimgr_resolve_repo || __apimgr_die "$provider repo get: --repo USER/REPO required"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO" | __apimgr_print_repo
}
__gitea_repo_create() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  local name="${APIMGR_REPO##*/}" owner="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$owner" ] && [ "$owner" != "$name" ] || __apimgr_die "$provider repo create: --repo OWNER/NAME required"
  local visibility="${APIMGR_VISIBILITY:-public}" privflag="false"
  [ "$visibility" = "private" ] && privflag="true"
  local payload; payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --argjson p "$privflag" '{name:$n, description:$d, private:$p, auto_init:true}')"
  local me; me="$(__gitea_api "$provider" GET /user | __apimgr_jq -r '.login')"
  if [ "$owner" = "$me" ]; then
    __gitea_api "$provider" POST "/user/repos" "$payload" | __apimgr_print_repo
  else
    __gitea_api "$provider" POST "/orgs/$owner/repos" "$payload" | __apimgr_print_repo
  fi
}
__gitea_repo_delete() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __apimgr_resolve_repo || __apimgr_die "$provider repo delete: --repo USER/REPO required"
  __apimgr_confirm "Delete $APIMGR_REPO from $provider? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __gitea_api "$provider" DELETE "/repos/$APIMGR_REPO" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__gitea_repo_all() {
  local provider="$1"
  if [ -n "$APIMGR_ORG" ]; then __gitea_org_all "$provider"; else __gitea_repo_list "$provider"; fi
}
# Issue actions for gitea-family. Same paths as github, just different auth header (handled in __gitea_curl).
__gitea_issue_repo() {
  local provider="$1"
  __apimgr_resolve_repo || __apimgr_die "$provider issue: --repo USER/REPO required"
}
__gitea_issue_list() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_issue_repo "$provider"
  local state; state="$(__apimgr_state_for "$provider")"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/issues?state=$state&type=issues&limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" |
    __apimgr_print_issue_list
}
__gitea_issue_get() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_issue_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider issue get: issue NUMBER required"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/issues/$n" | __apimgr_print_issue
}
__gitea_issue_create() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_issue_repo "$provider"
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "$provider issue create: --title required"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" '{title:$t, body:$b}')"
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/issues" "$payload" | __apimgr_jq -r '"Created issue #\(.number) — \(.html_url)"'
}
__gitea_issue_close() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_issue_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider issue close: issue NUMBER required"
  __gitea_api "$provider" PATCH "/repos/$APIMGR_REPO/issues/$n" '{"state":"closed"}' | __apimgr_jq -r '"Closed issue #\(.number) — \(.html_url)"'
}
__gitea_issue_comment() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_issue_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider issue comment: issue NUMBER required"
  [ -n "$APIMGR_BODY" ] || __apimgr_die "$provider issue comment: --body required"
  local payload; payload="$(__apimgr_jq -n --arg b "$APIMGR_BODY" '{body:$b}')"
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/issues/$n/comments" "$payload" | __apimgr_jq -r '"Commented on issue #'"$n"' — \(.html_url)"'
}
# Gitea PR actions. Same path shape as github (/pulls), different merge endpoint (POST /pulls/N/merge with {Do:"merge"}).
__gitea_resolve_base() {
  local provider="$1"
  if [ -n "$APIMGR_BASE" ]; then printf '%s' "$APIMGR_BASE"; return 0; fi
  if [ -n "$APIMGR_BASE_RESOLVED" ]; then printf '%s' "$APIMGR_BASE_RESOLVED"; return 0; fi
  APIMGR_BASE_RESOLVED="$(__gitea_api "$provider" GET "/repos/$APIMGR_REPO" | __apimgr_jq -r '.default_branch // "main"')"
  printf '%s' "$APIMGR_BASE_RESOLVED"
}
__gitea_pr_repo() {
  local provider="$1"
  __apimgr_resolve_repo || __apimgr_die "$provider pr: --repo USER/REPO required"
}
__gitea_pr_list() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_pr_repo "$provider"
  local state; state="$(__apimgr_state_for "$provider")"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/pulls?state=$state&limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_pr_list
}
__gitea_pr_get() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_pr_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider pr get: PR NUMBER required"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/pulls/$n" | __apimgr_print_pr
}
__gitea_pr_create() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_pr_repo "$provider"
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "$provider pr create: --title required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "$provider pr create: --branch SOURCE required"
  local base; base="$(__gitea_resolve_base "$provider")"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" --arg h "$APIMGR_BRANCH" --arg ba "$base" '{title:$t, body:$b, head:$h, base:$ba}')"
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/pulls" "$payload" | __apimgr_jq -r '"Created PR #\(.number) (\(.head.ref) → \(.base.ref)) — \(.html_url)"'
}
__gitea_pr_merge() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_pr_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider pr merge: PR NUMBER required"
  __apimgr_confirm "Merge PR #$n in $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/pulls/$n/merge" '{"Do":"merge"}' >/dev/null && printf_green "Merged PR #$n"
}
__gitea_pr_close() {
  local provider="$1" n="$2"
  __apimgr_require_creds "$provider"
  __gitea_pr_repo "$provider"
  [ -n "$n" ] || __apimgr_die "$provider pr close: PR NUMBER required"
  __gitea_api "$provider" PATCH "/repos/$APIMGR_REPO/pulls/$n" '{"state":"closed"}' | __apimgr_jq -r '"Closed PR #\(.number) — \(.html_url)"'
}
# Release actions for gitea-family. Same paths as github (/releases, /releases/tags/X).
__gitea_release_repo() { local provider="$1"; __apimgr_resolve_repo || __apimgr_die "$provider release: --repo USER/REPO required"; }
__gitea_release_list() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_release_repo "$provider"
  __gitea_api "$provider" GET "/repos/$APIMGR_REPO/releases?limit=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_release_list
}
__gitea_release_get() {
  local provider="$1" key="$2"
  __apimgr_require_creds "$provider"
  __gitea_release_repo "$provider"
  [ -n "$key" ] || __apimgr_die "$provider release get: TAG or ID required"
  case "$key" in
    [0-9]*) __gitea_api "$provider" GET "/repos/$APIMGR_REPO/releases/$key" | __apimgr_print_release ;;
    *)      __gitea_api "$provider" GET "/repos/$APIMGR_REPO/releases/tags/$key" | __apimgr_print_release ;;
  esac
}
__gitea_release_create() {
  local provider="$1"
  __apimgr_require_creds "$provider"
  __gitea_release_repo "$provider"
  [ -n "$APIMGR_TAG" ] || __apimgr_die "$provider release create: --tag NAME required"
  local payload; payload="$(__apimgr_jq -n \
    --arg tag "$APIMGR_TAG" \
    --arg name "${APIMGR_TITLE:-$APIMGR_TAG}" \
    --arg body "${APIMGR_BODY:-}" \
    --arg target "${APIMGR_BRANCH:-}" \
    '{tag_name:$tag, name:$name, body:$body} + (if $target == "" then {} else {target_commitish:$target} end)')"
  __gitea_api "$provider" POST "/repos/$APIMGR_REPO/releases" "$payload" | __apimgr_jq -r '"Created release \(.tag_name) — \(.html_url)"'
}
__gitea_release_delete() {
  local provider="$1" key="$2"
  __apimgr_require_creds "$provider"
  __gitea_release_repo "$provider"
  [ -n "$key" ] || __apimgr_die "$provider release delete: TAG or ID required"
  __apimgr_confirm "Delete release '$key' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  local id="$key"
  case "$key" in
    [0-9]*) ;;
    *)      id="$(__gitea_api "$provider" GET "/repos/$APIMGR_REPO/releases/tags/$key" | __apimgr_jq -r '.id // empty')"
            [ -n "$id" ] || __apimgr_die "$provider release delete: tag '$key' not found" ;;
  esac
  __gitea_api "$provider" DELETE "/repos/$APIMGR_REPO/releases/$id" >/dev/null && printf_green "Deleted release '$key' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== GitLab provider (api.v4 — uses PRIVATE-TOKEN header and URL-encoded namespace/path) ==============
# URL-encode a path segment (replace '/' with '%2F'). Used to address GitLab projects by their full path.
__gitlab_urlenc() { printf '%s' "${1//\//%2F}"; }
__gitlab_curl() {
  local token; token="$(__apimgr_provider_token gitlab)" || return 1
  __apimgr_curl -H "PRIVATE-TOKEN: $token" -H "Accept: application/json" "$@"
}
__gitlab_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url gitlab)" || return 1
  if [ -n "$data" ]; then
    __gitlab_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __gitlab_curl -X "$method" "$base$path"
  fi
}
__gitlab_verify() {
  __apimgr_require_creds gitlab
  local resp; resp="$(__gitlab_api GET /user)" || __apimgr_die "GitLab /user call failed"
  __apimgr_jq -r '"Authenticated as \(.username) (\(.name // "no name")) — \(.web_url)"' <<<"$resp"
}
__gitlab_user_get() {
  __apimgr_require_creds gitlab
  if [ -n "$APIMGR_USER" ]; then
    # GitLab's /users endpoint takes ?username= for lookup; returns an array of length 0 or 1.
    __gitlab_api GET "/users?username=$APIMGR_USER" | __apimgr_jq '.[0] // empty'
  else
    __gitlab_api GET /user | __apimgr_jq .
  fi
}
__gitlab_org_get() {
  __apimgr_require_creds gitlab
  [ -n "$APIMGR_ORG" ] || __apimgr_die "gitlab org get: --org NAME required"
  # GitLab "groups" are the equivalent of orgs; addressable by id or full path.
  __gitlab_api GET "/groups/$(__gitlab_urlenc "$APIMGR_ORG")" | __apimgr_jq .
}
__gitlab_org_all() {
  __apimgr_require_creds gitlab
  [ -n "$APIMGR_ORG" ] || __apimgr_die "gitlab org all: --org NAME required"
  __gitlab_api GET "/groups/$(__gitlab_urlenc "$APIMGR_ORG")/projects?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}&include_subgroups=true" |
    __apimgr_jq -r '.[] | "\(.path_with_namespace)\t\(.description // "")\t\(.visibility)"' |
    awk -F'\t' 'BEGIN{OFS=" │ "} {printf "%-45s %-50s %s\n", $1, substr($2,1,48), $3}'
}
__gitlab_repo_list() {
  __apimgr_require_creds gitlab
  local path
  if [ -n "$APIMGR_USER" ]; then
    path="/users/$(__gitlab_urlenc "$APIMGR_USER")/projects?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  else
    # /projects?membership=true returns all repos the authed user has any role in.
    path="/projects?membership=true&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  fi
  __gitlab_api GET "$path" |
    __apimgr_jq -r '.[] | "\(.path_with_namespace)\t\(.description // "")\t\(.visibility)"' |
    awk -F'\t' 'BEGIN{OFS=" │ "} {printf "%-45s %-50s %s\n", $1, substr($2,1,48), $3}'
}
__gitlab_repo_get() {
  __apimgr_require_creds gitlab
  __apimgr_resolve_repo || __apimgr_die "gitlab repo get: --repo USER/REPO required"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")" | __apimgr_jq -r '
    "Name:        \(.path_with_namespace)",
    "URL:         \(.web_url)",
    "Description: \(.description // "")",
    "Visibility:  \(.visibility)",
    "Default:     \(.default_branch // "")",
    "Stars:       \(.star_count // 0)",
    "Forks:       \(.forks_count // 0)",
    "Issues:      \(.open_issues_count // 0)"
  '
}
__gitlab_repo_create() {
  __apimgr_require_creds gitlab
  local name="${APIMGR_REPO##*/}" owner="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$owner" ] && [ "$owner" != "$name" ] || __apimgr_die "gitlab repo create: --repo OWNER/NAME required"
  local visibility="${APIMGR_VISIBILITY:-public}"
  # GitLab's create-project requires a numeric namespace_id when the owner isn't the authed user.
  local me_id me_username payload
  me_username="$(__gitlab_api GET /user | __apimgr_jq -r '.username')"
  if [ "$owner" = "$me_username" ]; then
    payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --arg v "$visibility" '{name:$n, description:$d, visibility:$v, initialize_with_readme:true}')"
  else
    local ns_id; ns_id="$(__gitlab_api GET "/groups/$(__gitlab_urlenc "$owner")" | __apimgr_jq -r '.id // empty')"
    [ -n "$ns_id" ] || __apimgr_die "gitlab repo create: group '$owner' not found or not visible"
    payload="$(__apimgr_jq -n --arg n "$name" --arg d "${APIMGR_BODY:-}" --arg v "$visibility" --argjson nid "$ns_id" '{name:$n, description:$d, visibility:$v, namespace_id:$nid, initialize_with_readme:true}')"
  fi
  __gitlab_api POST /projects "$payload" | __apimgr_jq -r '"Created: \(.path_with_namespace) — \(.web_url)"'
}
__gitlab_repo_delete() {
  __apimgr_require_creds gitlab
  __apimgr_resolve_repo || __apimgr_die "gitlab repo delete: --repo USER/REPO required"
  __apimgr_confirm "Delete $APIMGR_REPO from GitLab? This is irreversible (and on gitlab.com, queued for 7 days before hard delete)." || { printf_yellow "Aborted"; return 1; }
  __gitlab_api DELETE "/projects/$(__gitlab_urlenc "$APIMGR_REPO")" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__gitlab_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __gitlab_org_all; else __gitlab_repo_list; fi
}
# GitLab issue actions. Field names differ: .iid (not .number), .description (not .body), state values
# are opened|closed|all (normalized via __apimgr_state_for). Comments live under /notes, not /comments.
__gitlab_issue_repo() {
  __apimgr_resolve_repo || __apimgr_die "gitlab issue: --repo USER/REPO required"
}
__gitlab_issue_list() {
  __apimgr_require_creds gitlab
  __gitlab_issue_repo
  local state; state="$(__apimgr_state_for gitlab)"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/issues?state=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" |
    __apimgr_print_issue_list
}
__gitlab_issue_get() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_issue_repo
  [ -n "$n" ] || __apimgr_die "gitlab issue get: issue IID required"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/issues/$n" | __apimgr_print_issue
}
__gitlab_issue_create() {
  __apimgr_require_creds gitlab
  __gitlab_issue_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "gitlab issue create: --title required"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg d "${APIMGR_BODY:-}" '{title:$t, description:$d}')"
  __gitlab_api POST "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/issues" "$payload" | __apimgr_jq -r '"Created issue #\(.iid) — \(.web_url)"'
}
__gitlab_issue_close() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_issue_repo
  [ -n "$n" ] || __apimgr_die "gitlab issue close: issue IID required"
  __gitlab_api PUT "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/issues/$n" '{"state_event":"close"}' | __apimgr_jq -r '"Closed issue #\(.iid) — \(.web_url)"'
}
__gitlab_issue_comment() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_issue_repo
  [ -n "$n" ] || __apimgr_die "gitlab issue comment: issue IID required"
  [ -n "$APIMGR_BODY" ] || __apimgr_die "gitlab issue comment: --body required"
  local payload; payload="$(__apimgr_jq -n --arg b "$APIMGR_BODY" '{body:$b}')"
  __gitlab_api POST "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/issues/$n/notes" "$payload" | __apimgr_jq -r '"Commented on issue #'"$n"' — \(.web_url // "")"'
}
# GitLab merge-request actions. /merge_requests not /pulls; .iid not .number; source_branch/target_branch instead of head/base;
# merge is PUT /merge_requests/N/merge; close is PUT with state_event=close (not PATCH state=closed).
__gitlab_resolve_base() {
  if [ -n "$APIMGR_BASE" ]; then printf '%s' "$APIMGR_BASE"; return 0; fi
  if [ -n "$APIMGR_BASE_RESOLVED" ]; then printf '%s' "$APIMGR_BASE_RESOLVED"; return 0; fi
  APIMGR_BASE_RESOLVED="$(__gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")" | __apimgr_jq -r '.default_branch // "main"')"
  printf '%s' "$APIMGR_BASE_RESOLVED"
}
__gitlab_pr_repo() { __apimgr_resolve_repo || __apimgr_die "gitlab pr: --repo USER/REPO required"; }
__gitlab_pr_list() {
  __apimgr_require_creds gitlab
  __gitlab_pr_repo
  local state; state="$(__apimgr_state_for gitlab)"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/merge_requests?state=$state&per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_pr_list
}
__gitlab_pr_get() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_pr_repo
  [ -n "$n" ] || __apimgr_die "gitlab pr get: MR IID required"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/merge_requests/$n" | __apimgr_print_pr
}
__gitlab_pr_create() {
  __apimgr_require_creds gitlab
  __gitlab_pr_repo
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "gitlab pr create: --title required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "gitlab pr create: --branch SOURCE required"
  local base; base="$(__gitlab_resolve_base)"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg d "${APIMGR_BODY:-}" --arg s "$APIMGR_BRANCH" --arg ta "$base" '{title:$t, description:$d, source_branch:$s, target_branch:$ta}')"
  __gitlab_api POST "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/merge_requests" "$payload" | __apimgr_jq -r '"Created MR #\(.iid) (\(.source_branch) → \(.target_branch)) — \(.web_url)"'
}
__gitlab_pr_merge() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_pr_repo
  [ -n "$n" ] || __apimgr_die "gitlab pr merge: MR IID required"
  __apimgr_confirm "Merge MR !$n in $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __gitlab_api PUT "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/merge_requests/$n/merge" '{}' | __apimgr_jq -r 'if .state == "merged" then "Merged MR !'"$n"' — \(.merge_commit_sha[0:7])" else "Merge refused: state=\(.state)" end'
}
__gitlab_pr_close() {
  local n="$1"
  __apimgr_require_creds gitlab
  __gitlab_pr_repo
  [ -n "$n" ] || __apimgr_die "gitlab pr close: MR IID required"
  __gitlab_api PUT "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/merge_requests/$n" '{"state_event":"close"}' | __apimgr_jq -r '"Closed MR !\(.iid) — \(.web_url)"'
}
# Release actions for gitlab. Releases are addressed by tag_name only (no numeric id), and the field is
# `description` not `body`. The optional `ref` field on create lets you tag a non-default branch.
__gitlab_release_repo() { __apimgr_resolve_repo || __apimgr_die "gitlab release: --repo USER/REPO required"; }
__gitlab_release_list() {
  __apimgr_require_creds gitlab
  __gitlab_release_repo
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/releases?per_page=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __apimgr_print_release_list
}
__gitlab_release_get() {
  local key="$1"
  __apimgr_require_creds gitlab
  __gitlab_release_repo
  [ -n "$key" ] || __apimgr_die "gitlab release get: TAG required"
  __gitlab_api GET "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/releases/$(__gitlab_urlenc "$key")" | __apimgr_print_release
}
__gitlab_release_create() {
  __apimgr_require_creds gitlab
  __gitlab_release_repo
  [ -n "$APIMGR_TAG" ] || __apimgr_die "gitlab release create: --tag NAME required"
  # GitLab requires `ref` for tags that don't yet exist (it'll create the tag). If --branch is given use it,
  # otherwise default to the project's default_branch via the same resolver used by pr-create.
  local ref; ref="$(__gitlab_resolve_base)"
  local payload; payload="$(__apimgr_jq -n \
    --arg tag "$APIMGR_TAG" \
    --arg name "${APIMGR_TITLE:-$APIMGR_TAG}" \
    --arg desc "${APIMGR_BODY:-}" \
    --arg ref "$ref" \
    '{tag_name:$tag, name:$name, description:$desc, ref:$ref}')"
  __gitlab_api POST "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/releases" "$payload" | __apimgr_jq -r '"Created release \(.tag_name) — \(._links.self // "")"'
}
__gitlab_release_delete() {
  local key="$1"
  __apimgr_require_creds gitlab
  __gitlab_release_repo
  [ -n "$key" ] || __apimgr_die "gitlab release delete: TAG required"
  __apimgr_confirm "Delete release '$key' from $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __gitlab_api DELETE "/projects/$(__gitlab_urlenc "$APIMGR_REPO")/releases/$(__gitlab_urlenc "$key")" >/dev/null && printf_green "Deleted release '$key' from $APIMGR_REPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ============== Bitbucket Cloud provider (api v2.0 — workspaces/repositories/{slug}, paginated {values:[]} wrappers) ==============
# Auth: Bearer token (workspace/repo access tokens or OAuth). Basic auth with app passwords also works
# but the resolver chain doesn't expose username — users wanting Basic auth should pre-encode and pass via --token.
__bitbucket_curl() {
  local token; token="$(__apimgr_provider_token bitbucket)" || return 1
  __apimgr_curl -H "Authorization: Bearer $token" -H "Accept: application/json" "$@"
}
__bitbucket_api() {
  local method="$1" path="$2" data="$3"
  local base; base="$(__apimgr_provider_url bitbucket)" || return 1
  if [ -n "$data" ]; then
    __bitbucket_curl -X "$method" -H "Content-Type: application/json" --data "$data" "$base$path"
  else
    __bitbucket_curl -X "$method" "$base$path"
  fi
}
# Bitbucket list responses wrap data in {values:[]}; this unwraps so the shared formatters see a bare array.
__bitbucket_unwrap() { __apimgr_jq '.values // .'; }
__bitbucket_repo_check() { __apimgr_resolve_repo || __apimgr_die "bitbucket: --repo WORKSPACE/REPO required"; }
# Bitbucket-shaped repo formatters (different field names: full_name, is_private, links.html.href, mainbranch).
__bitbucket_print_repo_list() {
  __apimgr_jq -r '.[] | "\(.full_name)\t\(.description // "")\t\(.is_private)"' |
    awk -F'\t' '{printf "%-45s %-50s %s\n", $1, substr($2,1,48), ($3=="true"?"private":"public")}'
}
__bitbucket_print_repo() {
  __apimgr_jq -r '
    "Name:        \(.full_name)",
    "URL:         \(.links.html.href // "")",
    "Description: \(.description // "")",
    "Visibility:  \(if .is_private then "private" else "public" end)",
    "Default:     \(.mainbranch.name // "")",
    "Size:        \(.size // 0) bytes",
    "Language:    \(.language // "")"
  '
}
# Issue/PR formatters work on Bitbucket because the shared formatters fall back via // chains, but
# Bitbucket issues use .reporter.display_name and .content.raw — we add an unwrap in the issue/PR list paths.
__bitbucket_print_issue_list() {
  __apimgr_jq -r '.[] | "#\(.id)\t\(.state)\t\(.reporter.display_name // "")\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-12s %-20s %s\n", $1, substr($2,1,12), substr($3,1,20), $4}'
}
__bitbucket_print_pr_list() {
  __apimgr_jq -r '.[] | "#\(.id)\t\(.state)\t\(.author.display_name // "")\t\(.source.branch.name)→\(.destination.branch.name)\t\(.title)"' |
    awk -F'\t' '{printf "%-7s %-10s %-18s %-30s %s\n", $1, substr($2,1,10), substr($3,1,18), substr($4,1,30), $5}'
}
__bitbucket_verify() {
  __apimgr_require_creds bitbucket
  local resp; resp="$(__bitbucket_api GET /user)" || __apimgr_die "Bitbucket /user call failed"
  __apimgr_jq -r '"Authenticated as \(.username) (\(.display_name // "no name")) — \(.links.html.href // "")"' <<<"$resp"
}
__bitbucket_user_get() {
  __apimgr_require_creds bitbucket
  if [ -n "$APIMGR_USER" ]; then
    # Bitbucket /users/{name} was deprecated in 2019; the canonical lookup is by UUID (impractical) or
    # via the legacy workspace endpoint. Document the limitation and surface what we can — workspace info.
    __bitbucket_api GET "/workspaces/$APIMGR_USER" | __apimgr_jq .
  else
    __bitbucket_api GET /user | __apimgr_jq .
  fi
}
__bitbucket_org_get() {
  __apimgr_require_creds bitbucket
  [ -n "$APIMGR_ORG" ] || __apimgr_die "bitbucket org get: --org WORKSPACE required"
  __bitbucket_api GET "/workspaces/$APIMGR_ORG" | __apimgr_jq .
}
__bitbucket_org_all() {
  __apimgr_require_creds bitbucket
  [ -n "$APIMGR_ORG" ] || __apimgr_die "bitbucket org all: --org WORKSPACE required"
  __bitbucket_api GET "/repositories/$APIMGR_ORG?pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __bitbucket_unwrap | __bitbucket_print_repo_list
}
__bitbucket_repo_list() {
  __apimgr_require_creds bitbucket
  local path="/repositories?role=member&pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  [ -n "$APIMGR_USER" ] && path="/repositories/$APIMGR_USER?pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}"
  __bitbucket_api GET "$path" | __bitbucket_unwrap | __bitbucket_print_repo_list
}
__bitbucket_repo_get() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  __bitbucket_api GET "/repositories/$APIMGR_REPO" | __bitbucket_print_repo
}
__bitbucket_repo_create() {
  __apimgr_require_creds bitbucket
  local name="${APIMGR_REPO##*/}" owner="${APIMGR_REPO%/*}"
  [ -n "$name" ] && [ -n "$owner" ] && [ "$owner" != "$name" ] || __apimgr_die "bitbucket repo create: --repo WORKSPACE/REPO required"
  local visibility="${APIMGR_VISIBILITY:-public}" privflag="false"
  [ "$visibility" = "private" ] && privflag="true"
  local payload; payload="$(__apimgr_jq -n --arg d "${APIMGR_BODY:-}" --argjson p "$privflag" '{scm:"git", description:$d, is_private:$p}')"
  __bitbucket_api POST "/repositories/$APIMGR_REPO" "$payload" | __bitbucket_print_repo
}
__bitbucket_repo_delete() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  __apimgr_confirm "Delete $APIMGR_REPO from Bitbucket? This is irreversible." || { printf_yellow "Aborted"; return 1; }
  __bitbucket_api DELETE "/repositories/$APIMGR_REPO" >/dev/null && printf_green "Deleted $APIMGR_REPO"
}
__bitbucket_repo_all() {
  if [ -n "$APIMGR_ORG" ]; then __bitbucket_org_all; else __bitbucket_repo_list; fi
}
__bitbucket_issue_list() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  local state; state="$(__apimgr_state_for bitbucket issue)"
  local q=""; [ -n "$state" ] && q="?q=state%3D%22$state%22&"
  __bitbucket_api GET "/repositories/$APIMGR_REPO/issues${q}pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __bitbucket_unwrap | __bitbucket_print_issue_list
}
__bitbucket_issue_get() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket issue get: issue ID required"
  __bitbucket_api GET "/repositories/$APIMGR_REPO/issues/$n" | __apimgr_jq -r '
    "ID:        #\(.id)",
    "Title:     \(.title)",
    "State:     \(.state)",
    "Reporter:  \(.reporter.display_name // "")",
    "URL:       \(.links.html.href // "")",
    "Created:   \(.created_on)",
    "",
    "\(.content.raw // "")"
  '
}
__bitbucket_issue_create() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "bitbucket issue create: --title required"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg b "${APIMGR_BODY:-}" '{title:$t, content:{raw:$b}, kind:"task", priority:"minor"}')"
  __bitbucket_api POST "/repositories/$APIMGR_REPO/issues" "$payload" | __apimgr_jq -r '"Created issue #\(.id) — \(.links.html.href)"'
}
__bitbucket_issue_close() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket issue close: issue ID required"
  # Bitbucket issue close = state="resolved". Use PUT with full state field.
  __bitbucket_api PUT "/repositories/$APIMGR_REPO/issues/$n" '{"state":"resolved"}' | __apimgr_jq -r '"Closed issue #\(.id) — \(.links.html.href)"'
}
__bitbucket_issue_comment() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket issue comment: issue ID required"
  [ -n "$APIMGR_BODY" ] || __apimgr_die "bitbucket issue comment: --body required"
  local payload; payload="$(__apimgr_jq -n --arg b "$APIMGR_BODY" '{content:{raw:$b}}')"
  __bitbucket_api POST "/repositories/$APIMGR_REPO/issues/$n/comments" "$payload" >/dev/null && printf_green "Commented on issue #$n"
}
# PR/MR actions for bitbucket. State vocabulary differs (UPPERCASE), and "close" is "decline".
__bitbucket_resolve_base() {
  if [ -n "$APIMGR_BASE" ]; then printf '%s' "$APIMGR_BASE"; return 0; fi
  if [ -n "$APIMGR_BASE_RESOLVED" ]; then printf '%s' "$APIMGR_BASE_RESOLVED"; return 0; fi
  APIMGR_BASE_RESOLVED="$(__bitbucket_api GET "/repositories/$APIMGR_REPO" | __apimgr_jq -r '.mainbranch.name // "main"')"
  printf '%s' "$APIMGR_BASE_RESOLVED"
}
__bitbucket_pr_list() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  local state; state="$(__apimgr_state_for bitbucket pr)"
  __bitbucket_api GET "/repositories/$APIMGR_REPO/pullrequests?state=$state&pagelen=${APIMGR_LIMIT:-${APIMGR_DEFAULT_LIMIT:-30}}" | __bitbucket_unwrap | __bitbucket_print_pr_list
}
__bitbucket_pr_get() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket pr get: PR ID required"
  __bitbucket_api GET "/repositories/$APIMGR_REPO/pullrequests/$n" | __apimgr_jq -r '
    "ID:        #\(.id)",
    "Title:     \(.title)",
    "State:     \(.state)",
    "Author:    \(.author.display_name // "")",
    "Branches:  \(.source.branch.name) → \(.destination.branch.name)",
    "URL:       \(.links.html.href // "")",
    "Created:   \(.created_on)",
    "",
    "\(.description // "")"
  '
}
__bitbucket_pr_create() {
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$APIMGR_TITLE" ] || __apimgr_die "bitbucket pr create: --title required"
  [ -n "$APIMGR_BRANCH" ] || __apimgr_die "bitbucket pr create: --branch SOURCE required"
  local base; base="$(__bitbucket_resolve_base)"
  local payload; payload="$(__apimgr_jq -n --arg t "$APIMGR_TITLE" --arg d "${APIMGR_BODY:-}" --arg s "$APIMGR_BRANCH" --arg ta "$base" \
    '{title:$t, description:$d, source:{branch:{name:$s}}, destination:{branch:{name:$ta}}}')"
  __bitbucket_api POST "/repositories/$APIMGR_REPO/pullrequests" "$payload" | __apimgr_jq -r '"Created PR #\(.id) (\(.source.branch.name) → \(.destination.branch.name)) — \(.links.html.href)"'
}
__bitbucket_pr_merge() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket pr merge: PR ID required"
  __apimgr_confirm "Merge PR #$n in $APIMGR_REPO?" || { printf_yellow "Aborted"; return 1; }
  __bitbucket_api POST "/repositories/$APIMGR_REPO/pullrequests/$n/merge" '{"merge_strategy":"merge_commit"}' | __apimgr_jq -r 'if .state == "MERGED" then "Merged PR #'"$n"'" else "Merge state: \(.state)" end'
}
__bitbucket_pr_close() {
  local n="$1"
  __apimgr_require_creds bitbucket
  __bitbucket_repo_check
  [ -n "$n" ] || __apimgr_die "bitbucket pr close: PR ID required"
  # Bitbucket: close = decline. Separate endpoint, not a state PATCH.
  __bitbucket_api POST "/repositories/$APIMGR_REPO/pullrequests/$n/decline" '{}' | __apimgr_jq -r '"Declined PR #\(.id) — \(.links.html.href)"'
}
# Bitbucket Cloud has no first-class release object — releases are just git tags. Surface a friendly stub
# rather than a generic "not implemented" so the user knows it's a platform limitation, not a missing feature.
__bitbucket_release_unsupported() {
  __apimgr_die "bitbucket has no release API (releases are plain git tags). Use 'apimgr bitbucket api /repositories/$APIMGR_REPO/refs/tags' for tags."
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Stub providers — print a clear "not yet implemented" so the dispatch surface is honest about what works.
__apimgr_stub_provider() {
  __apimgr_die "Provider '$1' is not implemented yet. Architecture is in place; add __${1}_<action> functions to enable. See bin/apimgr __github_* / __gitea_* for templates."
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Provider dispatcher — routes "<provider> <action> [sub] [extra positionals]" to the right __<provider>_<action>
# function. Extra positionals (e.g. an issue number after `issue get`) are passed through to the action functions.
__apimgr_dispatch_provider() {
  local provider="$1" action="$2" sub="${3:-}"
  shift 3 2>/dev/null || true
  case "$provider" in
    github)
      case "$action" in
        verify)               __github_verify ;;
        user)                 __github_user_get ;;
        org)
          case "$sub" in
            all)              __github_org_all ;;
            *)                __github_org_get ;;
          esac ;;
        repo)
          case "$sub" in
            list)             __github_repo_list ;;
            get|"")           __github_repo_get ;;
            create)           __github_repo_create ;;
            delete|rm)        __github_repo_delete ;;
            all)              __github_repo_all ;;
            *)                __apimgr_die "github repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __github_issue_list ;;
            get|show)         __github_issue_get "$1" ;;
            create|new)       __github_issue_create ;;
            close)            __github_issue_close "$1" ;;
            comment)          __github_issue_comment "$1" ;;
            *)                __apimgr_die "github issue: unknown sub '$sub' (try list|get|create|close|comment)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __github_pr_list ;;
            get|show)         __github_pr_get "$1" ;;
            create|new)       __github_pr_create ;;
            merge)            __github_pr_merge "$1" ;;
            close)            __github_pr_close "$1" ;;
            *)                __apimgr_die "github pr: unknown sub '$sub' (try list|get|create|merge|close)" ;;
          esac ;;
        release|releases|rel)
          case "$sub" in
            list|"")          __github_release_list ;;
            get|show)         __github_release_get "$1" ;;
            create|new)       __github_release_create ;;
            delete|rm)        __github_release_delete "$1" ;;
            *)                __apimgr_die "github release: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "github api: PATH required (e.g. apimgr github api /user)"
          __github_api GET "$sub" ;;
        *)                    __apimgr_die "github: unknown action '$action'. Try: verify|user|org|repo|issue|pr|release|api" ;;
      esac ;;
    gitea|forgejo|codeberg)
      case "$action" in
        verify)               __gitea_verify "$provider" ;;
        user)                 __gitea_user_get "$provider" ;;
        org)
          case "$sub" in
            all)              __gitea_org_all "$provider" ;;
            *)                __gitea_org_get "$provider" ;;
          esac ;;
        repo)
          case "$sub" in
            list)             __gitea_repo_list "$provider" ;;
            get|"")           __gitea_repo_get "$provider" ;;
            create)           __gitea_repo_create "$provider" ;;
            delete|rm)        __gitea_repo_delete "$provider" ;;
            all)              __gitea_repo_all "$provider" ;;
            *)                __apimgr_die "$provider repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __gitea_issue_list "$provider" ;;
            get|show)         __gitea_issue_get "$provider" "$1" ;;
            create|new)       __gitea_issue_create "$provider" ;;
            close)            __gitea_issue_close "$provider" "$1" ;;
            comment)          __gitea_issue_comment "$provider" "$1" ;;
            *)                __apimgr_die "$provider issue: unknown sub '$sub' (try list|get|create|close|comment)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __gitea_pr_list "$provider" ;;
            get|show)         __gitea_pr_get "$provider" "$1" ;;
            create|new)       __gitea_pr_create "$provider" ;;
            merge)            __gitea_pr_merge "$provider" "$1" ;;
            close)            __gitea_pr_close "$provider" "$1" ;;
            *)                __apimgr_die "$provider pr: unknown sub '$sub' (try list|get|create|merge|close)" ;;
          esac ;;
        release|releases|rel)
          case "$sub" in
            list|"")          __gitea_release_list "$provider" ;;
            get|show)         __gitea_release_get "$provider" "$1" ;;
            create|new)       __gitea_release_create "$provider" ;;
            delete|rm)        __gitea_release_delete "$provider" "$1" ;;
            *)                __apimgr_die "$provider release: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "$provider api: PATH required"
          __gitea_api "$provider" GET "$sub" ;;
        *)                    __apimgr_die "$provider: unknown action '$action'. Try: verify|user|org|repo|issue|pr|release|api" ;;
      esac ;;
    gitlab)
      case "$action" in
        verify)               __gitlab_verify ;;
        user)                 __gitlab_user_get ;;
        org)
          case "$sub" in
            all)              __gitlab_org_all ;;
            *)                __gitlab_org_get ;;
          esac ;;
        repo)
          case "$sub" in
            list)             __gitlab_repo_list ;;
            get|"")           __gitlab_repo_get ;;
            create)           __gitlab_repo_create ;;
            delete|rm)        __gitlab_repo_delete ;;
            all)              __gitlab_repo_all ;;
            *)                __apimgr_die "gitlab repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __gitlab_issue_list ;;
            get|show)         __gitlab_issue_get "$1" ;;
            create|new)       __gitlab_issue_create ;;
            close)            __gitlab_issue_close "$1" ;;
            comment)          __gitlab_issue_comment "$1" ;;
            *)                __apimgr_die "gitlab issue: unknown sub '$sub' (try list|get|create|close|comment)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __gitlab_pr_list ;;
            get|show)         __gitlab_pr_get "$1" ;;
            create|new)       __gitlab_pr_create ;;
            merge)            __gitlab_pr_merge "$1" ;;
            close)            __gitlab_pr_close "$1" ;;
            *)                __apimgr_die "gitlab pr: unknown sub '$sub' (try list|get|create|merge|close)" ;;
          esac ;;
        release|releases|rel)
          case "$sub" in
            list|"")          __gitlab_release_list ;;
            get|show)         __gitlab_release_get "$1" ;;
            create|new)       __gitlab_release_create ;;
            delete|rm)        __gitlab_release_delete "$1" ;;
            *)                __apimgr_die "gitlab release: unknown sub '$sub' (try list|get|create|delete)" ;;
          esac ;;
        api)
          [ -n "$sub" ] || __apimgr_die "gitlab api: PATH required (e.g. apimgr gitlab api /version)"
          __gitlab_api GET "$sub" ;;
        *)                    __apimgr_die "gitlab: unknown action '$action'. Try: verify|user|org|repo|issue|pr|release|api" ;;
      esac ;;
    bitbucket)
      case "$action" in
        verify)               __bitbucket_verify ;;
        user)                 __bitbucket_user_get ;;
        org|workspace)
          case "$sub" in
            all)              __bitbucket_org_all ;;
            *)                __bitbucket_org_get ;;
          esac ;;
        repo)
          case "$sub" in
            list)             __bitbucket_repo_list ;;
            get|"")           __bitbucket_repo_get ;;
            create)           __bitbucket_repo_create ;;
            delete|rm)        __bitbucket_repo_delete ;;
            all)              __bitbucket_repo_all ;;
            *)                __apimgr_die "bitbucket repo: unknown sub '$sub' (try list|get|create|delete|all)" ;;
          esac ;;
        issue)
          case "$sub" in
            list|"")          __bitbucket_issue_list ;;
            get|show)         __bitbucket_issue_get "$1" ;;
            create|new)       __bitbucket_issue_create ;;
            close)            __bitbucket_issue_close "$1" ;;
            comment)          __bitbucket_issue_comment "$1" ;;
            *)                __apimgr_die "bitbucket issue: unknown sub '$sub' (try list|get|create|close|comment)" ;;
          esac ;;
        pr|pull|pulls|mr)
          case "$sub" in
            list|"")          __bitbucket_pr_list ;;
            get|show)         __bitbucket_pr_get "$1" ;;
            create|new)       __bitbucket_pr_create ;;
            merge)            __bitbucket_pr_merge "$1" ;;
            close|decline)    __bitbucket_pr_close "$1" ;;
            *)                __apimgr_die "bitbucket pr: unknown sub '$sub' (try list|get|create|merge|close)" ;;
          esac ;;
        release|releases|rel)
          __bitbucket_release_unsupported ;;
        api)
          [ -n "$sub" ] || __apimgr_die "bitbucket api: PATH required (e.g. apimgr bitbucket api /user)"
          __bitbucket_api GET "$sub" ;;
        *)                    __apimgr_die "bitbucket: unknown action '$action'. Try: verify|user|org|repo|issue|pr|api" ;;
      esac ;;
    docker|harbor|quay)
      __apimgr_stub_provider "$provider" ;;
    "")
      __apimgr_die "no provider specified — try: apimgr <provider> <action>, or run apimgr --help" ;;
    *)
      __apimgr_die "unknown provider '$provider'. Supported: github gitlab gitea forgejo codeberg bitbucket docker harbor quay" ;;
  esac
}
