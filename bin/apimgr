cmd_exists --error --ask bash || exit 3 # exit 3 if not found
#am_i_online --error || exit 4           # exit 4 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Export variables

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute functions

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute commands

# - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
# Recognized provider tokens — used to decide whether $1 is a provider or a top-level action.
# Top-level form: `apimgr <action> [sub]` auto-detects provider from git remote / APIMGR_DEFAULT_PROVIDER.
# Provider form:  `apimgr <provider> <action> [sub]` is explicit.
case "$1" in
github|gitlab|gitea|forgejo|codeberg|gitee|pagure|sourcehut|sr.ht|srht|onedev|bitbucket|docker|ghcr|glcr|harbor|quay|cloudsmith|artifactory|jfrog|nexus|sonatype)
  provider="$1"; action="${2:-}"; sub="${3:-}"
  [ -n "$action" ] || __apimgr_die "apimgr $provider: action required (verify|user|org|repo|issue|api). See --help."
  shift 3 2>/dev/null || shift 2 2>/dev/null || shift 1 2>/dev/null || true
  __apimgr_dispatch_provider "$provider" "$action" "$sub" "$@"
  APIMGR_EXIT_STATUS=$?
  ;;
verify|user|org|repo|issue|pr|release|api)
  # Top-level shortcut: provider auto-detected from git remote, then APIMGR_DEFAULT_PROVIDER.
  __apimgr_resolve_provider ""
  action="$1"; sub="${2:-}"
  shift 2 2>/dev/null || shift 1 2>/dev/null || true
  __apimgr_dispatch_provider "$APIMGR_PROVIDER" "$action" "$sub" "$@"
  APIMGR_EXIT_STATUS=$?
  ;;
"")
  # No args — show a one-line summary so users know it's installed and discover --help.
  printf_green "apimgr $VERSION — multi-provider API client. Run 'apimgr --help' for the command tree."
  printf_cyan "Default provider: ${APIMGR_DEFAULT_PROVIDER:-github}"
  __apimgr_resolve_repo 2>/dev/null && printf_cyan "Detected repo:    $APIMGR_REPO (provider: $APIMGR_PROVIDER)" || true
  ;;
*)
  __apimgr_die "Unknown command '$1'. Run 'apimgr --help' for the full command tree."
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Set exit code
APIMGR_EXIT_STATUS="${APIMGR_EXIT_STATUS:-0}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${APIMGR_EXIT_STATUS:-0}
