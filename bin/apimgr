  __printf_line "--config                        - Generate user config file"
  __printf_line "--reset-config                  - Recreate user config file from scratch"
  __printf_line "--version                       - Show script version"
  __printf_line "--options                       - Shows all available options"
  __printf_line "--debug                         - Enable script debugging (set -x)"
  __printf_line "--raw                           - Strip color/formatting from output"
  __printf_line "--force                         - Skip safety prompts (e.g. repo delete)"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Environment Variables"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
