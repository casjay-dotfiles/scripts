# Generate config files
[ -f "$APIMGR_CONFIG_DIR/$APIMGR_CONFIG_FILE" ] || [ "$*" = "--config" ] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$APIMGR_CONFIG_DIR/$APIMGR_CONFIG_FILE" ] && . "$APIMGR_CONFIG_DIR/$APIMGR_CONFIG_FILE"
