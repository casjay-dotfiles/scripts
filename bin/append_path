#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108121036-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$APPEND_PATH_TEMP_FILE" ] && rm -Rf "$APPEND_PATH_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108121036-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : append_path --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 12, 2021 10:36 EDT
# @File          : append_path
# @Description   : Append a folder to the system/user PATH
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_available() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$APPEND_PATH_CONFIG_DIR/$APPEND_PATH_CONFIG_FILE"
  [ -d "$APPEND_PATH_CONFIG_DIR" ] || mkdir -p "$APPEND_PATH_CONFIG_DIR"
  [ -d "$APPEND_PATH_CONFIG_BACKUP_DIR" ] || mkdir -p "$APPEND_PATH_CONFIG_BACKUP_DIR"
  [ -f "$APPEND_PATH_CONFIG_DIR/$APPEND_PATH_CONFIG_FILE" ] &&
    cp -Rf "$APPEND_PATH_CONFIG_DIR/$APPEND_PATH_CONFIG_FILE" "$APPEND_PATH_CONFIG_BACKUP_DIR/$APPEND_PATH_CONFIG_FILE.$$"
  cat <<EOF >"$APPEND_PATH_CONFIG_DIR/$APPEND_PATH_CONFIG_FILE"
# Settings for append_path

# Notification settings
APPEND_PATH_GOOD_MESSAGE="${APPEND_PATH_GOOD_MESSAGE:-Everything Went OK}"
APPEND_PATH_ERROR_MESSAGE="${APPEND_PATH_ERROR_MESSAGE:-Well that didn\'t work}"
APPEND_PATH_NOTIFY_ENABLED="${APPEND_PATH_NOTIFY_ENABLED:-yes}"
APPEND_PATH_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$PROG}"
APPEND_PATH_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$APPEND_PATH_NOTIFY_CLIENT_ICON}"

EOF
  if [ -f "$APPEND_PATH_CONFIG_DIR/$APPEND_PATH_CONFIG_FILE" ]; then
    printf_green "Your config file for append_path has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
APPEND_PATH_CACHE_DIR="${APPEND_PATH_CACHE_DIR:-$HOME/.cache/append_path}"
APPEND_PATH_CONFIG_DIR="${APPEND_PATH_CONFIG_DIR:-$HOME/.config/myscripts/append_path}"
APPEND_PATH_OPTIONS_DIR="${APPEND_PATH_OPTIONS_DIR:-$HOME/.local/share/myscripts/append_path/options}"
APPEND_PATH_CONFIG_BACKUP_DIR="${APPEND_PATH_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/append_path/backups}"
APPEND_PATH_TEMP_DIR="${APPEND_PATH_TEMP_DIR/system_scripts/append_path:-$HOME/.local/tmp/system_scripts/append_path}"
APPEND_PATH_TEMP_FILE="${APPEND_PATH_TEMP_DIR:-$HOME/.local/tmp/append_path}"
APPEND_PATH_CONFIG_FILE="${APPEND_PATH_CONFIG_FILE:-settings.conf}"
APPEND_PATH_GOOD_MESSAGE="${APPEND_PATH_GOOD_MESSAGE:-Everything Went OK}"
APPEND_PATH_ERROR_MESSAGE="${APPEND_PATH_ERROR_MESSAGE:-Well that didn\'t work}"
APPEND_PATH_NOTIFY_ENABLED="${APPEND_PATH_NOTIFY_ENABLED:-yes}"
APPEND_PATH_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
APPEND_PATH_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$APPEND_PATH_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$APPEND_PATH_TEMP_DIR" ] || mkdir -p "$APPEND_PATH_TEMP_DIR" &>/dev/null
[ -d "$APPEND_PATH_CACHE_DIR" ] || mkdir -p "$APPEND_PATH_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$APPEND_PATH_CONFIG_DIR/$APPEND_PATH_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$APPEND_PATH_CONFIG_DIR/$APPEND_PATH_CONFIG_FILE" ] &&
  . "$APPEND_PATH_CONFIG_DIR/$APPEND_PATH_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_available "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_available "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_available "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    shift 1
    GEN_SCRIPT_REPLACE_CWD="$1"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$APPEND_PATH_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${APPEND_PATH_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${APPEND_PATH_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${APPEND_PATH_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${APPEND_PATH_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash || exit 1 # exit 1 if not found
#am_i_online --error || exit       # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case ":$PATH:" in
*:"$1":*) ;;
*) PATH="${PATH:+$PATH:}$1" ;;
esac

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
