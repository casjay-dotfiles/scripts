#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202107300030-git"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#set opts
trap 'exitCode=${exitCode:-$?};[ -f "$ASK_FOR_PASSWORD_TEMP_FILE" ] && rm -Rf "$ASK_FOR_PASSWORD_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202107300030-git
# @Author        : casjay
# @Contact       : casjay
# @License       : LICENSE.md
# @ReadME        : ask_for_password --help
# @Copyright     : Copyright: (c) 2021 casjay, casjay
# @Created       : Friday, Jul 30, 2021 00:46 EDT
# @File          : ask_for_password
# @Description   : Ask for password script
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-simple.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE"
  [ -d "$ASK_FOR_PASSWORD_CONFIG_DIR" ] || mkdir -p "$ASK_FOR_PASSWORD_CONFIG_DIR"
  [ -d "$ASK_FOR_PASSWORD_CONFIG_BACKUP_DIR" ] || mkdir -p "$ASK_FOR_PASSWORD_CONFIG_BACKUP_DIR"
  [ -f "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE" ] &&
    cp -Rf "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE" "$ASK_FOR_PASSWORD_CONFIG_BACKUP_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE.$$"
  cat <<EOF >"$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE"
# Settings for ask_for_password
ASK_FOR_PASSWORD_TEMP_FILE="${TMPDIR:-/tmp}/ask_for_password"
ASK_FOR_PASSWORD_NOTIFY_ENABLED="yes"
ASK_FOR_PASSWORD_NOTIFY_CLIENT_NAME="\${NOTIFY_CLIENT_NAME:-\$APPNAME}"
ASK_FOR_PASSWORD_NOTIFY_CLIENT_ICON="\${NOTIFY_CLIENT_ICON:-\$ASK_FOR_PASSWORD_NOTIFY_CLIENT_ICON}"

EOF
  if [ -f "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE" ]; then
    printf_green "Your config file for ask_for_password has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
__get_pass() {
  local ASK_FOR_PASSWORD_NOTIFY_CLIENT_NAME="Ask for password"
  local SUDO_STATUS="$(sudo -n true)"
  local SHELL=/bin/bash
  if echo "$SUDO_STATUS" | grep -qs 'sudo: a password is required' &>/dev/null; then
    if [ -n "$DISPLAY" ] && [ -z "$SSH_CONNECT" ]; then
      if cmd_exists zenity; then
        __notifications "Attempting to get password from zenity"
        export SUDO_ASKPASS="$(zenity --password --title="Please enter your password: " --timeout=20 2>/dev/null)"
        sudo -S <<<$SUDO_ASKPASS true || return 1
      elif cmd_exists rofi; then
        __notifications "Attempting to get password from rofi"
        export SUDO_ASKPASS="$(rofi -theme /home/jason/.config/rofi/themes/purple.rasi -dmenu -password -i -no-fixed-num-lines -p "Please enter your password: " 2>/dev/null)"
        sudo -S <<<$SUDO_ASKPASS true || return 1
      elif cmd_exists dmenupass; then
        __notifications "Attempting to get password from dmenupass"
        export SUDO_ASKPASS="$(dmenupass "Please enter your password: " 2>/dev/null)"
        sudo -S <<<$SUDO_ASKPASS true || return 1
      elif cmd_exists gksudo; then
        __notifications "Attempting to get password from gksudo"
        export SUDO_ASKPASS="$(gksudo --print-pass --message "Please enter your password: " 2>/dev/null)"
        sudo -S <<<$SUDO_ASKPASS true || return 1
      elif [ $(uname -s) = MacOS ]; then
        __notifications "Attempting to get password from osascript"
        export SUDO_ASKPASS="$(osascript -e 'Tell application "System Events" to display dialog "Please enter your password: " default answer ""' -e 'text returned of result' 2>/dev/null)"
        sudo -S <<<$SUDO_ASKPASS true || return 1
      else
      __notifications "Attempting to get password from terminal"
      export SUDO_ASKPASS=
      export SUDO_PROMPT="$(printf "\t\t\033[1;31m")[sudo]$(printf "\033[1;36m") password for $(printf "\033[1;32m")%p: $(printf "\033[0m")"
      fi
    else
      __notifications "Attempting to get password from terminal"
      export SUDO_ASKPASS=
      export SUDO_PROMPT="$(printf "\t\t\033[1;31m")[sudo]$(printf "\033[1;36m") password for $(printf "\033[1;32m")%p: $(printf "\033[0m")"
    fi
  fi
  if [ -n "$DEBUGGER" ]; then 
    __notifications "Retrieved $SUDO_ASKPASS for the password"
    printf_green "Retrieved $SUDO_ASKPASS for the password"
    printf_green "With password helper being $SUDO_PROMPT"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Defaults
exitCode=""
ASK_FOR_PASSWORD_CONFIG_FILE="settings.conf"
ASK_FOR_PASSWORD_CONFIG_DIR="$HOME/.config/myscripts/ask_for_password"
ASK_FOR_PASSWORD_CONFIG_BACKUP_DIR="$HOME/.local/share/myscripts/ask_for_password/backups"
ASK_FOR_PASSWORD_OPTIONS_DIR="$HOME/.local/share/myscripts/ask_for_password/options"
ASK_FOR_PASSWORD_TEMP_FILE="${TMPDIR:-/tmp}/ask_for_password"
ASK_FOR_PASSWORD_NOTIFY_ENABLED="yes"
ASK_FOR_PASSWORD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
ASK_FOR_PASSWORD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$ASK_FOR_PASSWORD_NOTIFY_CLIENT_ICON}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h,d"
LONGOPTS="options,config,version,help,debug"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate Files
[ -f "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE" ] || __gen_config &>/dev/null
[ -f "$ASK_FOR_PASSWORD_OPTIONS_DIR/options" ] || __list_options "$ASK_FOR_PASSWORD_OPTIONS_DIR" &>/dev/null
[ -f "$ASK_FOR_PASSWORD_OPTIONS_DIR/array" ] || __list_array "$ASK_FOR_PASSWORD_OPTIONS_DIR" "$ARRAY" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
if [ -f "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE" ]; then
  . "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    __list_array "$ASK_FOR_PASSWORD_OPTIONS_DIR" "$ARRAY"
    __list_options "$ASK_FOR_PASSWORD_OPTIONS_DIR"
    exit $?
    ;;
  -v | --version)
    shift 1
    __version
    exit $?
    ;;
  -h | --help)
    shift 1
    __help
    exit $?
    ;;
  -c | --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -d | --debug)
    DEBUGGER=true
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
export NOTIFY_CLIENT_NAME="${ASK_FOR_PASSWORD_NOTIFY_CLIENT_NAME}"
export NOTIFY_CLIENT_ICON="${ASK_FOR_PASSWORD_NOTIFY_CLIENT_ICON}"
if [ "$ASK_FOR_PASSWORD_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash || exit 1
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables
SUDO_COMMAND="${SUDO_COMMAND:-$*}"
[ "$#" = 0 ] && SUDO_COMMAND="true"
[ "$1" = "sudo" ] && shift 1
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__get_pass && __notifications "Password obtained for ${SUDO_USER:-$USER}" && sudo $SUDO_COMMAND || __notifications "Failed to get password for ${SUDO_USER:-$USER}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
