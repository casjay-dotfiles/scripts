# @Description   : Ask for password script
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190116-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$ASK_FOR_PASSWORD_TEMP_FILE" ] && [ -f "$ASK_FOR_PASSWORD_TEMP_FILE" ] && rm -Rf "$ASK_FOR_PASSWORD_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE"
  [ -d "$ASK_FOR_PASSWORD_CONFIG_DIR" ] || mkdir -p "$ASK_FOR_PASSWORD_CONFIG_DIR"
  [ -d "$ASK_FOR_PASSWORD_CONFIG_BACKUP_DIR" ] || mkdir -p "$ASK_FOR_PASSWORD_CONFIG_BACKUP_DIR"
  [ -f "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE" ] &&
    cp -Rf "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE" "$ASK_FOR_PASSWORD_CONFIG_BACKUP_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE.$$"
  cat <<EOF >"$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE"
# Settings for ask_for_password

# Notification settings
ASK_FOR_PASSWORD_GOOD_MESSAGE="${ASK_FOR_PASSWORD_GOOD_MESSAGE:-Everything Went OK}"
ASK_FOR_PASSWORD_ERROR_MESSAGE="${ASK_FOR_PASSWORD_ERROR_MESSAGE:-Well something seems to have gone wrong}"
ASK_FOR_PASSWORD_NOTIFY_ENABLED="${ASK_FOR_PASSWORD_NOTIFY_ENABLED:-yes}"
ASK_FOR_PASSWORD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
ASK_FOR_PASSWORD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$ASK_FOR_PASSWORD_NOTIFY_CLIENT_ICON}"

# Colorization settings
ASK_FOR_PASSWORD_OUTPUT_COLOR="${ASK_FOR_PASSWORD_OUTPUT_COLOR:-5}"
ASK_FOR_PASSWORD_OUTPUT_COLOR_GOOD="${ASK_FOR_PASSWORD_OUTPUT_COLOR_GOOD:-2}"
ASK_FOR_PASSWORD_OUTPUT_COLOR_ERROR="${ASK_FOR_PASSWORD_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for ask_for_password has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__set_pass() {
  __ask_pass
  if [ -z "$PASS_WORD" ]; then
    PASS_WORD_STATUS="failed"
    return 1
  else
    if sudo -Sp '' true <<<$PASS_WORD >&1 2>&1 | grep -vq 'try again' &>/dev/null; then
      echo -e "$PASS_WORD" | sudo -S true &>/dev/null && export PASS_WORD_STATUS="completed" && return 0
      export sudoError=1
      export PASS_WORD_STATUS="failed"
      return 1
    else
      export PASS_WORD_STATUS="completed"
      return 0
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_pass() {
  local maxRetries=3
  local exitCode=1
  local sudoError=0
  local SHELL=/bin/bash
  local PASS_APP=""
  local PASS_WORD="Not Set"
  # Check if password is needed
  if ! builtin command sudo -n true &>/dev/null; then
    # Check for displays
    if [ -n "$DISPLAY" ] && [ -z "$SSH_CONNECT" ]; then
      # command check and set ask_pass
      if cmd_exists yad; then
        PASS_APP="yad"
        __ask_pass() { export PASS_WORD="$(yad --class="GSu" --title="Password" --text="Enter password for user <b>$USER</b>:" --image="dialog-password" --entry --hide-text)"; }
      elif cmd_exists zenity; then
        PASS_APP="zenity"
        __ask_pass() { export PASS_WORD="$(zenity --class="GSu" --title="Password" --text="Enter password for user $USER:" --entry --hide-text)"; }
      elif cmd_exists rofi; then
        PASS_APP="rofi"
        __ask_pass() { export PASS_WORD="$(rofi -theme ${ROFI_THEME:-purple} -dmenu -password -i -no-fixed-num-lines -p "Please enter your password: " 2>/dev/null)"; }
      elif cmd_exists dmenu; then
        PASS_APP="dmenu"
        __ask_pass() { export PASS_WORD="$(dmenu -fn Monospace-18 -P -p "Please enter your password: " <&- && echo 2>/dev/null)"; }
      elif cmd_exists kdialog; then
        PASS_APP="kdialog"
        __ask_pass() { export PASS_WORD="$(kdialog --password "Please enter your password: " 2>/dev/null)"; }
      elif cmd_exists gksudo; then
        PASS_APP="gksudo"
        __ask_pass() { export PASS_WORD="$(gksudo --print-pass --message "Please enter your password: " 2>/dev/null)"; }
      elif [ $(uname -s) = MacOS ]; then
        PASS_APP="osascript"
        __ask_pass() { export PASS_WORD="$(osascript -e 'Tell application "System Events" to display dialog "Please enter your password: " default answer ""' -e 'text returned of result' 2>/dev/null)"; }
      else
        PASS_APP="terminal"
        __ask_pass() { export SUDO_PROMPT="$(printf "\t\t\033[1;31m")[sudo]$(printf "\033[1;36m") password for $(printf "\033[1;32m")%p: $(printf "\033[0m")"; }
      fi
      # If no display
    else
      PASS_APP="terminal"
      __ask_pass() { SUDO_PROMPT="$(printf "\t\t\033[1;31m")[sudo]$(printf "\033[1;36m") password for $(printf "\033[1;32m")%p: $(printf "\033[0m")"; }
    fi
    # trye to get the password
    # Sanity check
    if [ -n "$PASS_APP" ]; then
      # Debugger
      if [ -n "$DEBUGGER" ]; then
        __notifications "Retrieved password for $SUDO_USER"
        printf_green "With password helper being $PASS_APP"
      fi
      # If password fails retry 2 more times
      retries=0
      __notifications "Attempting to get password from $PASS_APP"
      while [[ $retries -lt $maxRetries ]]; do
        if __set_pass; then
          sudoError=0
          export PASS_WORD_STATUS="completed"
          break
        else
          __notifications "Sorry sudo said try again"
          sudoError=1
          export PASS_WORD_STATUS="failed"
        fi
        ((retries++))
      done
      exitCode=$sudoError
      # Error was encountered
    else
      if [ "$PASS_WORD_STATUS" = "failed" ]; then
        message="No password seems to be present. Did you cancel?"
        printf_red "No password seems to be present. Did you cancel?"
        exitCode=1
      fi
    fi
    # sudo says no password needed
  else
    mesage="Your password seems to be cached"
    exitCode=0
    export PASS_WORD_STATUS="completed"
  fi
  # Clean up
  sleep .5
  unset PASS_APP PASS_WORD
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
ASK_FOR_PASSWORD_LOG_DIR="${ASK_FOR_PASSWORD_LOG_DIR:-$HOME/.local/log/ask_for_password}"
ASK_FOR_PASSWORD_CACHE_DIR="${ASK_FOR_PASSWORD_CACHE_DIR:-$HOME/.cache/ask_for_password}"
ASK_FOR_PASSWORD_CONFIG_DIR="${ASK_FOR_PASSWORD_CONFIG_DIR:-$HOME/.config/myscripts/ask_for_password}"
ASK_FOR_PASSWORD_CONFIG_BACKUP_DIR="${ASK_FOR_PASSWORD_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/ask_for_password/backups}"
ASK_FOR_PASSWORD_TEMP_DIR="${ASK_FOR_PASSWORD_TEMP_DIR:-$HOME/.local/tmp/system_scripts/ask_for_password}"
ASK_FOR_PASSWORD_OPTIONS_DIR="${ASK_FOR_PASSWORD_OPTIONS_DIR:-$HOME/.local/share/myscripts/ask_for_password/options}"
ASK_FOR_PASSWORD_TEMP_FILE="${ASK_FOR_PASSWORD_TEMP_FILE:-$(mktemp $ASK_FOR_PASSWORD_TEMP_DIR/XXXXXX 2>/dev/null)}"
ASK_FOR_PASSWORD_CONFIG_FILE="${ASK_FOR_PASSWORD_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
ASK_FOR_PASSWORD_OUTPUT_COLOR="${ASK_FOR_PASSWORD_OUTPUT_COLOR:-4}"
ASK_FOR_PASSWORD_OUTPUT_COLOR_2="${ASK_FOR_PASSWORD_OUTPUT_COLOR:-6}"
ASK_FOR_PASSWORD_OUTPUT_COLOR_GOOD="${ASK_FOR_PASSWORD_OUTPUT_COLOR_GOOD:-2}"
ASK_FOR_PASSWORD_OUTPUT_COLOR_ERROR="${ASK_FOR_PASSWORD_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
ASK_FOR_PASSWORD_GOOD_MESSAGE="${ASK_FOR_PASSWORD_GOOD_MESSAGE:-Everything Went OK}"
ASK_FOR_PASSWORD_ERROR_MESSAGE="${ASK_FOR_PASSWORD_ERROR_MESSAGE:-Well something seems to have gone wrong}"
ASK_FOR_PASSWORD_NOTIFY_ENABLED="${ASK_FOR_PASSWORD_NOTIFY_ENABLED:-yes}"
ASK_FOR_PASSWORD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
ASK_FOR_PASSWORD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$ASK_FOR_PASSWORD_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE" ] && . "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$ASK_FOR_PASSWORD_LOG_DIR" ] || mkdir -p "$ASK_FOR_PASSWORD_LOG_DIR" &>/dev/null
[ -d "$ASK_FOR_PASSWORD_TEMP_DIR" ] || mkdir -p "$ASK_FOR_PASSWORD_TEMP_DIR" &>/dev/null
[ -d "$ASK_FOR_PASSWORD_CACHE_DIR" ] || mkdir -p "$ASK_FOR_PASSWORD_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$ASK_FOR_PASSWORD_CONFIG_DIR/$ASK_FOR_PASSWORD_CONFIG_FILE" ] || [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    ASK_FOR_PASSWORD_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$ASK_FOR_PASSWORD_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${ASK_FOR_PASSWORD_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${ASK_FOR_PASSWORD_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${ASK_FOR_PASSWORD_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${ASK_FOR_PASSWORD_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
SUDO_COMMAND="${SUDO_COMMAND:-$SETARGS}"
[ "$#" = 0 ] && SUDO_COMMAND="true"
[ "$1" = "sudo" ] && shift 1

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if __get_pass && [ "$PASS_WORD_STATUS" = "completed" ]; then
  __notifications "${message:-Password obtained for ${SUDO_USER:-$USER}}"
  sudo $SUDO_COMMAND && exitCode=0 || exitCode=1
else
  exitCode=1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
