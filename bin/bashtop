#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108121815-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$BASHTOP_TEMP_FILE" ] && rm -Rf "$BASHTOP_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108121815-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : bashtop --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 12, 2021 18:15 EDT
# @File          : bashtop
# @Description   : System monitor written in bash
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_available() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE"
  [ -d "$BASHTOP_CONFIG_DIR" ] || mkdir -p "$BASHTOP_CONFIG_DIR"
  [ -d "$BASHTOP_CONFIG_BACKUP_DIR" ] || mkdir -p "$BASHTOP_CONFIG_BACKUP_DIR"
  [ -f "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE" ] &&
    cp -Rf "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE" "$BASHTOP_CONFIG_BACKUP_DIR/$BASHTOP_CONFIG_FILE.$$"
  cat <<EOF >"$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE"
# Settings for bashtop
BASHTOP_BIN_FILE="${BASHTOP_BIN_FILE:-$(dirname "${BASH_SOURCE[0]}/")/../sources}"

# Notification settings
BASHTOP_GOOD_MESSAGE="${BASHTOP_GOOD_MESSAGE:-Everything Went OK}"
BASHTOP_ERROR_MESSAGE="${BASHTOP_ERROR_MESSAGE:-Well that didn\'t work}"
BASHTOP_NOTIFY_ENABLED="${BASHTOP_NOTIFY_ENABLED:-yes}"
BASHTOP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$PROG}"
BASHTOP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$BASHTOP_NOTIFY_CLIENT_ICON}"

EOF
  if [ -f "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE" ]; then
    printf_green "Your config file for bashtop has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
BASHTOP_CACHE_DIR="${BASHTOP_CACHE_DIR:-/$HOME/.cache/bashtop}"
BASHTOP_CONFIG_DIR="${BASHTOP_CONFIG_DIR:-$HOME/.config/misc/bashtop}"
BASHTOP_OPTIONS_DIR="${BASHTOP_OPTIONS_DIR:-$HOME/.local/share/misc/bashtop/options}"
BASHTOP_CONFIG_BACKUP_DIR="${BASHTOP_CONFIG_BACKUP_DIR:-$HOME/.local/share/misc/bashtop/backups}"
BASHTOP_TEMP_DIR="${BASHTOP_TEMP_DIR/system_scripts/bashtop:-$HOME/.local/tmp/system_scripts/bashtop}"
BASHTOP_TEMP_FILE="${BASHTOP_TEMP_DIR:-$HOME/.local/tmp/bashtop}"
BASHTOP_CONFIG_FILE="${BASHTOP_CONFIG_FILE:-settings.conf}"
BASHTOP_GOOD_MESSAGE="${BASHTOP_GOOD_MESSAGE:-Everything Went OK}"
BASHTOP_ERROR_MESSAGE="${BASHTOP_ERROR_MESSAGE:-Well that didn\'t work}"
BASHTOP_NOTIFY_ENABLED="${BASHTOP_NOTIFY_ENABLED:-yes}"
BASHTOP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
BASHTOP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$BASHTOP_NOTIFY_CLIENT_ICON}"
BASHTOP_BIN_FILE="${BASHTOP_BIN_FILE:-$(dirname "${BASH_SOURCE[0]}/")/../sources}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$BASHTOP_TEMP_DIR" ] || mkdir -p "$BASHTOP_TEMP_DIR" &>/dev/null
[ -d "$BASHTOP_CACHE_DIR" ] || mkdir -p "$BASHTOP_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE" ] &&
  . "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h,z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_available "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_available "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_available "5" "Base Options" "-$ARRAY" ',' ''
    exit $?
    ;;
  -v | --version)
    shift 1
    __version
    exit $?
    ;;
  -h | --help)
    shift 1
    __help
    exit $?
    ;;
  -c | --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    shift 1
    GEN_SCRIPT_REPLACE_CWD="$1"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$BASHTOP_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${BASHTOP_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${BASHTOP_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${BASHTOP_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${BASHTOP_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash || exit 1 # exit 1 if not found
#am_i_online --error || exit       # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
bashtop_source="$BASHTOP_BIN_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main apps
cd "$bashtop_source" || exit 1
if [ -f "$HOME/.local/bin/bashtop" ]; then
  bash "$HOME/.local/bin/bashtop"
elif [ -f ./bashtop ]; then
  bash ./bashtop
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
