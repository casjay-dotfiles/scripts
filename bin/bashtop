#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : bashtop --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : bashtop
# @Description   : System monitor written in bash
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ -n "$DISPLAY" ]] && [ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# = 0 ]; } && TERMINAL_APP="TRUE" eval ${TERMINALE:-myterminal} -e "${APPNAME:-bash}" ${*:-} && { exit || exit 1; }
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$BASHTOP_TEMP_FILE" ] && [ -f "$BASHTOP_TEMP_FILE" ] && rm -Rf "$BASHTOP_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE"
  [ -d "$BASHTOP_CONFIG_DIR" ] || mkdir -p "$BASHTOP_CONFIG_DIR"
  [ -d "$BASHTOP_CONFIG_BACKUP_DIR" ] || mkdir -p "$BASHTOP_CONFIG_BACKUP_DIR"
  [ -f "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE" ] &&
    cp -Rf "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE" "$BASHTOP_CONFIG_BACKUP_DIR/$BASHTOP_CONFIG_FILE.$$"
  cat <<EOF >"$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE"
# Settings for bashtop

# Notification settings
BASHTOP_GOOD_MESSAGE="${BASHTOP_GOOD_MESSAGE:-Everything Went OK}"
BASHTOP_ERROR_MESSAGE="${BASHTOP_ERROR_MESSAGE:-Well something seems to have gone wrong}"
BASHTOP_NOTIFY_ENABLED="${BASHTOP_NOTIFY_ENABLED:-yes}"
BASHTOP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
BASHTOP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$BASHTOP_NOTIFY_CLIENT_ICON}"

# Colorization settings
BASHTOP_OUTPUT_COLOR="${BASHTOP_OUTPUT_COLOR:-5}"
BASHTOP_OUTPUT_COLOR_GOOD="${BASHTOP_OUTPUT_COLOR_GOOD:-2}"
BASHTOP_OUTPUT_COLOR_ERROR="${BASHTOP_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__bashtop() {
  if [ -f "$HOME/.local/bin/bashtop" ]; then
    bash "$HOME/.local/bin/bashtop"
  elif [ -f "$BASHTOP_BIN_DIR/bashtop" ]; then
    bash "$BASHTOP_BIN_DIR/bashtop"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
BASHTOP_LOG_DIR="${BASHTOP_LOG_DIR:-$HOME/.local/log/bashtop}"
BASHTOP_CACHE_DIR="${BASHTOP_CACHE_DIR:-$HOME/.cache/bashtop}"
BASHTOP_CONFIG_DIR="${BASHTOP_CONFIG_DIR:-$HOME/.config/myscripts/bashtop}"
BASHTOP_CONFIG_BACKUP_DIR="${BASHTOP_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/bashtop/backups}"
BASHTOP_TEMP_DIR="${BASHTOP_TEMP_DIR:-$HOME/.local/tmp/system_scripts/bashtop}"
BASHTOP_OPTIONS_DIR="${BASHTOP_OPTIONS_DIR:-$HOME/.local/share/myscripts/bashtop/options}"
BASHTOP_TEMP_FILE="${BASHTOP_TEMP_FILE:-$(mktemp $BASHTOP_TEMP_DIR/XXXXXX 2>/dev/null)}"
BASHTOP_CONFIG_FILE="${BASHTOP_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
BASHTOP_OUTPUT_COLOR="${BASHTOP_OUTPUT_COLOR:-4}"
BASHTOP_OUTPUT_COLOR_2="${BASHTOP_OUTPUT_COLOR:-6}"
BASHTOP_OUTPUT_COLOR_GOOD="${BASHTOP_OUTPUT_COLOR_GOOD:-2}"
BASHTOP_OUTPUT_COLOR_ERROR="${BASHTOP_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
BASHTOP_GOOD_MESSAGE="${BASHTOP_GOOD_MESSAGE:-Everything Went OK}"
BASHTOP_ERROR_MESSAGE="${BASHTOP_ERROR_MESSAGE:-Well something seems to have gone wrong}"
BASHTOP_NOTIFY_ENABLED="${BASHTOP_NOTIFY_ENABLED:-yes}"
BASHTOP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
BASHTOP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$BASHTOP_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE" ] && . "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$BASHTOP_LOG_DIR" ] || mkdir -p "$BASHTOP_LOG_DIR" &>/dev/null
[ -d "$BASHTOP_TEMP_DIR" ] || mkdir -p "$BASHTOP_TEMP_DIR" &>/dev/null
[ -d "$BASHTOP_CACHE_DIR" ] || mkdir -p "$BASHTOP_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$BASHTOP_CONFIG_DIR/$BASHTOP_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    BASHTOP_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$BASHTOP_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${BASHTOP_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${BASHTOP_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${BASHTOP_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${BASHTOP_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__bashtop "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
