# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
SHORTOPTS=""
SHORTOPTS+=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
LONGOPTS="completions:,config,debug,dir:,help,options,raw,version,silent"
LONGOPTS+=",force,cleanup,registry:,repo:,no-registry,no-repo,platform:"
LONGOPTS+=",tag:,add-tag:,all,build,url:,no-script,init"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
ARRAY="run[Dockerfile] init status version api[tags,list,search,sources,clone] "
ARRAY+=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
LIST=""
LIST+=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --raw)
    shift 1
    export SHOW_RAW="true"
    printf_column() { tee | grep '^'; }
    printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[ 0-9;]*[a-zA-Z],,g'; }
    ;;
  --debug)
    shift 1
    set -xo pipefail
    export SCRIPT_OPTS="--debug"
    export _DEBUG="on"
    __devnull() { tee || return 1; }
    __devnull2() { eval "$@" |& tee || return 1; }
    ;;
  --completions)
    if [ "$2" = "short" ]; then
      printf '%s\n' "-$SHORTOPTS" | sed 's|"||g;s|:||g;s|,|,-|g' | tr ',' '\n'
    elif [ "$2" = "long" ]; then
      printf '%s\n' "--$LONGOPTS" | sed 's|"||g;s|:||g;s|,|,--|g' | tr ',' '\n'
    elif [ "$2" = "array" ]; then
      printf '%s\n' "$ARRAY" | sed 's|"||g;s|:||g' | tr ',' '\n'
    elif [ "$2" = "list" ]; then
      printf '%s\n' "$LIST" | sed 's|"||g;s|:||g' | tr ',' '\n'
    else
      exit 1
    fi
    shift 2
    exit $?
    ;;
  --options)
    shift 1
    printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "Short Options" "-${SHORTOPTS}" ',' '-' 4
    [ -z "$LONGOPTS" ] || __list_options "Long Options" "--${LONGOPTS}" ',' '--' 4
    [ -z "$ARRAY" ] || __list_options "Base Options" "${ARRAY}" ',' '' 4
    [ -z "$LIST" ] || __list_options "Base Options" "${LIST}" ',' '' 4
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --silent)
    shift 1
    BUILDX_SILENT="true"
    ;;
  --dir)
    CWD_IS_SET="TRUE"
    BUILDX_CWD="$2"
    [ -d "$BUILDX_CWD" ] || mkdir -p "$BUILDX_CWD" |& __devnull
    shift 2
    ;;
  --force)
    shift 1
    BUILDX_FORCE="true"
    ;;
  --all)
    shift 1
    BUILDX_ALL="true"
    ;;
  --cleanup)
    shift 1
    BUILDX_CLEANUP="true"
    ;;
  --registry)
    BUILDX_ENABLE_REGISTRY="true"
    BUILDX_ADD_REGISTRY+="$2"
    shift 2
    ;;
  --repo)
    BUILDX_ADD_REPO="$2"
    shift 2
    ;;
  --no-registry)
    shift 1
    BUILDX_ENABLE_REGISTRY="false"
    BUILDX_ADD_REGISTRY=""
    ;;
  --no-repo)
    shift 1
    BUILDX_ADD_REPO=""
    ;;
  --platform)
    [ "$2" = "x64" ] && BUILDX_SET_PLATFORM="linux/amd64" && shift 2
    [ "$2" = "arm64" ] && BUILDX_SET_PLATFORM="linux/arm64" && shift 2
    BUILDX_DOCKER_PLATFORMS="${BUILDX_SET_PLATFORM:-$2}"
    printf_yellow "Setting platform to $BUILDX_DOCKER_PLATFORMS"
    BUILDX_SET_PLATFORM=""
    shift 2
    ;;
  --tag)
    BUILDX_AUTO_VERSION="false"
    BUILDX_SET_VERSION="${2//,/ }"
    shift 2
    ;;
  --add-tag)
    BUILDX_ADD_TAG="true"
    BUILDX_VERSION_TAG="${2//,/ }"
    shift 2
    ;;
  --url)
    urls="${2//,/ }"
    for url in $urls; do
      if [ -n "$url" ]; then
        REGISTRY_TAG+="-t $url "
      fi
    done
    unset url urls
    shift 2
    ;;
  --no-script)
    shift 1
    BUILDX_RUN_SCRIPT="false"
    ;;
  --build)
    shift 1
    BUILDX_ENABLED="no"
    ;;
  --init)
    shift 1
    BUILDX_FORCE_REINSTALL="true"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
