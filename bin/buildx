    printf_help "usage: $APPNAME api [list,search,sources,clone] [query]"
    exit 1
    ;;
  esac
  ;;

automated | cron)
  shift 1
  exitCode=0
  if [ $# -eq 0 ] && [ -d "$BUILDX_PROJECT_DIR" ]; then
    for projectDir in $BUILDX_PROJECT_DIR/*; do
      if [ -d "$projectDir" ]; then
        __automate "$projectDir"
        exitCode=$((1 + exitCode))
      else
        printf '%s\n' "$projectDir is not a directory"
        exitCode=$((1 + exitCode))
      fi
    done
  elif [ $# -ne 0 ]; then
    for projectDir in "$@"; do
      if [ -d "$projectDir" ]; then
        __automate "$projectDir"
        exitCode=$((1 + exitCode))
      else
        printf '%s\n' "$projectDir is not a directory"
        exitCode=$((1 + exitCode))
      fi
    done
  fi
  exit $exitCode
  ;;

all)
  shift 1
  [ -d "$BUILDX_CWD" ] || printf_exit "Usage: $APPNAME all [dir]"
  printf_cyan "Building all Dockerfiles in $BUILDX_CWD"
  for file in "$BUILDX_CWD/Dockerfile"*; do
    file="$(realpath "$file" 2>/dev/null || echo '')"
    [ -n "$file" ] && [ -f "$file" ] && __buildx_run "$file" || {
      printf_yellow "Can not find Dockerfile in $BUILDX_CWD" && exit 1
    }
  done
  exit $?
  ;;

run)
  shift 1
  __buildx_run "$@"
  ;;

*)
  __buildx_run "$@"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set exit code
exitCode="${exitCode:-$?}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
