}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -s "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$BUILDX_REQUIRE_SUDO" = "yes" ] && [ -z "$BUILDX_REQUIRE_SUDO_RUN" ]; then
    export BUILDX_REQUIRE_SUDO="no"
    export BUILDX_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "$(basename "$SUDO" 2>/dev/null)" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-$?}
  [ -f "$BUILDX_TEMP_FILE" ] && rm -Rf "$BUILDX_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__trap_exit_local() {
  [ "$_DEBUG" = "on" ] && [ -n "$exitCode" ] && echo $exitCode
  __buildx_cleanup
  __remove_pid
  echo ''
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__remove_pid() {
  if [ "$BUILDX_IS_RUNNING" = "true" ] && [ -f "$BUILDX_PID_FILE" ]; then
    rm -Rf "$BUILDX_PID_FILE"
  fi
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_buildx_installed() {
  local buildx_installed=""
  buildx_installed="$(docker buildx ls 2>&1 | grep -q 'STATUS' && echo 'yes' || echo 'no')"
  if [ "$buildx_installed" = "no" ]; then
    return 1
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_docker_installed() {
  if ! type -p docker &>/dev/null; then
    printf_red "Docker is not installed either run dockermgr init"
    printf_exit "or refer to docker documentation for installation"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_initialized() {
  [ "$BUILDX_FORCE" != "true" ] && [ -n "$builder_id" ] &&
    [ -n "$qemu_imagename" ] && [ -n "$binfmt_imagename" ] &&
    [ -f "$HOME/.docker/buildx/instances/$name" ] && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__jq() { jq "${@:--r}" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl() { curl -q -LSsf --max-time 2 --retry 0 "$*" 2>/dev/null || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__usage() {
  printf_exit 1 2 "Usage: $APPNAME [Dir] [Dockerfile] [name] [tag]" 1>&2
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker() {
  eval "$BUILDX_DOCKER_CMD" "$@" 2>/dev/null && true
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker_push() {
  __docker push "$tagged_name" |& tee -a "$logfile" &>/dev/null ||
    __docker push "$tagged_name" |& tee -a "$logfile" &>/dev/null ||
    __docker push "$tagged_name" |& tee -a "$logfile" &>/dev/null && true
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__qemu_version() {
  if grep -sq 'enabled' "/proc/sys/fs/binfmt_misc/status"; then
    if __cmd_exists qemu-aarch64-static; then
      version="$(qemu-aarch64-static --version | head -n1 | cut -d' ' -f3 | tr -cd '0-9.')"
      printf_blue "QEMU aarch64 version: $version"
    fi
    if __cmd_exists qemu-x86_64-static; then
      version="$(qemu-x86_64-static --version | head -n1 | cut -d' ' -f3 | tr -cd '0-9.')"
      printf_blue "QEMU x86_64 version: $version"
    fi
    if __cmd_exists qemu-arm-static; then
      version="$(qemu-arm-static --version | head -n1 | cut -d' ' -f3 | tr -cd '0-9.')"
      printf_blue "QEMU arm version: $version"
    fi
  else
    printf_red "Missing qemu-user-static package."
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker_version() {
  version="$(__docker --version | cut -d' ' -f3 | tr -cd '0-9.' | sed -e 's/ 0*/ /g')"
  [ -n "$version" ] && printf_blue "Docker version: $version"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__binfmt_version() {
  if __cmd_exists update-binfmts; then
    version="$(update-binfmts --version | awk '{print $NF}')"
    [ -n "$version" ] && printf_blue "update-binfmts version: $version"
  else
    printf_return "Please install update-binfmts"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_vars() {
  name="${1:-mybuilder}"
  qemu_imagename="buildx-qemu"
  binfmt_imagename="buildx-binfmt"
  qemu_id="$(__docker ps -a | awk '{print $NF}' | grep "$qemu_imagename" || echo '')"
  binfmt_id="$(__docker ps -a | awk '{print $NF}' | grep "$binfmt_imagename" || echo '')"
  builder_id="$(__docker ps -a | awk '{print $NF}' | grep "$name" | grep "buildkit" || echo '')"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_version() {
  features="$(__docker version | awk '/^ *Experimental:/ {print $2 ; exit}')"
  [ "$features" == "true" ] && printf_blue "Experimental Features: yes" ||
    printf_red "Experimental Features: no"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_cleanup() {
  if [ "$BUILDX_CLEANUP" = "true" ] && [ "$BUILDX_IS_RUNNING" = "true" ]; then
    printf_yellow "Cleaning up containers"
    __docker rm -f $builder_id $qemu_imagename $binfmt_imagename &>/dev/null
  fi
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_init() {
  __buildx_vars "$1"
  if [ "$BUILDX_FORCE" = "true" ]; then
    __docker rm -f $builder_id $qemu_imagename $binfmt_imagename &>/dev/null
  fi
  # Exit if already setup
  if __is_initialized; then
    printf_cyan "buildx seems to be already setup"
    return 0
  else
    printf_yellow "Initializing docker build"
    if [ -n "$binfmt" ] || [ -n "$qemu" ]; then
      printf_yellow "Removing old containers: $qemu_imagename,$binfmt_imagename"
      __docker rm -f "$qemu_imagename" &>/dev/null
      __docker rm -f "$binfmt_imagename" &>/dev/null
    fi
    if [ "$(uname -m)" = "x86_64" ]; then
      # Setup qemu
      printf_yellow "Setting up the qemu image - multiarch/qemu-user-static as $qemu_imagename"
      __docker run -d --name "$qemu_imagename" --privileged multiarch/qemu-user-static --reset -p yes &>/dev/null
      # Setup binfmt
      printf_yellow "Setting up the binfmt image - tonistiigi/binfmt as $binfmt_imagename"
      __docker run -d --name "$binfmt_imagename" --privileged tonistiigi/binfmt --install all &>/dev/null
      # setup buildx
      printf_blue "Setting up docker build to use buildx"
      __docker buildx create --name "$name" --use &>/dev/null
      __docker buildx use "$name" &>/dev/null
      __docker buildx inspect --bootstrap &>/dev/null
    fi
    printf_blue "Making sure docker service is running"
    if sudo systemctl status docker.service docker.socket | grep -q 'daemon-reload'; then
      sudo systemctl daemon-reload
    fi
    if ! systemctl status systemd-binfmt.service | grep -iq 'running'; then
      sudo systemctl enable -now systemd-binfmt.service &>/dev/null
      sudo systemctl restart systemd-binfmt.service &>/dev/null
    fi
    if ! systemctl status docker*.service | grep -iq 'running'; then
      sudo systemctl enable --now docker &>/dev/null
      sudo systemctl restart docker &>/dev/null
    fi
    printf_yellow "Making sure user is signed into to docker hub"
    __is_logged_in || __docker login || exit 2
    printf_purple "Finishing up"
    [ -d "$HOME/.docker/buildx" ] || mkdir -p "$HOME/.docker/buildx"
    sudo bash -c '[ -d "/root/.docker/buildx" ] && [ "/root/.docker/buildx" != "'$HOME/.docker/buildx'" ] && cp -Rf /root/.docker/buildx/. "'$HOME/.docker/buildx/'"'
    sudo chown -Rf "$SUDO_USER":"$SUDO_USER" "$HOME"
    printf_green "Docker build has been setup"
    printf_cyan "Usage: buildx [init, status, version]"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tag_versions() {
  local add_new_host="" add_image_name="" add_full_host=""
  host="${host:-$BUILDX_DEFAULT_HUB}"
  namespace="${namespace:-$BUILDX_DEFAULT_REPO}"
  add_image_name="${image_name//:*/}"
  add_tags="${BUILDX_VERSION_TAG//,/ }"
  add_full_host="${1:-$host/$namespace/$add_image_name}"
  if [ "$BUILDX_ADD_TAG" = "true" ]; then
    for tag in $add_tags; do
      add_new_host+="-t $add_full_host:$tag "
    done
    export ADD_HOST="$add_new_host"
  else
    add_new_host="$add_full_host:$tag_version"
    export image_name="$add_new_host"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_status() {
  local a="" e="" c="" r="" s=""
  e=0
  a="$*"
  c="$(__docker buildx inspect ${1:-$BUILDX_BUILDER_NAME} || false)"
  r="$(__docker buildx ls | grep ${1:-$BUILDX_BUILDER_NAME} | grep -qi 'running' && echo 'running' || false)"
  s="$(echo "$c" | grep -i 'Status:' | grep -qi 'running' && echo 'Running' || false)"
  if [ ${#a} = 0 ]; then
    [ -n "$s" ] && e=0 || e=1
  else
    if [ -n "$s" ]; then
      printf '%s\n' "$c"
      e=0
    else
      printf '%s\n' "buildx is not running"
      e=1
    fi
  fi
  return ${e:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_docker_build() {
  set -e -o pipefail
  cd "$BUILDX_CWD" || return 1
  buildx_status="0" ADD_HOST=""
  namespace="$BUILDX_ADD_REPO"
  platforms="${BUILDX_DOCKER_PLATFORMS// /,}"
  registry="${BUILDX_ADD_REGISTRY//,/ }"
  image_name="${tagged_name//$BUILDX_DEFAULT_REPO\//}"
  if [ -n "$registry" ] && [ "$BUILDX_ENABLE_REGISTRY" = "true" ]; then
    for host in $registry; do
      if [ -n "$BUILDX_ADD_REPO" ]; then
        [ "$BUILDX_ADD_REPO" = "" ] && namespace="library"
        [ "$BUILDX_ADD_REPO" = "_" ] && namespace="library"
        if echo "$image_name" | grep -q ":"; then
          full_host="$host/$namespace/$image_name"
          ADD_HOST+="-t $full_host "
        else
          __tag_versions "$host/$namespace/$image_name"
        fi
      else
        ADD_HOST+="-t $host/$namespace/$image_name "
      fi
    done
  else
    __tag_versions "$tagged_name"
  fi
  [ -n "$image_name" ] && tagged_name="$image_name" || tagged_name="$push_tag"
  if [ -f "$BUILDX_CWD/build.sh" ]; then
    printf '%s\n' "# Building $dirname using script on : $(date +'%Y-%m-%d at %H:%M')" >>"$logfile"
    $BUILDX_CWD/build.sh |& tee -a "$logfile" &>/dev/null && buildx_status=0 || buildx_status=1
  elif [ "$BUILDX_INSTALLED" = "true" ]; then
    printf '%s\n' "# Building $tagged_name using buildx on : $(date +'%Y-%m-%d at %H:%M')" >>"$logfile"
    printf '%s\n' "# Running for platforms: $platforms" >>"$logfile"
    eval "$BUILDX_DOCKER_CMD" buildx build ${BUILDX_REMOVE_BUILD:-} \
      --platform "$platforms" \
      --rm \
      --pull \
      --push \
      --no-cache \
      --progress auto \
      --output=type=registry \
      -t "$tagged_name" $ADD_HOST "${dir:-$PWD}" \
      -f ${Dockerfile:-Dockerfile} |& tee -a "$logfile" &>/dev/null || false
    buildx_status=$?
  else
    printf '%s\n' "# Building $tagged_name using build on : $(date +'%Y-%m-%d at %H:%M')" >>"$logfile"
    eval "$BUILDX_DOCKER_CMD" build \
      --pull \
      --force-rm \
      --no-cache \
      -t "$tagged_name" $ADD_HOST "${dir:-$PWD}" \
      -f ${Dockerfile:-Dockerfile} |& tee -a "$logfile" &>/dev/null || false
    buildx_status=$?
    if [ "$buildx_status" = 0 ]; then
      if __docker_push; then
        printf '\n%s\n' "# Pushing of $tagged_name completed on : $(date +'%Y-%m-%d at %H:%M')" >>"$logfile"
      else
        printf '\n%s\n' "# Pushing of $tagged_name failed on : $(date +'%Y-%m-%d at %H:%M')" >>"$logfile"
      fi
    fi
  fi
  if [ $buildx_status = 0 ]; then
    printf '\n%s\n' "# Finished building $tagged_name on : $(date +'%Y-%m-%d at %H:%M')" >>"$logfile"
  else
    printf '\n%s\n' "# Building of $tagged_name has failed on : $(date +'%Y-%m-%d at %H:%M')" >>"$logfile"
  fi
  __remove_pid
  return $buildx_status
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__build_cmd() {
  local exitCodeS="1"
  local dir="${1:-$REALPATH}"
  if [ -f "$dir/.build_failed" ]; then
    cat "$dir/.build_failed" | grep '^'
    printf_red "Please check the error log and fix all problems"
    printf_red "Then remove $dir/.build_failed and retry"
    exit 20
  fi
  if [ -f "$BUILDX_PID_FILE" ]; then
    printf_exit "$APPNAME is already running"
  else
    BUILDX_IS_RUNNING="true"
    echo "$BUILDX_PID_NUMBER" >"$BUILDX_PID_FILE"
  fi
  if [ "$BUILDX_INSTALLED" = "false" ]; then
    printf_yellow "💔 buildx is not installed - Using 'docker build' instead. 💔"
  fi
  printf_blue "Log is being written to: ${logfile//$HOME/~}"
  __run_docker_build
  exitCodeS=$?
  if [ "$exitCodeS" -ne 0 ]; then
    printf_yellow "The last 50 lines of the log are in:"
    printf_cyan "$dir/.build_failed"
    printf_blue "Full log is in the logfile"
    echo "build failed on $(date +'%Y-%m-%d at %H:%M')" >"$dir/.build_failed"
    tail -n50 "$logfile" >>"$dir/.build_failed"
  fi
  return ${exitCodeS:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__execute_buildx() {
  echo "$*" | grep -q '.*.:.*.' && __usage
  [ $# -ne 0 ] || __usage
  buildxexitCode=0
  notify_message=""
  tag_version="$BUILDX_DEFAULT_VERSION"
  if [ -f "$1" ]; then
    Dockerfile="$1"
    REALPATH="$(dirname "$(realpath "$Dockerfile")")"
    dirname="$(basename "$REALPATH")"
    shift 1
  elif [ -d "$1" ]; then
    Dockerfile="${1//$PWD\//}/Dockerfile"
    REALPATH="$(dirname "$(realpath "$Dockerfile")")"
    dirname="$(basename "$REALPATH")"
    shift 1
  elif [ -f "$PWD/$1" ]; then
    Dockerfile="${1//$PWD\//}"
    REALPATH="$(dirname "$(realpath "$Dockerfile")")"
    dirname="$(basename "$(dirname "$(realpath "$Dockerfile")")")"
    shift 1
  elif [ -f "$BUILDX_CWD/Dockerfile" ]; then
    Dockerfile="$BUILDX_CWD/Dockerfile"
    REALPATH="$(dirname "$(realpath "$Dockerfile")")"
    dirname="$(basename "$(dirname "$(realpath "$Dockerfile")")")"
  fi
  if [ -n "$REALPATH" ] && [ -f "$REALPATH/Dockerfile" ]; then
    builtin cd "$REALPATH" || exit 15
  else
    printf_exit "Well something went wrong while looking for Dockerfile"
  fi
  if [ $# -eq 1 ]; then
    name="${1:-$dirname}"
    shift 1
  elif [ $# -eq 2 ]; then
    name="${1:-$dirname}"
    tag_version="${2:-$tag_version}"
    BUILDX_DEFAULT_VERSION="$tag_version"
    shift 2
  else
    REALPATH="$(dirname "$(realpath "$PWD/Dockerfile")")"
    name="$(basename "$REALPATH")"
  fi
  name="$(echo "$name" | tr '[:upper:]' '[:lower:]')"
  dirname="$(echo "$dirname" | tr '[:upper:]' '[:lower:]')"
  if [ ! -f "$Dockerfile" ] || [ -z "$(ls -A "$Dockerfile" 2>/dev/null)" ]; then
    printf_exit "Can not find a $Dockerfile in $REALPATH"
  fi
  if [ "$BUILDX_DEFAULT_HUB" = "docker.io" ]; then
    tagged_name="$BUILDX_DEFAULT_REPO/$name"
  else
    tagged_name="$BUILDX_DEFAULT_HUB/$BUILDX_DEFAULT_REPO/$name"
  fi
  if [ -d "$REALPATH/.git" ]; then
    printf_yellow "This seems to be a git repo: running git pull"
    git -C "$REALPATH" pull -q &>/dev/null
  fi
  if [ -n "$Dockerfile" ]; then
    printf_cyan "Using $Dockerfile to build $tagged_name:$tag_version"
  else
    printf_cyan "Building $tagged_name"
  fi
  if [ -f "$Dockerfile" ]; then
    [ -d "$REALPATH/rootfs" ] || mkdir -p "$REALPATH/rootfs"
  fi
  logfolder="$(dirname "$tagged_name" | sed 's|.*://||g')"
  logfile="$BUILDX_LOG_DIR/$(echo "$tagged_name" | awk -F':' '{print $1}').log"
  push_tag="$tagged_name:$tag_version"
  set_tag="${push_tag//$BUILDX_DEFAULT_HUB\//}"
  pretty_name="${set_tag/:*/}"
  [ -d "$BUILDX_LOG_DIR/$logfolder" ] || mkdir -p "$BUILDX_LOG_DIR/$logfolder"
  if __build_cmd "$REALPATH"; then
    notify_message+="Successfully built $pretty_name|"
    printf_green "Successfully built $pretty_name"
    printf_green "Pulling the updated image"
    if __docker pull "$push_tag" &>/dev/null; then
      printf '\n%s\n' "# Successfully pulled $push_tag on : $(date +'%Y-%m-%d at %H:%M')" >>"$logfile"
      notify_message+="Successfully pulled $push_tag|"
      printf_green "Successfully pulled $push_tag"
      __docker rmi "$push_tag" &>/dev/null || true
      __docker rmi "$pretty_name" &>/dev/null || true
      buildxexitCode=0
    else
      printf '\n%s\n' "# Failed to pull $push_tag on : $(date +'%Y-%m-%d at %H:%M')" >>"$logfile"
      notify_message+="Failed to pull $push_tag|"
      printf_red "Failed to pull $push_tag" 1>&2
      buildxexitCode+=1
    fi
  else
    notify_message+="Failed to build $name|"
    printf_red "Failed to build $name" 1>&2
    buildxexitCode+=1
  fi
  notify_message="$(echo "$notify_message" | tr '|' '\n')"
  __notifications "${notify_message[@]}"
  exitCode="${buildxexitCode:-$?}"
  printf "# Exit status: %s\n" "$exitCode" >>"$logfile"
  printf '###############################################################################\n\n' >>"$logfile"
  [ -f "$BUILDX_PID_FILE" ] && rm -Rf "$BUILDX_PID_FILE"
  [ "$buildxexitCode" = 0 ] && exitCode=0 || exitCode=$buildxexitCode
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_logged_in() {
  __docker system info 2>&1 | grep -E 'Username|Registry' | grep -i "Username" | awk '{print $2}' | grep -q '^' &&
    return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api() {
  local repo
  repo="$(__curl "https://hub.docker.com/v2/repositories/$BUILDX_DEFAULT_REPO/?page_size=1000" | __jq -r '.results|.[]|.name' | grep '^')"
  [ -n "$repo" ] && echo "$repo" | grep -vE 'tools|templates|.docker' | grep '^' || exit 2
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_search() {
  [ $# -eq 1 ] || return 1
  local repo
  repo="$(__curl "https://hub.docker.com/v2/repositories/$1/?page_size=1000" | __jq -r '.results|.[]|.name' | grep '^')"
  [ -n "$repo" ] && echo "$repo" | grep -vE 'tools|templates|.docker' | grep '^' || exit 2
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_source() {
  local list
  list="$(__curl "https://api.github.com/orgs/${1:-$BUILDX_GIT_REPO_USER}/repos?per_page=1000" | __jq -r '.[].name' | grep '^')"
  [ -n "$list" ] || list="$(__curl -q -LSsf "https://api.github.com/users/${1:-BUILDX_GIT_REPO_USER}/repos?per_page=1000" | __jq -r '.[].name' | grep '^')"
  [ -n "$list" ] && echo "$list" | grep -vE 'tools|templates|.github' | grep '^' || exit 2
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_clone() {
  local repos git_url
  [ "$1" = "all" ] && repos="$(__api_source "$BUILDX_GIT_REPO_USER")" || repos="$(__api_source "$BUILDX_GIT_REPO_USER" | grep "$1" | head -n1)"
  git_url="${2:-$BUILDX_GIT_REPO_PROVIDER/$BUILDX_GIT_REPO_USER}"
  [ -n "$repo" ] || exit 2
  [ -n "$git_url" ] || exit 2
  for repo in $repos; do
    gitadmin clone "$git_url/$repo"
  done
}
