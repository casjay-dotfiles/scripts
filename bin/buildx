  __printf_line "--config                        - Generate user config file"
  __printf_line "--version                       - Show script version"
  __printf_line "--options                       - Shows all available options"
  __printf_line "--debug                         - Enables script debugging"
  __printf_line "--raw                           - Removes all formatting on output"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -s "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$BUILDX_REQUIRE_SUDO" = "yes" ] && [ -z "$BUILDX_REQUIRE_SUDO_RUN" ]; then
    export BUILDX_REQUIRE_SUDO="no"
    export BUILDX_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "$(basename "$SUDO" 2>/dev/null)" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-$?}
  [ -f "$BUILDX_TEMP_FILE" ] && rm -Rf "$BUILDX_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__trap_exit_local() {
  [ "$_DEBUG" = "on" ] && [ -n "$exitCode" ] && echo $exitCode
  __buildx_cleanup
  __remove_pid
  echo ''
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_docker_api_tags() {
  [ -n "$DEBUGGER" ] && set -x
  local tags="" latest="" words="" numbers=""
  [ $# -eq 3 ] || return 1
  tags="$(curl -q -LSsf "$1/$2/$3/tags?page_size=1000" | jq -r ".results[].name" | grep '^' | grep -v '^$')"
  latest="$(printf '%s' "$tags" | grep -E 'latest|edge|rolling' | grep '^')"
  words="$(printf '%s' "$tags" | grep -Ev 'latest|edge|rolling|[0-9]' | grep '^')"
  numbers="$(printf '%s' "$tags" | grep -E '[0-9]' | grep -Evi '[a-z]' | sort --reverse -u --version-sort | grep '^')"
  [ -n "$latest" ] && printf '%s\n' "$latest" || latest="na"
  [ -n "$words" ] && printf '%s\n' "$words" || word="na"
  [ -n "$numbers" ] && printf '%s\n' "$numbers" || numbers="na"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_tags() {
  [ -n "$DEBUGGER" ] && set -x
  local results=""
  local repo="${1:-}"
  local image="${2:-}"
  local registry="${3:-$2}"
  local api_url="${4:-v2/repositories}"
  local registry="https://registry.hub.docker.com/$api_url"
  echo "$image" | grep -q '/' && repo="${repo//\/*/}" && image="${repo//*\//}"
  [ -n "$image" ] || repo="library" image="$1"
  [ -n "$image" ] && [ -n "$image" ] || printf_exit "Usage: $APPNAME api tags [repo] [image]"
  results="$(__curl_docker_api_tags "$registry" "$repo" "$image" | grep '^')"
  if [ -n "$results" ]; then
    printf_cyan "found the following tags for $repo/$image"
    printf '%s\n' "$results" | printf_column "$BUILDX_OUTPUT_COLOR_1" | grep -v '^$'
    return 0
  else
    printf_exit "Failed to get tags from $registry/$repo/$image"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_dockerfile_ver() {
  [ -n "$DEBUGGER" ] && set -x
  local dver="" ver="" filename="" fileloc="" exitC=0
  local buildx_enable_tag="$BUILDX_ADD_TAG"
  fileloc="$(realpath "${1:-$Dockerfile}" 2>/dev/null)"
  filename="$(basename "$fileloc" 2>/dev/null)"
  get_vers="$(grep -s -E 'ARG.*CONTAINER_VERSION=|ARG.*DISTRO_VERSION=|ARG.*IMAGE_VERSION=' "$fileloc")"
  ver="$(basename "$filename" 2>/dev/null | sed 's/^[^\.]*\./rel:/' | awk -F ':' '{print $2}' | grep '^' || echo '')"
  cver="$(echo "$get_vers" | grep 'ARG.*CONTAINER_VERSION=' | awk -F '=' '{print $2}' | sed 's|"||g' | head -n1 | grep -Ev '\${.*_.*}|latest' | grep '^' || echo "")"
  dver="$(echo "$get_vers" | grep 'ARG.*DISTRO_VERSION=' | awk -F '=' '{print $2}' | sed 's|"||g' | head -n1 | grep -Ev '\${.*_.*}|latest|edge|rolling' | grep '^' || echo "${cver:-$ver}")"
  iver="$(echo "$get_vers" | grep 'ARG.*IMAGE_VERSION=' | awk -F '=' '{print $2}' | sed 's|"||g' | head -n1 | grep -Ev '\${.*_.*}|latest|edge|rolling' | grep '^' || echo "${cver:-$dver}")"
  dver="${iver:-$dver}"
  [ -f "$fileloc" ] || return 1
  [ "$cver" = "dev" ] && cver="devel"
  [ "$dver" = "dev" ] && dver="devel"
  if [ -n "$cver" ] && [ "$cver" != "$dver" ]; then
    BUILDX_ADD_TAG="true"
    BUILDX_VERSION_TAG="$BUILDX_VERSION_TAG $cver $dver latest"
    new_tag="$ver"
  elif [ -n "$dver" ]; then
    new_tag="$dver"
  elif [ -n "$iver" ]; then
    new_tag="$iver"
  elif echo "$ver" | grep -q '[0-9]'; then
    new_tag="$ver"
  elif echo "$ver" | grep -Eq 'edge'; then
    new_tag='edge'
  elif echo "$ver" | grep -Eq 'latest'; then
    new_tag='latest'
  elif echo "$ver" | grep -Eq 'rolling'; then
    new_tag='rolling'
  elif echo "$ver" | grep -Eq 'next|beta|alpha|test|testing'; then
    new_tag='next'
  elif [ -n "$ver" ]; then
    new_tag="$ver"
  else
    exitC=1
  fi
  [ -n "$BUILDX_VERSION_TAG" ] || BUILDX_ADD_TAG="${buildx_enable_tag:-}"
  return $exitC
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_run() {
  __reinit_buildx
  if [ $# -ne 0 ]; then
    __execute_buildx "$@"
    exitCode=$?
  elif [ -f "$BUILDX_CWD/Dockerfile" ]; then
    __execute_buildx "$BUILDX_CWD/Dockerfile"
    exitCode=$?
  else
    printf_red "Can not find a Dockerfile in ${BUILDX_CWD}"
    exitCode=1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__remove_pid() {
  if [ "$BUILDX_IS_RUNNING" = "true" ] && [ -f "$BUILDX_PID_FILE" ]; then
    rm -Rf "$BUILDX_PID_FILE"
  fi
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_buildx_installed() {
  local buildx_installed=""
  buildx_installed="$(__docker_init buildx ls 2>&1 | grep -q 'NAME/NODE' && echo 'yes' || echo '')"
  if [ "$buildx_installed" = "yes" ]; then
    export BUILDX_INSTALLED="true"
    return 0
  else
    export BUILDX_INSTALLED="false"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_docker_installed() {
  if ! type -p docker &>/dev/null; then
    printf_red "Docker is not installed either run dockermgr init"
    printf_exit "or refer to docker documentation for installation"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_initialized() {
  { [ -e "/root/.docker/buildx/instances/$name" ] || [ -e "$HOME/.docker/buildx/instances/$name" ]; } &&
    [ -n "$builder_id" ] && [ -n "$qemu_id" ] && [ -n "$binfmt_id" ] && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__jq() { jq "${@:--r}" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl() { curl -q -LSsf --max-time 2 --retry 0 "$*" 2>/dev/null || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__usage() {
  printf_exit 1 2 "Usage: $APPNAME [Dir] [Dockerfile] [name] [tag]" 1>&2
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker() {
  eval "$BUILDX_DOCKER_CMD" "$@" 2>/dev/null && true
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker_init() {
  eval "$BUILDX_DOCKER_CMD" "$@" 2>&1 && true
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker_push() {
  __docker push "$tagged_name" |& tee -a "$logfile" &>/dev/null ||
    __docker push "$tagged_name" |& tee -a "$logfile" &>/dev/null ||
    __docker push "$tagged_name" |& tee -a "$logfile" &>/dev/null && true
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__qemu_version() {
  if grep -sq 'enabled' "/proc/sys/fs/binfmt_misc/status"; then
    if __cmd_exists qemu-aarch64-static; then
      version="$(qemu-aarch64-static --version | head -n1 | cut -d' ' -f3 | tr -cd '0-9.')"
      printf_blue "QEMU aarch64 version: $version"
    fi
    if __cmd_exists qemu-x86_64-static; then
      version="$(qemu-x86_64-static --version | head -n1 | cut -d' ' -f3 | tr -cd '0-9.')"
      printf_blue "QEMU x86_64 version: $version"
    fi
    if __cmd_exists qemu-arm-static; then
      version="$(qemu-arm-static --version | head -n1 | cut -d' ' -f3 | tr -cd '0-9.')"
      printf_blue "QEMU arm version: $version"
    fi
  else
    printf_red "Missing qemu-user-static package."
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker_version() {
  version="$(__docker --version | cut -d' ' -f3 | tr -cd '0-9.' | sed -e 's/ 0*/ /g')"
  [ -n "$version" ] && printf_blue "Docker version: $version"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__binfmt_version() {
  if __cmd_exists update-binfmts; then
    version="$(update-binfmts --version | awk '{print $NF}')"
    [ -n "$version" ] && printf_blue "update-binfmts version: $version"
  else
    printf_return "Please install update-binfmts"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_vars() {
  [ "$1" = "" ] && shift 1
  export name="${1:-$BUILDX_BUILDER_NAME}"
  export name="${name:-mybuilder}"
  export qemu_imagename="buildx-qemu"
  export binfmt_imagename="buildx-binfmt"
  export qemu_id="$(__docker_init ps -a | awk '{print $NF}' | grep "$qemu_imagename" || echo '')"
  export binfmt_id="$(__docker_init ps -a | awk '{print $NF}' | grep "$binfmt_imagename" || echo '')"
  export builder_id="$(__docker_init ps -a | awk '{print $NF}' | grep "$name" | grep "buildkit" || __docker_init buildx ls | grep "$name" | awk -F ' ' '{print $1}' | head -n1 || echo '')"
  BUILDX_BUILDER_NAME="$name"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_version() {
  features="$(__docker version | awk '/^ *Experimental:/ {print $2 ; exit}')"
  [ "$features" == "true" ] && printf_blue "Experimental Features: yes" ||
    printf_red "Experimental Features: no"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__builder_init() {
  __buildx_vars "${BUILDX_BUILDER_NAME:-}"
  [ -n "$qemu_id" ] && [ -n "$binfmt_id" ] && [ -n "$builder_id" ] && return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__reinit_buildx() {
  __buildx_vars "${BUILDX_BUILDER_NAME:-}"
  [ "$BUILDX_INSTALLED" = "yes" ] || [ "$BUILDX_INIT_RAN" != "true" ] || return
  [ "$BUILDX_FORCE_REINSTALL" = "yes" ] || [ -z "$builder_id" ] || [ -z "$binfmt_id" ] || [ -z "$qemu_id" ] || return 1
  printf_cyan "Reinitializing buildx $name on $(date)"
  echo "Reinitializing buildx $name on $(date)" |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
  local force="${BUILDX_FORCE_REINSTALL:-$BUILDX_CLEAN_FORCE}"
  [ -z "$builder_id" ] || __docker_init rm -f $builder_id |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
  [ -z "$binfmt_id" ] || __docker_init rm -f "$qemu_imagename" |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
  [ -z "$qemu_id" ] || __docker_init rm -f "$binfmt_imagename" |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
  __docker_init run -d --name "$qemu_imagename" --privileged multiarch/qemu-user-static --reset -p yes --credential yes |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
  __docker_init run -d --name "$binfmt_imagename" --privileged tonistiigi/binfmt --install all |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
  __docker_init buildx create --driver docker-container --driver-opt network=host --driver-opt image=moby/buildkit:master --name ${name:-mybuilder} --use |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
  __docker_init buildx use "$name" |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
  __docker_init buildx inspect --bootstrap |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
  __buildx_vars "${BUILDX_BUILDER_NAME:-}"
  [ -n "$builder_id" ] && BUILDX_INSTALLED="true" && BUILDX_FORCE_REINSTALL="" BUILDX_FORCE="" BUILDX_INIT_RAN="true" || { echo "Initializing of buildx failed" |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null && printf_yellow "Initializing of buildx failed"; }
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_cleanup() {
  if [ "$BUILDX_CLEANUP" = "true" ] && [ "$BUILDX_IS_RUNNING" = "true" ]; then
    [ "$BUILDX_RAN_CLEANUP" = "true" ] || printf_yellow "Cleaning up containers"
    __docker rm -f $builder_id $qemu_imagename $binfmt_imagename &>/dev/null
    BUILDX_RAN_CLEANUP="true"
    __builder_init && return 1
  fi
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_init() {
  __buildx_vars "$1"
  local buildx_log_file="$HOME/.local/log/buildx/$name.log"
  if [ "$BUILDX_FORCE" = "true" ]; then
    [ -d "$HOME/.docker/buildx" ] && rm -Rf "$HOME/.docker/buildx"
    [ -d "/root/.docker/buildx" ] && __sudo rm -Rf "$HOME/.docker/buildx"
    BUILDX_CLEAN_FORCE="true"
    BUILDX_FORCE_REINSTALL="true"
    __reinit_buildx
  fi
  if [ "$BUILDX_FORCE_REINSTALL" = "true" ] || [ "$BUILDX_CLEAN_FORCE" = "true" ]; then
    __reinit_buildx
  elif __is_initialized && [ "$BUILDX_FORCE" != "true" ]; then
    printf_cyan "buildx seems to be already setup"
    return 0
  else
    echo "Starting buildx init for $name on $(date)" |& tee "$HOME/.local/log/buildx/$name.log"
    printf_yellow "Initializing docker build"
    printf_cyan "Setting logfile to: $buildx_log_file"
    if [ "$BUILDX_CLEANUP" = "true" ] || { [ -n "$binfmt" ] && [ -n "$qemu" ]; }; then
      printf_yellow "Removing old containers: $qemu_imagename,$binfmt_imagename"
      __docker_init rm -f "$qemu_imagename" |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
      __docker_init rm -f "$binfmt_imagename" |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
    fi
    if [ "$(uname -m)" = "x86_64" ]; then
      # Setup qemu
      # sudo docker run --rm --privileged multiarch/qemu-user-static --reset -p yes --credential yes
      printf_yellow "Setting up the qemu image - multiarch/qemu-user-static as $qemu_imagename"
      __docker_init run -d --name "$qemu_imagename" ---privileged multiarch/qemu-user-static --reset -p yes --credential yes |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
      # Setup binfmt
      printf_yellow "Setting up the binfmt image - tonistiigi/binfmt as $binfmt_imagename"
      __docker_init run -d --name "$binfmt_imagename" --privileged tonistiigi/binfmt --install all |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
      # setup buildx
      printf_blue "Setting up docker build to use buildx"
      #__docker_init buildx create --buildkitd-flags '--allow-insecure-entitlement security.insecure' --name "$name" --use |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
      __docker_init buildx create --driver docker-container --driver-opt network=host --driver-opt image=moby/buildkit:master --name ${name:-mybuilder} --use |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
      __docker_init buildx use "$name" |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
      __docker_init buildx inspect --bootstrap |& tee -a "$HOME/.local/log/buildx/$name.log" &>/dev/null
    fi
    printf_blue "Making sure docker service is running"
    if sudo systemctl status docker.service docker.socket | grep -q 'daemon-reload'; then
      sudo systemctl daemon-reload
    fi
    if ! systemctl status systemd-binfmt.service | grep -iq 'running'; then
      sudo systemctl enable -now systemd-binfmt.service &>/dev/null
      sudo systemctl restart systemd-binfmt.service &>/dev/null
    fi
    if ! systemctl status docker*.service | grep -iq 'running'; then
      sudo systemctl enable --now docker &>/dev/null
      sudo systemctl restart docker &>/dev/null
    fi
    printf_yellow "Making sure user is signed into to docker hub"
    __is_logged_in || __docker_init login || exit 2
    printf_purple "Finishing up"
    [ -d "$HOME/.docker/buildx" ] || mkdir -p "$HOME/.docker/buildx"
    sudo bash -c '[ -d "/root/.docker/buildx" ] && [ "/root/.docker/buildx" != "'$HOME/.docker/buildx'" ] && cp -Rf /root/.docker/buildx/. "'$HOME/.docker/buildx/'"'
    sudo chown -Rf "$SUDO_USER":"$SUDO_USER" "$HOME/.docker"
    [ -e "$HOME/.docker/buildx/current" ] && printf_green "Docker build has been setup"
    printf_cyan "Usage: buildx [init, status, version]"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tag_versions() {
  local add_new_host="" add_image_name="" add_full_host=""
  new=""
  host="${host:-$BUILDX_DEFAULT_HUB}"
  add_image_name="${image_name//:*/}"
  add_tags="${BUILDX_VERSION_TAG//,/ }"
  namespace="${namespace:-$BUILDX_DEFAULT_REPO}"
  add_full_host="${1:-$host/$namespace/$add_image_name}"
  if [ "$BUILDX_ADD_TAG" = "true" ]; then
    for tag in $add_tags; do
      [ "$tag" = "$BUILDX_DEFAULT_VERSION" ] || new+="-t $add_full_host:$tag "
    done
    ADD_HOST="$new "
  else
    add_new_host="$add_full_host:$tag_version"
  fi
  unset new
  image_name="$add_new_host"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__buildx_status() {
  local a="" e="" c="" r="" s=""
  e=0
  a="$*"
  c="$(__docker buildx inspect ${1:-$BUILDX_BUILDER_NAME} || false)"
  r="$(__docker buildx ls | grep ${1:-$BUILDX_BUILDER_NAME} | grep -qi 'running' && echo 'running' || false)"
  s="$(echo "$c" | grep -i 'Status:' | grep -qi 'running' && echo 'Running' || false)"
  if [ ${#a} = 0 ]; then
    [ -n "$s" ] && e=0 || e=1
  else
    if [ -n "$s" ]; then
      printf '%s\n' "$c"
      e=0
    else
      printf '%s\n' "buildx is not running"
      e=1
    fi
  fi
  return ${e:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_docker_script() {
  set_build_command="$(<"$BUILDX_CWD/build.sh")"
  set_build_command="${set_build_command//  / }"
  build_command="$(echo "$set_build_command" | grep '^' | grep -v '^$' | sed 's|,,| \\\n|g')"
  set_build_command="${set_build_command//,,/}"
  printf '%b%s: %b%s%b\n' "$GREEN" "Setting the build script to" "$CYAN" "$logscript_file" "$NC"
  printf 'Saving the build command to: %s\n' "$logscript_file" | tee -a "$logfile" &>/dev/null
  __save_build_script
  printf_blue "Setting default tag to: $set_tag"
  if [ "$BUILDX_ADD_TAG" = "true" ] || [ -n "$REGISTRY_TAG" ]; then
    printf_blue "Adding tags: $ADDITIONAL_PRETTY"
    printf '%s\n' "# Adding tags: $ADDITIONAL_PRETTY" | tee -a "$logfile" &>/dev/null
  fi
  sleep 2
  printf_cyan "Running for platforms: $platforms"
  printf '%s\n' "# Running for platforms: $platforms" | tee -a "$logfile" &>/dev/null
  printf 'Executing: %s\n' "$set_build_command" | tee -a "$logfile" &>/dev/null
  eval "$set_build_command" |& tee -a "$logfile" &>/dev/null || false
  return $?

}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_dockermgr_script() {
  local dir="/tmp/builder"
  local build_tags="-t $tagged_name $ADDITIONAL_TAGS"
  local build_name="$(basename "${tagged_name//:*/}")"
  local buildfile="$(basename "${Dockerfile:-Dockerfile}")"
  set_build_command='dockermgr --name '$build_name',, -- builder buildx_script "'$platforms'",, "'$build_tags'",, "'$dir'",, "'$dir/$buildfile'"'
  set_build_command="${set_build_command//  / }"
  build_command="$(echo "$set_build_command" | grep '^' | grep -v '^$' | sed 's|,,| \\\n|g')"
  set_build_command="${set_build_command//,,/}"
  printf '%b%s: %b%s%b\n' "$GREEN" "Setting the build script to" "$CYAN" "$logscript_file" "$NC"
  printf 'Saving the build command to: %s\n' "$logscript_file" | tee -a "$logfile" &>/dev/null
  __save_build_script
  printf_blue "Setting default tag to: $set_tag"
  if [ "$BUILDX_ADD_TAG" = "true" ] || [ -n "$REGISTRY_TAG" ]; then
    printf_blue "Adding tags: $ADDITIONAL_PRETTY"
    printf '%s\n' "# Adding tags: $ADDITIONAL_PRETTY" | tee -a "$logfile" &>/dev/null
  fi
  sleep 2
  printf_cyan "Running for platforms: $platforms"
  printf '%s\n' "# Running for platforms: $platforms" | tee -a "$logfile" &>/dev/null
  printf 'Executing: %s\n' "$build_command" | tee -a "$logfile" &>/dev/null
  eval "$set_build_command" |& tee -a "$logfile" &>/dev/null || false
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_buildx_script() {
  set_build_command="$BUILDX_DOCKER_CMD buildx build ${BUILDX_REMOVE_BUILD:-},, --platform $platforms,, --rm --pull --push,, --no-cache --progress auto --output=type=registry,, -t $tagged_name $ADDITIONAL_TAGS,, ${dir:-$PWD},, -f ${Dockerfile:-Dockerfile}"
  set_build_command="${set_build_command//  / }"
  build_command="$(echo "$set_build_command" | grep '^' | grep -v '^$' | sed 's|,,| \\\n|g')"
  set_build_command="${set_build_command//,,/}"
  printf '%b%s: %b%s%b\n' "$GREEN" "Setting the build script to" "$CYAN" "$logscript_file" "$NC"
  printf 'Saving the build command to: %s\n' "$logscript_file" | tee -a "$logfile" &>/dev/null
  __save_build_script
  printf_blue "Setting default tag to: $set_tag"
  if [ "$BUILDX_ADD_TAG" = "true" ] || [ -n "$REGISTRY_TAG" ]; then
    printf_blue "Adding tags: $ADDITIONAL_PRETTY"
    printf '%s\n' "# Adding tags: $ADDITIONAL_PRETTY" | tee -a "$logfile" &>/dev/null
  fi
  sleep 2
  printf_cyan "Running for platforms: $platforms"
  printf '%s\n' "# Running for platforms: $platforms" | tee -a "$logfile" &>/dev/null
  printf 'Executing: %s\n' "$set_build_command" | tee -a "$logfile" &>/dev/null
  eval "$set_build_command" |& tee -a "$logfile" &>/dev/null || false
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_build_script() {
  set_build_command="$BUILDX_DOCKER_CMD build,, --pull --force-rm --no-cache,, -t $tagged_name $ADDITIONAL_TAGS,, ${dir:-$PWD},, -f ${Dockerfile:-Dockerfile}"
  set_build_command="${set_build_command//  / }"
  build_command="$(echo "$set_build_command" | grep '^' | grep -v '^$' | sed 's|,,| \\\n|g')"
  set_build_command="${set_build_command//,,/}"
  printf '%b%s: %b%s%b\n' "$GREEN" "Setting the build script to" "$CYAN" "$logscript_file" "$NC"
  printf 'Saving the build command to: %s\n' "$logscript_file" | tee -a "$logfile" &>/dev/null
  __save_build_script
  printf_blue "Setting default tag to: $set_tag"
  if [ "$BUILDX_ADD_TAG" = "true" ] || [ -n "$REGISTRY_TAG" ]; then
    printf_blue "Adding tags: $ADDITIONAL_PRETTY"
    printf '%s\n' "# Adding tags: $ADDITIONAL_PRETTY" | tee -a "$logfile" &>/dev/null
  fi
  sleep 2
  printf_cyan "Running for platforms: $platforms"
  printf '%s\n' "# Running for platforms: $platforms" | tee -a "$logfile" &>/dev/null
  printf 'Executing: %s\n' "$set_build_command" | tee -a "$logfile" &>/dev/null
  eval "$set_build_command" |& tee -a "$logfile" &>/dev/null || false
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__save_build_script() {
  [ -d "$logscript_dir" ] || mkdir -p "$logscript_dir"
  echo "command: $build_command" |& tee "$logscript_file" &>/dev/null
  cat <<EOF |& tee "$logscript_file" &>/dev/null
#!/usr/bin/env bash
# Build command for $tagged_name

${build_command}
exit \$?

EOF
  chmod -Rf 755 "$logscript_file"
  [ -x "$logscript_file" ] && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_docker_build() {
  set -e -o pipefail
  cd "$BUILDX_CWD" || return 1
  buildx_status="0" ADD_HOST=""
  namespace="$BUILDX_ADD_REPO"
  platforms="${BUILDX_DOCKER_PLATFORMS// /,}"
  registry="${BUILDX_ADD_REGISTRY//,/ }"
  image_name="${tagged_name//$BUILDX_DEFAULT_REPO\//}"
  if [ -n "$BUILDX_ADD_REGISTRY" ] && [ "$BUILDX_ENABLE_REGISTRY" = "true" ]; then
    for host in $registry; do
      namespace="$BUILDX_ADD_REPO"
      if [ -n "$BUILDX_ADD_REPO" ]; then
        [ "$BUILDX_ADD_REPO" = "" ] && namespace="library"
        [ "$BUILDX_ADD_REPO" = "_" ] && namespace="library"
        if echo "$image_name" | grep -q ":"; then
          full_host="$host/$namespace/$image_name"
          ADD_HOST+="-t $full_host "
        else
          __tag_versions "$host/$namespace/$image_name"
        fi
      else
        ADD_HOST+="-t $host/$namespace/$image_name "
      fi
    done
  else
    __tag_versions "$tagged_name"
  fi
  ADDITIONAL_TAGS="$REGISTRY_TAG $ADD_HOST"
  ADDITIONAL_TAGS="${ADDITIONAL_TAGS//  / }"
  ADDITIONAL_PRETTY="${ADDITIONAL_TAGS//-t /}"
  [ -n "$image_name" ] && tagged_name="$image_name" || tagged_name="$push_tag"
  if [ -z "$BUILDX_RUN_SCRIPT" ] && [ -f "$BUILDX_CWD/build.sh" ]; then
    printf_blue "Building $tagged_name using script on : $(date +'%Y-%m-%d at %H:%M')"
    printf '%s\n' "# Building $dirname using script on : $(date +'%Y-%m-%d at %H:%M')" | tee -a "$logfile" &>/dev/null
    __run_docker_script
    buildx_status=$?
    # elif __cmd_exists dockermgr; then
    #printf_blue "Building $tagged_name using dockermgr on : $(date +'%Y-%m-%d at %H:%M')"
    #printf '%s\n' "# Building $dirname using dockermgr on : $(date +'%Y-%m-%d at %H:%M')" | tee -a "$logfile" &>/dev/null
    # __run_dockermgr_script "$1"
    buildx_status=$?
  elif [ "$BUILDX_INSTALLED" = "true" ]; then
    printf_blue "Building $tagged_name using buildx on : $(date +'%Y-%m-%d at %H:%M')"
    printf '%s\n' "# Building $tagged_name using buildx on : $(date +'%Y-%m-%d at %H:%M')" | tee -a "$logfile" &>/dev/null
    __run_buildx_script
    buildx_status=$?
  else
    printf_blue "Building $tagged_name using build on : $(date +'%Y-%m-%d at %H:%M')"
    printf '%s\n' "# Building $tagged_name using build on : $(date +'%Y-%m-%d at %H:%M')" | tee -a "$logfile" &>/dev/null
    __run_build_script
    buildx_status=$?
    if [ "$buildx_status" = 0 ]; then
      if __docker_push; then
        printf '%s\n' "# Pushing of $tagged_name completed on : $(date +'%Y-%m-%d at %H:%M')" | tee -a "$logfile" &>/dev/null
      else
        printf '%s\n' "# Pushing of $tagged_name failed on : $(date +'%Y-%m-%d at %H:%M')" | tee -a "$logfile" &>/dev/null
      fi
    fi
  fi
  if [ $buildx_status = 0 ]; then
    printf '%s\n' "# Finished building $tagged_name $ADDITIONAL_PRETTY" | tee -a "$logfile" &>/dev/null
    buildx_status=0
  else
    printf '%s\n' "# Building of $tagged_name has failed" | tee -a "$logfile" &>/dev/null
    buildx_status="${buildx_status:-10}"
  fi
  printf '\n%s\n' "buildx has Finished on: $(date +'%Y-%m-%d at %H:%M')" | tee -a "$logfile" &>/dev/null
  __remove_pid
  return $buildx_status
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__build_cmd() {
  local exitCodeS="1"
  local dir="${1:-$REALPATH}"
  if [ -f "$dir/.build_failed" ]; then
    cat "$dir/.build_failed" | grep '^'
    printf_red "Please check the error log and fix all problems"
    printf_red "Then remove $dir/.build_failed and retry"
    exit 20
  fi
  if [ -f "$BUILDX_PID_FILE" ]; then
    printf_exit "$APPNAME is already running"
  else
    BUILDX_IS_RUNNING="true"
    echo "$BUILDX_PID_NUMBER" >"$BUILDX_PID_FILE"
  fi
  if [ "$BUILDX_INSTALLED" = "false" ]; then
    printf_yellow "💔 buildx is not installed - Using 'docker build' instead. 💔"
  fi
  __run_docker_build
  exitCodeS=$?
  if [ "$exitCodeS" -ne 0 ]; then
    printf_yellow "The last 50 lines of the log are in:"
    printf_cyan "$dir/.build_failed"
    printf_blue "Full log is in the logfile"
    echo "build failed on $(date +'%Y-%m-%d at %H:%M')" >"$dir/.build_failed"
    tail -n50 "$logfile" >>"$dir/.build_failed"
  fi
  return ${exitCodeS:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__execute_buildx() {
  echo "$*" | grep -q '.*.:.*.' && __usage
  [ $# -ne 0 ] || __usage
  buildxexitCode=0
  notify_message=""
  if [ -f "$1" ]; then
    Dockerfile="$(realpath "$1")"
    REALPATH="$(dirname "$Dockerfile")"
    dirname="$(basename "$REALPATH")"
    shift 1
  elif [ -d "$1" ]; then
    Dockerfile="$(realpath "${1//$PWD\//}/Dockerfile")"
    REALPATH="$(dirname "$Dockerfile")"
    dirname="$(basename "$REALPATH")"
    shift 1
  elif [ -f "$PWD/$1" ]; then
    Dockerfile="$(realpath "${1//$PWD\//}")"
    REALPATH="$(dirname "$Dockerfile")"
    dirname="$(basename "$(dirname "$(realpath "$Dockerfile")")")"
    shift 1
  elif [ -f "$BUILDX_CWD/Dockerfile.latest" ]; then
    Dockerfile="$(realpath "$BUILDX_CWD/Dockerfile.latest")"
    REALPATH="$(dirname "$Dockerfile")"
    dirname="$(basename "$(dirname "$(realpath "$Dockerfile")")")"
  elif [ -f "$BUILDX_CWD/Dockerfile.next" ]; then
    Dockerfile="$(realpath "$BUILDX_CWD/Dockerfile.next")"
    REALPATH="$(dirname "$Dockerfile")"
    dirname="$(basename "$(dirname "$(realpath "$Dockerfile")")")"
  elif [ -f "$BUILDX_CWD/Dockerfile" ]; then
    Dockerfile="$(realpath "$BUILDX_CWD/Dockerfile")"
    REALPATH="$(dirname "$Dockerfile")"
    dirname="$(basename "$(dirname "$(realpath "$Dockerfile")")")"
  fi
  if [ -n "$REALPATH" ] && [ -f "$Dockerfile" ]; then
    builtin cd "$REALPATH" || exit 15
  else
    printf_exit "Well something went wrong while looking for $Dockerfile"
  fi
  if [ $# -eq 1 ]; then
    name="${1:-$dirname}"
    shift 1
  elif [ $# -eq 2 ]; then
    name="${1:-$dirname}"
    BUILDX_DEFAULT_VERSION="${2:-$BUILDX_DEFAULT_VERSION}"
    shift 2
  else
    REALPATH="$(dirname "$(realpath "$PWD/Dockerfile")")"
    name="$(basename "$REALPATH")"
  fi
  if [ ! -f "$Dockerfile" ] || [ -z "$(ls -A "$Dockerfile" 2>/dev/null)" ]; then
    printf_exit "Can not find a $Dockerfile in $REALPATH"
  fi
  __get_dockerfile_ver "$Dockerfile"
  name="$(echo "$name" | tr '[:upper:]' '[:lower:]')"
  dirname="$(echo "$dirname" | tr '[:upper:]' '[:lower:]')"
  BUILDX_DEFAULT_VERSION="${BUILDX_DEFAULT_VERSION//*:/}"
  tag_version="${new_tag:-$BUILDX_DEFAULT_VERSION}"
  tag_version="${tag_version,,}"
  BUILDX_DEFAULT_VERSION="$tag_version"
  SET_LATEST="$(grep --no-filename 'CONTAINER_VERSION=' "$Dockerfile" 2>/dev/null | grep 'latest' | awk -F '=' '{print $2}' | head -n1 | grep '' || echo '')"
  if [ "$(basename "$Dockerfile" 2>/dev/null)" = "Dockerfile" ] && [ "$tag_version" != "latest" ]; then
    BUILDX_ADD_TAG="true"
    BUILDX_VERSION_TAG="${BUILDX_VERSION_TAG},latest"
  elif [ -n "$SET_LATEST" ] && [ "$tag_version" != "latest" ]; then
    BUILDX_ADD_TAG="true"
    BUILDX_VERSION_TAG="${BUILDX_VERSION_TAG},latest"
  fi
  if [ "$BUILDX_DEFAULT_HUB" = "docker.io" ]; then
    tagged_name="$BUILDX_DEFAULT_REPO/$name"
  else
    tagged_name="$BUILDX_DEFAULT_HUB/$BUILDX_DEFAULT_REPO/$name"
  fi
  if [ -d "$REALPATH/.git" ]; then
    printf_yellow "This seems to be a git repo: running git pull"
    git -C "$REALPATH" pull -q &>/dev/null
  fi
  [ -n "$Dockerfile" ] && printf_cyan "Setting Dockerfile to: ${Dockerfile//$PWD\//./}"
  push_tag="$tagged_name:$tag_version"
  set_tag="${push_tag//$BUILDX_DEFAULT_HUB\//}"
  logfolder="$(dirname "$tagged_name" | sed 's|.*://||g')"
  logfile="$BUILDX_LOG_DIR/$(echo "$tagged_name" | awk -F':' '{print $1}').log"
  logscript_dir="$BUILDX_CONFIG_DIR/scripts/$(echo "$tagged_name" | awk -F '/' '{print $1}')"
  logscript_file="$logscript_dir/$(echo "$tagged_name" | awk -F '/' '{print $2}')-${tag_version}.sh"
  pretty_name="${set_tag/:*/}"
  printf_blue "Log is being written to: ${logfile//$HOME/~}"
  if [ -f "$Dockerfile" ]; then
    [ -d "$REALPATH/rootfs" ] || mkdir -p "$REALPATH/rootfs"
  fi
  [ -d "$BUILDX_LOG_DIR/$logfolder" ] || mkdir -p "$BUILDX_LOG_DIR/$logfolder"
  if __build_cmd "$REALPATH"; then
    notify_message+="Successfully built $set_tag $ADDITIONAL_PRETTY|"
    printf_green "Successfully built container: $pretty_name"
    printf_green "Pulling the updated image"
    if __docker pull "$push_tag" &>/dev/null; then
      printf '\n%s\n' "# Successfully pulled $push_tag on : $(date +'%Y-%m-%d at %H:%M')" | tee -a "$logfile" &>/dev/null
      notify_message+="Successfully pulled $push_tag|"
      printf_green "Successfully pulled $push_tag"
      __docker rmi "$push_tag" &>/dev/null || true
      __docker rmi "$pretty_name" &>/dev/null || true
      buildxexitCode=0
    else
      printf '\n%s\n' "# Failed to pull $push_tag on : $(date +'%Y-%m-%d at %H:%M')" | tee -a "$logfile" &>/dev/null
      notify_message+="Failed to pull $push_tag|"
      printf_red "Failed to pull $push_tag" 1>&2
      buildxexitCode+=1
    fi
  else
    notify_message+="Failed to build $name|"
    printf_red "Failed to build $name" 1>&2
    buildxexitCode+=1
  fi
  notify_message="$(echo "$notify_message" | tr '|' '\n')"
  __notifications "${notify_message[@]}"
  exitCode="${buildxexitCode:-$?}"
  printf "# Exit status: %s\n" "$exitCode" | tee -a "$logfile" &>/dev/null
  printf '###############################################################################\n\n' | tee -a "$logfile" &>/dev/null
  [ -f "$BUILDX_PID_FILE" ] && rm -Rf "$BUILDX_PID_FILE"
  [ "$buildxexitCode" = 0 ] && exitCode=0 || exitCode=$buildxexitCode
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_logged_in() {
  __docker system info 2>&1 | grep -E 'Username|Registry' | grep -i "Username" | awk '{print $2}' | grep -q '^' &&
    return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api() {
  local repo
  repo="$(__curl "https://hub.docker.com/v2/repositories/$BUILDX_DEFAULT_REPO/?page_size=1000" | __jq -r '.results|.[]|.name' | grep '^')"
  [ -n "$repo" ] && echo "$repo" | grep -vE 'tools|templates|.docker' | grep '^' || exit 2
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_search() {
  [ $# -eq 1 ] || return 1
  local repo
  repo="$(__curl "https://hub.docker.com/v2/repositories/$1/?page_size=1000" | __jq -r '.results|.[]|.name' | grep '^')"
  [ -n "$repo" ] && echo "$repo" | grep -vE 'tools|templates|.docker' | grep '^' || exit 2
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_source() {
  local list
  list="$(__curl "https://api.github.com/orgs/${1:-$BUILDX_GIT_REPO_USER}/repos?per_page=1000" | __jq -r '.[].name' | grep '^')"
  [ -n "$list" ] || list="$(__curl -q -LSsf "https://api.github.com/users/${1:-BUILDX_GIT_REPO_USER}/repos?per_page=1000" | __jq -r '.[].name' | grep '^')"
  [ -n "$list" ] && echo "$list" | grep -vE 'tools|templates|.github' | grep '^' || exit 2
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_clone() {
  local repos git_url
  [ "$1" = "all" ] && repos="$(__api_source "$BUILDX_GIT_REPO_USER")" || repos="$(__api_source "$BUILDX_GIT_REPO_USER" | grep "$1" | head -n1)"
  git_url="${2:-$BUILDX_GIT_REPO_PROVIDER/$BUILDX_GIT_REPO_USER}"
  [ -n "$repo" ] || exit 2
  [ -n "$git_url" ] || exit 2
  for repo in $repos; do
    gitadmin clone "$git_url/$repo"
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__automate() {
  # TODO: Clean this up
  local BUILDX_CWD="$(realpath "$1" 2>/dev/null)"
  local BUILDX_GIT_COMMIT_CUR=""
  local BUILDX_GIT_COMMIT_NEW=""
  [ -f "$BUILDX_CWD" ] && BUILDX_CWD="$(dirname "$BUILDX_CWD" 2>/dev/null)"
  [ -d "$BUILDX_CWD" ] && BUILDX_CWD="${BUILDX_CWD:-$PWD}" || { printf_red "Usage: $APPNAME cron [dir]" && return 1; }
  BUILDX_GIT_COMMIT_CUR="$(git -C "$BUILDX_CWD" log 2>/dev/null | head -n1 | tr ' ' '\n' | grep '[0-9].*[0-9].*[a-z]' || false)"
  echo "Attempting to update repo in $BUILDX_CWD" && git -C "$BUILDX_CWD" pull -q
  BUILDX_GIT_COMMIT_NEW="$(git -C "$BUILDX_CWD" log 2>/dev/null | head -n1 | tr ' ' '\n' | grep '[0-9].*[0-9].*[a-z]' || false)"
  [ -n "$BUILDX_GIT_COMMIT_CUR" ] && [ -n "$BUILDX_GIT_COMMIT_NEW" ] || { printf_red "Failed to get the git commit history" && return 1; }
  if [ "$BUILDX_GIT_COMMIT_CUR" = "$BUILDX_GIT_COMMIT_NEW" ]; then
    printf_cyan "No changes detected! exiting....."
    return
  else
    $APPNAME all "$BUILDX_CWD"
    return $?
  fi
}
