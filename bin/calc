#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : calc --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : calc
# @Description   : wrapper for qalc/bc
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ -n "$DISPLAY" ]] && [ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# = 0 ]; } && TERMINAL_APP="TRUE" eval ${TERMINALE:-myterminal} -e "${APPNAME:-bash}" ${*:-} && { exit || exit 1; }
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$CALC_TEMP_FILE" ] && [ -f "$CALC_TEMP_FILE" ] && rm -Rf "$CALC_TEMP_FILE" &>/dev/null' EXIT
trap '' SIGINT
trap '' SIGQUIT
trap '' SIGTSTP
set -o noglob

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-simple.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$CALC_CONFIG_DIR/$CALC_CONFIG_FILE"
  [ -d "$CALC_CONFIG_DIR" ] || mkdir -p "$CALC_CONFIG_DIR"
  [ -d "$CALC_CONFIG_BACKUP_DIR" ] || mkdir -p "$CALC_CONFIG_BACKUP_DIR"
  [ -f "$CALC_CONFIG_DIR/$CALC_CONFIG_FILE" ] &&
    cp -Rf "$CALC_CONFIG_DIR/$CALC_CONFIG_FILE" "$CALC_CONFIG_BACKUP_DIR/$CALC_CONFIG_FILE.$$"
  cat <<EOF >"$CALC_CONFIG_DIR/$CALC_CONFIG_FILE"
# Settings for calc

# Notification settings
CALC_GOOD_MESSAGE="${CALC_GOOD_MESSAGE:-Everything Went OK}"
CALC_ERROR_MESSAGE="${CALC_ERROR_MESSAGE:-Well something seems to have gone wrong}"
CALC_NOTIFY_ENABLED="${CALC_NOTIFY_ENABLED:-yes}"
CALC_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CALC_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CALC_NOTIFY_CLIENT_ICON}"

# Colorization settings
CALC_OUTPUT_COLOR="${CALC_OUTPUT_COLOR:-5}"
CALC_OUTPUT_COLOR_GOOD="${CALC_OUTPUT_COLOR_GOOD:-2}"
CALC_OUTPUT_COLOR_ERROR="${CALC_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$CALC_CONFIG_DIR/$CALC_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for calc has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      exec $APPNAME "$*"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__usage() {
  printf_cyan 'Usage: "20 * 4/2 + 23 - 14"'
  printf_red "press q to exit"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
calc_app() {
  if cmd_exists qalc; then
    local answer="$(qalc "$CALC_OUTPUT")"
  elif cmd_exists bc; then
    local answer="$(echo "$CALC_INPUT = $(echo "$CALC_OUTPUT" | bc -q)")"
  else
    printf_exit "Can't find a calculator app!"
  fi
  echo "$answer"
  if [ "$CALC_NOTIFY_ENABLED" = yes ]; then __notifications "Calc" "Answer is $answer"; fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
CALC_LOG_DIR="${CALC_LOG_DIR:-$HOME/.local/log/calc}"
CALC_CACHE_DIR="${CALC_CACHE_DIR:-$HOME/.cache/calc}"
CALC_CONFIG_DIR="${CALC_CONFIG_DIR:-$HOME/.config/myscripts/calc}"
CALC_CONFIG_BACKUP_DIR="${CALC_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/calc/backups}"
CALC_TEMP_DIR="${CALC_TEMP_DIR:-$HOME/.local/tmp/system_scripts/calc}"
CALC_OPTIONS_DIR="${CALC_OPTIONS_DIR:-$HOME/.local/share/myscripts/calc/options}"
CALC_TEMP_FILE="${CALC_TEMP_FILE:-$(mktemp $CALC_TEMP_DIR/XXXXXX 2>/dev/null)}"
CALC_CONFIG_FILE="${CALC_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
CALC_OUTPUT_COLOR="${CALC_OUTPUT_COLOR:-4}"
CALC_OUTPUT_COLOR_2="${CALC_OUTPUT_COLOR:-6}"
CALC_OUTPUT_COLOR_GOOD="${CALC_OUTPUT_COLOR_GOOD:-2}"
CALC_OUTPUT_COLOR_ERROR="${CALC_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
CALC_GOOD_MESSAGE="${CALC_GOOD_MESSAGE:-Everything Went OK}"
CALC_ERROR_MESSAGE="${CALC_ERROR_MESSAGE:-Well something seems to have gone wrong}"
CALC_NOTIFY_ENABLED="${CALC_NOTIFY_ENABLED:-yes}"
CALC_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CALC_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CALC_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$CALC_CONFIG_DIR/$CALC_CONFIG_FILE" ] && . "$CALC_CONFIG_DIR/$CALC_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$CALC_LOG_DIR" ] || mkdir -p "$CALC_LOG_DIR" &>/dev/null
[ -d "$CALC_TEMP_DIR" ] || mkdir -p "$CALC_TEMP_DIR" &>/dev/null
[ -d "$CALC_CACHE_DIR" ] || mkdir -p "$CALC_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$CALC_CONFIG_DIR/$CALC_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,term"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    CALC_CWD="$2"
    shift 2
    ;;
  --term)
    shift 1
    TERMINAL_APP="yes"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$CALC_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${CALC_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${CALC_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${CALC_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${CALC_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
CALC_INPUT="$*"
CALC_OUTPUT="$(echo "$CALC_INPUT" | sed '/^$/d;s/[[:blank:]]//g')"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ -n "$TERMINAL_APP" ]; then
  clear
  printf_newline "\n\n"
  __usage
  while :; do
    printf_read_input "2" "What is it you would like to solve?" "200" "CALC_INPUT" "-e"
    if [ "$CALC_INPUT" = "q" ] || [ -z "$CALC_INPUT" ]; then
      printf_newline "\n"
      break
    else
      clear
      printf_newline "\n\n\n"
      if [ "$CALC_INPUT" = "h" ] || [ "$CALC_INPUT" = "?" ]; then
        __usage
      else
        CALC_OUTPUT="$(echo "$CALC_INPUT" | sed '/^$/d;s/[[:blank:]]//g')"
        calc_app "$CALC_OUTPUT" | printf_readline "5"
      fi
      printf_newline
    fi
  done
  printf_newline
elif [ $# = 0 ]; then
  "$APPNAME" --term
else
  calc_app | printf_readline "2"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
