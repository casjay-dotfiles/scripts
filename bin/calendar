# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h,z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_available "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_available "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_available "5" "Base Options" "-$ARRAY" ',' ''
    exit $?
    ;;
  -v | --version)
    shift 1
    __version
    exit $?
    ;;
  -h | --help)
    shift 1
    __help
    exit $?
    ;;
  -c | --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    shift 1
    GEN_SCRIPT_REPLACE_CWD="$1"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$CALENDER_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${CALENDER_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${CALENDER_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${CALENDER_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${CALENDER_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash cal || exit 1 # exit 1 if not found
#am_i_online --error || exit       # exit 1 if no internet
cmd_exists yad && yad() { command yad "$*"; } || notifications "Calendar" "yad is not installed, graphical interface not available"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
LERTA=$(mktemp)
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case ${1:-$main} in
a | add)
  text_add_event 2>/dev/null
  exit 0
  ;;

ag | guia)
  gui_add_event 2>/dev/null
  ;;

c | category)
  if [ -n "$2" ]; then
    FILTER=$2
    shift
    list_by_cat 2>/dev/null
    exit 0
  else
    printf_red 'ERROR: you need to enter a category.\n' >&2
    exit 1
  fi
  ;;

category=?*)
  FILTER=${1#*=}
  if [ -n "$FILTER" ]; then
    list_by_cat 2>/dev/null
    exit 0
  else
    printf_red 'ERROR:  you need to enter a category.\n' >&2
    exit 1
  fi
  ;;

summary)
  if [ -n "$2" ]; then
    FILTER=$2
    shift
    list_by_text 2>/dev/null
    exit 0
  else
    printf_red 'ERROR: no text entered.\n' >&2
    exit 1
  fi
  ;;

summary=?*)
  FILTER=${1#*=}
  if [ -n "$FILTER" ]; then
    list_by_text 2>/dev/null
    exit 0
  else
    printf_red 'ERROR: no text entered.\n' >&2
    exit 1
  fi
  ;;

date)
  if [ -n "$2" ]; then
    DATEFILE=$2
    shift
    find_appointments 2>/dev/null
    exit 0
  else
    printf_red 'ERROR: you need to enter a date string.\n' >&2
    exit 1
  fi
  ;;

date=?*)
  DATEFILE=${1#*=}
  if [ -n "$DATEFILE" ]; then
    find_appointments 2>/dev/null
    exit 0
  else
    printf_red 'ERROR: you need to enter a date string.\n' >&2
    exit 1
  fi
  ;;

find)
  shift
  sdr=$1
  edr=$2
  date_range 2>/dev/null
  exit 0
  ;;

gui)
  tmpfile=$(mktemp)
  tagordo >$tmpfile
  gui_add_event 2>/dev/null
  ;;

*)
  list_all | printf_column "4"
  ;;
esac
unset
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
