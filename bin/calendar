CALENDER_OPTIONS_DIR="${CALENDER_OPTIONS_DIR:-$HOME/.local/share/misc/calender/options}"
CALENDER_CONFIG_BACKUP_DIR="${CALENDER_CONFIG_BACKUP_DIR:-$HOME/.local/share/misc/calender/backups}"
CALENDER_TEMP_DIR="${CALENDER_TEMP_DIR/system_scripts/calender:-$HOME/.local/tmp/system_scripts/calender}"
CALENDER_TEMP_FILE="${CALENDER_TEMP_DIR:-$HOME/.local/tmp/calender}"
CALENDER_CONFIG_FILE="${CALENDER_CONFIG_FILE:-settings.conf}"
CALENDER_GOOD_MESSAGE="${CALENDER_GOOD_MESSAGE:-Everything Went OK}"
CALENDER_ERROR_MESSAGE="${CALENDER_ERROR_MESSAGE:-Well that didn\'t work}"
CALENDER_NOTIFY_ENABLED="${CALENDER_NOTIFY_ENABLED:-yes}"
CALENDER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CALENDER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CALENDER_NOTIFY_CLIENT_ICON}"
CALENDER_EVENT_FILE="${CALENDER_EVENT_FILE:-$HOME/.local/share/ics}"
CALENDER_HOMETOWN="${CALENDER_HOMETOWN:-MYLOCATIONCITY}"
CALENDER_HOMECOUNTRY="${CALENDER_HOMECOUNTRY:-$MYLOCATIONCOUNTRY}"
CALENDER_DATEFORMAT="${CALENDER_DATEFORMAT:-%a %b %d, %Y %H:%M}"
CALENDER_TAGS=(work meeting study party)
CALENDER_TERSE="\$startdate - \$title"
#CALENDER_FULL="\$startdate - \$title\n\$desc\n\$location (\$category)"
CALENDER_MESSAGE="$(date +"Today is: %A %B %d, %Y and the time is: %H:%M")"
