# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
CALENDAR_LOG_DIR="${CALENDAR_LOG_DIR:-$HOME/.local/log/calendar}"
CALENDAR_CACHE_DIR="${CALENDAR_CACHE_DIR:-$HOME/.cache/calendar}"
CALENDAR_CONFIG_DIR="${CALENDAR_CONFIG_DIR:-$HOME/.config/myscripts/calendar}"
CALENDAR_CONFIG_BACKUP_DIR="${CALENDAR_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/calendar/backups}"
CALENDAR_TEMP_DIR="${CALENDAR_TEMP_DIR:-$HOME/.local/tmp/system_scripts/calendar}"
CALENDAR_OPTIONS_DIR="${CALENDAR_OPTIONS_DIR:-$HOME/.local/share/myscripts/calendar/options}"
CALENDAR_TEMP_FILE="${CALENDAR_TEMP_FILE:-$(mktemp $CALENDAR_TEMP_DIR/XXXXXX 2>/dev/null)}"
CALENDAR_CONFIG_FILE="${CALENDAR_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
CALENDAR_OUTPUT_COLOR="${CALENDAR_OUTPUT_COLOR:-4}"
CALENDAR_OUTPUT_COLOR_2="${CALENDAR_OUTPUT_COLOR:-6}"
CALENDAR_OUTPUT_COLOR_GOOD="${CALENDAR_OUTPUT_COLOR_GOOD:-2}"
CALENDAR_OUTPUT_COLOR_ERROR="${CALENDAR_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
CALENDAR_GOOD_MESSAGE="${CALENDAR_GOOD_MESSAGE:-Everything Went OK}"
CALENDAR_ERROR_MESSAGE="${CALENDAR_ERROR_MESSAGE:-Well something seems to have gone wrong}"
CALENDAR_NOTIFY_ENABLED="${CALENDAR_NOTIFY_ENABLED:-yes}"
CALENDAR_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CALENDAR_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CALENDAR_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
CALENDER_EVENT_FILE="${CALENDER_EVENT_FILE:-$HOME/.local/share/ics}"
CALENDER_HOMETOWN="${CALENDER_HOMETOWN:-MYLOCATIONCITY}"
CALENDER_HOMECOUNTRY="${CALENDER_HOMECOUNTRY:-$MYLOCATIONCOUNTRY}"
CALENDER_DATEFORMAT="${CALENDER_DATEFORMAT:-%a %b %d, %Y %H:%M}"
CALENDER_TAGS=${CALENDER_TAGS:-(work meeting study party)}
CALENDER_TERSE="\$startdate - \$title"
#CALENDER_FULL="\$startdate - \$title\n\$desc\n\$location (\$category)"
CALENDER_MESSAGE="${CALENDER_MESSAGE:-$(date +"Today is: %A %B %d, %Y and the time is: %H:%M")}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$CALENDAR_CONFIG_DIR/$CALENDAR_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$CALENDAR_CONFIG_DIR/$CALENDAR_CONFIG_FILE" ] && . "$CALENDAR_CONFIG_DIR/$CALENDAR_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$CALENDAR_LOG_DIR" ] || mkdir -p "$CALENDAR_LOG_DIR" &>/dev/null
[ -d "$CALENDAR_TEMP_DIR" ] || mkdir -p "$CALENDAR_TEMP_DIR" &>/dev/null
[ -d "$CALENDAR_CACHE_DIR" ] || mkdir -p "$CALENDAR_CACHE_DIR" &>/dev/null
[ -f "$CALENDAR_TEMP_FILE" ] || touch "$CALENDAR_TEMP_FILE" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap
trap 'exitCode=${exitCode:-$?};[ -n "$CALENDAR_TEMP_FILE" ] && [ -f "$CALENDAR_TEMP_FILE" ] && rm -Rf "$CALENDAR_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$CALENDAR_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${CALENDAR_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${CALENDAR_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${CALENDAR_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${CALENDAR_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    CALENDAR_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
