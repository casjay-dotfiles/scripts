# Send all output to /dev/null
__devnull() {
  tee &>/dev/null && CAPTIVE_AUTH_EXIT_STATUS=0 || CAPTIVE_AUTH_EXIT_STATUS=1
  return ${CAPTIVE_AUTH_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -'
# Send errors to /dev/null
__devnull2() {
  [ -n "$1" ] && local cmd="$1" && shift 1 || return 1
  eval $cmd "$*" 2>/dev/null && CAPTIVE_AUTH_EXIT_STATUS=0 || CAPTIVE_AUTH_EXIT_STATUS=1
  return ${CAPTIVE_AUTH_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -'
# See if the executable exists
__cmd_exists() {
  CAPTIVE_AUTH_EXIT_STATUS=0
  [ -n "$1" ] && local CAPTIVE_AUTH_EXIT_STATUS="" || return 0
  for cmd in "$@"; do
    builtin command -v "$cmd" &>/dev/null && CAPTIVE_AUTH_EXIT_STATUS+=$(($CAPTIVE_AUTH_EXIT_STATUS + 0)) || CAPTIVE_AUTH_EXIT_STATUS+=$(($CAPTIVE_AUTH_EXIT_STATUS + 1))
  done
  [ $CAPTIVE_AUTH_EXIT_STATUS -eq 0 ] || CAPTIVE_AUTH_EXIT_STATUS=3
  return ${CAPTIVE_AUTH_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__sleep() { read -r -t "${1:-1}" _ </dev/null; :; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for a valid internet connection
__am_i_online() {
  local CAPTIVE_AUTH_EXIT_STATUS=0
  curl -q -LSsfI --max-time 1 --retry 0 "${1:-https://1.1.1.1}" 2>&1 | grep -qi 'server:.*cloudflare' || CAPTIVE_AUTH_EXIT_STATUS=4
  return ${CAPTIVE_AUTH_EXIT_STATUS:-0}
}
