# User defined functions
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check internet connectivity
# Returns: 0=online, 1=captive portal, 2=no connectivity
__cauth_check() {
  local state http_code url_effective result

  if __cmd_exists nmcli; then
    state=$(nmcli networking connectivity check 2>/dev/null | tr -d '[:space:]')
    case "$state" in
      full) return 0 ;;
      portal|limited) return 1 ;;
      none) return 2 ;;
    esac
  fi

  result=$(curl -s -o /dev/null \
    -w "%{http_code}|%{url_effective}" \
    -L --max-time 8 --connect-timeout 4 \
    "${CAPTIVE_AUTH_CHECK_URL:-http://connectivitycheck.gstatic.com/generate_204}" 2>/dev/null)
  http_code="${result%%|*}"
  url_effective="${result##*|}"

  case "$http_code" in
    204) return 0 ;;
    000) return 2 ;;
    *)
      [[ "$url_effective" == *"connectivitycheck.gstatic.com"* ]] && return 2
      return 1
      ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Get the captive portal URL by probing known check endpoints
__cauth_get_portal_url() {
  local probe_urls=(
    "http://connectivitycheck.gstatic.com/generate_204"
    "http://detectportal.firefox.com/success.txt"
    "http://captive.apple.com/captive-auth-detect.html"
    "http://www.msftconnecttest.com/connecttest.txt"
  )
  local result http_code url_effective url

  for url in "${probe_urls[@]}"; do
    result=$(curl -s -o /dev/null \
      -w "%{http_code}|%{url_effective}" \
      -L --max-time 8 --connect-timeout 4 \
      "$url" 2>/dev/null)
    http_code="${result%%|*}"
    url_effective="${result##*|}"

    [ "$http_code" = "000" ] && continue
    # If we ended up somewhere other than the probe URL, that's the portal
    if [[ "$url_effective" != "$url"* ]]; then
      printf '%s' "$url_effective"
      return 0
    fi
  done

  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Identify portal vendor from hostname
__cauth_detect_vendor() {
  local host
  host=$(printf '%s' "$1" | grep -oE 'https?://[^/]+' | sed 's|https\?://||;s|:[0-9]*$||')
  case "$host" in
    *.arubanetworks.com) printf 'aruba' ;;
    *.meraki.com|*.merakioffline.com) printf 'meraki' ;;
    *.fortinet.com|*.fortigate.com) printf 'fortinet' ;;
    # on-prem FortiGate portals land on firewall IPs; detect by path instead
    *) printf 'unknown' ;;
  esac
}

# Extract a named hidden-input value from collapsed HTML
__cauth_field() {
  local html="$1" name="$2"
  printf '%s' "$html" \
    | grep -oiE "<input[^>]+>" \
    | grep -iE "name=['\"]?${name}['\"]?" \
    | grep -oiE "value=['\"][^'\"]*['\"]" \
    | sed "s/value=//;s/['\"]//g" \
    | head -1
}

# Aruba Central cloud guest portal
# Extracts the capture= token from the URL and POSTs the accept form.
# No HTML fetch required — all needed data is in the redirect URL.
__cauth_auth_aruba() {
  local portal_url="$1" cookie_file="$2" ua="$3"
  local capture_token login_url http_code

  capture_token=$(printf '%s' "$portal_url" | grep -oE '[?&]capture=[^&]+' | sed 's/[?&]capture=//')
  [ -z "$capture_token" ] && return 1

  login_url=$(printf '%s' "$portal_url" | sed 's/[?].*//')
  printf_cyan "Aruba portal — submitting accept to: $login_url"

  http_code=$(curl -s -o /dev/null -w "%{http_code}" -L \
    --max-time 15 --connect-timeout 5 \
    -c "$cookie_file" -b "$cookie_file" -A "$ua" \
    -e "$portal_url" \
    --data-urlencode "buttonClicked=4" \
    --data-urlencode "capture=${capture_token}" \
    --data-urlencode "redirect_url=" \
    --data-urlencode "err_flag=0" \
    --data-urlencode "err_msg=" \
    --data-urlencode "info_flag=0" \
    --data-urlencode "info_msg=" \
    "$login_url" 2>/dev/null)

  [ "${http_code:-000}" != "000" ]
}

# Cisco Meraki splash page
# Fetches the page to collect node_id/gateway_id then POSTs to /splash/grant_access.
__cauth_auth_meraki() {
  local portal_url="$1" cookie_file="$2" ua="$3"
  local tmphtml html_flat base_url node_id gateway_id http_code
  local -a curl_data=()

  tmphtml="$CAPTIVE_AUTH_TEMP_DIR/meraki_$$.html"
  curl -s -L -o "$tmphtml" \
    --max-time 15 --connect-timeout 5 \
    -c "$cookie_file" -A "$ua" \
    "$portal_url" 2>/dev/null || { rm -f "$tmphtml"; return 1; }
  [ -s "$tmphtml" ] || { rm -f "$tmphtml"; return 1; }
  html_flat=$(tr '\n' ' ' < "$tmphtml")
  rm -f "$tmphtml"

  base_url=$(printf '%s' "$portal_url" | grep -oE '^https?://[^/]+')
  node_id=$(__cauth_field "$html_flat" "node_id")
  gateway_id=$(__cauth_field "$html_flat" "gateway_id")

  curl_data+=(--data-urlencode "commit=Accept")
  [ -n "$node_id" ]    && curl_data+=(--data-urlencode "node_id=${node_id}")
  [ -n "$gateway_id" ] && curl_data+=(--data-urlencode "gateway_id=${gateway_id}")

  printf_cyan "Meraki splash — submitting accept to: ${base_url}/splash/grant_access"

  http_code=$(curl -s -o /dev/null -w "%{http_code}" -L \
    --max-time 15 --connect-timeout 5 \
    -c "$cookie_file" -b "$cookie_file" -A "$ua" \
    -e "$portal_url" \
    "${curl_data[@]}" \
    "${base_url}/splash/grant_access" 2>/dev/null)

  [ "${http_code:-000}" != "000" ]
}

# Fortinet FortiGate captive portal
# Extracts the magic token from the page and POSTs to /fgtauth.
# Also handles on-prem portals detected by /fgtauth path rather than hostname.
__cauth_auth_fortinet() {
  local portal_url="$1" cookie_file="$2" ua="$3"
  local tmphtml html_flat base_url magic http_code

  tmphtml="$CAPTIVE_AUTH_TEMP_DIR/forti_$$.html"
  curl -s -L -o "$tmphtml" \
    --max-time 15 --connect-timeout 5 \
    -c "$cookie_file" -A "$ua" \
    "$portal_url" 2>/dev/null || { rm -f "$tmphtml"; return 1; }
  [ -s "$tmphtml" ] || { rm -f "$tmphtml"; return 1; }
  html_flat=$(tr '\n' ' ' < "$tmphtml")
  rm -f "$tmphtml"

  magic=$(__cauth_field "$html_flat" "magic")
  [ -z "$magic" ] && magic=$(printf '%s' "$portal_url" | grep -oE '[?&]magic=[^&]+' | sed 's/[?&]magic=//')
  [ -z "$magic" ] && return 1

  base_url=$(printf '%s' "$portal_url" | grep -oE '^https?://[^/]+')
  printf_cyan "FortiGate portal — submitting accept to: ${base_url}/fgtauth"

  http_code=$(curl -s -o /dev/null -w "%{http_code}" -L \
    --max-time 15 --connect-timeout 5 \
    -c "$cookie_file" -b "$cookie_file" -A "$ua" \
    -e "$portal_url" \
    --data-urlencode "magic=${magic}" \
    --data-urlencode "username=" \
    --data-urlencode "password=" \
    "${base_url}/fgtauth" 2>/dev/null)

  [ "${http_code:-000}" != "000" ]
}

# JS-rendered portal fallback
# Scans raw HTML for meta-refresh and window.location redirects that
# a headless curl would miss, and follows them.
__cauth_auth_js_fallback() {
  local portal_url="$1" html_flat="$2" cookie_file="$3" ua="$4"
  local target http_code

  # meta http-equiv="refresh" content="0;url=..."
  target=$(printf '%s' "$html_flat" \
    | grep -oiE '<meta[^>]+http-equiv=["\047]?refresh["\047]?[^>]+>' \
    | grep -oiE 'url=[^"'"'"' >]+' \
    | sed 's/url=//I;s/["\047]//g' \
    | head -1)

  if [ -z "$target" ]; then
    # window.location[.href] = "..."
    target=$(printf '%s' "$html_flat" \
      | grep -oiE 'window\.location(\.href)?\s*=\s*["'"'"'][^"'"'"']+["'"'"']' \
      | grep -oiE '"[^"]+"|'"'"'[^'"'"']+'"'"'' \
      | tr -d '"'"'" \
      | grep '^http' \
      | head -1)
  fi

  [ -z "$target" ] && return 1

  printf_cyan "JS redirect detected — following to: $target"
  http_code=$(curl -s -o /dev/null -w "%{http_code}" -L \
    --max-time 15 --connect-timeout 5 \
    -c "$cookie_file" -b "$cookie_file" -A "$ua" \
    -e "$portal_url" \
    "$target" 2>/dev/null)

  [ "${http_code:-000}" != "000" ]
}

# Fetch the captive portal page, parse the first form, and submit it.
# Order: vendor-specific handler → JS redirect fallback → generic form parse.
__cauth_auto_auth() {
  local portal_url="$1"
  local cookie_file="$CAPTIVE_AUTH_TEMP_DIR/portal_cookies.txt"
  local ua="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
  local tmphtml="$CAPTIVE_AUTH_TEMP_DIR/portal_$$.html"
  local html_flat form_tag action method base_url http_code vendor

  vendor=$(__cauth_detect_vendor "$portal_url")

  # Vendor-specific handlers that know the submission protocol
  case "$vendor" in
    aruba)
      __cauth_auth_aruba "$portal_url" "$cookie_file" "$ua" && return 0
      ;;
    meraki)
      __cauth_auth_meraki "$portal_url" "$cookie_file" "$ua" && return 0
      ;;
    fortinet)
      __cauth_auth_fortinet "$portal_url" "$cookie_file" "$ua" && return 0
      ;;
  esac

  # Also detect on-prem FortiGate by path (/fgtauth) regardless of hostname
  if [[ "$portal_url" == */fgtauth* ]]; then
    __cauth_auth_fortinet "$portal_url" "$cookie_file" "$ua" && return 0
  fi

  # Fetch HTML for fallback paths
  curl -s -L -o "$tmphtml" \
    --max-time 15 --connect-timeout 5 \
    -c "$cookie_file" -A "$ua" \
    "$portal_url" 2>/dev/null || { rm -f "$tmphtml"; return 1; }

  [ -s "$tmphtml" ] || { rm -f "$tmphtml"; return 1; }
  html_flat=$(tr '\n' ' ' < "$tmphtml")
  rm -f "$tmphtml"

  # JS redirect fallback (meta-refresh, window.location)
  __cauth_auth_js_fallback "$portal_url" "$html_flat" "$cookie_file" "$ua" && return 0

  # Generic form parse
  base_url=$(printf '%s' "$portal_url" | grep -oE '^https?://[^/]+')

  form_tag=$(printf '%s' "$html_flat" | grep -oiE '<form[^>]+>' | head -1)
  action=$(printf '%s' "$form_tag" | grep -oiE 'action="[^"]*"' | sed 's/action=//;s/"//g')
  [ -z "$action" ] && action=$(printf '%s' "$form_tag" | grep -oiE "action='[^']*'" | sed "s/action=//;s/'//g")
  method=$(printf '%s' "$form_tag" | grep -oiE 'method="[^"]*"' | sed 's/method=//;s/"//g' | tr '[:upper:]' '[:lower:]')
  [ -z "$method" ] && method=$(printf '%s' "$form_tag" | grep -oiE "method='[^']*'" | sed "s/method=//;s/'//g" | tr '[:upper:]' '[:lower:]')
  method="${method:-post}"

  # Resolve relative form action URL
  if [ -z "$action" ]; then
    action="$portal_url"
  elif [[ "$action" == //* ]]; then
    action="${portal_url%%://*}:${action}"
  elif [[ "$action" == /* ]]; then
    action="${base_url}${action}"
  elif [[ "$action" != http* ]]; then
    action="${portal_url%/*}/${action}"
  fi

  # Collect hidden inputs and submit button values into curl data args
  local -a curl_data=()
  while IFS= read -r input; do
    [ -z "$input" ] && continue
    local iname ivalue
    iname=$(printf '%s' "$input" | grep -oiE 'name="[^"]*"' | sed 's/name=//;s/"//g')
    [ -z "$iname" ] && iname=$(printf '%s' "$input" | grep -oiE "name='[^']*'" | sed "s/name=//;s/'//g")
    ivalue=$(printf '%s' "$input" | grep -oiE 'value="[^"]*"' | sed 's/value=//;s/"//g')
    [ -z "$ivalue" ] && ivalue=$(printf '%s' "$input" | grep -oiE "value='[^']*'" | sed "s/value=//;s/'//g")
    [ -n "$iname" ] && curl_data+=("--data-urlencode" "${iname}=${ivalue}")
  done < <(printf '%s' "$html_flat" | grep -oiE '<input[^>]+>' | grep -iE 'type=.?(hidden|submit)')

  printf_cyan "Submitting to: $action"

  if [ "$method" = "get" ]; then
    http_code=$(curl -s -o /dev/null -w "%{http_code}" -L -G \
      --max-time 15 --connect-timeout 5 \
      -c "$cookie_file" -b "$cookie_file" -A "$ua" \
      -e "$portal_url" \
      "${curl_data[@]}" "$action" 2>/dev/null)
  else
    http_code=$(curl -s -o /dev/null -w "%{http_code}" -L \
      --max-time 15 --connect-timeout 5 \
      -c "$cookie_file" -b "$cookie_file" -A "$ua" \
      -e "$portal_url" \
      "${curl_data[@]}" "$action" 2>/dev/null)
  fi

  [ "${http_code:-000}" != "000" ]
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Open the portal URL in the first available browser
__cauth_open_browser() {
  local url="$1"
  local -a browsers=(xdg-open firefox chromium-browser chromium google-chrome-stable google-chrome w3m lynx)
  local b
  for b in "${browsers[@]}"; do
    if __cmd_exists "$b"; then
      "$b" "$url" &>/dev/null &
      disown
      return 0
    fi
  done
  printf_red "No browser found"
  printf_cyan "Open manually: $url"
  return 1
}
