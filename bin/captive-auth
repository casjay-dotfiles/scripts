# create the config file
__gen_config() {
  local NOTIFY_CLIENT_NAME="$APPNAME"
  if [ "$INIT_CONFIG" != "TRUE" ]; then
    printf_blue "Generating the config file in"
    printf_cyan "$CAPTIVE_AUTH_CONFIG_DIR/$CAPTIVE_AUTH_CONFIG_FILE"
  fi
  [ -d "$CAPTIVE_AUTH_CONFIG_DIR" ] || mkdir -p "$CAPTIVE_AUTH_CONFIG_DIR"
  [ -d "$CAPTIVE_AUTH_CONFIG_BACKUP_DIR" ] || mkdir -p "$CAPTIVE_AUTH_CONFIG_BACKUP_DIR"
  [ -f "$CAPTIVE_AUTH_CONFIG_DIR/$CAPTIVE_AUTH_CONFIG_FILE" ] &&
    cp -Rf "$CAPTIVE_AUTH_CONFIG_DIR/$CAPTIVE_AUTH_CONFIG_FILE" "$CAPTIVE_AUTH_CONFIG_BACKUP_DIR/$CAPTIVE_AUTH_CONFIG_FILE.$$"
  cat <<EOF >"$CAPTIVE_AUTH_CONFIG_DIR/$CAPTIVE_AUTH_CONFIG_FILE"
# Settings for captive-auth

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
CAPTIVE_AUTH_OUTPUT_COLOR_1="${CAPTIVE_AUTH_OUTPUT_COLOR_1:-}"
CAPTIVE_AUTH_OUTPUT_COLOR_2="${CAPTIVE_AUTH_OUTPUT_COLOR_2:-}"
CAPTIVE_AUTH_OUTPUT_COLOR_GOOD="${CAPTIVE_AUTH_OUTPUT_COLOR_GOOD:-}"
CAPTIVE_AUTH_OUTPUT_COLOR_ERROR="${CAPTIVE_AUTH_OUTPUT_COLOR_ERROR:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
CAPTIVE_AUTH_SYSTEM_NOTIFY_ENABLED="${CAPTIVE_AUTH_SYSTEM_NOTIFY_ENABLED:-}"
CAPTIVE_AUTH_GOOD_NAME="${CAPTIVE_AUTH_GOOD_NAME:-}"
CAPTIVE_AUTH_ERROR_NAME="${CAPTIVE_AUTH_ERROR_NAME:-}"
CAPTIVE_AUTH_GOOD_MESSAGE="${CAPTIVE_AUTH_GOOD_MESSAGE:-}"
CAPTIVE_AUTH_ERROR_MESSAGE="${CAPTIVE_AUTH_ERROR_MESSAGE:-}"
CAPTIVE_AUTH_NOTIFY_CLIENT_NAME="${CAPTIVE_AUTH_NOTIFY_CLIENT_NAME:-}"
CAPTIVE_AUTH_NOTIFY_CLIENT_ICON="${CAPTIVE_AUTH_NOTIFY_CLIENT_ICON:-}"
CAPTIVE_AUTH_NOTIFY_CLIENT_URGENCY="${CAPTIVE_AUTH_NOTIFY_CLIENT_URGENCY:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Captive Portal Settings
CAPTIVE_AUTH_CHECK_URL="${CAPTIVE_AUTH_CHECK_URL:-http://connectivitycheck.gstatic.com/generate_204}"
CAPTIVE_AUTH_AUTO_AUTH="${CAPTIVE_AUTH_AUTO_AUTH:-yes}"
CAPTIVE_AUTH_OPEN_BROWSER="${CAPTIVE_AUTH_OPEN_BROWSER:-yes}"
CAPTIVE_AUTH_RETRY_WAIT="${CAPTIVE_AUTH_RETRY_WAIT:-2}"
CAPTIVE_AUTH_MAX_RETRIES="${CAPTIVE_AUTH_MAX_RETRIES:-3}"

EOF
  if builtin type -t __gen_config_local | grep -q 'function'; then __gen_config_local; fi
  if [ -f "$CAPTIVE_AUTH_CONFIG_DIR/$CAPTIVE_AUTH_CONFIG_FILE" ]; then
    [ "$INIT_CONFIG" = "TRUE" ] || printf_green "Your config file for $APPNAME has been created"
    . "$CAPTIVE_AUTH_CONFIG_DIR/$CAPTIVE_AUTH_CONFIG_FILE"
    CAPTIVE_AUTH_EXIT_STATUS=0
  else
    printf_red "Failed to create the config file"
    CAPTIVE_AUTH_EXIT_STATUS=1
  fi
  return ${CAPTIVE_AUTH_EXIT_STATUS:-0}
}
