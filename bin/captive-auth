    CAPTIVE_AUTH_EXIT_STATUS=0
    ;;
  1)
    printf_yellow "Captive portal detected"
    PORTAL_URL=$(__cauth_get_portal_url)

    if [ -z "$PORTAL_URL" ]; then
      printf_red "Could not determine portal URL"
      CAPTIVE_AUTH_EXIT_STATUS=1
    else
      printf_cyan "Portal: $PORTAL_URL"

      if [ "$CAPTIVE_AUTH_AUTO_AUTH" = "yes" ]; then
        printf_cyan "Attempting automatic authentication..."
        __cauth_auto_auth "$PORTAL_URL"
        __sleep "${CAPTIVE_AUTH_RETRY_WAIT:-2}"

        __cauth_check
        if [ $? -eq 0 ]; then
          printf_green "Authenticated successfully"
          CAPTIVE_AUTH_EXIT_STATUS=0
        else
          printf_yellow "Auto-auth did not establish a connection"
          if [ "$CAPTIVE_AUTH_OPEN_BROWSER" = "yes" ]; then
            printf_cyan "Opening portal in browser..."
            __cauth_open_browser "$PORTAL_URL"
          else
            printf_cyan "Portal URL: $PORTAL_URL"
          fi
          CAPTIVE_AUTH_EXIT_STATUS=1
        fi
      else
        if [ "$CAPTIVE_AUTH_OPEN_BROWSER" = "yes" ]; then
          printf_cyan "Opening portal in browser..."
          __cauth_open_browser "$PORTAL_URL"
        else
          printf_cyan "Portal URL: $PORTAL_URL"
        fi
        CAPTIVE_AUTH_EXIT_STATUS=1
      fi
    fi
    ;;
  2)
    printf_red "No network connectivity"
    printf_yellow "Check that you are connected to a WiFi network"
    CAPTIVE_AUTH_EXIT_STATUS=2
    ;;
esac
