#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : check-for-updates --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : check-for-updates
# @Description   : check for package updates
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE"
  [ -d "$CHECK_FOR_UPDATES_CONFIG_DIR" ] || mkdir -p "$CHECK_FOR_UPDATES_CONFIG_DIR"
  [ -d "$CHECK_FOR_UPDATES_CONFIG_BACKUP_DIR" ] || mkdir -p "$CHECK_FOR_UPDATES_CONFIG_BACKUP_DIR"
  [ -f "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE" ] &&
    cp -Rf "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE" "$CHECK_FOR_UPDATES_CONFIG_BACKUP_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE.$$"
  cat <<EOF >"$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE"
# Settings for check-for-updates
CHECK_FOR_UPDATES_ENABLE_NOTIFICATIONS="${CHECK_FOR_UPDATES_ENABLE_NOTIFICATIONS:-yes}"
CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG="${CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG:-yes}"
CHECK_FOR_UPDATES_SUDO_ASKPASS_APPNAME="${SUDO_ASKPASS:-/usr/local/bin/ask_for_password}"
__ask_me_to_update() { ask_yes_no_question "Would you like to update" "pkmgr silent upgrade"; }

# Notification settings
CHECK_FOR_UPDATES_GOOD_MESSAGE="${CHECK_FOR_UPDATES_GOOD_MESSAGE:-Everything Went OK}"
CHECK_FOR_UPDATES_ERROR_MESSAGE="${CHECK_FOR_UPDATES_ERROR_MESSAGE:-Well something seems to have gone wrong}"
CHECK_FOR_UPDATES_NOTIFY_ENABLED="${CHECK_FOR_UPDATES_NOTIFY_ENABLED:-yes}"
CHECK_FOR_UPDATES_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CHECK_FOR_UPDATES_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CHECK_FOR_UPDATES_NOTIFY_CLIENT_ICON}"

# Colorization settings
CHECK_FOR_UPDATES_OUTPUT_COLOR="${CHECK_FOR_UPDATES_OUTPUT_COLOR:-5}"
CHECK_FOR_UPDATES_OUTPUT_COLOR_GOOD="${CHECK_FOR_UPDATES_OUTPUT_COLOR_GOOD:-2}"
CHECK_FOR_UPDATES_OUTPUT_COLOR_ERROR="${CHECK_FOR_UPDATES_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__version() { app_version; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__ask_me_to_update() {
  ask_for_password && ask_yes_no_question "${1:-Would you like to update?} " "pkmgr silent upgrade" || exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
CHECK_FOR_UPDATES_LOG_DIR="${CHECK_FOR_UPDATES_LOG_DIR:-$HOME/.local/log/check-for-updates}"
CHECK_FOR_UPDATES_CACHE_DIR="${CHECK_FOR_UPDATES_CACHE_DIR:-$HOME/.cache/check-for-updates}"
CHECK_FOR_UPDATES_CONFIG_DIR="${CHECK_FOR_UPDATES_CONFIG_DIR:-$HOME/.config/myscripts/check-for-updates}"
CHECK_FOR_UPDATES_CONFIG_BACKUP_DIR="${CHECK_FOR_UPDATES_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/check-for-updates/backups}"
CHECK_FOR_UPDATES_TEMP_DIR="${CHECK_FOR_UPDATES_TEMP_DIR:-$HOME/.local/tmp/system_scripts/check-for-updates}"
CHECK_FOR_UPDATES_OPTIONS_DIR="${CHECK_FOR_UPDATES_OPTIONS_DIR:-$HOME/.local/share/myscripts/check-for-updates/options}"
CHECK_FOR_UPDATES_CONFIG_FILE="${CHECK_FOR_UPDATES_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
CHECK_FOR_UPDATES_OUTPUT_COLOR="${CHECK_FOR_UPDATES_OUTPUT_COLOR:-4}"
CHECK_FOR_UPDATES_OUTPUT_COLOR_2="${CHECK_FOR_UPDATES_OUTPUT_COLOR:-6}"
CHECK_FOR_UPDATES_OUTPUT_COLOR_GOOD="${CHECK_FOR_UPDATES_OUTPUT_COLOR_GOOD:-2}"
CHECK_FOR_UPDATES_OUTPUT_COLOR_ERROR="${CHECK_FOR_UPDATES_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
CHECK_FOR_UPDATES_GOOD_MESSAGE="${CHECK_FOR_UPDATES_GOOD_MESSAGE:-Everything Went OK}"
CHECK_FOR_UPDATES_ERROR_MESSAGE="${CHECK_FOR_UPDATES_ERROR_MESSAGE:-Well something seems to have gone wrong}"
CHECK_FOR_UPDATES_NOTIFY_ENABLED="${CHECK_FOR_UPDATES_NOTIFY_ENABLED:-yes}"
CHECK_FOR_UPDATES_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CHECK_FOR_UPDATES_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CHECK_FOR_UPDATES_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
CHECK_FOR_UPDATES_ENABLE_NOTIFICATIONS="${CHECK_FOR_UPDATES_ENABLE_NOTIFICATIONS:-yes}"
CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG="${CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG:-yes}"
CHECK_FOR_UPDATES_SUDO_ASKPASS_APPNAME="${SUDO_ASKPASS:-/usr/local/bin/ask_for_password}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE" ] && . "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$CHECK_FOR_UPDATES_LOG_DIR" ] || mkdir -p "$CHECK_FOR_UPDATES_LOG_DIR" &>/dev/null
[ -d "$CHECK_FOR_UPDATES_TEMP_DIR" ] || mkdir -p "$CHECK_FOR_UPDATES_TEMP_DIR" &>/dev/null
[ -d "$CHECK_FOR_UPDATES_CACHE_DIR" ] || mkdir -p "$CHECK_FOR_UPDATES_CACHE_DIR" &>/dev/null
CHECK_FOR_UPDATES_TEMP_FILE="${CHECK_FOR_UPDATES_TEMP_FILE:-$(mktemp $CHECK_FOR_UPDATES_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$CHECK_FOR_UPDATES_TEMP_FILE" ] && [ -f "$CHECK_FOR_UPDATES_TEMP_FILE" ] && rm -Rf "$CHECK_FOR_UPDATES_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$CHECK_FOR_UPDATES_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${CHECK_FOR_UPDATES_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${CHECK_FOR_UPDATES_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${CHECK_FOR_UPDATES_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${CHECK_FOR_UPDATES_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,force,ask,show"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    CHECK_FOR_UPDATES_CWD="$2"
    shift 2
    ;;
  --force)
    __rm_rf "$CHECK_FOR_UPDATES_CACHE_DIR/update_check"
    ;;
  --ask)
    shift 1
    SETOPTS="ask"
    ;;
  --show)
    shift 1
    SETOPTS="show"
    ;;
  --notify)
    shift 1
    CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG="yes"
    CHECK_FOR_UPDATES_ENABLE_NOTIFICATIONS="yes"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1      # exit 1 if not found
am_i_online --error || { echo 0 && exit 1; } # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
# Use pkmgr if available otherwise use package manager
if builtin type -P pkmgr &>/dev/null; then
  updates=$(pkmgr check 2>/dev/null)
else
  # Brew update check
  if [ -n "$(builtin type -P brew)" ]; then
    if ! updates=$(brew outdated 2>/dev/null | grep -v Security | wc -l); then
      updates=0
    fi

  # Arch update check
  elif [ -n "$(builtin type -P pacman)" ]; then
    if ! updates_arch=$(pacman -Qu 2>/dev/null | wc -l); then
      updates_arch=0
    fi
    # yay doesn't do sudo
    if [ -n "$(builtin type -P yay)" ]; then
      if ! updates_aur=$(yay -Qum 2>/dev/null | wc -l); then
        updates_aur=0
      fi
    fi
    [ -n "$updates_arch" ] && updates=$(("$updates_arch" + "$updates_aur")) || updates="$updates_arch"

  # Debian update check
  elif [ -n "$(builtin type -P apt)" ]; then
    if ! updates=$(apt -q -y --ignore-hold --allow-change-held-packages --allow-unauthenticated -s dist-upgrade 2>/dev/null | grep '^Inst' | wc -l); then
      updates=0
    fi

    # Fedora update check
  elif [ -n "$(builtin type -P dnf)" ]; then
    if ! updates=$(dnf -q check-update 2>/dev/null | grep -v Security | wc -l); then
      updates=0
    fi

    # CentOS update check
  elif [ -n "$(builtin type -P yum)" ]; then
    if ! updates=$(yum -q check-update 2>/dev/null | grep -v Security | wc -l); then
      updates=0
    fi
  fi
fi
[[ -n "$updates" ]] || updates=0
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
case $SETOPTS in
ask)
  shift 1
  __ask_me_to_update "Would you like to update?"
  ;;

show)
  shift 1
  echo "$updates"
  ;;

*)
  if [[ $updates -gt 0 ]]; then
    echo "$updates"
  else
    echo 0
    __rm_rf "$CHECK_FOR_UPDATES_CACHE_DIR/update_check"
  fi
  if [[ $updates -gt 0 ]]; then
    if [ "$CHECK_FOR_UPDATES_ENABLE_NOTIFICATIONS" = "yes" ]; then
      if [ ! -f "$CHECK_FOR_UPDATES_CACHE_DIR/update_check" ]; then
        echo "$updates" >"$CHECK_FOR_UPDATES_CACHE_DIR/update_check"
        export CHECK_FOR_UPDATES_NOTIFY_GOOD_MESSAGE
        export NOTIFY_ERROR_MESSAGE="$CHECK_FOR_UPDATES_NOTIFY_ERROR_MESSAGE"
        export NOTIFY_GOOD_MESSAGE="$CHECK_FOR_UPDATES_NOTIFY_GOOD_MESSAGE"
        export NOTIFY_CLIENT_NAME="Update Check"
        notifications "System Updates:" "You have $updates update[s] available"
      fi
    fi
    if [ "$CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG" = "yes" ]; then
      [[ "$SETOPTS" = "ask" ]] || __ask_me_to_update
    fi
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
