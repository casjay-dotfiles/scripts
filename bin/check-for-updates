#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202103230834-git"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#set opts

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202103230834-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : check-for-updates --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Tuesday, Mar 23, 2021 08:34 EDT
# @File          : check-for-updates
# @Description   : check for package updates
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# helper functions - See github.com/dfmgr/misc/bin/functions.bash
__version() { app_version; }
__ask_me_to_update() { ask_yes_no_question "Would you like to update" "pkmgr silent upgrade"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__help() {
  app_help "4" "Usage: check-for-updates" \
    "-c, --config           -  create config file" \
    "-v, --version          -  display version" \
    "-h, --help             -  display help" \
    "--options              -  used by completions"
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE"
  [ -d "$CHECK_FOR_UPDATES_CONFIG_DIR" ] || mkdir -p "$CHECK_FOR_UPDATES_CONFIG_DIR"
  [ -d "$CHECK_FOR_UPDATES_CONFIG_BACKUP_DIR" ] || mkdir -p "$CHECK_FOR_UPDATES_CONFIG_BACKUP_DIR"
  [ -f "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE" ] &&
    cp -Rf "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE" "$CHECK_FOR_UPDATES_CONFIG_BACKUP_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE.$$"
  cat <<EOF >"$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE"
# Settings for check-for-updates
CHECK_FOR_UPDATES_CACHEDIR="\${CACHE_DIR:-$HOME/.cache/check_all_updates_sh}"
CHECK_FOR_UPDATES_ENABLE_NOTIFICATIONS="\${CHECK_FOR_UPDATES_ENABLE_NOTIFICATIONS:-yes}"
CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG="\${CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG:-yes}"
CHECK_FOR_UPDATES_SUDO_ASKPASS_APPNAME="\${SUDO_ASKPASS:-/usr/local/bin/ask_for_password}"
__ask_me_to_update() { ask_yes_no_question "Would you like to update" "pkmgr silent upgrade"; }

EOF
  if [ -f "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE" ]; then
    printf_green "Your config file for check-for-updates has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Defaults
exitCode=
CHECK_FOR_UPDATES_NOTIFY_GOOD_MESSAGE="${CHECK_FOR_UPDATES_NOTIFY_GOOD_MESSAGE:-Update Successfull}"
CHECK_FOR_UPDATES_NOTIFY_ERROR_MESSAGE="${CHECK_FOR_UPDATES_NOTIFY_ERROR_MESSAGE:-Failed to update}"
CHECK_FOR_UPDATES_CONFIG_FILE="settings.conf"
CHECK_FOR_UPDATES_CONFIG_DIR="$HOME/.config/myscripts/check-for-updates"
CHECK_FOR_UPDATES_CONFIG_BACKUP_DIR="$HOME/.local/share/myscripts/check-for-updates/backups"
CHECK_FOR_UPDATES_OPTIONS_DIR="$HOME/.local/share/myscripts/check-for-updates/options"
CHECK_FOR_UPDATES_CACHEDIR="${CACHE_DIR:-$HOME/.cache/check_all_updates_sh}"
CHECK_FOR_UPDATES_ENABLE_NOTIFICATIONS="${CHECK_FOR_UPDATES_ENABLE_NOTIFICATIONS:-yes}"
CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG="${CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG:-yes}"
CHECK_FOR_UPDATES_SUDO_ASKPASS_APPNAME="${SUDO_ASKPASS:-/usr/local/bin/ask_for_password}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h"
LONGOPTS="options,config,version,help,force"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate Files
[ -f "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE" ] || __gen_config &>/dev/null
[ -f "$CHECK_FOR_UPDATES_OPTIONS_DIR/options" ] || __list_options "$CHECK_FOR_UPDATES_OPTIONS_DIR" &>/dev/null
[ -f "$CHECK_FOR_UPDATES_OPTIONS_DIR/array" ] || __list_array "$CHECK_FOR_UPDATES_OPTIONS_DIR" "$ARRAY" &>/dev/null
[ -d "$CHECK_FOR_UPDATES_CACHEDIR" ] || mkdir -p "$CHECK_FOR_UPDATES_CACHEDIR"
[ -f "$CHECK_FOR_UPDATES_CACHEDIR/update_check" ] || __rm_rf "$CHECK_FOR_UPDATES_CACHEDIR/update_check"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE" ] &&
  . "$CHECK_FOR_UPDATES_CONFIG_DIR/$CHECK_FOR_UPDATES_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
SUDO_ASKPASS="$CHECK_FOR_UPDATES_SUDO_ASKPASS_APPNAME"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "$setopts" 2>/dev/null
while :; do
  case $1 in
  --options)
    __list_options "$CHECK_FOR_UPDATES_OPTIONS_DIR"
    __list_array "$CHECK_FOR_UPDATES_OPTIONS_DIR" "$ARRAY"
    exit $?
    ;;
  --version)
    __version
    exit $?
    ;;
  --help)
    __help
    exit $?
    ;;
  -c | --config)
    __gen_config
    exit $?
    ;;
  --force)
    __rm_rf "$CHECK_ALL_UPDATES_SH_CACHEDIR/update_check"
    ;;
  --)
    shift 1
    break
    ;;
    #*) break ;;
  esac
  shift
done
set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash || exit 1
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if am_i_online; then
  # Use pkmgr if available otherwise use package manager
  if [ -n "$(builtin type -P pkmgr)" ]; then
    updates=$(pkmgr check 2>/dev/null)
  else
    # Brew update check
    if [ -n "$(builtin type -P brew)" ]; then
      if ! updates=$(brew outdated 2>/dev/null | grep -v Security | wc -l); then
        updates=0
      fi

    # Arch update check
    elif [ -n "$(builtin type -P pacman)" ]; then
      if ! updates_arch=$(pacman -Qu 2>/dev/null | wc -l); then
        updates_arch=0
      fi
      # yay doesn't do sudo
      if [ -n "$(builtin type -P yay)" ]; then
        if ! updates_aur=$(yay -Qum 2>/dev/null | wc -l); then
          updates_aur=0
        fi
      fi
      [ -n "$updates_arch" ] && updates=$(("$updates_arch" + "$updates_aur")) || updates="$updates_arch"

    # Debian update check
    elif [ -n "$(builtin type -P apt)" ]; then
      if ! updates=$(apt -q -y --ignore-hold --allow-change-held-packages --allow-unauthenticated -s dist-upgrade 2>/dev/null | grep '^Inst' | wc -l); then
        updates=0
      fi

      # Fedora update check
    elif [ -n "$(builtin type -P dnf)" ]; then
      if ! updates=$(dnf -q check-update 2>/dev/null | grep -v Security | wc -l); then
        updates=0
      fi

      # CentOS update check
    elif [ -n "$(builtin type -P yum)" ]; then
      if ! updates=$(yum -q check-update 2>/dev/null | grep -v Security | wc -l); then
        updates=0
      fi
    fi
  fi
else
  updates=0
fi
if [[ $updates -gt 0 ]]; then
  echo "$updates"
else
  echo 0
  __rm_rf "$CHECK_ALL_UPDATES_SH_CACHEDIR/update_check"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ "$CHECK_FOR_UPDATES_ENABLE_UPDATE_NAG" = "yes" ] && [[ "$updates" -gt 0 ]]; then
  ask_for_password && __ask_me_to_update
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [[ $updates -gt 0 ]]; then
  if [ "$CHECK_ALL_UPDATES_SH_ENABLE_NOTIFICATIONS" = "yes" ]; then
    if [ ! -f "$CHECK_ALL_UPDATES_SH_CACHEDIR/update_check" ]; then
      echo "$updates" >"$CHECK_ALL_UPDATES_SH_CACHEDIR/update_check"
      export CHECK_FOR_UPDATES_NOTIFY_GOOD_MESSAGE
      export NOTIFY_ERROR_MESSAGE="$CHECK_FOR_UPDATES_NOTIFY_ERROR_MESSAGE"
      export NOTIFY_GOOD_MESSAGE="$CHECK_FOR_UPDATES_NOTIFY_GOOD_MESSAGE"
      export NOTIFY_CLIENT_NAME="Update Check"
      notifications "System Updates:" "You have $updates update[s] avaliable"
    fi
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
