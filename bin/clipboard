#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108201933-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$CLIP_TEMP_FILE" ] && rm -Rf "$CLIP_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108201933-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : clip --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Friday, Aug 20, 2021 19:33 EDT
# @File          : clip
# @Description   : Access system clipboard
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$CLIP_CONFIG_DIR/$CLIP_CONFIG_FILE"
  [ -d "$CLIP_CONFIG_DIR" ] || mkdir -p "$CLIP_CONFIG_DIR"
  [ -d "$CLIP_CONFIG_BACKUP_DIR" ] || mkdir -p "$CLIP_CONFIG_BACKUP_DIR"
  [ -f "$CLIP_CONFIG_DIR/$CLIP_CONFIG_FILE" ] &&
    cp -Rf "$CLIP_CONFIG_DIR/$CLIP_CONFIG_FILE" "$CLIP_CONFIG_BACKUP_DIR/$CLIP_CONFIG_FILE.$$"
  cat <<EOF >"$CLIP_CONFIG_DIR/$CLIP_CONFIG_FILE"
# Settings for clip

# Notification settings
CLIP_GOOD_MESSAGE="${CLIP_GOOD_MESSAGE:-Everything Went OK}"
CLIP_ERROR_MESSAGE="${CLIP_ERROR_MESSAGE:-Well that didn\'t work}"
CLIP_NOTIFY_ENABLED="${CLIP_NOTIFY_ENABLED:-yes}"
CLIP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CLIP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CLIP_NOTIFY_CLIENT_ICON}"

# Colorization settings
CLIP_OUTPUT_COLOR="${CLIP_OUTPUT_COLOR:-5}"
CLIP_OUTPUT_COLOR_GOOD="${CLIP_OUTPUT_COLOR_GOOD:-2}"
CLIP_OUTPUT_COLOR_ERROR="${CLIP_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$CLIP_CONFIG_DIR/$CLIP_CONFIG_FILE" ]; then
    printf_green "Your config file for clip has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
if [[ -f "$(builtin type -P xclip)" ]]; then
  clipboard() { xclip -selection clipboard; }
elif [[ -f "$(builtin type -P xsel 2>/dev/null)" ]]; then
  clipboard() { xsel -ib; }
elif [[ -f "$(builtin type -P clip.exe 2>/dev/null)" ]]; then
  clipboard() { clip.exe; }
elif [[ -f "$(builtin type -P pbcopy 2>/dev/null)" ]]; then
  clipboard() { pbcopy; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
CLIP_CACHE_DIR="${CLIP_CACHE_DIR:-$HOME/.cache/clip}"
CLIP_CONFIG_DIR="${CLIP_CONFIG_DIR:-$HOME/.config/myscripts/clip}"
CLIP_OPTIONS_DIR="${CLIP_OPTIONS_DIR:-$HOME/.local/share/myscripts/clip/options}"
CLIP_CONFIG_BACKUP_DIR="${CLIP_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/clip/backups}"
CLIP_TEMP_DIR="${CLIP_TEMP_DIR:-$HOME/.local/tmp/system_scripts/clip}"
CLIP_TEMP_FILE="${CLIP_TEMP_FILE:-$(mktemp $CLIP_TEMP_DIR/XXXXXX 2>/dev/null)}"
CLIP_CONFIG_FILE="${CLIP_CONFIG_FILE:-settings.conf}"
CLIP_GOOD_MESSAGE="${CLIP_GOOD_MESSAGE:-Everything Went OK}"
CLIP_ERROR_MESSAGE="${CLIP_ERROR_MESSAGE:-Well that didn\'t work}"
CLIP_NOTIFY_ENABLED="${CLIP_NOTIFY_ENABLED:-yes}"
CLIP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CLIP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CLIP_NOTIFY_CLIENT_ICON}"
CLIP_OUTPUT_COLOR="${CLIP_OUTPUT_COLOR:-5}"
CLIP_OUTPUT_COLOR_GOOD="${CLIP_OUTPUT_COLOR_GOOD:-2}"
CLIP_OUTPUT_COLOR_ERROR="${CLIP_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$CLIP_TEMP_DIR" ] || mkdir -p "$CLIP_TEMP_DIR" &>/dev/null
[ -d "$CLIP_CACHE_DIR" ] || mkdir -p "$CLIP_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$CLIP_CONFIG_DIR/$CLIP_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$CLIP_CONFIG_DIR/$CLIP_CONFIG_FILE" ] &&
  . "$CLIP_CONFIG_DIR/$CLIP_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    CLIP_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$CLIP_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${CLIP_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${CLIP_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${CLIP_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${CLIP_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [[ $# -ne 0 ]]; then
  contents="$*"
elif [[ -p /dev/stdin ]]; then
  contents="$(</dev/stdin)"
elif [[ -t 0 ]]; then
  contents="$(cat -)"
fi
echo "$contents" | clipboard
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
