APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE"
  [ -d "$CLOUDFLARE_CONFIG_DIR" ] || mkdir -p "$CLOUDFLARE_CONFIG_DIR"
  [ -d "$CLOUDFLARE_CONFIG_BACKUP_DIR" ] || mkdir -p "$CLOUDFLARE_CONFIG_BACKUP_DIR"
  [ -f "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE" ] &&
    cp -Rf "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE" "$CLOUDFLARE_CONFIG_BACKUP_DIR/$CLOUDFLARE_CONFIG_FILE.$$"
  cat <<EOF >"$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE"
# Settings for cloudflare
CLOUDFLARE_API_KEY="${CLOUDFLARE_API_KEY:-}"
CLOUDFLARE_RECORD="${CLOUDFLARE_RECORD:-}"
CLOUDFLARE_DNS_TYPE="${CLOUDFLARE_DNS_TYPE:-A}"
CLOUDFLARE_PROXY="${CLOUDFLARE_PROXY:-}"
CLOUDFLARE_ZONE="${CLOUDFLARE_ZONE:-}"
CLOUDFLARE_IP_ADDR="${CLOUDFLARE_IP_ADDR:-}"

# Notification settings
CLOUDFLARE_GOOD_MESSAGE="${CLOUDFLARE_GOOD_MESSAGE:-Everything Went OK}"
CLOUDFLARE_ERROR_MESSAGE="${CLOUDFLARE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
CLOUDFLARE_NOTIFY_ENABLED="${CLOUDFLARE_NOTIFY_ENABLED:-yes}"
CLOUDFLARE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CLOUDFLARE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CLOUDFLARE_NOTIFY_CLIENT_ICON}"

# Colorization settings
CLOUDFLARE_OUTPUT_COLOR="${CLOUDFLARE_OUTPUT_COLOR:-5}"
CLOUDFLARE_OUTPUT_COLOR_GOOD="${CLOUDFLARE_OUTPUT_COLOR_GOOD:-2}"
CLOUDFLARE_OUTPUT_COLOR_ERROR="${CLOUDFLARE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__get_ip() { curl -q -LSs "https://ifconfig.co" || curl -q -s "https://api.ipify.org" || curl -q -s "https://ipv4.icanhazip.com/"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__message() {
  if grep 'success' "$CLOUDFLARE_TEMP_FILE" | grep -q 'true'; then
    printf_green "${1:-Successfully created $CLOUDFLARE_RECORD}"
    return 0
  else
    printf_red "Well something went horribly wrong"
    cat "$CLOUDFLARE_TEMP_FILE" | jq -r '.errors | .[].message' 2>/dev/null | printf_readline 1
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__zone_identifier() {
  get_api() {
    CLOUDFLARE_ZONE="${1:-$CLOUDFLARE_ZONE}"
    curl -q -LSsf -X GET "https://api.cloudflare.com/client/v4/zones?name=$CLOUDFLARE_ZONE" \
      -H 'Authorization: Bearer '$CLOUDFLARE_API_KEY'' \
      -H 'Content-Type: application/json' 2>/dev/null
  }
  results=$(get_api)
  if echo "$results" | jq '.success' 2>/dev/null | grep -q 'false'; then
    return 1
  else
    echo "$results" | grep -Po '(?<="id":")[^"]*' | head -1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__record_identifier() {
  get_api() {
    curl -q -LSs -X GET "https://api.cloudflare.com/client/v4/zones/$(__zone_identifier)/dns_records" \
      -H "Authorization: Bearer $CLOUDFLARE_API_KEY" \
      -H "Content-Type: application/json"
  }
  results=$(get_api)
  if echo "$results" | jq '.success' 2>/dev/null | grep -q 'false'; then
    return 1
  else
    echo "$results" | jq -rc '.result | .[] | [.name,.id]' 2>/dev/null | grep "${CLOUDFLARE_RECORD:-^}" | tr -d '][' | sed 's|["]||g' | awk -F, '{print $2}' | head -n1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api() {
  get_api() {
    curl -q -LSs -X GET "https://api.cloudflare.com/client/v4/zones/$(__zone_identifier)/dns_records" \
      -H "Authorization: Bearer $CLOUDFLARE_API_KEY" \
      -H "Content-Type: application/json"
  }
  results=$(get_api)
  if echo "$results" | jq '.success' 2>/dev/null | grep -q 'false'; then
    return 1
  else
    echo "$results" | jq -c '.result | .[] | [.name,.type,.id]' 2>/dev/null
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_full() {
  get_api() {
    curl -q -LSs -X GET "https://api.cloudflare.com/client/v4/zones/$(__zone_identifier)/dns_records" \
      -H "Authorization: Bearer $CLOUDFLARE_API_KEY" \
      -H "Content-Type: application/json"
  }
  get_api | jq -r '.result | .[]' 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__delete_record() {
  printf_blue "Attempting to delete host"
  get_api() {
    curl -q -LSs -X DELETE "https://api.cloudflare.com/client/v4/zones/$(__zone_identifier)/dns_records/$(__record_identifier)" \
      -H "Authorization: Bearer $CLOUDFLARE_API_KEY" \
      -H "Content-Type: application/json"
  }
  get_api >>"$CLOUDFLARE_TEMP_FILE"
  __message "Successfully deleted $CLOUDFLARE_RECORD"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__create_record() {
  local CLOUDFLARE_RECORD="${1:-$CLOUDFLARE_RECORD}"
  local CLOUDFLARE_DNS_TYPE="${2:-$CLOUDFLARE_DNS_TYPE}"
  local CLOUDFLARE_PROXY="${3:-$CLOUDFLARE_PROXY}"
  printf_blue "Attempting to create a new host"
  get_api() {
    curl -q -LSs -X POST "https://api.cloudflare.com/client/v4/zones/$(__zone_identifier)/dns_records" \
      -H "Accept: application/json" \
      -H "Authorization: Bearer $CLOUDFLARE_API_KEY" \
      --data "{\"type\":\"${CLOUDFLARE_DNS_TYPE}\",\"name\":\"${CLOUDFLARE_RECORD}\",\"content\":\"${CLOUDFLARE_IP_ADDR}\",\"ttl\":120,\"priority\":0,\"proxied\":${CLOUDFLARE_PROXY}}"
  }
  get_api >>"$CLOUDFLARE_TEMP_FILE"
  __message "Successfully created ${CLOUDFLARE_RECORD}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__update_record() {
  CLOUDFLARE_RECORD="${1:-$CLOUDFLARE_RECORD}"
  CLOUDFLARE_ZONE="${2:-$CLOUDFLARE_ZONE}"
  CLOUDFLARE_PROXY="${CLOUDFLARE_PROXY:-true}"
  printf_blue "Attempting to update host"
  get_api() {
    curl -q -LSs -X PUT "https://api.cloudflare.com/client/v4/zones/$(__zone_identifier)/dns_records/$(__record_identifier)" \
      -H "Authorization: Bearer $CLOUDFLARE_API_KEY" \
      -H "Content-Type: application/json" \
      --data "{\"id\":\"${CLOUDFLARE_ZONE}\",\"type\":\"${CLOUDFLARE_DNS_TYPE}\",\"proxied\":${CLOUDFLARE_PROXY},\"name\":\"${CLOUDFLARE_RECORD}\",\"content\":\"${CLOUDFLARE_IP_ADDR}\"}"
  }
  get_api >>"$CLOUDFLARE_TEMP_FILE"
  __message "Successfully Updated ${CLOUDFLARE_RECORD}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__cloudflare_zone() {
  CLOUDFLARE_ZONE="${1:-$CLOUDFLARE_ZONE}"
  CLOUDFLARE_RECORD="${2:-$CLOUDFLARE_RECORD}"
  CLOUDFLARE_DNS_TYPE="${3:-$CLOUDFLARE_DNS_TYPE}"
  CLOUDFLARE_PROXY="${4:-$CLOUDFLARE_PROXY}"
  if [[ "$CLOUDFLARE_DNS_TYPE" == "CNAME" ]]; then
    CLOUDFLARE_IP_ADDR="$CLOUDFLARE_ZONE"
  else
    CLOUDFLARE_IP_ADDR=${CLOUDFLARE_IP_ADDR:-$(__get_ip 2>/dev/null)}
  fi
  [[ -n "$CLOUDFLARE_IP_ADDR" ]] || CLOUDFLARE_IP_ADDR=${IP_ADDR:-$(__get_ip 2>/dev/null)}
  [ -n "$CLOUDFLARE_ZONE" ] || __usage $CLOUDFLARE_ZONE || exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__usage() {
  if [ -z "${1:-$CLOUDFLARE_ZONE}" ]; then
    printf_return "Usage: $APPNAME ZONE RECORD DNS_TYPE PROXY"
  elif [ -n "${2:-$CLOUDFLARE_RECORD}" ]; then
    printf_return "Usage: $APPNAME ZONE RECORD DNS_TYPE PROXY"
  elif [ -n "${3:-$CLOUDFLARE_DNS_TYPE}" ]; then
    printf_return "Usage: $APPNAME ZONE RECORD DNS_TYPE PROXY"
  elif [ -n "${4:-$CLOUDFLARE_PROXY}" ]; then
    printf_return "Usage: $APPNAME ZONE RECORD DNS_TYPE PROXY"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
CLOUDFLARE_LOG_DIR="${CLOUDFLARE_LOG_DIR:-$HOME/.local/log/cloudflare}"
CLOUDFLARE_CACHE_DIR="${CLOUDFLARE_CACHE_DIR:-$HOME/.cache/cloudflare}"
CLOUDFLARE_CONFIG_DIR="${CLOUDFLARE_CONFIG_DIR:-$HOME/.config/myscripts/cloudflare}"
CLOUDFLARE_CONFIG_BACKUP_DIR="${CLOUDFLARE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/cloudflare/backups}"
CLOUDFLARE_TEMP_DIR="${CLOUDFLARE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/cloudflare}"
CLOUDFLARE_OPTIONS_DIR="${CLOUDFLARE_OPTIONS_DIR:-$HOME/.local/share/myscripts/cloudflare/options}"
CLOUDFLARE_CONFIG_FILE="${CLOUDFLARE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
CLOUDFLARE_OUTPUT_COLOR="${CLOUDFLARE_OUTPUT_COLOR:-4}"
CLOUDFLARE_OUTPUT_COLOR_2="${CLOUDFLARE_OUTPUT_COLOR:-6}"
CLOUDFLARE_OUTPUT_COLOR_GOOD="${CLOUDFLARE_OUTPUT_COLOR_GOOD:-2}"
CLOUDFLARE_OUTPUT_COLOR_ERROR="${CLOUDFLARE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
CLOUDFLARE_GOOD_MESSAGE="${CLOUDFLARE_GOOD_MESSAGE:-Everything Went OK}"
CLOUDFLARE_ERROR_MESSAGE="${CLOUDFLARE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
CLOUDFLARE_NOTIFY_ENABLED="${CLOUDFLARE_NOTIFY_ENABLED:-yes}"
CLOUDFLARE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CLOUDFLARE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CLOUDFLARE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
CLOUDFLARE_API_KEY="${CLOUDFLARE_API_KEY:-}"
CLOUDFLARE_RECORD="${CLOUDFLARE_RECORD:-}"
CLOUDFLARE_DNS_TYPE="${CLOUDFLARE_DNS_TYPE:-A}"
CLOUDFLARE_PROXY="${CLOUDFLARE_PROXY:-}"
CLOUDFLARE_ZONE="${CLOUDFLARE_ZONE:-}"
CLOUDFLARE_IP_ADDR="${CLOUDFLARE_IP_ADDR:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE" ] && . "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$CLOUDFLARE_LOG_DIR" ] || mkdir -p "$CLOUDFLARE_LOG_DIR" &>/dev/null
[ -d "$CLOUDFLARE_TEMP_DIR" ] || mkdir -p "$CLOUDFLARE_TEMP_DIR" &>/dev/null
[ -d "$CLOUDFLARE_CACHE_DIR" ] || mkdir -p "$CLOUDFLARE_CACHE_DIR" &>/dev/null
CLOUDFLARE_TEMP_FILE="${CLOUDFLARE_TEMP_FILE:-$(mktemp $CLOUDFLARE_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$CLOUDFLARE_TEMP_FILE" ] && [ -f "$CLOUDFLARE_TEMP_FILE" ] && rm -Rf "$CLOUDFLARE_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$CLOUDFLARE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${CLOUDFLARE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${CLOUDFLARE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${CLOUDFLARE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${CLOUDFLARE_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,ip:,zone:,proxy:,record:,full"
ARRAY="create update delete list verify"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    CLOUDFLARE_CWD="$2"
    shift 2
    ;;
  --ip)
    CLOUDFLARE_IP_ADDR="$2"
    shift 2
    ;;
  --zone)
    CLOUDFLARE_ZONE="$2"
    shift 2
    ;;
  --proxy)
    CLOUDFLARE_PROXY="$2"
    shift 2
    ;;
  --record)
    CLOUDFLARE_RECORD="$2"
    shift 2
    ;;
  --full)
    SET_API="full"
    shift 1
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[ -n "$CLOUDFLARE_API_KEY" ] || printf_exit 1 1 "Please set CLOUDFLARE_API_KEY variable"
__rm_rf "$CLOUDFLARE_TEMP_FILE"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
verify)
  shift 1
  __cloudflare_zone "${1:-$CLOUDFLARE_ZONE}" "$2" "$3" "$4"
  results="$(curl -q -LSs -X GET "https://api.cloudflare.com/client/v4/user/tokens/verify" -H "Authorization: Bearer $CLOUDFLARE_API_KEY" 2>/dev/null | jq -r '.messages | .[].message' 2>/dev/null | grep 'valid' | grep '^' || return)"
  [ -n "$results" ] && printf_green "Valid API Key" && printf '%s\n' "$results" | printf_readline ||
    printf_red "Invalid API Key"
  ;;

create)
  shift 1
  __cloudflare_zone "$1" "$2" "$3" "$4"
  __create_record "$CLOUDFLARE_RECORD" "$CLOUDFLARE_DNS_TYPE" "$CLOUDFLARE_PROXY"
  exit $?
  ;;

update)
  shift 1
  __cloudflare_zone "$1" "$2" "$3" "$4"
  __update_record "$CLOUDFLARE_RECORD" "$CLOUDFLARE_ZONE"
  exit $?
  ;;

delete)
  shift 1
  __cloudflare_zone "$1" "$2" "$3" "$4"
  __delete_record "$CLOUDFLARE_RECORD"
  exit $?
  ;;

list)
  shift 1
  __cloudflare_zone "$1" "$2" "$3" "$4"
  if [[ "$SET_API" = "full" ]]; then
    __api_full "$CLOUDFLARE_ZONE"
  else
    __api "$CLOUDFLARE_ZONE"
  fi
  ;;

*)
  __cloudflare_zone "$1" "$2" "$3" "$4"
  printf_cyan "Current settings for cloudflare"
  printf_blue "Email: $CLOUDFLARE_EMAIL"
  printf_blue "API_Key: $CLOUDFLARE_API_KEY"
  printf_blue "Default Record: $CLOUDFLARE_RECORD"
  printf_blue "Default DNS Type $CLOUDFLARE_DNS_TYPE"
  printf_blue "Default proxy: $CLOUDFLARE_PROXY"
  printf_blue "Default Zone: ${CLOUDFLARE_ZONE:-$1}"
  printf_blue "Configured IP Address: $CLOUDFLARE_IP_ADDR"
  printf_blue "Zone ID: $(__zone_identifier | grep '^' || printf 'Zone does not exist')"
  printf_blue "Record ID: $(__record_identifier | grep '^' || printf 'Record does not exist')"
  ;;

esac

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
