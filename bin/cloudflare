APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202207211103-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"
[[ "$1" == "--raw" ]] && export SHOW_RAW="true"
set -o pipefail
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Options are: desktopmgr_install devenvmgr_install dfmgr_install dockermgr_install fontmgr_install iconmgr_install
# pkmgr_install system_install systemmgr_install thememgr_install user_install wallpapermgr_install
user_install && __options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__devnull() {
  tee &>/dev/null || exitCode=1
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -'
__cmd_exist() {
  local exitCode=0
  for cmd in "$@"; do
    builtin command -v "$cmd" |& __devnull && true || exitCode+=1
  done
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# output version
__version() { printf_color "$VERSION" "2"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  printf_color "$1: " "$5"
  echo -ne "$2" | sed 's|:||g;s/'$3'/ '$4'/g'
  printf_newline
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_blue "Generating the config file in"
  printf_cyan "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE"
  [ -d "$CLOUDFLARE_CONFIG_DIR" ] || mkdir -p "$CLOUDFLARE_CONFIG_DIR"
  [ -d "$CLOUDFLARE_CONFIG_BACKUP_DIR" ] || mkdir -p "$CLOUDFLARE_CONFIG_BACKUP_DIR"
  [ -f "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE" ] &&
    cp -Rf "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE" "$CLOUDFLARE_CONFIG_BACKUP_DIR/$CLOUDFLARE_CONFIG_FILE.$$"
  cat <<EOF >"$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE"
# Settings for cloudflare
CLOUDFLARE_API_KEY="${CLOUDFLARE_API_KEY:-}"
CLOUDFLARE_RECORD="${CLOUDFLARE_RECORD:-}"
CLOUDFLARE_DNS_TYPE="${CLOUDFLARE_DNS_TYPE:-A}"
CLOUDFLARE_PROXY="${CLOUDFLARE_PROXY:-}"
CLOUDFLARE_ZONE="${CLOUDFLARE_ZONE:-}"
CLOUDFLARE_IP_ADDR="${CLOUDFLARE_IP_ADDR:-}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
CLOUDFLARE_OUTPUT_COLOR="${CLOUDFLARE_OUTPUT_COLOR:-}"
CLOUDFLARE_OUTPUT_COLOR_2="${CLOUDFLARE_OUTPUT_COLOR:-}"
CLOUDFLARE_OUTPUT_COLOR_GOOD="${CLOUDFLARE_OUTPUT_COLOR_GOOD:-}"
CLOUDFLARE_OUTPUT_COLOR_ERROR="${CLOUDFLARE_OUTPUT_COLOR_ERROR:-}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
CLOUDFLARE_NOTIFY_ENABLED="${CLOUDFLARE_NOTIFY_ENABLED:-}"
CLOUDFLARE_GOOD_NAME="${CLOUDFLARE_GOOD_NAME:-}"
CLOUDFLARE_ERROR_NAME="${CLOUDFLARE_ERROR_NAME:-}"
CLOUDFLARE_GOOD_MESSAGE="${CLOUDFLARE_GOOD_MESSAGE:-}"
CLOUDFLARE_ERROR_MESSAGE="${CLOUDFLARE_ERROR_MESSAGE:-}"
CLOUDFLARE_NOTIFY_CLIENT_NAME="${CLOUDFLARE_NOTIFY_CLIENT_NAME:-}"
CLOUDFLARE_NOTIFY_CLIENT_ICON="${CLOUDFLARE_NOTIFY_CLIENT_ICON:-}"
CLOUDFLARE_NOTIFY_CLIENT_URGENCY="${CLOUDFLARE_NOTIFY_CLIENT_URGENCY:-}"

EOF
  if [ -f "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    . "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Help function - Align to 55
__help() {
  __printf_head() { printf_purple "$*"; }
  __printf_opts() { printf_cyan "$*"; }
  __printf_line() { printf_blue "$*"; }
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "cloudflare:  cloudflare api script"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Usage: cloudflare [options] [commands]"
  __printf_line "cloudflare                  - "
  __printf_line "cloudflare                  - "
  __printf_line "cloudflare                  - "
  __printf_line "cloudflare                  - "
  __printf_line "cloudflare                  - "
  __printf_line "cloudflare                  - "
  __printf_line "cloudflare                  - "
  __printf_line "cloudflare                  - "
  __printf_line ""
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "cloudflare --help             - Shows this message"
  __printf_line "cloudflare --config           - Generate user config file"
  __printf_line "cloudflare --version          - Show script version"
  __printf_line "cloudflare --options          - Shows all available options"
  __printf_line "cloudflare --debug            - enable debugging"
  __printf_line "cloudflare --raw              - removes all formatting on output"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  printf '\n'
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__rm_rf() {
  rm -Rf "$*" 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__jq() {
  jq "$*" 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_ip() {
  curl -q -LSs -4 "https://ifconfig.co" ||
    curl -q -s -4 "https://api.ipify.org" ||
    curl -q -s -4 "https://ipv4.icanhazip.com/"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_ip6() {
  curl -q -LSs -6 "https://ifconfig.co" ||
    curl -q -s -6 "https://api.ipify.org" ||
    curl -q -s -6 "https://ipv4.icanhazip.com/"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__message() {
  if grep 'success' "$CLOUDFLARE_TEMP_FILE" | grep -q 'true'; then
    printf_green "${1:-Successfully created $CLOUDFLARE_RECORD}"
    return 0
  else
    printf_red "Well something went horribly wrong"
    __devnull2 cat "$CLOUDFLARE_TEMP_FILE" | __jq -r '.errors | .[].message' | printf_readline 1
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__zone_identifier() {
  get_api() {
    CLOUDFLARE_ZONE="${1:-$CLOUDFLARE_ZONE}"
    curl -q -LSsf -X GET \
      -H 'Authorization: Bearer '$CLOUDFLARE_API_KEY'' \
      -H "Content-Type: application/json" \
      "https://api.cloudflare.com/client/v4/zones?name=$CLOUDFLARE_ZONE" 2>/dev/null
    exitCode="$?"
    return ${exitCode:-$?}
  }
  results=$(get_api "$CLOUDFLARE_ZONE" || echo '')
  if echo "$results" | __jq '.success' | grep -q 'false'; then
    exitCode="1"
  else
    echo "$results" | grep -Po '(?<="id":")[^"]*' | head -1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__record_identifier() {
  get_api() {
    curl -q -LSs -X GET \
      -H 'Authorization: Bearer '$CLOUDFLARE_API_KEY'' \
      -H "Content-Type: application/json" \
      "https://api.cloudflare.com/client/v4/zones/$ZONE_ID/dns_records" 2>/dev/null
    exitCode=$?
    return ${exitCode:-$?}
  }
  results=$(get_api)
  if echo "$results" | __jq '.success' | grep -q 'false'; then
    exitCode="1"
  else
    echo "$results" |
      __jq -rc '.result | .[] | [.name,.id]' |
      grep "${CLOUDFLARE_RECORD:-^}" |
      tr -d '][' |
      sed 's|["]||g' |
      awk -F, '{print $2}' |
      head -n1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api() {
  get_api() {
    curl -q -LSs -X GET \
      -H 'Authorization: Bearer '$CLOUDFLARE_API_KEY'' \
      -H "Content-Type: application/json" \
      "https://api.cloudflare.com/client/v4/zones/$ZONE_ID/dns_records" 2>/dev/null
    exitCode="$?"
  }
  results=$(get_api || echo '')
  if echo "$results" | __jq '.success' | grep -q 'false'; then
    exitCode=1
  else
    echo "$results" | jq '.result|.[]' | jq -rc '[.name,.type,.id]'
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_full() {
  get_api() {
    curl -q -LSs -X GET \
      -H 'Authorization: Bearer '$CLOUDFLARE_API_KEY'' \
      -H "Content-Type: application/json" \
      "https://api.cloudflare.com/client/v4/zones/$ZONE_ID/dns_records" 2>/dev/null
    exitCode=$?
  }
  #jq -rc '{name:.name,type:.type,content:.content,proxiable:.proxiable,proxied:.proxied}
  get_api | jq '.result|.[]'
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__delete_record() {
  printf_blue "Attempting to delete host"
  get_api() {
    curl -q -LSs -X DELETE \
      -H 'Authorization: Bearer '$CLOUDFLARE_API_KEY'' \
      -H "Content-Type: application/json" \
      "https://api.cloudflare.com/client/v4/zones/$ZONE_ID/dns_records/$RECORD_ID" 2>/dev/null
    exitCode=$?
  }
  get_api >>"$CLOUDFLARE_TEMP_FILE"
  __message "Successfully deleted $CLOUDFLARE_RECORD"
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__create_record() {
  CLOUDFLARE_RECORD="${1:-$CLOUDFLARE_RECORD}"
  CLOUDFLARE_DNS_TYPE="${2:-$CLOUDFLARE_DNS_TYPE}"
  CLOUDFLARE_PROXY="${3:-$CLOUDFLARE_PROXY}"
  printf_blue "Attempting to create a new host"
  get_api() {
    curl -q -LSs -X POST \
      -H "Content-Type: application/json" \
      -H 'Authorization: Bearer '$CLOUDFLARE_API_KEY'' \
      --data "{\"type\":\"${CLOUDFLARE_DNS_TYPE}\",\"name\":\"${CLOUDFLARE_RECORD}\",\"content\":\"${CLOUDFLARE_IP_ADDR}\",\"ttl\":120,\"priority\":0,\"proxied\":${CLOUDFLARE_PROXY}}" \
      "https://api.cloudflare.com/client/v4/zones/$ZONE_ID/dns_records" 2>/dev/null
    exitCode=$?
  }
  get_api >>"$CLOUDFLARE_TEMP_FILE"
  __message "Successfully created ${CLOUDFLARE_RECORD}"
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__update_record() {
  CLOUDFLARE_RECORD="${1:-$CLOUDFLARE_RECORD}"
  CLOUDFLARE_ZONE="${2:-$CLOUDFLARE_ZONE}"
  CLOUDFLARE_PROXY="${3:-$CLOUDFLARE_PROXY}"
  printf_blue "Attempting to update host"
  get_api() {
    curl -q -LSs -X PATCH \
      -H 'Authorization: Bearer '$CLOUDFLARE_API_KEY'' \
      -H "Content-Type: application/json" \
      --data "{\"id\":\"${CLOUDFLARE_ZONE}\",\"type\":\"${CLOUDFLARE_DNS_TYPE}\",\"proxied\":${CLOUDFLARE_PROXY},\"name\":\"${CLOUDFLARE_RECORD}\",\"content\":\"${CLOUDFLARE_IP_ADDR}\"}" \
      "https://api.cloudflare.com/client/v4/zones/$ZONE_ID/dns_records/$RECORD_ID" 2>/dev/null
    exitCode=$?
  }
  get_api >>"$CLOUDFLARE_TEMP_FILE"
  __message "Successfully Updated ${CLOUDFLARE_RECORD}"
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__cloudflare_zone() {
  CLOUDFLARE_ZONE="${1:-$CLOUDFLARE_ZONE}"
  CLOUDFLARE_RECORD="${2:-$CLOUDFLARE_RECORD}"
  CLOUDFLARE_DNS_TYPE="${3:-$CLOUDFLARE_DNS_TYPE}"
  CLOUDFLARE_PROXY="${4:-$CLOUDFLARE_PROXY}"
  [[ -z "$CLOUDFLARE_ZONE" ]] || ZONE_ID="$(__zone_identifier "$CLOUDFLARE_ZONE")"
  [[ -z "$CLOUDFLARE_RECORD" ]] || RECORD_ID="$(__record_identifier "$CLOUDFLARE_RECORD")"
  if [[ "$CLOUDFLARE_DNS_TYPE" == "CNAME" ]]; then
    CLOUDFLARE_IP_ADDR="$CLOUDFLARE_ZONE"
  elif [[ "$CLOUDFLARE_DNS_TYPE" == "AAAA" ]]; then
    CLOUDFLARE_IP_ADDR=${CLOUDFLARE_IP_ADDR:-$(__get_ip6)}
  else
    CLOUDFLARE_IP_ADDR=${CLOUDFLARE_IP_ADDR:-$(__get_ip)}
  fi
  [[ -n "$CLOUDFLARE_IP_ADDR" ]] || CLOUDFLARE_IP_ADDR=${IP_ADDR:-$(__get_ip)}
  [[ -n "$CLOUDFLARE_PROXY" ]] || CLOUDFLARE_PROXY="true"
  [ -n "$CLOUDFLARE_ZONE" ] || __usage $CLOUDFLARE_ZONE || exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__usage() {
  if [ -z "${1:-$CLOUDFLARE_ZONE}" ]; then
    printf_return "Usage: $APPNAME ZONE RECORD DNS_TYPE PROXY"
  elif [ -n "${2:-$CLOUDFLARE_RECORD}" ]; then
    printf_return "Usage: $APPNAME ZONE RECORD DNS_TYPE PROXY"
  elif [ -n "${3:-$CLOUDFLARE_DNS_TYPE}" ]; then
    printf_return "Usage: $APPNAME ZONE RECORD DNS_TYPE PROXY"
  elif [ -n "${4:-$CLOUDFLARE_PROXY}" ]; then
    printf_return "Usage: $APPNAME ZONE RECORD DNS_TYPE PROXY"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Defaults
exitCode=0
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
CLOUDFLARE_CONFIG_FILE="${CLOUDFLARE_CONFIG_FILE:-settings.conf}"
CLOUDFLARE_CONFIG_DIR="${CLOUDFLARE_CONFIG_DIR:-$HOME/.config/myscripts/cloudflare}"
CLOUDFLARE_CONFIG_BACKUP_DIR="${CLOUDFLARE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/cloudflare/backups}"
CLOUDFLARE_LOG_DIR="${CLOUDFLARE_LOG_DIR:-$HOME/.local/log/cloudflare}"
CLOUDFLARE_TEMP_DIR="${CLOUDFLARE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/cloudflare}"
CLOUDFLARE_CACHE_DIR="${CLOUDFLARE_CACHE_DIR:-$HOME/.cache/cloudflare}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
CLOUDFLARE_OUTPUT_COLOR="${CLOUDFLARE_OUTPUT_COLOR:-4}"
CLOUDFLARE_OUTPUT_COLOR_2="${CLOUDFLARE_OUTPUT_COLOR:-5}"
CLOUDFLARE_OUTPUT_COLOR_GOOD="${CLOUDFLARE_OUTPUT_COLOR_GOOD:-2}"
CLOUDFLARE_OUTPUT_COLOR_ERROR="${CLOUDFLARE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
CLOUDFLARE_NOTIFY_ENABLED="${CLOUDFLARE_NOTIFY_ENABLED:-yes}"
CLOUDFLARE_GOOD_NAME="${CLOUDFLARE_GOOD_NAME:-Great:}"
CLOUDFLARE_ERROR_NAME="${CLOUDFLARE_ERROR_NAME:-Error:}"
CLOUDFLARE_GOOD_MESSAGE="${CLOUDFLARE_GOOD_MESSAGE:-No errors reported}"
CLOUDFLARE_ERROR_MESSAGE="${CLOUDFLARE_ERROR_MESSAGE:-Error reported}"
CLOUDFLARE_NOTIFY_CLIENT_NAME="${CLOUDFLARE_NOTIFY_CLIENT_NAME:-$APPNAME}"
CLOUDFLARE_NOTIFY_CLIENT_ICON="${CLOUDFLARE_NOTIFY_CLIENT_ICON:-notification-new}"
CLOUDFLARE_NOTIFY_CLIENT_URGENCY="${CLOUDFLARE_NOTIFY_CLIENT_URGENCY:-normal}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional Variables
CLOUDFLARE_API_KEY="${CLOUDFLARE_API_KEY:-}"
CLOUDFLARE_RECORD="${CLOUDFLARE_RECORD:-}"
CLOUDFLARE_DNS_TYPE="${CLOUDFLARE_DNS_TYPE:-A}"
CLOUDFLARE_PROXY="${CLOUDFLARE_PROXY:-}"
CLOUDFLARE_ZONE="${CLOUDFLARE_ZONE:-}"
CLOUDFLARE_IP_ADDR="${CLOUDFLARE_IP_ADDR:-}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE" ] ||
  [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE" ] &&
  . "$CLOUDFLARE_CONFIG_DIR/$CLOUDFLARE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$CLOUDFLARE_LOG_DIR" ] ||
  mkdir -p "$CLOUDFLARE_LOG_DIR" |& __devnull
[ -d "$CLOUDFLARE_TEMP_DIR" ] ||
  mkdir -p "$CLOUDFLARE_TEMP_DIR" |& __devnull
[ -d "$CLOUDFLARE_CACHE_DIR" ] ||
  mkdir -p "$CLOUDFLARE_CACHE_DIR" |& __devnull
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
CLOUDFLARE_TEMP_FILE="${CLOUDFLARE_TEMP_FILE:-$(mktemp $CLOUDFLARE_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$CLOUDFLARE_TEMP_FILE" ] && [ -f "$CLOUDFLARE_TEMP_FILE" ] && rm -Rf "$CLOUDFLARE_TEMP_FILE" |&__devnull' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$CLOUDFLARE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${NOTIFY_GOOD_MESSAGE:-$CLOUDFLARE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${NOTIFY_ERROR_MESSAGE:-$CLOUDFLARE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CLOUDFLARE_NOTIFY_CLIENT_ICON}"
    export NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$CLOUDFLARE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_URGENCY="${NOTIFY_CLIENT_URGENCY:-$CLOUDFLARE_NOTIFY_CLIENT_URGENCY}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

