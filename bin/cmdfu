#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108122210-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$CMDFU_TEMP_FILE" ] && rm -Rf "$CMDFU_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108122210-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : cmdfu --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 12, 2021 22:10 EDT
# @File          : cmdfu
# @Description   : search command usage examples on commandlinefu.com
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_available() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$CMDFU_CONFIG_DIR/$CMDFU_CONFIG_FILE"
  [ -d "$CMDFU_CONFIG_DIR" ] || mkdir -p "$CMDFU_CONFIG_DIR"
  [ -d "$CMDFU_CONFIG_BACKUP_DIR" ] || mkdir -p "$CMDFU_CONFIG_BACKUP_DIR"
  [ -f "$CMDFU_CONFIG_DIR/$CMDFU_CONFIG_FILE" ] &&
    cp -Rf "$CMDFU_CONFIG_DIR/$CMDFU_CONFIG_FILE" "$CMDFU_CONFIG_BACKUP_DIR/$CMDFU_CONFIG_FILE.$$"
  cat <<EOF >"$CMDFU_CONFIG_DIR/$CMDFU_CONFIG_FILE"
# Settings for cmdfu
CMDFU_API_URL="${CMDFU_API_URL:-http://www.commandlinefu.com}"

# Notification settings
CMDFU_GOOD_MESSAGE="${CMDFU_GOOD_MESSAGE:-Everything Went OK}"
CMDFU_ERROR_MESSAGE="${CMDFU_ERROR_MESSAGE:-Well that didn\'t work}"
CMDFU_NOTIFY_ENABLED="${CMDFU_NOTIFY_ENABLED:-yes}"
CMDFU_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$PROG}"
CMDFU_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CMDFU_NOTIFY_CLIENT_ICON}"

EOF
  if [ -f "$CMDFU_CONFIG_DIR/$CMDFU_CONFIG_FILE" ]; then
    printf_green "Your config file for cmdfu has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
CMDFU_CACHE_DIR="${CMDFU_CACHE_DIR:-/$HOME/.cache/cmdfu}"
CMDFU_CONFIG_DIR="${CMDFU_CONFIG_DIR:-$HOME/.config/misc/cmdfu}"
CMDFU_OPTIONS_DIR="${CMDFU_OPTIONS_DIR:-$HOME/.local/share/misc/cmdfu/options}"
CMDFU_CONFIG_BACKUP_DIR="${CMDFU_CONFIG_BACKUP_DIR:-$HOME/.local/share/misc/cmdfu/backups}"
CMDFU_TEMP_DIR="${CMDFU_TEMP_DIR/system_scripts/cmdfu:-$HOME/.local/tmp/system_scripts/cmdfu}"
CMDFU_TEMP_FILE="${CMDFU_TEMP_DIR:-$HOME/.local/tmp/cmdfu}"
CMDFU_CONFIG_FILE="${CMDFU_CONFIG_FILE:-settings.conf}"
CMDFU_GOOD_MESSAGE="${CMDFU_GOOD_MESSAGE:-Everything Went OK}"
CMDFU_ERROR_MESSAGE="${CMDFU_ERROR_MESSAGE:-Well that didn\'t work}"
CMDFU_NOTIFY_ENABLED="${CMDFU_NOTIFY_ENABLED:-yes}"
CMDFU_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CMDFU_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CMDFU_NOTIFY_CLIENT_ICON}"
CMDFU_API_URL="${CMDFU_API_URL:-http://www.commandlinefu.com}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$CMDFU_TEMP_DIR" ] || mkdir -p "$CMDFU_TEMP_DIR" &>/dev/null
[ -d "$CMDFU_CACHE_DIR" ] || mkdir -p "$CMDFU_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$CMDFU_CONFIG_DIR/$CMDFU_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$CMDFU_CONFIG_DIR/$CMDFU_CONFIG_FILE" ] &&
  . "$CMDFU_CONFIG_DIR/$CMDFU_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h,z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_available "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_available "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_available "5" "Base Options" "-$ARRAY" ',' ''
    exit $?
    ;;
  -v | --version)
    shift 1
    __version
    exit $?
    ;;
  -h | --help)
    shift 1
    __help
    exit $?
    ;;
  -c | --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    shift 1
    GEN_SCRIPT_REPLACE_CWD="$1"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$CMDFU_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${CMDFU_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${CMDFU_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${CMDFU_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${CMDFU_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash html2text || exit 1 # exit 1 if not found
am_i_online --error || exit                 # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
search="${*:-commandlinefu}"
API="commands/matching/${search// /-}/$(echo -n "$search" | base64)/sort-by-votes/plaintext"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if __urlcheck "$CMDFU_API_URL/$API"; then
  __curl "$CMDFU_API_URL/$API" | printf_readline "3"
else
  printf_return "1" "1" "Failed to search for $search"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
