#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108272203-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : config --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Friday, Aug 27, 2021 22:03 EDT
# @File          : config
# @Description   : Add dotfiles/config files to a git repo
# @TODO          :
# @Other         :
# @Resource      : https://www.atlassian.com/git/tutorials/dotfiles
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108272203-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$CONFIG_TEMP_FILE" ] && [ -f "$CONFIG_TEMP_FILE" ] && rm -Rf "$CONFIG_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$CONFIG_CONFIG_DIR/$CONFIG_CONFIG_FILE"
  [ -d "$CONFIG_CONFIG_DIR" ] || mkdir -p "$CONFIG_CONFIG_DIR"
  [ -d "$CONFIG_BACKUP_DIR" ] || mkdir -p "$CONFIG_BACKUP_DIR"
  [ -f "$CONFIG_CONFIG_DIR/$CONFIG_CONFIG_FILE" ] &&
    cp -Rf "$CONFIG_CONFIG_DIR/$CONFIG_CONFIG_FILE" "$CONFIG_BACKUP_DIR/$CONFIG_CONFIG_FILE.$$"
  cat <<EOF >"$CONFIG_CONFIG_DIR/$CONFIG_CONFIG_FILE"
# Settings for config
CONFIG_SYSTEM_HOME="${CONFIG_SYSTEM_HOME:-$HOME/.local/dotfiles}"
CONFIG_GIT_BARE_DIR="${CONFIG_GIT_BARE_DIR:-$HOME/.local/backups/config}"
CONFIG_SYSTEM_BACKUP_DIR="${CONFIG_SYSTEM_BACKUP_DIR:-$HOME/.local/backups/config}"

# Notification settings
CONFIG_GOOD_MESSAGE="${CONFIG_GOOD_MESSAGE:-Everything Went OK}"
CONFIG_ERROR_MESSAGE="${CONFIG_ERROR_MESSAGE:-Well something seems to have gone wrong}"
CONFIG_NOTIFY_ENABLED="${CONFIG_NOTIFY_ENABLED:-yes}"
CONFIG_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CONFIG_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CONFIG_NOTIFY_CLIENT_ICON}"

# Colorization settings
CONFIG_OUTPUT_COLOR="${CONFIG_OUTPUT_COLOR:-5}"
CONFIG_OUTPUT_COLOR_GOOD="${CONFIG_OUTPUT_COLOR_GOOD:-2}"
CONFIG_OUTPUT_COLOR_ERROR="${CONFIG_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$CONFIG_CONFIG_DIR/$CONFIG_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for config has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
_symlink() { ls -l "$1" | awk '{print $NF}'; }
_online_check() { am_i_online --error && return 0 || return 1; }
_cp() { cp -Rfva --parents --preserve=mode,ownership,timestamps "$1" "$2" || return 1; }
_stow() { eval git --git-dir="$CONFIG_CWD_BARE_DIR" --work-tree="$CONFIG_CWD_HOME_DIR" ${*:-} 2>&1 | printf_readline 4 || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_copy() {
  local -a args=("$@")
  local gitDir="$CONFIG_CWD_BARE_DIR"
  local workingTree="$CONFIG_CWD_HOME_DIR"
  local backupDir="$CONFIG_CWD_BACKUP_DIR"
  local exitCode=0
  for f in ${args[*]}; do
    file="$1"
    symlink="$(_symlink "$1")"
    if [[ "$file" = "$symlink" ]]; then
      _cp "$symlink" "$workingTree" &>/dev/null || exitCode+=1
      _cp "$file" "$workingTree" &>/dev/null || exitCode+=1
    else
      _cp "$file" "$workingTree" &>/dev/null || exitCode+=1
    fi
    unset file symlink
  done
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_add() {
  local -a args=("$@")
  local gitDir="$CONFIG_CWD_BARE_DIR"
  local workingTree="$CONFIG_CWD_HOME_DIR"
  local backupDir="$CONFIG_CWD_BACKUP_DIR"
  for f in ${args[*]}; do
    _copy "$f" && _stow add -f "$workingTree/$f" && true || false
    exitCode+=$?
  done
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_restore() {
  local -a args=("$@")
  local gitDir="$CONFIG_CWD_BARE_DIR"
  local workingTree="$CONFIG_CWD_HOME_DIR"
  local backupName="$HOME/.local/share/myscripts/config/backup/$(date +'%Y%m%d_%H%M').tar.gz"
  mkdir -p "$HOME/.local/share/myscripts/config/backup"
  for f in ${args[*]}; do
    file="${f//workingTree/}"
    [[ -f "$file" ]] && tar cfvzu "$backupDir" "$backupName"
    _cp "$f" "$file" && true || false
    exitCode+=$?
  done
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_checkout() {
  local gitDir="$CONFIG_CWD_BARE_DIR"
  local workingTree="$CONFIG_CWD_HOME_DIR"
  local backupDir="$CONFIG_CWD_BACKUP_DIR"
  _backup
  eval git --git-dir="$gitDir/" --work-tree="$workingTree" checkout --force | printf_readline 4
  _restore "$workingTree"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_bare() {
  local gitDir="$CONFIG_CWD_BARE_DIR"
  local workingTree="$CONFIG_CWD_HOME_DIR"
  local backupDir="$CONFIG_CWD_BACKUP_DIR"
  eval git clone --bare --git-dir="$gitDir/" --work-tree="$workingTree" ${1} 2>&1 | printf_readline 4
  cd "$workingTree" && git checkout --git-dir="$gitDir/" --work-tree="$workingTree" | printf_readline 4 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_backup() {
  local gitDir="$CONFIG_CWD_BARE_DIR"
  local workingTree="$CONFIG_CWD_HOME_DIR"
  local backupDir="$CONFIG_CWD_BACKUP_DIR"
  eval git --git-dir="$gitDir/" --work-tree="$workingTree" checkout 2>&1 | awk '{print $2}' | grep -E '^' |
    rsync -av --remove-source-files --files-from="-" $workingTree "$backupDir/" | printf_readline 4
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
git_remote() {
  if [ -z "$1" ]; then
    printf_read_input "3" "Enter the url to your git repo:" 120 "url"
    _stow remote add origin "$url"
  else
    _stow remote "$@"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
gitconfig_local() {
  local gitDir="$CONFIG_CWD_BARE_DIR"
  local workingTree="$CONFIG_CWD_HOME_DIR"
  printf_green "Setting up the local gitconfig file"
  if grep -s "$gitDir/config.local" "$gitDir/config.local" | grep -qv ' = '; then
    cat <<EOF | tee -a "$gitDir/config.local" &>/dev/null

[include]
path = $gitDir/config.local

EOF
  fi

  cat <<EOF | tee "$gitDir/config.local" &>/dev/null
[color "branch"]
  current = green bold
  local = green
  remote = yellow

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[status]
  submoduleSummary = 1

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[color "diff"]
  frag = magenta
  meta = yellow
  new = green
  old = red
  newMoved = cyan
  oldMoved = blue

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[color "status"]
  added = green reverse
  changed = yellow reverse
  untracked = red reverse

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[diff]
  colorMoved = zebra
  submodule = log

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[diff "bin"]
  textconv = hexdump -v -C

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#pretty log
[pretty]
  custom = "%C(magenta)%h%C(red)%d %C(yellow)%ar %C(green)%s %C(yellow)(%an)"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Aliases
g   = "!(){ git --git-dir="$gitDir/" --work-tree="$workingTree" log --graph --pretty=custom; };f"
l   = "!f(){ git --git-dir="$gitDir/" --work-tree="$workingTree" log --pretty=custom; };f"
s   = "!f(){ git --git-dir="$gitDir/" --work-tree="$workingTree" status -s -b; };f"
p   = "!f(){ git --git-dir="$gitDir/" --work-tree="$workingTree" push; };f"

EOF

  git --git-dir="$gitDir/" --work-tree="$workingTree" config --local commit.gpgSign false &>/dev/null
  git --git-dir="$gitDir/" --work-tree="$workingTree" config --local status.showUntrackedFiles no &>/dev/null
  git --git-dir="$gitDir/" --work-tree="$workingTree" config --local core.excludesfile "$workingTree/.gitignore" &>/dev/null

  if [[ -f "$gitDir/config.local" ]]; then
    printf_blue "The local git config file has been created in"
    exitCode=0
  else
    printf_red "Failed to create the config file in"
    exitCode=1
  fi
  printf_blue "$gitDir/config.local"
  return ${exitCode:-$?}
}

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
git_init() {
  { [[ $# -gt 2 ]] || [[ "$*" = *config ]] || [[ "$*" = *bare ]] || [[ "$*" = *clone ]] || [[ "$*" = *bare ]]; } && return
  local choice="" email="" name=""
  local gitDir="$CONFIG_CWD_BARE_DIR"
  local workingTree="$CONFIG_CWD_HOME_DIR"
  [[ -d "$gitDir" ]] && printf_read_question "4" "$gitDir already exists. Should I continue anyway? " "1" || return
  if [ ! -f "$workingTree/.gitignore" ]; then
    echo "$gitDir" >"$workingTree/.gitignore"
    echo "*/.git/*" >"$workingTree/.gitignore"
  else
    grep -sq "$gitDir" "$workingTree/.gitignore" 2>/dev/null || echo "$gitDir" >>"$workingTree/.gitignore"
    grep -sq '/.git/' "$workingTree/.gitignore" 2>/dev/null || echo "*/.git/*" >>"$workingTree/.gitignore"
  fi
  printf_read_question "4" "Do you already have a dotfiles repo: [y/N]" "1" "choice"
  if printf_answer_yes "$choice"; then
    printf_read_input "4" "What is the repo url:" "120" "url"
    git clone --bare "$url" "$gitDir" -q
    _checkout
    _stow config --local core.excludesfile "$workingTree/.gitignore"
    _stow config --local status.showUntrackedFiles no
  else
    mkdir -p "$gitDir"
    git init --bare "$gitDir" -q
    gitconfig_local
    _stow config --local status.showUntrackedFiles no
    _stow config --local commit.gpgSign false
    printf_read_question "4" "Would you like to add a remote git repo: [y/N]" "1" "choice"
    if printf_answer_yes "$choice"; then
      printf_read_input "4" "Enter the url to your git repo:" "120" "url"
      _stow remote add origin "$url"
    else
      printf_green "You did not add a remote git repo"
    fi
    printf_read_input "4" "Enter your name:" "120" "name"
    printf_read_input "4" "Enter email address:" "120" "email"
    _stow config --local user.name "$name"
    _stow config --local user.email "$email"
    _stow config --local include.path "$gitDir/config.local"
    _stow add -f "$workingTree/.gitignore"
    _stow commit -q -m "'🏠🐜❗ Added .gitignore 🏠🐜❗'"
  fi
  __help
  exit "$?"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
CONFIG_LOG_DIR="${CONFIG_LOG_DIR:-$HOME/.local/log/config}"
CONFIG_CACHE_DIR="${CONFIG_CACHE_DIR:-$HOME/.cache/config}"
CONFIG_CONFIG_DIR="${CONFIG_CONFIG_DIR:-$HOME/.config/myscripts/config}"
CONFIG_OPTIONS_DIR="${CONFIG_OPTIONS_DIR:-$HOME/.local/share/myscripts/config/options}"
CONFIG_BACKUP_DIR="${CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/config/backups}"
CONFIG_TEMP_DIR="${CONFIG_TEMP_DIR:-$HOME/.local/tmp/system_scripts/config}"
CONFIG_TEMP_FILE="${CONFIG_TEMP_FILE:-$(mktemp $CONFIG_TEMP_DIR/XXXXXX 2>/dev/null)}"
CONFIG_CONFIG_FILE="${CONFIG_CONFIG_FILE:-settings.conf}"
CONFIG_GOOD_MESSAGE="${CONFIG_GOOD_MESSAGE:-Everything Went OK}"
CONFIG_ERROR_MESSAGE="${CONFIG_ERROR_MESSAGE:-Well something seems to have gone wrong}"
CONFIG_NOTIFY_ENABLED="${CONFIG_NOTIFY_ENABLED:-yes}"
CONFIG_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CONFIG_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CONFIG_NOTIFY_CLIENT_ICON}"
CONFIG_OUTPUT_COLOR="${CONFIG_OUTPUT_COLOR:-5}"
CONFIG_OUTPUT_COLOR_GOOD="${CONFIG_OUTPUT_COLOR_GOOD:-2}"
CONFIG_OUTPUT_COLOR_ERROR="${CONFIG_OUTPUT_COLOR_ERROR:-1}"
CONFIG_SYSTEM_HOME="${CONFIG_SYSTEM_HOME:-$HOME/.local/dotfiles}"
CONFIG_GIT_BARE_DIR="${CONFIG_GIT_BARE_DIR:-$HOME/.local/backups/config}"
CONFIG_SYSTEM_BACKUP_DIR="${CONFIG_SYSTEM_BACKUP_DIR:-$HOME/.local/backups/config}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$CONFIG_CONFIG_DIR/$CONFIG_CONFIG_FILE" ] && . "$CONFIG_CONFIG_DIR/$CONFIG_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$CONFIG_LOG_DIR" ] || mkdir -p "$CONFIG_LOG_DIR" &>/dev/null
[ -d "$CONFIG_TEMP_DIR" ] || mkdir -p "$CONFIG_TEMP_DIR" &>/dev/null
[ -d "$CONFIG_CACHE_DIR" ] || mkdir -p "$CONFIG_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$CONFIG_CONFIG_DIR/$CONFIG_CONFIG_FILE" ] || [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,system:,name,custom,root"
ARRAY="init,info,local,log,status,restore,remove,add,commit,checkout,remote,pull,push,set,rename,clone,bare,backup"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    CONFIG_CWD_HOME_DIR="$2"
    shift 2
    ;;
  --root)
    shift 1
    ;;
  --system)
    shift 1
    if [ "$1" = "help" ]; then
      printf_custom "41" "Allows you to keep your system settings in a git repo"
      printf_green "Usage: config --system commands"
      printf_exit "See config help for commands"
      __help
    fi
    __requiresudo true
    CONFIG_SYSTEM_NAME="$(hostname -s)"
    ;;
  --name)
    if [ -z "$1" ] || [ -z "$2" ]; then
      printf_custom "41" "This allows the use of a custom git dir"
      printf_green "Usage: config --custom $CONFIG_GIT_BARE_DIR commands"
      printf_exit "See config help for commands"
      exit 1
    fi
    CONFIG_SYSTEM_NAME="$2"
    if [ -d "$CONFIG_GIT_BARE_DIR" ]; then
      printf_yellow "Warning: $CONFIG_GIT_BARE_DIR already in use"
      printf_read_question "Are you sure you want to continue using this repo? " "1" || exit 1
    fi
    shift 2
    ;;
  --custom)
    if [ -z "$2" ] || [ -z "$3" ] || [ -z "$4" ]; then
      printf_custom "41" "This allows the use of a custom git dir and home dir"
      printf_green "Usage: config --custom $CONFIG_GIT_BARE_DIR $CONFIG_SYSTEM_HOME commands"
      printf_exit "See config help for commands"
    fi
    CONFIG_CWD_BARE_DIR="$2"
    CONFIG_CWD_HOME_DIR="$3"
    shift 3
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$CONFIG_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${CONFIG_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${CONFIG_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${CONFIG_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${CONFIG_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
CONFIG_CWD_HOME_DIR="${CONFIG_CWD_HOME_DIR:-$CONFIG_SYSTEM_HOME/$CONFIG_SYSTEM_NAME}"                           # Git working dir
CONFIG_CWD_BARE_DIR="${CONFIG_CWD_BARE_DIR:-$CONFIG_GIT_BARE_DIR/$CONFIG_SYSTEM_NAME}"                          # Git bare dir
CONFIG_CWD_BACKUP_DIR="${CONFIG_CWD_BACKUP_DIR:-$CONFIG_SYSTEM_BACKUP_DIR/$CONFIG_SYSTEM_NAME/$(date +'%Y%m')}" # Git backup dir
mkdir -p "$CONFIG_CWD_HOME_DIR" "$CONFIG_CWD_BACKUP_DIR" &>/dev/null
[[ -d "$gitDir" ]] || git_init "$*"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
init)
  shift 1
  git_init "$*"
  ;;

info)
  shift 1
  printf_blue "Git bare dir is $CONFIG_CWD_BARE_DIR"
  printf_blue "Git Working dir is $CONFIG_CWD_HOME_DIR"
  printf_blue "Git backup dir is $CONFIG_CWD_BACKUP_DIR"
  _stow status
  exit
  ;;
local)
  shift 1
  _stow config --local "$@"
  ;;

log | l)
  shift 1
  _stow log --graph --pretty=custom "$@"
  exit
  ;;

status | s)
  shift 1
  _stow status -s -b "$@"
  exit
  ;;

restore | reset)
  shift 1
  _stow reset -- "$@"
  ;;

rm | remove)
  shift 1
  _stow rm -q -r --cached -f "$@"
  ;;

add | stow)
  shift 1
  printf_green "'🏠🐜❗ Adding files to repo - this may take a moment 🏠🐜❗'"
  _add "$*"
  [ $? = 0 ] && printf_green "Don't forget to run config commit"
  #_stow commit -q -m "'🏠🐜❗ Added Files 🏠🐜❗'"
  ;;

commit)
  shift 1
  printf_green "'🏠🐜❗ Committing files to repo 🏠🐜❗'"
  _stow commit -q -m "'🏠🐜❗ Added files to repo 🏠🐜❗'"
  ;;

checkout)
  shift 1
  _checkout "$*"
  ;;

remote)
  shift 1
  if _online_check; then
    git_remote "$*"
  fi
  ;;

pull)
  shift 1
  if _online_check; then
    _stow pull "$*"
  fi
  ;;

push)
  shift 1
  if _online_check; then
    _stow push "$*" || _stow push --set-upstream origin master "$@"
  fi
  ;;

set)
  shift 1
  _stow config "$*"
  exit $?
  ;;

rename)
  shift 1
  [[ "$1" = "help" ]] && printf_exit 1 2 "Usage: $APPNAME rename fromBranch toBranch - $APPNAME rename master main"
  fromBranch="${1:-master}"
  toBranch="${2:-main}"
  _stow branch -m $fromBranch $toBranch
  _stow fetch origin
  _stow branch -u origin/$fromBranch $toBranch
  _stow remote set-head origin -a
  _stow push --set-upstream origin $toBranch
  _stow branch -d "$fromBranch"
  exit $?
  ;;

clone)
  shift 1
  git clone "$1" "$2" -q
  exit $?
  ;;

bare)
  shift 1
  ARGS="$*"
  _bare $ARGS
  exit $?
  ;;

backup)
  shift 1
  _backup
  exit $?
  ;;

*)
  shift 0
  [ -n "$1" ] && _stow "$@" || __help
  exit $?
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
