#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108220416-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$CURRENCY_TEMP_FILE" ] && rm -Rf "$CURRENCY_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108220416-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : currency --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Sunday, Aug 22, 2021 04:16 EDT
# @File          : currency
# @Description   :
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$CURRENCY_CONFIG_DIR/$CURRENCY_CONFIG_FILE"
  [ -d "$CURRENCY_CONFIG_DIR" ] || mkdir -p "$CURRENCY_CONFIG_DIR"
  [ -d "$CURRENCY_CONFIG_BACKUP_DIR" ] || mkdir -p "$CURRENCY_CONFIG_BACKUP_DIR"
  [ -f "$CURRENCY_CONFIG_DIR/$CURRENCY_CONFIG_FILE" ] &&
    cp -Rf "$CURRENCY_CONFIG_DIR/$CURRENCY_CONFIG_FILE" "$CURRENCY_CONFIG_BACKUP_DIR/$CURRENCY_CONFIG_FILE.$$"
  cat <<EOF >"$CURRENCY_CONFIG_DIR/$CURRENCY_CONFIG_FILE"
# Settings for currency
CURRENCY_DEFAULT="${CURRENCY_DEFAULT:-USD}"
CURRENCY_API_HOST="${CURRENCY_API_HOST:-rate.sx}"
CURRENCY_API_OPTIONS="${CURRENCY_API_OPTIONS:-?qF}"

# Notification settings
CURRENCY_GOOD_MESSAGE="${CURRENCY_GOOD_MESSAGE:-Everything Went OK}"
CURRENCY_ERROR_MESSAGE="${CURRENCY_ERROR_MESSAGE:-Well that didn\'t work}"
CURRENCY_NOTIFY_ENABLED="${CURRENCY_NOTIFY_ENABLED:-yes}"
CURRENCY_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CURRENCY_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CURRENCY_NOTIFY_CLIENT_ICON}"

# Colorization settings
CURRENCY_OUTPUT_COLOR="${CURRENCY_OUTPUT_COLOR:-5}"
CURRENCY_OUTPUT_COLOR_GOOD="${CURRENCY_OUTPUT_COLOR_GOOD:-2}"
CURRENCY_OUTPUT_COLOR_ERROR="${CURRENCY_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$CURRENCY_CONFIG_DIR/$CURRENCY_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for currency has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__lookup() { curl -q -LSs "${1:-$CURRENCY_API_HOST}" 2>/dev/null || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
CURRENCY_LOG_DIR="${CURRENCY_LOG_DIR:-$HOME/.local/log/currency}"
CURRENCY_CACHE_DIR="${CURRENCY_CACHE_DIR:-$HOME/.cache/currency}"
CURRENCY_CONFIG_DIR="${CURRENCY_CONFIG_DIR:-$HOME/.config/myscripts/currency}"
CURRENCY_CONFIG_BACKUP_DIR="${CURRENCY_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/currency/backups}"
CURRENCY_TEMP_DIR="${CURRENCY_TEMP_DIR:-$HOME/.local/tmp/system_scripts/currency}"
CURRENCY_OPTIONS_DIR="${CURRENCY_OPTIONS_DIR:-$HOME/.local/share/myscripts/currency/options}"
CURRENCY_TEMP_FILE="${CURRENCY_TEMP_FILE:-$(mktemp $CURRENCY_TEMP_DIR/XXXXXX 2>/dev/null)}"
CURRENCY_CONFIG_FILE="${CURRENCY_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
CURRENCY_OUTPUT_COLOR="${CURRENCY_OUTPUT_COLOR:-4}"
CURRENCY_OUTPUT_COLOR_2="${CURRENCY_OUTPUT_COLOR:-6}"
CURRENCY_OUTPUT_COLOR_GOOD="${CURRENCY_OUTPUT_COLOR_GOOD:-2}"
CURRENCY_OUTPUT_COLOR_ERROR="${CURRENCY_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
CURRENCY_GOOD_MESSAGE="${CURRENCY_GOOD_MESSAGE:-Everything Went OK}"
CURRENCY_ERROR_MESSAGE="${CURRENCY_ERROR_MESSAGE:-Well that didn\'t work}"
CURRENCY_NOTIFY_ENABLED="${CURRENCY_NOTIFY_ENABLED:-yes}"
CURRENCY_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
CURRENCY_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$CURRENCY_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
CURRENCY_DEFAULT="${CURRENCY_DEFAULT:-USD}"
CURRENCY_API_HOST="${CURRENCY_API_HOST:-rate.sx}"
CURRENCY_API_OPTIONS="${CURRENCY_API_OPTIONS:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$CURRENCY_CONFIG_DIR/$CURRENCY_CONFIG_FILE" ] && . "$CURRENCY_CONFIG_DIR/$CURRENCY_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$CURRENCY_LOG_DIR" ] || mkdir -p "$CURRENCY_LOG_DIR" &>/dev/null
[ -d "$CURRENCY_TEMP_DIR" ] || mkdir -p "$CURRENCY_TEMP_DIR" &>/dev/null
[ -d "$CURRENCY_CACHE_DIR" ] || mkdir -p "$CURRENCY_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$CURRENCY_CONFIG_DIR/$CURRENCY_CONFIG_FILE" ] || INIT_CONFIG=TRUE __gen_config "${SETARGS:-$*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    CURRENCY_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$CURRENCY_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${CURRENCY_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${CURRENCY_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${CURRENCY_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${CURRENCY_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1            # exit 1 if not found
am_i_online --error "$CURRENCY_API_HOST" || exit 1 # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
convert)
  shift 1
  amount="${1:-1}"
  fromCur="${2:-$CURRENCY_DEFAULT}"
  toCur="${3:-EUR}"
  result="$(printf "%.2f" $(__lookup "${toCur}.$CURRENCY_API_HOST/${amount}${fromCur}"))"
  printf_blue "${amount} ${fromCur} is ${result} ${toCur}"
  ;;

list)
  shift 1
  result="$(__lookup "$CURRENCY_API_HOST/:currencies")"
  printf_blue "Found the following currencies"
  echo "$result" | printf_column $CURRENCY_OUTPUT_COLOR
  ;;

crypto)
  shift 1
  result="$(__lookup "$CURRENCY_API_HOST/:coins")"
  printf_blue "Below is a very long list of crypto currencies"
  echo "$result" | grep -E "${1:-^}" | printf_column $CURRENCY_OUTPUT_COLOR
  printf_cyan "Reduce the results by searching - $APPNAME crypto [searchTerm]"
  ;;

"${1}" | *)
  url="$(echo "${1:-$CURRENCY_DEFAULT}.$CURRENCY_API_HOST" | awk '{print tolower($0)}')"
  __lookup "${url}/${2:-$CURRENCY_API_OPTIONS}"
  printf_blue "Showing the data from ${url}"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
