# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_available() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$DDV_CONFIG_DIR/$DDV_CONFIG_FILE"
  [ -d "$DDV_CONFIG_DIR" ] || mkdir -p "$DDV_CONFIG_DIR"
  [ -d "$DDV_CONFIG_BACKUP_DIR" ] || mkdir -p "$DDV_CONFIG_BACKUP_DIR"
  [ -f "$DDV_CONFIG_DIR/$DDV_CONFIG_FILE" ] &&
    cp -Rf "$DDV_CONFIG_DIR/$DDV_CONFIG_FILE" "$DDV_CONFIG_BACKUP_DIR/$DDV_CONFIG_FILE.$$"
  cat <<EOF >"$DDV_CONFIG_DIR/$DDV_CONFIG_FILE"
# Settings for ddv

# Notification settings
DDV_GOOD_MESSAGE="${DDV_GOOD_MESSAGE:-Everything Went OK}"
DDV_ERROR_MESSAGE="${DDV_ERROR_MESSAGE:-Well that didn\'t work}"
DDV_NOTIFY_ENABLED="${DDV_NOTIFY_ENABLED:-yes}"
DDV_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$PROG}"
DDV_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DDV_NOTIFY_CLIENT_ICON}"

EOF
  if [ -f "$DDV_CONFIG_DIR/$DDV_CONFIG_FILE" ]; then
    printf_green "Your config file for ddv has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
_sf_set_header() { # {{{
  _s_show="$_s_first_dir"
  _sf_show 0 $((_s_cols - 3))
  local a_dir="$_s_show"
  _s_show="$_s_second_dir"
  _sf_show 0 $((_s_cols - 3))
  local b_dir="$_s_show"
  _s_header=""
  if [ $_s_noheader = 1 -o $_s_lines -lt 10 ]; then
    return
  elif [ $_s_cols -ge 66 ]; then
    _s_header=" $_s_n files are different in
<:$a_dir
>:$b_dir
 [n]j(n-down), [n]k(n-up), gg(top), G(bottom), [n]gg/G, (go to n)
 ^D(lf page down), ^U(Half page up), ^F(Page down), ^B(Page Up)
 d(delete from the list), Enter/Space(vim diff), q(quit)"
  elif [ $_s_cols -ge 40 ]; then
    _s_header=" $_s_n values in total
a:$a_dir
b:$b_dir
 vimike updown, e.g)j:down, k:up, gg/G
 d(delete from the list),
 Enter/Space(vim diff), q(quit)"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_sf_execute() {
  :
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_sf_select() {
  vim -d "$_s_first_dir/${_s_inputs[$_s_current_n]}" \
    "$_s_second_dir/${_s_inputs[$_s_current_n]}" </dev/tty
  tput civis >/dev/tty 2>/dev/null || tput vi >/dev/tty 2>/dev/null
  _sf_rm_del
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
DDV_CACHE_DIR="${DDV_CACHE_DIR:-$HOME/.cache/ddv}"
DDV_CONFIG_DIR="${DDV_CONFIG_DIR:-$HOME/.config/myscripts/ddv}"
DDV_OPTIONS_DIR="${DDV_OPTIONS_DIR:-$HOME/.local/share/myscripts/ddv/options}"
DDV_CONFIG_BACKUP_DIR="${DDV_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/ddv/backups}"
DDV_TEMP_DIR="${DDV_TEMP_DIR/system_scripts/ddv:-$HOME/.local/tmp/system_scripts/ddv}"
DDV_TEMP_FILE="${DDV_TEMP_DIR:-$HOME/.local/tmp/ddv}"
DDV_CONFIG_FILE="${DDV_CONFIG_FILE:-settings.conf}"
DDV_GOOD_MESSAGE="${DDV_GOOD_MESSAGE:-Everything Went OK}"
DDV_ERROR_MESSAGE="${DDV_ERROR_MESSAGE:-Well that didn\'t work}"
DDV_NOTIFY_ENABLED="${DDV_NOTIFY_ENABLED:-yes}"
DDV_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DDV_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DDV_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DDV_TEMP_DIR" ] || mkdir -p "$DDV_TEMP_DIR" &>/dev/null
[ -d "$DDV_CACHE_DIR" ] || mkdir -p "$DDV_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$DDV_CONFIG_DIR/$DDV_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DDV_CONFIG_DIR/$DDV_CONFIG_FILE" ] &&
  . "$DDV_CONFIG_DIR/$DDV_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h,z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_available "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_available "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_available "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  -v | --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  -c | --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    shift 1
    GEN_SCRIPT_REPLACE_CWD="$1"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DDV_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DDV_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DDV_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DDV_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DDV_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash || exit 1 # exit 1 if not found
#am_i_online --error || exit       # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
. sentaku -n
_SENTAKU_SEPARATOR=$'\n'

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
opt=""
if [ "$1" = "-w" ]; then
  opt=$1
  shift
fi

if [ $# -ne 2 ]; then
  printf_red "usage: basename($0) [-n] dir1 dir2"
  printf_red "-w: Ignore all spaces (--ignore-blank-lines -w)"
  exit 1
fi
_s_first_dir="${1%/}/"
_s_second_dir="${2%/}/"

if [ ! -d "$_s_first_dir" ] || [ ! -d "$_s_second_dir" ]; then
  "$_s_first_dir" or "$_s_second_dir" is not a directory.
  exit 1
fi

#echo "diff $opt -rq \"$_s_first_dir\" \"$_s_second_dir\" |grep \"^Files\" |grep -v "\.svn\/"| grep -v "\.git\/"|grep -v ^Binary| sed \"s|.*${_s_second_dir}||g\"|sed \"s| differ$||\""
diff_ret=$(diff $opt -rq "$_s_first_dir" "$_s_second_dir" | grep "^Files" | grep -v .svn | grep -v .git | grep -v Binary |
  sed "s|.*${_s_second_dir}||g" | sed "s| differ$||")
if [ "$diff_ret" = "" ]; then
  echo "There are no remained diff files"
else
  echo "$diff_ret" | _sf_main
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
