#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$DECRYPT_TEMP_FILE" ] && rm -Rf "$DECRYPT_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : decrypt --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : decrypt
# @Description   : perl oneliner to decrypt files
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$DECRYPT_CONFIG_DIR/$DECRYPT_CONFIG_FILE"
  [ -d "$DECRYPT_CONFIG_DIR" ] || mkdir -p "$DECRYPT_CONFIG_DIR"
  [ -d "$DECRYPT_CONFIG_BACKUP_DIR" ] || mkdir -p "$DECRYPT_CONFIG_BACKUP_DIR"
  [ -f "$DECRYPT_CONFIG_DIR/$DECRYPT_CONFIG_FILE" ] &&
    cp -Rf "$DECRYPT_CONFIG_DIR/$DECRYPT_CONFIG_FILE" "$DECRYPT_CONFIG_BACKUP_DIR/$DECRYPT_CONFIG_FILE.$$"
  cat <<EOF >"$DECRYPT_CONFIG_DIR/$DECRYPT_CONFIG_FILE"
# Settings for decrypt

# Notification settings
DECRYPT_GOOD_MESSAGE="${DECRYPT_GOOD_MESSAGE:-Everything Went OK}"
DECRYPT_ERROR_MESSAGE="${DECRYPT_ERROR_MESSAGE:-Well that didn\'t work}"
DECRYPT_NOTIFY_ENABLED="${DECRYPT_NOTIFY_ENABLED:-yes}"
DECRYPT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DECRYPT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DECRYPT_NOTIFY_CLIENT_ICON}"

# Colorization settings
DECRYPT_OUTPUT_COLOR="${DECRYPT_OUTPUT_COLOR:-5}"
DECRYPT_OUTPUT_COLOR_GOOD="${DECRYPT_OUTPUT_COLOR_GOOD:-2}"
DECRYPT_OUTPUT_COLOR_ERROR="${DECRYPT_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DECRYPT_CONFIG_DIR/$DECRYPT_CONFIG_FILE" ]; then
    printf_green "Your config file for decrypt has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
DECRYPT_LOG_DIR="${DECRYPT_LOG_DIR:-$HOME/.local/log/decrypt}"
DECRYPT_CACHE_DIR="${DECRYPT_CACHE_DIR:-$HOME/.cache/decrypt}"
DECRYPT_CONFIG_DIR="${DECRYPT_CONFIG_DIR:-$HOME/.config/myscripts/decrypt}"
DECRYPT_CONFIG_BACKUP_DIR="${DECRYPT_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/decrypt/backups}"
DECRYPT_TEMP_DIR="${DECRYPT_TEMP_DIR:-$HOME/.local/tmp/system_scripts/decrypt}"
DECRYPT_OPTIONS_DIR="${DECRYPT_OPTIONS_DIR:-$HOME/.local/share/myscripts/decrypt/options}"
DECRYPT_TEMP_FILE="${DECRYPT_TEMP_FILE:-$(mktemp $DECRYPT_TEMP_DIR/XXXXXX 2>/dev/null)}"
DECRYPT_CONFIG_FILE="${DECRYPT_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
DECRYPT_OUTPUT_COLOR="${DECRYPT_OUTPUT_COLOR:-4}"
DECRYPT_OUTPUT_COLOR_2="${DECRYPT_OUTPUT_COLOR:-6}"
DECRYPT_OUTPUT_COLOR_GOOD="${DECRYPT_OUTPUT_COLOR_GOOD:-2}"
DECRYPT_OUTPUT_COLOR_ERROR="${DECRYPT_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
DECRYPT_GOOD_MESSAGE="${DECRYPT_GOOD_MESSAGE:-Everything Went OK}"
DECRYPT_ERROR_MESSAGE="${DECRYPT_ERROR_MESSAGE:-Well that didn\'t work}"
DECRYPT_NOTIFY_ENABLED="${DECRYPT_NOTIFY_ENABLED:-yes}"
DECRYPT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DECRYPT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DECRYPT_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DECRYPT_CONFIG_DIR/$DECRYPT_CONFIG_FILE" ] && . "$DECRYPT_CONFIG_DIR/$DECRYPT_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DECRYPT_LOG_DIR" ] || mkdir -p "$DECRYPT_LOG_DIR" &>/dev/null
[ -d "$DECRYPT_TEMP_DIR" ] || mkdir -p "$DECRYPT_TEMP_DIR" &>/dev/null
[ -d "$DECRYPT_CACHE_DIR" ] || mkdir -p "$DECRYPT_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$DECRYPT_CONFIG_DIR/$DECRYPT_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    DECRYPT_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DECRYPT_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DECRYPT_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DECRYPT_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DECRYPT_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DECRYPT_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash perl || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ -t 0 ]; then
  fname="$1"
  shift $#
  if openssl aes-256-cbc -pbkdf2 -d -in "$fname" -out "${fname%\.*}" "$@" 2>/dev/null; then
    printf_green "Successfuly decrypted $1"
  else
    printf_return "Something went wrong: check your password"
  fi
else
  perl -e 'use IO::Select; $ready=IO::Select->new(STDIN)->can_read();'
  if openssl aes-256-cbc -pbkdf2 -d "$@" 2>/dev/null; then
    printf_green "Successfuly decrypted $1"
  else
    printf_return "Something went wrong: check your password"
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
