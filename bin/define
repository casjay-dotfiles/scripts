#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : define --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : define
# @Description   : Script to lookup definition of words using dict
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$DEFINE_TEMP_FILE" ] && [ -f "$DEFINE_TEMP_FILE" ] && rm -Rf "$DEFINE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$DEFINE_CONFIG_DIR/$DEFINE_CONFIG_FILE"
  [ -d "$DEFINE_CONFIG_DIR" ] || mkdir -p "$DEFINE_CONFIG_DIR"
  [ -d "$DEFINE_CONFIG_BACKUP_DIR" ] || mkdir -p "$DEFINE_CONFIG_BACKUP_DIR"
  [ -f "$DEFINE_CONFIG_DIR/$DEFINE_CONFIG_FILE" ] &&
    cp -Rf "$DEFINE_CONFIG_DIR/$DEFINE_CONFIG_FILE" "$DEFINE_CONFIG_BACKUP_DIR/$DEFINE_CONFIG_FILE.$$"
  cat <<EOF >"$DEFINE_CONFIG_DIR/$DEFINE_CONFIG_FILE"
# Settings for define
DEFINE_SERVER_HOST="${DEFINE_SERVER_HOST:-dict.org}"
DEFINE_SERVER_PORT="${DEFINE_SERVER_PORT:-2628}"
DEFINE_PING_URL="${DEFINE_PING_URL:-8.8.8.8}"

# Notification settings
DEFINE_GOOD_MESSAGE="${DEFINE_GOOD_MESSAGE:-Everything Went OK}"
DEFINE_ERROR_MESSAGE="${DEFINE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DEFINE_NOTIFY_ENABLED="${DEFINE_NOTIFY_ENABLED:-yes}"
DEFINE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DEFINE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DEFINE_NOTIFY_CLIENT_ICON}"

# Colorization settings
DEFINE_OUTPUT_COLOR="${DEFINE_OUTPUT_COLOR:-5}"
DEFINE_OUTPUT_COLOR_GOOD="${DEFINE_OUTPUT_COLOR_GOOD:-2}"
DEFINE_OUTPUT_COLOR_ERROR="${DEFINE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DEFINE_CONFIG_DIR/$DEFINE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for define has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__lookup() {
  dict -h ${DEFINE_SERVER_HOST} -p ${DEFINE_SERVER_PORT} -d gcide "$1" 2>/dev/null |
    grep -v 'No definitions found' | sed '/^$/d' | sed 's#From The Collaborative International.*##g'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
DEFINE_LOG_DIR="${DEFINE_LOG_DIR:-$HOME/.local/log/define}"
DEFINE_CACHE_DIR="${DEFINE_CACHE_DIR:-$HOME/.cache/define}"
DEFINE_CONFIG_DIR="${DEFINE_CONFIG_DIR:-$HOME/.config/myscripts/define}"
DEFINE_CONFIG_BACKUP_DIR="${DEFINE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/define/backups}"
DEFINE_TEMP_DIR="${DEFINE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/define}"
DEFINE_OPTIONS_DIR="${DEFINE_OPTIONS_DIR:-$HOME/.local/share/myscripts/define/options}"
DEFINE_TEMP_FILE="${DEFINE_TEMP_FILE:-$(mktemp $DEFINE_TEMP_DIR/XXXXXX 2>/dev/null)}"
DEFINE_CONFIG_FILE="${DEFINE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
DEFINE_OUTPUT_COLOR="${DEFINE_OUTPUT_COLOR:-4}"
DEFINE_OUTPUT_COLOR_2="${DEFINE_OUTPUT_COLOR:-6}"
DEFINE_OUTPUT_COLOR_GOOD="${DEFINE_OUTPUT_COLOR_GOOD:-2}"
DEFINE_OUTPUT_COLOR_ERROR="${DEFINE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
DEFINE_GOOD_MESSAGE="${DEFINE_GOOD_MESSAGE:-Everything Went OK}"
DEFINE_ERROR_MESSAGE="${DEFINE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DEFINE_NOTIFY_ENABLED="${DEFINE_NOTIFY_ENABLED:-yes}"
DEFINE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DEFINE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DEFINE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
DEFINE_SERVER_HOST="${DEFINE_SERVER_HOST:-dict.org}"
DEFINE_SERVER_PORT="${DEFINE_SERVER_PORT:-2628}"
DEFINE_PING_URL="${DEFINE_PING_URL:-8.8.8.8}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DEFINE_CONFIG_DIR/$DEFINE_CONFIG_FILE" ] && . "$DEFINE_CONFIG_DIR/$DEFINE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DEFINE_LOG_DIR" ] || mkdir -p "$DEFINE_LOG_DIR" &>/dev/null
[ -d "$DEFINE_TEMP_DIR" ] || mkdir -p "$DEFINE_TEMP_DIR" &>/dev/null
[ -d "$DEFINE_CACHE_DIR" ] || mkdir -p "$DEFINE_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$DEFINE_CONFIG_DIR/$DEFINE_CONFIG_FILE" ] || [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    DEFINE_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DEFINE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DEFINE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DEFINE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DEFINE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DEFINE_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash dict || exit 1     # exit 1 if not found
am_i_online --error "$DEFINE_PING_URL" || exit 1 # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
results="$(__lookup "$1")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [[ -n "$results" ]]; then
  echo "$results" | printf_readline "$DEFINE_OUTPUT_COLOR"
  __notifications "$results"
else
  printf_red "Nothing was found for $1"
  __notifications "Nothing was found for $1"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
