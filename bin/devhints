#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : devhints.io --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : devhints.io
# @Description   : search devhints.io
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$DEVHINTS_TEMP_FILE" ] && [ -f "$DEVHINTS_TEMP_FILE" ] && rm -Rf "$DEVHINTS_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$DEVHINTS_CONFIG_DIR/$DEVHINTS_CONFIG_FILE"
  [ -d "$DEVHINTS_CONFIG_DIR" ] || mkdir -p "$DEVHINTS_CONFIG_DIR"
  [ -d "$DEVHINTS_CONFIG_BACKUP_DIR" ] || mkdir -p "$DEVHINTS_CONFIG_BACKUP_DIR"
  [ -f "$DEVHINTS_CONFIG_DIR/$DEVHINTS_CONFIG_FILE" ] &&
    cp -Rf "$DEVHINTS_CONFIG_DIR/$DEVHINTS_CONFIG_FILE" "$DEVHINTS_CONFIG_BACKUP_DIR/$DEVHINTS_CONFIG_FILE.$$"
  cat <<EOF >"$DEVHINTS_CONFIG_DIR/$DEVHINTS_CONFIG_FILE"
# Settings for devhints.io
DEVHINTS_URL_RAW="${DEVHINTS_URL_RAW:-https://github.com/rstacruz/cheatsheets/raw/master}"
DEVHINTS_URL_API="${DEVHINTS_URL_API:-https://api.github.com/repos/rstacruz/cheatsheets/contents}"

# Notification settings
DEVHINTS_GOOD_MESSAGE="${DEVHINTS_GOOD_MESSAGE:-Everything Went OK}"
DEVHINTS_ERROR_MESSAGE="${DEVHINTS_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DEVHINTS_NOTIFY_ENABLED="${DEVHINTS_NOTIFY_ENABLED:-yes}"
DEVHINTS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DEVHINTS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DEVHINTS_NOTIFY_CLIENT_ICON}"

# Colorization settings
DEVHINTS_OUTPUT_COLOR="${DEVHINTS_OUTPUT_COLOR:-5}"
DEVHINTS_OUTPUT_COLOR_GOOD="${DEVHINTS_OUTPUT_COLOR_GOOD:-2}"
DEVHINTS_OUTPUT_COLOR_ERROR="${DEVHINTS_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DEVHINTS_CONFIG_DIR/$DEVHINTS_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for devhints.io has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      exit 1
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
find_tools() {
  wget -qO- --server-response=no -nv "${1:-$RAW_MD_URL}" | sed -e '/^{: /d' >"$LOCAL_CACHE_FILE"
  [ -s $LOCAL_CACHE_FILE ] || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__find_api() { curl -q -LSs "$DEVHINTS_URL_API" | jq -r '.[].name' | grep '\.md' | sed 's|\.md||g' | grep '^'; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
DEVHINTS_LOG_DIR="${DEVHINTS_LOG_DIR:-$HOME/.local/log/devhints}"
DEVHINTS_CACHE_DIR="${DEVHINTS_CACHE_DIR:-$HOME/.cache/devhints}"
DEVHINTS_CONFIG_DIR="${DEVHINTS_CONFIG_DIR:-$HOME/.config/myscripts/devhints}"
DEVHINTS_CONFIG_BACKUP_DIR="${DEVHINTS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/devhints/backups}"
DEVHINTS_TEMP_DIR="${DEVHINTS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/devhints}"
DEVHINTS_OPTIONS_DIR="${DEVHINTS_OPTIONS_DIR:-$HOME/.local/share/myscripts/devhints/options}"
DEVHINTS_TEMP_FILE="${DEVHINTS_TEMP_FILE:-$(mktemp $DEVHINTS_TEMP_DIR/XXXXXX 2>/dev/null)}"
DEVHINTS_CONFIG_FILE="${DEVHINTS_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
DEVHINTS_OUTPUT_COLOR="${DEVHINTS_OUTPUT_COLOR:-4}"
DEVHINTS_OUTPUT_COLOR_2="${DEVHINTS_OUTPUT_COLOR:-6}"
DEVHINTS_OUTPUT_COLOR_GOOD="${DEVHINTS_OUTPUT_COLOR_GOOD:-2}"
DEVHINTS_OUTPUT_COLOR_ERROR="${DEVHINTS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
DEVHINTS_GOOD_MESSAGE="${DEVHINTS_GOOD_MESSAGE:-Everything Went OK}"
DEVHINTS_ERROR_MESSAGE="${DEVHINTS_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DEVHINTS_NOTIFY_ENABLED="${DEVHINTS_NOTIFY_ENABLED:-yes}"
DEVHINTS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DEVHINTS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DEVHINTS_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
DEVHINTS_URL_RAW="${DEVHINTS_URL_RAW:-https://github.com/rstacruz/cheatsheets/raw/master}"
DEVHINTS_URL_API="${DEVHINTS_URL_API:-https://api.github.com/repos/rstacruz/cheatsheets/contents}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DEVHINTS_CONFIG_DIR/$DEVHINTS_CONFIG_FILE" ] && . "$DEVHINTS_CONFIG_DIR/$DEVHINTS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DEVHINTS_LOG_DIR" ] || mkdir -p "$DEVHINTS_LOG_DIR" &>/dev/null
[ -d "$DEVHINTS_TEMP_DIR" ] || mkdir -p "$DEVHINTS_TEMP_DIR" &>/dev/null
[ -d "$DEVHINTS_CACHE_DIR" ] || mkdir -p "$DEVHINTS_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$DEVHINTS_CONFIG_DIR/$DEVHINTS_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,refresh"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    DEVHINTS_CWD="$2"
    shift 2
    ;;
  --refresh)
    shift 1
    FORCE_REFRESH="true"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DEVHINTS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DEVHINTS_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DEVHINTS_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DEVHINTS_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DEVHINTS_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash wget mdless jq || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
RAW_MD_URL="$DEVHINTS_URL_RAW/${1:-bash}.md"
LOCAL_CACHE_FILE=$DEVHINTS_CACHE_DIR/${1:-bash}.md
{ [ -n "$FORCE_REFRESH" ] || [ ! -e "$LOCAL_CACHE_FILE" ]; } && find_tools
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
list)
  shift 1
  __find_api | printf_column $DEVHINTS_OUTPUT_COLOR
  ;;

search)
  shift 1
  results="$(__find_api | grep -i "${1:-help}")"
  if [[ -n "$results" ]]; then
    printf_blue "Found the following:"
    echo "$results" | printf_column $DEVHINTS_OUTPUT_COLOR
  else
    printf_exit "No results fount for $1"
  fi
  ;;

*)
  printf_green "Finding the results for ${1:-bash}"
  printf_blue "This may take a few moments............."
  if find_tools "$RAW_MD_URL"; then
    mdless $LOCAL_CACHE_FILE 2>/dev/null
  else
    printf_red "No cheat sheet found!"
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
