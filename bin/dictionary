#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108181957-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : dictionary --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Aug 18, 2021 19:57 EDT
# @File          : dictionary
# @Description   : Thesaurus
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108181957-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$DICTIONARY_CONFIG_DIR/$DICTIONARY_CONFIG_FILE"
  [ -d "$DICTIONARY_CONFIG_DIR" ] || mkdir -p "$DICTIONARY_CONFIG_DIR"
  [ -d "$DICTIONARY_CONFIG_BACKUP_DIR" ] || mkdir -p "$DICTIONARY_CONFIG_BACKUP_DIR"
  [ -f "$DICTIONARY_CONFIG_DIR/$DICTIONARY_CONFIG_FILE" ] &&
    cp -Rf "$DICTIONARY_CONFIG_DIR/$DICTIONARY_CONFIG_FILE" "$DICTIONARY_CONFIG_BACKUP_DIR/$DICTIONARY_CONFIG_FILE.$$"
  cat <<EOF >"$DICTIONARY_CONFIG_DIR/$DICTIONARY_CONFIG_FILE"
# Settings for dictionary
DICTIONARY_SERVER_LANG="${DICTIONARY_SERVER_LANG:-en}"
DICTIONARY_SERVER_HOST="${DICTIONARY_SERVER_HOST:-https://api.dictionaryapi.dev/api}"

# Notification settings
DICTIONARY_GOOD_MESSAGE="${DICTIONARY_GOOD_MESSAGE:-Everything Went OK}"
DICTIONARY_ERROR_MESSAGE="${DICTIONARY_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DICTIONARY_NOTIFY_ENABLED="${DICTIONARY_NOTIFY_ENABLED:-yes}"
DICTIONARY_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DICTIONARY_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DICTIONARY_NOTIFY_CLIENT_ICON}"

# Colorization settings
DICTIONARY_OUTPUT_COLOR="${DICTIONARY_OUTPUT_COLOR:-5}"
DICTIONARY_OUTPUT_COLOR_GOOD="${DICTIONARY_OUTPUT_COLOR_GOOD:-2}"
DICTIONARY_OUTPUT_COLOR_ERROR="${DICTIONARY_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DICTIONARY_CONFIG_DIR/$DICTIONARY_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__origin() {
  res="$(curl -q -LSs "$DICTIONARY_SERVER_HOST/v2/entries/$DICTIONARY_SERVER_LANG/${1}" | jq -r .[]'.origin' 2>/dev/null || echo)"
  [ -n "$res" ] && echo "$res" || return
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__definition() {
  res="$(curl -q -LSs --fail "$DICTIONARY_SERVER_HOST/v2/entries/$DICTIONARY_SERVER_LANG/${1}" | jq -r '.[].meanings | .[].definitions | .[].definition' 2>/dev/null || echo)"
  [ -n "$res" ] && echo "$res" || return
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__synonyms() {
  res="$(curl -q -LSs --fail "$DICTIONARY_SERVER_HOST/v2/entries/$DICTIONARY_SERVER_LANG/${1}" | jq -r '.[].meanings | .[].definitions | .[].synonyms | .[]' | tr ' ' '\n' | sort -u | tr '\n' ' ' || echo)"
  [ -n "$res" ] && echo "$res" || return
}
__display() {
  if [ "$DICTIONARY_TEMP_FILE" ] && [ -s "$DICTIONARY_TEMP_FILE" ]; then
    cat "$DICTIONARY_TEMP_FILE" | printf_readline "$DICTIONARY_OUTPUT_COLOR"
    cat "$DICTIONARY_TEMP_FILE" | __yad__text
  else
    echo "An error has occured!" | printf_readline
    echo "An error has occured!" | __yad__text
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
DICTIONARY_LOG_DIR="${DICTIONARY_LOG_DIR:-$HOME/.local/log/dictionary}"
DICTIONARY_CACHE_DIR="${DICTIONARY_CACHE_DIR:-$HOME/.cache/dictionary}"
DICTIONARY_CONFIG_DIR="${DICTIONARY_CONFIG_DIR:-$HOME/.config/myscripts/dictionary}"
DICTIONARY_CONFIG_BACKUP_DIR="${DICTIONARY_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/dictionary/backups}"
DICTIONARY_TEMP_DIR="${DICTIONARY_TEMP_DIR:-$HOME/.local/tmp/system_scripts/dictionary}"
DICTIONARY_OPTIONS_DIR="${DICTIONARY_OPTIONS_DIR:-$HOME/.local/share/myscripts/dictionary/options}"
DICTIONARY_CONFIG_FILE="${DICTIONARY_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
DICTIONARY_OUTPUT_COLOR="${DICTIONARY_OUTPUT_COLOR:-4}"
DICTIONARY_OUTPUT_COLOR_2="${DICTIONARY_OUTPUT_COLOR:-6}"
DICTIONARY_OUTPUT_COLOR_GOOD="${DICTIONARY_OUTPUT_COLOR_GOOD:-2}"
DICTIONARY_OUTPUT_COLOR_ERROR="${DICTIONARY_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
DICTIONARY_GOOD_MESSAGE="${DICTIONARY_GOOD_MESSAGE:-Everything Went OK}"
DICTIONARY_ERROR_MESSAGE="${DICTIONARY_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DICTIONARY_NOTIFY_ENABLED="${DICTIONARY_NOTIFY_ENABLED:-yes}"
DICTIONARY_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DICTIONARY_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DICTIONARY_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
DICTIONARY_SERVER_LANG="${DICTIONARY_SERVER_LANG:-en}"
DICTIONARY_SERVER_HOST="${DICTIONARY_SERVER_HOST:-https://api.dictionaryapi.dev/api}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$DICTIONARY_CONFIG_DIR/$DICTIONARY_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DICTIONARY_CONFIG_DIR/$DICTIONARY_CONFIG_FILE" ] && . "$DICTIONARY_CONFIG_DIR/$DICTIONARY_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$DICTIONARY_LOG_DIR" ] || mkdir -p "$DICTIONARY_LOG_DIR" &>/dev/null
[ -d "$DICTIONARY_TEMP_DIR" ] || mkdir -p "$DICTIONARY_TEMP_DIR" &>/dev/null
[ -d "$DICTIONARY_CACHE_DIR" ] || mkdir -p "$DICTIONARY_CACHE_DIR" &>/dev/null
DICTIONARY_TEMP_FILE="${DICTIONARY_TEMP_FILE:-$(mktemp $DICTIONARY_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$DICTIONARY_TEMP_FILE" ] && [ -f "$DICTIONARY_TEMP_FILE" ] && rm -Rf "$DICTIONARY_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$DICTIONARY_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DICTIONARY_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DICTIONARY_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DICTIONARY_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DICTIONARY_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY="origin synonym"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    DICTIONARY_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash dict || exit 1            # exit 1 if not found
am_i_online "$DICTIONARY_SERVER_HOST" --error || exit 1 # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case $1 in
synonym | s)
  shift 1
  search="$*"
  synonym="$(__synonyms "$search")"
  {
    printf 'Lookup: %s\n\n' "$search"
    [ -n "$synonym" ] && printf 'synonyms: %s\n\n' "${synonym:-none}" | tr ' ' '\n'
  } >"$DICTIONARY_TEMP_FILE"
  __display
  ;;
origin | o)
  shift 1
  search="$*"
  origin="$(__origin "$search")"
  {
    printf 'Lookup: %s\n\n' "$search"
    [ -n "$origin" ] && printf 'origin: %s\n\n' "${origin:-none}"
  } >"$DICTIONARY_TEMP_FILE"
  __display
  ;;
*)
  search="$*"
  origin="$(__origin "$search")"
  synonym="$(__synonyms "$search")"
  definition="$(__definition "$search")"
  if [ -n "$origin" ] && [ -n "$definition" ]; then
    {
      printf 'Lookup: %s\n\n' "$search"
      [ -n "$origin" ] && printf 'Origin: %s\n\n' "$origin"
      [ -n "$synonym" ] && printf 'synonyms: %s\n\n' "$synonym"
      [ -n "$definition" ] && printf 'Definition:\n%s\n' "$definition"
    } >"$DICTIONARY_TEMP_FILE"
    __display
  else
    printf_custom $DICTIONARY_OUTPUT_COLOR_ERROR "No results found for $1"
  fi
  ;;
esac
[ -f "$DICTIONARY_TEMP_FILE" ] && rm -Rf "$DICTIONARY_TEMP_FILE" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
