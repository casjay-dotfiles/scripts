#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : dmenu-usb --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : dmenu-usb
# @Description   : dmenu prompt to unmount drives
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$DMENU_USB_TEMP_FILE" ] && [ -f "$DMENU_USB_TEMP_FILE" ] && rm -Rf "$DMENU_USB_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$DMENU_USB_CONFIG_DIR/$DMENU_USB_CONFIG_FILE"
  [ -d "$DMENU_USB_CONFIG_DIR" ] || mkdir -p "$DMENU_USB_CONFIG_DIR"
  [ -d "$DMENU_USB_CONFIG_BACKUP_DIR" ] || mkdir -p "$DMENU_USB_CONFIG_BACKUP_DIR"
  [ -f "$DMENU_USB_CONFIG_DIR/$DMENU_USB_CONFIG_FILE" ] &&
    cp -Rf "$DMENU_USB_CONFIG_DIR/$DMENU_USB_CONFIG_FILE" "$DMENU_USB_CONFIG_BACKUP_DIR/$DMENU_USB_CONFIG_FILE.$$"
  cat <<EOF >"$DMENU_USB_CONFIG_DIR/$DMENU_USB_CONFIG_FILE"
# Settings for dmenu-usb

# Notification settings
DMENU_USB_GOOD_MESSAGE="${DMENU_USB_GOOD_MESSAGE:-Everything Went OK}"
DMENU_USB_ERROR_MESSAGE="${DMENU_USB_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DMENU_USB_NOTIFY_ENABLED="${DMENU_USB_NOTIFY_ENABLED:-yes}"
DMENU_USB_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DMENU_USB_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DMENU_USB_NOTIFY_CLIENT_ICON}"

# Colorization settings
DMENU_USB_OUTPUT_COLOR="${DMENU_USB_OUTPUT_COLOR:-5}"
DMENU_USB_OUTPUT_COLOR_GOOD="${DMENU_USB_OUTPUT_COLOR_GOOD:-2}"
DMENU_USB_OUTPUT_COLOR_ERROR="${DMENU_USB_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DMENU_USB_CONFIG_DIR/$DMENU_USB_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
{ builtin type -P rofi &>/dev/null && __dmenu() { rofi -theme ${ROFI_THEME:-purple} -dmenu -i -p "$1" 2>/dev/null; }; } ||
  { builtin type -P dmenu &>/dev/null && __dmenu() { dmenu -i -p "$1" 2>/dev/null; }; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__ask() {
  case $(printf "Mount\\nUnmount" | __dmenu "Would you like to mount or unmount a device?") in
  Mount) $APPNAME mount ;;
  Unmount) $APPNAME umount ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
unmountusb() {
  [ -z "$drives" ] && exit
  chosen="$(echo "$drives" | __dmenu "Unmount which drive?")" || exit 1
  chosen="$(echo "$chosen" | awk '{print $1}')"
  [ -z "$chosen" ] && exit
  sudo -A umount "$chosen" && __notifications "💻 USB unmounting" "$chosen unmounted."
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
unmountandroid() {
  chosen="$(awk '/simple-mtpfs/ {print $2}' /etc/mtab | __dmenu "Unmount which device?")" || exit 1
  [ -z "$chosen" ] && exit
  sudo -A umount -l "$chosen" && __notifications "🤖 Android unmounting" "$chosen unmounted."
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
asktype_unmount() {
  choice="$(printf "USB\\nAndroid" | __dmenu "Unmount a USB drive or Android device?")" || exit 1
  case "$choice" in
  USB) unmountusb ;;
  Android) unmountandroid ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
getmount() {
  [ -z "$chosen" ] && exit 1
  mp="$(find $1 2>/dev/null | __dmenu "Type in mount point.")"
  [ "$mp" = "" ] && exit 1
  if [ ! -d "$mp" ]; then
    mkdiryn=$(printf "No\\nYes" | __dmenu "$mp does not exist. Create it?")
    [ "$mkdiryn" = "Yes" ] && (mkdir -p "$mp" || sudo -A mkdir -p "$mp")
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
mountusb() {
  chosen="$(echo "$usbdrives" | __dmenu "Mount which drive?" | awk '{print $1}')"
  sudo -A mount "$chosen" 2>/dev/null && notifications "💻 USB mounting" "$chosen mounted." && exit 0
  alreadymounted=$(lsblk -nrpo "name,type,mountpoint" | awk '$2=="part"&&$3!~/\/boot|\/home$|SWAP/&&length($3)>1{printf "-not \\( -path *%s -prune \\) \\ \n",$3}')
  getmount "/mnt /media /mount /home -maxdepth 5 -type d $alreadymounted"
  partitiontype="$(lsblk -no "fstype" "$chosen")"
  case "$partitiontype" in
  "vfat") sudo -A mount -t vfat "$chosen" "$mp" -o rw,umask=0000 ;;
  *)
    sudo -A mount "$chosen" "$mp"
    user="$(whoami)"
    ug="$(groups | awk '{print $1}')"
    sudo -A chown "$user":"$ug" "$mp"
    ;;
  esac
  notifications "💻 USB mounting" "$chosen mounted to $mp."
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
mountandroid() {
  chosen=$(echo "$anddrives" | __dmenu "Which Android device?" | cut -d : -f 1)
  getmount "$HOME -maxdepth 3 -type d"
  simple-mtpfs --device "$chosen" "$mp"
  echo "OK" | __dmenu "Tap Allow on your phone if it asks for permission and then press enter"
  simple-mtpfs --device "$chosen" "$mp"
  notifications "🤖 Android Mounting" "Android device mounted to $mp."
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
asktype_mount() {
  case $(printf "USB\\nAndroid" | __dmenu "Mount a USB drive or Android device?") in
  USB) mountusb ;;
  Android) mountandroid ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
DMENU_USB_LOG_DIR="${DMENU_USB_LOG_DIR:-$HOME/.local/log/dmenu_usb}"
DMENU_USB_CACHE_DIR="${DMENU_USB_CACHE_DIR:-$HOME/.cache/dmenu_usb}"
DMENU_USB_CONFIG_DIR="${DMENU_USB_CONFIG_DIR:-$HOME/.config/myscripts/dmenu_usb}"
DMENU_USB_CONFIG_BACKUP_DIR="${DMENU_USB_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/dmenu_usb/backups}"
DMENU_USB_TEMP_DIR="${DMENU_USB_TEMP_DIR:-$HOME/.local/tmp/system_scripts/dmenu_usb}"
DMENU_USB_OPTIONS_DIR="${DMENU_USB_OPTIONS_DIR:-$HOME/.local/share/myscripts/dmenu_usb/options}"
DMENU_USB_TEMP_FILE="${DMENU_USB_TEMP_FILE:-$(mktemp $DMENU_USB_TEMP_DIR/XXXXXX 2>/dev/null)}"
DMENU_USB_CONFIG_FILE="${DMENU_USB_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
DMENU_USB_OUTPUT_COLOR="${DMENU_USB_OUTPUT_COLOR:-4}"
DMENU_USB_OUTPUT_COLOR_2="${DMENU_USB_OUTPUT_COLOR:-6}"
DMENU_USB_OUTPUT_COLOR_GOOD="${DMENU_USB_OUTPUT_COLOR_GOOD:-2}"
DMENU_USB_OUTPUT_COLOR_ERROR="${DMENU_USB_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
DMENU_USB_GOOD_MESSAGE="${DMENU_USB_GOOD_MESSAGE:-Everything Went OK}"
DMENU_USB_ERROR_MESSAGE="${DMENU_USB_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DMENU_USB_NOTIFY_ENABLED="${DMENU_USB_NOTIFY_ENABLED:-yes}"
DMENU_USB_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DMENU_USB_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DMENU_USB_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DMENU_USB_CONFIG_DIR/$DMENU_USB_CONFIG_FILE" ] && . "$DMENU_USB_CONFIG_DIR/$DMENU_USB_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DMENU_USB_LOG_DIR" ] || mkdir -p "$DMENU_USB_LOG_DIR" &>/dev/null
[ -d "$DMENU_USB_TEMP_DIR" ] || mkdir -p "$DMENU_USB_TEMP_DIR" &>/dev/null
[ -d "$DMENU_USB_CACHE_DIR" ] || mkdir -p "$DMENU_USB_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$DMENU_USB_CONFIG_DIR/$DMENU_USB_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    DMENU_USB_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DMENU_USB_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DMENU_USB_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DMENU_USB_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DMENU_USB_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DMENU_USB_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
drives=$(lsblk -nrpo "name,type,size,mountpoint" | awk '$4!~/\/boot|\/efi|\/home$|SWAP/&&length($4)>1{printf "%s (%s)\n",$4,$3}')
anddrives=$(simple-mtpfs -l 2>/dev/null)
usbdrives="$(lsblk -rpo "name,type,size,mountpoint" | awk '$2=="part"&&$4==""{printf "%s (%s)\n",$1,$3}')"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app

case "$1" in
mount)
  shift 1
  if [ -z "$usbdrives" ]; then
    if [ -z "$anddrives" ]; then
      printf_red "No USB drive or Android device detected"
      __notifications "No USB drive or Android device detected"
      exit 1
    else
      printf_green "Android device(s) detected."
      __notifications "Android device(s) detected."
      mountandroid
    fi
  else
    if [ -z "$anddrives" ]; then
      printf_green "USB drive(s) detected."
      __notifications "USB drive(s) detected."
      mountusb
    else
      printf_green "Mountable USB drive(s) and Android device(s) detected."
      __notifications "Mountable USB drive(s) and Android device(s) detected."
      asktype_mount
    fi
  fi
  ;;
umount | unmount)
  shift 1
  if ! grep simple-mtpfs /etc/mtab; then
    if [ -z "$drives" ]; then
      printf_red "No drives to unmount."
      __notifications "No drives to unmount."
      exit 1
    else
      printf_green "Unmountable USB drive detected."
      __notifications "Unmountable USB drive detected."
      unmountusb
    fi
  else
    if [ -z "$drives" ]; then
      printf_green "Unmountable Android device detected."
      __notifications "Unmountable Android device detected."
      unmountandroid
    else
      printf_green "Unmountable USB drive(s) and Android device(s) detected."
      __notifications "Unmountable USB drive(s) and Android device(s) detected."
      asktype_unmount
    fi
  fi
  ;;
*)
  __ask
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
