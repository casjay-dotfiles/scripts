#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -euo pipefail
trap 'exitCode=${exitCode:-$?};[ -f "$DMENUHANDLER_TEMP_FILE" ] && rm -Rf "$DMENUHANDLER_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : dmenuhandler --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : dmenuhandler
# @Description   : Feed this script a link and it will give dmenu
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$DMENUHANDLER_CONFIG_DIR/$DMENUHANDLER_CONFIG_FILE"
  [ -d "$DMENUHANDLER_CONFIG_DIR" ] || mkdir -p "$DMENUHANDLER_CONFIG_DIR"
  [ -d "$DMENUHANDLER_CONFIG_BACKUP_DIR" ] || mkdir -p "$DMENUHANDLER_CONFIG_BACKUP_DIR"
  [ -f "$DMENUHANDLER_CONFIG_DIR/$DMENUHANDLER_CONFIG_FILE" ] &&
    cp -Rf "$DMENUHANDLER_CONFIG_DIR/$DMENUHANDLER_CONFIG_FILE" "$DMENUHANDLER_CONFIG_BACKUP_DIR/$DMENUHANDLER_CONFIG_FILE.$$"
  cat <<EOF >"$DMENUHANDLER_CONFIG_DIR/$DMENUHANDLER_CONFIG_FILE"
# Settings for dmenuhandler

# Notification settings
DMENUHANDLER_GOOD_MESSAGE="${DMENUHANDLER_GOOD_MESSAGE:-Everything Went OK}"
DMENUHANDLER_ERROR_MESSAGE="${DMENUHANDLER_ERROR_MESSAGE:-Well that didn\'t work}"
DMENUHANDLER_NOTIFY_ENABLED="${DMENUHANDLER_NOTIFY_ENABLED:-yes}"
DMENUHANDLER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DMENUHANDLER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DMENUHANDLER_NOTIFY_CLIENT_ICON}"

# Colorization settings
DMENUHANDLER_OUTPUT_COLOR="${DMENUHANDLER_OUTPUT_COLOR:-5}"
DMENUHANDLER_OUTPUT_COLOR_GOOD="${DMENUHANDLER_OUTPUT_COLOR_GOOD:-2}"
DMENUHANDLER_OUTPUT_COLOR_ERROR="${DMENUHANDLER_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DMENUHANDLER_CONFIG_DIR/$DMENUHANDLER_CONFIG_FILE" ]; then
    printf_green "Your config file for dmenuhandler has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
{ builtin type -P rofi &>/dev/null && __dmenu() { rofi -dmenu -i -p "Open link with what program?" -theme purple 2>/dev/null; }; } ||
  { builtin type -P dmenu &>/dev/null && __dmenu() { dmenu -i -p "Open link with what program?" 2>/dev/null; }; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
DMENUHANDLER_CACHE_DIR="${DMENUHANDLER_CACHE_DIR:-$HOME/.cache/dmenuhandler}"
DMENUHANDLER_CONFIG_DIR="${DMENUHANDLER_CONFIG_DIR:-$HOME/.config/myscripts/dmenuhandler}"
DMENUHANDLER_OPTIONS_DIR="${DMENUHANDLER_OPTIONS_DIR:-$HOME/.local/share/myscripts/dmenuhandler/options}"
DMENUHANDLER_CONFIG_BACKUP_DIR="${DMENUHANDLER_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/dmenuhandler/backups}"
DMENUHANDLER_TEMP_DIR="${DMENUHANDLER_TEMP_DIR:-$HOME/.local/tmp/system_scripts/dmenuhandler}"
DMENUHANDLER_TEMP_FILE="${DMENUHANDLER_TEMP_FILE:-$(mktemp $DMENUHANDLER_TEMP_DIR/XXXXXX 2>/dev/null)}"
DMENUHANDLER_CONFIG_FILE="${DMENUHANDLER_CONFIG_FILE:-settings.conf}"
DMENUHANDLER_GOOD_MESSAGE="${DMENUHANDLER_GOOD_MESSAGE:-Everything Went OK}"
DMENUHANDLER_ERROR_MESSAGE="${DMENUHANDLER_ERROR_MESSAGE:-Well that didn\'t work}"
DMENUHANDLER_NOTIFY_ENABLED="${DMENUHANDLER_NOTIFY_ENABLED:-yes}"
DMENUHANDLER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DMENUHANDLER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DMENUHANDLER_NOTIFY_CLIENT_ICON}"
DMENUHANDLER_OUTPUT_COLOR="${DMENUHANDLER_OUTPUT_COLOR:-5}"
DMENUHANDLER_OUTPUT_COLOR_GOOD="${DMENUHANDLER_OUTPUT_COLOR_GOOD:-2}"
DMENUHANDLER_OUTPUT_COLOR_ERROR="${DMENUHANDLER_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DMENUHANDLER_TEMP_DIR" ] || mkdir -p "$DMENUHANDLER_TEMP_DIR" &>/dev/null
[ -d "$DMENUHANDLER_CACHE_DIR" ] || mkdir -p "$DMENUHANDLER_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$DMENUHANDLER_CONFIG_DIR/$DMENUHANDLER_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DMENUHANDLER_CONFIG_DIR/$DMENUHANDLER_CONFIG_FILE" ] &&
  . "$DMENUHANDLER_CONFIG_DIR/$DMENUHANDLER_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    DMENUHANDLER_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DMENUHANDLER_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DMENUHANDLER_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DMENUHANDLER_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DMENUHANDLER_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DMENUHANDLER_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$(printf "copy url\\nmpv\\nmpv (loop)\\nqueue download\\n\\nqueue youtube-dl\\nfeh\\nbrowser\\nw3m\\nmpv (float)" | __dmenu)" in
"copy url") echo "$1" | xclip -selection clipboard ;;
mpv) setsid mpv -quiet "$1" 2>/dev/null & ;;
"mpv (loop)") setsid mpv --input-ipc-server=/tmp/mpvsoc"$(date +%s)" -quiet --loop "$1" 2>/dev/null & ;;
"queue download") tsp curl -LO "$1" 2>/dev/null ;;
"queue youtube-dl") tsp youtube-dl --write-metadata -ic "$1" 2>/dev/null ;;
browser) setsid "$BROWSER" "$1" 2>/dev/null & ;;
feh) setsid feh "$1" 2>/dev/null & ;;
w3m) w3m "$1" 2>/dev/null ;;
"mpv (float)") setsid mpv --input-ipc-server=/tmp/mpvsoc"$(date +%s)" --geometry=+0-0 --autofit=30% --title="mpvfloat" "$1" 2>/dev/null & ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
