#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : dmenurecord --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : dmenurecord
# @Description   : Ask for recording type via dmenu
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$DMENURECORD_TEMP_FILE" ] && [ -f "$DMENURECORD_TEMP_FILE" ] && rm -Rf "$DMENURECORD_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$DMENURECORD_CONFIG_DIR/$DMENURECORD_CONFIG_FILE"
  [ -d "$DMENURECORD_CONFIG_DIR" ] || mkdir -p "$DMENURECORD_CONFIG_DIR"
  [ -d "$DMENURECORD_CONFIG_BACKUP_DIR" ] || mkdir -p "$DMENURECORD_CONFIG_BACKUP_DIR"
  [ -f "$DMENURECORD_CONFIG_DIR/$DMENURECORD_CONFIG_FILE" ] &&
    cp -Rf "$DMENURECORD_CONFIG_DIR/$DMENURECORD_CONFIG_FILE" "$DMENURECORD_CONFIG_BACKUP_DIR/$DMENURECORD_CONFIG_FILE.$$"
  cat <<EOF >"$DMENURECORD_CONFIG_DIR/$DMENURECORD_CONFIG_FILE"
# Settings for dmenurecord
DMENURECORD_SAVE_DIR="${DMENURECORD_SAVE_DIR:-$HOME/Recordings}"
DMENURECORD_EXT="${DMENURECORD_EXT:-.mkv}"
DMENURECORD_DATE_FMT="${DMENURECORD_DATE_FMT:-"%y%m%d-%H%M-%S"}"

# Notification settings
DMENURECORD_GOOD_MESSAGE="${DMENURECORD_GOOD_MESSAGE:-Everything Went OK}"
DMENURECORD_ERROR_MESSAGE="${DMENURECORD_ERROR_MESSAGE:-Well that didn\'t work}"
DMENURECORD_NOTIFY_ENABLED="${DMENURECORD_NOTIFY_ENABLED:-yes}"
DMENURECORD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DMENURECORD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DMENURECORD_NOTIFY_CLIENT_ICON}"

# Colorization settings
DMENURECORD_OUTPUT_COLOR="${DMENURECORD_OUTPUT_COLOR:-5}"
DMENURECORD_OUTPUT_COLOR_GOOD="${DMENURECORD_OUTPUT_COLOR_GOOD:-2}"
DMENURECORD_OUTPUT_COLOR_ERROR="${DMENURECORD_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DMENURECORD_CONFIG_DIR/$DMENURECORD_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for dmenurecord has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
{ builtin type -P rofi &>/dev/null && __dmenu() { rofi -theme ${ROFI_THEME:-purple} -dmenu -i -p "$1" 2>/dev/null; }; } ||
  { builtin type -P dmenu &>/dev/null && __dmenu() { dmenu -i -p "$1" 2>/dev/null; }; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
updateicon() {
  echo "$1" >"$DMENURECORD_TEMP_DIR/recordingicon"
  [ -n "${STATUSBAR}" ] && pkill -RTMIN+9 "${STATUSBAR:?}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
killrecording() {
  recpid="$(cat "$DMENURECORD_TEMP_DIR/recordingpid")"
  # kill with SIGTERM, allowing finishing touches.
  kill -15 "$recpid" &>/dev/null
  rm -f "$DMENURECORD_TEMP_DIR/recordingpid"
  updateicon ""
  [ -n "${STATUSBAR}" ] && pkill -RTMIN+9 "${STATUSBAR:?}"
  # even after SIGTERM, ffmpeg may still run, so SIGKILL it.
  sleep 3
  kill -9 "$recpid" &>/dev/null
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
screencast() {
  ffmpeg -y \
    -f x11grab \
    -framerate 60 \
    -s "$(xdpyinfo | grep dimensions | awk '{print $2;}')" \
    -i $DISPLAY \
    -f alsa -i default \
    -r 30 \
    -c:v libx264rgb -crf 0 -preset ultrafast -c:a flac \
    "$DMENURECORD_SAVE_DIR/screencast-$DMENURECORD_DATE$DMENURECORD_EXT" &>/dev/null &
  echo $! >"$DMENURECORD_TEMP_DIR/recordingpid"
  updateicon "⏺️🎙️"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
video() {
  ffmpeg \
    -f x11grab \
    -s "$(xdpyinfo | grep dimensions | awk '{print $2;}')" \
    -i $DISPLAY \
    -c:v libx264 -qp 0 -r 30 \
    "$DMENURECORD_SAVE_DIR/video-$DMENURECORD_DATE$DMENURECORD_EXT" &>/dev/null &
  echo $! >"$DMENURECORD_TEMP_DIR/recordingpid"
  updateicon "⏺️"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
webcamhidef() {
  ffmpeg \
    -f v4l2 \
    -i /dev/video0 \
    -video_size 1920x1080 \
    "$DMENURECORD_SAVE_DIR/webcam-$DMENURECORD_DATE$DMENURECORD_EXT" &>/dev/null &
  echo $! >"$DMENURECORD_TEMP_DIR/recordingpid"
  updateicon "🎥"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
webcam() {
  ffmpeg \
    -f v4l2 \
    -i /dev/video0 \
    -video_size 640x480 \
    "$DMENURECORD_SAVE_DIR/webcam-$DMENURECORD_DATE$DMENURECORD_EXT" &>/dev/null &
  echo $! >"$DMENURECORD_TEMP_DIR/recordingpid"
  updateicon "🎥"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
audio() {
  ffmpeg \
    -f alsa -i default \
    -c:a flac \
    "$DMENURECORD_SAVE_DIR/audio-$DMENURECORD_DATE.flac" &>/dev/null &
  echo $! >"$DMENURECORD_TEMP_DIR/recordingpid"
  updateicon "🎙️"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
askrecording() {
  choice=$(printf "screencast\\nvideo\\naudio\\nwebcam\\nwebcam (hi-def)" | __dmenu "Select recording style:")
  case "$choice" in
  screencast) screencast ;;
  audio) audio ;;
  video) video ;;
  webcam) webcam ;;
  "webcam (hi-def)") webcamhidef ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
asktoend() {
  response=$(printf "No\\nYes" | __dmenu "Recording still active. End recording?") &&
    [ "$response" = "Yes" ] && killrecording
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
DMENURECORD_LOG_DIR="${DMENURECORD_LOG_DIR:-$HOME/.local/log/dmenurecord}"
DMENURECORD_CACHE_DIR="${DMENURECORD_CACHE_DIR:-$HOME/.cache/dmenurecord}"
DMENURECORD_CONFIG_DIR="${DMENURECORD_CONFIG_DIR:-$HOME/.config/myscripts/dmenurecord}"
DMENURECORD_CONFIG_BACKUP_DIR="${DMENURECORD_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/dmenurecord/backups}"
DMENURECORD_TEMP_DIR="${DMENURECORD_TEMP_DIR:-$HOME/.local/tmp/system_scripts/dmenurecord}"
DMENURECORD_OPTIONS_DIR="${DMENURECORD_OPTIONS_DIR:-$HOME/.local/share/myscripts/dmenurecord/options}"
DMENURECORD_TEMP_FILE="${DMENURECORD_TEMP_FILE:-$(mktemp $DMENURECORD_TEMP_DIR/XXXXXX 2>/dev/null)}"
DMENURECORD_CONFIG_FILE="${DMENURECORD_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
DMENURECORD_OUTPUT_COLOR="${DMENURECORD_OUTPUT_COLOR:-4}"
DMENURECORD_OUTPUT_COLOR_2="${DMENURECORD_OUTPUT_COLOR:-6}"
DMENURECORD_OUTPUT_COLOR_GOOD="${DMENURECORD_OUTPUT_COLOR_GOOD:-2}"
DMENURECORD_OUTPUT_COLOR_ERROR="${DMENURECORD_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
DMENURECORD_GOOD_MESSAGE="${DMENURECORD_GOOD_MESSAGE:-Everything Went OK}"
DMENURECORD_ERROR_MESSAGE="${DMENURECORD_ERROR_MESSAGE:-Well that didn\'t work}"
DMENURECORD_NOTIFY_ENABLED="${DMENURECORD_NOTIFY_ENABLED:-yes}"
DMENURECORD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DMENURECORD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DMENURECORD_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
DMENURECORD_EXT="${DMENURECORD_EXT:-.mkv}"
DMENURECORD_DATE_FMT="${DMENURECORD_DATE_FMT:-+"%y%m%d-%H%M-%S"}"
DMENURECORD_SAVE_DIR="${DMENURECORD_SAVE_DIR:-$HOME/Recordings}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DMENURECORD_CONFIG_DIR/$DMENURECORD_CONFIG_FILE" ] && . "$DMENURECORD_CONFIG_DIR/$DMENURECORD_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DMENURECORD_LOG_DIR" ] || mkdir -p "$DMENURECORD_LOG_DIR" &>/dev/null
[ -d "$DMENURECORD_TEMP_DIR" ] || mkdir -p "$DMENURECORD_TEMP_DIR" &>/dev/null
[ -d "$DMENURECORD_CACHE_DIR" ] || mkdir -p "$DMENURECORD_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$DMENURECORD_CONFIG_DIR/$DMENURECORD_CONFIG_FILE" ] && [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config "${SETARGS:-$*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    DMENURECORD_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DMENURECORD_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DMENURECORD_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DMENURECORD_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DMENURECORD_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DMENURECORD_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
DMENURECORD_DATE="$(date +"$DMENURECORD_DATE_FMT")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
screencast) screencast ;;
audio) audio ;;
video) video ;;
kill) killrecording ;;
*) ([ -f "$DMENURECORD_TEMP_DIR/recordingpid" ] && asktoend && exit) || askrecording ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
