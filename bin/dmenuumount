#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$DMENUUMOUNT_TEMP_FILE" ] && rm -Rf "$DMENUUMOUNT_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : dmenuumount --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : dmenuumount
# @Description   : dmenu prompt to unmount drives
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$DMENUUMOUNT_CONFIG_DIR/$DMENUUMOUNT_CONFIG_FILE"
  [ -d "$DMENUUMOUNT_CONFIG_DIR" ] || mkdir -p "$DMENUUMOUNT_CONFIG_DIR"
  [ -d "$DMENUUMOUNT_CONFIG_BACKUP_DIR" ] || mkdir -p "$DMENUUMOUNT_CONFIG_BACKUP_DIR"
  [ -f "$DMENUUMOUNT_CONFIG_DIR/$DMENUUMOUNT_CONFIG_FILE" ] &&
    cp -Rf "$DMENUUMOUNT_CONFIG_DIR/$DMENUUMOUNT_CONFIG_FILE" "$DMENUUMOUNT_CONFIG_BACKUP_DIR/$DMENUUMOUNT_CONFIG_FILE.$$"
  cat <<EOF >"$DMENUUMOUNT_CONFIG_DIR/$DMENUUMOUNT_CONFIG_FILE"
# Settings for dmenuumount

# Notification settings
DMENUUMOUNT_GOOD_MESSAGE="${DMENUUMOUNT_GOOD_MESSAGE:-Everything Went OK}"
DMENUUMOUNT_ERROR_MESSAGE="${DMENUUMOUNT_ERROR_MESSAGE:-Well that didn\'t work}"
DMENUUMOUNT_NOTIFY_ENABLED="${DMENUUMOUNT_NOTIFY_ENABLED:-yes}"
DMENUUMOUNT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DMENUUMOUNT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DMENUUMOUNT_NOTIFY_CLIENT_ICON}"

# Colorization settings
DMENUUMOUNT_OUTPUT_COLOR="${DMENUUMOUNT_OUTPUT_COLOR:-5}"
DMENUUMOUNT_OUTPUT_COLOR_GOOD="${DMENUUMOUNT_OUTPUT_COLOR_GOOD:-2}"
DMENUUMOUNT_OUTPUT_COLOR_ERROR="${DMENUUMOUNT_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DMENUUMOUNT_CONFIG_DIR/$DMENUUMOUNT_CONFIG_FILE" ]; then
    printf_green "Your config file for dmenuumount has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
unmountusb() {
  [ -z "$drives" ] && exit
  chosen="$(echo "$drives" | dmenu -i -p "Unmount which drive?")" || exit 1
  chosen="$(echo "$chosen" | awk '{print $1}')"
  [ -z "$chosen" ] && exit
  sudo -A umount "$chosen" && __notifications "💻 USB unmounting" "$chosen unmounted."
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
unmountandroid() {
  chosen="$(awk '/simple-mtpfs/ {print $2}' /etc/mtab | dmenu -i -p "Unmount which device?")" || exit 1
  [ -z "$chosen" ] && exit
  sudo -A umount -l "$chosen" && __notifications "🤖 Android unmounting" "$chosen unmounted."
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
asktype() {
  choice="$(printf "USB\\nAndroid" | dmenu -i -p "Unmount a USB drive or Android device?")" || exit 1
  case "$choice" in
  USB) unmountusb ;;
  Android) unmountandroid ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
DMENUUMOUNT_CACHE_DIR="${DMENUUMOUNT_CACHE_DIR:-$HOME/.cache/dmenuumount}"
DMENUUMOUNT_CONFIG_DIR="${DMENUUMOUNT_CONFIG_DIR:-$HOME/.config/myscripts/dmenuumount}"
DMENUUMOUNT_OPTIONS_DIR="${DMENUUMOUNT_OPTIONS_DIR:-$HOME/.local/share/myscripts/dmenuumount/options}"
DMENUUMOUNT_CONFIG_BACKUP_DIR="${DMENUUMOUNT_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/dmenuumount/backups}"
DMENUUMOUNT_TEMP_DIR="${DMENUUMOUNT_TEMP_DIR:-$HOME/.local/tmp/system_scripts/dmenuumount}"
DMENUUMOUNT_TEMP_FILE="${DMENUUMOUNT_TEMP_FILE:-$(mktemp $DMENUUMOUNT_TEMP_DIR/XXXXXX 2>/dev/null)}"
DMENUUMOUNT_CONFIG_FILE="${DMENUUMOUNT_CONFIG_FILE:-settings.conf}"
DMENUUMOUNT_GOOD_MESSAGE="${DMENUUMOUNT_GOOD_MESSAGE:-Everything Went OK}"
DMENUUMOUNT_ERROR_MESSAGE="${DMENUUMOUNT_ERROR_MESSAGE:-Well that didn\'t work}"
DMENUUMOUNT_NOTIFY_ENABLED="${DMENUUMOUNT_NOTIFY_ENABLED:-yes}"
DMENUUMOUNT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DMENUUMOUNT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DMENUUMOUNT_NOTIFY_CLIENT_ICON}"
DMENUUMOUNT_OUTPUT_COLOR="${DMENUUMOUNT_OUTPUT_COLOR:-5}"
DMENUUMOUNT_OUTPUT_COLOR_GOOD="${DMENUUMOUNT_OUTPUT_COLOR_GOOD:-2}"
DMENUUMOUNT_OUTPUT_COLOR_ERROR="${DMENUUMOUNT_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DMENUUMOUNT_TEMP_DIR" ] || mkdir -p "$DMENUUMOUNT_TEMP_DIR" &>/dev/null
[ -d "$DMENUUMOUNT_CACHE_DIR" ] || mkdir -p "$DMENUUMOUNT_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$DMENUUMOUNT_CONFIG_DIR/$DMENUUMOUNT_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DMENUUMOUNT_CONFIG_DIR/$DMENUUMOUNT_CONFIG_FILE" ] &&
  . "$DMENUUMOUNT_CONFIG_DIR/$DMENUUMOUNT_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    DMENUUMOUNT_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DMENUUMOUNT_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DMENUUMOUNT_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DMENUUMOUNT_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DMENUUMOUNT_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DMENUUMOUNT_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
drives=$(lsblk -nrpo "name,type,size,mountpoint" | awk '$4!~/\/boot|\/efi|\/home$|SWAP/&&length($4)>1{printf "%s (%s)\n",$4,$3}')
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if ! grep simple-mtpfs /etc/mtab; then
  [ -z "$drives" ] && echo "No drives to unmount." && exit
  printf_red "Unmountable USB drive detected."
  __notifications "Unmountable USB drive detected."
  unmountusb
else
  if [ -z "$drives" ]; then
    echo "Unmountable Android device detected."
    unmountandroid
  else
    echo "Unmountable USB drive(s) and Android device(s) detected."
    asktype
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
