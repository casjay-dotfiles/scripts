# @File          : dockermgr
# @Description   : docker script to manage containers
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108281904-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
dockermgr_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_available() { echo -e "$LIST" | tr ' ' '\n' && exit 0; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_list() {
  local api_url="https://api.github.com/orgs/dockermgr/repos?per_page=1000"
  am_i_online &&
    curl -q -LSs "$api_url" | jq -r '.[].name' | grep -Ev 'community|template' | sort -u ||
    __list_available
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$DOCKERMGR_CONFIG_DIR/$DOCKERMGR_CONFIG_FILE"
  [ -d "$DOCKERMGR_CONFIG_DIR" ] || mkdir -p "$DOCKERMGR_CONFIG_DIR"
  [ -d "$DOCKERMGR_CONFIG_BACKUP_DIR" ] || mkdir -p "$DOCKERMGR_CONFIG_BACKUP_DIR"
  [ -f "$DOCKERMGR_CONFIG_DIR/$DOCKERMGR_CONFIG_FILE" ] &&
    cp -Rf "$DOCKERMGR_CONFIG_DIR/$DOCKERMGR_CONFIG_FILE" "$DOCKERMGR_CONFIG_BACKUP_DIR/$DOCKERMGR_CONFIG_FILE.$$"
  cat <<EOF >"$DOCKERMGR_CONFIG_DIR/$DOCKERMGR_CONFIG_FILE"
# Settings for dockermgr
DOCKERMGR_GIT_REPO="${DOCKERMGR_GIT_REPO:-https://github.com/dockermgr}"
DOCKERMGR_CLONE_DIR="${DOCKERMGR_CLONE_DIR:-$HOME/Projects/dockermgr}"
DOCKERMGR_DOCKER_BIN="${DOCKERMGR_DOCKER_BIN:-__sudo -HE docker}"
DOCKERMGR_INSTALL_SCRIPT="${DOCKERMGR_INSTALL_SCRIPT:-https://get.docker.com}"
DOCKERMGR_K3B_INSTALL_SCRIPT="${DOCKERMGR_K3B_INSTALL_SCRIPT:-https://get.k3s.io}"
DOCKERMGR_HOME="${DOCKERMGR_HOME:-$HOME/.local/share/srv/docker}"
DOCKERMGR_INSTALL_TMP="${DOCKERMGR_INSTALL_TMP:-/tmp/docker_install.sh}"

# Notification settings
DOCKERMGR_GOOD_MESSAGE="${DOCKERMGR_GOOD_MESSAGE:-Everything Went OK}"
DOCKERMGR_ERROR_MESSAGE="${DOCKERMGR_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DOCKERMGR_NOTIFY_ENABLED="${DOCKERMGR_NOTIFY_ENABLED:-yes}"
DOCKERMGR_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DOCKERMGR_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DOCKERMGR_NOTIFY_CLIENT_ICON}"

# Colorization settings
DOCKERMGR_OUTPUT_COLOR="${DOCKERMGR_OUTPUT_COLOR:-5}"
DOCKERMGR_OUTPUT_COLOR_GOOD="${DOCKERMGR_OUTPUT_COLOR_GOOD:-2}"
DOCKERMGR_OUTPUT_COLOR_ERROR="${DOCKERMGR_OUTPUT_COLOR_ERROR:-1}"

EOF

  if [[ ! -f "$HOME/.docker/config.json" ]]; then
    mkdir -p "$HOME/.docker" &>/dev/null
    echo '{ "auths": {} }' >"$HOME/.docker/config.json"
  fi
  if [ -f "$DOCKERMGR_CONFIG_DIR/$DOCKERMGR_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__docker() { eval $DOCKERMGR_DOCKER_BIN "$*"; }
__docker_stop() { __docker ps -q 2>/dev/null | xargs $DOCKERMGR_DOCKER_BIN stop; }
__docker_rm() { __docker ps -aq 2>/dev/null | __col 3 | xargs $DOCKERMGR_DOCKER_BIN rm -f; }
__docker_rmi() { __docker images 2>/dev/null | grep none | __col 3 | xargs $DOCKERMGR_DOCKER_BIN rmi -f; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__sudo_rm() {
  if __sudo -n true &>/dev/null && __sudo true; then
    sudo rm -Rf "$*" || printf_return "Can not remove $*"
  else
    printf_return "Can not remove $* with sudo"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__status() {
  local status
  if ps -aux | grep -w [d]ocker &>/dev/null; then
    status="$(ps -aux | grep -w [d]ocker | grep -wv 'docker-proxy' | tr ' ' '\n' | grep -v '^$' | grep -E 'unix|tcp' | grep '^')"
    printf_green "Docker is running"
    if [[ -n "$status" ]]; then
      printf_green "Listening on the following:"
      echo "$status" | printf_readline $DOCKERMGR_OUTPUT_COLOR
      exitCode=0
    fi
  else
    printf_red "docker does not seem to be running"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker_service() {
  service_active="$(systemctl show -p ActiveState "docker" | cut -d'=' -f2 | grep ^active)"
  service_running="$(systemctl status docker 2>/dev/null | grep -F running)"
  if [[ -z "$service_active" ]] || [[ -z "$service_running" ]]; then
    __sudo -n true && ask_for_password true &>/dev/null || return 1
    __sudo systemctl start docker &>/dev/null || return 1
    __sudo systemctl enable --now docker &>/dev/null || return 1
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__init() {
  am_i_online --error -m "Can not setup docker: No internet" || exit 1
  __sudo -n true &>/dev/null && __sudo true || printf_exit 1 1 "This script requires root privileges"
  if ! cmd_exists docker; then
    printf_newline
    printf_green "Installing docker and setting up systemd"
    printf_green "This will take a few minutes"
    if cmd_exists pacman; then
      __sudo pacman -Syy --noconfirm docker &>/dev/null
    else
      if curl -q -LSsfk --connect-timeout 3 --retry 0 --fail "$DOCKERMGR_INSTALL_SCRIPT" >"$DOCKERMGR_INSTALL_TMP"; then
        chmod 755 "$DOCKERMGR_INSTALL_TMP"
        __sudo bash -c "$DOCKERMGR_INSTALL_TMP" 2>&1 | tee "$DOCKERMGR_TEMP_FILE" &>/dev/null
        if grep -q 'E: The repository' "$DOCKERMGR_TEMP_FILE"; then
          printf_red "Distro not supported please do a manual install"
          printf_red "https://github.com/dockermgr/community/wiki"
          printf_red "https://docs.docker.com/engine/install/"
          exit 1
        fi
      else
        printf_exit "Failed to download the script from $DOCKERMGR_INSTALL_SCRIPT"
      fi
    fi
  fi
  if cmd_exists docker; then
    printf_green "Docker has been installed."
  else
    printf_exit "Installation has failed: could not install docker"
  fi
  printf_green "Continuing with configuration"
  mkdir -p "$HOME/.docker"
  if grep -q docker /etc/group; then
    __sudo usermod -aG docker "$USER" &>/dev/null
    __sudo chown -R "$USER":"$USER" "$HOME/.docker" &>/dev/null
    __sudo chmod -R g+rwx "$HOME/.docker" &>/dev/null
    [ -n "$(builtin type -P gpasswd 2>/dev/null)" ] && __sudo gpasswd -a "${USER}" docker &>/dev/null
  fi

  if [ ! -f /etc/systemd/system/docker.service.d/docker.conf ]; then
    __sudo mkdir -p /etc/systemd/system/docker.service.d
    cat <<EOF 2>/dev/null | __sudo tee /etc/systemd/system/docker.service.d/docker.conf &>/dev/null
[Service]
ExecStart=
ExecStart=/usr/bin/dockerd -H tcp://0.0.0.0:2375 -H unix://var/run/docker.sock

EOF
  fi
  if __docker_service; then
    printf_green "docker installation has completed"
  else
    printf_red "docker installation has failed"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__init_help() {
  printf_green "Setup docker"
  exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__rancher() {
  __install rancher
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__k3b() {
  __execute "curl -q -LSsf $DOCKERMGR_K3B_INSTALL_SCRIPT | __sudo bash -" "Installing k3b please wait....."
  if cmd_exists k3s; then
    k3s kubectl get node &>/dev/null
    __sudo k3s server &>/dev/null &
    printf_green "Kubernetes has been installed"
    true
  else
    printf_red "Kubernetes install has failed"
    false
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__install_helm() {
  curl -q -LSsf https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash &>/dev/null
  if cmd_exists helm; then
    printf_green "Helm has been installed"
    helm completion bash | __sudo tee /etc/bash_completion.d/helm &>/dev/null
    true
  else
    printf_red "Helm install has failed"
    false
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__minikube_curl() {
  curl -q -LOSs --fail "https://storage.googleapis.com/minikube/releases/latest/minikube-$1" -o "/tmp/minikube" &>/dev/null
  if [[ $? -eq 0 ]]; then
    [ -f /tmp/minikube ] && __sudo mv /tmp/minikube /usr/local/bin/minikube
    return $?
  else
    printf_exit "Failed to download minikube"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__minikube() {
  cmd_exists docker || printf_exit "Docker is not installed"
  local driver="${1:-docker}"
  local uname="$(uname -s)"
  printf_blue "Installing minikube"
  if [[ "$uname" == "Linux" ]]; then
    __minikube_curl linux-amd64
  elif [[ "$uname" == "Darwin" ]]; then
    __minikube_curl darwin-amd64
  else
    printf_red "minikube is not supported on $uname"
  fi
  if cmd_exists minikube; then
    printf_green "Minikube has been installed"
    minikube completion bash | __sudo tee /etc/bash_completion.d/minikube &>/dev/null
    printf_blue "Attempting to start minikube cluster using driver: $driver"
    minikube start --driver=$driver | printf_readline 5 &&
      minikube kubectl -- get pods -A | grep '^kube' | printf_readline 6
    return $?
  else
    printf_red "Minikube install has failed"
    return $?
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__download() {
  REPO_NAME="$1"
  REPO_URL="$DOCKERMGR_GIT_REPO/$REPO_NAME"
  DIR_NAME="$DOCKERMGR_CLONE_DIR/$REPO_NAME"
  gitadmin clone "$REPO_URL" "$DIR_NAME"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
installer_delete() {
  local LISTARRAY="$*"
  local exitCode=
  local app=""
  for app in $LISTARRAY; do
    local APPDIR="$HOME/.local/share/dockermgr"
    local INSTDIR="$HOME/.local/share/dockermgr"
    local DATADIR="$HOME/.local/share/srv/docker"
    local SHAREDIR="$HOME/.local/share/CasjaysDev/apps/dockermgr"
    local MESSAGE="${MESSAGE:-Removing $app from ${msg:-your system}}"
    if [ -d "$APPDIR/$app" ] || [ -d "$INSTDIR/$app" ] || [ -d "$DATADIR/$app" ] || [ -f "$SHAREDIR/$app" ]; then
      printf_yellow "$MESSAGE"
      printf_blue "Deleting the files from $APPDIR/$app"
      rm -Rf "$APPDIR/${app:?}" 2>/dev/null || __sudo_rm "$APPDIR/${app:?}" 2>/dev/null
      printf_blue "Deleting the files from $INSTDIR/$app"
      rm -Rf "$INSTDIR/${app:?}" 2>/dev/null || __sudo_rm "$INSTDIR/${app:?}" 2>/dev/null
      printf_blue "Deleting the files from $DATADIR/$app"
      rm -Rf "$DATADIR/${app:?}" 2>/dev/null || __sudo_rm "$DATADIR/${app:?}" 2>/dev/null
      printf_blue "Deleting the files from $SHAREDIR/$app"
      rm -Rf "$SHAREDIR/${app:?}" 2>/dev/null || __sudo_rm "$SHAREDIR/${app:?}" 2>/dev/null
      printf_blue "Removing docker container"
      eval $DOCKERMGR_DOCKER_BIN rm -f "$app" "${app}-web" &>/dev/null
      if [ -d "$APPDIR/$app" ] || [ -d "$INSTDIR/$app" ] || [ -d "$DATADIR/$app" ] || [ -f "$SHAREDIR/$app" ]; then
        exitCode+=1
        printf_red "There was a problem deleting $app"
      else
        exitCode+=0
        printf_green "$app has been removed"
        echo ""
      fi
    else
      printf_error "$app doesn't seem to be installed"
    fi
    unset app
  done
  return ${exitCode}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__install() {
  __docker_service
  __sudo -n true || printf_exit "sudo has failed"
  declare -a LISTARRAY="$*"
  for container in ${LISTARRAY[*]}; do
    local APPNAME="$container"
    local APPDIR="$HOME/.local/share/srv/docker/$APPNAME"
    local DATADIR="$HOME/.local/share/srv/docker/$APPNAME"
    local INSTDIR="$HOME/.local/share/dockermgr/$APPNAME"
    export APPNAME APPDIR INSTDIR DATADIR REPO
    mkdir -p "$APPDIR" "$INSTDIR" "$DATADIR" &>/dev/null
    printf_green "Running the installer script for $container"
    am_i_online --error -m "Can not setup docker: No internet" || exit 1
    if [ -f "$INSTDIR/install.sh" ] && [ -d "$INSTDIR/.git" ]; then
      printf_green "Updating container in $INSTDIR"
      git -C "$INSTDIR" reset --hard -q &&
        git -C "$INSTDIR" pull -q &&
        chmod -Rf 755 "$INSTDIR/install.sh" &&
        bash -c "$INSTDIR/install.sh"
    else
      printf_green "Installing container to $INSTDIR"
      git clone -q "$REPO/$APPNAME" "$INSTDIR" &&
        chmod -Rf 755 "$INSTDIR/install.sh" &&
        bash -c "$INSTDIR/install.sh"
    fi
    # fi
    __sudo chown "$USER":"$USER" "$INSTDIR" "$DATADIR"
    printf '\n'
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__install_help() {
  printf_green "Usage: $APPNAME install NAME    |    $APPNAME install transmission"
  exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_help() {
  printf_green "Usage: dockermgr run imageName"
  printf_green "See http://hub.docker.com for images"
  exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_main() {
  NAME="$(echo "$1" | sed 's/[!@#\$%^&*():]//g')"
  if [ "$(__docker ps -q -f status=running -f name=^/${NAME}$)" ]; then
    __docker container exec -it "$NAME" /bin/sh
  else
    if [ -n "$1" ]; then
      __docker run -d --network host -it --name "$NAME" --restart always "$1" /sbin/init &&
        __docker container exec -it "$NAME" /bin/sh
    else
      printf_exit "Error: No container name was given"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_test() {
  local container="$1"
  local image="${2:-}"
  __docker pull "$2" && docker run -it -delete --name "$1" /bin/bash
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_update() {
  if [ "$*" != "" ]; then
    __install "$@"
  else
    printf_cyan "Looking in $DOCKERMGR_HOME for installed containers"
    if [ -d "$DOCKERMGR_HOME" ] && [ "$(find "$DOCKERMGR_HOME" -mindepth 1 -maxdepth 1 -type d | wc -l)" -ne 0 ]; then
      for d in $(ls "$DOCKERMGR_HOME"); do
        __install "$d"
      done
    else
      printf_return "There is nothing to update in $DOCKERMGR_HOME"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_cron() {
  local frequency="0 4 * * 6"
  local croncmd="$APPNAME cron run"
  case $1 in
  run)
    logr bash -c "am_i_online && $(expr $RANDOM \% 300) && docker images | awk '(NR>1) && ($2!~/none/) {print $1":"$2}' | xargs -L1 docker pull"
    ;;
  remove)
    shift 1
    removecrontab "$frequency $croncmd"
    ;;
  add)
    addtocrontab "$frequency $croncmd"
    ;;
  *)
    addtocrontab "$frequency $croncmd"
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__ssh_help() {
  printf_green "Auto connect to first container if none are specified"
  printf_green "Usage: $APPNAME ssh container_name"
  exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__ssh_error() {
  printf_red "There are no running containers"
  exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__connect_main() {
  CONTAINER="$1"
  if [[ "$CONTAINER" == "" ]]; then
    CONTAINER=$(docker ps | grep -Eo "^[0-9a-z]{8,}\b") || __ssh_error
  fi
  __docker exec -i -t "$CONTAINER" bash -l
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__install_front() {
  cmd_exists docker || __init || exit 1
  printf_cyan "Installing yacht"
  __sudo docker rm yacht -f &>/dev/null
  if __install yacht &>/dev/null; then
    printf_yellow "Username:  admin@yacht.local"
    printf_yellow "Password:  pass"
    printf_yellow "URL:       http://yacht.local:14053"
    printf_green "Yacht has been installed"
  else
    printf_red "Failed to install yacht"
  fi
  echo
  printf_cyan "Installing nginx-proxy-manager"
  __sudo docker rm nginx-manager -f &>/dev/null
  if __install nginx-manager &>/dev/null; then
    printf_yellow "Username:  admin@example.com"
    printf_yellow "Password:  changeme"
    printf_yellow "URL:       http://nginx-manager.local:8888"
    printf_green "nginx-manager has been installed"
  else
    printf_red "Failed to install nginx-proxy-manager"
  fi
  echo
}
