    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    DOCKERMGR_CWD="$2"
    shift 2
    ;;
  -f | --force)
    shift 1
    export FORCE_INSTALL="true"
    ;;
  -a | --all)
    shift 1
    INSTALL_ALL="true"
    ;;
  --raw)
    shift 1
    printf_column() { cat -; }
    printf_readline() { cat -; }
    printf_red() { echo "$1"; }
    printf_green() { echo "$1"; }
    printf_cyan() { echo "$1"; }
    printf_purple() { echo "$1"; }
    printf_exit() { echo "$2"; }
    ;;
  -d)
    shift 1
    DOCKER_ARG+="--detach "
    ;;
  --dockerfile)
    shift 1
    DOCKERMGR_CREATE_BUILD="true"
    ;;
  -P)
    shift 1
    DOCKER_ARG+="--publish-all "
    ;;
  -p)
    DOCKER_ARG+="--publish $2 "
    shift 2
    ;;
  -e)
    DOCKER_ARG+="--env $2 "
    shift 2
    ;;
  -v)
    DOCKER_ARG+="--volume $2 "
    shift 2
    ;;
  -m)
    DOCKER_ARG+="--platform $2 "
    shift 2
    ;;
  -u)
    DOCKER_ARG+="--user $2 "
    shift 2
    ;;
  -w)
    DOCKER_ARG+="--workdir $2 "
    shift 2
    ;;
  --platform)
    DOCKER_PULL_ARG+="--platform $2 "
    DOCKER_ARG+="--platform $2 "
    shift 2
    ;;
  --describe)
    DOCKERHUB_DESCRIPTION="$2"
    shift 2
    ;;
  --name)
    DOCKERMGR_CONTAINER_NAME="$2"
    shift 2
    ;;
  --info)
    shift 1
    DOCKERMGR_SHOW_INFO="true"
    ;;
