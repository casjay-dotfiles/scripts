#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$DOCKERRUN_TEMP_FILE" ] && rm -Rf "$DOCKERRUN_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : dockerrun --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : dockerrun
# @Description   : run docker image
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Generating the config file in"
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "$DOCKERRUN_CONFIG_DIR/$DOCKERRUN_CONFIG_FILE"
  [ -d "$DOCKERRUN_CONFIG_DIR" ] || mkdir -p "$DOCKERRUN_CONFIG_DIR"
  [ -d "$DOCKERRUN_CONFIG_BACKUP_DIR" ] || mkdir -p "$DOCKERRUN_CONFIG_BACKUP_DIR"
  [ -f "$DOCKERRUN_CONFIG_DIR/$DOCKERRUN_CONFIG_FILE" ] &&
    cp -Rf "$DOCKERRUN_CONFIG_DIR/$DOCKERRUN_CONFIG_FILE" "$DOCKERRUN_CONFIG_BACKUP_DIR/$DOCKERRUN_CONFIG_FILE.$$"
  cat <<EOF >"$DOCKERRUN_CONFIG_DIR/$DOCKERRUN_CONFIG_FILE"
# Settings for dockerrun
DOCKERRUN_DOCKER_BIN="${DOCKERRUN_DOCKER_BIN:-docker}"

# Notification settings
DOCKERRUN_GOOD_MESSAGE="${DOCKERRUN_GOOD_MESSAGE:-Everything Went OK}"
DOCKERRUN_ERROR_MESSAGE="${DOCKERRUN_ERROR_MESSAGE:-Well that didn\'t work}"
DOCKERRUN_NOTIFY_ENABLED="${DOCKERRUN_NOTIFY_ENABLED:-yes}"
DOCKERRUN_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DOCKERRUN_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DOCKERRUN_NOTIFY_CLIENT_ICON}"

# Colorization settings
DOCKERRUN_OUTPUT_COLOR="${DOCKERRUN_OUTPUT_COLOR:-5}"
DOCKERRUN_OUTPUT_COLOR_GOOD="${DOCKERRUN_OUTPUT_COLOR_GOOD:-2}"
DOCKERRUN_OUTPUT_COLOR_ERROR="${DOCKERRUN_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DOCKERRUN_CONFIG_DIR/$DOCKERRUN_CONFIG_FILE" ]; then
    [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Your config file for dockerrun has been created"
    exitCode=0
    exec $APPNAME "$*"
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__docker() { eval $DOCKERRUN_DOCKER_BIN "$*"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
DOCKERRUN_LOG_DIR="${DOCKERRUN_LOG_DIR:-$HOME/.local/log/dockerrun}"
DOCKERRUN_CACHE_DIR="${DOCKERRUN_CACHE_DIR:-$HOME/.cache/dockerrun}"
DOCKERRUN_CONFIG_DIR="${DOCKERRUN_CONFIG_DIR:-$HOME/.config/myscripts/dockerrun}"
DOCKERRUN_CONFIG_BACKUP_DIR="${DOCKERRUN_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/dockerrun/backups}"
DOCKERRUN_TEMP_DIR="${DOCKERRUN_TEMP_DIR:-$HOME/.local/tmp/system_scripts/dockerrun}"
DOCKERRUN_OPTIONS_DIR="${DOCKERRUN_OPTIONS_DIR:-$HOME/.local/share/myscripts/dockerrun/options}"
DOCKERRUN_TEMP_FILE="${DOCKERRUN_TEMP_FILE:-$(mktemp $DOCKERRUN_TEMP_DIR/XXXXXX 2>/dev/null)}"
DOCKERRUN_CONFIG_FILE="${DOCKERRUN_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
DOCKERRUN_OUTPUT_COLOR="${DOCKERRUN_OUTPUT_COLOR:-4}"
DOCKERRUN_OUTPUT_COLOR_2="${DOCKERRUN_OUTPUT_COLOR:-6}"
DOCKERRUN_OUTPUT_COLOR_GOOD="${DOCKERRUN_OUTPUT_COLOR_GOOD:-2}"
DOCKERRUN_OUTPUT_COLOR_ERROR="${DOCKERRUN_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
DOCKERRUN_GOOD_MESSAGE="${DOCKERRUN_GOOD_MESSAGE:-Everything Went OK}"
DOCKERRUN_ERROR_MESSAGE="${DOCKERRUN_ERROR_MESSAGE:-Well that didn\'t work}"
DOCKERRUN_NOTIFY_ENABLED="${DOCKERRUN_NOTIFY_ENABLED:-yes}"
DOCKERRUN_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DOCKERRUN_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DOCKERRUN_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
DOCKERRUN_DOCKER_BIN="${DOCKERRUN_DOCKER_BIN:-sudo docker}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DOCKERRUN_CONFIG_DIR/$DOCKERRUN_CONFIG_FILE" ] && . "$DOCKERRUN_CONFIG_DIR/$DOCKERRUN_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DOCKERRUN_LOG_DIR" ] || mkdir -p "$DOCKERRUN_LOG_DIR" &>/dev/null
[ -d "$DOCKERRUN_TEMP_DIR" ] || mkdir -p "$DOCKERRUN_TEMP_DIR" &>/dev/null
[ -d "$DOCKERRUN_CACHE_DIR" ] || mkdir -p "$DOCKERRUN_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$DOCKERRUN_CONFIG_DIR/$DOCKERRUN_CONFIG_FILE" ] || SHOW_CONFIG_MESSAGE=NO __gen_config "$*"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    DOCKERRUN_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DOCKERRUN_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DOCKERRUN_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DOCKERRUN_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DOCKERRUN_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DOCKERRUN_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
{ cmd_exists docker || am_i_online --error; } || bash -c "$(__curl https://get.docker.com)" || printf_exit "Installation has failed"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
NAME="$(echo "$1" | sed 's/[!@#\$%^&*():]//g')"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ "$(__docker ps -q -f status=running -f name=^/${NAME}$)" ]; then
  __docker container exec -it "$NAME" /bin/bash -l
else
  __docker run -d --network host -it --name "$NAME" --restart always "$1" /sbin/init &&
    __docker container exec -it "$NAME" /bin/bash -l
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
