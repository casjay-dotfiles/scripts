#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$DOCKERSSH_TEMP_FILE" ] && rm -Rf "$DOCKERSSH_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : dockerssh --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : dockerssh
# @Description   : docker connection script
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$DOCKERSSH_CONFIG_DIR/$DOCKERSSH_CONFIG_FILE"
  [ -d "$DOCKERSSH_CONFIG_DIR" ] || mkdir -p "$DOCKERSSH_CONFIG_DIR"
  [ -d "$DOCKERSSH_CONFIG_BACKUP_DIR" ] || mkdir -p "$DOCKERSSH_CONFIG_BACKUP_DIR"
  [ -f "$DOCKERSSH_CONFIG_DIR/$DOCKERSSH_CONFIG_FILE" ] &&
    cp -Rf "$DOCKERSSH_CONFIG_DIR/$DOCKERSSH_CONFIG_FILE" "$DOCKERSSH_CONFIG_BACKUP_DIR/$DOCKERSSH_CONFIG_FILE.$$"
  cat <<EOF >"$DOCKERSSH_CONFIG_DIR/$DOCKERSSH_CONFIG_FILE"
# Settings for dockerssh
DOCKERSSH_DOCKER_BIN="${DOCKERSSH_DOCKER_BIN:-}"

# Notification settings
DOCKERSSH_GOOD_MESSAGE="${DOCKERSSH_GOOD_MESSAGE:-Everything Went OK}"
DOCKERSSH_ERROR_MESSAGE="${DOCKERSSH_ERROR_MESSAGE:-Well that didn\'t work}"
DOCKERSSH_NOTIFY_ENABLED="${DOCKERSSH_NOTIFY_ENABLED:-yes}"
DOCKERSSH_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DOCKERSSH_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DOCKERSSH_NOTIFY_CLIENT_ICON}"

# Colorization settings
DOCKERSSH_OUTPUT_COLOR="${DOCKERSSH_OUTPUT_COLOR:-5}"
DOCKERSSH_OUTPUT_COLOR_GOOD="${DOCKERSSH_OUTPUT_COLOR_GOOD:-2}"
DOCKERSSH_OUTPUT_COLOR_ERROR="${DOCKERSSH_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DOCKERSSH_CONFIG_DIR/$DOCKERSSH_CONFIG_FILE" ]; then
    printf_green "Your config file for dockerssh has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
_error() {
  printf_red "There are no running containers"
  exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker() { eval $DOCKERSSH_DOCKER_BIN "$*"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
DOCKERSSH_CACHE_DIR="${DOCKERSSH_CACHE_DIR:-$HOME/.cache/dockerssh}"
DOCKERSSH_CONFIG_DIR="${DOCKERSSH_CONFIG_DIR:-$HOME/.config/myscripts/dockerssh}"
DOCKERSSH_OPTIONS_DIR="${DOCKERSSH_OPTIONS_DIR:-$HOME/.local/share/myscripts/dockerssh/options}"
DOCKERSSH_CONFIG_BACKUP_DIR="${DOCKERSSH_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/dockerssh/backups}"
DOCKERSSH_TEMP_DIR="${DOCKERSSH_TEMP_DIR:-$HOME/.local/tmp/system_scripts/dockerssh}"
DOCKERSSH_TEMP_FILE="${DOCKERSSH_TEMP_FILE:-$(mktemp $DOCKERSSH_TEMP_DIR/XXXXXX 2>/dev/null)}"
DOCKERSSH_CONFIG_FILE="${DOCKERSSH_CONFIG_FILE:-settings.conf}"
DOCKERSSH_GOOD_MESSAGE="${DOCKERSSH_GOOD_MESSAGE:-Everything Went OK}"
DOCKERSSH_ERROR_MESSAGE="${DOCKERSSH_ERROR_MESSAGE:-Well that didn\'t work}"
DOCKERSSH_NOTIFY_ENABLED="${DOCKERSSH_NOTIFY_ENABLED:-yes}"
DOCKERSSH_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DOCKERSSH_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DOCKERSSH_NOTIFY_CLIENT_ICON}"
DOCKERSSH_OUTPUT_COLOR="${DOCKERSSH_OUTPUT_COLOR:-5}"
DOCKERSSH_OUTPUT_COLOR_GOOD="${DOCKERSSH_OUTPUT_COLOR_GOOD:-2}"
DOCKERSSH_OUTPUT_COLOR_ERROR="${DOCKERSSH_OUTPUT_COLOR_ERROR:-1}"
DOCKERSSH_DOCKER_BIN="${DOCKERSSH_DOCKER_BIN:-sudo docker}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DOCKERSSH_TEMP_DIR" ] || mkdir -p "$DOCKERSSH_TEMP_DIR" &>/dev/null
[ -d "$DOCKERSSH_CACHE_DIR" ] || mkdir -p "$DOCKERSSH_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$DOCKERSSH_CONFIG_DIR/$DOCKERSSH_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DOCKERSSH_CONFIG_DIR/$DOCKERSSH_CONFIG_FILE" ] &&
  . "$DOCKERSSH_CONFIG_DIR/$DOCKERSSH_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    DOCKERSSH_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DOCKERSSH_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DOCKERSSH_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DOCKERSSH_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DOCKERSSH_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DOCKERSSH_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash docker || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
CONTAINER=$1
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [[ "$CONTAINER" == "" ]]; then
  CONTAINER=$(__docker ps | grep -Eo "^[0-9a-z]{8,}\b") || _error
fi
__docker exec -i -t $CONTAINER bash -l
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
