#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : dos2unix --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : dos2unix
# @Description   : Find files with Windows line endings (and convert them to Unix in force mode)
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$DOS2UNIX_TEMP_FILE" ] && [ -f "$DOS2UNIX_TEMP_FILE" ] && rm -Rf "$DOS2UNIX_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$DOS2UNIX_CONFIG_DIR/$DOS2UNIX_CONFIG_FILE"
  [ -d "$DOS2UNIX_CONFIG_DIR" ] || mkdir -p "$DOS2UNIX_CONFIG_DIR"
  [ -d "$DOS2UNIX_CONFIG_BACKUP_DIR" ] || mkdir -p "$DOS2UNIX_CONFIG_BACKUP_DIR"
  [ -f "$DOS2UNIX_CONFIG_DIR/$DOS2UNIX_CONFIG_FILE" ] &&
    cp -Rf "$DOS2UNIX_CONFIG_DIR/$DOS2UNIX_CONFIG_FILE" "$DOS2UNIX_CONFIG_BACKUP_DIR/$DOS2UNIX_CONFIG_FILE.$$"
  cat <<EOF >"$DOS2UNIX_CONFIG_DIR/$DOS2UNIX_CONFIG_FILE"
# Settings for dos2unix

# Notification settings
DOS2UNIX_GOOD_MESSAGE="${DOS2UNIX_GOOD_MESSAGE:-Everything Went OK}"
DOS2UNIX_ERROR_MESSAGE="${DOS2UNIX_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DOS2UNIX_NOTIFY_ENABLED="${DOS2UNIX_NOTIFY_ENABLED:-yes}"
DOS2UNIX_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DOS2UNIX_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DOS2UNIX_NOTIFY_CLIENT_ICON}"

# Colorization settings
DOS2UNIX_OUTPUT_COLOR="${DOS2UNIX_OUTPUT_COLOR:-5}"
DOS2UNIX_OUTPUT_COLOR_GOOD="${DOS2UNIX_OUTPUT_COLOR_GOOD:-2}"
DOS2UNIX_OUTPUT_COLOR_ERROR="${DOS2UNIX_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$DOS2UNIX_CONFIG_DIR/$DOS2UNIX_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      unset INIT_CONFIG
      eval bash -c "$APPNAME $*"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
_dos2unix() { perl -pi -e 's/\r\n?/\n/g' "$1"; }
_crlf_file() { grep -q $'\x0D' "$1" && echo "$1" && if [ "$2" = 1 ]; then _dos2unix "$1"; fi; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
DOS2UNIX_LOG_DIR="${DOS2UNIX_LOG_DIR:-$HOME/.local/log/dos2unix}"
DOS2UNIX_CACHE_DIR="${DOS2UNIX_CACHE_DIR:-$HOME/.cache/dos2unix}"
DOS2UNIX_CONFIG_DIR="${DOS2UNIX_CONFIG_DIR:-$HOME/.config/myscripts/dos2unix}"
DOS2UNIX_CONFIG_BACKUP_DIR="${DOS2UNIX_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/dos2unix/backups}"
DOS2UNIX_TEMP_DIR="${DOS2UNIX_TEMP_DIR:-$HOME/.local/tmp/system_scripts/dos2unix}"
DOS2UNIX_OPTIONS_DIR="${DOS2UNIX_OPTIONS_DIR:-$HOME/.local/share/myscripts/dos2unix/options}"
DOS2UNIX_TEMP_FILE="${DOS2UNIX_TEMP_FILE:-$(mktemp $DOS2UNIX_TEMP_DIR/XXXXXX 2>/dev/null)}"
DOS2UNIX_CONFIG_FILE="${DOS2UNIX_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
DOS2UNIX_OUTPUT_COLOR="${DOS2UNIX_OUTPUT_COLOR:-4}"
DOS2UNIX_OUTPUT_COLOR_2="${DOS2UNIX_OUTPUT_COLOR:-6}"
DOS2UNIX_OUTPUT_COLOR_GOOD="${DOS2UNIX_OUTPUT_COLOR_GOOD:-2}"
DOS2UNIX_OUTPUT_COLOR_ERROR="${DOS2UNIX_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
DOS2UNIX_GOOD_MESSAGE="${DOS2UNIX_GOOD_MESSAGE:-Everything Went OK}"
DOS2UNIX_ERROR_MESSAGE="${DOS2UNIX_ERROR_MESSAGE:-Well something seems to have gone wrong}"
DOS2UNIX_NOTIFY_ENABLED="${DOS2UNIX_NOTIFY_ENABLED:-yes}"
DOS2UNIX_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
DOS2UNIX_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$DOS2UNIX_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$DOS2UNIX_CONFIG_DIR/$DOS2UNIX_CONFIG_FILE" ] && . "$DOS2UNIX_CONFIG_DIR/$DOS2UNIX_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$DOS2UNIX_LOG_DIR" ] || mkdir -p "$DOS2UNIX_LOG_DIR" &>/dev/null
[ -d "$DOS2UNIX_TEMP_DIR" ] || mkdir -p "$DOS2UNIX_TEMP_DIR" &>/dev/null
[ -d "$DOS2UNIX_CACHE_DIR" ] || mkdir -p "$DOS2UNIX_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$DOS2UNIX_CONFIG_DIR/$DOS2UNIX_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="f"
LONGOPTS="options,config,version,help,dir:,force"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    DOS2UNIX_CWD="$2"
    shift 2
    ;;
  -f | --force)
    shift 1
    setforce=1
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$DOS2UNIX_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${DOS2UNIX_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${DOS2UNIX_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${DOS2UNIX_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${DOS2UNIX_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
force="${setforce:-0}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ "$1" = "" ]; then
  _crlf_file $1 $force || exitcode=1
else
  # All files
  for file in $(find ${1:-.} -type f -not -path "*/.git/*" -not -path "*/node_modules/*" 2>/dev/null | xargs file | grep ASCII | cut -d: -f1); do
    _crlf_file $file $force || exitcode=1
  done
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
