#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202112081553-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : earthquakes --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Dec 08, 2021 15:53 EST
# @File          : earthquakes
# @Description   : Get earthquake information from the USGS
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202112081553-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$EARTHQUAKES_CONFIG_DIR/$EARTHQUAKES_CONFIG_FILE"
  [ -d "$EARTHQUAKES_CONFIG_DIR" ] || mkdir -p "$EARTHQUAKES_CONFIG_DIR"
  [ -d "$EARTHQUAKES_CONFIG_BACKUP_DIR" ] || mkdir -p "$EARTHQUAKES_CONFIG_BACKUP_DIR"
  [ -f "$EARTHQUAKES_CONFIG_DIR/$EARTHQUAKES_CONFIG_FILE" ] &&
    cp -Rf "$EARTHQUAKES_CONFIG_DIR/$EARTHQUAKES_CONFIG_FILE" "$EARTHQUAKES_CONFIG_BACKUP_DIR/$EARTHQUAKES_CONFIG_FILE.$$"
  cat <<EOF >"$EARTHQUAKES_CONFIG_DIR/$EARTHQUAKES_CONFIG_FILE"
# Settings for earthquakes
EARTHQUAKES_API_URL="${EARTHQUAKES_API_URL:-https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson}"

# Notification settings
EARTHQUAKES_GOOD_MESSAGE="${EARTHQUAKES_GOOD_MESSAGE:-Everything Went OK}"
EARTHQUAKES_ERROR_MESSAGE="${EARTHQUAKES_ERROR_MESSAGE:-Well something seems to have gone wrong}"
EARTHQUAKES_NOTIFY_ENABLED="${EARTHQUAKES_NOTIFY_ENABLED:-yes}"
EARTHQUAKES_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
EARTHQUAKES_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$EARTHQUAKES_NOTIFY_CLIENT_ICON}"

# Colorization settings
EARTHQUAKES_OUTPUT_COLOR="${EARTHQUAKES_OUTPUT_COLOR:-5}"
EARTHQUAKES_OUTPUT_COLOR_GOOD="${EARTHQUAKES_OUTPUT_COLOR_GOOD:-2}"
EARTHQUAKES_OUTPUT_COLOR_ERROR="${EARTHQUAKES_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$EARTHQUAKES_CONFIG_DIR/$EARTHQUAKES_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__jq() {
  jq '.features[].properties.time|= (. / 1000 | strftime("%Y-%m-%d %H:%M:%S")) | .features[].properties.updated|= (. / 1000 | strftime("%Y-%m-%d %H:%M:%S"))' 2>/dev/null |
    jq -rc '.features[].properties | [{Place: .place,Time: .time,Updated: .updated,Magnitude: .mag,Alert: .alert,tsunami: .tsunami}]' 2>/dev/null |
    jq 2>/dev/null | sed 's|null|none|g' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__sed_clean() {
  tr -d '{' |
    sed 's|\[||g;s|\"||g;s|{||g' |
    sed 's|\]||g;s|\}||g' |
    sed 's|"||g;s|||g' |
    sed 's|\\t||g;s|,||g' |
    sed 's/\\n/\n/g; s/\\t/\t/g' |
    sed 's|tsunami: 1|tsunami: yes|g' |
    sed 's|tsunami: 0|tsunami: no|g'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__output() {
  echo "${1:-$RES}" |
    __jq |
    __sed_clean
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
EARTHQUAKES_LOG_DIR="${EARTHQUAKES_LOG_DIR:-$HOME/.local/log/earthquakes}"
EARTHQUAKES_CACHE_DIR="${EARTHQUAKES_CACHE_DIR:-$HOME/.cache/earthquakes}"
EARTHQUAKES_CONFIG_DIR="${EARTHQUAKES_CONFIG_DIR:-$HOME/.config/myscripts/earthquakes}"
EARTHQUAKES_OPTIONS_DIR="${EARTHQUAKES_OPTIONS_DIR:-$HOME/.local/share/myscripts/earthquakes/options}"
EARTHQUAKES_CONFIG_BACKUP_DIR="${EARTHQUAKES_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/earthquakes/backups}"
EARTHQUAKES_TEMP_DIR="${EARTHQUAKES_TEMP_DIR:-$HOME/.local/tmp/system_scripts/earthquakes}"
EARTHQUAKES_CONFIG_FILE="${EARTHQUAKES_CONFIG_FILE:-settings.conf}"
EARTHQUAKES_GOOD_MESSAGE="${EARTHQUAKES_GOOD_MESSAGE:-Everything Went OK}"
EARTHQUAKES_ERROR_MESSAGE="${EARTHQUAKES_ERROR_MESSAGE:-Well something seems to have gone wrong}"
EARTHQUAKES_NOTIFY_ENABLED="${EARTHQUAKES_NOTIFY_ENABLED:-yes}"
EARTHQUAKES_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
EARTHQUAKES_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$EARTHQUAKES_NOTIFY_CLIENT_ICON}"
EARTHQUAKES_OUTPUT_COLOR="${EARTHQUAKES_OUTPUT_COLOR:-2}"
EARTHQUAKES_OUTPUT_COLOR_GOOD="${EARTHQUAKES_OUTPUT_COLOR_GOOD:-2}"
EARTHQUAKES_OUTPUT_COLOR_ERROR="${EARTHQUAKES_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Enviroment overrides
EARTHQUAKES_API_URL="${EARTHQUAKES_API_URL:-https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$EARTHQUAKES_CONFIG_DIR/$EARTHQUAKES_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$EARTHQUAKES_CONFIG_DIR/$EARTHQUAKES_CONFIG_FILE" ] && . "$EARTHQUAKES_CONFIG_DIR/$EARTHQUAKES_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$EARTHQUAKES_LOG_DIR" ] || mkdir -p "$EARTHQUAKES_LOG_DIR" &>/dev/null
[ -d "$EARTHQUAKES_TEMP_DIR" ] || mkdir -p "$EARTHQUAKES_TEMP_DIR" &>/dev/null
[ -d "$EARTHQUAKES_CACHE_DIR" ] || mkdir -p "$EARTHQUAKES_CACHE_DIR" &>/dev/null
EARTHQUAKES_TEMP_FILE="${EARTHQUAKES_TEMP_FILE:-$(mktemp $EARTHQUAKES_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$EARTHQUAKES_TEMP_FILE" ] && [ -f "$EARTHQUAKES_TEMP_FILE" ] && rm -Rf "$EARTHQUAKES_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$EARTHQUAKES_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${EARTHQUAKES_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${EARTHQUAKES_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${EARTHQUAKES_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${EARTHQUAKES_NOTIFY_CLIENT_ICON}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    __help
    shift 1
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    EARTHQUAKES_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
RES="$(curl -q --fail -LSsf "$EARTHQUAKES_API_URL" 2>/dev/null || echo "")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [[ -n "$RES" ]]; then
  __output | sed '$!N; /^\(.*\)\n\1$/!P; D' | __yad__text "Earthquake Data" "$EARTHQUAKES_OUTPUT_COLOR" ||
    echo "$RES" | printf_readline "$EARTHQUAKES_OUTPUT_COLOR"
else
  printf_red "Failed to get earthquake data from"
  printf_yellow "$EARTHQUAKES_API_URL"
  exitCode=1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
