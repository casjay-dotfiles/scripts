#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$EMOJIS_TEMP_FILE" ] && rm -Rf "$EMOJIS_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : emojis --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : emojis
# @Description   : show and choose an emoji
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$EMOJIS_CONFIG_DIR/$EMOJIS_CONFIG_FILE"
  [ -d "$EMOJIS_CONFIG_DIR" ] || mkdir -p "$EMOJIS_CONFIG_DIR"
  [ -d "$EMOJIS_CONFIG_BACKUP_DIR" ] || mkdir -p "$EMOJIS_CONFIG_BACKUP_DIR"
  [ -f "$EMOJIS_CONFIG_DIR/$EMOJIS_CONFIG_FILE" ] &&
    cp -Rf "$EMOJIS_CONFIG_DIR/$EMOJIS_CONFIG_FILE" "$EMOJIS_CONFIG_BACKUP_DIR/$EMOJIS_CONFIG_FILE.$$"
  cat <<EOF >"$EMOJIS_CONFIG_DIR/$EMOJIS_CONFIG_FILE"
# Settings for emojis

# Notification settings
EMOJIS_GOOD_MESSAGE="${EMOJIS_GOOD_MESSAGE:-Everything Went OK}"
EMOJIS_ERROR_MESSAGE="${EMOJIS_ERROR_MESSAGE:-Well that didn\'t work}"
EMOJIS_NOTIFY_ENABLED="${EMOJIS_NOTIFY_ENABLED:-yes}"
EMOJIS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
EMOJIS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$EMOJIS_NOTIFY_CLIENT_ICON}"

# Colorization settings
EMOJIS_OUTPUT_COLOR="${EMOJIS_OUTPUT_COLOR:-5}"
EMOJIS_OUTPUT_COLOR_GOOD="${EMOJIS_OUTPUT_COLOR_GOOD:-2}"
EMOJIS_OUTPUT_COLOR_ERROR="${EMOJIS_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$EMOJIS_CONFIG_DIR/$EMOJIS_CONFIG_FILE" ]; then
    printf_green "Your config file for emojis has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
dmenu_emojis() {
  xclip -h 2>/dev/null || exit 1
  chosen=$(cut -d ';' -f1 $CASJAYSDEVDIR/helpers/emojis/emojis | dmenu -i -l 20 | sed "s/ .*//")
  [ "$chosen" != "" ] || exit
  if [ -n "$1" ]; then
    #xdotool key Shift+Insert
    xdotool key --clearmodifiers ctrl+shift+v
  else
    echo "$chosen" | tr -d '\n' | xclip -selection clipboard
    notifications "Emojify" "'$chosen' copied to clipboard." &
    xdotool key --clearmodifiers ctrl+shift+v
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
update_list() {
  emojify -l | awk '{print $2}' 2>/dev/null | tr '\n' ' ' | sed 's#-  emojify emojis: ##g'
  printf_newline "\n"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
EMOJIS_CACHE_DIR="${EMOJIS_CACHE_DIR:-$HOME/.cache/emojis}"
EMOJIS_CONFIG_DIR="${EMOJIS_CONFIG_DIR:-$HOME/.config/myscripts/emojis}"
EMOJIS_OPTIONS_DIR="${EMOJIS_OPTIONS_DIR:-$HOME/.local/share/myscripts/emojis/options}"
EMOJIS_CONFIG_BACKUP_DIR="${EMOJIS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/emojis/backups}"
EMOJIS_TEMP_DIR="${EMOJIS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/emojis}"
EMOJIS_TEMP_FILE="${EMOJIS_TEMP_FILE:-$(mktemp $EMOJIS_TEMP_DIR/XXXXXX 2>/dev/null)}"
EMOJIS_CONFIG_FILE="${EMOJIS_CONFIG_FILE:-settings.conf}"
EMOJIS_GOOD_MESSAGE="${EMOJIS_GOOD_MESSAGE:-Everything Went OK}"
EMOJIS_ERROR_MESSAGE="${EMOJIS_ERROR_MESSAGE:-Well that didn\'t work}"
EMOJIS_NOTIFY_ENABLED="${EMOJIS_NOTIFY_ENABLED:-yes}"
EMOJIS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
EMOJIS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$EMOJIS_NOTIFY_CLIENT_ICON}"
EMOJIS_OUTPUT_COLOR="${EMOJIS_OUTPUT_COLOR:-5}"
EMOJIS_OUTPUT_COLOR_GOOD="${EMOJIS_OUTPUT_COLOR_GOOD:-2}"
EMOJIS_OUTPUT_COLOR_ERROR="${EMOJIS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$EMOJIS_TEMP_DIR" ] || mkdir -p "$EMOJIS_TEMP_DIR" &>/dev/null
[ -d "$EMOJIS_CACHE_DIR" ] || mkdir -p "$EMOJIS_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$EMOJIS_CONFIG_DIR/$EMOJIS_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$EMOJIS_CONFIG_DIR/$EMOJIS_CONFIG_FILE" ] &&
  . "$EMOJIS_CONFIG_DIR/$EMOJIS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY="update dmenu search print list"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    EMOJIS_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$EMOJIS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${EMOJIS_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${EMOJIS_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${EMOJIS_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${EMOJIS_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
ARRAY="$(<${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/helpers/emojis/array)"
LIST="$(<${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/helpers/emojis/list)"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
update)
  mkdir -p "$HOME/.local/bin"
  curl -LSs https://raw.githubusercontent.com/mrowa44/emojify/master/emojify -o "$HOME/.local/bin/emojify" 2>/dev/null && chmod +x "$HOME/.local/bin/emojify"
  [ $? -eq 0 ] && printf_green "Update Successful" || printf_red "Update Failed"
  if (sudo -vn && sudo -ln) 2>&1 | grep -v 'may not' >/dev/null; then
    sudo mv -f "$HOME/.local/bin/emojify" /usr/local/bin/emojify &&
      update_list | sudo tee "$CASJAYSDEVDIR/helpers/emojis/list" &>/dev/null
    [ $? -eq 0 ] && printf_green "System Update Successful" || printf_red "System Update Failed"
  fi
  ;;

dmenu)
  if cmd_exists dmenu; then
    dmenu_emojis "$@"
    printf '\n'
  else
    printf_exit "dmenu doesn't seem to be installed"
  fi
  ;;

search)
  shift 1
  var="$1"
  emojify --list | grep "$var"
  ;;

print)
  shift 1
  if [ $# -eq 0 ]; then
    if [ -p "/dev/stdin" ]; then
      message="$(</dev/stdin)"
    else
      __help
    fi
  else
    message="$*"
  fi
  emojify "$message" | printf_readline 2
  ;;

list)
  printf_red "List of available emojis - Just copy and use"
  column "$CASJAYSDEVDIR/helpers/emojis/list"
  ;;

*) __help ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
