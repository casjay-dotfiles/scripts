#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$ENCRYPT_TEMP_FILE" ] && rm -Rf "$ENCRYPT_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : encrypt --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : encrypt
# @Description   : perl oneliner is to enable encrypt files
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$ENCRYPT_CONFIG_DIR/$ENCRYPT_CONFIG_FILE"
  [ -d "$ENCRYPT_CONFIG_DIR" ] || mkdir -p "$ENCRYPT_CONFIG_DIR"
  [ -d "$ENCRYPT_CONFIG_BACKUP_DIR" ] || mkdir -p "$ENCRYPT_CONFIG_BACKUP_DIR"
  [ -f "$ENCRYPT_CONFIG_DIR/$ENCRYPT_CONFIG_FILE" ] &&
    cp -Rf "$ENCRYPT_CONFIG_DIR/$ENCRYPT_CONFIG_FILE" "$ENCRYPT_CONFIG_BACKUP_DIR/$ENCRYPT_CONFIG_FILE.$$"
  cat <<EOF >"$ENCRYPT_CONFIG_DIR/$ENCRYPT_CONFIG_FILE"
# Settings for encrypt

# Notification settings
ENCRYPT_GOOD_MESSAGE="${ENCRYPT_GOOD_MESSAGE:-Everything Went OK}"
ENCRYPT_ERROR_MESSAGE="${ENCRYPT_ERROR_MESSAGE:-Well that didn\'t work}"
ENCRYPT_NOTIFY_ENABLED="${ENCRYPT_NOTIFY_ENABLED:-yes}"
ENCRYPT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
ENCRYPT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$ENCRYPT_NOTIFY_CLIENT_ICON}"

# Colorization settings
ENCRYPT_OUTPUT_COLOR="${ENCRYPT_OUTPUT_COLOR:-5}"
ENCRYPT_OUTPUT_COLOR_GOOD="${ENCRYPT_OUTPUT_COLOR_GOOD:-2}"
ENCRYPT_OUTPUT_COLOR_ERROR="${ENCRYPT_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$ENCRYPT_CONFIG_DIR/$ENCRYPT_CONFIG_FILE" ]; then
    printf_green "Your config file for encrypt has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
ENCRYPT_CACHE_DIR="${ENCRYPT_CACHE_DIR:-$HOME/.cache/encrypt}"
ENCRYPT_CONFIG_DIR="${ENCRYPT_CONFIG_DIR:-$HOME/.config/myscripts/encrypt}"
ENCRYPT_OPTIONS_DIR="${ENCRYPT_OPTIONS_DIR:-$HOME/.local/share/myscripts/encrypt/options}"
ENCRYPT_CONFIG_BACKUP_DIR="${ENCRYPT_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/encrypt/backups}"
ENCRYPT_TEMP_DIR="${ENCRYPT_TEMP_DIR:-$HOME/.local/tmp/system_scripts/encrypt}"
ENCRYPT_TEMP_FILE="${ENCRYPT_TEMP_FILE:-$(mktemp $ENCRYPT_TEMP_DIR/XXXXXX 2>/dev/null)}"
ENCRYPT_CONFIG_FILE="${ENCRYPT_CONFIG_FILE:-settings.conf}"
ENCRYPT_GOOD_MESSAGE="${ENCRYPT_GOOD_MESSAGE:-Everything Went OK}"
ENCRYPT_ERROR_MESSAGE="${ENCRYPT_ERROR_MESSAGE:-Well that didn\'t work}"
ENCRYPT_NOTIFY_ENABLED="${ENCRYPT_NOTIFY_ENABLED:-yes}"
ENCRYPT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
ENCRYPT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$ENCRYPT_NOTIFY_CLIENT_ICON}"
ENCRYPT_OUTPUT_COLOR="${ENCRYPT_OUTPUT_COLOR:-5}"
ENCRYPT_OUTPUT_COLOR_GOOD="${ENCRYPT_OUTPUT_COLOR_GOOD:-2}"
ENCRYPT_OUTPUT_COLOR_ERROR="${ENCRYPT_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$ENCRYPT_TEMP_DIR" ] || mkdir -p "$ENCRYPT_TEMP_DIR" &>/dev/null
[ -d "$ENCRYPT_CACHE_DIR" ] || mkdir -p "$ENCRYPT_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$ENCRYPT_CONFIG_DIR/$ENCRYPT_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$ENCRYPT_CONFIG_DIR/$ENCRYPT_CONFIG_FILE" ] &&
  . "$ENCRYPT_CONFIG_DIR/$ENCRYPT_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    ENCRYPT_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$ENCRYPT_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${ENCRYPT_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${ENCRYPT_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${ENCRYPT_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${ENCRYPT_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ -t 0 ]; then
  fname="$1"
  shift
  openssl aes-256-cbc -pbkdf2 -salt -in "$fname" -out "${fname}.enc" "$@"
else
  perl -e 'use IO::Select; $ready=IO::Select->new(STDIN)->can_read();'
  openssl aes-256-cbc -pbkdf2 -salt "$@"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
