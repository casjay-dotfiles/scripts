#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : expandurl --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : expandurl
# @Description   : Get full url from a shortner and copy to clipboard
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$EXPANDURL_TEMP_FILE" ] && [ -f "$EXPANDURL_TEMP_FILE" ] && rm -Rf "$EXPANDURL_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$EXPANDURL_CONFIG_DIR/$EXPANDURL_CONFIG_FILE"
  [ -d "$EXPANDURL_CONFIG_DIR" ] || mkdir -p "$EXPANDURL_CONFIG_DIR"
  [ -d "$EXPANDURL_CONFIG_BACKUP_DIR" ] || mkdir -p "$EXPANDURL_CONFIG_BACKUP_DIR"
  [ -f "$EXPANDURL_CONFIG_DIR/$EXPANDURL_CONFIG_FILE" ] &&
    cp -Rf "$EXPANDURL_CONFIG_DIR/$EXPANDURL_CONFIG_FILE" "$EXPANDURL_CONFIG_BACKUP_DIR/$EXPANDURL_CONFIG_FILE.$$"
  cat <<EOF >"$EXPANDURL_CONFIG_DIR/$EXPANDURL_CONFIG_FILE"
# Settings for expandurl

# Notification settings
EXPANDURL_GOOD_MESSAGE="${EXPANDURL_GOOD_MESSAGE:-Everything Went OK}"
EXPANDURL_ERROR_MESSAGE="${EXPANDURL_ERROR_MESSAGE:-Well something seems to have gone wrong}"
EXPANDURL_NOTIFY_ENABLED="${EXPANDURL_NOTIFY_ENABLED:-yes}"
EXPANDURL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
EXPANDURL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$EXPANDURL_NOTIFY_CLIENT_ICON}"

# Colorization settings
EXPANDURL_OUTPUT_COLOR="${EXPANDURL_OUTPUT_COLOR:-5}"
EXPANDURL_OUTPUT_COLOR_GOOD="${EXPANDURL_OUTPUT_COLOR_GOOD:-2}"
EXPANDURL_OUTPUT_COLOR_ERROR="${EXPANDURL_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$EXPANDURL_CONFIG_DIR/$EXPANDURL_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      unset INIT_CONFIG
      eval bash -c "$APPNAME $*"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
EXPANDURL_LOG_DIR="${EXPANDURL_LOG_DIR:-$HOME/.local/log/expandurl}"
EXPANDURL_CACHE_DIR="${EXPANDURL_CACHE_DIR:-$HOME/.cache/expandurl}"
EXPANDURL_CONFIG_DIR="${EXPANDURL_CONFIG_DIR:-$HOME/.config/myscripts/expandurl}"
EXPANDURL_CONFIG_BACKUP_DIR="${EXPANDURL_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/expandurl/backups}"
EXPANDURL_TEMP_DIR="${EXPANDURL_TEMP_DIR:-$HOME/.local/tmp/system_scripts/expandurl}"
EXPANDURL_OPTIONS_DIR="${EXPANDURL_OPTIONS_DIR:-$HOME/.local/share/myscripts/expandurl/options}"
EXPANDURL_TEMP_FILE="${EXPANDURL_TEMP_FILE:-$(mktemp $EXPANDURL_TEMP_DIR/XXXXXX 2>/dev/null)}"
EXPANDURL_CONFIG_FILE="${EXPANDURL_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
EXPANDURL_OUTPUT_COLOR="${EXPANDURL_OUTPUT_COLOR:-4}"
EXPANDURL_OUTPUT_COLOR_2="${EXPANDURL_OUTPUT_COLOR:-6}"
EXPANDURL_OUTPUT_COLOR_GOOD="${EXPANDURL_OUTPUT_COLOR_GOOD:-2}"
EXPANDURL_OUTPUT_COLOR_ERROR="${EXPANDURL_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
EXPANDURL_GOOD_MESSAGE="${EXPANDURL_GOOD_MESSAGE:-Everything Went OK}"
EXPANDURL_ERROR_MESSAGE="${EXPANDURL_ERROR_MESSAGE:-Well something seems to have gone wrong}"
EXPANDURL_NOTIFY_ENABLED="${EXPANDURL_NOTIFY_ENABLED:-yes}"
EXPANDURL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
EXPANDURL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$EXPANDURL_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$EXPANDURL_CONFIG_DIR/$EXPANDURL_CONFIG_FILE" ] && . "$EXPANDURL_CONFIG_DIR/$EXPANDURL_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$EXPANDURL_LOG_DIR" ] || mkdir -p "$EXPANDURL_LOG_DIR" &>/dev/null
[ -d "$EXPANDURL_TEMP_DIR" ] || mkdir -p "$EXPANDURL_TEMP_DIR" &>/dev/null
[ -d "$EXPANDURL_CACHE_DIR" ] || mkdir -p "$EXPANDURL_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$EXPANDURL_CONFIG_DIR/$EXPANDURL_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    EXPANDURL_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$EXPANDURL_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${EXPANDURL_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${EXPANDURL_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${EXPANDURL_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${EXPANDURL_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash curl || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
URL="$1"
GET_URL="$(curl -q -ILSsi "$URL" 2>/dev/null | grep -v "$URL" | grep -i ^Location | awk '{print $2}' | grep '^')"
[[ -n "$URL" ]] || printf_exit "Nothing to expand"
[[ -n "$GET_URL" ]] || printf_exit "Your search for $URL returned no results"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [[ -n "$GET_URL" ]]; then
  __notifications "Found:\n" "$GET_URL\ncopied to your clipboard"
  printf_blue "Found the following url[s]"
  echo "$GET_URL" | clipboard &>/dev/null
  echo "$GET_URL" | printf_readline $EXPANDURL_OUTPUT_COLOR
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
