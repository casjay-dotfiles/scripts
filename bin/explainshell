#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108130127-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$EXPLAINSHELL_TEMP_FILE" ] && rm -Rf "$EXPLAINSHELL_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108130127-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : explainshell --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Friday, Aug 13, 2021 01:27 EDT
# @File          : explainshell
# @Description   : search explainshell.com for commands
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_available() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$EXPLAINSHELL_CONFIG_DIR/$EXPLAINSHELL_CONFIG_FILE"
  [ -d "$EXPLAINSHELL_CONFIG_DIR" ] || mkdir -p "$EXPLAINSHELL_CONFIG_DIR"
  [ -d "$EXPLAINSHELL_CONFIG_BACKUP_DIR" ] || mkdir -p "$EXPLAINSHELL_CONFIG_BACKUP_DIR"
  [ -f "$EXPLAINSHELL_CONFIG_DIR/$EXPLAINSHELL_CONFIG_FILE" ] &&
    cp -Rf "$EXPLAINSHELL_CONFIG_DIR/$EXPLAINSHELL_CONFIG_FILE" "$EXPLAINSHELL_CONFIG_BACKUP_DIR/$EXPLAINSHELL_CONFIG_FILE.$$"
  cat <<EOF >"$EXPLAINSHELL_CONFIG_DIR/$EXPLAINSHELL_CONFIG_FILE"
# Settings for explainshell
EXPLAINSHELL_API="https://explainshell.com/explain"

# Notification settings
EXPLAINSHELL_GOOD_MESSAGE="${EXPLAINSHELL_GOOD_MESSAGE:-Everything Went OK}"
EXPLAINSHELL_ERROR_MESSAGE="${EXPLAINSHELL_ERROR_MESSAGE:-Well that didn\'t work}"
EXPLAINSHELL_NOTIFY_ENABLED="${EXPLAINSHELL_NOTIFY_ENABLED:-yes}"
EXPLAINSHELL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$PROG}"
EXPLAINSHELL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$EXPLAINSHELL_NOTIFY_CLIENT_ICON}"

EOF
  if [ -f "$EXPLAINSHELL_CONFIG_DIR/$EXPLAINSHELL_CONFIG_FILE" ]; then
    printf_green "Your config file for explainshell has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__explain() {
  local HEAD="$(curl -q -ILSsi "$URL" | grep '200 OK' | grep '^.' || false)"
  if [ -z "$HEAD" ]; then
    printf "Received an invalid response"
    return 1
  else
    curl -q -LSs "$URL" |
      sed -e '/<script/,/<\/script>/d' |
      sed -e '/(function/,/});/d' |
      sed -n '/<pre/,/<\/pre>/p' |
      sed -s 's/<[^>]*>//g' |
      sed -e 's/^ *//g;s/ *$//g' |
      grep '.'
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
EXPLAINSHELL_CACHE_DIR="${EXPLAINSHELL_CACHE_DIR:-$HOME/.cache/explainshell}"
EXPLAINSHELL_CONFIG_DIR="${EXPLAINSHELL_CONFIG_DIR:-$HOME/.config/myscripts/explainshell}"
EXPLAINSHELL_OPTIONS_DIR="${EXPLAINSHELL_OPTIONS_DIR:-$HOME/.local/share/myscripts/explainshell/options}"
EXPLAINSHELL_CONFIG_BACKUP_DIR="${EXPLAINSHELL_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/explainshell/backups}"
EXPLAINSHELL_TEMP_DIR="${EXPLAINSHELL_TEMP_DIR/system_scripts/explainshell:-$HOME/.local/tmp/system_scripts/explainshell}"
EXPLAINSHELL_TEMP_FILE="${EXPLAINSHELL_TEMP_DIR:-$HOME/.local/tmp/explainshell}"
EXPLAINSHELL_CONFIG_FILE="${EXPLAINSHELL_CONFIG_FILE:-settings.conf}"
EXPLAINSHELL_GOOD_MESSAGE="${EXPLAINSHELL_GOOD_MESSAGE:-Everything Went OK}"
EXPLAINSHELL_ERROR_MESSAGE="${EXPLAINSHELL_ERROR_MESSAGE:-Well that didn\'t work}"
EXPLAINSHELL_NOTIFY_ENABLED="${EXPLAINSHELL_NOTIFY_ENABLED:-yes}"
EXPLAINSHELL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
EXPLAINSHELL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$EXPLAINSHELL_NOTIFY_CLIENT_ICON}"
EXPLAINSHELL_API="https://explainshell.com/explain"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$EXPLAINSHELL_TEMP_DIR" ] || mkdir -p "$EXPLAINSHELL_TEMP_DIR" &>/dev/null
[ -d "$EXPLAINSHELL_CACHE_DIR" ] || mkdir -p "$EXPLAINSHELL_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$EXPLAINSHELL_CONFIG_DIR/$EXPLAINSHELL_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$EXPLAINSHELL_CONFIG_DIR/$EXPLAINSHELL_CONFIG_FILE" ] &&
  . "$EXPLAINSHELL_CONFIG_DIR/$EXPLAINSHELL_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h,z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
for opts in $SETARGS; do
  echo "$opts" | grep -q '\-' && OPTS+="${opts} "
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_available "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_available "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_available "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  -v | --version)
    shift 1
    __version
    exit $?
    ;;
  -h | --help)
    shift 1
    __help
    exit $?
    ;;
  -c | --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    shift 1
    GEN_SCRIPT_REPLACE_CWD="$1"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$EXPLAINSHELL_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${EXPLAINSHELL_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${EXPLAINSHELL_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${EXPLAINSHELL_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${EXPLAINSHELL_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash curl || exit 1 # exit 1 if not found
#am_i_online --error || exit       # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
CMD="$1" && shift 1
ARGS="${OPTS:-}" && shift $#
CMD=$(echo "$CMD" | sed -e 's/%/%25/g')
CMD=$(echo "$CMD" | sed -e 's/ /%20/g')
CMD=$(echo "$CMD" | sed -e 's/!/%21/g')
CMD=$(echo "$CMD" | sed -e 's/"/%22/g')
CMD=$(echo "$CMD" | sed -e 's/#/%23/g')
CMD=$(echo "$CMD" | sed -e 's/\$/%24/g')
CMD=$(echo "$CMD" | sed -e 's/\&/%26/g')
CMD=$(echo "$CMD" | sed -e 's/'\''/%27/g')
CMD=$(echo "$CMD" | sed -e 's/'\('/%28/g')
CMD=$(echo "$CMD" | sed -e 's/'\)'/%29/g')
CMD=$(echo "$CMD" | sed -e 's/\*/%2a/g')
CMD=$(echo "$CMD" | sed -e 's/+/%2b/g')
CMD=$(echo "$CMD" | sed -e 's/,/%2c/g')
CMD=$(echo "$CMD" | sed -e 's/-/%2d/g')
CMD=$(echo "$CMD" | sed -e 's/\./%2e/g')
CMD=$(echo "$CMD" | sed -e 's/\//%2f/g')
CMD=$(echo "$CMD" | sed -e 's/:/%3a/g')
CMD=$(echo "$CMD" | sed -e 's/;/%3b/g')
CMD=$(echo "$CMD" | sed -e 's/>/%3e/g')
CMD=$(echo "$CMD" | sed -e 's/?/%3f/g')
CMD=$(echo "$CMD" | sed -e 's/@/%40/g')
CMD=$(echo "$CMD" | sed -e 's/\[/%5b/g')
CMD=$(echo "$CMD" | sed -e 's/\\/%5c/g')
CMD=$(echo "$CMD" | sed -e 's/\]/%5d/g')
CMD=$(echo "$CMD" | sed -e 's/\^/%5e/g')
CMD=$(echo "$CMD" | sed -e 's/_/%5f/g')
CMD=$(echo "$CMD" | sed -e 's/`/%60/g')
CMD=$(echo "$CMD" | sed -e 's/{/%7b/g')
CMD=$(echo "$CMD" | sed -e 's/|/%7c/g')
CMD=$(echo "$CMD" | sed -e 's/}/%7d/g')
CMD=$(echo "$CMD" | sed -e 's/~/%7e/g')
URL=$(echo "$EXPLAINSHELL_API/$CMD?args=$ARGS" | sed -e 's/ /+/g' | grep '^')
RESULTS="$(__explain | grep '^')"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
printf_newline
echo "$RESULTS" | printf_readline
printf_newline
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
