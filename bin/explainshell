#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#set opts

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202103200708-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : explainshell --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Saturday, Mar 20, 2021 07:08 EDT
# @File          : explainshell
# @Description   : search explainshell.com for commands
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/master/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
__explain() {
  curl -LSs "$URL" |
    sed -n '/<pre/,/<\/pre>/p' |
    sed -n '/<pre/,/<\/pre>/p' |
    sed -s 's/<[^>]*>//g' |
    sed -e 's/^ *//g;s/ *$//g' |
    grep '.'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
cmd_exists curl || exit 1
__am_i_online_err || exit 1
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -z "$1" ] || [ -z "$2" ]; then __help; fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
CMD="$1" && shift 1
ARGS=${*} && shift $#
URL=$(echo "http://explainshell.com/explain/$CMD?args=$ARGS" | sed -e 's/ /+/g')
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
RESPONSE="$(__explain)"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if echo "$RESPONSE" | grep -q "GoogleAnalyticsObject"; then
  printf_return "Recieved an invalid response"
else
  printf_newline
  printf_blue "$RESPONSE" | printf_readline
  printf_newline
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
exit $?
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
