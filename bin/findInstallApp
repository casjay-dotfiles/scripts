#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : findInstallApp --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : findInstallApp
# @Description   : Try to find and install the application
# @TODO          : Add zenity prompts
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$FINDINSTALLAPP_TEMP_FILE" ] && [ -f "$FINDINSTALLAPP_TEMP_FILE" ] && rm -Rf "$FINDINSTALLAPP_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$FINDINSTALLAPP_CONFIG_DIR/$FINDINSTALLAPP_CONFIG_FILE"
  [ -d "$FINDINSTALLAPP_CONFIG_DIR" ] || mkdir -p "$FINDINSTALLAPP_CONFIG_DIR"
  [ -d "$FINDINSTALLAPP_CONFIG_BACKUP_DIR" ] || mkdir -p "$FINDINSTALLAPP_CONFIG_BACKUP_DIR"
  [ -f "$FINDINSTALLAPP_CONFIG_DIR/$FINDINSTALLAPP_CONFIG_FILE" ] &&
    cp -Rf "$FINDINSTALLAPP_CONFIG_DIR/$FINDINSTALLAPP_CONFIG_FILE" "$FINDINSTALLAPP_CONFIG_BACKUP_DIR/$FINDINSTALLAPP_CONFIG_FILE.$$"
  cat <<EOF >"$FINDINSTALLAPP_CONFIG_DIR/$FINDINSTALLAPP_CONFIG_FILE"
# Settings for findInstallApp

# Notification settings
FINDINSTALLAPP_GOOD_MESSAGE="${FINDINSTALLAPP_GOOD_MESSAGE:-Everything Went OK}"
FINDINSTALLAPP_ERROR_MESSAGE="${FINDINSTALLAPP_ERROR_MESSAGE:-Well something seems to have gone wrong}"
FINDINSTALLAPP_NOTIFY_ENABLED="${FINDINSTALLAPP_NOTIFY_ENABLED:-yes}"
FINDINSTALLAPP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
FINDINSTALLAPP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$FINDINSTALLAPP_NOTIFY_CLIENT_ICON}"

# Colorization settings
FINDINSTALLAPP_OUTPUT_COLOR="${FINDINSTALLAPP_OUTPUT_COLOR:-5}"
FINDINSTALLAPP_OUTPUT_COLOR_GOOD="${FINDINSTALLAPP_OUTPUT_COLOR_GOOD:-2}"
FINDINSTALLAPP_OUTPUT_COLOR_ERROR="${FINDINSTALLAPP_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$FINDINSTALLAPP_CONFIG_DIR/$FINDINSTALLAPP_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      unset INIT_CONFIG
      eval bash -c "$APPNAME $@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__dfmgr() { dfmgr "$*" &>/dev/null && return 0 || return 1; }
__pkmgr() { pkmgr "$*" &>/dev/null && return 0 || return 1; }
__systemmgr() { sudo systemmgr "$*" &>/dev/null && return 0 || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__message() {
  local mgr="$1" && shift 1
  local arg="$*" && shift $#
  if [ -z "$DISPLAY" ] || [ -n "$SSH_TTY" ]; then
    printf_green "Trying to find $arg via $mgr"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
run_requires() {
  local ARGS="$*"
  for cmd in $ARGS; do
    cmd_exists "$cmd " || local CMD+="$cmd "
  done
  if [ -n "$CMD" ]; then __require_app "$CMD" && exitCode=0 || exitCode=1; fi
  [ $exitCode -eq 0 ] && return 0 || exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
run_pkmgr_findInstallApp() {
  cmd_exists pkmgr || return 1
  local pkg LISTARRAY
  declare -a LISTARRAY="$*"
  __message "pkmgr" "$LISTARRAY"
  for pkg in ${LISTARRAY[*]}; do
    cmd_exists "$pkg" || __pkmgr install "$pkg"
  done
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
run_dfmgr_findInstallApp() {
  cmd_exists dfmgr || return 1
  local pkg LISTARRAY
  declare -a LISTARRAY="$*"
  __message "dfmgr" "$LISTARRAY"
  for pkg in ${LISTARRAY[*]}; do
    cmd_exists "$pkg" || __dfmgr install "$pkg"
  done
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
run_systemmgr_findInstallApp() {
  cmd_exists systemmgr || return 1
  local pkg LISTARRAY
  declare -a LISTARRAY="$*"
  __message "systemmgr" "$LISTARRAY"
  for pkg in ${LISTARRAY[*]}; do
    cmd_exists "$pkg" || __systemmgr install "$pkg"
  done
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
run_npm_findInstallApp() {
  cmd_exists npm || return 1
  local pkg LISTARRAY
  declare -a LISTARRAY="$*"
  __message "npm" "$LISTARRAY"
  for pkg in ${LISTARRAY[*]}; do
    cmd_exists "$pkg" || __pkmgr npm install "$pkg"
    exitCode+=$?
  done
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run() {
  if am_i_online && [ $# -ne 0 ]; then
    run_pkmgr_findInstallApp "$@" ||
      run_dfmgr_findInstallApp "$@" ||
      run_systemmgr_findInstallApp "$@" ||
      run_npm_findInstallApp "$@" ||
      export exitCode=$?
  else
    sleep 3
    export exitCode=1
  fi
  return=$exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
FINDINSTALLAPP_LOG_DIR="${FINDINSTALLAPP_LOG_DIR:-$HOME/.local/log/findInstallApp}"
FINDINSTALLAPP_CACHE_DIR="${FINDINSTALLAPP_CACHE_DIR:-$HOME/.cache/findInstallApp}"
FINDINSTALLAPP_CONFIG_DIR="${FINDINSTALLAPP_CONFIG_DIR:-$HOME/.config/myscripts/findInstallApp}"
FINDINSTALLAPP_CONFIG_BACKUP_DIR="${FINDINSTALLAPP_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/findInstallApp/backups}"
FINDINSTALLAPP_TEMP_DIR="${FINDINSTALLAPP_TEMP_DIR:-$HOME/.local/tmp/system_scripts/findInstallApp}"
FINDINSTALLAPP_OPTIONS_DIR="${FINDINSTALLAPP_OPTIONS_DIR:-$HOME/.local/share/myscripts/findInstallApp/options}"
FINDINSTALLAPP_TEMP_FILE="${FINDINSTALLAPP_TEMP_FILE:-$(mktemp $FINDINSTALLAPP_TEMP_DIR/XXXXXX 2>/dev/null)}"
FINDINSTALLAPP_CONFIG_FILE="${FINDINSTALLAPP_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
FINDINSTALLAPP_OUTPUT_COLOR="${FINDINSTALLAPP_OUTPUT_COLOR:-4}"
FINDINSTALLAPP_OUTPUT_COLOR_2="${FINDINSTALLAPP_OUTPUT_COLOR:-6}"
FINDINSTALLAPP_OUTPUT_COLOR_GOOD="${FINDINSTALLAPP_OUTPUT_COLOR_GOOD:-2}"
FINDINSTALLAPP_OUTPUT_COLOR_ERROR="${FINDINSTALLAPP_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
FINDINSTALLAPP_GOOD_MESSAGE="${FINDINSTALLAPP_GOOD_MESSAGE:-Everything Went OK}"
FINDINSTALLAPP_ERROR_MESSAGE="${FINDINSTALLAPP_ERROR_MESSAGE:-Well something seems to have gone wrong}"
FINDINSTALLAPP_NOTIFY_ENABLED="${FINDINSTALLAPP_NOTIFY_ENABLED:-yes}"
FINDINSTALLAPP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
FINDINSTALLAPP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$FINDINSTALLAPP_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$FINDINSTALLAPP_CONFIG_DIR/$FINDINSTALLAPP_CONFIG_FILE" ] && . "$FINDINSTALLAPP_CONFIG_DIR/$FINDINSTALLAPP_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$FINDINSTALLAPP_LOG_DIR" ] || mkdir -p "$FINDINSTALLAPP_LOG_DIR" &>/dev/null
[ -d "$FINDINSTALLAPP_TEMP_DIR" ] || mkdir -p "$FINDINSTALLAPP_TEMP_DIR" &>/dev/null
[ -d "$FINDINSTALLAPP_CACHE_DIR" ] || mkdir -p "$FINDINSTALLAPP_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$FINDINSTALLAPP_CONFIG_DIR/$FINDINSTALLAPP_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    FINDINSTALLAPP_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$FINDINSTALLAPP_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${FINDINSTALLAPP_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${FINDINSTALLAPP_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${FINDINSTALLAPP_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${FINDINSTALLAPP_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
sudoif && ask_for_password true || printf_exit "$APPNAME requires root privileges"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -n "$DISPLAY" ] && [ -z "$SSH_TTY" ]; then
  if __run "$@" | zenity --progress --no-cancel --pulsate --auto-close --title="Attempting install" --text="Trying to install $*" --height=200 --width=400; then exitCode=0; else exitCode=1; fi
else
  if __run "$@"; then exitCode=0; else exitCode=1; fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ "$exitCode" = 0 ]; then
  if [ -n "$DISPLAY" ] && [ -z "$SSH_TTY" ]; then
    zenity --timeout=10 --height=200 --width=400 --info --title="Install successful" --text="Successfully installed $*"
  else
    printf_green "Successfully installed $*"
  fi
  exitCode=0
else
  if [ -n "$DISPLAY" ] && [ -z "$SSH_TTY" ]; then
    zenity --timeout=10 --height=200 --width=400 --error --title="Install unsuccessful" --text="Failed to install $*"
  else
    printf_error "Failed to install $*"
  fi
  exitCode=1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
