#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : findmypi --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : findmypi
# @Description   : Script to find a raspberry pi on your network
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$FINDMYPI_TEMP_FILE" ] && [ -f "$FINDMYPI_TEMP_FILE" ] && rm -Rf "$FINDMYPI_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$FINDMYPI_CONFIG_DIR/$FINDMYPI_CONFIG_FILE"
  [ -d "$FINDMYPI_CONFIG_DIR" ] || mkdir -p "$FINDMYPI_CONFIG_DIR"
  [ -d "$FINDMYPI_CONFIG_BACKUP_DIR" ] || mkdir -p "$FINDMYPI_CONFIG_BACKUP_DIR"
  [ -f "$FINDMYPI_CONFIG_DIR/$FINDMYPI_CONFIG_FILE" ] &&
    cp -Rf "$FINDMYPI_CONFIG_DIR/$FINDMYPI_CONFIG_FILE" "$FINDMYPI_CONFIG_BACKUP_DIR/$FINDMYPI_CONFIG_FILE.$$"
  cat <<EOF >"$FINDMYPI_CONFIG_DIR/$FINDMYPI_CONFIG_FILE"
# Settings for findmypi

# Notification settings
FINDMYPI_GOOD_MESSAGE="${FINDMYPI_GOOD_MESSAGE:-Everything Went OK}"
FINDMYPI_ERROR_MESSAGE="${FINDMYPI_ERROR_MESSAGE:-Well something seems to have gone wrong}"
FINDMYPI_NOTIFY_ENABLED="${FINDMYPI_NOTIFY_ENABLED:-yes}"
FINDMYPI_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
FINDMYPI_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$FINDMYPI_NOTIFY_CLIENT_ICON}"

# Colorization settings
FINDMYPI_OUTPUT_COLOR="${FINDMYPI_OUTPUT_COLOR:-5}"
FINDMYPI_OUTPUT_COLOR_GOOD="${FINDMYPI_OUTPUT_COLOR_GOOD:-2}"
FINDMYPI_OUTPUT_COLOR_ERROR="${FINDMYPI_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$FINDMYPI_CONFIG_DIR/$FINDMYPI_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      unset INIT_CONFIG
      eval bash -c "$APPNAME $@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__gethostname() {
  local host="$1"
  cmd_exists nslookup && sethost="$(getent hosts $host 2>/dev/null | head -n 1 | awk '{print $2}')"
  echo "$host    $sethost" >>"$HOME/Documents/raspis.txt" 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
FINDMYPI_LOG_DIR="${FINDMYPI_LOG_DIR:-$HOME/.local/log/findmypi}"
FINDMYPI_CACHE_DIR="${FINDMYPI_CACHE_DIR:-$HOME/.cache/findmypi}"
FINDMYPI_CONFIG_DIR="${FINDMYPI_CONFIG_DIR:-$HOME/.config/myscripts/findmypi}"
FINDMYPI_CONFIG_BACKUP_DIR="${FINDMYPI_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/findmypi/backups}"
FINDMYPI_TEMP_DIR="${FINDMYPI_TEMP_DIR:-$HOME/.local/tmp/system_scripts/findmypi}"
FINDMYPI_OPTIONS_DIR="${FINDMYPI_OPTIONS_DIR:-$HOME/.local/share/myscripts/findmypi/options}"
FINDMYPI_TEMP_FILE="${FINDMYPI_TEMP_FILE:-$(mktemp $FINDMYPI_TEMP_DIR/XXXXXX 2>/dev/null)}"
FINDMYPI_CONFIG_FILE="${FINDMYPI_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
FINDMYPI_OUTPUT_COLOR="${FINDMYPI_OUTPUT_COLOR:-4}"
FINDMYPI_OUTPUT_COLOR_2="${FINDMYPI_OUTPUT_COLOR:-6}"
FINDMYPI_OUTPUT_COLOR_GOOD="${FINDMYPI_OUTPUT_COLOR_GOOD:-2}"
FINDMYPI_OUTPUT_COLOR_ERROR="${FINDMYPI_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
FINDMYPI_GOOD_MESSAGE="${FINDMYPI_GOOD_MESSAGE:-Everything Went OK}"
FINDMYPI_ERROR_MESSAGE="${FINDMYPI_ERROR_MESSAGE:-Well something seems to have gone wrong}"
FINDMYPI_NOTIFY_ENABLED="${FINDMYPI_NOTIFY_ENABLED:-yes}"
FINDMYPI_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
FINDMYPI_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$FINDMYPI_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$FINDMYPI_CONFIG_DIR/$FINDMYPI_CONFIG_FILE" ] && . "$FINDMYPI_CONFIG_DIR/$FINDMYPI_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$FINDMYPI_LOG_DIR" ] || mkdir -p "$FINDMYPI_LOG_DIR" &>/dev/null
[ -d "$FINDMYPI_TEMP_DIR" ] || mkdir -p "$FINDMYPI_TEMP_DIR" &>/dev/null
[ -d "$FINDMYPI_CACHE_DIR" ] || mkdir -p "$FINDMYPI_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$FINDMYPI_CONFIG_DIR/$FINDMYPI_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    FINDMYPI_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$FINDMYPI_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${FINDMYPI_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${FINDMYPI_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${FINDMYPI_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${FINDMYPI_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash nmap || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
default_if=$(ip route list | awk '/^default/ {print $5}')
[ -z "$1" ] && ip="$(ip -o -f inet addr show $default_if | awk '{print $4}' | awk -F/ '{print $1}')" || ip="$1"
[ -z "$2" ] && nm="$(ip -o -f inet addr show $default_if | awk '{print $4}' | awk -F/ '{print $2}')" || nm="$2"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
sudoif && ask_for_password true || printf_exit "nmap requires root privileges"
printf_green "Searching the $ip/$nm network for your Raspberry PI"
printf_green "Depending on your network range this may take some time\n"
sudo nmap -sP "$ip"/"$nm" 2>/dev/null | awk '/^Nmap/{ip=$NF}/Raspberry Pi/{print ip}' | sed 's#(##g' | sed 's#)##g' | tee "$FINDMYPI_TEMP_FILE" &>/dev/null
if [ -s "$FINDMYPI_TEMP_FILE" ]; then
  while IFS="" read -r device || [ -n "$device" ]; do
    printf_cyan "I have found the following device[s]: $device"
    __gethostname "$device"
  done <"$FINDMYPI_TEMP_FILE"
  echo "" && printf_blue "Saved the list to $HOME/Documents/MyRaspi.txt"
else
  printf_red "I didn't find a Raspberry PI on your network"
fi
__rm_rf "$FINDMYPI_TEMP_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
