#!/usr/bin/env bash
# shellcheck shell=bash
# - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version           :  202606040822-git
# @@Author           :  Jason Hempstead
# @@Contact          :  jason@casjaysdev.pro
# @@License          :  WTFPL
# @@ReadME           :  for_each_in --help
# @@Copyright        :  Copyright: (c) 2026 Jason Hempstead, Casjays Developments
# @@Created          :  Friday, May 15, 2026 12:43 EDT
# @@File             :  for_each_in
# @@Description      :  Run a command for each item matching a glob — registry-aware injection
# @@Changelog        :  Rewrite: drop placeholder system, add command registry for --dir/-C/destdir injection
# @@TODO             :
# @@Other            :
# @@Resource         :
# @@Terminal App     :  no
# @@sudo/root        :  no
# @@Template         :  bash/system
# - - - - - - - - - - - - - - - - - - - - - - - - -
# shellcheck disable=SC1001,SC1003,SC2001,SC2003,SC2016,SC2031,SC2090,SC2115,SC2120,SC2155,SC2199,SC2229,SC2317,SC2329
# - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="${0##*/}"
VERSION="202605181200-git"
USER="${SUDO_USER:-$USER}"
export CASJAYSDEV_TITLE_PREV="${CASJAYSDEV_TITLE_PREV:-${CASJAYSDEV_TITLE_SET:-$APPNAME}}" CASJAYSDEV_TITLE_SET
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Initial debugging
[ "$1" = "--debug" ] && set -x && export SCRIPT_OPTS="--debug" && export _DEBUG="on"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Disables colorization
[ "$1" = "--no-color" ] && export SHOW_RAW="true"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# pipes fail
set -o pipefail
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Send all output to /dev/null
__devnull() {
  tee &>/dev/null && FOR_EACH_IN_EXIT_STATUS=0 || FOR_EACH_IN_EXIT_STATUS=1
  return ${FOR_EACH_IN_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# colorization — ANSI escapes directly (never tput); PRINTF_COLOR selects fg color (0–7)
if [ -n "${NO_COLOR+x}" ] || [ "$SHOW_RAW" = "true" ]; then
  __printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
else
  __printf_color() { printf '\e[3%sm%b\e[0m' "${PRINTF_COLOR:-7}" "$1"; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Inline color helpers — each sets PRINTF_COLOR locally before calling __printf_color
__printf_red()     { local PRINTF_COLOR=1; __printf_color "$1\n"; }
__printf_green()   { local PRINTF_COLOR=2; __printf_color "$1\n"; }
__printf_yellow()  { local PRINTF_COLOR=3; __printf_color "$1\n"; }
__printf_blue()    { local PRINTF_COLOR=4; __printf_color "$1\n"; }
__printf_purple()  { local PRINTF_COLOR=5; __printf_color "$1\n"; }
__printf_cyan()    { local PRINTF_COLOR=6; __printf_color "$1\n"; }
__printf_newline() { printf '\n'; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional print helpers
__printf_head() { __printf_blue "$1"; }
__printf_opts() { __printf_purple "$1"; }
__printf_line() { __printf_cyan "$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# output version
__version() { __printf_cyan "$VERSION"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  local PRINTF_COLOR="${5:-4}"
  __printf_color "$1: "
  echo -ne "$2" | sed 's|:||g;s/'$3'/ '$4'/g' | tr '\n' ' '
  __printf_newline
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# create the config file
__gen_config() {
  if [ "$INIT_CONFIG" != "TRUE" ]; then
    __printf_blue "Generating the config file in"
    __printf_cyan "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE"
  fi
  [ -d "$FOR_EACH_IN_CONFIG_DIR" ] || mkdir -p "$FOR_EACH_IN_CONFIG_DIR"
  [ -d "$FOR_EACH_IN_CONFIG_BACKUP_DIR" ] || mkdir -p "$FOR_EACH_IN_CONFIG_BACKUP_DIR"
  [ -f "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" ] &&
    cp -Rf "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" "$FOR_EACH_IN_CONFIG_BACKUP_DIR/$FOR_EACH_IN_CONFIG_FILE.$$"
  cat <<EOF >"$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE"
# Settings for for_each_in

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Loop behaviour defaults
FOR_EACH_IN_DRY_RUN="${FOR_EACH_IN_DRY_RUN:-no}"
FOR_EACH_IN_VERBOSE="${FOR_EACH_IN_VERBOSE:-no}"
FOR_EACH_IN_STOP_ON_ERROR="${FOR_EACH_IN_STOP_ON_ERROR:-no}"
FOR_EACH_IN_SUMMARY="${FOR_EACH_IN_SUMMARY:-no}"

EOF
  if builtin type -t __gen_config_local | grep -q -- 'function'; then __gen_config_local; fi
  if [ -f "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" ]; then
    [ "$INIT_CONFIG" = "TRUE" ] || __printf_green "Your config file for $APPNAME has been created"
    . "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE"
    FOR_EACH_IN_EXIT_STATUS=0
  else
    __printf_red "Failed to create the config file"
    FOR_EACH_IN_EXIT_STATUS=1
  fi
  return ${FOR_EACH_IN_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Help function - Align to 50
__help() {
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "for_each_in:  - $VERSION"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Usage: for_each_in [options] PATTERN [--not] [-FLAG PATH]... COMMAND [ARGS...]"
  __printf_line "              - "

  __printf_line "  PATTERN              Quoted glob passed to --dir or as first positional arg"
  __printf_line "                       e.g.  \"*\"  \"../*\"  \"./*/*\"  \"../*/src\""
  __printf_line "              - "

  __printf_line "Conditions (bash test flags, all ANDed, repeatable):"
  __printf_line "  -FLAG PATH           [ -FLAG item/PATH ] — PATH relative to loop item"
  __printf_line "  -FLAG .              [ -FLAG item ]      — test the item itself"
  __printf_line "  -e PATH              exists (any type)"
  __printf_line "  -f PATH              regular file"
  __printf_line "  -d PATH              directory"
  __printf_line "  -L PATH              symlink"
  __printf_line "  -r/-w/-x PATH        readable / writable / executable"
  __printf_line "  -s PATH              non-empty"
  __printf_line "  -b/-c/-p/-S PATH     block dev / char dev / pipe / socket"
  __printf_line "  -u/-g/-k PATH        setuid / setgid / sticky bit"
  __printf_line "  --not -FLAG PATH     invert the immediately following condition"
  __printf_line "              - "

  __printf_line "Command injection — the script detects the command and injects the"
  __printf_line "loop item in the right place automatically:"
  __printf_line "              - "

  __printf_line "  git / tig / make     item injected as -C item  (before subcommand)"
  __printf_line "    git pull           → git -C item pull"
  __printf_line "    make install       → make -C item install"
  __printf_line "              - "

  __printf_line "  gitadmin / gitcommit / gitignore / gen-* / publishit / backupapp"
  __printf_line "  run_server / setupmgr / pkmgr / dockermgr / composemgr / tryforever"
  __printf_line "  run_command / timeit / logr / virtmgr / lxcmgr / virt-check"
  __printf_line "  update-lecerts / update-ip / update-motd / update-resolv / reqpkgs"
  __printf_line "                       item injected as --dir item  (before subcommand)"
  __printf_line "    gitadmin pull      → gitadmin --dir item pull"
  __printf_line "    gen-readme update  → gen-readme --dir item update"
  __printf_line "              - "

  __printf_line "  cp / mv / rsync / ln / install"
  __printf_line "                       item appended as destination (last arg)"
  __printf_line "    cp -Rfv ./AI.md    → cp -Rfv ./AI.md item"
  __printf_line "    rsync -avhP ./src/ → rsync -avhP ./src/ item"
  __printf_line "              - "

  __printf_line "  anything else        item appended as last arg"
  __printf_line "    unlink             → unlink item"
  __printf_line "    chmod 755          → chmod 755 item"
  __printf_line "              - "

  __printf_line "Examples:"
  __printf_line "  # Pull every git repo under current dir"
  __printf_line "  for_each_in \"*\" -d .git gitadmin pull"
  __printf_line "              - "

  __printf_line "  # Commit all repos"
  __printf_line "  for_each_in \"*\" -d .git gitcommit all"
  __printf_line "              - "

  __printf_line "  # Regenerate readme in every project that has one"
  __printf_line "  for_each_in \"*\" -f README.md gen-readme update"
  __printf_line "              - "

  __printf_line "  # Copy AI.md into every project dir under parent"
  __printf_line "  for_each_in \"../*\" -d . cp -Rfv ./AI.md"
  __printf_line "              - "

  __printf_line "  # Rsync a template into every matching subdir"
  __printf_line "  for_each_in \"../*\" -d . rsync -avhP ./tmpl/"
  __printf_line "              - "

  __printf_line "  # Remove all symlinks under a two-level glob"
  __printf_line "  for_each_in \"./*/*\" -L . unlink"
  __printf_line "              - "

  __printf_line "  # Run make in each dir that has a Makefile, stop on first error"
  __printf_line "  for_each_in --stop-on-error \"*\" -f Makefile make build"
  __printf_line "              - "

  __printf_line "  # Dry-run with summary"
  __printf_line "  for_each_in -n --summary \"*\" -d .git gitadmin pull"
  __printf_line "              - "

  __printf_line "  # Multiple conditions (all must pass)"
  __printf_line "  for_each_in \"*\" -d .git -f Makefile make install"
  __printf_line "              - "

  __printf_line "  # Skip symlinks"
  __printf_line "  for_each_in \"../*/src\" --not -L . cp -Rfv ./conf.d"
  __printf_line "              - "

  __printf_line "--dir PATTERN - Glob pattern (alias for positional arg)"

  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "--help        - Shows this message"

  __printf_line "--config      - Generate user config file"

  __printf_line "--version     - Show script version"

  __printf_line "--options     - Shows all available options"

  __printf_line "--debug       - Enables script debugging"

  __printf_line "--no-color    - Disable ANSI color output"

  __printf_line ""
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit_for_each_in() {
  FOR_EACH_IN_EXIT_STATUS=${FOR_EACH_IN_EXIT_STATUS:-0}
  [ -f "$FOR_EACH_IN_TEMP_FILE" ] && rm -Rf "$FOR_EACH_IN_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q -- 'function'; then __trap_exit_local; fi
  return $FOR_EACH_IN_EXIT_STATUS
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap '__trap_exit_for_each_in' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Command registry — determines how the loop item is injected into the command
#
#   dash-C   : git / tig / make    → cmd -C {item} [subcmd] [args]
#   dir-flag : known bin/ scripts  → cmd --dir {item} [subcmd] [args]
#   destdir  : cp / mv / rsync / ln / install → cmd [args] {item}
#   append   : everything else     → cmd [args] {item}
#
__injection_mode() {
  local _bin="${1##*/}"
  case "$_bin" in
  git|tig|make)
    echo "dash-C"
    ;;
  gitadmin|gitcommit|gitignore|\
  gen-changelog|gen-gitattr|gen-readme|gen-license|gen-header|gen-script|\
  gen-dockerfile|gen-dockermgr|gen-caddy|gen-nginx|gen-apache|gen-traefik|\
  gen-ssl|gen-vars|gen-links|gen-passwd|gen-dns|gen-network|gen-mydomain|\
  gen-completion|gen-html|gen-playlist|\
  publishit|backupapp|run_server|setupmgr|pkmgr|dockermgr|composemgr|\
  tryforever|run_command|timeit|logr|virtmgr|lxcmgr|virt-check|\
  update-lecerts|update-ip|update-motd|update-resolv|reqpkgs)
    echo "dir-flag"
    ;;
  cp|mv|rsync|ln|install)
    echo "destdir"
    ;;
  *)
    echo "append"
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__for_each_in_main() {
  # Pattern: from --dir flag or first positional arg
  local _pattern="${FOR_EACH_IN_PATTERN:-}"
  if [ -z "$_pattern" ]; then
    _pattern="${1:-}"
    shift || true
  fi
  if [ -z "$_pattern" ]; then
    __printf_red "Usage: $APPNAME [options] PATTERN [--not] [-FLAG PATH]... COMMAND [ARGS...]"
    return 2
  fi

  # Parse conditions: triples of (negate, flag, path)
  # PATH is always required — use . to test the item itself
  local -a _conds=()
  local _negate=""
  while true; do
    case "${1:-}" in
    --not)
      _negate="!"
      shift 1
      ;;
    -b|-c|-d|-e|-f|-g|-G|-h|-k|-L|-N|-O|-p|-r|-s|-S|-u|-w|-x)
      _conds+=("$_negate" "$1" "${2:-.}")
      _negate=""
      shift 2
      ;;
    *) break ;;
    esac
  done

  # Remaining args are the command and its arguments
  local -a _cmd=("$@")
  if [ ${#_cmd[@]} -eq 0 ]; then
    __printf_red "No command specified"
    return 2
  fi

  local _mode
  _mode="$(__injection_mode "${_cmd[0]}")"

  # Glob expansion — nullglob so unmatched patterns yield nothing
  local _nullglob_was_set=0
  shopt -q nullglob && _nullglob_was_set=1
  shopt -s nullglob
  local -a _items=($_pattern)
  (( _nullglob_was_set )) || shopt -u nullglob

  if [ ${#_items[@]} -eq 0 ]; then
    __printf_yellow "No matches for pattern: $_pattern"
    return 0
  fi

  local _item _neg _flag _rel _tp _i _skip _ret=0
  local _count_processed=0 _count_skipped=0 _count_failed=0
  local -a _run_cmd

  for _item in "${_items[@]}"; do
    # Evaluate all conditions — every one must pass (AND)
    _skip=0
    for (( _i=0; _i<${#_conds[@]}; _i+=3 )); do
      _neg="${_conds[$_i]}"
      _flag="${_conds[$((_i+1))]}"
      _rel="${_conds[$((_i+2))]}"
      if [ -z "$_rel" ] || [ "$_rel" = "." ]; then
        _tp="$_item"
      else
        _tp="$_item/$_rel"
      fi
      if [ "$_neg" = "!" ]; then
        [ "$_flag" "$_tp" ] && { _skip=1; break; } || true
      else
        [ "$_flag" "$_tp" ] || { _skip=1; break; }
      fi
    done
    if [ "$_skip" != "0" ]; then
      (( _count_skipped++ )) || true
      continue
    fi

    # Build the command with item injected per registry mode
    case "$_mode" in
    dash-C)
      # git -C item subcmd [args]
      _run_cmd=("${_cmd[0]}" "-C" "$_item" "${_cmd[@]:1}")
      ;;
    dir-flag)
      # cmd --dir item subcmd [args]
      _run_cmd=("${_cmd[0]}" "--dir" "$_item" "${_cmd[@]:1}")
      ;;
    destdir|append|*)
      # cmd [args] item
      _run_cmd=("${_cmd[@]}" "$_item")
      ;;
    esac

    if [ "$FOR_EACH_IN_VERBOSE" = "yes" ] || [ "$FOR_EACH_IN_DRY_RUN" = "yes" ]; then
      __printf_cyan "$(printf '%q ' "${_run_cmd[@]}")"
    fi

    if [ "$FOR_EACH_IN_DRY_RUN" = "yes" ]; then
      (( _count_processed++ )) || true
      continue
    fi

    if "${_run_cmd[@]}"; then
      (( _count_processed++ )) || true
    else
      _ret=$?
      (( _count_failed++ )) || true
      __printf_red "Failed (exit $_ret): $(printf '%q ' "${_run_cmd[@]}")"
      [ "$FOR_EACH_IN_STOP_ON_ERROR" = "yes" ] && break
    fi
  done

  if [ "$FOR_EACH_IN_SUMMARY" = "yes" ] || [ "$FOR_EACH_IN_VERBOSE" = "yes" ]; then
    __printf_blue "Done — processed: $_count_processed  skipped: $_count_skipped  failed: $_count_failed"
  fi

  return $_ret
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Default exit code
FOR_EACH_IN_EXIT_STATUS=0
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Application folders
FOR_EACH_IN_CONFIG_DIR="${FOR_EACH_IN_CONFIG_DIR:-$HOME/.config/myscripts/for_each_in}"
FOR_EACH_IN_CONFIG_BACKUP_DIR="${FOR_EACH_IN_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/for_each_in/backups}"
FOR_EACH_IN_TEMP_DIR="${FOR_EACH_IN_TEMP_DIR:-$HOME/.local/tmp/system_scripts/for_each_in}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# File settings
FOR_EACH_IN_CONFIG_FILE="${FOR_EACH_IN_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Loop behaviour defaults (overridable by config or env)
FOR_EACH_IN_DRY_RUN="${FOR_EACH_IN_DRY_RUN:-no}"
FOR_EACH_IN_VERBOSE="${FOR_EACH_IN_VERBOSE:-no}"
FOR_EACH_IN_STOP_ON_ERROR="${FOR_EACH_IN_STOP_ON_ERROR:-no}"
FOR_EACH_IN_SUMMARY="${FOR_EACH_IN_SUMMARY:-no}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pattern set via --dir flag (empty = use positional arg)
FOR_EACH_IN_PATTERN="${FOR_EACH_IN_PATTERN:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config file on first run
[ -f "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" ] || [ "$*" = "--config" ] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" ] && . "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure temp directory exists
[ -d "$FOR_EACH_IN_TEMP_DIR" ] || mkdir -p "$FOR_EACH_IN_TEMP_DIR" |& __devnull
# - - - - - - - - - - - - - - - - - - - - - - - - -
FOR_EACH_IN_TEMP_FILE="${FOR_EACH_IN_TEMP_FILE:-$(mktemp "$FOR_EACH_IN_TEMP_DIR/XXXXXX" 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Argument/Option settings
SETARGS=("$@")
# - - - - - - - - - - - - - - - - - - - - - - - - -
SHORTOPTS="+"
SHORTOPTS+="nv"
# - - - - - - - - - - - - - - - - - - - - - - - - -
LONGOPTS="completions:,config,reset-config,debug,dir:,help,options,no-color,version,silent,"
LONGOPTS+="dry-run,verbose,stop-on-error,summary,"
# - - - - - - - - - - - - - - - - - - - - - - - - -
ARRAY=""
ARRAY+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
LIST=""
LIST+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --no-color)
    shift 1
    export SHOW_RAW="true"
    __printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
    ;;
  --debug)
    shift 1
    set -xo pipefail
    export SCRIPT_OPTS="--debug"
    export _DEBUG="on"
    __devnull() { tee || return 1; }
    ;;
  --completions)
    if [ "$2" = "short" ]; then
      printf '%s\n' "-$SHORTOPTS" | sed 's|"||g;s|:||g;s|,|,-|g' | tr ',' '\n'
    elif [ "$2" = "long" ]; then
      printf '%s\n' "--$LONGOPTS" | sed 's|"||g;s|:||g;s|,|,--|g' | tr ',' '\n'
    elif [ "$2" = "array" ]; then
      printf '%s\n' "$ARRAY" | sed 's|"||g;s|:||g' | tr ',' '\n'
    elif [ "$2" = "list" ]; then
      printf '%s\n' "$LIST" | sed 's|"||g;s|:||g' | tr ',' '\n'
    else
      exit 1
    fi
    shift 2
    exit $?
    ;;
  --options)
    shift 1
    __printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "Short Options" "-${SHORTOPTS}" ',' '-' 4
    [ -z "$LONGOPTS" ] || __list_options "Long Options" "--${LONGOPTS}" ',' '--' 4
    [ -z "$ARRAY" ] || __list_options "Base Options" "${ARRAY}" ',' '' 4
    [ -z "$LIST" ] || __list_options "LIST Options" "${LIST}" ',' '' 4
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --reset-config)
    shift 1
    [ -f "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" ] && rm -Rf "${FOR_EACH_IN_CONFIG_DIR:?}/$FOR_EACH_IN_CONFIG_FILE"
    __gen_config
    exit $?
    ;;
  --silent)
    shift 1
    FOR_EACH_IN_SILENT="true"
    ;;
  --dir)
    FOR_EACH_IN_PATTERN="$2"
    shift 2
    ;;
  --dry-run|-n)
    shift 1
    FOR_EACH_IN_DRY_RUN="yes"
    ;;
  --verbose|-v)
    shift 1
    FOR_EACH_IN_VERBOSE="yes"
    ;;
  --stop-on-error)
    shift 1
    FOR_EACH_IN_STOP_ON_ERROR="yes"
    ;;
  --summary)
    shift 1
    FOR_EACH_IN_SUMMARY="yes"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
# - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__for_each_in_main "$@"
FOR_EACH_IN_EXIT_STATUS=$?
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Set exit code
FOR_EACH_IN_EXIT_STATUS="${FOR_EACH_IN_EXIT_STATUS:-0}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${FOR_EACH_IN_EXIT_STATUS:-0}
# - - - - - - - - - - - - - - - - - - - - - - - - -
