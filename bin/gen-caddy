# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GEN_CADDY_CONFIG_DIR/$GEN_CADDY_CONFIG_FILE"
  [ -d "$GEN_CADDY_CONFIG_DIR" ] || mkdir -p "$GEN_CADDY_CONFIG_DIR"
  [ -d "$GEN_CADDY_CONFIG_BACKUP_DIR" ] || mkdir -p "$GEN_CADDY_CONFIG_BACKUP_DIR"
  [ -f "$GEN_CADDY_CONFIG_DIR/$GEN_CADDY_CONFIG_FILE" ] &&
    cp -Rf "$GEN_CADDY_CONFIG_DIR/$GEN_CADDY_CONFIG_FILE" "$GEN_CADDY_CONFIG_BACKUP_DIR/$GEN_CADDY_CONFIG_FILE.$$"
  cat <<EOF >"$GEN_CADDY_CONFIG_DIR/$GEN_CADDY_CONFIG_FILE"
# Settings for gen-caddy
# folder where caddyserver will be kept
GEN_CADDY_FILE_DIR="${GEN_CADDY_FILE_DIR:-/usr/local/share/caddyserver}"
# folder where public files should be
GEN_CADDY_WWW_DIR="${GEN_CADDY_WWW_DIR:-/var/caddy/www}"
# caddy web server configuration file
GEN_CADDY_CONFIG_DIR="${GEN_CADDY_CONFIG_DIR:-/etc/Caddyfile}"
# folder where logs will be written
GEN_CADDY_LOG_DIR="${GEN_CADDY_LOG_DIR:-/var/log/caddy}"
# user under caddy is gonna be running
GEN_CADDY_DEFAULT_USER="${GEN_CADDY_DEFAULT_USER:-caddy}"

# Notification settings
GEN_CADDY_GOOD_MESSAGE="${GEN_CADDY_GOOD_MESSAGE:-Everything Went OK}"
GEN_CADDY_ERROR_MESSAGE="${GEN_CADDY_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_CADDY_NOTIFY_ENABLED="${GEN_CADDY_NOTIFY_ENABLED:-yes}"
GEN_CADDY_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_CADDY_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_CADDY_NOTIFY_CLIENT_ICON}"

# Colorization settings
GEN_CADDY_OUTPUT_COLOR="${GEN_CADDY_OUTPUT_COLOR:-5}"
GEN_CADDY_OUTPUT_COLOR_GOOD="${GEN_CADDY_OUTPUT_COLOR_GOOD:-2}"
GEN_CADDY_OUTPUT_COLOR_ERROR="${GEN_CADDY_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GEN_CADDY_CONFIG_DIR/$GEN_CADDY_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      unset INIT_CONFIG
      eval bash -c "$APPNAME $@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__get_caddy_pid() { pgrep -nf "$GEN_CADDY_FILE_DIR/caddy" 2>/dev/null || pgrep -nf caddy 2>/dev/null || return 1; }
