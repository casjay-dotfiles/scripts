# begin main app
case $1 in
'start' | 'startcaddy')
  shift 1
  amiroot
  #caddy start &>/dev/null
  startcaddy
  ;;
'stop' | 'stopcaddy')
  shift 1
  amiroot
  stopcaddy
  ;;
'reload' | 'reloadcaddy')
  shift 1
  reloadcaddy
  ;;
'restart')
  shift 1
  amiroot
  stopcaddy
  sleep 2
  startcaddy
  ;;
'status' | 'caddystatus')
  shift 1
  caddystatus
  ;;
'install')
  shift 1
  amiroot
  plugin="$1"
  installcaddy
  makeservice
  ;;
'install-naked')
  shift 1
  amiroot
  plugin="$1"
  installcaddy naked
  ;;
'update' | 'updatecaddy')
  shift 1
  amiroot
  plugin="$1"
  updatecaddy
  ;;
'fixphp' | 'fixphpfpm')
  shift 1
  amiroot
  fixphpfpm
  ;;
'installphp')
  shift 1
  amiroot
  installphp
  ;;
'edit')
  shift 1
  amiroot
  edit_gen_caddy_config
  ;;
'service' | 'makeservice')
  shift 1
  amiroot
  rm -f /etc/systemd/system/caddy.service
  makeservice
  ;;
'uninstall' | 'delete')
  shift 1
  amiroot
  DELETE_CADDY="yes"
  deletecaddy
  ;;
'delete-service' | 'remove-startup')
  shift 1
  amiroot
  removeservice
  ;;
'config' | 'gen-config')
  shift 1
  amiroot
  gen_caddy_config
  exit $?
  ;;
'html' | 'gen-html')
  shift 1
  make_example_html $2
  exit $?
  ;;
'backup')
  shift 1
  amiroot
  backupcaddy
  ;;
'restore')
  shift 1
  amiroot
  restorecaddy
  ;;
'about')
  shift 1
  about
  ;;
'help')
  shift 1
  prms
  ;;
'version' | 'versioninfo')
  shift 1
  versioninfo
  ;;
'download')
  shift 1
  amiroot
  getcaddy
  ;;
'reverse')
  shift 1
  if cmd_exists caddy; then
    $GEN_CADDY_BIN_FILE reverse-proxy -to 127.0.0.1:${1:-3000} -from :${2:-$(generate_random_port)}
  else
    printf_red "caddy doesn't seem to be installed"
    printf_exit 1 1 "Please run $APPNAME install to setup caddy"
  fi
  ;;
'check')
  shift 1
  amiroot
  checkconfigfile "$1"
  ;;
