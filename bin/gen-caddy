trap 'exitCode=${exitCode:-$?};[ -n "$GEN_CADDY_TEMP_FILE" ] && [ -f "$GEN_CADDY_TEMP_FILE" ] && rm -Rf "$GEN_CADDY_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
