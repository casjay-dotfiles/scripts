GEN_CADDY_OUTPUT_COLOR_ERROR="${GEN_CADDY_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
GEN_CADDY_GOOD_MESSAGE="${GEN_CADDY_GOOD_MESSAGE:-Everything Went OK}"
GEN_CADDY_ERROR_MESSAGE="${GEN_CADDY_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_CADDY_NOTIFY_ENABLED="${GEN_CADDY_NOTIFY_ENABLED:-yes}"
GEN_CADDY_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_CADDY_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_CADDY_NOTIFY_CLIENT_ICON}"
