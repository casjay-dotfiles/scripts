GEN_CADDY_TEMP_DIR="${GEN_CADDY_TEMP_DIR:-$HOME/.local/tmp/system_scripts/gen-caddy}"
GEN_CADDY_OPTIONS_DIR="${GEN_CADDY_OPTIONS_DIR:-$HOME/.local/share/myscripts/gen-caddy/options}"
GEN_CADDY_CONFIG_FILE="${GEN_CADDY_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
GEN_CADDY_OUTPUT_COLOR="${GEN_CADDY_OUTPUT_COLOR:-4}"
GEN_CADDY_OUTPUT_COLOR_2="${GEN_CADDY_OUTPUT_COLOR:-6}"
