[ -d "$GEN_CADDY_CACHE_DIR" ] || mkdir -p "$GEN_CADDY_CACHE_DIR" &>/dev/null
[ -d "$GEN_CADDY_BIN_DIR" ] || mkdir -p "$GEN_CADDY_BIN_DIR" &>/dev/null
GEN_CADDY_TEMP_FILE="${GEN_CADDY_TEMP_FILE:-$(mktemp $GEN_CADDY_TEMP_DIR/XXXXXX 2>/dev/null)}"
GEN_CADDY_DOMAIN_PORT="$([ -f "$GEN_CADDY_SERVER_FILE" ] && grep ':' -s "$GEN_CADDY_SERVER_FILE" | sed 's|htt.*://||g;s|{||g' | awk -F ':' '{print $2}' | head -n1 | grep '[0-9]' | grep '^' || echo "$(generate_random_port)")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
