  printf_blue "run $(tput setaf 3)$bashname help $(tput sgr0) for help"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
prms() {
  printf_blue "$bashname reverse port                                - Proxy to localhost:PORT."
  printf_blue "$bashname start                                       - Start $caddyname."
  printf_blue "$bashname stop                                        - Stop/Shutdown $caddyname."
  printf_blue "$bashname reload                                      - Reload $caddyname."
  printf_blue "$bashname restart                                     - Restart $caddyname."
  printf_blue "$bashname status                                      - Check $caddyname is running or not"
  printf_blue "$bashname install                                     - Install $caddyname on fresh OS."
  printf_blue "$bashname install-naked                               - Install only $caddyname and no prompt."
  printf_blue "$bashname edit                                        - Edit Caddyfile using nano or default editor."
  printf_blue "$bashname service                                     - Make $caddyname start on boot (upstart/systemd)."
  printf_blue "$bashname update                                      - Update $caddyname."
  printf_blue "$bashname delete                                      - Uninstall $caddyname and data."
  printf_blue "$bashname version                                     - Print version information."
  printf_blue "$bashname about                                       - About $caddyname Installer."
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
isinstalled() {
  # check if caddy is installed or return error code 1
  if [[ ! -x "$GEN_CADDY_FILE_DIR/caddy" ]]; then
    echo
    printf_blue "Caddy is not installed."
    printf_blue "run $(tput setaf 3)$bashname install$(tput sgr0) to install $caddyname"
    echo
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
startcaddy() {
  isinstalled || exit 1
  caddypid="/var/run/caddy"
  if [[ ! -f $caddypid ]]; then
    mkdir -p $caddypid || (
      printf_blue "error creating folder $caddypid"
      printf_blue "try running with: sudo $bashname start"
      exit 1
    ) || exit 1
    chown $GEN_CADDY_DEFAULT_USER $caddypid
  fi
  # Detect if running or start
  pids=$(__get_caddy_pid)
  if [ -z "$pids" ]; then
    printf_blue "Starting $caddyname..."
    if [[ -e /etc/init/caddy.conf || -e /etc/systemd/system/caddy.service ]]; then
      # If service exist use service
      hash service 2>/dev/null && service caddy start || systemctl start caddy
    else
      sudo -HE -u $GEN_CADDY_DEFAULT_USER "$GEN_CADDY_FILE_DIR/caddy" start -config=/etc/Caddyfile -pidfile=/var/run/caddy/caddy.pid &>/dev/null &
    fi
    sleep 1
    printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
    sleep 1
    # restart or reload php for smooth environment
    hash php 2>/dev/null && restartphpfpm
    pids=$(__get_caddy_pid)
    caddystatus
  else
    printf_blue "$caddyname is already $(tput setaf 2)running$(tput sgr0) on: $pids (PID)"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
stopcaddy() {
  pids=$(__get_caddy_pid)
  if [ -z "$pids" ]; then
    printf_blue "$caddyname is $(tput setaf 1)NOT running$(tput sgr0)"
  else
    secs=$(ps -p "$pids" -oetime= | tr '-' ':' | awk -F: '{ total=0; m=1; } { for (i=0; i < NF; i++) {total += $(NF-i)*m; m *= i >= 2 ? 24 : 60 }} {print total}')
    printf_blue "Shutting down $caddyname..."
    # Wait if Caddy uptime is less than 5 seconds
    if [[ $secs -lt 5 ]]; then
      sleep 4
    fi
    if [[ -e /etc/init/caddy.conf || -e /etc/systemd/system/caddy.service ]]; then
      # Most arch based linux don't have service
      hash service 2>/dev/null && service caddy stop || systemctl stop caddy
    else
      kill "$pids"
    fi
    sleep 1
    printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
reloadcaddy() {
  if [ -z "$pids" ]; then
    printf_blue "$caddyname is $(tput setaf 1)NOT running$(tput sgr0)"
    printf_blue "run $(tput setaf 3)$bashname start$(tput sgr0) to start Caddy"
  else
    printf_blue "Reloading $caddyname..."
    if [[ -e /etc/init/caddy.conf || -e /etc/systemd/system/caddy.service ]]; then
      # Headless server should have service
      hash service 2>/dev/null && service caddy reload || systemctl reload caddy
    else
      kill -USR1 "$pids"
    fi
    sleep 2
    printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
    printf_blue "To restart, use $(tput setaf 6)$bashname restart$(tput sgr0)"
    printf_blue "Refresh your browser at least 3 times to take affect"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
restartphpfpm() {
  phpvalue
  # Ubuntu
  if [[ -e "$ubuntuphp5fpm" ]]; then
    service php5-fpm restart &>/dev/null
  # CentOS
  elif [[ -e "$centosphpfpm" || -e "$centosphpfpm2" ]]; then
    service php-fpm restart &>/dev/null
  # PHP 7
  elif [[ -e "$phpfpm7" ]]; then
    /etc/init.d/php7.*-fpm reload &>/dev/null
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
caddystatus() {
  # Check if Caddy is installed or not
  isinstalled || exit 1
  # Detect Caddy process
  if [ -z "$pids" ]; then
    printf_blue "$caddyname is $(tput setaf 1)NOT running$(tput sgr0)"
  else
    caddymemusage=$(ps axo rss,comm,pid | grep "$pids" | awk '{$1/=1024;printf "%.0fMB\t",$1}{print $2}' | awk '{print $1}')
    secs=$(ps -p "$pids" -oetime= | tr '-' ':' | awk -F: '{ total=0; m=1; } { for (i=0; i < NF; i++) {total += $(NF-i)*m; m *= i >= 2 ? 24 : 60 }} {print total}')
    if [[ $secs -lt 120 ]]; then
      caddyuptime="$secs seconds"
    elif [[ $secs -lt 3600 ]]; then
      caddyuptime=$(printf '%d minutes %d seconds\n' $(($secs % 3600 / 60)) $(($secs % 60)))
    elif [[ $secs -lt 86400 ]]; then
      caddyuptime=$(printf '%d hrs %d min %d sec\n' $(($secs / 3600)) $(($secs % 3600 / 60)) $(($secs % 60)))
    else
      caddyuptime=$(printf_blue $((secs / 86400))" days, "$(date -d "1970-01-01 + $secs seconds" "+%H hrs %M min %S sec"))
    fi
    printf_blue "$caddyname is $(tput setaf 2)running$(tput sgr0)"
    printf_blue "Caddy (PID: $pids) is using $caddymemusage RAM"
    printf_blue "System available RAM $(free -h | grep Mem: | awk '{print $7}')B"
    printf_blue "Uptime - $caddyuptime"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
amiroot() {
  if [[ "$EUID" -ne 0 ]]; then
    printf_blue "Sorry, you need to run this as root"
    printf_blue "Try running with command 'sudo'"
    exit
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
getcaddy() {
  # Detect architecture
  if uname -m | grep -q x86_64; then
    cpubits="amd64"
    cpubitsname="64bit..."
  elif uname -m | grep -q aarch64; then
    cpubits="arm64"
    cpubitsname="AArch64..."
  elif uname -m | grep -q 86; then
    cpubits="386"
    cpubitsname="32bit..."
  elif uname -m | grep -q armv5; then
    cpubits="arm5"
    cpubitsname="ARM 5..."
  elif uname -m | grep -q armv6l; then
    cpubits="arm6"
    cpubitsname="ARM 6..."
  elif uname -m | grep -q armv7l; then
    cpubits="arm7"
    cpubitsname="ARM 7..."
  else
    echo
    printf_blue "unsupported or unknown architecture"
    echo
    exit
  fi
  # Downloading Caddy
  local INSTALL=""
  os="$(echo "$OS" | tr '[:upper:]' '[:lower:]')"
  curver="$(curl -q -LSs https://api.github.com/repos/caddyserver/caddy/releases/latest | grep tag_name | sed 's/[^0-9\.]*//g')"
  downurl="$(echo "https://github.com/caddyserver/caddy/releases/download/v${curver}/caddy_${curver}_${os}_${cpubits}.tar.gz")"
  isupdate="$1"
  nocert="--no-check-certificate"
  if [[ $isupdate == "update" ]]; then
    caddyversion=$("$GEN_CADDY_FILE_DIR/caddy" -version | awk '{print}')
    printf_blue "Found $caddyversion"
  fi
  printf_blue "Downloading caddy $curver for $os from"
  printf_blue "$downurl"
  # Start downloading caddy now
  if ! wget -q $nocert "$downurl" -O "caddy_custom.tar.gz"; then
    printf_red "Error: Cannot download Caddy binary from"
    printf_blue "$downurl"
    exit 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
installcaddy() {
  if [[ -e "$GEN_CADDY_FILE_DIR/caddy" ]]; then
    printf_blue "$caddyname is already installed on"
    printf_blue "$GEN_CADDY_FILE_DIR/caddy"
    echo
    exit
  fi
  # Download caddy
  getcaddy
  # Creating folders
  mkdir -p $GEN_CADDY_FILE_DIR
  mkdir -p $GEN_CADDY_LOG_DIR
  # Extract Caddy to appropriate folder
  printf_blue "Extracting $caddyname to $GEN_CADDY_FILE_DIR..."
  if ! tar xzf caddy_custom.tar.gz -C $GEN_CADDY_FILE_DIR; then
    printf_blue "[$(tput setaf 1)FAILED$(tput sgr0)]"
    printf_blue "Error: Cannot extract 'caddy_custom.tar.gz'"
    printf_blue "Abort."
    exit 1
  fi
  printf_blue "$(tput setaf 2)[DONE]$(tput sgr0)"
  # Deleting Caddy archive
  rm -f caddy_custom.tar.gz
  # Skip php installation on arch-linux and naked install
  # Php installation support for arch-linux will be implemented later
  if [[ ! $1 == naked ]]; then
    hash pacman 2>/dev/null || installphp
  fi
  # Creating non-root user
  if id -u $GEN_CADDY_DEFAULT_USER >/dev/null 2>&1; then
    printf_blue "User '$GEN_CADDY_DEFAULT_USER' already exists. Skipped!"
  else
    printf_blue "Creating user '$GEN_CADDY_DEFAULT_USER'..."
    useradd -r -d $GEN_CADDY_FILE_DIR -s /bin/false $GEN_CADDY_DEFAULT_USER &>/dev/null
    printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
  fi
  chown -R $GEN_CADDY_DEFAULT_USER $GEN_CADDY_FILE_DIR
  chown -R $GEN_CADDY_DEFAULT_USER $GEN_CADDY_LOG_DIR
  # Port setup
  printf_blue "Binding port using setcap..."
  if hash setcap 2>/dev/null; then
    setcap cap_net_bind_service=+ep "$GEN_CADDY_FILE_DIR/caddy" &>/dev/null && printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]" || printf_blue "[$(tput setaf 1)FAILED$(tput sgr0)]"
  elif hash apt-get 2>/dev/null; then
    apt-get install libcap2-bin -y &>/dev/null
    setcap cap_net_bind_service=+ep "$GEN_CADDY_FILE_DIR/caddy" &>/dev/null && printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]" || printf_blue "[$(tput setaf 1)FAILED$(tput sgr0)]"
  else
    printf_blue "[$(tput setaf 1)FAILED$(tput sgr0)]"
  fi
  # Show succes message on naked install
  if [[ $1 == naked ]]; then
    printf_blue "Installed $caddyname to $GEN_CADDY_FILE_DIR"
  fi
  # Create symlink
  if ! cmd_exists caddy; then
    __ln_sf "$GEN_CADDY_FILE_DIR/caddy" /usr/local/bin/caddy
  fi
  # Create update check file
  printf_blue $(date +%s) >$updateCheck
  chmod 777 $updateCheck
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
compareVersion() {
  IFS='.' read -ra ver1 <<<"$1"
  IFS='.' read -ra ver2 <<<"$2"
  [[ ${#ver1[@]} -gt ${#ver2[@]} ]] && till=${#ver1[@]} || till=${#ver2[@]}
  for ((i = 0; i < ${till}; i++)); do
    local num1
    local num2
    [[ -z ${ver1[i]} ]] && num1=0 || num1=${ver1[i]}
    [[ -z ${ver2[i]} ]] && num2=0 || num2=${ver2[i]}
    if [[ $num1 -gt $num2 ]]; then
      printf_blue ">"
      return 0
    elif
      [[ $num1 -lt $num2 ]]
    then
      printf_blue "<"
      return 0
    fi
  done
  printf_blue "="
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
updatecaddy() {
  isinstalled || exit 1
  caddyversion=$("$GEN_CADDY_FILE_DIR/caddy" -version | sed -e 's/-/ /g' -e 's/[^0-9\. ]*//g' | awk '{print $1}')
  CADDYV=$(wget -qO- https://api.github.com/repos/caddyserver/caddy/releases/latest | grep tag_name | sed 's/[^0-9\.]*//g')
  isGreater=$(compareVersion $CADDYV $caddyversion)
  if [[ $isGreater != ">" ]]; then
    printf_blue "Looks like you already have latest version installed."
    sleep 0.1
    printf_blue "Abort."
    sleep 0.1
    exit
  fi
  # Download caddy
  getcaddy update
  sleep 0.1
  # Stop current process if found
  if [ -n "$pids" ]; then
    printf_blue "Found Caddy is running!"
    stopcaddy
  fi
  # Delete Caddy folder
  printf_blue "Removing current $caddyname from $GEN_CADDY_FILE_DIR"
  sleep 0.2
  rm -rf "${GEN_CADDY_FILE_DIR:?}/"*
  printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
  sleep 0.1
  # Extract Caddy to appropriate folder
  printf_blue "Extracting $caddyname to $GEN_CADDY_FILE_DIR..."
  if ! tar xzf caddy_custom.tar.gz -C $GEN_CADDY_FILE_DIR; then
    printf_blue "[$(tput setaf 1)FAILED$(tput sgr0)]"
    printf_blue "Error: Cannot extract 'caddy_custom.tar.gz'"
    printf_blue "Abort."
    exit 1
  fi
  printf_blue "$(tput setaf 2)[DONE]$(tput sgr0)"
  # Granting owner access and required permission
  if id -u $GEN_CADDY_DEFAULT_USER >/dev/null 2>&1; then
    chown -R $GEN_CADDY_DEFAULT_USER $GEN_CADDY_FILE_DIR
  fi
  # Port setup
  hash setcap 2>/dev/null && setcap cap_net_bind_service=+ep "$GEN_CADDY_FILE_DIR/caddy" &>/dev/null
  # Removing caddy archive and printing info
  printf_blue $(date +%s) >$updateCheck
  chmod 777 $updateCheck
  rm -f caddy_custom.tar.gz # Deleting Caddy archive
  caddyversion=$("$GEN_CADDY_FILE_DIR/caddy" -version | awk '{print}')
  echo
  printf_blue "Updated to $caddyversion"
  echo
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
installphp() {
  if [[ -e "$GEN_CADDY_FILE_DIR" ]]; then
    printf_read_question "5" "Are you gonna run php site? [y/N]: " "1" "option"
    case $option in
    [yY][eE][sS] | [yY])
      printf_blue "Installing required php files..."
      # Detecting apt-get/yum
      if hash apt-get 2>/dev/null; then
        CODENAME=$(cat /etc/*-release | grep "VERSION_ID=" | cut -f1 -d'.' | cut -f2 -d'"')
        DEBIAN9=$(lsb_release -i | awk 'NF{ print $NF }')
        # If debian 9 or above select php7
        if [[ $DEBIAN9 == Debian ]]; then
          DEBIAN9V=$(lsb_release -r | awk 'NF{ print $NF }' | cut -f1 -d'.')
          CODENAME="0"
        fi
      fi
      # Setup PHP
      if [[ $CODENAME -gt 15 ]] || [[ $DEBIAN9V -eq 9 ]]; then
        PHP="php7.0"
      elif [[ $DEBIAN9V -ge 10 ]]; then
        PHP="php"
      else
        PHP="php5"
      fi
      # Install PHP
      if hash yum 2>/dev/null; then
        yum update -y &>/dev/null && yum install sed php-fpm php-cli php-curl curl sudo -y &>/dev/null
        printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
        printf_blue "Installed 'php-fpm php-cli php-curl curl sudo'"
        fixphpfpm
      elif hash apt-get 2>/dev/null; then
        apt-get update -y &>/dev/null && apt-get install sed $PHP-fpm $PHP-cli $PHP-curl curl sudo -y &>/dev/null
        printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
        printf_blue "Installed '$PHP-fpm $PHP-cli $PHP-curl curl sudo'"
        fixphpfpm
      else
        printf_blue "[$(tput setaf 1)FAILED$(tput sgr0)]"
      fi
      ;;
    *)
      printf_blue "PHP installation skipped!"
      ;;
    esac
  else
    printf_blue "Looks like Caddy was not installed!"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
phpvalue() {
  ubuntuphp5fpm="/etc/php5/fpm/pool.d/www.conf"
  centosphpfpm="/etc/php/fpm/pool.d/www.conf"
  centosphpfpm2="/etc/php-fpm.d/www.conf"
  phpfpm7=$(echo /etc/php/7.*/fpm/pool.d/www.conf)
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
fixphpfpm() {
  phpvalue
  phpuser=$1
  if [[ $phpuser == "" ]]; then
    phpuser=$GEN_CADDY_DEFAULT_USER
  fi
  # Detect php5-fpm or php-fpm
  printf_blue "Fixing php sock issue..."
  #Ubuntu
  if [[ -e "$ubuntuphp5fpm" ]]; then
    sed -i "s@user = .*@user = $phpuser@g" $ubuntuphp5fpm
    sed -i "s@group = .*@group = $phpuser@g" $ubuntuphp5fpm
    sed -i 's/listen = .*/listen = 127.0.0.1:9000/g' $ubuntuphp5fpm
    printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
  # CentOS
  elif [[ -e "$centosphpfpm" ]]; then
    sed -i "s@user = .*@user = $phpuser@g" $centosphpfpm
    sed -i "s@group = .*@group = $phpuser@g" $centosphpfpm
    printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
  # CentOS 2
  elif [[ -e "$centosphpfpm2" ]]; then
    sed -i "s@user = .*@user = $phpuser@g" $centosphpfpm2
    sed -i "s@group = .*@group = $phpuser@g" $centosphpfpm2
    printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
  # PHP 7
  elif [[ -e "$phpfpm7" ]]; then
    sed -i "s@user = .*@user = $phpuser@g" $phpfpm7
    sed -i "s@group = .*@group = $phpuser@g" $phpfpm7
    printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
  else
    printf_blue "[$(tput setaf 1)FAILED$(tput sgr0)]"
    printf_blue "php not found!"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
gen_caddy_config() {
  phpvalue
  # Ubuntu
  if [[ -e "$ubuntuphp5fpm" ]]; then
    phpsock=$(grep "listen = *" <$ubuntuphp5fpm | cut -c 10-)
  # CentOS
  elif [[ -e "$centosphpfpm" ]]; then
    phpsock=$(grep "listen = *" <$centosphpfpm | cut -c 10-)
  # CentOS 2
  elif [[ -e "$centosphpfpm2" ]]; then
    phpsock=$(grep "listen = *" <$centosphpfpm2 | cut -c 10-)
  # PHP 7
  elif [[ -e "$phpfpm7" ]]; then
    sed -i 's/listen = .*/listen = 127.0.0.1:9000/g' $phpfpm7
    phpsock=$(grep "listen = *" <$phpfpm7 | cut -c 10-)
  else
    phpsock="127.0.0.1:9000"
  fi
  # Check if Caddyfile exist
  # Generate Caddyfile
  if [[ ! -e $GEN_CADDY_CONFIG_DIR ]]; then
    printf_blue "Enter your domain name"
    printf_blue "Seperated by comma"
    printf_read_input "5" "Domain name: " "200" domainname "-i ${HOSTNAME:-localhost}"
    # Check if gonna run locally
    if [[ $domainname == "localhost" || $domainname == "localhost:*" || $domainname == "127.0.0*" || $domainname == "192.168*" ]]; then
      printf_blue "SSL is disabled on non-production server."
    else
      printf_blue "Enter your email for automated ssl [off]"
      printf_read_input "5" "Email: " "200" domainmail '-e'
      until [[ "$domainmail" == *@*.* || "$domainmail" == off ]]; do
        printf_blue "Invalid email"
        printf_blue "Type $(tput setaf 3)off$(tput sgr0) if you don't want https"
        printf_read_input "5" "Email: " "200" domainmail '-e'
      done
    fi
    if [[ "$domainmail" == off ]]; then
      domainmail=""
    fi
    echo "http://$domainname:85 {
    bind $(__getlipaddr && echo $CURRIP4)
    root * $GEN_CADDY_WWW_DIR
    encode gzip
    tls ${domainmail:-internal}
    php_fastcgi $phpsock
    log {
        output file /var/log/caddy/access.log
        }
}
" >$GEN_CADDY_CONFIG_DIR
    printf_blue "$GEN_CADDY_CONFIG_DIR created"
  else
    printf_blue "$GEN_CADDY_CONFIG_DIR found. Skipped! "
  fi
  # Check if GEN_CADDY_WWW_DIR exist
  if [[ ! -e $GEN_CADDY_WWW_DIR ]]; then
    mkdir -p $GEN_CADDY_WWW_DIR
  fi
  # Generate example html
  # shellcheck disable=SC1078,SC1079,SC2140
  if [[ ! -e $GEN_CADDY_WWW_DIR/index.html ]]; then
    __cp_rf "$CASJAYSDEVDIR/templates/apache/html/." "$GEN_CADDY_WWW_DIR/"
    printf_blue "Template HTML Documents copied"
    printf_blue "$GEN_CADDY_WWW_DIR/index.html"
  else
    printf_blue "index.html found. Skipped!"
  fi
  # phpinfo
  if [[ ! -e $GEN_CADDY_WWW_DIR/info.php ]]; then
    printf_blue "<?php phpinfo(); ?>" >>$GEN_CADDY_WWW_DIR/info.php
    printf_blue "PHP-info file created"
    printf_blue "$GEN_CADDY_WWW_DIR/info.php"
  fi
  chown -R $GEN_CADDY_DEFAULT_USER $GEN_CADDY_WWW_DIR
  printf_blue "Done. Caddy has been installed :)"
  printf_blue "Run $(tput setaf 3)$bashname start$(tput sgr0) to start $caddyname"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
makeservice() {
  if [[ -e /etc/systemd/system/caddy.service || -e /etc/init.d/caddy.sh ]]; then
    printf_blue "Service already exists. Skipped!"
  else
    nocert="--no-check-certificate"
    init=$(cat /proc/1/comm)
    printf_blue "Creating startup service..."
    if [ "$init" == 'systemd' ]; then
      MAIN="$"
      MAINPID="MAINPID"
      rm -f /etc/systemd/system/caddy.service
      cat <<EOF >/etc/systemd/system/caddy.service
[Unit]
Description=Caddy HTTP/2 web server
Documentation=https://caddyserver.com/docs
After=network-online.target
Requires=network-online.target

[Service]
User=$GEN_CADDY_DEFAULT_USER
StartLimitInterval=86400
StartLimitBurst=5
LimitNOFILE=16535
ExecStart=$GEN_CADDY_FILE_DIR/caddy start -watch -config=/etc/Caddyfile -pidfile=/var/run/caddy/caddy.pid
ExecReload=/bin/kill -USR1 $MAIN$MAINPID
ExecStop=/bin/kill $MAIN$MAINPID
PIDFile=/var/run/caddy/caddy.pid

[Install]
WantedBy=multi-user.target
EOF
      chmod 0644 /etc/systemd/system/caddy.service
      printf_blue "$(tput setaf 2)DONE$(tput sgr0)"
      systemctl daemon-reload &>/dev/null
      systemctl enable caddy &>/dev/null
    else
      # Download
      wget -q $nocert "https://raw.githubusercontent.com/sayem314/Caddy-Web-Server-Installer/master/php-fpm/runcaddy.sh" -O "/etc/init.d/caddy.sh"
      chmod +x /etc/init.d/caddy.sh
      # Enable
      if hash yum 2>/dev/null; then
        chkconfig caddy.sh on
        printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
      elif hash apt-get 2>/dev/null; then
        printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
        update-rc.d caddy.sh defaults
      else
        printf_blue "[$(tput setaf 1)FAILED$(tput sgr0)]"
      fi
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
deletecaddy() {
  if [[ -e "$GEN_CADDY_FILE_DIR" ]]; then
    printf_blue "Are you sure you want to uninstall Caddy web server? [y/N]"
    printf_read_question "5" "Select an option: " "1" "option"
    case $option in
    [yY][eE][sS] | [yY])
      # Stop caddy if running
      if [ -n "$pids" ]; then
        printf_blue "Found Caddy is running!"
        stopcaddy
        sleep 2
      fi
      sleep 1
      # Disable and remove startup script if exist
      removeservice
      # Remove Caddy web server folder, usually on /opt/caddyserver.
      rm -rf $GEN_CADDY_FILE_DIR &>/dev/null
      cmd_exists caddy && __rm_rf "$GEN_CADDY_FILE_DIR/caddy"
      # Backup Caddyfile if exists, usually on /etc/Caddyfile.
      if [[ -e $GEN_CADDY_CONFIG_DIR ]]; then
        cp $GEN_CADDY_CONFIG_DIR $GEN_CADDY_CONFIG_DIR.bak
        printf_blue "Backup of current Caddyfile saved to $GEN_CADDY_CONFIG_DIR.bak"
      fi
      # Now remove Caddyfile
      rm -f $GEN_CADDY_CONFIG_DIR &>/dev/null
      # Prompt if data should be removed
      if [[ -d "$GEN_CADDY_WWW_DIR" ]]; then
        printf_blue "$caddyname has been deleted."
        deletecaddydata
      else
        # remove caddy user
        if [[ ! $GEN_CADDY_DEFAULT_USER == $(whoami) ]]; then
          if id -u $GEN_CADDY_DEFAULT_USER >/dev/null 2>&1; then
            hash php 2>/dev/null && fixphpfpm www-data
            restartphpfpm
            userdel $GEN_CADDY_DEFAULT_USER # delete caddy user
            printf_blue "$caddyname and Caddy user '$GEN_CADDY_DEFAULT_USER' has been deleted."
          fi
        fi
      fi
      exit
      ;;
    [nN][oO] | [nN])
      printf_blue "Abort."
      exit
      ;;
    *)
      printf_blue "Incorrect input, exiting! "
      exit
      ;;
    esac
  else
    printf_blue "Looks like Caddy is not installed!"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
removeservice() {
  if [[ -e /etc/init/caddy.conf || -e /etc/systemd/system/caddy.service ]]; then
    init=$(cat /proc/1/comm)
    printf_blue "Removing startup service..."
    if [ "$init" == 'systemd' ]; then
      systemctl disable caddy &>/dev/null
      rm -f /etc/systemd/system/caddy.service &>/dev/null
    elif [ "$init" == 'init' ]; then
      update-rc.d -f caddy.sh remove
      rm -f /etc/init/caddy.conf &>/dev/null
    fi
    printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
deletecaddydata() {
  totalsize=$(du -sh $GEN_CADDY_WWW_DIR)
  totalfiles=$(find $GEN_CADDY_WWW_DIR -type f | wc -l)
  printf_blue "Would you also like to delete data?"
  printf_blue "Size: $totalsize (Files: $totalfiles)"
  printf_read_question "5" "Select an option [y/N]: " "1" option
  case $option in
  [yY][eE][sS] | [yY])
    printf_blue "Deleting $GEN_CADDY_WWW_DIR (data)..."
    sleep 2
    rm -rf $GEN_CADDY_WWW_DIR # deleting caddy html folder
    printf_blue "[$(tput setaf 2)DONE$(tput sgr0)]"
    # remove caddy user too if exists
    if [[ ! $GEN_CADDY_DEFAULT_USER == $(whoami) ]]; then
      if id -u $GEN_CADDY_DEFAULT_USER >/dev/null 2>&1; then
        hash php 2>/dev/null && fixphpfpm www-data
        hash php 2>/dev/null && restartphpfpm
        userdel $GEN_CADDY_DEFAULT_USER # delete caddy user
        printf_blue "Caddy user '$GEN_CADDY_DEFAULT_USER' has been deleted too."
      fi
    fi
    ;;
  *)
    printf_blue "Removing $GEN_CADDY_WWW_DIR (data)... [$(tput setaf 5)Skipped$(tput sgr0)]"
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
versioninfo() {
  if [[ -e "$GEN_CADDY_FILE_DIR/caddy" ]]; then
    printf_blue "$("$GEN_CADDY_FILE_DIR/caddy" -version)"
  else
    printf_blue "$caddyname is not installed."
  fi
  printf_blue "$caddyname Installer - $cwsiv"
  if hash php 2>/dev/null; then
    printf_blue "$(php -v | grep cli)"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
edit_gen_caddy_config() {
  if hash nano 2>/dev/null; then
    printf_blue "opening $GEN_CADDY_CONFIG_DIR using nano"
    nano $GEN_CADDY_CONFIG_DIR
  elif hash editor 2>/dev/null; then
    editor $GEN_CADDY_CONFIG_DIR
  else
    printf_blue "error: please manually edit files"
    printf_blue "$GEN_CADDY_CONFIG_DIR"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
checkforupdate() {
  caddyversion=$("$GEN_CADDY_FILE_DIR/caddy" -version | sed -e 's/-/ /g' -e 's/[^0-9\. ]*//g' | awk '{print $1}')
  CADDYV=$(wget -qO- https://api.github.com/repos/caddyserver/caddy/releases/latest | grep tag_name | sed 's/[^0-9\.]*//g')
  isGreater=$(compareVersion $CADDYV $caddyversion)
  if [[ $CADDYV != "" && $isGreater == ">" ]]; then
    printf_blue "$(tput setaf 1)NOTICE:$(tput sgr0)"
    printf_blue "There is an update available of $caddyname"
    printf_blue "run $(tput setaf 3)$bashname update$(tput sgr0) to update"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
backupcaddy() {
  backupname="caddybackup-$(date +"%Y%m%d%H%M").tar.gz"
  printf_blue "Please wait! Creating backup $backupname"
  printf_blue "$(du -sh $GEN_CADDY_FILE_DIR)"
  printf_blue "$(du -sh $GEN_CADDY_CONFIG_DIR)"
  tar -czf "$backupname" $GEN_CADDY_FILE_DIR $GEN_CADDY_CONFIG_DIR --absolute-names || (
    printf_blue "error creating backup $backupname"
    printf_blue "Abort."
    rm -f "$backupname"
    exit
  )
  printf_blue "Backup finished."
  printf_blue "$(du -sh "$backupname")"
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
restorecaddy() {
  if [[ ! -x "$GEN_CADDY_FILE_DIR/caddy" ]]; then
    printf_blue "$(tput setaf 1)WARN:$(tput sgr0)"
    printf_blue "Caddy is not installed."
    printf_blue "It is recommended to install Caddy before restoring."
    printf_read_question "5" "Press enter to continue anyway!" || return
  fi
  printf_read_input "5" "Please provide backup name: " "160" backupname || exit
  printf_blue "Please wait! restoring backup $backupname"
  if [[ -e $backupname ]]; then
    printf_blue "$(du -sh "$backupname")"
    tar -xzf "$backupname" --absolute-names || (
      printf_blue "error restoring backup $backupname"
      printf_blue "Abort."
      exit
    )
    printf_blue "Restore finished."
  else
    printf_blue "$backupname not found on $(pwd)"
    printf_blue "Abort."
  fi
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
GEN_CADDY_LOG_DIR="${GEN_CADDY_LOG_DIR:-$HOME/.local/log/gen-caddy}"
