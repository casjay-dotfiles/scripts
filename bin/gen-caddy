# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GEN_CADDY_CONFIG_DIR/$GEN_CADDY_CONFIG_FILE" ] && . "$GEN_CADDY_CONFIG_DIR/$GEN_CADDY_CONFIG_FILE"
