# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case $1 in
'start' | 'startcaddy')
  caddy start &>/dev/null
  startcaddy
  ;;
'stop' | 'stopcaddy')
  stopcaddy
  ;;
'reload' | 'reloadcaddy')
  reloadcaddy
  ;;
'restart')
  stopcaddy
  sleep 2
  startcaddy
  ;;
'status' | 'caddystatus')
  caddystatus
  ;;
'install')
  amiroot
  plugin="$2"
  installcaddy
  makeservice
  gen_caddy_config
  ;;
'install-naked')
  amiroot
  plugin="$2"
  installcaddy naked
  ;;
'update' | 'updatecaddy')
  amiroot
  plugin="$2"
  updatecaddy
  gen_caddy_config
  ;;
'fixphp' | 'fixphpfpm')
  amiroot
  fixphpfpm
  ;;
'installphp')
  amiroot
  installphp
  ;;
'edit')
  amiroot
  edit_gen_caddy_config
  ;;
'service' | 'makeservice')
  rm -f /etc/systemd/system/caddy.service
  amiroot
  makeservice
  ;;
'uninstall')
  amiroot
  deletecaddy
  ;;
'delete-service' | 'remove-startup')
  amiroot
  removeservice
  ;;
'backup')
  backupcaddy
  ;;
'restore')
  restorecaddy
  ;;
'about')
  about
  ;;
'help')
  prms
  ;;
'version' | 'versioninfo')
  versioninfo
  ;;
'download')
  getcaddy
  ;;
'reverse')
  shift 1
  if cmd_exists caddy; then
    sudo -H -u $GEN_CADDY_DEFAULT_USER "$GEN_CADDY_FILE_DIR/caddy" reverse-proxy -to 127.0.0.1:${1:-3000} -from :${2:-20000}
  else
    printf_red "caddy doesn't seem to be installed"
    printf_exit 1 1 "Please run $bashname install to setup caddy"
  fi
  ;;
*)
  caddystatus
  howto
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
