  __printf_line "mydomain ip ip6                 - Create a new zone with domain:mydomain ip:ip ipv6:ip6"
  __printf_line "--force                         - Will run a wizard to setup the domain"
  __printf_line "--domain [domain]               - Set the domain name"
  __printf_line "--hostip6 [ipv6_address]        - Set the host ip v6 address"
  __printf_line "--dnsip4 [ipv4_address]         - Set the dns ip v4 address"
  __printf_line "--dnsip6 [ipv6_address]         - Set the dns ip v6 address"
  __printf_line "--dnsip6 [ipv6_address]         - Set the dns ip v6 address"
  __printf_line "--forward [ipv4_address]        - Set the allowed forward address"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "--help                          - Shows this message"
  __printf_line "--config                        - Generate user config file"
  __printf_line "--version                       - Show script version"
  __printf_line "--options                       - Shows all available options"
  __printf_line "--debug                         - Enables script debugging"
  __printf_line "--raw                           - Removes all formatting on output"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -s "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$GEN_DNS_REQUIRE_SUDO" = "yes" ] && [ -z "$GEN_DNS_REQUIRE_SUDO_RUN" ]; then
    export GEN_DNS_REQUIRE_SUDO="no"
    export GEN_DNS_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "$(basename "$SUDO" 2>/dev/null)" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-$?}
  [ -f "$GEN_DNS_TEMP_FILE" ] && rm -Rf "$GEN_DNS_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__tsig_key() {
  [ -n "$(type -P tsig-keygen || false)" ] || return 1
  tsig-keygen -a hmac-sha256 | grep 'secret' | sed 's|.*secret ||g;s|"||g;s|;||g' | grep '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__has_ipv4() { [ -n "$2" ] && printf '%s%s\n' "$1" "$2" || return; }
__has_ipv6() { [ -n "$2" ] && printf '%s%s\n' "$1" "$2" || return; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__import() {
  [ -z "$3" ] && ___grep_rm() { grep -v ''.*:.*:.*''; } || ___grep_rm() { grep '^'; }
  [ -f "/var/named/master/$1.zone" ] && import="$(cat "/var/named/master/$1.zone" | grep -Ev ';|^\$|TXT' | ___grep_rm | sed 's|   [1-9].*\..*|   '$2'|g;s|   [1-9].*:.*|   '$3'|g')" || return
  cat <<EOF | tee
;  ********** begin imported settings **********
$import
;  ********** end imported settings **********

EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__set_ip_addresses() {
  [ -z "$GEN_DNS_FORCE" ] && [ -n "$GEN_DNS_DEFAULT_DNS_IP4" ] || printf_read_question "3" "What is your DNS Servers IP" 120 GEN_DNS_DEFAULT_DNS_IP4
  [ -z "$GEN_DNS_FORCE" ] && [ -n "$GEN_DNS_DEFAULT_HOST_IP4" ] || printf_read_question "3" "What is your hosts IP address" 120 GEN_DNS_DEFAULT_HOST_IP4
  if [[ "$GEN_DNS_HAS_IPV6" != "no" ]]; then
    if [ -z "$GEN_DNS_DEFAULT_DNS_IP6" ] || [ -z "$GEN_DNS_DEFAULT_DNS_IP4" ]; then
      printf_read_question "3" "Does you dns or host have IP6?" 1 GEN_DNS_HAS_IPV6
    fi
  fi
  if printf_answer_yes "$GEN_DNS_HAS_IPV6"; then
    [ -z "$GEN_DNS_FORCE" ] && [ -n "$GEN_DNS_DEFAULT_DNS_IP6" ] || printf_read_question "3" "What is your DNS Servers IP6" 120 GEN_DNS_DEFAULT_DNS_IP6
    [ -z "$GEN_DNS_FORCE" ] && [ -n "$GEN_DNS_DEFAULT_HOST_IP6" ] || printf_read_question "3" "What is your hosts IP6 address" 120 GEN_DNS_DEFAULT_HOST_IP6
  else
    true
  fi
  [ -n "$GEN_DNS_DEFAULT_DNS_IP4" ] || [ -n "$GEN_DNS_DEFAULT_HOST_IP4" ] || printf_error "Continuing but with unset variables"
  [ "$GEN_DNS_HAS_IPV6" = "y" ] && [ -z "$GEN_DNS_DEFAULT_DNS_IP6" ] && printf_exit "You have IPV6 enabled but did not provide an IPV6 address"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__edit_conf() {
  local zoneFile="$GEN_DNS_FILE_ZONE_DIR/$1.zone"
  local confFile="$GEN_DNS_FILE_CONF_DIR/$1.conf"
  if [ -n "$zoneFile" ] || [ -n "$confFile" ]; then
    [ -f "$zoneFile" ] && $GEN_DNS_EDITOR "$zoneFile" 2>/dev/null || false
    [ -f "$confFile" ] && $GEN_DNS_EDITOR "$confFile" 2>/dev/null || false
  else
    [ -f "$GEN_DNS_CONFIG_DIR/dns-zone.txt" ] &&
      $GEN_DNS_EDITOR "$GEN_DNS_CONFIG_DIR/dns-zone.txt" 2>/dev/null || false
  fi
  [ $? -eq 0 ] && printf_green "File[s] has been edited" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__template() {
  local serial="" domain="" dns_ipv4="" dns_ipv6="" host_ipv4="" host_ipv6=""
  [ -n "$GEN_DNS_VERSION_NEW" ] && GEN_DNS_VERSION="${GEN_DNS_VERSION_NEW: -2}"
  serial="$(date +"$GEN_DNS_SERIAL_FMT")$GEN_DNS_VERSION"
  domain="$GEN_DNS_DEFAULT_DOMAIN"
  dns_ipv4="${GEN_DNS_DEFAULT_DNS_IP4:-}"
  dns_ipv6="${GEN_DNS_DEFAULT_DNS_IP6:-}"
  host_ipv4="${GEN_DNS_DEFAULT_HOST_IP4:-}"
  host_ipv6="${GEN_DNS_DEFAULT_HOST_IP6:-}"
  if [ -f "$GEN_DNS_FILE_ZONE_DIR/template.zone" ]; then
    cat <<EOF
$(. "$GEN_DNS_CONFIG_DIR/template.zone")

EOF
  else
    cat <<EOF
; Bind DNS settings for $domain
;  ********** begin soa settings **********
\$TTL                                                   38400
@                                      SOA             dns1.$domain dns-admin.$domain ( $serial 10800 3600 1209600 38400)
;*                                     SOA             dns1.$domain dns-admin.$domain ( $serial 10800 3600 1209600 38400)
;  ********** end soa settings **********

;  ********** begin domain settings **********
\$ORIGIN                                                $domain.
dns                                    A               $dns_ipv4
dns1                                   A               $dns_ipv4
dns2                                   A               $dns_ipv4
$(__has_ipv6 "dns                                        AAAA        " "$dns_ipv6")
$(__has_ipv6 "dns1                                       AAAA        " "$dns_ipv6")
$(__has_ipv6 "dns2                                       AAAA        " "$dns_ipv6")
;  ********** end domain settings **********

;  ********** begin nameserver settings **********
@                                      NS              dns1.$domain.
@                                      NS              dns2.$domain.
;*                                     NS              dns1.$domain.
;*                                     NS              dns2.$domain.
;  ********** end nameserver settings **********

;  ********** begin host settings **********
$(__has_ipv4 "@                                          A           " "$host_ipv4")
$(__has_ipv4 "*                                          A           " "$host_ipv4")
$(__has_ipv6 "@                                          AAAA        " "$host_ipv6")
$(__has_ipv6 "*                                          AAAA        " "$host_ipv6")
;  ********** end host settings **********

;  ********** begin github pages settings **********
;@                                     CNAME           username.github.io.; [preferred] - use github cname
;*                                     CNAME           username.github.io.; [preferred] - use github cname
;@                                     A               185.199.108.153 ; github pages
;@                                     A               185.199.109.153 ; github pages
;@                                     A               185.199.110.153 ; github pages
;@                                     A               185.199.111.153 ; github pages
;*                                     A               185.199.108.153 ; github pages
;*                                     A               185.199.109.153 ; github pages
;*                                     A               185.199.110.153 ; github pages
;*                                     A               185.199.111.153 ; github pages
;  ********** end github pages settings **********

;  ********** begin email settings **********
gsuite                                 CNAME           gsuite.mail.casjay.net.redirect.center.
client                                 CNAME           gsuite.mail.casjay.net.redirect.center.
mail                                   CNAME           ASPMX.L.GOOGLE.COM.
smtp                                   CNAME           smtp.gmail.com.
imap                                   CNAME           imap.gmail.com.
pop                                    CNAME           pop.gmail.com.
autoconfig                             CNAME           mail
autodiscover                           CNAME           mail
@                                      MX              1 ASPMX.L.GOOGLE.COM.
*                                      MX              1 ASPMX.L.GOOGLE.COM.
@                                      MX              5 ALT1.ASPMX.L.GOOGLE.COM.
*                                      MX              5 ALT1.ASPMX.L.GOOGLE.COM.
@                                      MX              5 ALT2.ASPMX.L.GOOGLE.COM.
*                                      MX              5 ALT2.ASPMX.L.GOOGLE.COM.
@                                      SPF             "v=spf1 a mx ptr all"
*                                      SPF             "v=spf1 a mx ptr all"
@                                      TXT             "v=spf1 a mx ptr all"
*                                      TXT             "v=spf1 a mx ptr all"
;  ********** end email settings **********

;  ********** begin gsuite settings **********
office                                 CNAME           gsuite.casjay.net.redirect.center.
sites                                  CNAME           gsuite.sites.casjay.net.redirect.center.
drive                                  CNAME           gsuite.drive.casjay.net.redirect.center.
cloud                                  CNAME           gsuite.drive.casjay.net.redirect.center.
groups                                 CNAME           gsuite.groups.casjay.net.redirect.center.
calendar                               CNAME           gsuite.calendar.casjay.net.redirect.center.
admin.gsuite                           CNAME           google.com.opts-slash.a.opts-slash.casjay.net.opts-https.redirect.center.
;  ********** end gsuite settings **********

;  ********** begin database settings **********
sql                                    CNAME           sqldb.us.
*.sql                                  CNAME           sqldb.us.
pgsql                                  CNAME           sqldb.us.
mysql                                  CNAME           sqldb.us.
mongo                                  CNAME           sqldb.us.
redis                                  CNAME           sqldb.us.
;  ********** end database settings **********

;  ********** begin nntp settings **********
nntp                                   CNAME           $domain.
news                                   CNAME           nntp
lists                                  CNAME           nntp
;  ********** end nntp settings **********

;  ********** begin ntp settings **********
ntp                                    CNAME           $domain.
