#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : gen-dns --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : gen-dns
# @Description   : Generate a dns zone
# @TODO          :
# @Other         :
# @Resource      : https://bash.cyberciti.biz/domain/create-bind9-domain-zone-configuration-file/
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$GEN_DNS_TEMP_FILE" ] && [ -f "$GEN_DNS_TEMP_FILE" ] && rm -Rf "$GEN_DNS_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GEN_DNS_CONFIG_DIR/$GEN_DNS_CONFIG_FILE"
  [ -d "$GEN_DNS_CONFIG_DIR" ] || mkdir -p "$GEN_DNS_CONFIG_DIR"
  [ -d "$GEN_DNS_CONFIG_BACKUP_DIR" ] || mkdir -p "$GEN_DNS_CONFIG_BACKUP_DIR"
  [ -f "$GEN_DNS_CONFIG_DIR/$GEN_DNS_CONFIG_FILE" ] &&
    cp -Rf "$GEN_DNS_CONFIG_DIR/$GEN_DNS_CONFIG_FILE" "$GEN_DNS_CONFIG_BACKUP_DIR/$GEN_DNS_CONFIG_FILE.$$"
  cat <<EOF >"$GEN_DNS_CONFIG_DIR/$GEN_DNS_CONFIG_FILE"
# Settings for gen-dns
GEN_DNS_SERIAL_FMT="%Y%m%d"
GEN_DNS_EDITOR="${GEN_DNS_EDITOR:-vim}"
GEN_DNS_FILE_DIR="$GEN_DNS_CONFIG_DIR/zones"
GEN_DNS_DEFAULT_OS_IP="${GEN_DNS_DEFAULT_OS_IP:-}"
GEN_DNS_DEFAULT_DNS_IP="${GEN_DNS_DEFAULT_DNS_IP:-}"
GEN_DNS_DEFAULT_DNS_IP6="${GEN_DNS_DEFAULT_DNS_IP6:-}"
GEN_DNS_DEFAULT_OS_IP6="${GEN_DNS_DEFAULT_OS_IP6:-}"
GEN_DNS_HAS_IPV6="${GEN_DNS_HAS_IPV6:-}"

# Notification settings
GEN_DNS_GOOD_MESSAGE="${GEN_DNS_GOOD_MESSAGE:-Everything Went OK}"
GEN_DNS_ERROR_MESSAGE="${GEN_DNS_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_DNS_NOTIFY_ENABLED="${GEN_DNS_NOTIFY_ENABLED:-yes}"
GEN_DNS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_DNS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_DNS_NOTIFY_CLIENT_ICON}"

# Colorization settings
GEN_DNS_OUTPUT_COLOR="${GEN_DNS_OUTPUT_COLOR:-5}"
GEN_DNS_OUTPUT_COLOR_GOOD="${GEN_DNS_OUTPUT_COLOR_GOOD:-2}"
GEN_DNS_OUTPUT_COLOR_ERROR="${GEN_DNS_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GEN_DNS_CONFIG_DIR/$GEN_DNS_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for gen-dns has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      exec $APPNAME "$*"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__ip_addr() {
  [ -n "$GEN_DNS_DEFAULT_DNS_IP" ] || printf_read_question "3" "What is your DNS Servers IP" 120 GEN_DNS_DEFAULT_DNS_IP
  [ -n "$GEN_DNS_DEFAULT_OS_IP" ] || printf_read_question "3" "What is your hosts IP address" 120 GEN_DNS_DEFAULT_OS_IP
  if [[ "$GEN_DNS_HAS_IPV6" != "no" ]]; then
    { [ -z "$GEN_DNS_DEFAULT_DNS_IP6" ] || [ -z "$GEN_DNS_DEFAULT_DNS_IP" ]; } &&
      printf_read_question "3" "Does you dns or host have IP6?" 1 GEN_DNS_HAS_IPV6
  fi
  if printf_answer_yes "$GEN_DNS_HAS_IPV6"; then
    [ -n "$GEN_DNS_DEFAULT_DNS_IP6" ] || printf_read_question "3" "What is your DNS Servers IP6" 120 GEN_DNS_DEFAULT_DNS_IP6
    [ -n "$GEN_DNS_DEFAULT_OS_IP6" ] || printf_read_question "3" "What is your hosts IP6 address" 120 GEN_DNS_DEFAULT_OS_IP6
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__edit_conf() {
  if [ -n "$1" ]; then
    [ -f "$1" ] && $GEN_DNS_EDITOR "$1" 2>/dev/null
  else
    [ -f "$GEN_DNS_CONFIG_DIR/dns-zone.txt" ] &&
      $GEN_DNS_EDITOR "$GEN_DNS_CONFIG_DIR/dns-zone.txt" 2>/dev/null
  fi
  printf_green "File has been edited"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__template() {
  GEN_DNS_SERIAL_FMT="$(date +"$GEN_DNS_SERIAL_FMT")01"
  cat <<EOF
\$ORIGIN                                     '$GEN_DNS_DEFAULT_DOMAIN'.
\$TTL                                        38400

;  **********soa settings**********
@                            IN  SOA         dns1 dns-admin ( ${GEN_DNS_SERIAL_FMT}01 10800 3600 1209600 38400)
*                            IN  SOA         dns1 dns-admin ( ${GEN_DNS_SERIAL_FMT}01 10800 3600 1209600 38400)

;  **********nameserver settings**********
@                            IN  NS          dns1
@                            IN  NS          dns2
*                            IN  NS          dns1
*                            IN  NS          dns2

;  **********dns settings**********
dns                          IN  A           ${GEN_DNS_DEFAULT_DNS_IP:-149.28.32.84}
dns1                         IN  A           ${GEN_DNS_DEFAULT_DNS_IP:-149.28.32.84}
dns2                         IN  A           ${GEN_DNS_DEFAULT_DNS_IP:-149.28.32.84}

dns                          IN  AAAA        ${GEN_DNS_DEFAULT_DNS_IP6:-2001:19f0:5:2653:5400:02ff:fee3:f42e}
dns1                         IN  AAAA        ${GEN_DNS_DEFAULT_DNS_IP6:-2001:19f0:5:2653:5400:02ff:fee3:f42e}
dns2                         IN  AAAA        ${GEN_DNS_DEFAULT_DNS_IP6:-2001:19f0:5:2653:5400:02ff:fee3:f42e}

;  **********host settings**********
@                            IN  A           ${GEN_DNS_DEFAULT_OS_IP:-185.199.108.153}
@                            IN  A           ${GEN_DNS_DEFAULT_OS_IP:-185.199.109.153}
@                            IN  A           ${GEN_DNS_DEFAULT_OS_IP:-185.199.110.153}
@                            IN  A           ${GEN_DNS_DEFAULT_OS_IP:-185.199.111.153}
*                            IN  A           ${GEN_DNS_DEFAULT_OS_IP:-185.199.108.153}
*                            IN  A           ${GEN_DNS_DEFAULT_OS_IP:-185.199.109.153}
*                            IN  A           ${GEN_DNS_DEFAULT_OS_IP:-185.199.110.153}
*                            IN  A           ${GEN_DNS_DEFAULT_OS_IP:-185.199.111.153}
@                            IN  AAAA        ${GEN_DNS_DEFAULT_OS_IP6}
*                            IN  AAAA        ${GEN_DNS_DEFAULT_OS_IP6}

@                            IN  HINFO       "Web" "Shared Hosting"
@                            IN  TXT         "Free Web Hosted"
*                            IN  HINFO       "Web" "Shared Hosting"
*                            IN  TXT         "Free Web Hosted"

;  **********xmpp settings**********
;xmpp
irc                          IN  CNAME       chat.freenode.net.
webchat                      IN  CNAME       webchat.freenode.net.
xmpp                         IN  CNAME       xmpp-server.l.google.com.
talk                         IN  CNAME       xmpp
chat                         IN  CNAME       xmpp
userdata                     IN  CNAME       xmpp
pubsub                       IN  CNAME       xmpp
conference                   IN  CNAME       xmpp
;_xmpp-server.conference     IN  SRV         10  1   5269    xmpp
;_xmpp-server.pubsub._tcp    IN  SRV         10  1   5269    xmpp
;_xmpp-client._tcp           IN  SRV         10  1   5222    xmpp
;_xmpp-server._tcp           IN  SRV         10  1   5269    xmpp
_xmpp-server._tcp            IN  SRV         5   0   5269    xmpp-server.l.google.com.
_xmpp-server._tcp            IN  SRV         20  0   5269    xmpp-server1.l.google.com.
_xmpp-server._tcp            IN  SRV         20  0   5269    xmpp-server2.l.google.com.
_xmpp-server._tcp            IN  SRV         20  0   5269    xmpp-server3.l.google.com.
_xmpp-server._tcp            IN  SRV         20  0   5269    xmpp-server4.l.google.com.

;  **********jabber settings**********
_jabber._tcp                 IN  SRV         5   0   5269    xmpp-server.l.google.com.
_jabber._tcp                 IN  SRV         20  0   5269    xmpp-server1.l.google.com.
_jabber._tcp                 IN  SRV         20  0   5269    xmpp-server2.l.google.com.
_jabber._tcp                 IN  SRV         20  0   5269    xmpp-server3.l.google.com.
_jabber._tcp                 IN  SRV         20  0   5269    xmpp-server4.l.google.com.

;  **********irc settings**********
_irc._tcp                    IN  SRV         10 10   6667    chat.freenode.net.
_ircs._tcp                   IN  SRV         10 10   6697    chat.freenode.net.

;  **********email settings**********
gsuite                       IN  CNAME       gsuite.mail.casjay.net.redirect.center.
client                       IN  CNAME       gsuite.mail.casjay.net.redirect.center.
mail                         IN  CNAME       ASPMX.L.GOOGLE.COM.
smtp                         IN  CNAME       smtp.gmail.com.
imap                         IN  CNAME       imap.gmail.com.
pop                          IN  CNAME       pop.gmail.com.
lists                        IN  CNAME       mail
autoconfig                   IN  CNAME       mail
autodiscover                 IN  CNAME       mail
news                         IN  CNAME       mail

@                            IN  MX          1 ASPMX.L.GOOGLE.COM.
*                            IN  MX          1 ASPMX.L.GOOGLE.COM.
@                            IN  MX          5 ALT1.ASPMX.L.GOOGLE.COM.
*                            IN  MX          5 ALT1.ASPMX.L.GOOGLE.COM.
@                            IN  MX          5 ALT2.ASPMX.L.GOOGLE.COM.
*                            IN  MX          5 ALT2.ASPMX.L.GOOGLE.COM.

@                            IN  SPF         "v=spf1 a mx ptr all"
*                            IN  SPF         "v=spf1 a mx ptr all"
@                            IN  TXT         "v=spf1 a mx ptr all"
*                            IN  TXT         "v=spf1 a mx ptr all"

;  **********ntp settings**********
;machines on ntp.org
ntp                          IN  CNAME       0.casjay.pool.ntp.org.
pool.ntp                     IN  CNAME       ntp
*.pool.ntp                   IN  CNAME       ntp

;  **********gsuite settings**********
office      3600             IN  CNAME       gsuite.casjay.net.redirect.center.
sites       3600             IN  CNAME       gsuite.sites.casjay.net.redirect.center.
drive       3600             IN  CNAME       gsuite.drive.casjay.net.redirect.center.
cloud       3600             IN  CNAME       gsuite.drive.casjay.net.redirect.center.
groups      3600             IN  CNAME       gsuite.groups.casjay.net.redirect.center.
calendar    3600             IN  CNAME       gsuite.calendar.casjay.net.redirect.center.

;  **********sip settings**********
;pbx                         IN  A           ${GEN_DNS_DEFAULT_OS_IP:-149.28.32.84}
;sip                         IN  A           ${GEN_DNS_DEFAULT_OS_IP:-149.28.32.84}
;tel                         IN  A           ${GEN_DNS_DEFAULT_OS_IP:-149.28.32.84}
;iax                         IN  A           ${GEN_DNS_DEFAULT_OS_IP:-149.28.32.84}

;  **********database settings**********
;sql                          IN  CNAME      ${GEN_DNS_DEFAULT_OS_IP:-149.28.32.84}
;*.sql                        IN  CNAME      ${GEN_DNS_DEFAULT_OS_IP:-149.28.32.84}

;  **********support settings**********
;wiki                         IN  CNAME      help.casjay.net.redirect.center.
;support                      IN  CNAME      help.casjay.net.redirect.center.

;  **********vpn settings**********
;ppp                          IN  A          ${GEN_DNS_DEFAULT_OS_IP:-149.28.32.84}
;vpn                          IN  A          ${GEN_DNS_DEFAULT_OS_IP:-149.28.32.84}

;  **********misc settings**********
;invoice                      IN  A          ${GEN_DNS_DEFAULT_OS_IP:-149.28.32.84}
;piwik                        IN  A          ${GEN_DNS_DEFAULT_OS_IP:-149.28.32.84}

;  **********other settings**********
localhost                    IN  A           127.0.0.1
localhost                    IN  AAAA        ::1
@                            IN  CAA         0 issue "letsencrypt.org"
@                            IN  CAA         0 iodef "mailto:casjay+ssl@gmail.com"
@                            IN  TYPE257     \# 22 000569737375656C657473656E63727970742E6F7267

EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__addtonamed() {
  printf_yellow "Add the contents of $GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone.conf to your named.conf file"
  echo 'zone "'$GEN_DNS_DEFAULT_DOMAIN'" {
        type master;
        file "'$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone'";
        allow-update {key "certbot."; key "dhcp-key"; trusted;};
    };' >"$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone.conf"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_dns_conf() {
  printf_read_question "3" "Would you like to replace the zone?" "1" REPLACE
  printf_answer_yes $REPLACE || printf_exit "1" "2" "$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone already exist\n"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_dns() {
  printf_green "Configuring DNS zone"
  [ -n "$GEN_DNS_DEFAULT_DOMAIN" ] || printf_read_question "3" "What is your Domain name" 120 GEN_DNS_DEFAULT_DOMAIN
  [ -f "$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone" ] && __gen_dns_conf
  __ip_addr
  [ -n "$GEN_DNS_DEFAULT_DOMAIN" ] || [ -n "$GEN_DNS_DEFAULT_DNS_IP" ] || [ -n "$GEN_DNS_DEFAULT_OS_IP" ] || printf_error "Continuing but with unset variables"
  if [ -z "$GEN_DNS_DEFAULT_DNS_IP6" ] || [ -z "$GEN_DNS_DEFAULT_OS_IP6" ]; then
    __template | grep -Fv 'AAAA' >"$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone"
  else
    __template >"$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone"
  fi
  if [ -f /etc/named/other/google-verifications.conf ]; then
    cat /etc/named/other/google-verifications.conf >>"$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone"
    echo "" >>"$GEN_DNS_FILE_DIR"
  fi
  if [ -f /etc/named/other/misc.conf ]; then
    cat /etc/named/other/misc.conf >>"$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone"
    echo "" >>"$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone"
  fi
  if [ $? = 0 ] && [ -f "$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone" ]; then
    printf_green "zone for $GEN_DNS_DEFAULT_DOMAIN has been setup and saved to "
    printf_yellow "$GEN_DNS_FILE_DIR/$GEN_DNS_DEFAULT_DOMAIN.zone"
    __addtonamed
  else
    printf_exit 1 1 "Failed to configure $GEN_DNS_DEFAULT_DOMAIN"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
GEN_DNS_LOG_DIR="${GEN_DNS_LOG_DIR:-$HOME/.local/log/gen-dns}"
GEN_DNS_CACHE_DIR="${GEN_DNS_CACHE_DIR:-$HOME/.cache/gen-dns}"
GEN_DNS_CONFIG_DIR="${GEN_DNS_CONFIG_DIR:-$HOME/.config/myscripts/gen-dns}"
GEN_DNS_CONFIG_BACKUP_DIR="${GEN_DNS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/gen-dns/backups}"
GEN_DNS_TEMP_DIR="${GEN_DNS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/gen-dns}"
GEN_DNS_OPTIONS_DIR="${GEN_DNS_OPTIONS_DIR:-$HOME/.local/share/myscripts/gen-dns/options}"
GEN_DNS_TEMP_FILE="${GEN_DNS_TEMP_FILE:-$(mktemp $GEN_DNS_TEMP_DIR/XXXXXX 2>/dev/null)}"
GEN_DNS_CONFIG_FILE="${GEN_DNS_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
GEN_DNS_OUTPUT_COLOR="${GEN_DNS_OUTPUT_COLOR:-4}"
GEN_DNS_OUTPUT_COLOR_2="${GEN_DNS_OUTPUT_COLOR:-6}"
GEN_DNS_OUTPUT_COLOR_GOOD="${GEN_DNS_OUTPUT_COLOR_GOOD:-2}"
GEN_DNS_OUTPUT_COLOR_ERROR="${GEN_DNS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
GEN_DNS_GOOD_MESSAGE="${GEN_DNS_GOOD_MESSAGE:-Everything Went OK}"
GEN_DNS_ERROR_MESSAGE="${GEN_DNS_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_DNS_NOTIFY_ENABLED="${GEN_DNS_NOTIFY_ENABLED:-yes}"
GEN_DNS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_DNS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_DNS_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
GEN_DNS_EDITOR="${GEN_DNS_EDITOR:-vim}"
GEN_DNS_FILE_DIR="${GEN_DNS_FILE_DIR:-$GEN_DNS_CONFIG_DIR/zones}"
GEN_DNS_SERIAL_FMT="${GEN_DNS_SERIAL_FMT:-%Y%m%d}"
GEN_DNS_DEFAULT_DOMAIN="${GEN_DNS_DEFAULT_DOMAIN:-}"
GEN_DNS_DEFAULT_OS_IP="${GEN_DNS_DEFAULT_OS_IP:-}"
GEN_DNS_DEFAULT_DNS_IP="${GEN_DNS_DEFAULT_DNS_IP:-}"
GEN_DNS_DEFAULT_DNS_IP6="${GEN_DNS_DEFAULT_DNS_IP6:-}"
GEN_DNS_DEFAULT_OS_IP6="${GEN_DNS_DEFAULT_OS_IP6:-}"
GEN_DNS_HAS_IPV6="${GEN_DNS_HAS_IPV6:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GEN_DNS_CONFIG_DIR/$GEN_DNS_CONFIG_FILE" ] && . "$GEN_DNS_CONFIG_DIR/$GEN_DNS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$GEN_DNS_LOG_DIR" ] || mkdir -p "$GEN_DNS_LOG_DIR" &>/dev/null
[ -d "$GEN_DNS_TEMP_DIR" ] || mkdir -p "$GEN_DNS_TEMP_DIR" &>/dev/null
[ -d "$GEN_DNS_CACHE_DIR" ] || mkdir -p "$GEN_DNS_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$GEN_DNS_CONFIG_DIR/$GEN_DNS_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY="edit "
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    GEN_DNS_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$GEN_DNS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${GEN_DNS_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${GEN_DNS_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${GEN_DNS_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${GEN_DNS_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
