# Actions based on env
GEN_DOCKERFILE_TEMPLATE="alpine"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
case "$1" in
alpine)
  shift 1
  GEN_DOCKERFILE_TEMPLATE="alpine"
  ;;
debian)
  shift 1
  GEN_DOCKERFILE_TEMPLATE="debian"
  ;;
rhel)
  shift 1
  GEN_DOCKERFILE_TEMPLATE="rhel"
  ;;
