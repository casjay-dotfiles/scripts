# Generate config files
[ -f "$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE" ] ||
  [ "$*" = "--config" ] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE" ] &&
  . "$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$GEN_DOCKERFILE_LOG_DIR" ] ||
  mkdir -p "$GEN_DOCKERFILE_LOG_DIR" |& __devnull
[ -d "$GEN_DOCKERFILE_TEMP_DIR" ] ||
  mkdir -p "$GEN_DOCKERFILE_TEMP_DIR" |& __devnull
[ -d "$GEN_DOCKERFILE_CACHE_DIR" ] ||
  mkdir -p "$GEN_DOCKERFILE_CACHE_DIR" |& __devnull
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
GEN_DOCKERFILE_TEMP_FILE="${GEN_DOCKERFILE_TEMP_FILE:-$(mktemp $GEN_DOCKERFILE_TEMP_DIR/XXXXXX 2>/dev/null)}"
