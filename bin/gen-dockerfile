# Migrate legacy ENV_IMAGE_* variables once before normal processing
__migrate_env_script
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Set actions based on variables
shopt -s nullglob
dockerfiles_in_dir=("$GEN_DOCKERFILE_CWD"/Dockerfile*)
shopt -u nullglob
[ "${#dockerfiles_in_dir[@]}" -ne 0 ] && GEN_DOCKER_ONLY_DOCKERFILE="true"
