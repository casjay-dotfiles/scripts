# User defined functions
# - - - - - - - - - - - - - - - - - - - - - - - - -
__dockerignore() { __cmd_exists dockerignore && dockerignore || true; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__rm_rf() {
  for d in "$@"; do
    [ -e "$d" ] && rm -Rf "$d"
    [ ! -e "$d" ] || return 1
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__trim() {
  local var="${*//;/ }"
  var="${var#"${var%%[![:space:]]*}"}" # remove leading whitespace characters
  var="${var%"${var##*[![:space:]]}"}" # remove trailing whitespace characters
  while [[ "$var" == *"  "* ]]; do
    var="${var//  / }"
  done
  [ -n "$var" ] && printf '%s' "$var"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__lower() {
  printf '%s' "${1,,}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__registry_host_from_ref() {
  local ref="${1:-}" first_segment="" remainder=""
  first_segment="${ref%%/*}"
  remainder="${ref#*/}"
  [ "$ref" != "$remainder" ] || return 1
  case "$first_segment" in
  localhost | *.* | *:*)
    [ "$remainder" != "${remainder#*/}" ] || return 1
    printf '%s' "$first_segment"
    ;;
  *)
    return 1
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__strip_registry_provider() {
  local ref="${1:-}" registry_host=""
  registry_host="$(__registry_host_from_ref "$ref" 2>/dev/null || true)"
  if [ -n "$registry_host" ]; then
    printf '%s' "${ref#*/}"
  else
    printf '%s' "$ref"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__normalize_registry_provider() {
  local raw_value="${1:-}" registry_base="" registry_host="" registry_scheme="https"
  raw_value="${raw_value%/}"
  [ -n "$raw_value" ] || raw_value="docker.io"
  if [[ "$raw_value" == *://* ]]; then
    registry_scheme="${raw_value%%://*}"
    registry_host="${raw_value#*://}"
    registry_host="${registry_host%%/*}"
  else
    registry_host="${raw_value%%/*}"
  fi
  registry_host="$(__lower "$registry_host")"
  case "$registry_host" in
  hub.docker.com | index.docker.io | registry-1.docker.io)
    registry_host="docker.io"
    ;;
  esac
  registry_base="$registry_scheme://$registry_host"
  GEN_DOCKERFILE_REGISTRY_URL="$registry_base"
  GEN_DOCKERFILE_HUB_BASE="$GEN_DOCKERFILE_REGISTRY_URL"
  GEN_DOCKERFILE_REGISTRY_HOST="$registry_host"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__render_templates_to_file() {
  local output_file="${1:-}" template_file=""
  shift 1 || true
  [ -n "$output_file" ] || return 1
  : >"$output_file" || return 1
  for template_file in "$@"; do
    [ -f "$template_file" ] || continue
    . "$template_file"
  done >"$output_file"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Keep a narrow compatibility bridge for older config/env names while
# treating GEN_DOCKERFILE_SET_* as the primary runtime inputs.
__sync_repo_setting_aliases() {
  [ -n "$GEN_DOCKERFILE_SET_REGISTRY_URL" ] || GEN_DOCKERFILE_SET_REGISTRY_URL="${GEN_DOCKERFILE_SET_REGISTRY_PROVIDER:-}"
  [ -n "$GEN_DOCKERFILE_SET_REGISTRY_PROVIDER" ] || GEN_DOCKERFILE_SET_REGISTRY_PROVIDER="${GEN_DOCKERFILE_SET_REGISTRY_URL:-}"
  [ -n "$GEN_DOCKERFILE_SET_GIT_ORG" ] || GEN_DOCKERFILE_SET_GIT_ORG="${GEN_DOCKERFILE_GIT_ORG_OVERRIDE:-}"
  [ -n "$GEN_DOCKERFILE_SET_REGISTRY_ORG" ] || GEN_DOCKERFILE_SET_REGISTRY_ORG="${GEN_DOCKERFILE_REGISTRY_ORG_OVERRIDE:-}"
  [ -n "$GEN_DOCKERFILE_SET_GIT_REPO" ] || GEN_DOCKERFILE_SET_GIT_REPO="${GEN_DOCKERFILE_GIT_REPO_NAME_OVERRIDE:-}"
  [ -n "$GEN_DOCKERFILE_SET_REGISTRY_REPO" ] || GEN_DOCKERFILE_SET_REGISTRY_REPO="${GEN_DOCKERFILE_REGISTRY_REPO_OVERRIDE:-}"
  [ -n "$GEN_DOCKERFILE_SET_GIT_REPO_URL" ] || GEN_DOCKERFILE_SET_GIT_REPO_URL="${GEN_DOCKERFILE_GIT_REPO_OVERRIDE:-}"
  GEN_DOCKER_GIT_ORG="${GEN_DOCKERFILE_SET_GIT_ORG:-${GEN_DOCKERFILE_DEFAULT_GIT_ORG:-$GEN_DOCKER_GIT_ORG}}"
  GEN_DOCKER_REGISTRY_ORG="${GEN_DOCKERFILE_SET_REGISTRY_ORG:-${GEN_DOCKERFILE_DEFAULT_REGISTRY_ORG:-$GEN_DOCKER_REGISTRY_ORG}}"
  GEN_DOCKER_DEFAULT_ORG="${GEN_DOCKERFILE_SET_REGISTRY_ORG:-${GEN_DOCKER_DEFAULT_ORG:-}}"
  GEN_DOCKERFILE_GIT_ORG_OVERRIDE="${GEN_DOCKERFILE_SET_GIT_ORG:-}"
  GEN_DOCKERFILE_REGISTRY_ORG_OVERRIDE="${GEN_DOCKERFILE_SET_REGISTRY_ORG:-}"
  GEN_DOCKERFILE_GIT_REPO_NAME_OVERRIDE="${GEN_DOCKERFILE_SET_GIT_REPO:-}"
  GEN_DOCKERFILE_REGISTRY_REPO_OVERRIDE="${GEN_DOCKERFILE_SET_REGISTRY_REPO:-}"
  GEN_DOCKERFILE_GIT_REPO_OVERRIDE="${GEN_DOCKERFILE_SET_GIT_REPO_URL:-}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__git_remote_url() {
  git -C "${1:-$GEN_DOCKERFILE_CWD}" remote get-url origin 2>/dev/null ||
    git -C "${1:-$GEN_DOCKERFILE_CWD}" config --get remote.origin.url 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__parse_git_remote() {
  local remote_url="${1:-}" sanitized="" host="" path=""
  GEN_DOCKERFILE_REMOTE_URL=""
  GEN_DOCKERFILE_REMOTE_BASE=""
  GEN_DOCKERFILE_REMOTE_OWNER=""
  GEN_DOCKERFILE_REMOTE_REPO=""
  [ -n "$remote_url" ] || return 1
  remote_url="${remote_url%.git}"
  case "$remote_url" in
  *@*:* )
    sanitized="${remote_url#*@}"
    host="${sanitized%%:*}"
    path="${sanitized#*:}"
    ;;
  *://* )
    sanitized="${remote_url#*://}"
    sanitized="${sanitized#*@}"
    host="${sanitized%%/*}"
    path="${sanitized#*/}"
    ;;
  * )
    return 1
    ;;
  esac
  [ -n "$host" ] || return 1
  [ "${path#*/}" != "$path" ] || return 1
  GEN_DOCKERFILE_REMOTE_URL="$remote_url"
  GEN_DOCKERFILE_REMOTE_BASE="https://$host"
  GEN_DOCKERFILE_REMOTE_OWNER="${path%%/*}"
  GEN_DOCKERFILE_REMOTE_REPO="$(basename -- "$path")"
  [ -n "$GEN_DOCKERFILE_REMOTE_OWNER" ] && [ -n "$GEN_DOCKERFILE_REMOTE_REPO" ]
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__is_project_directory() {
  local cwd="${1:-$GEN_DOCKERFILE_CWD}" base_dir="" resolved_base=""
  cwd="$(realpath -m "$cwd" 2>/dev/null)"
  for base_dir in ${GEN_DOCKERFILE_PROJECT_DIRS:-"$HOME/Documents $HOME/Projects $HOME/Developer $HOME/Development $HOME/Workspace $HOME/Workspaces $HOME/src"}; do
    case "$base_dir" in
    "~"*) base_dir="$HOME${base_dir#\~}" ;;
    esac
    resolved_base="$(realpath -m "$base_dir" 2>/dev/null)"
    case "$cwd/" in
    "$resolved_base"/*) return 0 ;;
    esac
  done
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__resolve_repo_settings() {
  local default_git_org="${GEN_DOCKERFILE_DEFAULT_GIT_ORG:-casjaysdevdocker}"
  local default_registry_org="${GEN_DOCKERFILE_DEFAULT_REGISTRY_ORG:-casjaysdevdocker}"
  local default_repo="${GEN_DOCKERFILE_DEFAULT_REPO:-${GEN_DOCKERFILE_DEFAULT_IMAGE##*/}}"
  local remote_url="" path_org="" path_repo="" configured_git_org="" configured_registry_org=""
  [ -n "$default_repo" ] || default_repo="${GEN_DOCKERFILE_TEMPLATE:-alpine}"
  if __is_project_directory "$GEN_DOCKERFILE_CWD"; then
    path_org="$(basename -- "$(dirname "$GEN_DOCKERFILE_CWD")")"
    path_repo="$(basename -- "$GEN_DOCKERFILE_CWD")"
  fi
  if remote_url="$(__git_remote_url "$GEN_DOCKERFILE_CWD" 2>/dev/null)"; then
    __parse_git_remote "$remote_url" || true
  fi
  __sync_repo_setting_aliases
  configured_git_org="${GEN_DOCKERFILE_SET_GIT_ORG:-}"
  configured_registry_org="${GEN_DOCKERFILE_SET_REGISTRY_ORG:-}"
  [ "$configured_git_org" = "$default_git_org" ] && configured_git_org=""
  [ "$configured_registry_org" = "$default_registry_org" ] && configured_registry_org=""
  GEN_DOCKERFILE_RESOLVED_REGISTRY_REPO="${GEN_DOCKERFILE_SET_REGISTRY_REPO:-${ENV_REGISTRY_REPO:-${GEN_DOCKERFILE_REMOTE_REPO:-${path_repo:-$default_repo}}}}"
  GEN_DOCKERFILE_RESOLVED_GIT_REPO_NAME="${GEN_DOCKERFILE_SET_GIT_REPO:-${GEN_DOCKERFILE_REMOTE_REPO:-${path_repo:-$default_repo}}}"
  GEN_DOCKERFILE_RESOLVED_GIT_ORG="${GEN_DOCKERFILE_SET_GIT_ORG:-${configured_git_org:-${GEN_DOCKERFILE_REMOTE_OWNER:-$path_org}}}"
  GEN_DOCKERFILE_RESOLVED_REGISTRY_ORG="${GEN_DOCKERFILE_SET_REGISTRY_ORG:-${ENV_REGISTRY_ORG:-${configured_registry_org:-${GEN_DOCKERFILE_REMOTE_OWNER:-$path_org}}}}"
  [ -n "$GEN_DOCKERFILE_RESOLVED_GIT_ORG" ] || GEN_DOCKERFILE_RESOLVED_GIT_ORG="$default_git_org"
  [ -n "$GEN_DOCKERFILE_RESOLVED_REGISTRY_ORG" ] || GEN_DOCKERFILE_RESOLVED_REGISTRY_ORG="$default_registry_org"
  GEN_DOCKERFILE_RESOLVED_ORG="${GEN_DOCKERFILE_RESOLVED_REGISTRY_ORG:-$GEN_DOCKERFILE_RESOLVED_GIT_ORG}"
  if [ -n "$GEN_DOCKERFILE_SET_GIT_REPO_URL" ]; then
    GEN_DOCKERFILE_RESOLVED_GIT_REPO="$GEN_DOCKERFILE_SET_GIT_REPO_URL"
  elif [ -n "$GEN_DOCKERFILE_REMOTE_URL" ] && [ "$GEN_DOCKERFILE_RESOLVED_GIT_ORG/$GEN_DOCKERFILE_RESOLVED_GIT_REPO_NAME" = "$GEN_DOCKERFILE_REMOTE_OWNER/$GEN_DOCKERFILE_REMOTE_REPO" ]; then
    GEN_DOCKERFILE_RESOLVED_GIT_REPO="$GEN_DOCKERFILE_REMOTE_URL"
  else
    GEN_DOCKERFILE_RESOLVED_GIT_REPO="${GEN_DOCKERFILE_GIT_BASE:-https://github.com}/$GEN_DOCKERFILE_RESOLVED_GIT_ORG/$GEN_DOCKERFILE_RESOLVED_GIT_REPO_NAME"
  fi
  name="$GEN_DOCKERFILE_RESOLVED_REGISTRY_REPO"
  organization="$GEN_DOCKERFILE_RESOLVED_ORG"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__init_git() {
  gitignore --dir "$GEN_DOCKERFILE_CWD" default --automated &>/dev/null && printf_purple "Created $GEN_DOCKERFILE_CWD/.gitignore"
  gen-gitattr --dir "$GEN_DOCKERFILE_CWD" default --automated &>/dev/null && printf_purple "Created $GEN_DOCKERFILE_CWD/.gitattributes"
  # Create .dockerignore
  __dockerignore &>/dev/null && printf_purple "Created $GEN_DOCKERFILE_CWD/.dockerignore"
  # create README.md
  [ -f "$GEN_DOCKERFILE_CWD/README.md" ] || gen-readme projects docker.md "$GEN_DOCKERFILE_CWD/README.md" &>/dev/null && printf_purple "Created $GEN_DOCKERFILE_CWD/README.md"
  # create LICENSE.md
  [ -f "$GEN_DOCKERFILE_CWD/LICENSE.md" ] || gen-license wtfpl "$GEN_DOCKERFILE_CWD/LICENSE.md" &>/dev/null && printf_purple "Created $GEN_DOCKERFILE_CWD/LICENSE.md"
  printf_green "Using $repo as VCS url"
  if [ -d "$rootfs_dir/usr/local/bin" ] && [ -d "$template_dir/data" ] && [ -d "$template_dir/config" ] || [ "$GEN_DOCKERFILE_TEMPLATE" = "scratch" ]; then
    printf_blue "All files and Directories have been created"
    if [ "$GEN_DOCKER_INIT" = "true" ]; then rm -Rf "$file"; fi
    if [ -f "$file" ] && [ "$GEN_DOCKER_GIT_AUTO_INIT" = "yes" ]; then
      if [ ! -d "$GEN_DOCKERFILE_CWD/.git" ] && [ ! -f "$GEN_DOCKERFILE_CWD/.nogit" ]; then
        if [ "$GEN_DOCKER_AUTOMATED" = "true" ]; then
          gitadmin --dir "$GEN_DOCKERFILE_CWD" setup "$repo" --automated
        else
          [ -f "$GEN_DOCKERFILE_CWD/.gitignore" ] || gitignore "$GEN_DOCKERFILE_CWD" default
          gitadmin --dir "$GEN_DOCKERFILE_CWD" setup "$repo"
        fi
      fi
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__custom_init_files() {
  [ -d "$custom_init_dir" ] || mkdir -p "$custom_init_dir"
  for custom_init_file in "$GEN_DOCKERFILE_TEMPLATE_DIR/init_scripts"/*.sh; do
    custom_init_name="$(basename -- "$custom_init_file")"
    custom_init_command="${custom_init_name##*-}"
    custom_init_command="${custom_init_command%.sh}"
    printf_purple "Creating setup script: $custom_init_dir/$custom_init_name"
    if [ -f "$custom_init_dir/$custom_init_name" ]; then
      mv -f "$custom_init_dir/$custom_init_name" "$custom_init_dir/$custom_init_name.bak"
    fi
    . "$custom_init_file" >"$custom_init_dir/$custom_init_name"
    if [ -f "$custom_init_dir/$custom_init_name" ]; then
      chmod -Rf 755 "$custom_init_dir/$custom_init_name"
      chmod -Rf +x "$custom_init_dir/$custom_init_name"
    else
      printf_red "Failed to create $custom_init_dir/$custom_init_name"
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__replace_line_in_file() {
  local file="${1:-}" pattern="${2:-}" replacement="${3:-}" nth="${4:-0}" tmp_file=""
  [ -f "$file" ] || return 1
  tmp_file="$(mktemp "$GEN_DOCKERFILE_TEMP_DIR/replace.XXXXXX" 2>/dev/null)" || return 1
  awk -v pattern="$pattern" -v replacement="$replacement" -v nth="$nth" '
  $0 ~ pattern {
    count++
    if (nth == 0 || count == nth) {
      $0 = replacement
    }
  }
  { print }
  ' "$file" >"$tmp_file" && mv -f "$tmp_file" "$file"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__parse_scoped_value() {
  local raw_value="${1:-}" default_scope="${2:-registry}"
  if [[ "$raw_value" == *:* ]]; then
    GEN_DOCKERFILE_SCOPE="${raw_value%%:*}"
    GEN_DOCKERFILE_SCOPE_VALUE="${raw_value#*:}"
  else
    GEN_DOCKERFILE_SCOPE="$default_scope"
    GEN_DOCKERFILE_SCOPE_VALUE="$raw_value"
  fi
  [ "$GEN_DOCKERFILE_SCOPE" = "reg" ] && GEN_DOCKERFILE_SCOPE="registry"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__set_scoped_owner_override() {
  __parse_scoped_value "${1:-}" "registry"
  case "$GEN_DOCKERFILE_SCOPE" in
  git)
    GEN_DOCKERFILE_SET_GIT_ORG="$GEN_DOCKERFILE_SCOPE_VALUE"
    ;;
  registry)
    GEN_DOCKERFILE_SET_REGISTRY_ORG="$GEN_DOCKERFILE_SCOPE_VALUE"
    ;;
  esac
  __sync_repo_setting_aliases
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__set_scoped_repo_override() {
  __parse_scoped_value "${1:-}" "registry"
  case "$GEN_DOCKERFILE_SCOPE" in
  git)
    GEN_DOCKERFILE_SET_GIT_REPO="$GEN_DOCKERFILE_SCOPE_VALUE"
    ;;
  registry)
    GEN_DOCKERFILE_SET_REGISTRY_REPO="$GEN_DOCKERFILE_SCOPE_VALUE"
    ;;
  esac
  __sync_repo_setting_aliases
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__upsert_assignment() {
  local file="${1:-}" key="${2:-}" value="${3:-}" tmp_file="" found="false"
  [ -f "$file" ] || return 1
  tmp_file="$(mktemp "$GEN_DOCKERFILE_TEMP_DIR/upsert.XXXXXX" 2>/dev/null)" || return 1
  awk -v key="$key" -v value="$value" '
  BEGIN { found = 0 }
  $0 ~ "^" key "=" {
    print key "=\"" value "\""
    found = 1
    next
  }
  { print }
  END {
    if (found == 0) {
      print key "=\"" value "\""
    }
  }
  ' "$file" >"$tmp_file" && mv -f "$tmp_file" "$file"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__reset_env_script_vars() {
  ENV_ADD_IMAGE_PUSH=""
  ENV_ADD_TAGS=""
  ENV_AUTHOR=""
  ENV_DISTRO_TAG=""
  ENV_DOCKERFILE=""
  ENV_GIT_REPO_URL=""
  ENV_IMAGE_TAG=""
  ENV_MAINTAINER=""
  ENV_PACKAGES=""
  ENV_PLATFORMS=""
  ENV_PULL_URL=""
  ENV_REGISTRY_ORG=""
  ENV_REGISTRY_PUSH=""
  ENV_REGISTRY_REPO=""
  ENV_REGISTRY_URL=""
  ENV_USE_TEMPLATE=""
  ENV_VENDOR=""
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__write_env_file() {
  local env_file="${1:-}"
  [ -n "$env_file" ] || return 1
  dotenv_base_file="$(basename -- "$env_file")"
  . "$GEN_DOCKERFILE_TEMPLATE_DIR/dotenv.template" >"$env_file"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__update_env_file_in_place() {
  local env_file="${1:-}"
  [ -f "$env_file" ] || return 1
  __write_env_file "$env_file" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__update_dockerfile_in_place() {
  local dockerfile="${1:-}" image_name=""
  [ -f "$dockerfile" ] || return 1
  image_name="$(basename -- "$GEN_DOCKERFILE_PUSH_URL")"
  __replace_line_in_file "$dockerfile" '^ARG IMAGE_NAME=' "ARG IMAGE_NAME=\"$image_name\"" || return 1
  __replace_line_in_file "$dockerfile" '^ARG PHP_SERVER=' "ARG PHP_SERVER=\"$image_name\"" || true
  __replace_line_in_file "$dockerfile" '^ARG IMAGE_REPO=' "ARG IMAGE_REPO=\"$GEN_DOCKERFILE_PUSH_URL\"" || return 1
  __replace_line_in_file "$dockerfile" '^LABEL org[.]opencontainers[.]image[.]url=' "LABEL org.opencontainers.image.url=\"$GEN_DOCKERFILE_HUB_REPO\"" || true
  __replace_line_in_file "$dockerfile" '^LABEL org[.]opencontainers[.]image[.]source=' "LABEL org.opencontainers.image.source=\"$GEN_DOCKERFILE_HUB_REPO\"" 1 || true
  __replace_line_in_file "$dockerfile" '^LABEL org[.]opencontainers[.]image[.]source=' "LABEL org.opencontainers.image.source=\"$GEN_DOCKERFILE_GIT_REPO\"" 2 || true
  __replace_line_in_file "$dockerfile" '^LABEL org[.]opencontainers[.]image[.]documentation=' "LABEL org.opencontainers.image.documentation=\"$GEN_DOCKERFILE_GIT_REPO\"" || true
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__migrate_env_script() {
  local env_file="" env_dockerfile="" env_image_tag="" env_use_template="" env_git_repo_url="" env_registry_repo="" env_registry_push=""
  local env_registry_url="" env_registry_org=""
  shopt -s nullglob
  for env_file in "$GEN_DOCKERFILE_CWD/.env.scripts" "$GEN_DOCKERFILE_CWD/.env.scripts".*; do
    [ -f "$env_file" ] || continue
    grep -qE '^(ENV_HUB_BASE|ENV_IMAGE_PUSH|ENV_IMAGE_NAME|ENV_ORG_NAME)=' "$env_file" || continue
    __reset_env_script_vars
    . "$env_file"
    env_dockerfile="${ENV_DOCKERFILE:-Dockerfile}"
    env_image_tag="${ENV_IMAGE_TAG:-}"
    env_use_template="${ENV_USE_TEMPLATE:-}"
    env_git_repo_url="${ENV_GIT_REPO_URL:-}"
    env_registry_repo="${ENV_REGISTRY_REPO:-${ENV_IMAGE_NAME:-}}"
    env_registry_org="${ENV_REGISTRY_ORG:-${ENV_ORG_NAME:-}}"
    env_registry_url="${ENV_REGISTRY_URL:-${ENV_HUB_BASE:-}}"
    env_registry_push="${ENV_REGISTRY_PUSH:-${ENV_IMAGE_PUSH:-}}"
    __reset_env_script_vars
    ENV_DOCKERFILE="$env_dockerfile"
    ENV_IMAGE_TAG="$env_image_tag"
    ENV_USE_TEMPLATE="$env_use_template"
    ENV_GIT_REPO_URL="$env_git_repo_url"
    ENV_REGISTRY_REPO="$env_registry_repo"
    ENV_REGISTRY_ORG="$env_registry_org"
    ENV_REGISTRY_URL="$env_registry_url"
    ENV_REGISTRY_PUSH="$env_registry_push"
    GEN_DOCKERFILE_REGISTRY_PROVIDER_EXPLICIT="false"
    GEN_DOCKERFILE_SET_GIT_ORG=""
    GEN_DOCKERFILE_SET_REGISTRY_ORG=""
    GEN_DOCKERFILE_SET_GIT_REPO=""
    GEN_DOCKERFILE_SET_REGISTRY_REPO=""
    GEN_DOCKERFILE_SET_GIT_REPO_URL=""
    GEN_DOCKERFILE_SET_REGISTRY_URL=""
    [ -n "$env_use_template" ] && GEN_DOCKERFILE_TEMPLATE="$env_use_template"
    [ -n "$env_image_tag" ] && GEN_DOCKERFILE_DEFAULT_VERSION="$env_image_tag" && GEN_DOCKERFILE_SET_VERSION="$env_image_tag"
    [ -n "$env_git_repo_url" ] && GEN_DOCKERFILE_SET_GIT_REPO_URL="$env_git_repo_url"
    [ -n "$env_registry_url" ] && GEN_DOCKERFILE_SET_REGISTRY_URL="$env_registry_url"
    __sync_repo_setting_aliases
    __set_make_file_variables "$GEN_DOCKERFILE_CWD/$env_dockerfile" "${GEN_DOCKERFILE_SET_REGISTRY_REPO:-${env_registry_repo:-$(basename -- "$GEN_DOCKERFILE_CWD")}}" "$env_git_repo_url"
    __set_variables
    printf_blue "Migrating $(basename -- "$env_file") to ENV_REGISTRY_*"
    __write_env_file "$env_file" || return 1
  done
  shopt -u nullglob
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__update_generated_files() {
  local env_file="" env_dockerfile="" env_image_tag="" env_use_template="" env_git_repo_url="" env_registry_repo="" updated_count=0
  shopt -s nullglob
  for env_file in "$GEN_DOCKERFILE_CWD/.env.scripts" "$GEN_DOCKERFILE_CWD/.env.scripts".*; do
    [ -f "$env_file" ] || continue
    __reset_env_script_vars
    . "$env_file"
    env_dockerfile="${ENV_DOCKERFILE:-Dockerfile}"
    env_image_tag="${ENV_IMAGE_TAG:-}"
    env_use_template="${ENV_USE_TEMPLATE:-}"
    env_registry_repo="${ENV_REGISTRY_REPO:-}"
    env_git_repo_url="${GEN_DOCKERFILE_SET_GIT_REPO_URL:-}"
    if [ -z "$GEN_DOCKERFILE_SET_GIT_ORG$GEN_DOCKERFILE_SET_GIT_REPO$GEN_DOCKERFILE_SET_GIT_REPO_URL" ]; then
      env_git_repo_url="${env_git_repo_url:-${ENV_GIT_REPO_URL:-}}"
    fi
    [ -n "$env_use_template" ] && GEN_DOCKERFILE_TEMPLATE="$env_use_template"
    [ -n "$env_image_tag" ] && GEN_DOCKERFILE_DEFAULT_VERSION="$env_image_tag" && GEN_DOCKERFILE_SET_VERSION="$env_image_tag"
    [ -n "$env_git_repo_url" ] && GEN_DOCKERFILE_SET_GIT_REPO_URL="$env_git_repo_url"
    __sync_repo_setting_aliases
    __set_make_file_variables "$GEN_DOCKERFILE_CWD/$env_dockerfile" "${GEN_DOCKERFILE_SET_REGISTRY_REPO:-${env_registry_repo:-$(basename -- "$GEN_DOCKERFILE_CWD")}}" "$env_git_repo_url"
    __set_variables
    printf_blue "Updating ${env_dockerfile} using $(basename -- "$env_file")"
    __update_env_file_in_place "$env_file" || return 1
    __update_dockerfile_in_place "$GEN_DOCKERFILE_CWD/$env_dockerfile" || return 1
    updated_count=$((updated_count + 1))
  done
  shopt -u nullglob
  [ "$updated_count" -gt 0 ] || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__execute_gen_dockerfile() {
  if [ $# -lt 3 ]; then
    export name="$(basename -- "$GEN_DOCKERFILE_CWD")"
    __docker_file "${1:-$GEN_DOCKERFILE_CWD/Dockerfile}" "$name" ${2:-}
  elif [ $# -eq 3 ]; then
    __docker_file "$1" "$2" ${3:-}
  else
    printf_red "Usage: [Dockerfile] [name] [gitRepo]"
    printf_exit "IE: ./Dockerfile alpine https://github.com/[orgname]/[reponame]"
  fi
  echo ""
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__docker_file() {
  dotenv_file=""
  build_date="$(date +"${BUILDX_BUILD_DATE_FORMAT:-%Y%m%d%H%M}")"
  if [ -z "$GEN_DOCKERFILE_SET_VERSION" ]; then
    dotenv_file="$GEN_DOCKERFILE_CWD/.env.scripts"
  elif [ "$GEN_DOCKERFILE_SET_VERSION" != "latest" ]; then
    dotenv_file="$GEN_DOCKERFILE_CWD/.env.scripts.$GEN_DOCKERFILE_SET_VERSION"
  else
    dotenv_file="$GEN_DOCKERFILE_CWD/.env.scripts"
  fi
  __set_make_file_variables "$@"
  if [ "$GEN_DOCKER_INIT" != "true" ]; then
    if [ -f "$GEN_DOCKERFILE_CWD/rootfs/usr/local/etc/docker/functions/entrypoint.sh" ]; then
      GEN_DOCKER_ONLY_DOCKERFILE="true"
      GEN_DOCKER_INIT=""
    fi
  fi
  if [ -f "$GEN_DOCKERFILE_CWD/.env.scripts.${file_version:-latest}" ]; then
    printf_cyan "Setting version to ${file_version:-latest}"
    if [ -f "$GEN_DOCKERFILE_CWD/.env.scripts.${file_version:-latest}" ]; then
      . "$GEN_DOCKERFILE_CWD/.env.scripts.${file_version:-latest}"

    fi
    if [ "$GEN_DOCKERFILE_FORCE" = "yes" ]; then
      GEN_DOCKER_INIT=true
      GEN_DOCKER_ONLY_DOCKERFILE=false
      __rm_rf "$GEN_DOCKERFILE_CWD"/*
    fi

    __set_variables
    __set_make_file_variables "$@"
  elif [ -f "$dotenv_file" ]; then
    [ -f "$dotenv_file" ] && . "$dotenv_file"
    __set_variables
    __set_make_file_variables "$@"
  fi
  [ -d "$rootfs_dir" ] || GEN_DOCKER_ONLY_DOCKERFILE=false
  [ -n "$file_version" ] && GEN_DOCKERFILE_DEFAULT_VERSION="$file_version"
  GEN_DOCKERFILE_SET_VERSION="${GEN_DOCKERFILE_DEFAULT_VERSION}"
  GEN_DOCKERFILE_SET_DISTRO_VERSION="${GEN_DOCKERFILE_DEFAULT_DISTRO_VERSION:-$GEN_DOCKERFILE_SET_DISTRO_VERSION}"
  GEN_DOCKERFILE_SET_TAGS="$(printf '%s\n' "$GEN_DOCKERFILE_SET_TAGS" "$GEN_DOCKERFILE_DEFAULT_VERSION" "$GEN_DOCKERFILE_DEFAULT_TAGS" | tr ' ' '\n' | sort -urV | grep -vE '^$|^USE_DATE$' | tr '\n' ' ')"
  GEN_DOCKER_USE_DATE_TAG="$(printf '%s\n' "$GEN_DOCKERFILE_SET_TAGS" "$GEN_DOCKERFILE_DEFAULT_VERSION" "$GEN_DOCKERFILE_DEFAULT_TAGS" | tr ' ' '\n' | sort -u | grep -x 'USE_DATE' | head -n1)"
  # Rewite dockerfile to version number
  if [ -n "$file_version" ] && [[ "$file" != *Dockerfile* ]] && [[ "$file" == *"$file_version"* ]]; then
    file="Dockerfile"
    is_file_versioned="false"
  fi
  [ -n "$file_version" ] && [ "$is_file_versioned" = "false" ] && file="$file.$file_version" && dotenv_file="$GEN_DOCKERFILE_CWD/.env.scripts.$file_version"
  GEN_DOCKERFILE_DOCKERFILE_NAME="$(basename -- "$file")"
  # begin
  local tag_name="${GEN_DOCKERFILE_SET_TAGS:-latest} $GEN_DOCKER_USE_DATE_TAG"
  # if [ "$GEN_DOCKER_INIT" = "true" ]; then
  # GEN_DOCKER_AUTOMATED="true"
  # init_message="Initializing $name in: ${GEN_DOCKERFILE_CWD//$PWD\//}"
  # else
  # init_message="Initialize $name in: ${file//$PWD\//}"
  # fi
  # if [ "$GEN_DOCKER_AUTOMATED" != "true" ]; then
  # [ -f "$file" ] && printf_pause "If this is what you want press enter or control-c to exit"
  # fi
  # Init Dockerfile functions
  __configure_dockerfile "$name"
  #
  [ -n "$GEN_DOCKERFILE_SET_DISTRO_NAME" ] || GEN_DOCKERFILE_SET_DISTRO_NAME="$GEN_DOCKERFILE_PULL_URL"
  [ -f "$dotenv_file" ] && printf_blue "Updating $dotenv_file" || printf_purple "Creating $dotenv_file"
  __write_env_file "$dotenv_file"
  [ "$GEN_DOCKER_INIT" != "true" ] || [ ! -f "$rootfs_dir/usr/local/bin/entrypoint.sh" ] || return
  . "$dotenv_file" && __set_variables && repo="${GEN_DOCKERFILE_GIT_REPO:-$repo}"
  if [ -f "$rootfs_dir/usr/local/bin/entrypoint.sh" ] && [ -f "$file.$GEN_DOCKERFILE_BACKUP_EXT" ]; then
    printf_cyan "Generating your Dockerfile using template: $GEN_DOCKERFILE_TEMPLATE"
    if __make_file "$GEN_DOCKERFILE_TEMPLATE" "$file"; then
      __update_env_file_in_place "$dotenv_file" || exit 1
      __update_dockerfile_in_place "$file" || exit 1
      printf_green "Your Dockerfile for $name has been created in: $(readlink -f "$GEN_DOCKERFILE_CWD")"
      exit 0
    else
      printf_green "Failed to create Dockerfile for $name"
      exit 1
    fi
  elif [ "$GEN_DOCKERFILE_TEMPLATE" = "scratch" ]; then
    if [ "$GEN_DOCKER_INIT" != "true" ]; then
      if __make_file "$GEN_DOCKERFILE_TEMPLATE" "$file"; then
        __update_env_file_in_place "$dotenv_file" || exit 1
        __update_dockerfile_in_place "$file" || exit 1
        printf_green "Your Dockerfile for $name has been created in: $(readlink -f "$GEN_DOCKERFILE_CWD")"
      else
        printf_green "Failed to create Dockerfile for $name"
        exit 1
      fi
    fi
    # Create actions file
    printf_blue "Creating $GEN_DOCKERFILE_CWD/.gitea/workflows/docker.yaml"
    [ -d "$GEN_DOCKERFILE_CWD/.gitea/workflows" ] || mkdir -p "$GEN_DOCKERFILE_CWD/.gitea/workflows"
    __create_actions_file >"$GEN_DOCKERFILE_CWD/.gitea/workflows/docker.yaml"
    # Create pkmgr script
    printf_blue "Creating $rootfs_dir/usr/local/bin/pkmgr"
    [ -d "$rootfs_dir/usr/local/bin" ] || mkdir -p "$rootfs_dir/usr/local/bin"
    __create_pkmgr_install_script >"$rootfs_dir/usr/local/bin/pkmgr"
    chmod -Rf 755 "$rootfs_dir/usr/local/bin/pkmgr"
    # Run git
    __init_git
    [ -f "$dotenv_file" ] && exit 0 || exit 1
  else
    printf_cyan "Generating your Dockerfile using template: $GEN_DOCKERFILE_TEMPLATE"
    __make_file "$GEN_DOCKERFILE_TEMPLATE" "$file"
    if [ -f "$file" ]; then
      __update_env_file_in_place "$dotenv_file" || exit 1
      __update_dockerfile_in_place "$file" || exit 1
      printf_green "Your Dockerfile for $name has been created in: $(readlink -f "$file")"
      # Create directories
      if [ "$GEN_DOCKER_ONLY_DOCKERFILE" != "true" ]; then
        for create_dir in $make_directories; do
          printf_purple "Creating Directory: ${create_dir//$GEN_DOCKERFILE_CWD\//}"
          mkdir -p "$create_dir"
        done
        # create functions file
        printf_blue "Creating global functions file"
        [ -d "$rootfs_dir/usr/local/etc/docker/functions" ] || mkdir -p "$rootfs_dir/usr/local/etc/docker/functions"
        cp -Rf "$CASJAYSDEVDIR/templates/scripts/functions/docker-entrypoint" "$rootfs_dir/usr/local/etc/docker/functions/entrypoint.sh" &>/dev/null
        if [ -f "$rootfs_dir/usr/local/etc/docker/functions/entrypoint.sh" ]; then
          printf_cyan "Created $rootfs_dir/usr/local/etc/docker/functions/entrypoint.sh"
        fi
        # Create actions file
        printf_blue "Creating $GEN_DOCKERFILE_CWD/.gitea/workflows/docker.yaml"
        [ -d "$GEN_DOCKERFILE_CWD/.gitea/workflows" ] || mkdir -p "$GEN_DOCKERFILE_CWD/.gitea/workflows"
        __create_actions_file >"$GEN_DOCKERFILE_CWD/.gitea/workflows/docker.yaml"
        # Create pkmgr script
        printf_blue "Creating $rootfs_dir/usr/local/bin/pkmgr"
        [ -d "$rootfs_dir/usr/local/bin" ] || mkdir -p "$rootfs_dir/usr/local/bin"
        __create_pkmgr_install_script >"$rootfs_dir/usr/local/bin/pkmgr"
        chmod -Rf 755 "$rootfs_dir/usr/local/bin/pkmgr"
        # Create entrypoint script
        printf_blue "Creating $rootfs_dir/usr/local/bin/entrypoint.sh"
        if [ -f "$rootfs_dir/usr/local/bin/entrypoint.sh" ]; then
          printf_yellow "Found existing entrypoint... ${GREEN}Backing up${NC}"
          mv -f "$rootfs_dir/usr/local/bin/entrypoint.sh" "$rootfs_dir/usr/local/bin/entrypoint.sh.$GEN_DOCKERFILE_BACKUP_EXT"
        fi
        if GEN_SCRIPT_EDITFILE="N" gen-script other docker-entrypoint --name "$name" --dir "$rootfs_dir/usr/local/bin" "entrypoint.sh" &>/dev/null; then
          printf_green "Created the entrypoint script"
        else
          printf_red "Failed to create the entrypoint script"
        fi
        # create custom init files
        __custom_init_files
        # create env files
        mkdir -p "$shared_dir/template-files/config/env/examples"
        __create_env "$shared_dir/template-files/config/env/default.sample"
        if [ -d "$CASJAYSDEVDIR/templates/env/docker" ]; then
          printf_yellow "Copying enviroment files to $shared_dir/template-files/config/env/examples/$name"
          for env_file in "$CASJAYSDEVDIR/templates/env/docker"/*; do
            if [ -f "$env_file" ]; then
              name="$(basename -- "$env_file")"
              if ! cp -Rf "$env_file" "$shared_dir/template-files/config/env/examples" |& __devnull; then
                printf_red "Failed to copy $name to $shared_dir/template-files/config/env/examples/$name"
              fi
            fi
          done
        fi
        # create init dir
        printf_cyan "Creating $init_dir dir"
        [ -d "$init_dir" ] || mkdir -p "$init_dir"
        # Make sure git keeps empty directories
        touch "$template_dir/data/.gitkeep"
        touch "$template_dir/config/.gitkeep"
        touch "$template_dir/defaults/.gitkeep"
        # create .gitignore
        __init_git
      fi
      exitCode=$?
    else
      printf_red "Failed to create Dockerfile for $name in $GEN_DOCKERFILE_CWD"
      exitCode=1
    fi
  fi
  [ -f "$tmpFile" ] && rm -Rf "$tmpFile"
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__make_file() {
  template="${1,,}"
  GEN_DOCKERFILE_TEMPLATE="$template"
  case "$template" in
  alpine)
    shift 1
    __alpine_file "$1"
    ;;

  arch | archlinux)
    shift 1
    __arch_file "$1"
    ;;

  debian)
    shift 1
    __debian_file "$1"
    ;;

  ubuntu)
    shift 1
    __ubuntu_file "$1"
    ;;

  rhel | rockylinux | almalinux | oraclelinux | redhat | centos)
    shift 1
    __almalinux "$1"
    ;;

  web)
    shift 1
    __web "$1"
    ;;

  xorg)
    shift 1
    __xorg "$1"
    ;;

  scratch)
    shift 1
    __scratch "$1"
    ;;

  *)
    __alpine_file "${2:-$1}"
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__create_start_script() {
  local script_filename="$(basename -- "$1")"
  local rootfs_dir="${dir:-${GEN_DOCKERFILE_CWD:-$PWD}}/rootfs"
  local init_dir="${init_dir:-$rootfs_dir/usr/local/etc/docker/init.d}"
  local script_file="$init_dir/$script_filename"
  local mess="startup script"
  [ "$script_filename" = "service.sample" ] && mess="example start script"
  printf_cyan "Creating the $mess for $script_file"
  [ -d "$init_dir" ] || mkdir -p "$init_dir"
  GEN_SCRIPT_EDITFILE="N" gen-script other start-service --name "$script_filename" --dir "$init_dir" "$script_filename" #&>/dev/null
  [ -f "$script_file" ] && printf_cyan "Created $script_file"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__create_pkmgr_install_script() {
  . "$GEN_DOCKERFILE_TEMPLATE_DIR/pkmgr.template"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__create_actions_file() {
  name="${name:-$(__basename "$GEN_DOCKERFILE_CWD")}"
  . "$GEN_DOCKERFILE_TEMPLATE_DIR/actions.template"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__create_env() {
  . "$GEN_DOCKERFILE_TEMPLATE_DIR/envfile.template" >"$1"
  [ -f "$1" ] && printf_cyan "Created default env file in $1" || printf_red "failed to create $1"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__scratch() {
  Dfile="${1:-$file}"
  [ -n "$ENV_PACKAGES" ] && packages="$ENV_PACKAGES" || packages="${GEN_DOCKER_FILE_PKGS_ALL//,/ } "
  packages="$(__trim "$packages")"
  if [ -f "$GEN_DOCKERFILE_CONFIG_DIR/templates/scratch.template" ]; then
    __render_templates_to_file "$Dfile" "$GEN_DOCKERFILE_CONFIG_DIR/templates/scratch.template"
  else
    __render_templates_to_file "$Dfile" "$GEN_DOCKERFILE_TEMPLATE_DIR/scratch.template"
  fi
  [ -f "$Dfile" ] && return 0 || return 1

}
# - - - - - - - - - - - - - - - - - - - - - - - - -
