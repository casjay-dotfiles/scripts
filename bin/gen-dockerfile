# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker_file() {
  local name repo dir bak_ext="$$.bak"
  file="${1:-$GEN_DOCKERFILE_CWD/Dockerfile}"
  name="${2:-$(basename "$GEN_DOCKERFILE_CWD")}"
  repo="${3:-$GEN_DOCKERFILE_GIT_BASE/$name}"
  dir="${GEN_DOCKERFILE_CWD:-$(dirname "$file")}"
  rootfs_dir="$dir/rootfs"
  template_dir="$rootfs_dir/usr/local/share/template-files"
  make_directories="$dir $rootfs_dir/usr/local/bin $rootfs_dir $template_dir/config $template_dir/data $template_dir/defaults"
  GEN_DOCKERFILE_TEMPLATE="${GEN_DOCKERFILE_TEMPLATE:-alpine}"
  printf_yellow "This will create a new Dockerfile in $GEN_DOCKERFILE_CWD"
  if [ "$GEN_DOCKER_AUTOMATED" != "true" ]; then
    [ -f "$file" ] && printf_pause "If this is what you want press enter or control-c to exit"
  fi
  if [ -f "$file" ]; then
    printf_yellow "Found an existing Dockerfile at: $file"
    printf_cyan "Backing up to: $file.$bak_ext"
    mv -f "$file" "$file.$bak_ext"
  fi
  if [ -f "$rootfs_dir/usr/local/bin/entrypoint.sh" ] && [ -f "$file.$bak_ext" ]; then
    printf_purple "Generating your Dockerfile using template: $GEN_DOCKERFILE_TEMPLATE"
    if __make_file "$GEN_DOCKERFILE_TEMPLATE" "$file"; then
      printf_green "Your Dockerfile for $name has been created in: $(readlink -f "$dir")"
      exit 0
    else
      printf_green "Failed to create Dockerfile for $name"
      exit 1
    fi
  else
    printf_purple "Generating your Dockerfile using template: $GEN_DOCKERFILE_TEMPLATE"
    __make_file "$GEN_DOCKERFILE_TEMPLATE" "$file"
    if [ -f "$file" ]; then
      printf_green "Your Dockerfile for $name has been created in: $(readlink -f "$dir")"
      if [ "$GEN_DOCKER_ONLY_DOCKERFILE" != "true" ]; then
        for create_dir in $make_directories; do
          printf_purple "Creating Directory: ${create_dir//$dir\//}"
          mkdir -p "$create_dir" && touch "$create_dir/.gitkeep"
        done
        # Create entrypoint script
        printf_blue "Creating $rootfs_dir/usr/local/bin/entrypoint.sh"
        if [ -f "$rootfs_dir/usr/local/bin/entrypoint.sh" ]; then
          printf_yellow "Found existing entrypoint... ${GREEN}Backing up${NC}"
          mv -f "$rootfs_dir/usr/local/bin/entrypoint.sh" "$rootfs_dir/usr/local/bin/entrypoint.sh.$bak_ext"
        fi
        if GEN_SCRIPT_EDITFILE="N" gen-script --name "$name" other docker-entrypoint "$rootfs_dir/usr/local/bin/entrypoint.sh" &>/dev/null; then
          printf_green "Created the entrypoint script"
        else
          printf_red "Failed to create the entrypoint script"
        fi
        # Create start-service script
        printf_blue "Creating $rootfs_dir/usr/local/bin/start-$name.sh"
        if [ -f "$rootfs_dir/usr/local/bin/start-$name.sh" ]; then
          printf_yellow "Found existing start-$name script... ${GREEN}Backing up${NC}"
          mv -f "$rootfs_dir/usr/local/bin/start-$name.sh" "$rootfs_dir/usr/local/bin/start-$name.sh.$bak_ext"
        fi
        if GEN_SCRIPT_EDITFILE="N" gen-script --name "$name" other start-service "$rootfs_dir/usr/local/bin/start-$name.sh" &>/dev/null; then
          sed -i 's|REPLACE_SERVICE_NAME|'$name'|g' "$rootfs_dir/usr/local/bin/start-$name.sh"
          printf_green "Created the start script"
        else
          printf_red "Failed to create the start-$name script"
        fi
        # Create .dockerignore README.md LICENSE.md and directories
        __dockerignore
        [ -f "$dir/README.md" ] || gen-readme projects docker.md "$dir/README.md"
        [ -f "$dir/LICENSE.md" ] || gen-license wtfpl "$dir/LICENSE.md"
        printf_green "Using $repo as VCS url"
        if [ -d "$rootfs_dir/usr/local/bin" ] && [ -d "$template_dir/data" ] && [ -d "$template_dir/config" ]; then
          printf_blue "All files and Directories have been created"
          if [ "$GEN_DOCKER_GIT_AUTO_INIT" = "yes" ]; then
            if [ ! -d "$dir/.git" ] && [ ! -f "$dir/.nogit" ]; then
              if [ "$GEN_DOCKER_AUTOMATED" = "true" ]; then
                gitignore "$dir" default --automated
                gitadmin --dir "$dir" setup "$repo" --automated
              else
                [ -f "$dir/.gitignore" ] || gitignore "$dir" default
                gitadmin --dir "$dir" setup "$repo"
              fi
            fi
          fi
        fi
      fi
      exitCode=$?
    else
      printf_red "Failed to create Dockerfile for $name in $dir"
      exitCode=1
    fi
  fi
  printf '\n'
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__execute_gen_dockerfile() {
  if [ $# -lt 3 ]; then
    name="$(basename "$GEN_DOCKERFILE_CWD")"
    __docker_file "${1:-$GEN_DOCKERFILE_CWD/Dockerfile}" "$name" "${2:-$1}"
  elif [ $# -eq 3 ]; then
    __docker_file "$1" "$2" ${3:-$GEN_DOCKERFILE_GIT_BASE}
  else
    printf_red "Usage: [Dockerfile] [name] [gitRepoBase]"
    printf_exit "IE: ./Dockerfile alpine https://github.com/casjaysdevdocker"
  fi
  return $exitCode
}
