}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__configure_dockerfile() {
  name="${1:-$GEN_DOCKERFILE_TEMPLATE}"
  printf_yellow "Initializing $name in: ${GEN_DOCKERFILE_CWD//$PWD\//}"
  printf_blue "Setting the tag[s] to: $tag_name"
  if [ -f "$file" ] && [ -f "$file.$GEN_DOCKERFILE_BACKUP_EXT" ]; then
    printf_yellow "Found an existing Dockerfile at: $file"
    printf_cyan "Backing up to: $file.$date.$GEN_DOCKERFILE_BACKUP_EXT"
    mv -f "$file.bak" "$file.$date.$GEN_DOCKERFILE_BACKUP_EXT"
    mv -f "$file" "$file.$GEN_DOCKERFILE_BACKUP_EXT"
  elif [ -f "$file" ]; then
    printf_yellow "Found an existing Dockerfile at: $file"
    printf_cyan "Backing up to: $file.$GEN_DOCKERFILE_BACKUP_EXT"
    mv -f "$file" "$file.$GEN_DOCKERFILE_BACKUP_EXT"
  fi
  # - - - - - - - - - - - - - - - - - - - - - - - - -
  __set_variables
  # - - - - - - - - - - - - - - - - - - - - - - - - -
  [ -f "$GEN_DOCKERFILE_TEMPLATE_DIR/template_options.source" ] && . "$GEN_DOCKERFILE_TEMPLATE_DIR/template_options.source" && printf_yellow "Setting options from: $GEN_DOCKERFILE_TEMPLATE_DIR/template_options.source"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__set_variables() {
  local has_explicit_registry_override="false" has_explicit_git_override="false" push_path="" env_registry_host=""
  __sync_repo_setting_aliases
  [ -n "$GEN_DOCKERFILE_SET_REGISTRY_ORG" ] && has_explicit_registry_override="true"
  [ -n "$GEN_DOCKERFILE_SET_REGISTRY_REPO" ] && has_explicit_registry_override="true"
  [ -n "$GEN_DOCKERFILE_SET_GIT_ORG" ] && has_explicit_git_override="true"
  [ -n "$GEN_DOCKERFILE_SET_GIT_REPO" ] && has_explicit_git_override="true"
  [ -n "$GEN_DOCKERFILE_SET_GIT_REPO_URL" ] && has_explicit_git_override="true"
  # Set variables from .env.scripts file
  [ -n "$ENV_PACKAGES" ] && packages="$ENV_PACKAGES"
  [ -n "$ENV_VENDOR" ] && GEN_DOCKERFILE_VENDOR="$ENV_VENDOR"
  [ -n "$ENV_AUTHOR" ] && GEN_DOCKERFILE_AUTHOR="$ENV_AUTHOR"
  [ -n "$ENV_REGISTRY_URL" ] && [ -z "$GEN_DOCKERFILE_SET_REGISTRY_URL" ] && GEN_DOCKERFILE_SET_REGISTRY_URL="$ENV_REGISTRY_URL"
  [ -n "$GEN_DOCKERFILE_REGISTRY_URL" ] || GEN_DOCKERFILE_REGISTRY_URL="$GEN_DOCKERFILE_HUB_BASE"
  [ -n "$GEN_DOCKERFILE_REGISTRY_URL" ] || GEN_DOCKERFILE_REGISTRY_URL="https://docker.io"
  GEN_DOCKERFILE_HUB_BASE="$GEN_DOCKERFILE_REGISTRY_URL"
  [ -n "$ENV_MAINTAINER" ] && GEN_DOCKERFILE_MAINTAINER="$ENV_MAINTAINER"
  [ -n "$ENV_ADD_TAGS" ] && GEN_DOCKERFILE_SET_TAGS="$ENV_ADD_TAGS" || GEN_DOCKERFILE_SET_TAGS="$GEN_DOCKERFILE_DEFAULT_TAGS"
  [ -n "$ENV_USE_TEMPLATE" ] && GEN_DOCKERFILE_TEMPLATE="$ENV_USE_TEMPLATE" || GEN_DOCKERFILE_TEMPLATE="$GEN_DOCKERFILE_DEFAULT_TEMPLATE"
  __normalize_registry_provider "${GEN_DOCKERFILE_SET_REGISTRY_URL:-${GEN_DOCKERFILE_REGISTRY_URL:-docker.io}}"
  __resolve_repo_settings
  if [ -n "$ENV_REGISTRY_PUSH" ] && [ "$has_explicit_registry_override" != "true" ]; then
    push_path="$(__strip_registry_provider "$ENV_REGISTRY_PUSH")"
    env_registry_host="$(__registry_host_from_ref "$ENV_REGISTRY_PUSH" 2>/dev/null || true)"
    [ -n "$env_registry_host" ] && [ -z "$GEN_DOCKERFILE_SET_REGISTRY_URL" ] && __normalize_registry_provider "$env_registry_host"
  else
    push_path="${GEN_DOCKERFILE_DEFAULT_IMAGE:-$GEN_DOCKERFILE_RESOLVED_REGISTRY_REPO}"
  fi
  [ -n "$ENV_IMAGE_TAG" ] && GEN_DOCKERFILE_SET_VERSION="$ENV_IMAGE_TAG" || GEN_DOCKERFILE_SET_VERSION="${GEN_DOCKERFILE_DEFAULT_VERSION:-latest}"
  if [ -n "$ENV_REGISTRY_ORG" ] && [ "$has_explicit_registry_override" != "true" ]; then
    GEN_DOCKERFILE_SET_ORG="$ENV_REGISTRY_ORG"
  else
    GEN_DOCKERFILE_SET_ORG="${GEN_DOCKERFILE_RESOLVED_ORG:-$GEN_DOCKERFILE_DEFAULT_REGISTRY_ORG}"
  fi
  [ -n "$ENV_DISTRO_TAG" ] && GEN_DOCKERFILE_SET_DISTRO_VERSION="$ENV_DISTRO_TAG" || GEN_DOCKERFILE_SET_DISTRO_VERSION="$GEN_DOCKERFILE_DEFAULT_DISTRO_VERSION"
  [ -n "$ENV_PULL_URL" ] && GEN_DOCKERFILE_SET_DISTRO_NAME="$ENV_PULL_URL" || GEN_DOCKERFILE_SET_DISTRO_NAME="${GEN_DOCKERFILE_DEFAULT_DISTRO_NAME_SOURCE:-$GEN_DOCKERFILE_DEFAULT_DISTRO_NAME}"
  # - - - - - - - - - - - - - - - - - - - - - - - - -
  # Actions based on env
  [ -n "$GEN_DOCKERFILE_SET_BUILD" ] || GEN_DOCKERFILE_SET_BUILD='${IMAGE_VERSION}'
  [ -n "$GEN_DOCKERFILE_SET_DISTRO_VERSION" ] || GEN_DOCKERFILE_SET_DISTRO_VERSION='${IMAGE_VERSION}'
  [ -z "$GEN_DOCKERFILE_SET_TAGS" ] || GEN_DOCKERFILE_SET_TAGS="$(__trim "${GEN_DOCKERFILE_SET_TAGS//,/ }")"
  [[ "$push_path" == */* ]] || push_path="${GEN_DOCKERFILE_SET_ORG:-$GEN_DOCKERFILE_DEFAULT_REGISTRY_ORG}/$push_path"
  GEN_DOCKERFILE_PUSH_URL="$push_path"
  if [ "$GEN_DOCKERFILE_REGISTRY_PROVIDER_EXPLICIT" = "true" ] || [ "$GEN_DOCKERFILE_REGISTRY_HOST" != "docker.io" ]; then
    GEN_DOCKERFILE_PUSH_URL="${GEN_DOCKERFILE_REGISTRY_HOST}/$push_path"
  fi
  # - - - - - - - - - - - - - - - - - - - - - - - - -
  if [ "$has_explicit_git_override" = "true" ]; then
    GEN_DOCKERFILE_GIT_REPO="${GEN_DOCKERFILE_RESOLVED_GIT_REPO:-$GEN_DOCKERFILE_GIT_REPO}"
  else
    [ -n "$GEN_DOCKERFILE_GIT_REPO" ] || GEN_DOCKERFILE_GIT_REPO="${GEN_DOCKERFILE_RESOLVED_GIT_REPO:-$GEN_DOCKERFILE_GIT_BASE/$GEN_DOCKERFILE_DEFAULT_GIT_ORG/$(basename -- "$GEN_DOCKERFILE_RESOLVED_GIT_REPO_NAME")}"
  fi
  GEN_DOCKERFILE_HUB_REPO="$GEN_DOCKERFILE_HUB_BASE/$push_path"
  # - - - - - - - - - - - - - - - - - - - - - - - - -
  GEN_DOCKERFILE_SET_ORG="$(__lower "$GEN_DOCKERFILE_SET_ORG")"
  GEN_DOCKERFILE_PUSH_URL="$(__lower "$GEN_DOCKERFILE_PUSH_URL")"
  GEN_DOCKERFILE_SET_VERSION="$(__lower "$GEN_DOCKERFILE_SET_VERSION")"
  GEN_DOCKERFILE_PULL_URL="$(__lower "${GEN_DOCKERFILE_SET_DISTRO_NAME:-casjaysdev/$GEN_DOCKERFILE_TEMPLATE}")"
  if [ "$has_explicit_git_override" = "true" ]; then
    GEN_DOCKERFILE_GIT_REPO="$(__lower "$GEN_DOCKERFILE_GIT_REPO")"
  else
    GEN_DOCKERFILE_GIT_REPO="$(__lower "${ENV_GIT_REPO_URL:-$GEN_DOCKERFILE_GIT_REPO}")"
  fi
  GEN_DOCKERFILE_REGISTRY_URL="$(__lower "$GEN_DOCKERFILE_REGISTRY_URL")"
  GEN_DOCKERFILE_HUB_BASE="$GEN_DOCKERFILE_REGISTRY_URL"
  GEN_DOCKERFILE_HUB_REPO="$(__lower "$GEN_DOCKERFILE_HUB_REPO")"
  # - - - - - - - - - - - - - - - - - - - - - - - - -
  GEN_DOCKER_FILE_EXPOSE_PORTS="$(printf '%s\n' "$GEN_DOCKER_FILE_EXPOSE_PORTS+" | tr ' ' '\n' | sort -uV | grep -v '^$' | tr '\n' ',')"
  GEN_DOCKER_FILE_EXPOSE_PORTS="${GEN_DOCKER_FILE_EXPOSE_PORTS//,/ }"
  return
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__set_make_file_variables() {
  local input_repo="${3:-}"
  date="$(date +'%Y%m%d%H%M')"
  file="${1:-$GEN_DOCKERFILE_CWD/Dockerfile}"
  [ -n "$ENV_REGISTRY_REPO" ] && name="$ENV_REGISTRY_REPO" || name="${2:-$(basename -- "$GEN_DOCKERFILE_CWD")}"
  [ -n "$GEN_DOCKERFILE_SET_REGISTRY_REPO" ] && name="$GEN_DOCKERFILE_SET_REGISTRY_REPO"
  [ -n "$GEN_DOCKERFILE_DEFAULT_VERSION" ] && version="$GEN_DOCKERFILE_DEFAULT_VERSION" || version="$GEN_DOCKERFILE_SET_VERSION"
  file="$(realpath "${ENV_DOCKERFILE:-$file}")"
  repo="${ENV_GIT_REPO_URL:-$input_repo}"
  GEN_DOCKERFILE_SET_GIT_REPO_URL="${GEN_DOCKERFILE_SET_GIT_REPO_URL:-$input_repo}"
  __sync_repo_setting_aliases
  tmpFile="$GEN_DOCKERFILE_CWD/init.$$"
  rootfs_dir="$GEN_DOCKERFILE_CWD/rootfs"
  shared_dir="$rootfs_dir/usr/local/share"
  template_dir="$shared_dir/template-files"
  custom_init_dir="$rootfs_dir/root/docker/setup"
  init_dir="$rootfs_dir/usr/local/etc/docker/init.d"
  GEN_DOCKERFILE_TEMPLATE="${GEN_DOCKERFILE_TEMPLATE:-alpine}"
  __resolve_repo_settings
  make_directories="$GEN_DOCKERFILE_CWD $rootfs_dir $shared_dir $template_dir/config $template_dir/data $template_dir/defaults"
  file_version="$(printf '%s\n' "$version" | grep -v 'latest' | sed 's|[a-zA-Z]||g;s|^ ||g' | awk '{print $1}' | sed 's| ||g' | grep '[a-z]')"
  file_version_is_named="$(printf '%s\n' "$version" | grep -v 'latest' | tr '[:upper:]' '[:lower:]' | awk '{print $1}' | sed 's| ||g' | grep '[0-9a-z]')"
  [ -n "$file_version_is_named" ] && [ -z "$file_version" ] && file_version="$file_version_is_named"
  is_file_versioned="true"
  [ -n "$file_version" ] && [[ "$file" != *"$file_version"* ]] && is_file_versioned="false"
  repo="$GEN_DOCKERFILE_RESOLVED_GIT_REPO"
  IMAGE_REPO="${GEN_DOCKERFILE_HUB_BASE//http*:\/\//}"
}
