# output version
__version() { printf_cyan "$VERSION"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__normalize_cli_args() {
  GEN_DOCKERFILE_NORMALIZED_ARGS=()
  while [ $# -gt 0 ]; do
    case "$1" in
    --user | --org | --repo)
      local flag="$1"
      shift 1
      if [ $# -ge 2 ] && [[ "$1" =~ ^(git|reg|registry)$ ]] && [[ "$2" != -* ]]; then
        GEN_DOCKERFILE_NORMALIZED_ARGS+=("$flag" "$1:$2")
        shift 2
      elif [ $# -ge 1 ]; then
        GEN_DOCKERFILE_NORMALIZED_ARGS+=("$flag" "$1")
        shift 1
      else
        GEN_DOCKERFILE_NORMALIZED_ARGS+=("$flag")
      fi
      ;;
    *)
      GEN_DOCKERFILE_NORMALIZED_ARGS+=("$1")
      shift 1
      ;;
    esac
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  local options="${2//:/}"
  printf_color "$1: " "$5"
  printf '%s' "${options//$3/ $4}"
  printf_newline
}
