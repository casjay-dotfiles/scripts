#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version           :  202207061337-git
# @Author            :  Jason Hempstead
# @Contact           :  jason@casjaysdev.com
# @License           :  WTFPL
# @ReadME            :  gen-dockerfile --help
# @Copyright         :  Copyright: (c) 2022 Jason Hempstead, Casjays Developments
# @Created           :  Wednesday, Jul 06, 2022 13:37 EDT
# @File              :  gen-dockerfile
# @Description       :  Create a Dockerfile
# @TODO              :
# @Other             :
# @Resource          :
# @sudo/root         :  no
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202207061337-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 90
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE"
  [ -d "$GEN_DOCKERFILE_CONFIG_DIR" ] || mkdir -p "$GEN_DOCKERFILE_CONFIG_DIR"
  [ -d "$GEN_DOCKERFILE_CONFIG_BACKUP_DIR" ] || mkdir -p "$GEN_DOCKERFILE_CONFIG_BACKUP_DIR"
  [ -f "$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE" ] &&
    cp -Rf "$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE" "$GEN_DOCKERFILE_CONFIG_BACKUP_DIR/$GEN_DOCKERFILE_CONFIG_FILE.$$"
  cat <<EOF >"$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE"
# Settings for gen-dockerfile
GEN_DOCKERFILE_GIT_BASE="${GEN_DOCKERFILE_GIT_BASE:-https://github.com/casjaysdevdocker}"
GEN_DOCKERFILE_DEFAULT_IMAGE="${GEN_DOCKERFILE_DEFAULT_IMAGE:-casjaysdevdocker/alpine:latest}"

# Notification settings
GEN_DOCKERFILE_GOOD_MESSAGE="${GEN_DOCKERFILE_GOOD_MESSAGE:-Everything Went OK}"
GEN_DOCKERFILE_ERROR_MESSAGE="${GEN_DOCKERFILE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_DOCKERFILE_NOTIFY_ENABLED="${GEN_DOCKERFILE_NOTIFY_ENABLED:-yes}"
GEN_DOCKERFILE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_DOCKERFILE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_DOCKERFILE_NOTIFY_CLIENT_ICON}"

# Colorization settings
GEN_DOCKERFILE_OUTPUT_COLOR="${GEN_DOCKERFILE_OUTPUT_COLOR:-5}"
GEN_DOCKERFILE_OUTPUT_COLOR_GOOD="${GEN_DOCKERFILE_OUTPUT_COLOR_GOOD:-2}"
GEN_DOCKERFILE_OUTPUT_COLOR_ERROR="${GEN_DOCKERFILE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__make_file() {
  if [[ -f "$GEN_DOCKERFILE_CONFIG_DIR/Dockerfile" ]]; then
    cat <<EOF | tee "$file" &>/dev/null
    $(. "$GEN_DOCKERFILE_CONFIG_DIR/Dockerfile")
EOF
  else
    cat <<EOF | tee "$file" &>/dev/null
FROM ${DOCKER_IMAGE:-casjaysdevdocker/alpine:latest} as build

RUN mkdir -p /bin/.gitkeep /config/.gitkeep /data/.gitkeep && \
  rm -Rf /bin/.gitkeep /config/.gitkeep /data/.gitkeep && \
  apk update

COPY ./bin/. /usr/local/bin/
COPY ./config/. /config/
COPY ./data/. /data/

FROM scratch
ARG BUILD_DATE="\$(date +'%Y-%m-%d %H:%M')"

LABEL org.label-schema.name="$name" \\
  org.label-schema.description="containerized version of $name" \\
  org.label-schema.url="${repo:-https://hub.docker.com/r/casjaysdevdocker}/$name" \\
  org.label-schema.vcs-url="${repo:-https://github.com/casjaysdevdocker}/$name" \\
  org.label-schema.build-date=\$BUILD_DATE \\
  org.label-schema.version=\$BUILD_DATE \\
  org.label-schema.vcs-ref=\$BUILD_DATE \\
  org.label-schema.license="WTFPL" \\
  org.label-schema.vcs-type="Git" \\
  org.label-schema.schema-version="latest" \\
  org.label-schema.vendor="CasjaysDev" \\
  maintainer="CasjaysDev <docker-admin@casjaysdev.com>"

ENV SHELL="/bin/bash" \\
  TERM="xterm-256color" \\
  HOSTNAME="casjaysdev-$name" \\
  TZ="\${TZ:-America/New_York}"

WORKDIR /root
VOLUME ["/root","/config"]
EXPOSE 9090

COPY --from=build /. /

HEALTHCHECK CMD [ "/usr/local/bin/entrypoint-$name.sh", "healthcheck" ]
ENTRYPOINT [ "/usr/local/bin/entrypoint-$name.sh" ]
CMD [ "/usr/bin/bash", "-c" ]

EOF
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__docker_file() {
  local file name repo dir
  file="$1"
  name="${2:-$(basename $(dirname $(readlink -f "./Dockerfile")))}"
  repo="${3:-$GEN_DOCKERFILE_GIT_BASE/$name}"
  dir="$(dirname "$file")"
  bak_ext="$$.bak"
  [[ -d "$dir" ]] || mkdir -p "$dir"
  if [[ -f "$file" ]]; then
    printf_yellow "Found an existing Dockerfile at: $file"
    printf_cyan "Backing up to: $file.$bak_ext"
    mv -f "$file" "$file.$bak_ext"
  fi
  printf_purple "Creating Directories: bin data config"
  mkdir -p "$dir" "$dir/bin" "$dir/data" "$dir/config"
  touch "$dir/bin/.gitkeep" "$dir/data/.gitkeep" "$dir/config/.gitkeep"
  printf_purple "Generating your Dockerfile"
  __make_file
  if [[ -f "$file" ]]; then
    printf_blue "Creating $dir/bin/entrypoint-$name.sh"
    if [[ -f "$dir/bin/entrypoint-$name.sh" ]]; then
      printf_yellow "Found existing entrypoint... Backing up"
      mv -f "$dir/bin/entrypoint-$name.sh" "$dir/bin/entrypoint-$name.sh.$bak_ext"
    fi
    gen-script bash docker-entrypoint "$dir/bin/entrypoint-$name.sh" &>/dev/null &&
      printf_green "Created the entrypoint script" || printf_red "Failed to create the entrypoint file"
    [[ -f "$dir/README.md" ]] || gen-readme "$dir" projects docker.md
    [[ -d "$dir/LICENSE.md" ]] || gen-license "$dir" wtfpl
    printf_green "Using $repo as VCS url"
    printf_green "Your Dockerfile for $name has been created in:"
    printf_cyan "$(readlink -f "$dir")"
    if [[ -d "$dir/bin" ]] && [[ -d "$dir/data" ]] && [[ -d "$dir/config" ]]; then
      [[ -f "$dir/.gitignore" ]] || gitignore "$dir" default &>/dev/null
      printf_blue "All files and Directories have been created"
      if [ ! -d "$dir/.git" ]; then
        gitadmin "$dir" setup "$repo" --automated
      fi
    else
      printf_exit 1 1 "Well something went horribly wrong"
    fi
    return 0
  else
    printf_red "Failed to create Dockerfile for $name in $dir"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
GEN_DOCKERFILE_LOG_DIR="${GEN_DOCKERFILE_LOG_DIR:-$HOME/.local/log/gen-dockerfile}"
GEN_DOCKERFILE_CACHE_DIR="${GEN_DOCKERFILE_CACHE_DIR:-$HOME/.cache/gen-dockerfile}"
GEN_DOCKERFILE_CONFIG_DIR="${GEN_DOCKERFILE_CONFIG_DIR:-$HOME/.config/myscripts/gen-dockerfile}"
GEN_DOCKERFILE_OPTIONS_DIR="${GEN_DOCKERFILE_OPTIONS_DIR:-$HOME/.local/share/myscripts/gen-dockerfile/options}"
GEN_DOCKERFILE_CONFIG_BACKUP_DIR="${GEN_DOCKERFILE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/gen-dockerfile/backups}"
GEN_DOCKERFILE_TEMP_DIR="${GEN_DOCKERFILE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/gen-dockerfile}"
GEN_DOCKERFILE_CONFIG_FILE="${GEN_DOCKERFILE_CONFIG_FILE:-settings.conf}"
GEN_DOCKERFILE_GOOD_MESSAGE="${GEN_DOCKERFILE_GOOD_MESSAGE:-Everything Went OK}"
GEN_DOCKERFILE_ERROR_MESSAGE="${GEN_DOCKERFILE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_DOCKERFILE_NOTIFY_ENABLED="${GEN_DOCKERFILE_NOTIFY_ENABLED:-yes}"
GEN_DOCKERFILE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_DOCKERFILE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_DOCKERFILE_NOTIFY_CLIENT_ICON}"
GEN_DOCKERFILE_OUTPUT_COLOR="${GEN_DOCKERFILE_OUTPUT_COLOR:-5}"
GEN_DOCKERFILE_OUTPUT_COLOR_GOOD="${GEN_DOCKERFILE_OUTPUT_COLOR_GOOD:-2}"
GEN_DOCKERFILE_OUTPUT_COLOR_ERROR="${GEN_DOCKERFILE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Enviroment overrides
GEN_DOCKERFILE_GIT_BASE="${GEN_DOCKERFILE_GIT_BASE:-https://github.com/casjaysdevdocker}"
GEN_DOCKERFILE_DEFAULT_IMAGE="${GEN_DOCKERFILE_DEFAULT_IMAGE:-casjaysdevdocker/alpine:latest}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE" ] && . "$GEN_DOCKERFILE_CONFIG_DIR/$GEN_DOCKERFILE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$GEN_DOCKERFILE_LOG_DIR" ] || mkdir -p "$GEN_DOCKERFILE_LOG_DIR" &>/dev/null
[ -d "$GEN_DOCKERFILE_TEMP_DIR" ] || mkdir -p "$GEN_DOCKERFILE_TEMP_DIR" &>/dev/null
[ -d "$GEN_DOCKERFILE_CACHE_DIR" ] || mkdir -p "$GEN_DOCKERFILE_CACHE_DIR" &>/dev/null
GEN_DOCKERFILE_TEMP_FILE="${GEN_DOCKERFILE_TEMP_FILE:-$(mktemp $GEN_DOCKERFILE_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$GEN_DOCKERFILE_TEMP_FILE" ] && [ -f "$GEN_DOCKERFILE_TEMP_FILE" ] && rm -Rf "$GEN_DOCKERFILE_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$GEN_DOCKERFILE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${GEN_DOCKERFILE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${GEN_DOCKERFILE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${GEN_DOCKERFILE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${GEN_DOCKERFILE_NOTIFY_CLIENT_ICON}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    __help
    shift 1
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    GEN_DOCKERFILE_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [[ "$1" = "" ]]; then
  printf_yellow "This will create a new Dockerfile in $PWD"
  printf_pause "If this is what you want press enter or control-c to exit"
  __docker_file "$PWD/Dockerfile"
elif [[ -n "$GEN_DOCKERFILE_CWD" ]]; then
  ___docker_file_docker_file "$GEN_DOCKERFILE_CWD/Dockerfile" "$2" $GEN_DOCKERFILE_GIT_BASE
elif [[ -d "$1" ]]; then
  __docker_file "$1/Dockerfile" "$2" $GEN_DOCKERFILE_GIT_BASE
else
  __docker_file "$1" "$2" $GEN_DOCKERFILE_GIT_BASE
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
