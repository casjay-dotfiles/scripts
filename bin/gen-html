APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__replace() { $sed -i 's|'"$1"'|'"$2"'|g' "$3" &>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GEN_HTML_CONFIG_DIR/$GEN_HTML_CONFIG_FILE"
  [ -d "$GEN_HTML_CONFIG_DIR" ] || mkdir -p "$GEN_HTML_CONFIG_DIR"
  [ -d "$GEN_HTML_CONFIG_BACKUP_DIR" ] || mkdir -p "$GEN_HTML_CONFIG_BACKUP_DIR"
  [ -f "$GEN_HTML_CONFIG_DIR/$GEN_HTML_CONFIG_FILE" ] &&
    cp -Rf "$GEN_HTML_CONFIG_DIR/$GEN_HTML_CONFIG_FILE" "$GEN_HTML_CONFIG_BACKUP_DIR/$GEN_HTML_CONFIG_FILE.$$"
  cat <<EOF >"$GEN_HTML_CONFIG_DIR/$GEN_HTML_CONFIG_FILE"
# Settings for gen-html
# Default directory
GEN_HTML_CONFIG_DIR="${GEN_HTML_CONFIG_DIR:-$HOME/.config/myscripts/gen-html}"
# Default files directory
GEN_HTML_DIR_FILES="${GEN_HTML_DIR_FILES:-$GEN_HTML_CONFIG_DIR/files}"
# Default custom directory
GEN_HTML_DIR_FILES_CUSTOM="${GEN_HTML_DIR_FILES_CUSTOM:-$GEN_HTML_CONFIG_DIR/custom}"
# Default html file
GEN_HTML_DEFAULT_HTML="${GEN_HTML_DEFAULT_HTML:-${GEN_HTML_DIR_FILES:-$CASJAYSDEVDIR/templates}/template.html}"
# Default git repo
GEN_HTML_REPO="${GEN_HTML_REPO:-}"
# Default Raw URL
GEN_HTML_REPO_RAW="${GEN_HTML_REPO_RAW:-}"
# Default name
GEN_HTML_GIT_USER="${GEN_HTML_GIT_USER:-$USER}"
# Default e-mail
GEN_HTML_GIT_EMAIL="${GEN_HTML_GIT_EMAIL:-$USER@$HOSTNAME}"

# Notification settings
GEN_HTML_GOOD_MESSAGE="${GEN_HTML_GOOD_MESSAGE:-Everything Went OK}"
GEN_HTML_ERROR_MESSAGE="${GEN_HTML_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_HTML_NOTIFY_ENABLED="${GEN_HTML_NOTIFY_ENABLED:-yes}"
GEN_HTML_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_HTML_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_HTML_NOTIFY_CLIENT_ICON}"

# Colorization settings
GEN_HTML_OUTPUT_COLOR="${GEN_HTML_OUTPUT_COLOR:-5}"
GEN_HTML_OUTPUT_COLOR_GOOD="${GEN_HTML_OUTPUT_COLOR_GOOD:-2}"
GEN_HTML_OUTPUT_COLOR_ERROR="${GEN_HTML_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GEN_HTML_CONFIG_DIR/$GEN_HTML_CONFIG_FILE" ]; then
    . "$GEN_HTML_CONFIG_DIR/$GEN_HTML_CONFIG_FILE"
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      copy_templates &>/dev/null
      exec $APPNAME "$*"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__file_failed() {
  printf_error "Failed to get the html file"
  printf_exit 1 1 "from: $1"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
get_remote_file() {
  [[ -n "$GEN_HTML_REPO" ]] || return 1
  local filename name default_ext
  filename="$1"
  name="$(__basename "$filename")"
  check_uri "$1" filename="$1" || filename="$GEN_HTML_REPO_RAW/$name"
  [[ "$filename" = -q ]] || printf_green "Attempting to get $filename"
  __urlverify "$filename" && __curl "$filename" | tee "$GEN_HTML_DIR_FILES_CUSTOM/$name" &>/dev/null
  if [ -f "$GEN_HTML_DIR_FILES_CUSTOM/$name" ] && [[ -s "$GEN_HTML_DIR_FILES_CUSTOM/$name" ]]; then
    printf_cyan "Successfully saved $name to $GEN_HTML_DIR_FILES_CUSTOM"
    create_local_file "$GEN_HTML_DIR_FILES_CUSTOM/$name"
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
copy_templates() {
  local TEMPLATE_REPO=""
  printf_green "Installing the html files to:"
  printf_blue "$GEN_HTML_DIR_FILES"
  if am_i_online && [[ -n "$GEN_HTML_REPO" ]]; then
    if [ -d "$GEN_HTML_CONFIG_DIR/gitrepo/.git" ]; then
      git -C "$GEN_HTML_CONFIG_DIR/gitrepo" pull -q &>/dev/null
      TEMPLATE_REPO="$(__git_remote_fetch $GEN_HTML_CONFIG_DIR/gitrepo)"
    else
      if git clone -q "$GEN_HTML_REPO" "$GEN_HTML_CONFIG_DIR/gitrepo" &>/dev/null; then
        TEMPLATE_REPO="$GEN_HTML_REPO"
      else
        __cp_rf "${CASJAYSDEVDIR}/templates/template.html" "$GEN_HTML_DIR_FILES/"
        TEMPLATE_REPO="${CASJAYSDEVDIR}/templates"
      fi
    fi
  else
    if [ -f "${CASJAYSDEVDIR}/templates/template.html" ]; then
      __cp_rf "${CASJAYSDEVDIR}/templates/template.html" "$GEN_HTML_DIR_FILES/"
      TEMPLATE_REPO="${CASJAYSDEVDIR}/templates"
    else
      printf_exit 1 1 "Can not get html files"
    fi
  fi
  if [ -d "$GEN_HTML_CONFIG_DIR/gitrepo/files" ]; then
    __cp_rf "$GEN_HTML_CONFIG_DIR/gitrepo/files/." "$GEN_HTML_DIR_FILES/"
  fi
  if [ "$(__count_files "$GEN_HTML_DIR_FILES" "2")" -ne 0 ]; then
    printf_green "Successfully copied the template files"
  else
    if [ "$(__count_files "$GEN_HTML_DIR_FILES" "2")" -eq 0 ]; then
      printf_red "could not copy the html files"
      printf_red "from $TEMPLATE_REPO"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_modify_html_file() {
  local fileName="$1"
  if [ -f "$fileName" ]; then
    __replace "GEN_HTML_REPLACE_YEAR" "$(date +'%Y')" "$fileName"
    __replace "GEN_HTML_REPLACE_AUTHOR" "$GEN_HTML_GIT_USER" "$fileName"
    __replace "GEN_HTML_REPLACE_EMAIL" "$GEN_HTML_GIT_EMAIL" "$fileName"
  else
    printf_exit "Failed to find the file at $fileName"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
create_local_file() {
  local default_file default_ext default_ext post_mess html_base html_name fileName
  fileName="${1:-$GEN_HTML_CWD/index.html}"
  default_file="$(basename ${2:-$GEN_HTML_DEFAULT_HTML} 2>/dev/null)"
  post_mess="$fileName for $GEN_HTML_CWD"
  html_base="$(basename "${default_file^^*}" 2>/dev/null)"
  html_name="${html_base%.*}"
  # Search custom dir
  if [ -f "$GEN_HTML_DIR_FILES_CUSTOM/${default_file//$GEN_HTML_DIR_FILES\//}" ]; then
    template="$GEN_HTML_DIR_FILES_CUSTOM/${default_file//$GEN_HTML_DIR_FILES\//}"
    message="Using $html_name $post_mess"
  # Search template dir
  elif [ -f "$GEN_HTML_DIR_FILES/${GEN_HTML_DEFAULT_HTML//$GEN_HTML_DIR_FILES\//}" ]; then
    template="$GEN_HTML_DIR_FILES/${GEN_HTML_DEFAULT_HTML//$GEN_HTML_DIR_FILES\//}"
    message="Using Default $GEN_HTML_DEFAULT_HTML $post_mess"
  elif [[ -f "$GEN_HTML_DEFAULT_HTML" ]]; then
    template="$GEN_HTML_DEFAULT_HTML"
    message="Using file from $GEN_HTML_DEFAULT_HTML"
  else
    printf_exit 1 1 "Can not find any html files matching ${2:-$default_file} for $fileName"
  fi
  printf_green "$message"
  [ -f "$template" ] || __file_failed "$template"
  [[ -f "$fileName" ]] && mv -f "$fileName" "$fileName.$$"
  cat "$template" >"$fileName" 2>/dev/null
  if [ -f "$fileName" ] && [ -s "$fileName" ]; then
    _modify_html_file "$fileName"
    printf_green "$fileName has been created"
  else
    __file_failed "$1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
GEN_HTML_LOG_DIR="${GEN_HTML_LOG_DIR:-$HOME/.local/log/gen-html}"
GEN_HTML_CACHE_DIR="${GEN_HTML_CACHE_DIR:-$HOME/.cache/gen-html}"
GEN_HTML_CONFIG_DIR="${GEN_HTML_CONFIG_DIR:-$HOME/.config/myscripts/gen-html}"
GEN_HTML_CONFIG_BACKUP_DIR="${GEN_HTML_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/gen-html/backups}"
GEN_HTML_TEMP_DIR="${GEN_HTML_TEMP_DIR:-$HOME/.local/tmp/system_scripts/gen-html}"
GEN_HTML_OPTIONS_DIR="${GEN_HTML_OPTIONS_DIR:-$HOME/.local/share/myscripts/gen-html/options}"
GEN_HTML_CONFIG_FILE="${GEN_HTML_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
GEN_HTML_OUTPUT_COLOR="${GEN_HTML_OUTPUT_COLOR:-4}"
GEN_HTML_OUTPUT_COLOR_2="${GEN_HTML_OUTPUT_COLOR:-6}"
GEN_HTML_OUTPUT_COLOR_GOOD="${GEN_HTML_OUTPUT_COLOR_GOOD:-2}"
GEN_HTML_OUTPUT_COLOR_ERROR="${GEN_HTML_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
GEN_HTML_GOOD_MESSAGE="${GEN_HTML_GOOD_MESSAGE:-Everything Went OK}"
GEN_HTML_ERROR_MESSAGE="${GEN_HTML_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_HTML_NOTIFY_ENABLED="${GEN_HTML_NOTIFY_ENABLED:-yes}"
GEN_HTML_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_HTML_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_HTML_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
GEN_HTML_DIR_FILES="${GEN_HTML_DIR_FILES:-${GEN_HTML_DIR/files:-$CASJAYSDEVDIR/templates}}"
GEN_HTML_DIR_FILES_CUSTOM="${GEN_HTML_DIR_FILES_CUSTOM:-$GEN_HTML_CONFIG_DIR/custom}"
GEN_HTML_REPO="${GEN_HTML_REPO:-}"
GEN_HTML_REPO_RAW="${GEN_HTML_REPO_RAW:-}"
GEN_HTML_GIT_USER="${GEN_HTML_GIT_USER:-$(__git_globaluser)}"
GEN_HTML_GIT_EMAIL="${GEN_HTML_GIT_EMAIL:-$(__git_globalemail)}"
GEN_HTML_DEFAULT_HTML="${GEN_HTML_DEFAULT_HTML:-${GEN_HTML_DIR_FILES:-$CASJAYSDEVDIR/templates}/template.html}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$GEN_HTML_CONFIG_DIR/$GEN_HTML_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GEN_HTML_CONFIG_DIR/$GEN_HTML_CONFIG_FILE" ] && . "$GEN_HTML_CONFIG_DIR/$GEN_HTML_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$GEN_HTML_LOG_DIR" ] || mkdir -p "$GEN_HTML_LOG_DIR" &>/dev/null
[ -d "$GEN_HTML_TEMP_DIR" ] || mkdir -p "$GEN_HTML_TEMP_DIR" &>/dev/null
[ -d "$GEN_HTML_CACHE_DIR" ] || mkdir -p "$GEN_HTML_CACHE_DIR" &>/dev/null
[ -d "$GEN_HTML_DIR_FILES" ] || mkdir -p "$GEN_HTML_DIR_FILES" &>/dev/null
[ -d "$GEN_HTML_DIR_FILES_CUSTOM" ] || mkdir -p "$GEN_HTML_DIR_FILES_CUSTOM" &>/dev/null
GEN_HTML_TEMP_FILE="${GEN_HTML_TEMP_FILE:-$(mktemp $GEN_HTML_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$GEN_HTML_TEMP_FILE" ] && [ -f "$GEN_HTML_TEMP_FILE" ] && rm -Rf "$GEN_HTML_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$GEN_HTML_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${GEN_HTML_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${GEN_HTML_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${GEN_HTML_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${GEN_HTML_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,copy"
ARRAY="custom download list"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    { [ "$GEN_HTML_DEFAULT_HTML" = "config" ] || [ "$GEN_HTML_FILE" = "config" ]; } &&
      html_file="$WHICH_HTML_DEF" || html_file="$GEN_HTML_DEFAULT_HTML"
    __gen_config
    exit $?
    ;;
  --dir)
    GEN_HTML_CWD="$2"
    shift 2
    ;;
  --copy)
    copy_templates
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
[[ -n "$GEN_HTML_CWD" ]] || GEN_HTML_CWD="$(dirname "$(readlink -f "$1")" 2>/dev/null)"
[ "$GEN_HTML_CWD" = "." ] && GEN_HTML_CWD="$(__basedir ".")"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash curl git || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
GEN_HTML_CHOICE="${1:-$GEN_HTML_DEFAULT_HTML}"
GEN_HTML_FILE="$(basename ${GEN_HTML_CHOICE:-$WHICH_HTML_DEF} 2>/dev/null)"
GEN_HTML_WHICH_FILE="$(echo "${1:-$GEN_HTML_FILE}")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "${1:-$GEN_HTML_WHICH_FILE}" in
list)
  shift 1
  if [ "$(__count_files "$GEN_HTML_DIR_FILES")" -eq 0 ]; then
    [[ -f "${CASJAYSDEVDIR}/helpers/gen-html/array" ]] &&
      cat "${CASJAYSDEVDIR}/helpers/gen-html/array" | printf_readline "2"
  else
    __find "$GEN_HTML_DIR_FILES" | printf_readline "2"
    [ "$(__count_files "$GEN_HTML_DIR_FILES_CUSTOM")" -eq 0 ] ||
      __find "$GEN_HTML_DIR_FILES_CUSTOM" | printf_readline "2"
  fi
  exit $?
  ;;

download)
  shift 1
  tmpfolder="/tmp/html.$$"
  printf_green "Cloning the repo to $tmpfolder"
  __git_clone "$GEN_HTML_REPO_RAW" "$tmpfolder"
  if [[ -d "$tmpfolder/files" ]]; then
    printf_green "Copying files to $GEN_HTML_DIR_FILES_CUSTOM"
    __cp_rf "$tmpfolder/files/." "$GEN_HTML_DIR_FILES_CUSTOM/"
    __rm_rf "$tmpfolder"
  fi
  if [ -d "$GEN_HTML_DIR_FILES_CUSTOM" ] && [ "$(__count_files "$GEN_HTML_DIR_FILES_CUSTOM" "2")" -ne 0 ]; then
    printf_green "Done cloning and copying the files"
  else
    printf_red "Failed to setup custom html file"
  fi
  ;;

custom)
  shift 1
  if [ -f "$2" ]; then
    create_local_file "$2" "$1"
  else
    get_remote_file "$2" "$1"
  fi
  ;;

*)
  create_local_file "$@"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
