#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108041709-git"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#set opts
trap 'GEN_LICENSE_EXITCODE=${GEN_LICENSE_EXITCODE:-$?};[ -f "$GEN_LICENSE_TEMP_FILE" ] && rm -Rf "$GEN_LICENSE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108041709-git
# @Author        : casjay
# @Contact       : casjay
# @License       : LICENSE.md
# @ReadME        : gen-license --help
# @Copyright     : Copyright: (c) 2021 casjay, casjay
# @Created       : Wednesday, Aug 04, 2021 17:09 EDT
# @File          : gen-license
# @Description   : Create a license file
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/$GIT_DEFAULT_BRANCH/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# I'm sure there is a better way to do this
if [ -d "$1" ]; then
  GEN_LICENSE_WD="$1"
  shift 1
elif [ "$1" = "-d" ] || [ "$1" = "-dir" ] || [ "$1" = "--dir" ]; then
  GEN_LICENSE_WD="$2"
  shift 2
  [ -d "$GEN_LICENSE_WD" ] || printf_exit "$GEN_LICENSE_WD doesn't seem to be a directory"
else
  GEN_LICENSE_WD="$PWD"
fi
if [ "$GEN_LICENSE_WD" = "." ]; then GEN_LICENSE_WD="$(__basedir ".")"; fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file"
  printf_green "$GEN_LICENSE_SETTINGS_FILE"
  cat <<EOF >"$GEN_LICENSE_SETTINGS_FILE"
# Settings for $APPNAME
# Default directory
GEN_LICENSE_DIR="${GEN_LICENSE_DIR:-$GEN_LICENSE_DIR}"
# Default license
GEN_LICENSE_DEFAULT_LICENSE="${GEN_LICENSE_DEFAULT_LICENSE:-wtfpl}"
# Default files directory
GEN_LICENSE_DIR_FILES="${GEN_LICENSE_DIR_FILES_CUSTOM:-$HOME/.config/myscripts/gen-license/files}"
# Default custom directory
GEN_LICENSE_DIR_FILES_CUSTOM="${GEN_LICENSE_DIR_FILES_CUSTOM:-$HOME/.config/myscripts/gen-license/custom}"
# Default git repo
GEN_LICENSE_REPO="${GEN_LICENSE_REPO:-https://github.com/devenvmgr/licenses}"
# Default Raw URL
GEN_LICENSE_REPO_RAW="${GEN_LICENSE_REPO_RAW:-$WHICH_LICENSE_URL}"
# Default name
GEN_LICENSE_GIT_USER="$GEN_LICENSE_GIT_USER"
# Default e-mail
GEN_LICENSE_GIT_EMAIL="$GEN_LICENSE_GIT_EMAIL"

EOF
  __copy_templates
  if [ -f "$GEN_LICENSE_SETTINGS_FILE" ]; then
    printf_green "Initializing has finished"
  else
    printf_green "Failed to generate the config file"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_lic() { __create_local_file "$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__list_available() {
  find "$GEN_LICENSE_DIR"/* -maxdepth 1 -type f 2>/dev/null
}
__copy_templates() {
  local TEMPLATE_REPO=""
  printf_green "Installing the license files to:"
  printf_blue "$GEN_LICENSE_DIR_FILES"
  if __am_i_online; then
    if [ -d "$GEN_LICENSE_DIR/gitrepo/.git" ]; then
      git -C "$GEN_LICENSE_DIR/gitrepo" pull -q &>/dev/null
      TEMPLATE_REPO="$(__git_remote_fetch $GEN_LICENSE_DIR/gitrepo)"
    else
      if git clone -q "$GEN_LICENSE_REPO" "$GEN_LICENSE_DIR/gitrepo" &>/dev/null; then
        TEMPLATE_REPO="$GEN_LICENSE_REPO"
      else
        __cp_rf "${CASJAYSDEVDIR}/templates/licenses/." "$GEN_LICENSE_DIR_FILES/"
        TEMPLATE_REPO="${CASJAYSDEVDIR}/templates/licenses"
      fi
    fi
  else
    if [ -d "${CASJAYSDEVDIR}/templates/licenses" ]; then
      __cp_rf "${CASJAYSDEVDIR}/templates/licenses/." "$GEN_LICENSE_DIR_FILES/"
      TEMPLATE_REPO="${CASJAYSDEVDIR}/templates/licenses"
    else
      printf_exit 1 1 "Can not get license files"
    fi
  fi
  if [ -d "$GEN_LICENSE_DIR/gitrepo/files" ]; then
    __cp_rf "$GEN_LICENSE_DIR/gitrepo/files/." "$GEN_LICENSE_DIR_FILES/"
  fi
  if [ "$(__count_files "$GEN_LICENSE_DIR_FILES" "2")" -ne 0 ]; then
    printf_green "Successfully copied the template files"
  else
    if [ "$(__count_files "$GEN_LICENSE_DIR_FILES" "2")" -eq 0 ]; then
      printf_red "could not copy the license files"
      printf_red "from $TEMPLATE_REPO"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__modify_license_file() {
  if grep -iq 'What The Fuck Public License' "$GEN_LICENSE_WD/LICENSE.md" ||
    grep -iq 'DO WHAT THE FUCK YOU WANT TO PUBLIC LICENSE' "$GEN_LICENSE_WD/LICENSE.md"; then
    if grep -iq 'CURYEAR AuthorName' "$GEN_LICENSE_WD/LICENSE.md"; then
      [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && __sed -i "s# CURYEAR # $(date +'%Y') #g" "$GEN_LICENSE_WD/LICENSE.md"
      [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && __sed -i "s#AuthorName#${GEN_LICENSE_GIT_USER}#g" "$GEN_LICENSE_WD/LICENSE.md"
    else
      [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && __sed -i "s# 2004 # $(date +'%Y') #g" "$GEN_LICENSE_WD/LICENSE.md"
      [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && __sed -i "s#Sam Hocevar#${GEN_LICENSE_GIT_USER}#g" "$GEN_LICENSE_WD/LICENSE.md"
      [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && __sed -i "s#sam@hocevar.net#${GEN_LICENSE_GIT_EMAIL}#g" "$GEN_LICENSE_WD/LICENSE.md"
    fi
  fi
  [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && __sed -i "s#GEN_LICENSE_REPLACE_YEAR#$(date +'%Y')#g" "$GEN_LICENSE_WD/LICENSE.md"
  [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && __sed -i "s#GEN_LICENSE_REPLACE_AUTHOR#${GEN_LICENSE_GIT_USER}#g" "$GEN_LICENSE_WD/LICENSE.md"
  [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && __sed -i "s#GEN_LICENSE_REPLACE_EMAIL#${GEN_LICENSE_GIT_EMAIL}#g" "$GEN_LICENSE_WD/LICENSE.md"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__file_failed() {
  printf_error "Failed to get the license file"
  printf_exit 1 1 "from: $1"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__create_local_file() {
  [ -f "$1" ] || __file_failed "$1"
  cat "$1" >"$GEN_LICENSE_WD/LICENSE.md" 2>/dev/null
  if [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && [ -s "$GEN_LICENSE_WD/LICENSE.md" ]; then
    __modify_license_file
    printf_green "Your LICENSE file has been created"
  else
    __file_failed "$1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_remote_file() {
  local name="$(__basename "$1")"
  __curl "$1" >"$GEN_LICENSE_DIR_FILES_CUSTOM/$name" 2>/dev/null
  if [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && [ -s "$GEN_LICENSE_WD/LICENSE.md" ]; then
    __create_local_file "$GEN_LICENSE_DIR_FILES_CUSTOM/$name"
  else
    __file_failed "$1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__list() {
  if [ "$(__count_files "$GEN_LICENSE_DIR_FILES")" -eq 0 ]; then
    cat "${CASJAYSDEVDIR}/helpers/gen-license/array" | printf_readline "2"
  else
    __find "$GEN_LICENSE_DIR_FILES" | printf_readline "2"
    [ "$(__count_files "$GEN_LICENSE_DIR_FILES_CUSTOM")" -eq 0 ] ||
      __find "$GEN_LICENSE_DIR_FILES_CUSTOM" | printf_readline "2"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__download() {
  tmpfolder="/tmp/licenses.$$"
  printf_green "Cloning the repo to $tmpfolder"
  __git_clone "$GEN_LICENSE_REPO_RAW" "$tmpfolder"
  printf_green "Copying files to $GEN_LICENSE_DIR_FILES_CUSTOM"
  __cp_rf "$tmpfolder/files/." "$GEN_LICENSE_DIR_FILES_CUSTOM/"
  __rm_rf "$tmpfolder"
  if [ -d "$GEN_LICENSE_DIR_FILES_CUSTOM" ] && [ "$(__count_files "$GEN_LICENSE_DIR_FILES_CUSTOM" "2")" -ne 0 ]; then
    printf_green "Done cloning and copying the files"
  else
    printf_red "Failed to setup custom license files"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Defaults
GEN_LICENSE_EXITCODE=""
GEN_LICENSE_DEFAULT_LICENSE="${GEN_LICENSE_DEFAULT_LICENSE:-wtfpl}"
GEN_LICENSE_DIR="${GEN_LICENSE_DIR:-$HOME/.config/myscripts/gen-license}"
GEN_LICENSE_SETTINGS_FILE="${GEN_LICENSE_SETTINGS_FILE:-$GEN_LICENSE_DIR/settings.conf}"
GEN_LICENSE_DIR_FILES="${GEN_LICENSE_DIR_FILES:-$GEN_LICENSE_DIR/files}"
GEN_LICENSE_DIR_FILES_CUSTOM="${GEN_LICENSE_DIR_FILES_CUSTOM:-$HOME/.config/myscripts/gen-license/custom}"
GEN_LICENSE_REPO="${GEN_LICENSE_REPO:-https://github.com/devenvmgr/licenses}"
GEN_LICENSE_REPO_RAW="${GEN_LICENSE_REPO_RAW:-$WHICH_LICENSE_URL}"
GEN_LICENSE_GIT_USER="${GEN_LICENSE_GIT_USER:-$(__git_globaluser)}"
GEN_LICENSE_GIT_EMAIL="${GEN_LICENSE_GIT_EMAIL:-$(__git_globalemail)}"
GEN_LICENSE_CONFIG_BACKUP_DIR="${GEN_LICENSE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/gen-license/backups}"
GEN_LICENSE_OPTIONS_DIR="${GEN_LICENSE_OPTIONS_DIR:-$HOME/.local/share/myscripts/gen-license/options}"
GEN_LICENSE_TEMP_FILE="${GEN_LICENSE_TEMP_FILE:-${TMPDIR:-/tmp}/gen-license}"
GEN_LICENSE_NOTIFY_ENABLED="${GEN_LICENSE_NOTIFY_ENABLED:-yes}"
GEN_LICENSE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_LICENSE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_LICENSE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h"
LONGOPTS="options,config,version,help"
ARRAY="$(__list_available)"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate Files
[ -f "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE" ] || __gen_config &>/dev/null
[ -f "$GEN_LICENSE_OPTIONS_DIR/options" ] || __list_options "$GEN_LICENSE_OPTIONS_DIR" &>/dev/null
[ -f "$GEN_LICENSE_OPTIONS_DIR/array" ] || __list_array "$GEN_LICENSE_OPTIONS_DIR" "$ARRAY" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
if [ -f "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE" ]; then
  . "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    __list_array "$GEN_LICENSE_OPTIONS_DIR" "$ARRAY"
    __list_options "$GEN_LICENSE_OPTIONS_DIR"
    exit $?
    ;;
  -v | --version)
    shift 1
    __version
    exit $?
    ;;
  -h | --help)
    shift 1
    __help
    exit $?
    ;;
  -c | --config)
    shift 1
    if [ "$GEN_LICENSE_DEFAULT_LICENSE" = "config" ] || [ "$GEN_LICENSE_FILE" = "config" ]; then
      license="$WHICH_LICENSE_DEF"
    else
      license="$GEN_LICENSE_DEFAULT_LICENSE"
    fi
    __gen_config
    exit $?
    ;;
  -l | --list)
    shift 1
    __list
    exit $?
    ;;
  --copy)
    __copy_templates
    exit $?
    ;;

  -d | --download)
    shift 1
    __download
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
export NOTIFY_CLIENT_NAME="${GEN_LICENSE_NOTIFY_CLIENT_NAME}"
export NOTIFY_CLIENT_ICON="${GEN_LICENSE_NOTIFY_CLIENT_ICON}"
if [ "$GEN_LICENSE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash || exit 1
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables
GEN_LICENSE_CHOICE="${1:-$GEN_LICENSE_DEFAULT_LICENSE}"
GEN_LICENSE_FILE="$(basename ${GEN_LICENSE_CHOICE:-$WHICH_LICENSE_DEF} 2>/dev/null)"
GEN_LICENSE_WHICH_FILE="$(echo "${1:-$GEN_LICENSE_FILE}" | tr [A-Z] [a-z])"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__mkd "$GEN_LICENSE_DIR_FILES"
__mkd "$GEN_LICENSE_DIR_FILES_CUSTOM"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -d "$GEN_LICENSE_DIR_FILES" ] && [ "$(__count_files "$GEN_LICENSE_DIR_FILES")" -ne 0 ]; then
  GEN_LICENSE_REPO_RAW="$GEN_LICENSE_DIR_FILES"
elif [ -d "$CASJAYSDEVDIR/templates/licenses" ]; then
  GEN_LICENSE_REPO_RAW="$CASJAYSDEVDIR/templates/licenses"
else
  __get_lic() { __get_remote_file "$1"; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Init
if [ ! -f "$GEN_LICENSE_SETTINGS_FILE" ] && [ ! -d "$GEN_LICENSE_DIR_FILES" ]; then
  if [ "$#" = 0 ]; then __gen_config; fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$GEN_LICENSE_WHICH_FILE" in
wtfpl)
  shift 1
  printf_green "Using the WTFPL license for $GEN_LICENSE_WD"
  __get_lic "$GEN_LICENSE_REPO_RAW/wtfpl.md"
  ;;

gpl1)
  shift 1
  printf_green "Using the GPL V1 license for $GEN_LICENSE_WD"
  __get_lic "$GEN_LICENSE_REPO_RAW/gpl1.md"
  ;;

gpl2)
  shift 1
  printf_green "Using the GPL V2 license for $GEN_LICENSE_WD"
  __get_lic "$GEN_LICENSE_REPO_RAW/gpl2.md"
  ;;

gpl3)
  shift 1
  printf_green "Using the GPL V3 license for $GEN_LICENSE_WD"
  __get_lic "$GEN_LICENSE_REPO_RAW/gpl3.md"
  ;;

agpl)
  shift 1
  printf_green "Using the AGPL license for $GEN_LICENSE_WD"
  __get_lic "$GEN_LICENSE_REPO_RAW/agpl.md"
  ;;

fdl)
  shift 1
  printf_green "Using the FDL license for $GEN_LICENSE_WD"
  __get_lic "$GEN_LICENSE_REPO_RAW/fdl.md"
  ;;

mit)
  shift 1
  printf_green "Using the MIT license for $GEN_LICENSE_WD"
  __get_lic "$GEN_LICENSE_REPO_RAW/mit.md"
  ;;

apache)
  shift 1
  printf_green "Using the Apache license for $GEN_LICENSE_WD"
  __get_lic "$GEN_LICENSE_REPO_RAW/apache.md"
  ;;

bsd2)
  shift 1
  printf_green "Using the BSD license for $GEN_LICENSE_WD"
  __get_lic "$GEN_LICENSE_REPO_RAW/bsd2.md"
  ;;

bsd3)
  shift 1
  printf_green "Using the BSD license for $GEN_LICENSE_WD"
  __get_lic "$GEN_LICENSE_REPO_RAW/bsd3.md"
  ;;

custom)
  shift 1
  printf_green "Using the custom license for $GEN_LICENSE_WD"
  if [ -f "$1" ]; then
    __create_local_file "$1"
  else
    __get_remote_file "$1"
  fi
  ;;

*)
  shift
  if [ "$GEN_LICENSE_FILE" = "$GEN_LICENSE_DEFAULT_LICENSE" ] || [ $# = 0 ]; then
    printf_green "Using Default license for $GEN_LICENSE_WD"
    if [ -f "$GEN_LICENSE_DEFAULT_LICENSE" ]; then
      __create_local_file "$GEN_LICENSE_DEFAULT_LICENSE"
    elif [ -f "$GEN_LICENSE_DIR_FILES/$GEN_LICENSE_DEFAULT_LICENSE" ]; then
      __create_local_file "$GEN_LICENSE_DIR_FILES/$GEN_LICENSE_DEFAULT_LICENSE"
    fi
  elif [ -f "$GEN_LICENSE_FILE" ]; then
    printf_green "Using $GEN_LICENSE_FILE for $GEN_LICENSE_WD"
    __create_local_file "$GEN_LICENSE_FILE"
  elif [ -f "$GEN_LICENSE_DIR_FILES/$GEN_LICENSE_FILE" ]; then
    printf_green "Using $GEN_LICENSE_DIR_FILES/$GEN_LICENSE_FILE for $GEN_LICENSE_WD"
    __create_local_file "$GEN_LICENSE_DIR_FILES/$GEN_LICENSE_FILE"
  elif [ -f "$GEN_LICENSE_DIR_FILES_CUSTOM/$GEN_LICENSE_FILE" ]; then
    printf_green "Using $GEN_LICENSE_DIR_FILES_CUSTOM/$GEN_LICENSE_FILE for $GEN_LICENSE_WD"
    __create_local_file "$GEN_LICENSE_DIR_FILES_CUSTOM/$GEN_LICENSE_FILE"
  elif [ -f "$GEN_LICENSE_DIR_FILES/$GEN_LICENSE_WHICH_FILE" ]; then
    printf_red "$GEN_LICENSE_DIR_FILES/$GEN_LICENSE_WHICH_FILE"
    printf_red " doesn't exist: Using the default license"
  else
    __get_remote_file "$GEN_LICENSE_FILE"
  fi
  ;;
esac

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${GEN_LICENSE_EXITCODE:-$?}
