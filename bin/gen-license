#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#set opts

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202103200730-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : gen-license --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Saturday, Mar 20, 2021 07:30 EDT
# @File          : gen-license
# @Description   : Create a license file
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__check_app curl
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# I'm sure there is a better way to do this
if [ -d "$1" ]; then
  GEN_LICENSE_WD="$1"
  shift 1
elif [ "$1" = "-d" ] || [ "$1" = "-dir" ] || [ "$1" = "--dir" ]; then
  GEN_LICENSE_WD="$2"
  shift 2
  [ -d "$GEN_LICENSE_WD" ] || printf_exit "$GEN_LICENSE_WD doesn't seem to be a directory"
else
  GEN_LICENSE_WD="$PWD"
fi
if [ "$GEN_LICENSE_WD" = "." ]; then GEN_LICENSE_WD="$(__basedir ".")"; fi
###
GEN_LICENSE_DEFAULT_LICENSE="${GEN_LICENSE_DEFAULT_LICENSE:-wtfpl}"
GEN_LICENSE_DIR="${GEN_LICENSE_DIR:-$HOME/.config/myscripts/gen-license}"
GEN_LICENSE_SETTINGS_FILE="$GEN_LICENSE_DIR/settings.conf"
GEN_LICENSE_DIR_FILES="$GEN_LICENSE_DIR/files"
GEN_LICENSE_DIR_FILES_CUSTOM="${GEN_LICENSE_DIR_FILES_CUSTOM:-$HOME/.config/myscripts/gen-license/custom}"
GEN_LICENSE_REPO="${GEN_LICENSE_REPO:-https://github.com/devenvmgr/licenses}"
GEN_LICENSE_REPO_RAW="${GEN_LICENSE_REPO_RAW:-$WHICH_LICENSE_URL}"
GEN_LICENSE_GIT_USER="${GEN_LICENSE_GIT_USER:-$(__git_globaluser)}"
GEN_LICENSE_GIT_EMAIL="${GEN_LICENSE_GIT_EMAIL:-$(__git_globalemail)}"
GEN_LICENSE_CHOICE="${1:-$GEN_LICENSE_DEFAULT_LICENSE}"
GEN_LICENSE_FILE="$(basename ${GEN_LICENSE_CHOICE:-$WHICH_LICENSE_DEF} 2>/dev/null)"
GEN_LICENSE_WHICH_FILE="$(echo "${1:-$GEN_LICENSE_FILE}" | tr [A-Z] [a-z])"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[ -f "$GEN_LICENSE_SETTINGS_FILE" ] && . "$GEN_LICENSE_SETTINGS_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__mkd "$GEN_LICENSE_DIR_FILES"
__mkd "$GEN_LICENSE_DIR_FILES_CUSTOM"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__file_failed() {
  printf_error "Failed to get the license file"
  printf_exit 1 1 "from: $1"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
get_remote_file() {
  local name="$(__basename "$1")"
  printf_green "Using $name for $GEN_LICENSE_WD"
  __curl "$1" >"$GEN_LICENSE_DIR_FILES_CUSTOM/$name" 2>/dev/null
  if [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && [ -s "$GEN_LICENSE_WD/LICENSE.md" ]; then
    create_local_file "$GEN_LICENSE_DIR_FILES_CUSTOM/$name"
  else
    __file_failed "$1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__replace() { $sed -i 's|'"$1"'|'"$2"'|g' "$3" &>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
get_lic() { create_local_file "$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
gen_config() {
  printf_green "Generating the config file"
  printf_green "$GEN_LICENSE_SETTINGS_FILE"
  cat <<EOF >"$GEN_LICENSE_SETTINGS_FILE"
# Settings for $APPNAME
# Default directory
GEN_LICENSE_DIR="${GEN_LICENSE_DIR:-$GEN_LICENSE_DIR}"
# Default license
GEN_LICENSE_DEFAULT_LICENSE="${GEN_LICENSE_DEFAULT_LICENSE:-wtfpl}"
# Default files directory
GEN_LICENSE_DIR_FILES="${GEN_LICENSE_DIR_FILES:-$HOME/.config/myscripts/gen-license/files}"
# Default custom directory
GEN_LICENSE_DIR_FILES_CUSTOM="${GEN_LICENSE_DIR_FILES_CUSTOM:-$HOME/.config/myscripts/gen-license/custom}"
# Default git repo
GEN_LICENSE_REPO="${GEN_LICENSE_REPO:-https://github.com/devenvmgr/licenses}"
# Default Raw URL
GEN_LICENSE_REPO_RAW="${GEN_LICENSE_REPO_RAW:-$WHICH_LICENSE_URL}"
# Default name
GEN_LICENSE_GIT_USER="${GEN_LICENSE_GIT_USER:-$USER}"
# Default e-mail
GEN_LICENSE_GIT_EMAIL="${GEN_LICENSE_GIT_EMAIL:-$USER@$HOSTNAME}"

EOF
  copy_templates
  if [ -f "$GEN_LICENSE_SETTINGS_FILE" ]; then
    printf_green "Initializing has finished"
  else
    printf_green "Failed to generate the config file"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
copy_templates() {
  local TEMPLATE_REPO=""
  printf_green "Installing the license files to:"
  printf_blue "$GEN_LICENSE_DIR_FILES"
  if am_i_online; then
    if [ -d "$GEN_LICENSE_DIR/gitrepo/.git" ]; then
      git -C "$GEN_LICENSE_DIR/gitrepo" pull -q &>/dev/null
      TEMPLATE_REPO="$(__git_remote_fetch $GEN_LICENSE_DIR/gitrepo)"
    else
      if git clone -q "$GEN_LICENSE_REPO" "$GEN_LICENSE_DIR/gitrepo" &>/dev/null; then
        TEMPLATE_REPO="$GEN_LICENSE_REPO"
      else
        __cp_rf "${CASJAYSDEVDIR}/templates/licenses/." "$GEN_LICENSE_DIR_FILES/"
        TEMPLATE_REPO="${CASJAYSDEVDIR}/templates/licenses"
      fi
    fi
  else
    if [ -d "${CASJAYSDEVDIR}/templates/licenses" ]; then
      __cp_rf "${CASJAYSDEVDIR}/templates/licenses/." "$GEN_LICENSE_DIR_FILES/"
      TEMPLATE_REPO="${CASJAYSDEVDIR}/templates/licenses"
    else
      printf_exit 1 1 "Can not get license files"
    fi
  fi
  if [ -d "$GEN_LICENSE_DIR/gitrepo/files" ]; then
    __cp_rf "$GEN_LICENSE_DIR/gitrepo/files/." "$GEN_LICENSE_DIR_FILES/"
  fi
  if [ "$(__count_files "$GEN_LICENSE_DIR_FILES" "2")" -ne 0 ]; then
    printf_green "Successfully copied the template files"
  else
    if [ "$(__count_files "$GEN_LICENSE_DIR_FILES" "2")" -eq 0 ]; then
      printf_red "could not copy the license files"
      printf_red "from $TEMPLATE_REPO"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_modify_license_file() {
 if  [ -f "$GEN_LICENSE_WD/LICENSE.md" ] ; then
   if grep -iq 'What The Fuck Public License' "$GEN_LICENSE_WD/LICENSE.md"; then
     __replace "CURYEAR " "$(date +'%Y') " "$GEN_LICENSE_WD/LICENSE.md"
     __replace "AuthorName" "$GEN_LICENSE_GIT_USER" "$GEN_LICENSE_WD/LICENSE.md"
     __replace " 2004 " " $(date +'%Y') " "$GEN_LICENSE_WD/LICENSE.md"
     __replace "Sam Hocevar" "$GEN_LICENSE_GIT_USER" "$GEN_LICENSE_WD/LICENSE.md"
     __replace "sam@hocevar.net" "$GEN_LICENSE_GIT_EMAIL" "$GEN_LICENSE_WD/LICENSE.md"
   fi
  __replace "GEN_LICENSE_REPLACE_YEAR" "$(date +'%Y')" "$GEN_LICENSE_WD/LICENSE.md"
  __replace "GEN_LICENSE_REPLACE_AUTHOR" "$GEN_LICENSE_GIT_USER" "$GEN_LICENSE_WD/LICENSE.md"
  __replace "GEN_LICENSE_REPLACE_EMAIL" "$GEN_LICENSE_GIT_EMAIL" "$GEN_LICENSE_WD/LICENSE.md"
else 
  printf_exit "Failed to find the file at $GEN_LICENSE_WD/LICENSE.md"
fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
create_local_file() {
  local default_file="${1:-$GEN_LICENSE_DEFAULT_LICENSE}"
  local default_ext="${GEN_LICENSE_DEFAULT_LICENSE_EXT:-md}"
  local post_mess="license for $GEN_LICENSE_WD"
  local LIC="$(basename "${default_file^^*}" 2>/dev/null)"
  if [ -f "$default_file" ]; then
    template="$default_file"
    message="Using $LIC $post_mess"
  elif [ -f "$default_file.$default_ext" ]; then
    template="$default_file.$default_ext"
    message="Using $LIC $post_mess"
  elif [ "$default_file.$default_ext" = "$GEN_LICENSE_DEFAULT_LICENSE" ] || [ $# = 0 ]; then
    message="Using Default license $post_mess"
    if [ -f "$GEN_LICENSE_DEFAULT_LICENSE" ]; then
      template="$GEN_LICENSE_DEFAULT_LICENSE"
    elif [ -f "$GEN_LICENSE_DIR_FILES/$default_file" ]; then
      template="$GEN_LICENSE_DIR_FILES/$default_file"
    elif [ -f "$GEN_LICENSE_DIR_FILES_CUSTOM/$default_file.$default_ext" ]; then
      template="$GEN_LICENSE_DIR_FILES_CUSTOM/$default_file.$default_ext"
    fi
    # Search default dir
  elif [ -f "$(__find $GEN_LICENSE_DIR_FILES/$default_file.$default_ext)" ]; then
    template="$(__find $GEN_LICENSE_DIR_FILES/${arg1:-$default_file}.$default_ext)"
    message="Using $LIC $post_mess"
    shift 1
  elif [ -f "$(__find $GEN_LICENSE_DIR_FILES/$default_file)" ]; then
    template="$(__find $GEN_LICENSE_DIR_FILES/$default_file)"
    message="Using $LIC $post_mess"
  elif [ -f "$(__find $GEN_LICENSE_DIR_FILES/$default_file.$default_ext)" ]; then
    template="$(__find $GEN_LICENSE_DIR_FILES/$default_file.$default_ext)"
    message="Using $LIC $post_mess)"
  else
    # Search Custom dir
    if [ -f "$(__find $GEN_LICENSE_DIR_FILES_CUSTOM/$default_file)" ]; then
      template="$(__find $GEN_LICENSE_DIR_FILES/$default_file)"
      message="Using $LIC $post_mess"
      shift 1
      if [ -f "$(__find $GEN_LICENSE_DIR_FILES_CUSTOM/$default_ext)" ]; then
        template="$(__find $GEN_LICENSE_DIR_FILES/$default_file.$default_ext)"
        message="Using $LIC $post_mess"
        shift 1
      elif [ -f "$(__find $GEN_LICENSE_DIR_FILES_CUSTOM/$default_file.$default_ext)" ]; then
        template="$(__find $GEN_LICENSE_DIR_FILES_CUSTOM/$default_file.$default_ext)"
        message="Using the default template: $(__find $GEN_LICENSE_DIR_FILES/$default_file.$default_ext)"
      fi
    else
      printf_exit 1 1 "Can not find any readmes matching $1 ${2:-$default_file}.$default_ext"
    fi
  fi
  printf_green "$message"
  template="${template:?}"
  #  printf_exit "$template"
  [ -f "$template" ] || __file_failed "$template"
  cat "$template" >"$GEN_LICENSE_WD/LICENSE.md" 2>/dev/null
  if [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && [ -s "$GEN_LICENSE_WD/LICENSE.md" ]; then
    _modify_license_file
    printf_green "Your LICENSE file has been created"
  else
    __file_failed "$1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Init
if [ ! -f "$GEN_LICENSE_SETTINGS_FILE" ] && [ ! -d "$GEN_LICENSE_DIR_FILES" ]; then
  if [ "$#" = 0 ]; then gen_config; fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -d "$GEN_LICENSE_DIR_FILES" ] && [ "$(__count_files "$GEN_LICENSE_DIR_FILES")" -ne 0 ]; then
  GEN_LICENSE_REPO_RAW="$GEN_LICENSE_DIR_FILES"
elif [ -d "$CASJAYSDEVDIR/templates/licenses" ]; then
  GEN_LICENSE_REPO_RAW="$CASJAYSDEVDIR/templates/licenses"
else
  get_lic() { get_remote_file "$1"; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Main
case "${GETOPTS:-$GEN_LICENSE_WHICH_FILE}" in
-list)
  shift 1
  if [ "$(__count_files "$GEN_LICENSE_DIR_FILES")" -eq 0 ]; then
    cat "${CASJAYSDEVDIR}/helpers/gen-license/array" | printf_readline "2"
  else
    __find "$GEN_LICENSE_DIR_FILES" | printf_readline "2"
    [ "$(__count_files "$GEN_LICENSE_DIR_FILES_CUSTOM")" -eq 0 ] ||
      __find "$GEN_LICENSE_DIR_FILES_CUSTOM" | printf_readline "2"
  fi
  exit $?
  ;;

-config)
  shift 1
  if [ "$GEN_LICENSE_DEFAULT_LICENSE" = "config" ] || [ "$GEN_LICENSE_FILE" = "config" ]; then
    license="$WHICH_LICENSE_DEF"
  else
    license="$GEN_LICENSE_DEFAULT_LICENSE"
  fi
  gen_config
  exit $?
  ;;

-copy)
  copy_templates
  exit $?
  ;;

-download)
  shift 1
  tmpfolder="/tmp/licenses.$$"
  printf_green "Cloning the repo to $tmpfolder"
  __git_clone "$GEN_LICENSE_REPO_RAW" "$tmpfolder"
  printf_green "Copying files to $GEN_LICENSE_DIR_FILES_CUSTOM"
  __cp_rf "$tmpfolder/files/." "$GEN_LICENSE_DIR_FILES_CUSTOM/"
  __rm_rf "$tmpfolder"
  if [ -d "$GEN_LICENSE_DIR_FILES_CUSTOM" ] && [ "$(__count_files "$GEN_LICENSE_DIR_FILES_CUSTOM" "2")" -ne 0 ]; then
    printf_green "Done cloning and copying the files"
  else
    printf_red "Failed to setup custom license files"
  fi
  ;;

custom)
  shift 1
  if [ -f "$1" ]; then
    create_local_file "$1"
  else
    get_remote_file "$1"
  fi
  ;;

*)
  shift
  get_lic "$@"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
exit $?
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
