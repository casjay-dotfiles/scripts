user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE"
  [ -d "$GEN_LICENSE_CONFIG_DIR" ] || mkdir -p "$GEN_LICENSE_CONFIG_DIR"
  [ -d "$GEN_LICENSE_CONFIG_BACKUP_DIR" ] || mkdir -p "$GEN_LICENSE_CONFIG_BACKUP_DIR"
  [ -f "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE" ] &&
    cp -Rf "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE" "$GEN_LICENSE_CONFIG_BACKUP_DIR/$GEN_LICENSE_CONFIG_FILE.$$"
  cat <<EOF >"$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE"
# Settings for gen-license
# Default directory
GEN_LICENSE_CONFIG_DIR="${GEN_LICENSE_CONFIG_DIR:-$HOME/.config/myscripts/gen-license}"
# Default extension
GEN_LICENSE_DEFAULT_LICENSE_EXT="${GEN_LICENSE_DEFAULT_LICENSE_EXT:-md}"
# Default files directory
GEN_LICENSE_DIR_FILES="${GEN_LICENSE_DIR_FILES:-$GEN_LICENSE_CONFIG_DIR/files}"
# Default custom directory
GEN_LICENSE_DIR_FILES_CUSTOM="${GEN_LICENSE_DIR_FILES_CUSTOM:-$GEN_LICENSE_CONFIG_DIR/custom}"
# Default license
GEN_LICENSE_DEFAULT_LICENSE="${GEN_LICENSE_DEFAULT_LICENSE:-${GEN_LICENSE_DIR_FILES:-$CASJAYSDEVDIR/templates}/wtfpl}"
# Default git repo
GEN_LICENSE_REPO="${GEN_LICENSE_REPO:-https://github.com/devenvmgr/licenses}"
# Default Raw URL
GEN_LICENSE_REPO_RAW="${GEN_LICENSE_REPO_RAW:-https://github.com/devenvmgr/licenses/raw/main/files}"
# Default name
GEN_LICENSE_GIT_USER="${GEN_LICENSE_GIT_USER:-$USER}"
# Default e-mail
GEN_LICENSE_GIT_EMAIL="${GEN_LICENSE_GIT_EMAIL:-$USER@$HOSTNAME}"

# Notification settings
GEN_LICENSE_GOOD_MESSAGE="${GEN_LICENSE_GOOD_MESSAGE:-Everything Went OK}"
GEN_LICENSE_ERROR_MESSAGE="${GEN_LICENSE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_LICENSE_NOTIFY_ENABLED="${GEN_LICENSE_NOTIFY_ENABLED:-yes}"
GEN_LICENSE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_LICENSE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_LICENSE_NOTIFY_CLIENT_ICON}"

# Colorization settings
GEN_LICENSE_OUTPUT_COLOR="${GEN_LICENSE_OUTPUT_COLOR:-5}"
GEN_LICENSE_OUTPUT_COLOR_GOOD="${GEN_LICENSE_OUTPUT_COLOR_GOOD:-2}"
GEN_LICENSE_OUTPUT_COLOR_ERROR="${GEN_LICENSE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE" ]; then
    . "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE"
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      copy_templates &>/dev/null
      exec $APPNAME "$*"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__file_failed() {
  printf_error "Failed to get the license file"
  printf_exit 1 1 "from: $1"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
get_remote_file() {
  local filename="$1"
  local name="$(__basename "$filename")"
  local default_ext="$GEN_LICENSE_DEFAULT_LICENSE_EXT"
  check_uri "$1" filename="$1" || filename="$GEN_LICENSE_REPO_RAW/$name.$default_ext"
  [[ "$filename" = -q ]] || printf_green "Attempting to get $filename"
  __urlverify "$filename" && __curl "$filename" | tee "$GEN_LICENSE_DIR_FILES_CUSTOM/$name" &>/dev/null
  if [ -f "$GEN_LICENSE_DIR_FILES_CUSTOM/$name" ] && [[ -s "$GEN_LICENSE_DIR_FILES_CUSTOM/$name" ]]; then
    printf_cyan "Successfully saved $name to $GEN_LICENSE_DIR_FILES_CUSTOM"
    create_local_file "$GEN_LICENSE_DIR_FILES_CUSTOM/$name"
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__replace() { $sed -i 's|'"$1"'|'"$2"'|g' "$3" &>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
copy_templates() {
  local TEMPLATE_REPO=""
  printf_green "Installing the license files to:"
  printf_blue "$GEN_LICENSE_DIR_FILES"
  if am_i_online; then
    if [ -d "$GEN_LICENSE_CONFIG_DIR/gitrepo/.git" ]; then
      git -C "$GEN_LICENSE_CONFIG_DIR/gitrepo" pull -q &>/dev/null
      TEMPLATE_REPO="$(__git_remote_fetch $GEN_LICENSE_CONFIG_DIR/gitrepo)"
    else
      if git clone -q "$GEN_LICENSE_REPO" "$GEN_LICENSE_CONFIG_DIR/gitrepo" &>/dev/null; then
        TEMPLATE_REPO="$GEN_LICENSE_REPO"
      else
        __cp_rf "${CASJAYSDEVDIR}/templates/licenses/." "$GEN_LICENSE_DIR_FILES/"
        TEMPLATE_REPO="${CASJAYSDEVDIR}/templates/licenses"
      fi
    fi
  else
    if [ -d "${CASJAYSDEVDIR}/templates/licenses" ]; then
      __cp_rf "${CASJAYSDEVDIR}/templates/licenses/." "$GEN_LICENSE_DIR_FILES/"
      TEMPLATE_REPO="${CASJAYSDEVDIR}/templates/licenses"
    else
      printf_exit 1 1 "Can not get license files"
    fi
  fi
  if [ -d "$GEN_LICENSE_CONFIG_DIR/gitrepo/files" ]; then
    __cp_rf "$GEN_LICENSE_CONFIG_DIR/gitrepo/files/." "$GEN_LICENSE_DIR_FILES/"
  fi
  if [ "$(__count_files "$GEN_LICENSE_DIR_FILES" "2")" -ne 0 ]; then
    printf_green "Successfully copied the template files"
  else
    if [ "$(__count_files "$GEN_LICENSE_DIR_FILES" "2")" -eq 0 ]; then
      printf_red "could not copy the license files"
      printf_red "from $TEMPLATE_REPO"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_modify_license_file() {
  if [ -f "$GEN_LICENSE_WD/LICENSE.md" ]; then
    if grep -iq 'What The Fuck Public License' "$GEN_LICENSE_WD/LICENSE.md"; then
      __replace "CURYEAR " "$(date +'%Y') " "$GEN_LICENSE_WD/LICENSE.md"
      __replace "AuthorName" "$GEN_LICENSE_GIT_USER" "$GEN_LICENSE_WD/LICENSE.md"
      __replace " 2004 " " $(date +'%Y') " "$GEN_LICENSE_WD/LICENSE.md"
      __replace "Sam Hocevar" "$GEN_LICENSE_GIT_USER" "$GEN_LICENSE_WD/LICENSE.md"
      __replace "sam@hocevar.net" "$GEN_LICENSE_GIT_EMAIL" "$GEN_LICENSE_WD/LICENSE.md"
    fi
    __replace "GEN_LICENSE_REPLACE_YEAR" "$(date +'%Y')" "$GEN_LICENSE_WD/LICENSE.md"
    __replace "GEN_LICENSE_REPLACE_AUTHOR" "$GEN_LICENSE_GIT_USER" "$GEN_LICENSE_WD/LICENSE.md"
    __replace "GEN_LICENSE_REPLACE_EMAIL" "$GEN_LICENSE_GIT_EMAIL" "$GEN_LICENSE_WD/LICENSE.md"
  else
    printf_exit "Failed to find the file at $GEN_LICENSE_WD/LICENSE.md"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
create_local_file() {
  local default_file="$(basename ${1:-$GEN_LICENSE_DEFAULT_LICENSE} 2>/dev/null)"
  local default_ext="${GEN_LICENSE_DEFAULT_LICENSE_EXT:-md}"
  local post_mess="license for $GEN_LICENSE_WD"
  local license_base="$(basename "${default_file^^*}" 2>/dev/null)"
  local license_name="${license_base%.*}"
  # Search default dir - no extension
  if [ -f "$GEN_LICENSE_DIR_FILES/${default_file//$GEN_LICENSE_DIR_FILES\//}" ]; then
    template="$GEN_LICENSE_DIR_FILES/${default_file//$GEN_LICENSE_DIR_FILES\//}"
    message="Using $license_name $post_mess"
  # Search custom dir - no extension
  elif [ -f "$GEN_LICENSE_DIR_FILES_CUSTOM/${default_file//$GEN_LICENSE_DIR_FILES\//}" ]; then
    template="$GEN_LICENSE_DIR_FILES_CUSTOM/${default_file//$GEN_LICENSE_DIR_FILES\//}"
    message="Using $license_name $post_mess"
  # Search default dir - default extension
  elif [ -f "$GEN_LICENSE_DIR_FILES/${default_file//$GEN_LICENSE_DIR_FILES\//}.$default_ext" ]; then
    template="$GEN_LICENSE_DIR_FILES/${default_file//$GEN_LICENSE_DIR_FILES\//}.$default_ext"
    message="Using $license_name $post_mess"
  # Search custom dir - default extension
  elif [ -f "$GEN_LICENSE_DIR_FILES_CUSTOM/${default_file//$GEN_LICENSE_DIR_FILES\//}.$default_ext" ]; then
    template="$GEN_LICENSE_DIR_FILES_CUSTOM/${default_file//$GEN_LICENSE_DIR_FILES\//}.$default_ext"
    message="Using $license_name $post_mess"
  # Default license file - no extension
  elif [ -f "$GEN_LICENSE_DIR_FILES/${GEN_LICENSE_DEFAULT_LICENSE//$GEN_LICENSE_DIR_FILES\//}" ]; then
    template="$GEN_LICENSE_DIR_FILES/${GEN_LICENSE_DEFAULT_LICENSE//$GEN_LICENSE_DIR_FILES\//}"
    message="Using Default $GEN_LICENSE_DEFAULT_LICENSE $post_mess"
  # Default license file - default extension
  elif [ -f "$GEN_LICENSE_DIR_FILES/${GEN_LICENSE_DEFAULT_LICENSE//$GEN_LICENSE_DIR_FILES\//}.$default_ext" ]; then
    template="$GEN_LICENSE_DIR_FILES/${GEN_LICENSE_DEFAULT_LICENSE//$GEN_LICENSE_DIR_FILES\//}.$default_ext"
    message="Using Default $GEN_LICENSE_DEFAULT_LICENSE $post_mess"
  # Attempt url
  elif get_remote_file "$GEN_LICENSE_REPO_RAW/$default_file.$default_ext" -q; then
    template="$GEN_LICENSE_DIR_FILES_CUSTOM/$default_file.$default_ext"
    message="Using file from $GEN_LICENSE_DIR_FILES_CUSTOM/$default_file.$default_ext"
  else
    printf_exit 1 1 "Can not find any readmes matching $1 ${2:-$default_file}.$default_ext"
  fi
  printf_green "$message"
  template="${template:-$GEN_LICENSE_DEFAULT_LICENSE}"
  [ -f "$template" ] || __file_failed "$template"
  cat "$template" >"$GEN_LICENSE_WD/LICENSE.md" 2>/dev/null
  if [ -f "$GEN_LICENSE_WD/LICENSE.md" ] && [ -s "$GEN_LICENSE_WD/LICENSE.md" ]; then
    _modify_license_file
    printf_green "Your LICENSE file has been created"
  else
    __file_failed "$1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
GEN_LICENSE_LOG_DIR="${GEN_LICENSE_LOG_DIR:-$HOME/.local/log/gen-license}"
GEN_LICENSE_CACHE_DIR="${GEN_LICENSE_CACHE_DIR:-$HOME/.cache/gen-license}"
GEN_LICENSE_CONFIG_DIR="${GEN_LICENSE_CONFIG_DIR:-$HOME/.config/myscripts/gen-license}"
GEN_LICENSE_CONFIG_BACKUP_DIR="${GEN_LICENSE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/gen-license/backups}"
GEN_LICENSE_TEMP_DIR="${GEN_LICENSE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/gen-license}"
GEN_LICENSE_OPTIONS_DIR="${GEN_LICENSE_OPTIONS_DIR:-$HOME/.local/share/myscripts/gen-license/options}"
GEN_LICENSE_TEMP_FILE="${GEN_LICENSE_TEMP_FILE:-$(mktemp $GEN_LICENSE_TEMP_DIR/XXXXXX 2>/dev/null)}"
GEN_LICENSE_CONFIG_FILE="${GEN_LICENSE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
GEN_LICENSE_OUTPUT_COLOR="${GEN_LICENSE_OUTPUT_COLOR:-4}"
GEN_LICENSE_OUTPUT_COLOR_2="${GEN_LICENSE_OUTPUT_COLOR:-6}"
GEN_LICENSE_OUTPUT_COLOR_GOOD="${GEN_LICENSE_OUTPUT_COLOR_GOOD:-2}"
GEN_LICENSE_OUTPUT_COLOR_ERROR="${GEN_LICENSE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
GEN_LICENSE_GOOD_MESSAGE="${GEN_LICENSE_GOOD_MESSAGE:-Everything Went OK}"
GEN_LICENSE_ERROR_MESSAGE="${GEN_LICENSE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_LICENSE_NOTIFY_ENABLED="${GEN_LICENSE_NOTIFY_ENABLED:-yes}"
GEN_LICENSE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_LICENSE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_LICENSE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
GEN_LICENSE_DIR_FILES="${GEN_LICENSE_DIR_FILES:-${GEN_LICENSE_DIR/files:-$CASJAYSDEVDIR/templates}}"
GEN_LICENSE_DIR_FILES_CUSTOM="${GEN_LICENSE_DIR_FILES_CUSTOM:-$GEN_LICENSE_CONFIG_DIR/custom}"
GEN_LICENSE_REPO="${GEN_LICENSE_REPO:-https://github.com/devenvmgr/licenses}"
GEN_LICENSE_REPO_RAW="${GEN_LICENSE_REPO_RAW:-https://github.com/devenvmgr/licenses/raw/main/files}"
GEN_LICENSE_GIT_USER="${GEN_LICENSE_GIT_USER:-$(__git_globaluser)}"
GEN_LICENSE_GIT_EMAIL="${GEN_LICENSE_GIT_EMAIL:-$(__git_globalemail)}"
GEN_LICENSE_DEFAULT_LICENSE="${GEN_LICENSE_DEFAULT_LICENSE:-${GEN_LICENSE_DIR_FILES:-$CASJAYSDEVDIR/templates}/wtfpl}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE" ] && . "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$GEN_LICENSE_LOG_DIR" ] || mkdir -p "$GEN_LICENSE_LOG_DIR" &>/dev/null
[ -d "$GEN_LICENSE_TEMP_DIR" ] || mkdir -p "$GEN_LICENSE_TEMP_DIR" &>/dev/null
[ -d "$GEN_LICENSE_CACHE_DIR" ] || mkdir -p "$GEN_LICENSE_CACHE_DIR" &>/dev/null
[ -d "$GEN_LICENSE_DIR_FILES" ] || mkdir -p "$GEN_LICENSE_DIR_FILES" &>/dev/null
[ -d "$GEN_LICENSE_DIR_FILES_CUSTOM" ] || mkdir -p "$GEN_LICENSE_DIR_FILES_CUSTOM" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$GEN_LICENSE_CONFIG_DIR/$GEN_LICENSE_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
if [ -d "$1" ]; then
  GEN_LICENSE_WD="$1"
  shift 1
elif [ "$1" = "-d" ] || [ "$1" = "-dir" ] || [ "$1" = "--dir" ]; then
  GEN_LICENSE_WD="$2"
  shift 2
  [ -d "$GEN_LICENSE_WD" ] || printf_exit "$GEN_LICENSE_WD doesn't seem to be a directory"
else
  GEN_LICENSE_WD="$PWD"
fi
[ "$GEN_LICENSE_WD" = "." ] && GEN_LICENSE_WD="$(__basedir ".")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,copy"
ARRAY="custom download list"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    { [ "$GEN_LICENSE_DEFAULT_LICENSE" = "config" ] || [ "$GEN_LICENSE_FILE" = "config" ]; } &&
      license="$WHICH_LICENSE_DEF" || license="$GEN_LICENSE_DEFAULT_LICENSE"
    __gen_config
    exit $?
    ;;
  --dir)
    GEN_LICENSE_CWD="$2"
    shift 2
    ;;
  --copy)
    copy_templates
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$GEN_LICENSE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${GEN_LICENSE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${GEN_LICENSE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${GEN_LICENSE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${GEN_LICENSE_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash curl git || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
GEN_LICENSE_CHOICE="${1:-$GEN_LICENSE_DEFAULT_LICENSE}"
GEN_LICENSE_FILE="$(basename ${GEN_LICENSE_CHOICE:-$WHICH_LICENSE_DEF} 2>/dev/null)"
GEN_LICENSE_WHICH_FILE="$(echo "${1:-$GEN_LICENSE_FILE}" | tr [A-Z] [a-z])"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "${1:-$GEN_LICENSE_WHICH_FILE}" in
list)
  shift 1
  if [ "$(__count_files "$GEN_LICENSE_DIR_FILES")" -eq 0 ]; then
    cat "${CASJAYSDEVDIR}/helpers/gen-license/array" | printf_readline "2"
  else
    __find "$GEN_LICENSE_DIR_FILES" | printf_readline "2"
    [ "$(__count_files "$GEN_LICENSE_DIR_FILES_CUSTOM")" -eq 0 ] ||
      __find "$GEN_LICENSE_DIR_FILES_CUSTOM" | printf_readline "2"
  fi
  exit $?
  ;;

download)
  shift 1
  tmpfolder="/tmp/licenses.$$"
  printf_green "Cloning the repo to $tmpfolder"
  __git_clone "$GEN_LICENSE_REPO_RAW" "$tmpfolder"
  printf_green "Copying files to $GEN_LICENSE_DIR_FILES_CUSTOM"
  __cp_rf "$tmpfolder/files/." "$GEN_LICENSE_DIR_FILES_CUSTOM/"
  __rm_rf "$tmpfolder"
  if [ -d "$GEN_LICENSE_DIR_FILES_CUSTOM" ] && [ "$(__count_files "$GEN_LICENSE_DIR_FILES_CUSTOM" "2")" -ne 0 ]; then
    printf_green "Done cloning and copying the files"
  else
    printf_red "Failed to setup custom license files"
  fi
  ;;

custom)
  shift 1
  if [ -f "$1" ]; then
    create_local_file "$1"
  else
    get_remote_file "$1"
  fi
  ;;

*)
  create_local_file "$*"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
