# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : gen-nginx
# @Description   : Generate a nginx proxy host
# @TODO          : Add more config options
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GEN_NGINX_CONFIG_DIR/$GEN_NGINX_CONFIG_FILE"
  [ -d "$GEN_NGINX_CONFIG_DIR" ] || mkdir -p "$GEN_NGINX_CONFIG_DIR"
  [ -d "$GEN_NGINX_CONFIG_BACKUP_DIR" ] || mkdir -p "$GEN_NGINX_CONFIG_BACKUP_DIR"
  [ -f "$GEN_NGINX_CONFIG_DIR/$GEN_NGINX_CONFIG_FILE" ] &&
    cp -Rf "$GEN_NGINX_CONFIG_DIR/$GEN_NGINX_CONFIG_FILE" "$GEN_NGINX_CONFIG_BACKUP_DIR/$GEN_NGINX_CONFIG_FILE.$$"
  cat <<EOF | tee "$GEN_NGINX_CONFIG_DIR/$GEN_NGINX_CONFIG_FILE" &>/dev/null
# Settings for gen-nginx
GEN_NGINX_WWW_USER_DIR="${GEN_NGINX_WWW_DIR_USER:-$GEN_NGINX_CONFIG_DIR/files/www}"
GEN_NGINX_VHOST_USER_DIR="${GEN_NGINX_VHOST_USER_DIR:-$GEN_NGINX_CONFIG_DIR/files/vhosts}"
GEN_NGINX_WWW_SYSTEM_DIR="${GEN_NGINX_WWW_DIR_ROOT:-/var/www/html}"
GEN_NGINX_VHOST_SYSTEM_DIR="${GEN_NGINX_VHOST_DIR_ROOT:-/etc/nginx/vhosts.d}"

# Notification settings
GEN_NGINX_GOOD_MESSAGE="${GEN_NGINX_GOOD_MESSAGE:-Everything Went OK}"
GEN_NGINX_ERROR_MESSAGE="${GEN_NGINX_ERROR_MESSAGE:-Well that didn\'t work}"
GEN_NGINX_NOTIFY_ENABLED="${GEN_NGINX_NOTIFY_ENABLED:-yes}"
GEN_NGINX_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_NGINX_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_NGINX_NOTIFY_CLIENT_ICON}"

# Colorization settings
GEN_NGINX_OUTPUT_COLOR="${GEN_NGINX_OUTPUT_COLOR:-5}"
GEN_NGINX_OUTPUT_COLOR_GOOD="${GEN_NGINX_OUTPUT_COLOR_GOOD:-2}"
GEN_NGINX_OUTPUT_COLOR_ERROR="${GEN_NGINX_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GEN_NGINX_CONFIG_DIR/$GEN_NGINX_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for gen-nginx has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__nginx_conf_dir() {
  if [[ -z "$GEN_NGINX_VHOST_USER_DIR" ]] || [[ -z "$GEN_NGINX_VHOST_SYSTEM_DIR" ]]; then
    printf_read_input "4" "Where are your nginx server files located?" "120" "GEN_NGINX_VHOST_USER_DIR" "-e"
    if [[ ! -d "$GEN_NGINX_VHOST_USER_DIR" ]]; then
      printf_exit "$GEN_NGINX_VHOST_USER_DIR is an invalid directory"
      exit 1
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__nginx_dom() {
  [[ -n "$NGINXDOMAIN" ]] || printf_read_input "4" "What is your domain name? " "120" "NGINXDOMAIN" "-i $(hostname -f) "
  [[ -n "$REVPROXYNAME" ]] || printf_read_input "4" "What is the name of the app? " "120" "REVPROXYNAME"
  [[ -n "$REVPROXY" ]] || printf_read_input "4" "What should I proxy for? " "120" "REVPROXY" "-i localhost "
  [[ -n "$REVPROXY_PORT" ]] || printf_read_input "4" "What is your port is your app listening on [3000]? " "120" "REVPROXY_PORT" "-i 3000 "
  [[ -n "$REVPROXY_PROTO" ]] || printf_read_input "4" "What is the protocol http[s]? " "120" "REVPROXY_PROTO" "-i http "
  # Sanity check
  [[ -n "$NGINXDOMAIN" ]] || printf_exit "domain name is required"
  [[ -n "$REVPROXYNAME" ]] || printf_exit "app name is required"
  [[ -n "$REVPROXY" ]] || printf_exit "reverse proxy host is required"
  [[ -n "$REVPROXY_PORT" ]] || printf_exit "reverse proxy port is required"
  export NGINXDOMAIN REVPROXYNAME REVPROXY REVPROXY_PORT REVPROXY_PROTO
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__nginx_conf_file() {
  if [ -f "$GEN_NGINX_CONFIG_DIR/template.conf" ]; then
    cat <<EOF | tee "$GEN_NGINX_VHOST_USER_DIR/$NGINXDOMAIN.conf" &>/dev/null
"$GEN_NGINX_CONFIG_DIR/template.conf"
EOF
  else
    if [ -d "/etc/letsencrypt/live/domain" ] || [ -d "/etc/letsencrypt/live/$(hostname -f)" ]; then
      cat <<EOF | tee "$GEN_NGINX_VHOST_USER_DIR/$NGINXDOMAIN.conf" &>/dev/null
#Define your primary service
# upstream $REVPROXYNAME { server $REVPROXY:$REVPROXY_PORT fail_timeout=0; }

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  ssl_protocols TLSv1 TLSv1.1 TLSv1.2; # Dropping SSLv3, ref: POODLE
  ssl_prefer_server_ciphers on;
  ssl_ciphers ECDHE-RSA-AES256-GCM-SHA512:DHE-RSA-AES256-GCM-SHA512:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-SHA384;
  ssl_session_timeout 1d;
  ssl_session_cache shared:SSL:50m;
  server_name $NGINXDOMAIN;
  access_log /var/log/nginx/access.log;
  error_log  /var/log/nginx/error.log info;
  keepalive_timeout 75 75;
  ssl_certificate /etc/letsencrypt/live/domain/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/domain/privkey.pem;
  add_header Strict-Transport-Security "max-age=7200";

  location / {
    proxy_redirect          http:// https://;
    proxy_pass              $REVPROXY_PROTO://$REVPROXY;
    proxy_ssl_verify        off;
    send_timeout            3600;
    client_max_body_size    1024M;
    proxy_connect_timeout   3600;
    proxy_send_timeout      3600;
    proxy_read_timeout      3600;
    proxy_http_version      1.1;
    proxy_request_buffering off;
    proxy_buffering         off;
    proxy_set_header        Host $host:$server_port;
    proxy_set_header        X-Real-IP $remote_addr;
    proxy_set_header        X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header        X-Forwarded-Proto $scheme;
    proxy_set_header        Upgrade $http_upgrade;
    proxy_set_header        Connection $connection_upgrade;
    }

#  location ~ ^/uri {
#    rewrite ^/(.*)$ /$1 break;
#    proxy_pass http://127.0.0.1:port/;
#    proxy_set_header X-Real-IP $remote_addr;
#    proxy_set_header Host $host;
#    proxy_redirect   off;
#    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#    }

#  location ~ ^/uri {
#    rewrite ^/(.*)$ http://$host:$port/ permanent;
#    }

    include /etc/nginx/global.d/nginx-defaults.conf;
    include /etc/nginx/global.d/nginx-defaults.conf;
    include /etc/nginx/global.d/cgi-bin.conf;
    include /etc/nginx/global.d/munin.conf;
    include /etc/nginx/global.d/vnstats.conf;
    include /etc/nginx/global.d/others.conf;
}
EOF
    else
      cat <<EOF | tee "$GEN_NGINX_VHOST_USER_DIR/$NGINXDOMAIN.conf" &>/dev/null
#Define your primary service
# upstream $REVPROXYNAME { server $REVPROXY:$REVPROXY_PORT fail_timeout=0; }

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  ssl_protocols TLSv1 TLSv1.1 TLSv1.2; # Dropping SSLv3, ref: POODLE
  ssl_prefer_server_ciphers on;
  ssl_ciphers ECDHE-RSA-AES256-GCM-SHA512:DHE-RSA-AES256-GCM-SHA512:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-SHA384;
  ssl_session_timeout 1d;
  ssl_session_cache shared:SSL:50m;
  server_name $NGINXDOMAIN;
  access_log /var/log/nginx/access.log;
  error_log  /var/log/nginx/error.log info;
  keepalive_timeout 75 75;
  ssl_certificate /etc/ssl/CA/CasjaysDev/certs/localhost.crt;
  ssl_certificate_key /etc/ssl/CA/CasjaysDev/private/localhost.key;
  add_header Strict-Transport-Security "max-age=7200";

  location / {
    proxy_redirect          http:// https://;
    proxy_pass              $REVPROXY_PROTO://$REVPROXY:$REVPROXY_PORT;
    proxy_ssl_verify        off;
    send_timeout            3600;
    client_max_body_size    1024M;
    proxy_connect_timeout   3600;
    proxy_send_timeout      3600;
    proxy_read_timeout      3600;
    proxy_http_version      1.1;
    proxy_request_buffering off;
    proxy_buffering         off;
    proxy_set_header        Host $host:$server_port;
    proxy_set_header        X-Real-IP $remote_addr;
    proxy_set_header        X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header        X-Forwarded-Proto $scheme;
    proxy_set_header        Upgrade $http_upgrade;
    proxy_set_header        Connection $connection_upgrade;
    }

#  location ~ ^/uri {
#    rewrite ^/(.*)$ /$1 break;
#    proxy_pass $REVPROXY_PROTO://$REVPROXY:$REVPROXY_PORT/;
#    proxy_set_header X-Real-IP $remote_addr;
#    proxy_set_header Host $host;
#    proxy_redirect   off;
#    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#    }

#  location ~ ^/uri {
#    rewrite ^/(.*)$ $REVPROXY_PROTO://$REVPROXY:$REVPROXY_PORT permanent;
#    }

    include /etc/nginx/global.d/nginx-defaults.conf;
    include /etc/nginx/global.d/nginx-defaults.conf;
    include /etc/nginx/global.d/cgi-bin.conf;
    include /etc/nginx/global.d/munin.conf;
    include /etc/nginx/global.d/vnstats.conf;
    include /etc/nginx/global.d/others.conf;
}
EOF

    fi
  fi
  printf_newline
  printf_head 4 "Setting up $NGINXDOMAIN.conf" "in $GEN_NGINX_VHOST_USER_DIR"
  if [ -f "$GEN_NGINX_VHOST_USER_DIR/$NGINXDOMAIN.conf" ]; then
    printf_green "Successfully created $GEN_NGINX_VHOST_USER_DIR/$NGINXDOMAIN.conf"
  else
    print_error "Failed to create $GEN_NGINX_VHOST_USER_DIR/$NGINXDOMAIN.conf"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__hosts() {
  grep "$REVPROXY" /etc/hosts &>/dev/null || echo "127.0.0.3      $REVPROXY" | sudo tee -a /etc/hosts &>/dev/null
  grep "$NGINXDOMAIN" /etc/hosts &>/dev/null || echo "127.0.0.3      $NGINXDOMAIN" | sudo tee -a /etc/hosts &>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
GEN_NGINX_LOG_DIR="${GEN_NGINX_LOG_DIR:-$HOME/.local/log/gen-nginx}"
GEN_NGINX_CACHE_DIR="${GEN_NGINX_CACHE_DIR:-$HOME/.cache/gen-nginx}"
GEN_NGINX_CONFIG_DIR="${GEN_NGINX_CONFIG_DIR:-$HOME/.config/myscripts/gen-nginx}"
GEN_NGINX_CONFIG_BACKUP_DIR="${GEN_NGINX_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/gen-nginx/backups}"
GEN_NGINX_TEMP_DIR="${GEN_NGINX_TEMP_DIR:-$HOME/.local/tmp/system_scripts/gen-nginx}"
GEN_NGINX_OPTIONS_DIR="${GEN_NGINX_OPTIONS_DIR:-$HOME/.local/share/myscripts/gen-nginx/options}"
GEN_NGINX_TEMP_FILE="${GEN_NGINX_TEMP_FILE:-$(mktemp $GEN_NGINX_TEMP_DIR/XXXXXX 2>/dev/null)}"
GEN_NGINX_CONFIG_FILE="${GEN_NGINX_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
GEN_NGINX_OUTPUT_COLOR="${GEN_NGINX_OUTPUT_COLOR:-4}"
GEN_NGINX_OUTPUT_COLOR_2="${GEN_NGINX_OUTPUT_COLOR:-6}"
GEN_NGINX_OUTPUT_COLOR_GOOD="${GEN_NGINX_OUTPUT_COLOR_GOOD:-2}"
GEN_NGINX_OUTPUT_COLOR_ERROR="${GEN_NGINX_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
GEN_NGINX_GOOD_MESSAGE="${GEN_NGINX_GOOD_MESSAGE:-Everything Went OK}"
GEN_NGINX_ERROR_MESSAGE="${GEN_NGINX_ERROR_MESSAGE:-Well that didn\'t work}"
GEN_NGINX_NOTIFY_ENABLED="${GEN_NGINX_NOTIFY_ENABLED:-yes}"
GEN_NGINX_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_NGINX_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_NGINX_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
GEN_NGINX_WWW_DIR_USER="${GEN_NGINX_WWW_DIR_USER:-$GEN_NGINX_CONFIG_DIR/files/www}"
GEN_NGINX_VHOST_USER_DIR="${GEN_NGINX_VHOST_USER_DIR:-$GEN_NGINX_CONFIG_DIR/files/vhosts}"
GEN_NGINX_WWW_DIR_SYSTEM="${GEN_NGINX_WWW_DIR_ROOT:-/var/www/html}"
GEN_NGINX_VHOST_SYSTEM_DIR="${GEN_NGINX_VHOST_DIR_ROOT:-/etc/nginx/vhosts.d}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GEN_NGINX_CONFIG_DIR/$GEN_NGINX_CONFIG_FILE" ] && . "$GEN_NGINX_CONFIG_DIR/$GEN_NGINX_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$GEN_NGINX_LOG_DIR" ] || mkdir -p "$GEN_NGINX_LOG_DIR" &>/dev/null
[ -d "$GEN_NGINX_TEMP_DIR" ] || mkdir -p "$GEN_NGINX_TEMP_DIR" &>/dev/null
[ -d "$GEN_NGINX_CACHE_DIR" ] || mkdir -p "$GEN_NGINX_CACHE_DIR" &>/dev/null
[ -d "$GEN_NGINX_WWW_DIR_USER" ] || mkdir -p "$GEN_NGINX_WWW_DIR_USER" &>/dev/null
[ -d "$GEN_NGINX_VHOST_USER_DIR" ] || mkdir -p "$GEN_NGINX_VHOST_USER_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$GEN_NGINX_CONFIG_DIR/$GEN_NGINX_CONFIG_FILE" ] || INIT_CONFIG=TRUE __gen_config "${SETARGS:-$*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    GEN_NGINX_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$GEN_NGINX_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${GEN_NGINX_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${GEN_NGINX_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${GEN_NGINX_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${GEN_NGINX_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
NGINXDOMAIN="${NGINXDOMAIN:-$1}"
REVPROXYNAME="${REVPROXYNAME:-$2}"
REVPROXY="${REVPROXY:-$3}"
REVPROXY_PORT="${REVPROXY_PORT:-$4}"
REVPROXY_PROTO="${REVPROXY_PROTO:-$5}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__nginx_dom
__nginx_conf_dir
__nginx_conf_file "$@"
if [ "$GEN_NGINX_VHOST_USER_DIR/$NGINXDOMAIN.conf" != "$GEN_NGINX_VHOST_SYSTEM_DIR/$NGINXDOMAIN.conf" ]; then
  if __can_i_sudo; then
    __requiresudo true
    __nginx_conf_dir
    sudo mkdir -p "$GEN_NGINX_VHOST_SYSTEM_DIR"
    printf_green "Installing config to $GEN_NGINX_VHOST_SYSTEM_DIR/$NGINXDOMAIN.conf"
    sudo cp -f "$GEN_NGINX_VHOST_USER_DIR/$NGINXDOMAIN.conf" "$GEN_NGINX_VHOST_SYSTEM_DIR/$NGINXDOMAIN.conf"
    sudo systemctl status nginx | grep -iq 'active (running)' && sudo systemctl restart nginx
  fi
else
  printf_red "Can not install to system due to not enough privileges"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
