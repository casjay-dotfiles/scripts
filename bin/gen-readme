#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : gen-readme --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : gen-readme
# @Description   : Create a readme from template
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$GEN_README_TEMP_FILE" ] && [ -f "$GEN_README_TEMP_FILE" ] && rm -Rf "$GEN_README_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GEN_README_CONFIG_DIR/$GEN_README_CONFIG_FILE"
  [ -d "$GEN_README_CONFIG_DIR" ] || mkdir -p "$GEN_README_CONFIG_DIR"
  [ -d "$GEN_README_CONFIG_BACKUP_DIR" ] || mkdir -p "$GEN_README_CONFIG_BACKUP_DIR"
  [ -f "$GEN_README_CONFIG_DIR/$GEN_README_CONFIG_FILE" ] &&
    cp -Rf "$GEN_README_CONFIG_DIR/$GEN_README_CONFIG_FILE" "$GEN_README_CONFIG_BACKUP_DIR/$GEN_README_CONFIG_FILE.$$"
  cat <<EOF >"$GEN_README_CONFIG_DIR/$GEN_README_CONFIG_FILE"
# Settings for gen-readme
GEN_README_FILE_DIR="${GEN_README_FILE_DIR:-$GEN_README_CONFIG_DIR/files}"
GEN_README_DEFAULT_README="${GEN_README_DEFAULT_README:-default.md}"
GEN_README_GIT_REPO="${GEN_README_GIT_REPO:-https://github.com/devenvmgr/readmes}"
GEN_README_GIT_USER="${GEN_README_GIT_USER:-$(__git_globaluser)}"
GEN_README_GIT_EMAIL="${GEN_README_GIT_EMAIL:-$(__git_globalemail)}"
GEN_README_REPLACE_DEFAULT_BRANCH="${GEN_README_REPLACE_DEFAULT_BRANCH:-main}"

# Notification settings
GEN_README_GOOD_MESSAGE="${GEN_README_GOOD_MESSAGE:-Everything Went OK}"
GEN_README_ERROR_MESSAGE="${GEN_README_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_README_NOTIFY_ENABLED="${GEN_README_NOTIFY_ENABLED:-yes}"
GEN_README_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_README_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_README_NOTIFY_CLIENT_ICON}"

# Colorization settings
GEN_README_OUTPUT_COLOR="${GEN_README_OUTPUT_COLOR:-5}"
GEN_README_OUTPUT_COLOR_GOOD="${GEN_README_OUTPUT_COLOR_GOOD:-2}"
GEN_README_OUTPUT_COLOR_ERROR="${GEN_README_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GEN_README_CONFIG_DIR/$GEN_README_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for gen-readme has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__copy_templates() {
  printf_green "Installing the readme files"
  if [ -d "$GEN_README_FILE_DIR/.git" ]; then
    git -C "$GEN_README_FILE_DIR" pull -q
  elif [ -d "${CASJAYSDEVDIR}/templates/readmes" ]; then
    printf_green "Copying the template files"
    printf_yellow "from: $CASJAYSDEVDIR/templates/readmes"
    printf_yellow "to: $GEN_README_FILE_DIR"
    __cp_rf "$CASJAYSDEVDIR/templates/readmes/." "$GEN_README_FILE_DIR/"
    if [ "$(__count_files $GEN_README_FILE_DIR)" -ne 0 ]; then
      printf_green "Copying has succeeded"
    else
      printf_error "Copying of files has failed"
    fi
  else
    printf_error "Can not get readme files"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__sed() { $sed "$*" 2>/dev/null; }
__replace() { $sed -i 's|'"$1"'|'"$2"'|g' "$3" &>/dev/null; }
__list_available() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
__file_failed() { printf_exit "Failed to get the readme file: $readmeFile"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__findcmd() {
  find "$GEN_README_FILE_DIR" -type f ${1} -not -path "${GEN_README_FILE_DIR}/*/.git/*" 2>/dev/null |
    __sed 's|'$GEN_README_FILE_DIR/'||g' | sort -u
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
create_local_file() {
  cat "$1" >"$GEN_README_CWD/README.md" 2>/dev/null
  if [ -f "$GEN_README_CWD/README.md" ]; then
    printf_green "Your README file has been created"
  else
    __file_failed "$1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
get_remote_file() {
  __curl "$1" >"$GEN_README_CWD/README.md" 2>/dev/null
  if [ -f "$GEN_README_CWD/README.md" ]; then
    printf_green "Your README file has been created"
  else
    __file_failed "$1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
generate_readme() {
  local readmeFile="${1:-$GEN_README_DEFAULT_README}"
  local whichreadme="$(__strip_ext $readmeFile || exit 1)"
  local author="$GEN_README_GIT_USER"
  local GEN_README_CWD="$(dirname $GEN_README_CWD/README.md)"
  local BaseDir="$(basename "$GEN_README_CWD" 2>/dev/null)"
  printf_green "Dir:$GEN_README_CWD | Base:$BaseDir "
  if [ -f "$GEN_README_FILE_DIR/$readmeFile" ]; then
    printf_green "Using $whichreadme for $GEN_README_CWD"
    create_local_file "$GEN_README_FILE_DIR/$readmeFile"
    [ -f "${GEN_README_CWD}/README.md" ] && __replace "AuthorName" "${author}" "${GEN_README_CWD}/README.md"
    [ -f "${GEN_README_CWD}/README.md" ] && __replace "ProjectName" "${BaseDir}" "${GEN_README_CWD}/README.md"
    [ -f "${GEN_README_CWD}/README.md" ] && __replace "GEN_README_REPLACE_APPNAME" "${BaseDir}" "${GEN_README_CWD}/README.md"
    [ -f "${GEN_README_CWD}/README.md" ] && __replace "GEN_README_REPLACE_DEFAULT_BRANCH" "${GEN_README_REPLACE_DEFAULT_BRANCH}" "${GEN_README_CWD}/README.md"
    if [ -f "${GEN_README_CWD}/install.sh" ]; then
      local REPLACE_DESCRIBE="$(__grep_desc "${GEN_README_CWD}/install.sh")"
      __replace "GEN_README_REPLACE_DESCRIBE" "$REPLACE_DESCRIBE" "${GEN_README_CWD}/README.md"
    elif [ -f "$(type -P "${BaseDir}")" ]; then
      [ -d "$GEN_README_CWD/bin" ] && local PATH="$GEN_README_CWD/bin:$PATH"
      local command="$(type -P "${BaseDir}")"
      local REPLACE_DESCRIBE="$(__grep_desc "${command}")"
      __replace "GEN_README_REPLACE_DESCRIBE" "$REPLACE_DESCRIBE" "${GEN_README_CWD}/README.md"
    else
      __replace "GEN_README_REPLACE_DESCRIBE" "$BaseDir README" "${GEN_README_CWD}/README.md"
    fi
  else
    printf_exit 1 1 "$GEN_README_FILE_DIR/$readmeFile does not exist"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__find_readme() {
  arg1=${1// /\/}
  arg2=${2// /\/}
  arg3=${3// /\/}
  if [ -f "$(__find "$GEN_README_FILE_DIR/$arg1/$arg2/${arg3:-default}")" ]; then
    template="$(__find "$GEN_README_FILE_DIR/$arg1/$arg2/${arg3:-default}")"
    dest="${4:-$GEN_README_CWD/README.md}"
    shift 2
  elif [ -f "$(__find "$GEN_README_FILE_DIR/$arg1/${arg2:-default}")" ]; then
    template="$(__find "$GEN_README_FILE_DIR/$arg1/${arg2:-default}")"
    dest="${3:-$GEN_README_CWD/README.md}"
    shift 2
  elif [ -f "$(__find "$GEN_README_FILE_DIR/${arg1:-default}")" ]; then
    template="$(__find "$GEN_README_FILE_DIR/${arg1:-default}")"
    dest="${2:-$GEN_README_CWD/README.md}"
    shift 1
  elif [ -f "$(__find "$GEN_README_FILE_DIR/$GEN_README_DEFAULT_README")" ]; then
    printf_green "Using the default template: $(__find "$GEN_README_FILE_DIR/$GEN_README_DEFAULT_README")"
    template="$(__find "$GEN_README_FILE_DIR/$GEN_README_DEFAULT_README")"
    dest="${1:-$GEN_README_CWD/README.md}"
  else
    printf_exit 1 1 "Can not find any readmes matching $1 ${2:-$GEN_README_DEFAULT_README}"
  fi
  template="${template//$GEN_README_FILE_DIR\//}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
GEN_README_LOG_DIR="${GEN_README_LOG_DIR:-$HOME/.local/log/gen-readme}"
GEN_README_CACHE_DIR="${GEN_README_CACHE_DIR:-$HOME/.cache/gen-readme}"
GEN_README_CONFIG_DIR="${GEN_README_CONFIG_DIR:-$HOME/.config/myscripts/gen-readme}"
GEN_README_CONFIG_BACKUP_DIR="${GEN_README_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/gen-readme/backups}"
GEN_README_TEMP_DIR="${GEN_README_TEMP_DIR:-$HOME/.local/tmp/system_scripts/gen-readme}"
GEN_README_OPTIONS_DIR="${GEN_README_OPTIONS_DIR:-$HOME/.local/share/myscripts/gen-readme/options}"
GEN_README_TEMP_FILE="${GEN_README_TEMP_FILE:-$(mktemp $GEN_README_TEMP_DIR/XXXXXX 2>/dev/null)}"
GEN_README_CONFIG_FILE="${GEN_README_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
GEN_README_OUTPUT_COLOR="${GEN_README_OUTPUT_COLOR:-4}"
GEN_README_OUTPUT_COLOR_2="${GEN_README_OUTPUT_COLOR:-6}"
GEN_README_OUTPUT_COLOR_GOOD="${GEN_README_OUTPUT_COLOR_GOOD:-2}"
GEN_README_OUTPUT_COLOR_ERROR="${GEN_README_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
GEN_README_GOOD_MESSAGE="${GEN_README_GOOD_MESSAGE:-Everything Went OK}"
GEN_README_ERROR_MESSAGE="${GEN_README_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GEN_README_NOTIFY_ENABLED="${GEN_README_NOTIFY_ENABLED:-yes}"
GEN_README_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GEN_README_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GEN_README_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
GEN_README_FILE_DIR="${GEN_README_FILE_DIR:-$GEN_README_CONFIG_DIR/files}"
GEN_README_DEFAULT_README="${GEN_README_DEFAULT_README:-default.md}"
GEN_README_GIT_REPO="${GEN_README_GIT_REPO:-https://github.com/devenvmgr/readmes}"
GEN_README_GIT_USER="${GEN_README_GIT_USER:-$(__git_globaluser)}"
GEN_README_GIT_EMAIL="${GEN_README_GIT_EMAIL:-$(__git_globalemail)}"
GEN_README_REPLACE_DEFAULT_BRANCH="${GEN_README_REPLACE_DEFAULT_BRANCH:-main}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GEN_README_CONFIG_DIR/$GEN_README_CONFIG_FILE" ] && . "$GEN_README_CONFIG_DIR/$GEN_README_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$GEN_README_LOG_DIR" ] || mkdir -p "$GEN_README_LOG_DIR" &>/dev/null
[ -d "$GEN_README_TEMP_DIR" ] || mkdir -p "$GEN_README_TEMP_DIR" &>/dev/null
[ -d "$GEN_README_CACHE_DIR" ] || mkdir -p "$GEN_README_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$GEN_README_CONFIG_DIR/$GEN_README_CONFIG_FILE" ] || [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,copy"
ARRAY="list,search,download,custom,all"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    GEN_README_CWD="$2"
    shift 2
    ;;
  --copy)
    shift 1
    __copy_templates
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$GEN_README_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${GEN_README_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${GEN_README_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${GEN_README_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${GEN_README_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -d "$1" ]; then
  GEN_README_CWD="$1"
  shift 1
else
  GEN_README_CWD="$PWD"
fi
if [ "$GEN_README_CWD" = "." ]; then GEN_README_CWD="$(__basedir ".")"; fi
if [[ "$1" != *-copy ]] || [[ "$1" != *-config ]]; then
  if [ "$(__count_files "$GEN_README_FILE_DIR")" -eq 0 ]; then
    __mkd "$GEN_README_FILE_DIR"
    if [ "$(__count_files "$CASJAYSDEVDIR/templates/readmes")" -ne 0 ]; then
      __copy_templates &>/dev/null
    else
      printf_exit "1" "1" "No readme files exist"
    fi
  fi
fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
list)
  shift 1
  __findcmd "${1:-}" | printf_column "2"
  ;;

search)
  shift 1
  __findcmd | grep -i "${1:-*}" | printf_column "2"
  ;;

download)
  shift 1
  printf_green "Cloning the repo to $GEN_README_FILE_DIR/"
  if __git_clone "${1:-$GEN_README_GIT_REPO}" /tmp/readme_clone; then
    __mkd "$GEN_README_FILE_DIR/"
    __cp_rf /tmp/readme_clone/files/. "$GEN_README_FILE_DIR/"
    __rm_rf /tmp/readme_clone
  else
    __copy_templates
  fi
  exit $?
  ;;

custom)
  shift 1
  __find_readme "$@"
  if [ -f "$readmeFile" ]; then
    generate_readme "$readmeFile"
  else
    get_remote_file "$1"
  fi
  ;;

all)
  shift 1
  __find_readme "$@"
  generate_readme "$template"
  ;;

*)
  if [ $# = 0 ]; then
    __help
  else
    __find_readme "$@"
    generate_readme "$template"
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
