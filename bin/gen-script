# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
#exit \${exitCode:-$?}

EOF
  else
    cat <<EOF
#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME_README="$GEN_SCRIPT_REPLACE_APPNAME"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : $GEN_SCRIPT_VERSION
# @Author        : $GEN_SCRIPT_AUTHOR
# @Contact       : $GEN_SCRIPT_EMAIL
# @License       : $GEN_SCRIPT_DEFLICENSE
# @ReadME        : $(__filename $GEN_SCRIPT_NEWFILE 2>/dev/null) --help
# @Copyright     : $GEN_SCRIPT_COPYRIGHT
# @Created       : $GEN_SCRIPT_CREATED
# @File          : $(__filename $GEN_SCRIPT_NEWFILE 2>/dev/null)
# @Description   : ${desc:-$get_desc}
# @TODO          : ${todo:-$get_todo}
# @Other         : ${other:-$get_other}
# @Resource      : ${res:-$get_res}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set variables
__heading="- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__sed_head() { sed 's#..* :##g;s#^ ##g'; }
__grep_head() { grep -sE '[".#]?@[A-Z]' "\$(type -P "\${2:-\$GEN_SCRIPT_REPLACE_FILENAME}")" | grep "\${1:-}"; }
__version() { __grep_head 'Version' "\$(type -P "$GEN_SCRIPT_REPLACE_FILENAME")" | __sed_head | head -n1 | grep '^'; }
__printf_color() { printf "%b" "\$(tput setaf "\$2" 2>/dev/null)" "\$1" "\$(tput sgr0 2>/dev/null)"; }
__printf_head() { __printf_color "\n\t\t\$__heading\n\t\t\$2\n\t\t\$__heading\n" "\$1"; }
__printf_help() {
  test -n "\$1" && test -z "\${1//[0-9]/}" && local color="\$1" && shift 1 || local color="4"
  local msg="\$*"
  shift
  __printf_color "\t\t\$msg\n" "\$color"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
printf '\n'
