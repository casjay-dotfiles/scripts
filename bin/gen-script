# end help
printf '\n'
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit "\${exitCode:-$?}"

EOF
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__file_is() {
  if [ "$filetype" = "$1" ]; then
    if [ -f "$newcmd" ]; then
      local GEN_SCRIPT_REPLACE_license="$(__get_header 'License' "$new" || echo)"
      local GEN_SCRIPT_REPLACE_readme="$(__get_header 'ReadME' "$new" || echo)"
      local GEN_SCRIPT_REPLACE_desc="$(__get_header 'Description ' "$new" || echo)"
      local GEN_SCRIPT_REPLACE_todo="$(__get_header 'TODO ' "$new" || echo)"
      local GEN_SCRIPT_REPLACE_other="$(__get_header 'Other ' "$new" || echo)"
      local GEN_SCRIPT_REPLACE_resource="$(__get_header 'Resource ' "$new" || echo)"
      local license="$(__get_header 'License ' "$newcmd" || echo)"
      local readme="$(__get_header 'ReadME ' "$newcmd" || echo)"
      local desc="$(__get_header 'Description ' "$newcmd" || echo)"
      local todo="$(__get_header 'TODO ' "$newcmd" || echo)"
      local other="$(__get_header 'Other ' "$newcmd" || echo)"
      local resource="$(__get_header 'Resource' "$newcmd" || echo)"
    fi
    [ -n "$license" ] && [ -n "$GEN_SCRIPT_REPLACE_license" ] && __sed "$GEN_SCRIPT_REPLACE_license" "$license" "$new"
    [ -n "$readme" ] && [ -n "$GEN_SCRIPT_REPLACE_readme" ] && __sed "$GEN_SCRIPT_REPLACE_readme" "$readme" "$new"
    [ -n "$desc" ] && [ -n "$GEN_SCRIPT_REPLACE_desc" ] && __sed "$GEN_SCRIPT_REPLACE_desc" "$desc" "$new"
    [ -n "$todo" ] && [ -n "$GEN_SCRIPT_REPLACE_todo" ] && __sed "$GEN_SCRIPT_REPLACE_todo" "$todo" "$new"
    [ -n "$other" ] && [ -n "$GEN_SCRIPT_REPLACE_other" ] && __sed "$GEN_SCRIPT_REPLACE_other" "$other" "$new"
    [ -n "$resource" ] && [ -n "$GEN_SCRIPT_REPLACE_resource" ] && __sed "$GEN_SCRIPT_REPLACE_resource" "$resource" "$new"
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__makefile() {
  local temp="$1"
  local new="${newfile:-$2}"
  local newdir="$(__dirname "$new")"
  local newfile="$(basename "$2" 2>/dev/null)"
  shift $#
  __mkd "$newdir"
  __vars "$new"
  __cp_rf "$temp" "$new" || return 1
  __get_prev "$new" || return 1
  __edit_header "$new" || return 1
  local newcmd="$(command -v "$new" || type -P "$new" || ls -A "$new")"
  chmod -f 755 "$new" || return 1
  if __file_is "completion"; then
    local compfile="_$(basename "$new" 2>/dev/null)_completions"
    local destfolder="$(dirname "$new")"
    printf_cyan "Creating and moving the completion file:"
    printf_yellow "$destfolder/$compfile"
    __mkd "$destfolder" &&
      __mv_f "$new" "$destfolder/$compfile" &&
      new="$destfolder/$compfile" &&
      filename="$compfile" &&
      chmod 664 "$destfolder/$filename" && exitCode=0 || exitCode=1
  else
    exitCode=0
  fi
  [ ${exitCode:-$?} -ne 0 ] && printf_red "Failed to create $new" || printf_green "Your ${filetype:-script} has been created"
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__edit_header() {
  local GEN_SCRIPT_NEWFILE="$1"
  local GEN_SCRIPT_NEWFILE_FULL="$(__get_full_file "$1")"
  local GEN_SCRIPT_NEWFILE_SHORT="$(basename "$1" 2>/dev/null)"
  local GEN_SCRIPT_FULLPATH="$(__fullfilename "$1")"
  local GEN_SCRIPT_NEWFILEDIR="$(__dirname $GEN_SCRIPT_NEWFILE_FULL)"
  local GEN_SCRIPT_NEWFILEDIR="${GEN_FILENAME:-$GEN_SCRIPT_NEWFILEDIR}"
  local GEN_SCRIPT_REPLACE_CONFIG_DIR="$(__gen_env_vars "$GEN_SCRIPT_NEWFILE_SHORT")_CONFIG_DIR"
  local GEN_SCRIPT_REPLACE_CONFIG_FILE="$(__gen_env_vars "$GEN_SCRIPT_NEWFILE_SHORT")_CONFIG_FILE"
  local GEN_SCRIPT_REPLACE_OPTIONS_DIR="$(__gen_env_vars "$GEN_SCRIPT_NEWFILE_SHORT")_OPTIONS_DIR"
  local GEN_SCRIPT_REPLACE_ENV="$(__gen_env_vars "$GEN_SCRIPT_NEWFILE_SHORT")"
  __vars "$*"
  [ -f "$GEN_SCRIPT_NEWFILE" ] && printf_green "Editing the header info" || printf_exit 1 1 "Failed to created the file"
  __sed "GEN_SCRIPT_REPLACE_APPNAME" "${GEN_SCRIPT_NEWFILEDIR##*/}" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_DEFAULT_BRANCH" "$GEN_SCRIPT_GIT_DEFAULT_BRANCH" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_OPTIONS_DIR" "$GEN_SCRIPT_REPLACE_OPTIONS_DIR" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_CONFIG_DIR" "$GEN_SCRIPT_REPLACE_CONFIG_DIR" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_CONFIG_FILE" "$GEN_SCRIPT_REPLACE_CONFIG_FILE" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_ENV" "$GEN_SCRIPT_REPLACE_ENV" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_COPYRIGHT" "$GEN_SCRIPT_COPYRIGHT" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_VERSION" "$GEN_SCRIPT_VERSION" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_FILENAME" "$(__filename "$GEN_SCRIPT_NEWFILE")" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_FULLFILENAME" "$GEN_SCRIPT_FULLPATH" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_VERSION" "$GEN_SCRIPT_VERSION" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_DATE" "$GEN_SCRIPT_CREATED" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_LICENSE" "$GEN_SCRIPT_DEFLICENSE" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_README" "$GEN_SCRIPT_DEFREADME" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_AUTHOR" "$GEN_SCRIPT_AUTHOR" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_EMAIL" "$GEN_SCRIPT_EMAIL" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_YEAR" "$GEN_SCRIPT_YEAR" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_DESC" "${desc:-$get_desc}" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_TODO" "${todo:-$get_todo}" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_OTHER" "${other:-$get_other}" "$GEN_SCRIPT_NEWFILE"
  __sed "GEN_SCRIPT_REPLACE_RES" "${res:-$get_res}" "$GEN_SCRIPT_NEWFILE"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_header_help() {
  printf_head "Usage: gen-script -head filename options"
  printf_blue "-h, --help                  -  Show this message"
  printf_blue "-a, --all                   -  Show options"
  printf_blue "-f, --functions             -  Shows functions"
  printf_blue "-d, --description           -  Creates the description for file header"
  printf_blue "-t, --todo                  -  Add a TODO to file header"
  printf_blue "-c, --copy                  -  Adds a copyrigth to file header"
  printf_blue "-o, --other                 -  Adds an other to the file header"
  printf_blue "-r, --res                   -  Adds resources to the file header"
  printf_blue "-i, --type                  -  Adds type to functions: user system"
  printf_blue "-p, --prev                  -  Will set header based on an existing file"
  printf_blue "-u, --user                  -  Generate a script for suitable for local user"
  printf_blue "-l, --license               -  Adds the license type to header"
  printf_blue "-e, --no                    -  Don't ask to edit file"
  printf_blue "-k, --keep                  -  Will not overwrite an existing file"
  printf_blue "--replace                   -  Imports and creates a new header to replace an older one"
  printf_blue "--raw                       -  Generate a raw header"
  printf_newline
  printf_blue "types: devenvmgr dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr"
  exit 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_header() {
  [ -z "$pause" ] || { clear && printf_newline "\n\n\n"; }
  rerun() {
    unset gen_header_replace exitCode
    rerun=true
    __gen_header
    exit $?
  }
  if [ "$rerun" != "true" ]; then
    __set_header "$@"
    __vars "$filename"
    printf_green "New header info for $filename"
    __get_prev "$filename"
    [ -n "$gen_header_raw" ] && filename=template
    local GEN_SCRIPT_DEFREADME="$(__filename $filename 2>/dev/null) --help"
    local GEN_SCRIPT_NEWFILE="$filename"
    local GEN_SCRIPT_REPLACE_ENV="$(__gen_env_vars "$filename")"
    [ -n "$gen_header_raw" ] || [ -n "${desc:-$get_desc}" ] || printf_yellow "Description: ${desc:-None provided}"
    [ -n "$gen_header_raw" ] || [ -n "${todo:-$get_todo}" ] || printf_yellow "TODO: ${todo:-None provided}"
  fi
  if [ -n "$gen_header_prev" ]; then
    __check_header "$filename" || __no_header
    __providefilename "$filename"
    printf_blue "Imported header from $(__fullfilename "$filename")"
    printf_newline
    __prev_header
  elif [ "$gen_header_replace" = true ]; then
    __check_header "$filename" || __no_header
    __providefilename "$filename"
    printf_blue "Imported header from $(__fullfilename "$filename")"
    printf_newline
    __replace_header "$filename"
  elif [ -n "$gen_header_raw" ]; then
    printf_blue "Showing the raw header template"
    printf_newline
    __gen_header_raw || rerun
  elif [ -f "$GEN_SCRIPT_CONFIG_DIR/templates/headerfile" ] && [ -z "$gen_header_user" ]; then
    printf_blue "Using header from $GEN_SCRIPT_CONFIG_DIR/templates/headerfile"
    printf_newline
    cat <<EOF | tee
$(. $GEN_SCRIPT_CONFIG_DIR/templates/headerfile)
EOF
  elif [ -n "$gen_header_user" ] && [ -z "$gen_header_raw" ]; then
    printf_newline
    __gen_template_user | sed "s|GEN_SCRIPT_REPLACE_ENV|$GEN_SCRIPT_REPLACE_ENV|g"
  else
    printf_newline
    __gen_template_system | sed "s|GEN_SCRIPT_REPLACE_ENV|$GEN_SCRIPT_REPLACE_ENV|g"
  fi
  if [ "$showFunctions" = "true" ]; then
    __gen_functions
  fi
  printf_newline
  [ ${exitCode:-$?} -ne 0 ] || printf_blue "Your header is ready for use"
  [ -z "$pause" ] || __print_wait "Press any key when done"
  printf_newline
  return ${exitCode:-$?}
}

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_template_user() {
  [ "$header_type" = "user" ] && PROG="PROG" || PROG="APPNAME"
  if [ -f "$GEN_SCRIPT_CONFIG_DIR/templates/gen_user.sh" ]; then
    cat <<EOF | tee
$(. $GEN_SCRIPT_CONFIG_DIR/templates/gen_user.sh)
EOF
  else
    cat <<EOF | tee
#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : $GEN_SCRIPT_VERSION
# @Author        : $GEN_SCRIPT_AUTHOR
# @Contact       : $GEN_SCRIPT_EMAIL
# @License       : $GEN_SCRIPT_DEFLICENSE
# @ReadME        : $(__filename $GEN_SCRIPT_NEWFILE 2>/dev/null) --help
# @Copyright     : $GEN_SCRIPT_COPYRIGHT
# @Created       : $GEN_SCRIPT_CREATED
# @File          : $(__filename $GEN_SCRIPT_NEWFILE 2>/dev/null)
# @Description   : ${desc:-$get_desc}
# @TODO          : ${todo:-$get_todo}
# @Other         : ${other:-$get_other}
# @Resource      : ${res:-$get_res}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$PROG="\$(basename "\$0")"
VERSION="$GEN_SCRIPT_VERSION"
USER="\${SUDO_USER:-\${USER}}"
HOME="\${USER_HOME:-\${HOME}}"
SRC_DIR="\${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "\$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=\${exitCode:-\$?};[ -n "\$GEN_SCRIPT_REPLACE_ENV_TEMP_FILE" ] && [ -f "\$GEN_SCRIPT_REPLACE_ENV_TEMP_FILE" ] && rm -Rf "\$GEN_SCRIPT_REPLACE_ENV_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
EOF
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_template_system() {
  if [ -f "$GEN_SCRIPT_CONFIG_DIR/templates/gen_system.sh" ]; then
    cat <<EOF | tee
$(. $GEN_SCRIPT_CONFIG_DIR/templates/gen_system.sh)
EOF
  else
    cat <<EOF | tee
#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : $GEN_SCRIPT_VERSION
# @Author        : $GEN_SCRIPT_AUTHOR
# @Contact       : $GEN_SCRIPT_EMAIL
# @License       : $GEN_SCRIPT_DEFLICENSE
# @ReadME        : $GEN_SCRIPT_DEFREADME
# @Copyright     : $GEN_SCRIPT_COPYRIGHT
# @Created       : $GEN_SCRIPT_CREATED
# @File          : $(__filename $GEN_SCRIPT_NEWFILE 2>/dev/null)
# @Description   : ${desc:-$get_desc}
# @TODO          : ${todo:-$get_todo}
# @Other         : ${other:-$get_other}
# @Resource      : ${res:-$get_res}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="\$(basename "\$0")"
VERSION="$GEN_SCRIPT_VERSION"
USER="\${SUDO_USER:-\${USER}}"
HOME="\${USER_HOME:-\${HOME}}"
SRC_DIR="\${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "\$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=\${exitCode:-\$?};[ -n "\$GEN_SCRIPT_REPLACE_ENV_TEMP_FILE" ] && [ -f "\$GEN_SCRIPT_REPLACE_ENV_TEMP_FILE" ] && rm -Rf "\$GEN_SCRIPT_REPLACE_ENV_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
EOF
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_header_raw() {
  if [ "$header_type" = "user" ]; then
    GEN_SCRIPT_REPLACE_PROG="PROG"
  else
    GEN_SCRIPT_REPLACE_PROG="APPNAME"
  fi
  if [ -f "$GEN_SCRIPT_CONFIG_DIR/templates/gen_raw.sh" ]; then
    cat <<EOF | tee
$(. $GEN_SCRIPT_CONFIG_DIR/templates/gen_raw.sh)
EOF
  else
    cat <<EOF | tee
#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : GEN_SCRIPT_REPLACE_VERSION
# @Author        : GEN_SCRIPT_REPLACE_AUTHOR
# @Contact       : GEN_SCRIPT_REPLACE_EMAIL
# @License       : GEN_SCRIPT_REPLACE_LICENSE
# @ReadME        : GEN_SCRIPT_REPLACE_FILENAME --help
# @Copyright     : GEN_SCRIPT_REPLACE_COPYRIGHT
# @Created       : GEN_SCRIPT_REPLACE_DATE
# @File          : GEN_SCRIPT_REPLACE_FILENAME
# @Description   : GEN_SCRIPT_REPLACE_DESC
# @TODO          : GEN_SCRIPT_REPLACE_TODO
# @Other         : GEN_SCRIPT_REPLACE_OTHER
# @Resource      : GEN_SCRIPT_REPLACE_RES
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$GEN_SCRIPT_REPLACE_PROG="\$(basename "\$0")"
VERSION="GEN_SCRIPT_REPLACE_VERSION"
USER="\${SUDO_USER:-\${USER}}"
HOME="\${USER_HOME:-\${HOME}}"
SRC_DIR="\${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "\$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=\${exitCode:-\$?};[ -n "\$GEN_SCRIPT_REPLACE_ENV_TEMP_FILE" ] && [ -f "\$GEN_SCRIPT_REPLACE_ENV_TEMP_FILE" ] && rm -Rf "\$GEN_SCRIPT_REPLACE_ENV_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -'
EOF
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_functions() {
  __vars "$@"
  if [ -n "$gen_header_user" ] || [ "$header_type" = "user" ]; then
    if [ -f "$GEN_SCRIPT_CONFIG_DIR/templates/gen_user_functions.sh" ]; then
      cat <<EOF | tee
$(. $GEN_SCRIPT_CONFIG_DIR/templates/gen_user_functions.sh)
EOF
    else
      cat <<EOF | tee
# Main function file
if [ -f "\$SRC_DIR/functions.bash" ]; then
  FUNCTIONS_DIR="\$SRC_DIR"
  . "\$FUNCTIONS_DIR/functions.bash"
elif [ -f "\$HOME/.local/bin/functions.bash" ]; then
  FUNCTIONS_DIR="\$HOME/.local/bin"
  . "\$FUNCTIONS_DIR/functions.bash"
else
  printf "\t\t\033[0;31m%s \033[0m\n" "Could not source the functions file from $\FUNCTIONS_DIR"
  return 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
EOF
    fi
  else
    if [ -f "$GEN_SCRIPT_CONFIG_DIR/templates/gen_system_functions.sh" ]; then
      cat <<EOF | tee
$(. $GEN_SCRIPT_CONFIG_DIR/templates/gen_system_functions.sh)
EOF
    else
      echo '# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/'$GEN_SCRIPT_GIT_DEFAULT_BRANCH'/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
'${default_type:-user}_install'
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
'
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__backup_file() {
  local BASEDIR="${GEN_SCRIPT_CONFIG_BACKUP_DIR:-$GEN_SCRIPT_CONFIG_DIR/backups}"
  local BACKUPDIR="$BASEDIR/${destfolder/\//}"
  local NAME="$filename-$(date +'%m%d%Y%H%M' 2>/dev/null)"
  [ -d "$BACKUPDIR" ] || __mkd "$BACKUPDIR"
  if cp -Rf "$destfolder/$filename" "$BACKUPDIR/$NAME" &>/dev/null; then
    printf_blue "copied $filename to ${BACKUPDIR/$GEN_SCRIPT_CONFIG_DIR\//}/$NAME"
  else
    printf_red "Failed to copy $filename BACKUPDIR/$NAME"
  fi
  if [ -f "$destfolder/$filename" ]; then __rm_rf "$destfolder/$filename"; fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__vars() {
  [ -f "$GEN_SCRIPT_TOP_DIR/README.md" ] && GEN_SCRIPT_DEFREADME="README.md" || GEN_SCRIPT_DEFREADME="$(basename "$1" 2>/dev/null) --help"
  [ -f "$GEN_SCRIPT_TOP_DIR/LICENSE.md" ] && GEN_SCRIPT_DEFLICENSE="LICENSE.md" || GEN_SCRIPT_DEFLICENSE="${GEN_SCRIPT_DEFLICENSE:-}"
  [ -f "$GEN_SCRIPT_TOP_DIR/version.txt" ] && GEN_SCRIPT_VERSION="$(cat $GEN_SCRIPT_TOP_DIR/version.txt 2>/dev/null)" || GEN_SCRIPT_VERSION="${GEN_SCRIPT_VERSION:-}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__find_file() {
  arg1=${1// /\/}
  arg2=${2// /\/}
  arg3=${3// /\/}
  arg4=${4// /\/}
  if [ -f "$GEN_SCRIPT_TEMPLATE_DIR/$arg1/$arg2/$arg3/${arg4:-default}" ]; then
    template="$GEN_SCRIPT_TEMPLATE_DIR/$arg1/$arg2/$arg3/${arg4:-default}"
    [[ "$5" = -* ]] && dest="${newScript:-$filename}" || dest="${5:-$filename}"
    shift 4
  elif [ -f "$GEN_SCRIPT_TEMPLATE_DIR/$arg1/$arg2/${arg3:-default}" ]; then
    template="$GEN_SCRIPT_TEMPLATE_DIR/$arg1/$arg2/${arg3:-default}"
    [[ "$4" = -* ]] && dest="${newScript:-$filename}" || dest="${4:-$filename}"
    shift 3
  elif [ -f "$GEN_SCRIPT_TEMPLATE_DIR/$arg1/${arg2:-default}" ]; then
    template="$GEN_SCRIPT_TEMPLATE_DIR/$arg1/${arg2:-default}"
    [[ "$3" = -* ]] && dest="${newScript:-$filename}" || dest="${3:-$filename}"
    shift 2
  elif [ -f "$GEN_SCRIPT_TEMPLATE_DIR/${arg1:-default}" ]; then
    template="$GEN_SCRIPT_TEMPLATE_DIR/${arg1:-default}"
    [[ "$2" = -* ]] && dest="${newScript:-$filename}" || dest="${2:-filename}"
    shift 1
  else
    printf_green "Using the default template: bash"
    template="$GEN_SCRIPT_TEMPLATE_DIR/shell/bash"
    [[ "$1" = -* ]] && dest="${newScript:-$filename}" || dest="${1:-$filename}"
  fi
  if grep -q 'local cur prev words cword opts' "$template"; then
    dest="$(dirname "$filename" 2>/dev/null)/$GEN_SCRIPT_DEFAULT_COMPLETION_DIR/$(basename "$filename" 2>/dev/null)"
    filetype="completion"
  elif [[ "$template" = readme_* ]]; then
    dest="$(dirname "$filename" 2>/dev/null)/$GEN_SCRIPT_DEFAULT_MAN_DIR/$(basename "$filename" 2>/dev/null)"
    filetype="manual"
  else
    filetype=""
    dest="${dest:-newScript}"
  fi
  __set_header "$dest" "$@"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__default_name() {
  if [ -z "${1}" ]; then
    printf_red "No filename was provided: using default $(__filename "${2:-newScript}")"
    OVERWRITE=N
    return 0
  else
    return 1
  fi
}
