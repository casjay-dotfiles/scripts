# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_setup_new_added() {
  local commit_file="${1/$GEN_SCRIPT_CWD\//}"
  [ -d "$GEN_SCRIPT_CWD/.git" ] || return 0
  git -C "$GEN_SCRIPT_CWD" add -A "$commit_file" >/dev/null &&
    printf_blue "Added $commit_file to git" ||
    return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_setup_new_commit() {
  [ -d "$GEN_SCRIPT_CWD/.git" ] || return 0
  message="$1"
  shift 1
  printf_blue "Committing changes to $GEN_SCRIPT_CWD"
  printf_cyan "Message: $(echo "$message" | head -n1)"
  git -C "$GEN_SCRIPT_CWD" commit --untracked=no -q -S -m "$message" $* &>/dev/null || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__setup_new() {
  export PATH="${SRC_DIR}:${PATH}"
  files=""
  create_filename="${1:-newScript}"
  new_type="${new_type:-system}"
  type="${2:-$new_type}"
  dir="${GEN_SCRIPT_CWD}"
  name="$(basename "$(readlink -f "$dir" 2>/dev/null)" 2>/dev/null)"
  case ${type} in
  _remove_)
    shift 1
    printf_cyan "Deleting $create_filename from $dir"
    files="$dir/${create_filename} "
    files+="$dir/bin/${create_filename} "
    files+="$dir/man/${create_filename} "
    files+="$dir/completions/_${create_filename}_completions "
    for file in $files; do
      [ -f "$file" ] && printf_green "Deleting $file"
      __rm_rf "$file"
    done
    __git_setup_new_commit "$(printf '%s\n\n%s\n' "➖ Delete: $create_filename ➖" "Deleted $create_filename from $name")" -a
    exit
    ;;
  user)
    shift 1
    printf_cyan "Creating user script: $create_filename in $dir"
    $APPNAME bash user "$create_filename" "$@" &>/dev/null
    $APPNAME completions user.bash "$create_filename" "$@" &>/dev/null
    $APPNAME other script_readme "$create_filename" "$@" &>/dev/null
    files="$dir/${create_filename} "
    files+="$dir/bin/${create_filename} "
    files+="$dir/man/${create_filename} "
    files+="$dir/completions/_${create_filename}_completions"
    [ -d "$dir/bin" ] && [ -f "$dir/${create_filename}" ] && __mv_f "$dir/$create_filename" "$dir/bin/$create_filename"
    for file in $files; do
      [ -f "$file" ] && printf_green "Created $file" && __git_setup_new_added "$file"
    done
    __git_setup_new_commit "$(printf '%s\n' "➕ Added: $create_filename to $name ➕")" -a
    exit
    ;;
  system)
    shift 1
    printf_cyan "Creating system script: $create_filename in $dir"
    $APPNAME bash system "$create_filename" "$@" &>/dev/null
    $APPNAME completions system.bash "$create_filename" "$@" &>/dev/null
    $APPNAME other script_help "$create_filename" "$@" &>/dev/null
    files="$dir/${create_filename} "
    files+="$dir/bin/${create_filename} "
    files+="$dir/man/${create_filename} "
    files+="$dir/completions/_${create_filename}_completions"
    [ -d "$dir/bin" ] && [ -f "$dir/${create_filename}" ] && __mv_f "$dir/$create_filename" "$dir/bin/$create_filename"
    for file in $files; do
      [ -f "$file" ] && printf_green "Created $file" && __git_setup_new_added "$file"
    done
    __git_setup_new_commit "$(printf '%s\n' "➕ Added: $create_filename to $name ➕")" -a
    exit
    ;;
  *)
    shift
    printf_cyan "Creating system script: $create_filename in $dir"
    $APPNAME bash system "$create_filename" "$@" &>/dev/null
    $APPNAME completions system.bash "$create_filename" "$@" &>/dev/null
    $APPNAME other script_help "$create_filename" "$@" &>/dev/null
    files="$dir/${create_filename} "
    files+="$dir/bin/${create_filename} "
    files+="$dir/man/${create_filename} "
    files+="$dir/completions/_${create_filename}_completions"
    [ -d "$dir/bin" ] && [ -f "$dir/${create_filename}" ] && __mv_f "$dir/$create_filename" "$dir/bin/$create_filename"
    for file in $files; do
      [ -f "$file" ] && printf_green "Created $file" && __git_setup_new_added "$file"
    done
    __git_setup_new_commit "$(printf '%s\n' "➕ Added: $create_filename to $name ➕")" -a
    exit
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Begin
GEN_SCRIPT_OPTS="$*"
# I'm sure there is a better way to do this
if [ "$1" = "-d" ] || [ "$1" = "-dir" ] || [ "$1" = "--dir" ]; then
  GEN_SCRIPT_CWD="$2"
  shift 2
  [ -d "$GEN_SCRIPT_CWD" ] || printf_exit "$GEN_SCRIPT_CWD doesn't seem to be a directory"
else
  GEN_SCRIPT_CWD="$PWD"
fi
if [ "$GEN_SCRIPT_CWD" = "." ]; then GEN_SCRIPT_CWD="$(__basedir ".")"; fi
if [ "$1" = "--skip" ]; then OVERWRITE="Y" && OPENEDIT="N" && shift 1; fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# default variables
GEN_SCRIPT_TOP_DIR="$(__git_top_dir "$GEN_SCRIPT_CWD" || echo $GEN_SCRIPT_CWD 2>/dev/null)"
GEN_SCRIPT_YEAR="${GEN_SCRIPT_YEAR:-$(date +%Y 2>/dev/null)}"
GEN_SCRIPT_EMAIL="${GEN_SCRIPT_EMAIL:-${USER}@$(hostname -f 2>/dev/null)}"
GEN_SCRIPT_AUTHOR="${GEN_SCRIPT_AUTHOR:-$USER}"
GEN_SCRIPT_COMPANY="${GEN_SCRIPT_AUTHOR:-$USER}"
GEN_SCRIPT_VERSIONFMT="${VERSION_DATE_FORMAT:-%Y%m%d%H%M-git}"
GEN_SCRIPT_DEFREADME="${GEN_SCRIPT_DEFREADME:-README.md}"
GEN_SCRIPT_DEFLICENSE="${GEN_SCRIPT_DEFLICENSE:-WTFPL}"
GEN_SCRIPT_DEFAULT_MAN_DIR="${GEN_SCRIPT_DEFAULT_MAN_DIR:-man}"
GEN_SCRIPT_DEFAULT_COMPLETION_DIR="${GEN_SCRIPT_DEFAULT_COMPLETION_DIR:-completions}"
GEN_SCRIPT_DATEFMT="${GEN_SCRIPT_DATEFMT:-%A, %b %d, %Y %H:%M %Z}"
GEN_SCRIPT_COPYRIGHT="${GEN_SCRIPT_COPYRIGHT:-Copyright: (c) $GEN_SCRIPT_YEAR $GEN_SCRIPT_AUTHOR, $GEN_SCRIPT_COMPANY}"
GEN_SCRIPT_OPTSDIR="${GEN_SCRIPT_OPTSDIR:-$HOME/.local/share/gen-script}"
GEN_SCRIPT_CONFIG_DIR="${GEN_SCRIPT_CONFIG_DIR:-$HOME/.config/gen-script}"
GEN_SCRIPT_CONFIG_BACKUP_DIR="${GEN_SCRIPT_CONFIG_BACKUP_DIR:-$GEN_SCRIPT_CONFIG_DIR/backups}"
GEN_SCRIPT_COPY_CONFIRM="${GEN_SCRIPT_COPY_CONFIRM:-yes}"
GEN_SCRIPT_GIT_DEFAULT_BRANCH="${GEN_SCRIPT_GIT_DEFAULT_BRANCH:-main}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -d "$GEN_SCRIPT_CONFIG_DIR/files" ]; then
  GEN_SCRIPT_TEMPLATE_DIR="$GEN_SCRIPT_CONFIG_DIR/files"
else
  GEN_SCRIPT_TEMPLATE_DIR="${GEN_SCRIPT_TEMPLATE_DIR:-$CASJAYSDEVDIR/templates/scripts}"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[ -f "$GEN_SCRIPT_CONFIG_DIR/settings.conf" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[ -f "$GEN_SCRIPT_CONFIG_DIR/settings.conf" ] && . "$GEN_SCRIPT_CONFIG_DIR/settings.conf"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
GEN_SCRIPT_VERSION="$(date +"${GEN_SCRIPT_VERSIONFMT}" 2>/dev/null)"
GEN_SCRIPT_CREATED="$(date +"${GEN_SCRIPT_DATEFMT}" 2>/dev/null)"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ "$(__count_files $GEN_SCRIPT_CONFIG_DIR/files "3")" -eq 0 ]; then
  __mkd "$GEN_SCRIPT_CONFIG_DIR/files"
  if [ "$(__count_files "$CASJAYSDEVDIR/templates/scripts" "2")" -ne 0 ]; then
    printf_green "Setting up the Scripts directory"
    __cp_rf "$CASJAYSDEVDIR/templates/scripts/." "$GEN_SCRIPT_CONFIG_DIR/files/"
  else
    printf_exit "1" "1" "No scripts exist"
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[ -f "$GEN_SCRIPT_CONFIG_DIR" ] && __rm_rf "$GEN_SCRIPT_CONFIG_DIR"
[ -d "$GEN_SCRIPT_CONFIG_DIR" ] || __mkd "$GEN_SCRIPT_CONFIG_DIR"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Main application
case ${1:-$SETOPTS} in
-a | --options)
  shift 1
  __gen_opts "$@"
  exit $?
  ;;
-c | --copy)
  shift 1
  __copy_templates "$@"
  exit $?
  ;;
-g | --config)
  shift 1
  __gen_config && __copy_templates "$@"
  exit $?
  ;;

-folders)
  shift 1
  [[ "$1" = "--raw" ]] && shift 1 && printf_blue() { echo "$*"; }
  if [[ "$1" = "--full" ]]; then
    shift 1
    clear
    printf_newline '\n\n\n'
    [[ "$1" = "--noreplace" ]] && shift 1 && NEW_FOLDER="GEN_SCRIPT_REPLACE_ENV" || NEW_FOLDER="${1}"
    printf_green "Creating folder info for $NEW_FOLDER"
    __gen_folders | sed 's|'$(__gen_env_vars "GEN_SCRIPT_REPLACE_ENV")'|'$(__gen_env_vars "$NEW_FOLDER")'|g'
  else
    echo
    printf_green "Creating folder info for $2"
    NEW_FOLDER="$(__gen_env_vars "${1}_${2}")"
    printf_blue "$NEW_FOLDER"
    printf_blue '[[ -d "'$NEW_FOLDER'" ]] || mkdir -p "'$NEW_FOLDER'" &>/dev/null'
  fi
  echo
  printf_pause
  exit
  ;;

-function)
  shift 1
  [[ $1 = -u ]] && gen_header_user=true && shift 1
  [ $# -lt 2 ] || printf_exit "Only takes a filename as an argument"
  printf_green "New functions info for ${1:-template}"
  __gen_functions ${1:-template}
  printf_green "End of functions"
  exit $?
  ;;

-replace)
  shift 1
  [ -f "$1" ] && filename="$1" || filename="$(type -P "$(basename "$1" 2>/dev/null)")"
  if [ $# -ne 3 ]; then
    printf_exit "Requires filename search replace"
  else
    __update_header "$filename" "$2" "$3"
  fi
  exit
  ;;

-readme) # This needs major work done
  shift 1
  exitCode=0
  if [ "$1" = "--basename" ]; then
    shift 1
    filename_base="true"
  fi
  if [ "${@:$#}" = user ] || [ "${@:$#}" = system ]; then
    template_type="${@:$#}"
  fi
  if [ "$1" = "-import" ]; then
    shift 1
    if [ $# -lt 2 ]; then
      printf_exit 1 1 "Usage: gen-script -readme [-import importfile] filename --type[system,user]"
    fi
    printf_green "Importing the readme file"
    prev_filename="$1"
    if [ "$filename_base" = "true" ]; then
      new_filename="$(basename "${2:-$1}" 2>/dev/null)"
    else
      new_filename="$(dirname "${2:-.}" 2>/dev/null)/$GEN_SCRIPT_DEFAULT_MAN_DIR/$(basename "${2:-$1}" 2>/dev/null)"
    fi
    new_type="${template_type:-system}"
    filename="$(basename "$new_filename" 2>/dev/null)"
    dirname="$(dirname "$new_filename" 2>/dev/null)"
    __get_prev "$filename" &>/dev/null
    desc="Manual for $filename"
    GEN_SCRIPT_NEWFILE="$prev_filename"
    GEN_SCRIPT_REPLACE_APPNAME="$(__filename "$prev_filename")"
    GEN_SCRIPT_REPLACE_FILENAME="$GEN_SCRIPT_REPLACE_APPNAME"
    GEN_SCRIPT_REPLACE_DESC="${get_desc:-$desc}"
    [ -f "$new_filename" ] && __cp_rf "$new_filename" "$GEN_SCRIPT_CONFIG_DIR/backups/$new_filename"
    if [ -f "$prev_filename" ]; then
      PREV_README="$(cat <<<"$(__prev_readme "$prev_filename")")"
    else
      printf_error "Failed to find $prev_filename: Using ${new_type:-system} as the default"
      PREV_README="$(printf '\n__printf_help "5" "Usage: '$GEN_SCRIPT_REPLACE_APPNAME'  "\n')"
      PREV_README+="$(printf '\n__printf_help "4" "BeginHelp"\n')"
    fi
    [ -z "$GEN_SCRIPT_REPLACE_DESC" ] || printf_yellow "Got the description from $filename"
    printf_yellow "Using the $template_type template and importing"
    printf_blue "from: $prev_filename"
    printf_blue "to: $new_filename"
    [ -d "$dirname" ] || __mkd "$dirname"
    __import_readme "${new_type:-system}" "$(__prev_readme "$prev_filename")" >"$new_filename"
    if [ -f "$new_filename" ]; then
      __sed "GEN_SCRIPT_REPLACE_APPNAME" "$(basename "$new_filename" 2>/dev/null)" "$new_filename"
      __sed "GEN_SCRIPT_REPLACE_FILENAME" "$(basename "$new_filename" 2>/dev/null)" "$new_filename"
      __sed "GEN_SCRIPT_REPLACE_DESC" "$GEN_SCRIPT_REPLACE_DESC" "$new_filename"
      __sed "^printf_head " "__printf_head " "$new_filename"
      __sed "^printf_help " "__printf_help " "$new_filename"
      __sed " |  " "   " "$new_filename"
    else
      printf_exit "Failed to create $new_filename"
      exitCode=1
    fi
    if [ -f "$new_filename" ] && [ $exitCode = 0 ]; then
      chmod 755 "$new_filename"
      printf_green "Successfully created the new readme file"
      exitCode=0
    else
      printf_red "Creation of the readme file has failed"
      exitCode=0
    fi
  elif [[ "$1" = "--template" ]]; then
    shift 1
    printf_green "Creating from template"
    prev_filename="$1"
    new_filename="$(dirname "${1:-.}" 2>/dev/null)/$GEN_SCRIPT_DEFAULT_MAN_DIR/$(basename "${1}" 2>/dev/null)"
    path_filename="$(type -P "$prev_filename" 2>/dev/null)"
    template_type="${2:-system}"
    filename="$(basename "$new_filename" 2>/dev/null)"
    dirname="$(dirname "$new_filename" 2>/dev/null)"
    __get_prev "$filename" &>/dev/null
    desc="Manual for $filename"
    GEN_SCRIPT_NEWFILE="$prev_filename"
    GEN_SCRIPT_REPLACE_APPNAME="$(__filename "$prev_filename")"
    GEN_SCRIPT_REPLACE_FILENAME="$GEN_SCRIPT_REPLACE_APPNAME"
    GEN_SCRIPT_REPLACE_DESC="${get_desc:-$desc}"
    [ -f "$new_filename" ] && __cp_rf "$new_filename" "$GEN_SCRIPT_CONFIG_DIR/backups/$new_filename"
    [ -z "$GEN_SCRIPT_REPLACE_DESC" ] || printf_yellow "Got the description from $filename"
    printf_yellow "Using the $template_type template"
    printf_blue "from: $prev_filename"
    printf_blue "to: $new_filename"
    [ -d "$dirname" ] || __mkd "$dirname"
    __readme_template "${2:-system}" "$(__prev_readme "$prev_filename")" >"$new_filename"
    if [ -f "$new_filename" ]; then
      __sed "GEN_SCRIPT_REPLACE_APPNAME" "$(basename "$new_filename" 2>/dev/null)" "$new_filename"
      __sed "GEN_SCRIPT_REPLACE_FILENAME" "$(basename "$new_filename" 2>/dev/null)" "$new_filename"
      __sed "GEN_SCRIPT_REPLACE_DESC" "$GEN_SCRIPT_REPLACE_DESC" "$new_filename"
      __sed "^printf_head " "__printf_head " "$new_filename"
      __sed "^printf_help " "__printf_help " "$new_filename"
      __sed " |  " "   " "$new_filename"
    else
      printf_exit "Failed to create $new_filename"
      exitCode=1
    fi
    if [ -f "$new_filename" ] && [ $exitCode = 0 ]; then
      chmod 755 "$new_filename"
      printf_green "Successfully created the new readme file"
      exitCode=0
    else
      printf_red "Creation of the readme file has failed"
      exitCode=0
    fi
  else
    if [ $# -lt 2 ]; then printf_exit 1 1 "Usage: gen-script -readme templatefile filename"; fi
    readme_template="$GEN_SCRIPT_CONFIG_DIR/files/other/$1"
    readme_file="$2"
    if [ -f "$readme_template" ]; then
      printf_yellow "Using the template and copying"
      printf_green "from: $readme_template"
      printf_green "to: $readme_file "
      __cp_rf "$readme_template" "$readme_file"
      __sed "GEN_SCRIPT_REPLACE_APPNAME" "$(basename "$readme_file" 2>/dev/null)" "$readme_file"
      __sed "GEN_SCRIPT_REPLACE_FILENAME" "$(basename "$readme_file" 2>/dev/null)" "$readme_file"
      __sed "GEN_SCRIPT_REPLACE_DESC" "$GEN_SCRIPT_REPLACE_DESC" "$readme_file"
    else
      printf_red "$readme_template doesn't exist"
      exitCode=1
    fi
    if [ -f "$readme_file" ] && [ "$exitCode" = 0 ]; then
      chmod 755 "$readme_file"
      printf_green "Successfully created the new readme file"
    else
      printf_red "Creation of the readme file has failed"
      exitCode=1
    fi
  fi
  printf_newline
  exit $exitCode
  ;;

-head)
  shift 1
  __header_opts "$@"
  if [[ "$1" != -* ]] && [ $# -ne 0 ]; then
    filename="${1:-template}"
    shift 1
  elif __remove_opts "$HEADER_ARGS" &>/dev/null; then
    filename="$(__remove_opts "$HEADER_ARGS")"
    shift 1
  else
    filename="template"
  fi
  __gen_header "$@"
  exit $?
  ;;
new)
  shift 1
  { [[ $# -lt 1 ]] || [[ $1 = "help" ]]; } && printf_exit "Usage: $APPNAME new name [user|system|_remove_] -- [options]"
  __setup_new "$@"
  exit
  ;;

completions)
  [[ -z "$2" || "$2" = "help" || "$2" = "--help" ]] && printf_exit "6" "2" "Usage: $APPNAME $1 [templateName] [fileName] [options]" && printf_newline
  filename="${3:-$2}"
  __default_name "$3" "${filename}"
  __find_file "$@"
  ;;

bash)
  [[ -z "$2" || "$2" = "help" || "$2" = "--help" ]] && printf_exit "6" "2" "Usage: $APPNAME $1 [templateName] [fileName] [options]" && printf_newline
  filename="${3:-$2}"
  __default_name "$3" "${filename}"
  __find_file "$@"
  ;;

installers)
  [[ -z "$2" || "$2" = "help" || "$2" = "--help" ]] && printf_exit "6" "2" "Usage: $APPNAME $1 [templateName] [fileName] [options]" && printf_newline
  [[ -n "$3" ]] && filename="${3:-$2}" || filename="install.sh"
  __default_name "$3" "${filename}"
  __find_file "$@"
  ;;

os)
  [[ -z "$2" || "$2" = "help" || "$2" = "--help" ]] && printf_exit "6" "2" "Usage: $APPNAME $1 [templateName] [fileName] [options]" && printf_newline
  filename="${3:-$2}"
  __default_name "$3" "${filename}"
  __find_file "$@"
  ;;

shell)
  [[ -z "$2" || "$2" = "help" || "$2" = "--help" ]] && printf_exit "6" "2" "Usage: $APPNAME $1 [templateName] [fileName] [options]" && printf_newline
  filename="${3:-$2}"
  __default_name "$3" "${filename}"
  __find_file "$@"
  ;;

"$1")
  [[ -z "$2" || "$2" = "help" || "$2" = "--help" ]] && printf_exit "6" "2" "Usage: $APPNAME $1 [templateName] [fileName] [options]" && printf_newline
  filename="${3:-$2}"
  __default_name "$3" "${filename}"
  __find_file "$@"
  ;;

all) ## Bash Completion list
  [[ -z "$2" || "$2" = "help" || "$2" = "--help" ]] && printf_exit "6" "2" "Usage: $APPNAME $1 [templateName] [fileName] [options]" && printf_newline
  shift 1
  filename="${2:-$1}"
  __default_name "$2" "${filename}"
  __find_file "$@"
  ;;

*) ## Allows drop in without need to update this
  [[ -z "$1" || "$1" = "help" || "$1" = "--help" ]] && printf_exit "6" "2" "Usage: $APPNAME [templateName] [fileName] [options]" && printf_newline
  __find_file "$@"
  ;;
esac
shift $#
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Sanity check
[ -n "$dest" ] || dest="$PWD/newScript"
[ -f "$template" ] || printf_exit 1 1 "The template file doesn't exist: $template"
[ -n "${dest:-newScript}" ] || printf_exit 1 1 "Something went wrong while setting up ${dest:-newScript}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# file and folder setup
filename="$(__filename "${dest:-newScript}" 2>/dev/null)"
destfolder="$(__basedir "$dest" 2>/dev/null)"
templatename="$(basename "$template" 2>/dev/null)"
# # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate the file
if [ "$templatename" = "readme" ] || [ "$templatename" = "script_help" ]; then
  printf_yellow "Setting up the script as a scripts readme file"
  if [ -d "$GEN_SCRIPT_CWD/helpers/man" ]; then
    destfolder="$GEN_SCRIPT_CWD/helpers/man"
  else
    destfolder="${GEN_SCRIPT_MAN_DIR:-$destfolder/man}"
  fi
  filename="${filename// /_}"
fi
if [ "$filename" = "newScript" ]; then
  printf_read_question "3" "What should we name this ?" "120" "tmpfilename" "-i ${dest:-$filename}"
  tmpfilename="${tmpfilename:-$filename}"
else
  tmpfilename="$filename"
fi
filename=${tmpfilename// /_}
if [ -f "$destfolder/$filename" ] && [ "$OVERWRITE" != "Y" ]; then
  printf_read_question "3" "Should we overwrite this file?" "1" "YN" ""
  if printf_answer_yes "$YN"; then
    printf_read_question "3" "Should i display file before overwrite?" "1" "SHOW" ""
    printf_answer_yes "$SHOW" && cat "$destfolder/$filename" || __backup_file
  else
    printf_exit 1 1 "Refusing to overwrite existing file!"
  fi
fi
if [ "$MAKEFILE" != "N" ]; then
  printf_green "Copying the file ${template//$GEN_SCRIPT_TEMPLATE_DIR\//} to"
  printf_yellow "$destfolder/$filename"
  __makefile "${template:?}" "$destfolder/$filename"
elif printf_read_question "3" "Should we just display this file?" "1" "YN" "" && printf_answer_yes "$YN"; then
  __makefile "${template:?}" "${TMPDIR:-/tmp}/template.$$.sh"
  cat "${TMPDIR:-/tmp}/template.$$.sh"
  __rm_rf "${TMPDIR:-/tmp}/template.$$.sh"
else
  printf_red "Not creating the file due to the MAKEFILE=no being set"
fi
if [ "$EDITFILE" != "N" ]; then
  [ -n "$OPENEDIT" ] || printf_read_question "3" "Should we edit this file?" "1" "EDIT" ""
  printf_answer_yes "$EDIT" && $EDITOR "$destfolder/$filename"
fi
printf_newline ""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
exit ${exitCode:-$?}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
