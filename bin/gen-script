  #   return
  # fi
  # #-import type
  # if [[ "$OPTS" = -short ]]; then
  #   echo "${SHORT_OPTS//,/ -}" >"$GEN_SCRIPT_OPTSDIR/opts-short.txt"
  # fi
  # if [[ "$OPTS" = -long ]]; then
