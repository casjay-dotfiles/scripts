    -H "Authorization: token $GIT_PRIVATE_ACCESS_TOKEN" \
    -H 'Content-Type: application/json' \
    -H 'accept: application/json' \
    -d '{"username": "'$2'","description": "'$3'","website": "'$4'","visibility": "'${5:-public}'"}' \
    "https://$GITADMIN_PERSONAL_GIT_HOST/api/v1/admin/users/$1/orgs" 2>/dev/null | jq -r '.'
  return $?
}
