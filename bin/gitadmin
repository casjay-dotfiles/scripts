# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GITADMIN_CONFIG_DIR/$GITADMIN_CONFIG_FILE"
  [ -d "$GITADMIN_CONFIG_DIR" ] || mkdir -p "$GITADMIN_CONFIG_DIR"
  [ -d "$GITADMIN_CONFIG_BACKUP_DIR" ] || mkdir -p "$GITADMIN_CONFIG_BACKUP_DIR"
  [ -f "$GITADMIN_CONFIG_DIR/$GITADMIN_CONFIG_FILE" ] &&
    cp -Rf "$GITADMIN_CONFIG_DIR/$GITADMIN_CONFIG_FILE" "$GITADMIN_CONFIG_BACKUP_DIR/$GITADMIN_CONFIG_FILE.$$"
  cat <<EOF >"$GITADMIN_CONFIG_DIR/$GITADMIN_CONFIG_FILE"
# Settings for gitadmin
GITADMIN_DEFAULT_GIT_DIR="${GITADMIN_DEFAULT_GIT_DIR:-$HOME/Projects/gitadmin}"
GITADMIN_DEFAULT_GIT_DIR_GITHUB="${GITADMIN_DEFAULT_GIT_DIR_GITHUB:-$GITADMIN_DEFAULT_GIT_DIR/github}"
GITADMIN_DEFAULT_GIT_DIR_GITLAB="${GITADMIN_DEFAULT_GIT_DIR_GITLAB:-$GITADMIN_DEFAULT_GIT_DIR/gitlab}"
GITADMIN_DEFAULT_GIT_DIR_PRIVATE="${GITADMIN_DEFAULT_GIT_DIR_PRIVATE:-$GITADMIN_DEFAULT_GIT_DIR/Private}"
GITADMIN_PERSONAL_GIT_HOST="${GITADMIN_PERSONAL_GIT_HOST:-$PERSONAL_GIT_HOST}"
GITADMIN_DEFAULT_BRANCH="${GITADMIN_DEFAULT_BRANCH:-main}"
GITADMIN_DEFAULT_MAINCONFIG="gitmainconfig"
GITADMIN_DEFAULT_USERNAME="${GITADMIN_DEFAULT_USERNAME:-$GITHUB_USERNAME}"
GITADMIN_DEFAULT_USER_DOMAIN="${GITADMIN_DEFAULT_USER_DOMAIN:-}"
GITADMIN_GITHUB_AUTH_TOKEN="${GITADMIN_GITHUB_AUTH_TOKEN:-$GITHUB_ACCESS_TOKEN}"
GITADMIN_DEFAULT_REPO_BASE="${REPO_URL:-https://github.com}"
GITADMIN_DOMAIN_TEMPLATE="${GITADMIN_DOMAIN_TEMPLATE:-https://github.com/casjay-templates/domain-template}"
GITADMIN_DEFAULT_README="${GITADMIN_DEFAULT_README:-default}"
GITADMIN_DEFAULT_LICENSE="${GITADMIN_DEFAULT_LICENSE:-$MY_LICENSE_FILE}"
GITADMIN_VERSION_DATE_FORMAT="${VERSION_DATE_FORMAT:-%Y%m%d%H%M-git}"

# Notification settings
GITADMIN_GOOD_MESSAGE="${GITADMIN_GOOD_MESSAGE:-Everything Went OK}"
GITADMIN_ERROR_MESSAGE="${GITADMIN_ERROR_MESSAGE:-Well that didn\'t work}"
GITADMIN_NOTIFY_ENABLED="${GITADMIN_NOTIFY_ENABLED:-yes}"
GITADMIN_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GITADMIN_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GITADMIN_NOTIFY_CLIENT_ICON}"

# Colorization settings
GITADMIN_OUTPUT_COLOR="${GITADMIN_OUTPUT_COLOR:-5}"
GITADMIN_OUTPUT_COLOR_GOOD="${GITADMIN_OUTPUT_COLOR_GOOD:-2}"
GITADMIN_OUTPUT_COLOR_ERROR="${GITADMIN_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GITADMIN_CONFIG_DIR/$GITADMIN_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for gitadmin has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
#set folder name based on githost
__git_hostname() { echo "$@" | sed -e "s/[^/]*\/\/\([^@]*@\)\?\([^:/]*\).*/\2/" | awk -F. '{print $(NF-1) "." $NF}' | sed 's#\..*##g'; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#setup directory structure
__git_username_repo() {
  unset url protocol separator hostname username userrepo
  local url="$1"
  local re="^(https?|git|ssh)(:\/\/|@)([^\/:]+)[\/:]([^\/:]+)\/(.+)$"
  local githostname="$(__git_hostname $url 2>/dev/null)"
  if [ -d "$url" ]; then
    protocol=
    separator=
    hostname=localhost
    userrepo="$(__basename "$url")"
    username="$(__basename "$(dirname "$url")")"
    folder="local"
    projectdir="${GITADMIN_DEFAULT_GIT_DIR:-$HOME/Projects/gitadmin}/$folder/$username-$userrepo"
  elif [[ $url =~ $re ]]; then
    protocol=${BASH_REMATCH[1]}
    separator=${BASH_REMATCH[2]}
    hostname=${BASH_REMATCH[3]}
    username=${BASH_REMATCH[4]}
    userrepo=${BASH_REMATCH[5]}
    folder=$githostname
    projectdir="${GITADMIN_DEFAULT_GIT_DIR:-$HOME/Projects/gitadmin}/$folder/$username/$userrepo"
  else
    return 1
  fi
  export url protocol separator hostname username userrepo
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# issues API
__api_issues_token() {
  local user="${1:-$USERNAME}"
  local git_repo="$2"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  ISSUE_HTML="https://github.com/repos/$user/$git_repo/issues"
  ISSUE_API="https://api.github.com/repos/$user/$git_repo/issues"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# call the issues api
__api_issues() {
  __api_issues_token "$1" "$2"
  curl -q -LSs "${CURL_HEADER}" -H "Accept: application/vnd.github.v3+json" "$ISSUE_API"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Gist API
__api_gist() {
  local user="${1:-$USERNAME}"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "https://api.github.com/users/$user/gists"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set Message for token - user
__api_user_token() {
  local user="${1:-$USERNAME}"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  if [ -n "$GITADMIN_GITHUB_AUTH_TOKEN" ]; then
    export GITHUBAPIREPO="https://api.github.com/users/$user/repos?per_page=1000&type=owner"
    export MESSAGE="Getting the repos for $user using\n\t\tgithub token $GITADMIN_GITHUB_AUTH_TOKEN"
  else
    export GITHUBAPIREPO="https://api.github.com/users/$user/repos?per_page=1000"
    export MESSAGE="Getting the repos for $USERNAME"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User api
__api_user() {
  local user="${1:-$USERNAME}"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  __api_user_token "$user"
  __urlverify "$GITHUBAPIREPO" || return 1
  __devnull2 curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "$GITHUBAPIREPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set Message for token - org
__api_org_token() {
  local user="${1:-$USERNAME}"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  if [ -n "$GITADMIN_GITHUB_AUTH_TOKEN" ]; then
    export GITHUBAPIREPO="https://api.github.com/orgs/$user/repos?per_page=1000&type=owner"
    export MESSAGE="Getting the repos for $user using\n\t\tgithub token $GITADMIN_GITHUB_AUTH_TOKEN"
  else
    export GITHUBAPIREPO="https://api.github.com/orgs/$user/repos?per_page=1000"
    export MESSAGE="Getting the repos for $user"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Organization API
__api_org() {
  local user="${1:-$USERNAME}"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  __api_user_token "$user"
  __urlverify "$GITHUBAPIREPO" || return 1
  __devnull2 curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "$GITHUBAPIREPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Call the API
__api_url() { __api_user "${1:-$USERNAME}" || __api_org "${1:-$USERNAME}" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# pull function
__git_pull() {
  local git_dir="${1:-$GITADMIN_WD}" && shift 1
  local args="$*"
  local regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$(__git_remote_origin "$git_dir")" =~ $regex ]]; then
    if am_i_online; then
      git -C "$git_dir" pull $args -f -q &>/dev/null && return 0 || return 1
    else return 1; fi
  else
    git -C "$git_dir" pull $args -f -q &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Push function
__git_push() {
  local git_dir="${1:-$GITADMIN_WD}" && shift 1
  local args="$*"
  local regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$(__git_remote_origin "$git_dir")" =~ $regex ]]; then
    if am_i_online; then
      git -C "$git_dir" push $args -q &>/dev/null && return 0 || return 1
    else return 1; fi
  else
    git -C "$git_dir" push $args -q &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Clone function
__git_clone() {
  local git_url="$1" && shift 1
  local git_dir="$1" && shift 1
  local args="$*" && shift $#
  local regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$git_url" =~ $regex ]]; then
    if am_i_online; then
      git clone "$git_url" "$git_dir" -q $args &>/dev/null && return 0 || return 1
    else
      return 1
    fi
  else
    git clone "$git_url" "$git_dir" -q $args &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a README.md file if one doesn't exist
create_new_readme_template() {
  local git_dir="${1:-$GITADMIN_WD}"
  if [ -f "$(command -v gen-readme)" ] && [ ! -f "$git_dir/README.md" ]; then
    gen-readme "$git_dir" default &>/dev/null
  else
    local author="$(__git_globaluser)"
    local GitBaseDir="$(__git_top_dir "$git_dir")"
    local BaseDir="${GitBaseDir##*/}"
    [ -f "$CASJAYSDEVDIR/templates/readmes/projects/default.md" ] &&
      cat "$CASJAYSDEVDIR/templates/readmes/projects/default.md" >"$git_dir/README.md"
    [ -f "$git_dir/README.md" ] && __sed -i "s#ProjectName#${BaseDir}#g" "$git_dir/README.md"
    [ -f "$git_dir/README.md" ] && __sed -i "s#AuthorName#${author}#g" "$git_dir/README.md"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a license if a LICENSE.md file doesn't exist
create_new_license() {
  local git_dir="${1:-$GITADMIN_WD}"
  if [ -f "$(command -v gen-license)" ] && [ ! -f "$git_dir/LICENSE.md" ]; then
    gen-license "$git_dir" "$GITADMIN_DEFAULT_LICENSE" &>/dev/null
  else
    local author="$(__git_globaluser)"
    local year="$(date +'%Y')"
    [ -f "$GITADMIN_DEFAULT_LICENSE" ] && cat "$GITADMIN_DEFAULT_LICENSE" >"$git_dir/LICENSE.md"
    [ -f "$git_dir/LICENSE.md" ] && __sed -i "s#CURYEAR#${year}#g" "$git_dir/LICENSE.md"
    [ -f "$git_dir/LICENSE.md" ] && __sed -i "s#AuthorName#${author}#g" "$git_dir/LICENSE.md"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# The template to create a new private github repo
create_new_private_repo_template() {
  read -r -d '' JSON_TEMPLATE <<EOF
{
  "name" : "%s",
  "description" : "%s",
  "homepage" : "%s",
  "visibility" : "private",
  "private" : true,
  "has_issues" : false,
  "has_downloads" : false,
  "has_wiki" : false,
  "has_projects" : false
}
EOF
  JSON_OUTPUT=$(printf "$JSON_TEMPLATE" "$REPO_NAME" "$DESCRIPTION" "$GITADMIN_DEFAULT_USER_DOMAIN")
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# The template to create a new public github repo
create_new_repo_template() {
  read -r -d '' JSON_TEMPLATE <<EOF
{
  "name" : "%s",
  "description" : "%s",
  "homepage" : "%s",
  "visibility" : "public",
  "private" : false,
  "has_issues" : false,
  "has_downloads" : false,
  "has_wiki" : false,
  "has_projects" : false
}
EOF
  JSON_OUTPUT=$(printf "$JSON_TEMPLATE" "$REPO_NAME" "$DESCRIPTION" "$GITADMIN_DEFAULT_USER_DOMAIN")
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if input is a url
do_not_add_a_url() {
  local string="$1"
  local regex="(https?|ftp|file)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$string" =~ $regex ]]; then
    printf_red "Do not provide the full url"
    printf_red "only provide the username/repo"
    exit 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# The initialize git function
run_git_init() {
  local git_dir="${1:-$GITADMIN_WD}"
  local git_repo="$git_repo"
  local git_push=""
  local git_confirm=""
  local git_confirm_repo=""
  if [ -n "$git_remote_repo" ]; then
    git -C "$git_dir" remote add origin "$git_remote_repo" &>/dev/null &&
      printf_cyan "$git_remote_repo has been added" || printf_exit 'Failed to add repo'
    printf_read_question "3" "Should I push to the new repo? [y/n]" "1" "git_push"
    if printf_answer_yes "$git_push"; then
      printf_read_question "3" "This will overwrite the repo if it exists. Continue? [y/n]" "1" "git_confirm_repo"
      if printf_answer_yes "$git_confirm_repo"; then
        if [ -f "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
          cp -Rf "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" "$git_dir/.git/config"
        fi
        git -C "$git_dir" push -q -f --set-upstream origin "$GITADMIN_DEFAULT_BRANCH" &>/dev/null
        __git_push "$git_dir"
        if [ -d "$git_dir/.git" ]; then
          printf_green "Successfully pushed to $git_remote_repo"
        else
          printf_red "Push to $git_remote_repo has failed"
        fi
      else
        printf_yellow "Not pushing due to user canceling"
      fi
    else
      printf_yellow "Not pushing due to user canceling"
    fi
  else
    printf_red "No remote repo specified"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup a new git repo
run_git_setup() {
  local git_dir="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local git_prev="$(git -C "$GITADMIN_WD" remote -v 2>/dev/null | grep push | head -n 1 | awk '{print $2}' 2>/dev/null)"
  local git_continue="${continue:-}"
  local git_reuse="${reuse:-}"
  local git_version_file="$VERSIONFILE"
  local git_version_fmt="$VERSION_DATE_FORMAT"
  local GITADMIN_EXITCODE=0
  printf_green "Initializing the repo in $git_dir"
  if [ -d "$git_dir/.git" ]; then
    local git_prev="$(git -C "$git_dir" remote -v | grep push | head -n 1 | awk '{print $2}' 2>/dev/null)"
    printf_error "This project already has git setup"
    if [ -n "$git_prev" ]; then
      printf_green "Remote repo is: $git_prev"
    fi
    printf_read_question "3" "Should I continue to reset this repo? [y/n]" "1" "git_continue"
    if printf_answer_yes "$git_continue"; then
      __rm_rf "$git_dir/.git"
    else
      printf_red "Initialization has failed due to user"
      exit 1
    fi
  fi
  [ -f "$git_version_file" ] && date +"$git_version_fmt" >"$git_version_file"
  ls "$git_dir/README"* >/dev/null 2>&1 || create_new_readme_template "$git_dir"
  ls "$git_dir/LICENSE"* >/dev/null 2>&1 || create_new_license "$git_dir"
  __devnull git -C "$git_dir" init . &&
    __devnull git -C "$git_dir" add . &&
    git -C "$git_dir" commit -q -m ' 🦈🏠🐜❗ Initial Commit ❗🐜🦈🏠 ' &&
    printf_green "Success: $(__git_repobase "$git_dir") has been initialized" ||
    printf_red "Failed to initialize $(__git_repobase "$git_dir")"
  if [ -n "$git_prev" ]; then
    printf_read_question "3" "Should I reuse the remote repo? [y/n] " "1" "git_reuse"
  else
    git_prev=""
    git_repo=""
    git_remote_repo=""
  fi
  if printf_answer_yes "$git_reuse"; then
    git_remote="y"
    git_remote_repo="$git_prev"
    run_git_init "$git_dir"
  else
    printf_read_question "3" "Should I add a remote repo? [y/n] " "1" "git_remote"
    if printf_answer_yes "$git_remote"; then
      printf_read_input "3" "Enter remote repo: " "120" "git_remote_repo"
      export git_remote_repo
      if run_git_init "$git_dir"; then
        GITADMIN_EXITCODE=0
      else
        GITADMIN_EXITCODE=1
      fi
    else
      printf_yellow "You have decided not to add a remote repository"
    fi
  fi
  if [ $GITADMIN_EXITCODE -ne 0 ]; then
    printf_red "Initialization has failed"
  fi
  exit $GITADMIN_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run git setup with no interactions
run_git_setup_automated() {
  local git_dir="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local git_prev="$(git -C "$GITADMIN_WD" remote -v | grep push | head -n 1 | awk '{print $2}' 2>/dev/null)"
  local git_version_file="$VERSIONFILE"
  local git_version_fmt="$VERSION_DATE_FORMAT"
  local GITADMIN_EXITCODE=0
  [ -d "$git_dir" ] || __mkd "$git_dir"
  if [ ! -d "$git_dir/.git" ]; then
    printf_red "This does not seem to be a git repo"
    exit 1
  fi
  if [ -z "$git_prev" ]; then
    printf_red "Can't run in automated mode due to there not being a repo setup"
    exit 1
  fi
  printf_red "Setting up $git_dir as requested" && sleep 5
  __rm_rf .git
  [ -f "$git_version_file" ] && date +"$git_version_fmt" >"$git_version_file"
  ls "$git_dir/README"* 1>/dev/null 2>&1 || create_new_readme_template "$git_dir"
  ls "$git_dir/LICENSE"* 1>/dev/null 2>&1 || create_new_license "$git_dir"
  __devnull git -C "$git_dir" init &&
    __devnull git -C "$git_dir" remote add origin "$git_prev" &&
    if [ -f "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
      __cp_rf "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" "$git_dir/.git/config"
    fi &&
    __devnull git -C "$git_dir" add . &&
    __devnull2 git -C "$git_dir" commit -q -m ' 🦈🏠🐜❗ Initial Commit ❗🐜🦈🏠 ' &&
    __git_push "$git_dir" --set-upstream origin "$GITADMIN_DEFAULT_BRANCH" &&
    __git_push "$git_dir" &&
    printf_green "Successfully pushed to: $git_prev" ||
    printf_red "Push to $git_prev has failed"
  echo ""
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Makes a new jeckyll site
make_newsite() {
  local site_dir="$HOME/Public/sites"
  local site_folder="${1:-newsite}"
  local site_repo="${2:-$GITADMIN_DOMAIN_TEMPLATE}"
  printf_green "Setting up site in: $site_dir/$site_folder"
  printf_blue "Using $site_repo as template"
  if __git_clone "$site_repo" "$site_dir/$site_folder"; then
    cd "$site_dir/$site_folder" || return 1
    __rm_rf "$site_dir/$site_folder/.git"
    [[ "$EDITOR" =~ code ]] && code . || "$EDITOR" _config.yml
    printf_pause
    gitadmin "$site_dir/$site_folder" setup
  else
    printf_error "Failed to clone $DOMAIN_TEMPLATE"
    false
  fi
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Gets the organizations from the user
git_all_orgs() {
  git_user="${1:-$USERNAME}"
  api_url="https://api.github.com/users/$git_user/orgs?per_page=1000&type=owner"
  if [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ]; then
    git_user="$(curl -q -H "Accept: application/vnd.github.v3+json" -LSs "$api_url" 2>/dev/null | jq '.[].login' 2>/dev/null | sed 's#"##g')"
  else
    git_user="$(curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Accept: application/vnd.github.v3+json" -LSs "$api_url" 2>/dev/null | jq '.[].login' 2>/dev/null | sed 's#"##g')"
  fi
  export GIT_ALL_REPOS="${git_user}"
}
git_all_orgs_clone() {
  git_all_orgs "${1:-$USERNAME}"
  for org in $USERNAME $GIT_ALL_REPOS; do
    gitadmin orgs clone "$org"
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Initializes a repo with default options
repos_init() {
  local git_dir="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local git_version_file="$VERSIONFILE"
  local git_version_fmt="$VERSION_DATE_FORMAT"
  [ -f "$git_version_file" ] && date +"$git_version_fmt" >"$git_version_file"
  git -C "$git_dir" add .
  if [ -f "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
    cp -Rf "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" "$git_dir/.git/config"
  fi
  __devnull2 git -C "$git_dir" commit -m ' 🦈🏠🐜 Initial Commit 🐜🦈🏠 '
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Initializes a repo for github
git_init() {
  local git_dir="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local git_version_file="$VERSIONFILE"
  local git_version_fmt="$VERSION_DATE_FORMAT"
  local git_remote=""
  [ "$1" = "" ] && printf_red "Usage: userName repoName\n" && return 1
  [ "$2" = "" ] && printf_red "Usage: userName repoName\n" && return 1
  git_setup "$git_dir"
  [ -f "$git_version_file" ] && date +"$git_version_fmt" >"$git_version_file"
  __devnull2 git -C "$git_dir" add .
  if [ -f "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
    cp -Rf "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" "$git_dir/.git/config"
  fi
  __devnull2 git -C "$git_dir" commit -m ' 🦈🏠🐜 Initial Commit 🐜🦈🏠 '
  __devnull2 git -C "$git_dir" remote add origin "${remote:-https://github.com/$1/$2}"
  __git_push "$git_dir" -u origin "$GITADMIN_DEFAULT_BRANCH"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# List gists
ghgist_list() {
  local user="${1:-$USERNAME}"
  shift 1
  __api_gist "$user" | jq ".[] | .description, .id" | awk 'NR%2{printf "%s ",$0;next;}1' | sed 's|""|"No Description"|g;s/" "/ | ID: /g;s|^"|Gist Title: |g;s|"||g' && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# search gists
search_list() {
  local user="${1:-$USERNAME}"
  shift 1
  __api_gist "$1" | jq ".[] | .description, .id" | awk 'NR%2{printf "%s ",$0;next;}1' |
    sed 's|""|"No Description"|g;s/" "/ | ID: /g;s|^"|Gist Title: |g;s|"||g' | grep -is "$2" &&
    return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Delete gist
ghgist_delete() {
  local gist_id="$(basename $1)"
  local gist_exit="0"
  local gist_succes="Deleted gist: $gist_id"
  local gist_failed="failed to delete gist: $gist_id"
  shift 1
  if [ -z "$gist_id" ]; then printf_exit "Please provide the gist ID"; fi
  curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs -X DELETE "https://api.github.com/gists/$gist_id" >"$GITADMIN_TEMP_FILE"
  grep -viqs "Not Found" "$GITADMIN_TEMP_FILE" && gist_exit=1 || gist_exit=0
  __getexitcode $gist_exit "$gist_succes" "$gist_failed"
  return $gist_exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a new gist
ghgist_create() {
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && printf_exit "ERROR: GITADMIN_GITHUB_AUTH_TOKEN is not set"
  local gist_exit=0
  local gist_describe="$1"
  local gist_filename="$2"
  local gist_content="$3"
  local gist_content="$(printf "%s\r" "{\"description\": \"$gist_describe\",\"public\": true,\"files\": {\"$gist_filename\": {\"content\": \"$gist_content\"}}}" >$GITADMIN_TEMP_FILE-data.txt)"
  printf_green "Creating gist with Description $gist_describe and filename: $gist_filename"
  if curl -q -X POST -LSsi -H "Content-Type: application/json" -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" --data @$GITADMIN_TEMP_FILE-data.txt https://api.github.com/gists |
    grep -w "html_url" | grep "gist" | awk '{print $2}' | __sed 's/\,//;s|"||g' 2>/dev/null >"$GITADMIN_TEMP_FILE"; then
    gist_exit=0
    gist_id="Gist ID: $(basename $(head -n1 "$GITADMIN_TEMP_FILE"))"
    gist_succes="Gist Url: $(cat $GITADMIN_TEMP_FILE)"
    __rm_rf "$GITADMIN_TEMP_FILE-data.txt"
  else
    gist_exit=1
    gist_failed="Failed to create the gist"
  fi
  printf_cyan "$gist_id"
  __getexitcode $gist_exit "$gist_succes" "$gist_failed"
  return $gist_exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Edits a gist
ghgist_edit() {
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && printf_exit "ERROR: GITADMIN_GITHUB_AUTH_TOKEN is not set"
  local gist_exit=0
  local gist_id="$1"
  local gist_describe="$2"
  local gist_filename="$3"
  local gist_content="$4"
  local gist_content="$(printf "%s\r" "{\"description\": \"$gist_describe\",\"public\": true,\"files\": {\"$gist_filename\": {\"content\": \"$gist_content\"}}}" >$GITADMIN_TEMP_FILE-data.txt)"
  printf_green "Editing $gist_id with Description $gist_describe and filename: $gist_filename"
  if curl -q -X PATCH -LSsi -H "Content-Type: application/json" -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" --data @$GITADMIN_TEMP_FILE-data.txt https://api.github.com/gists/$gist_id |
    grep -w "html_url" | grep "gist" | awk '{print $2}' | __sed 's/\,//;s|"||g' 2>/dev/null >"$GITADMIN_TEMP_FILE"; then
    gist_exit=0
    gist_id="Gist ID: $(basename $(head -n1 "$GITADMIN_TEMP_FILE"))"
    gist_succes="Gist Url: $(cat $GITADMIN_TEMP_FILE)"
    __rm_rf "$GITADMIN_TEMP_FILE-data.txt"
  else
    gist_exit=1
    gist_failed="Failed to create the gist"
  fi
  printf_cyan "$gist_id"
  __getexitcode $gist_exit "$gist_succes" "$gist_failed"
  return $gist_exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Reusable function for delete
ghdelete-user() {
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && printf_exit "ERROR: GITADMIN_GITHUB_AUTH_TOKEN is not set"
  local git_user="${1:-$USERNAME}"
  local git_repo="${2:-$REPONAME}"
  curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -LSs -XDELETE "https://api.github.com/repos/$git_user/$git_repo" >"$GITADMIN_TEMP_FILE" 2>/dev/null
  if grep -qs 'Not Found' "$GITADMIN_TEMP_FILE"; then
    return 0
  elif __api_user "$git_user" | grep -qvi "$git_repo"; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Deletes a github repo
ghdelete() {
  local git_user="$1"
  local git_repo="$2"
  local git_failed="Deletion of $git_repo failed"
  local git_succes="Deletion of $git_repo successful"
  local GITADMIN_EXITCODE=0
  printf_green "Deleting $git_repo for user $git_user"
  if ! ghdelete-user "$git_user" "$git_repo"; then
    GITADMIN_EXITCODE=1
  fi
  __getexitcode $GITADMIN_EXITCODE "$git_succes" "$git_failed"
  return $GITADMIN_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Reusable function for create repo
curl_orgs_create() {
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && printf_exit "ERROR: GITADMIN_GITHUB_AUTH_TOKEN is not set"
  curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -LSs "https://api.github.com/orgs/$USERNAME/repos" \
    -d "{\"name\": \"$REPONAME\", \"description\": \"$DESCR\"}" >"$GITADMIN_TEMP_FILE"
  if grep -qis '"full_name": "'$USERNAME'/'$REPONAME'"' "$GITADMIN_TEMP_FILE"; then
    printf_green "https://github.com/$USERNAME/$REPONAME has been created"
    return 0
  elif grep -qis 'name already exists on this account' "$GITADMIN_TEMP_FILE"; then
    printf_green "https://github.com/$USERNAME/$REPONAME already exists"
    return 0
  else
    return 1
  fi
}
curl_user_create() {
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && printf_exit "ERROR: GITADMIN_GITHUB_AUTH_TOKEN is not set"
  curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -LSs "https://api.github.com/user/repos" \
    -d "{\"name\": \"$REPONAME\", \"description\": \"$DESCR\"}" >"$GITADMIN_TEMP_FILE"
  if grep -qis '"full_name": "'$USERNAME'/'$REPONAME'"' "$GITADMIN_TEMP_FILE"; then
    return 0
  elif grep -qis 'name already exists on this account' "$GITADMIN_TEMP_FILE"; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a new repo on github
ghcreate() {
  [ "$GITADMIN_GITHUB_AUTH_TOKEN" = "" ] && printf_red "No auth token set - GITHUB_ACCESS_TOKEN\n" && return 1
  local git_user="$1"
  local git_repo="$2"
  local git_describe="$3"
  local git_failed="Creation of $git_repo failed"
  local git_succes="Success: https://github.com/$1/$2"
  local GITADMIN_EXITCODE=0
  printf_blue "This may take a few seconds."
  printf_blue "Sending your request to the github API."
  printf_green "Creating $git_repo for user $git_user"
  if curl_orgs_create || curl_user_create; then
    GITADMIN_EXITCODE=0
  else
    GITADMIN_EXITCODE=1
  fi
  __getexitcode "$GITADMIN_EXITCODE" "$git_succes" "$git_failed"
  return "$GITADMIN_EXITCODE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# clone a single repo from user
ghsinglerepo() {
  [ "$1" = "" ] && printf_red "Usage: --single userName repoName" && return 1
  [ "$2" = "" ] && printf_red "Usage: --single userName repoName" && return 1
  __git_clone "https://github.com/$1/$2" "${3:-}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# push local repo
git_push_single() {
  SUCCESS_MSG() { echo "Push to $(__git_remote_origin "${projectdir:-$GITADMIN_WD}") has completed"; }
  FAILED_MSG() { echo "Push to $(__git_remote_origin "${projectdir:-$GITADMIN_WD}") has failed"; }
  local git_dir="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local GITADMIN_EXITCODE=0
  if [ -d "$git_dir/.git" ]; then
    printf_custom "4" "Pushing the repo in $git_dir"
    __git_push "$git_dir" && GITADMIN_EXITCODE=0 || GITADMIN_EXITCODE=1
    __getexitcode $GITADMIN_EXITCODE "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  else
    if [ -n "$1" ]; then
      GITADMIN_WD_NAME="$(__git_hostname "$1")"
      projectdir="$1"
      __git_username_repo "$1"
      local username="$username"
      local userrepo="$userrepo"
    else
      projectdir="${projectdir:-$PROJECT_BASE/$GITADMIN_WD_NAME/$username/$userrepo}"
    fi
    if [ -d "$projectdir/.git" ]; then
      printf_custom "4" "Pushing the repo in $projectdir"
      __git_push "$projectdir" && GITADMIN_EXITCODE=0 || GITADMIN_EXITCODE=1
      __getexitcode $GITADMIN_EXITCODE "$(SUCCESS_MSG)" "$(FAILED_MSG)"
    else
      GITADMIN_EXITCODE=1
    fi
  fi
  return $GITADMIN_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# pull a single repo
git_pull_single() {
  SUCCESS_MSG() { echo "Pull from $(__git_remote_origin "${projectdir:-$GITADMIN_WD}") has completed"; }
  FAILED_MSG() { echo "Pull from $(__git_remote_origin "${projectdir:-$GITADMIN_WD}") has failed"; }
  local GITADMIN_WD="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local GITADMIN_EXITCODE=0
  if [ -d "$GITADMIN_WD/.git" ]; then
    printf_custom "4" "Pulling the repo in $GITADMIN_WD"
    __git_pull "$GITADMIN_WD" && GITADMIN_EXITCODE=0 || GITADMIN_EXITCODE=1
    __getexitcode $GITADMIN_EXITCODE "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  else
    if [ -n "$1" ]; then
      GITADMIN_WD_NAME="$(__git_hostname "$1")"
      projectdir="$1"
      __git_username_repo "$1"
    else
      projectdir="${projectdir:-$PROJECT_BASE/$GITADMIN_WD_NAME/$username/$userrepo}"
    fi
    if [ -d "$projectdir/.git" ]; then
      printf_custom "4" "Pulling the repo in $projectdir"
      __git_pull "$projectdir" && GITADMIN_EXITCODE=0 || GITADMIN_EXITCODE=1
      __getexitcode $projectdir "$(SUCCESS_MSG)" "$(FAILED_MSG)"
    else
      return 1
    fi
  fi
  exit "$?"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# clone a single repo
git_clone_single() {
  SUCCESS_MSG() { echo "Cloning from $git_url has completed"; }
  FAILED_MSG() { echo "Cloning from $git_url has failed"; }
  __git_username_repo "$1"
  local git_url="$1"
  local projectdir="${2:-$projectdir}"
  local projectdir="${projectdir:-$PROJECT_BASE/$GITADMIN_WD_NAME/$username/$userrepo}"
  local GITADMIN_EXITCODE=0
  if [ -d "$projectdir/.git" ]; then
    printf_custom "4" "Updating the repo in $projectdir"
    __git_pull "$projectdir" && GITADMIN_EXITCODE=0 || GITADMIN_EXITCODE=1
    __getexitcode $GITADMIN_EXITCODE "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  else
    printf_custom "4" "Cloning the repo to $projectdir"
    __git_clone "$git_url" "$projectdir" && GITADMIN_EXITCODE=0 || GITADMIN_EXITCODE=1
    __getexitcode $GITADMIN_EXITCODE "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  fi
  exit "$?"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#continue pulling
git_update_loop() {
  if [[ "$*" =~ "--while" ]]; then
    while true; do
      for project in $(ls -d "$HOME"/Projects/*/*/*); do
        printf_green "Updating $project $(__devnull __git_pull "$project") $(__getexitcode)"
      done && clear
      printf_custom "3" "Sleeping for a minute $(sleep 60)"
    done
  else
    for project in $(ls -d "$HOME"/Projects/*/*/*); do
      printf_green "Updating $project $(__devnull __git_pull "$project") $(__getexitcode)"
    done
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# cron functions
__run_cron() {
  local frequency="0 4 * * 6"
  local croncmd="$APPNAME cron run"
  case $1 in
  run)
    logr -name gitadmin 'am_i_online --console && $(expr $RANDOM \% 300) && gitadmin org all && gitadmin --user'
    ;;
  remove)
    shift 1
    removecrontab "$frequency $croncmd"
    ;;
  add)
    addtocrontab "$frequency $croncmd"
    ;;
  *)
    addtocrontab "$frequency $croncmd"
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Shorten URL
git_io() {
  local short_url="$1"
  local short_name="$2"
  printf_blue "Attempting to create $short_url on git.io"
  if [ -n "$short_name" ]; then
    MESSAGE="$(curl -q -LSsi https://git.io -F "url=$short_url" -F "code=$short_name" 2>/dev/null | grep 'Location: ')"
  else
    MESSAGE="$(curl -q -LSsi https://git.io -F "url=$short_url" 2>/dev/null | grep 'Location: ')"
  fi
  if [ -n "$MESSAGE" ]; then
    printf_green "$MESSAGE"
  else
    printf_return "Failed to create the shortened URL"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# rename api
__rename_branch_api() {
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && printf_exit "ERROR: GITADMIN_GITHUB_AUTH_TOKEN is not set"
  local git_branch="$1"
  local git_user="${2:-$(basename "$(dirname "$GITADMIN_WD")")}"
  local git_repo="${3:-$(basename "$GITADMIN_WD")}"
  curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" "https://api.github.com/repos/$git_user/$git_repo" \
    -d '{"default_branch":"'$git_branch'"}' | grep -qs '"default_branch": "'$git_branch'"' &>/dev/null &&
    git -C "$GITADMIN_WD" push --delete origin ${git_old_branch:-master} -fq &>/dev/null &&
    return 0 ||
    return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# rename master to main
__rename_branch() {
  local git_branch="$1"
  local git_user="${2:-$(basename "$(dirname "$GITADMIN_WD")")}"
  local git_repo="${3:-$(basename "$GITADMIN_WD")}"
  printf_blue "Changing git branch to $git_branch on $git_repo"
  git -C "$GITADMIN_WD" branch -m ${git_old_branch:-master} "$git_branch" &>/dev/null
  git -C "$GITADMIN_WD" push -u origin "$git_branch" -fq &>/dev/null
  if __rename_branch_api "$git_branch" "$git_user" "$git_repo"; then
    printf_green "Changed the default branch on github.com/$git_user/$git_repo"
  fi &&
    printf_green "Successfully renamed the default branch" ||
    printf_exit 1 1 "Failed to rename the default branch"
  git config init.defaultBranch "$git_branch" &>/dev/null
  #grep -rl --exclude-dir='.git' '/raw/'${git_old_branch:-master}'/' "$GITADMIN_WD" | xargs sed -i 's|/raw/'${git_old_branch:-master}'/|/raw/'$branch'/|g'
  #gitcommit
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# main cloning function
main() {
  sleep 3
  __git_username_repo "$1"
  local git_user="$1"
  local git_repo="${2:-$REPO_URL}"
  local git_base="${projectdir:-$GITADMIN_DEFAULT_GIT_DIR/github}"
  printf_yellow "ProjectDir: ${projectdir:-$PROJECT_DIR/$USERNAME}"
  printf_yellow "BaseRepo URL: $git_repo"
  for i in $(cat "$GITADMIN_TEMP_FILE"); do
    local git_dir="$git_base/$git_user/$i"
    if [ -d "$git_base/$git_user/$i/.git" ]; then
      local git_failed="Git pull $git_user/$i failed"
      local git_sucess="Git pull $git_user/$i completed"
      printf_purple "Now running git pull $git_user/$i"
      if [ -f "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
        cp -Rf "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" "$git_dir/.git/config"
      fi
      __git_pull "$git_dir"
      __getexitcode "$SUCCES" "$ERROR"
    else
      ERROR="Git clone $git_user/$i failed"
      SUCCES="Git clone $git_user/$i completed"
      printf_purple "Now running git clone $git_user/$i"
      __git_clone "$git_repo/$i" "$git_dir"
      __getexitcode "$git_sucess" "$git_failed"
    fi
  done
  exit "${EXIT:-$?}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
GITADMIN_LOG_DIR="${GITADMIN_LOG_DIR:-$HOME/.local/log/gitadmin}"
GITADMIN_CACHE_DIR="${GITADMIN_CACHE_DIR:-$HOME/.cache/gitadmin}"
GITADMIN_CONFIG_DIR="${GITADMIN_CONFIG_DIR:-$HOME/.config/myscripts/gitadmin}"
GITADMIN_CONFIG_BACKUP_DIR="${GITADMIN_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/gitadmin/backups}"
GITADMIN_TEMP_DIR="${GITADMIN_TEMP_DIR:-$HOME/.local/tmp/system_scripts/gitadmin}"
GITADMIN_OPTIONS_DIR="${GITADMIN_OPTIONS_DIR:-$HOME/.local/share/myscripts/gitadmin/options}"
GITADMIN_TEMP_FILE="${GITADMIN_TEMP_FILE:-$(mktemp $GITADMIN_TEMP_DIR/XXXXXX 2>/dev/null)}"
GITADMIN_CONFIG_FILE="${GITADMIN_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
GITADMIN_OUTPUT_COLOR="${GITADMIN_OUTPUT_COLOR:-4}"
GITADMIN_OUTPUT_COLOR_2="${GITADMIN_OUTPUT_COLOR:-6}"
GITADMIN_OUTPUT_COLOR_GOOD="${GITADMIN_OUTPUT_COLOR_GOOD:-2}"
GITADMIN_OUTPUT_COLOR_ERROR="${GITADMIN_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
GITADMIN_GOOD_MESSAGE="${GITADMIN_GOOD_MESSAGE:-Everything Went OK}"
GITADMIN_ERROR_MESSAGE="${GITADMIN_ERROR_MESSAGE:-Well that didn\'t work}"
GITADMIN_NOTIFY_ENABLED="${GITADMIN_NOTIFY_ENABLED:-yes}"
GITADMIN_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GITADMIN_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GITADMIN_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
GITADMIN_VERSION_DATE_FORMAT="${VERSION_DATE_FORMAT:-%Y%m%d%H%M-git}"
GITADMIN_DEFAULT_BRANCH="${GITADMIN_DEFAULT_BRANCH:-main}"
GITADMIN_DEFAULT_USERNAME="${GITADMIN_DEFAULT_USERNAME:-$GITHUB_USERNAME}"
GITADMIN_GITHUB_AUTH_TOKEN="${GITADMIN_GITHUB_AUTH_TOKEN:-$GITHUB_ACCESS_TOKEN}"
GITADMIN_DEFAULT_REPO_BASE="${REPO_URL:-https://github.com}"
GITADMIN_DEFAULT_LICENSE="${MY_LICENSE_FILE:-$CASJAYSDEVDIR/templates/wtfpl.md}"
GITADMIN_VERSION_DATE_FORMAT="${VERSION_DATE_FORMAT:-%Y%m%d%H%M-git}"
GITADMIN_DOMAIN_TEMPLATE="${GITADMIN_DOMAIN_TEMPLATE:-https://github.com/casjay-templates/domain-template}"
GITADMIN_DEFAULT_README="${GITADMIN_DEFAULT_README:-default}"
GITADMIN_DEFAULT_GIT_DIR="${GITADMIN_DEFAULT_GIT_DIR:-$HOME/Projects/gitadmin}"
GITADMIN_DEFAULT_GIT_DIR="${GITADMIN_DEFAULT_GIT_DIR:-$HOME/Projects/gitadmin}"
GITADMIN_DEFAULT_GIT_DIR_GITHUB="${GITADMIN_DEFAULT_GIT_DIR_GITHUB:-$GITADMIN_DEFAULT_GIT_DIR/github}"
GITADMIN_DEFAULT_GIT_DIR_GITLAB="${GITADMIN_DEFAULT_GIT_DIR_GITLAB:-$GITADMIN_DEFAULT_GIT_DIR/gitlab}"
GITADMIN_DEFAULT_GIT_DIR_PRIVATE="${GITADMIN_DEFAULT_GIT_DIR_PRIVATE:-$GITADMIN_DEFAULT_GIT_DIR/Private}"
GITADMIN_PERSONAL_GIT_HOST="${GITADMIN_PERSONAL_GIT_HOST:-$PERSONAL_GIT_HOST}"
GITADMIN_DEFAULT_USER_DOMAIN="${GITADMIN_DEFAULT_USER_DOMAIN:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GITADMIN_CONFIG_DIR/$GITADMIN_CONFIG_FILE" ] && . "$GITADMIN_CONFIG_DIR/$GITADMIN_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$GITADMIN_LOG_DIR" ] || mkdir -p "$GITADMIN_LOG_DIR" &>/dev/null
[ -d "$GITADMIN_TEMP_DIR" ] || mkdir -p "$GITADMIN_TEMP_DIR" &>/dev/null
[ -d "$GITADMIN_CACHE_DIR" ] || mkdir -p "$GITADMIN_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$GITADMIN_CONFIG_DIR/$GITADMIN_CONFIG_FILE" ] && [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config "${SETARGS:-$*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
[ -n "$GITADMIN_DEFAULT_USERNAME" ] || printf_yellow "Please set GITADMIN_DEFAULT_USERNAME or GITHUB_USERNAME variable in settings"
[ -n "$GITADMIN_GITHUB_AUTH_TOKEN" ] || printf_yellow "Please set GITADMIN_GITHUB_AUTH_TOKEN or GITHUB_ACCESS_TOKEN variable in settings"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="u,o,s:"
LONGOPTS="options,config,version,help,dir:,user,org,single:"
ARRAY="repos stow setup newsite private gitlab github single init gist orgs remote list "
ARRAY+="delete create pull clone push user update commit branch log status cron issues squash "
ARRAY+=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    GITADMIN_CWD="$2"
    shift 2
    ;;
  -s | --single)
    shift 1
    [ "$1" == "help" ] && printf_help "Usage: $APPNAME --single | clone a single repo"
    ghsinglerepo "$@"
    exit $?
    ;;
  -u | --user)
    [ "$1" == "help" ] && printf_help "Usage: $APPNAME --user | List user repos"
    __api_user "$USERNAME"
    ;;
  -o | --org)
    [ "$1" == "help" ] && printf_help "Usage: $APPNAME --org | List organization repos"
    __api_org "$USERNAME"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$GITADMIN_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${GITADMIN_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${GITADMIN_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${GITADMIN_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${GITADMIN_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash git curl || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -d "$1" ]; then
  GITADMIN_WD="$1"
  [ -d "$GITADMIN_WD" ] || printf_exit "$GITADMIN_WD doesn't seem to be a directory"
  shift 1
else
  GITADMIN_WD="$PWD"
fi
if [ "$GITADMIN_WD" = "." ]; then
  GITADMIN_WD="$(__basedir ".")"
fi
unset PREVREPO
topdir="$(__git_top_dir "$GITADMIN_WD" 2>/dev/null)"
USERNAME="${GITADMIN_DEFAULT_USERNAME:-}"
REPO_URL="${REPO_URL:-$GITADMIN_DEFAULT_REPO_BASE}"
PROJECT_BASE="$GITADMIN_DEFAULT_GIT_DIR"
PROJECT_DIR="${PROJECT_DIR:-$PROJECT_BASE}"
GITADMIN_TEMP_FILE="${GITADMIN_TEMP_FILE:-/tmp/gitadmin-XXXXXXXXX}"
GITADMIN_WD="${topdir:-$PROJECT_DIR}"
VERSIONFILE="$(__git_top_dir "$topdir" 2>/dev/null)/version.txt"
VERSION_DATE_FORMAT="${VERSION_DATE_FORMAT:-%Y%m%d%H%M-git}"
DOMAIN_TEMPLATE="$GITADMIN_DOMAIN_TEMPLATE"
if [ "$(git config --get user.name | wc -m)" -lt 2 ]; then
  printf_read_input "What is you Name" "120" "GIT_NAME"
  git config --global user.name "$GIT_NAME" 2>/dev/null
fi
if [ "$(git config --get user.email | wc -m)" -lt 2 ]; then
  printf_read_input "What is you Email" "120" "GIT_EMAIL"
  git config --global user.email "$GIT_EMAIL" 2>/dev/null
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
shorten)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin shorten [url] [name]"
  git_io "$@"
  ;;

latest)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin latest [userName] [repoName] [arch]"
  printf_red "This has been moved to install-latest"
  install-latest install "$@"
  ;;

newsite)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin newsite [sitename] [template:default]"
  make_newsite "$@"
  ;;

s | status)
  shift 1
  [[ "$1" = "help" ]] && printf_help "Usage: gitadmin status"
  [ -d "$GITADMIN_WD/.git" ] || printf_exit "$GITADMIN_WD doesn't seem to be a git repo"
  __git_status "$GITADMIN_WD"
  exit $?
  ;;

l | log)
  shift 1
  [[ "$1" = "help" ]] && printf_help "Usage: gitadmin log"
  [ -d "$GITADMIN_WD/.git" ] || printf_exit "$GITADMIN_WD doesn't seem to be a git repo"
  __git_log "$GITADMIN_WD"
  exit $?
  ;;

init)
  shift 1
  [[ "$1" = "help" ]] && printf_help "Usage: gitadmin init"
  git_init "$@"
  ;;

setup | reset)
  shift 1
  [[ "$1" = "help" ]] && printf_help "Usage: gitadmin setup [--automated]"
  if [ "$1" = "--automate" ] || [ "$1" = "--automated" ]; then
    shift 1
    run_git_setup_automated "$@"
  else
    run_git_setup "$@"
  fi
  ;;

stow)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin stow [files]"
  config "$@"
  ;;

branch)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin branch newname userName repoName"
  [ -d "$GITADMIN_WD/.git" ] || printf_exit "$GITADMIN_WD doesn't seem to be a git repo"
  __rename_branch "${1:-main}" "$2" "$3"
  ;;

commit)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin commit [message]"
  gitcommit -d "$GITADMIN_WD" "$@"
  ;;

update)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin update [--while]"
  git_update_loop "$@"
  ;;

create)
  shift 1
  [[ "$1" = "help" || $# -lt 2 ]] && printf_help "Usage: gitadmin create userName repoName Description"
  USERNAME="${1:-$USERNAME}"
  REPONAME="$2"
  ghcreate "$@"
  exit ${gist_exit:-$?}
  ;;

delete)
  shift 1
  [[ "$1" = "help" || "$1" != 2 ]] && printf_help "Usage: gitadmin delete userName repoName"
  USERNAME="${1:-$USERNAME}"
  ghdelete "$2"
  exit ${gist_exit:-$?}
  ;;

push) # push a repo
  shift 1
  [[ "$1" = "help" ]] && printf_help "Usage: gitadmin push [MyProjectDir,all]"
  USERNAME="${1:-$USERNAME}"
  if [ "$1" = "all" ]; then
    for dir in $(find "$GITADMIN_DEFAULT_GIT_DIR"/*/$USERNAME/* -maxdepth 0 -type d); do
      git_push_single "$dir"
    done
  else
    git_push_single "$@"
  fi
  ;;

pull) # update repo
  shift 1
  [[ "$1" = "help" ]] && printf_help "Usage: gitadmin pull [MyProjectDir]"
  USERNAME="${1:-$USERNAME}"
  if [ "$1" = "all" ]; then
    for dir in $(find "$GITADMIN_DEFAULT_GIT_DIR"/*/$USERNAME/* -maxdepth 0 -type d); do
      git_pull_single "$dir"
    done
  else
    git_pull_single "$@"
  fi

  ;;

clone) # Clone repo from url
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin clone MyURL"
  git_clone_single "$@"
  ;;

repos)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin repos [userName]"
  USERNAME="${1:-$USERNAME}"
  REPO_URL="https://github.com/$USERNAME"
  __api_user_token "$USERNAME"
  curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls "$GITHUBAPIREPO" | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
  COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l)"
  printf_green "$MESSAGE\n\t\tThere's currently $COUNT repos avaliable\n\t\tInitialing $REPO_URL"
  cat "$GITADMIN_TEMP_FILE" | printf_column "5"
  ;;

merge) # merge options
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin merge [toBranch] [fromBranch]"
  git -C "$GITADMIN_WD" switch $1
  git -C "$GITADMIN_WD" merge $2
  ;;

rebase) # rebase options
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin rebase [fromBranch] [toBranch]"
  git -C "$GITADMIN_WD" switch $1
  git -C "$GITADMIN_WD" rebase $2
  ;;

switch)
  shift 1
  case $1 in
  create)
    [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin switch create [branchName]"
    git -C "$GITADMIN_WD" switch -c $1
    exit $?
    ;;

  *)
    [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin switch [branchName]"
    git -C "$GITADMIN_WD" switch $1
    exit $?
    ;;
  esac
  ;;

squash) # squash options
  shift 1
  case $1 in
  head)
    shift 1
    [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin squash head [number]"
    git -C "$GITADMIN_WD" rebase -i HEAD~$1
    exit $?
    ;;
  merge)
    [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin squash head [hash]"
    shift 1
    git -C "$GITADMIN_WD" merge --squash $1
    exit $?
    ;;
  hash)
    shift 1
    [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin squash head [hash]"
    git -C "$GITADMIN_WD" rebase -i $1
    exit $?
    ;;
  *)
    [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin squash [hash]"
    git -C "$GITADMIN_WD" rebase -i $1
    exit $?
    ;;
  esac
  ;;

# Remote options
remote)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin remote [show,add]"
  case "$2" in
  show)
    shift 1
    [[ "$1" = "help" ]] && printf_help "Usage: gitadmin remote show"
    git -C "$GITADMIN_WD" remote show origin
    ;;
  add)
    shift 1
    [[ "$1" = "help" ]] && printf_help "Usage: gitadmin remote add [remoteURL]"
    git -C "$GITADMIN_WD" remote add origin "$1"
    ;;
  *)
    git -C "$GITADMIN_WD" remote show origin
    ;;
  esac
  ;;

# gist options
gist)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin gist [userName]"
  case "$1" in
  create)
    [ -z "$1" ] && printf_help "Usage: gitadmin gist create description filename text\n"
    shift 1
    ghgist_create "$@"
    exit ${gist_exit:-$?}
    ;;

  delete)
    shift 1
    [ "$1" -lt 3 ] && printf_help "Usage: gitadmin gist delete [GIT_URL or GIST_ID]\n"
    ghgist_delete "$@"
    exit ${gist_exit:-$?}
    ;;

  edit)
    shift 1
    [ "$1" -lt 3 ] && printf_help "Usage: gitadmin gist edit GIST_ID description filename text\n"
    ghgist_edit "$@"
    exit ${gist_exit:-$?}
    ;;

  list)
    shift 1
    [ -z "$1" ] && printf_help "Usage: gitadmin gist list GIST_USER\n"
    ghgist_list "$@"
    exit ${gist_exit:-$?}
    ;;
  search)
    [ -z "$1" ] && printf_help "Usage: gitadmin gist search GIST_USER SearchTerm"
    search_list "$@"
    exit ${gist_exit:-$?}
    ;;
  esac
  ;;

# Single repo options
single)
  shift 1
  [ "$1" = "help" ] && __help
  [ -z "$1" ] && __help
  case $1 in
  init) # init a github repo
    shift 1
    if [ "$#" -ne 1 ]; then printf_exit "Usage: gitadmin single init RepoName"; fi
    if [[ "$1" = "help" ]]; then printf_exit "Create a new single project\n\t\tUsage: gitadmin single init RepoName"; fi
    do_not_add_a_url "$1"
    homerepo="$(echo "$1" | __sed 's/\",// ; s/\.[^.]*$// ; s#"##g')"
    __mkd "$1"
    [ -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to initialize $GITADMIN_WD"
    repos_init "$GITADMIN_WD"
    exit "$?"
    ;;

  push) # push a repo
    shift 1
    [ "$1" == "help" ] && printf_help "Usage: $APPNAME push | push the repo"
    USERNAME="${1:-$USERNAME}"
    if [ "$1" = "all" ]; then
      for dir in $(find "$GITADMIN_DEFAULT_GIT_DIR"/*/$USERNAME/* -maxdepth 0 -type d); do
        git_push_single "$dir"
      done
    else
      git_push_single "$@"
    fi
    ;;

  pull) # update repo
    shift 1
    [ "$1" == "help" ] && printf_help "Usage: $APPNAME update | pull the repos"
    git_push_single "$@"
    ;;

  clone) # Clone repo from url
    shift 1
    [ "$1" == "help" ] && printf_help "Usage: $APPNAME clone | clone the repos"
    git_clone_single "$@"
    ;;
  esac
  ;;

# User repos
user)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin user [userName]"
  case "$1" in
  list)
    shift 1
    USERNAME="${1:-$USERNAME}"
    __api_user "$USERNAME" | jq '.[].full_name' | sed 's#"##g' | printf_column "5"
    ;;

  *)
    USERNAME="${1:-$USERNAME}"
    REPO_URL="$REPO_URL/$USERNAME"
    __api_user_token "$USERNAME"
    curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls "$GITHUBAPIREPO" | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
    COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l)"
    printf_green "$MESSAGE\n\t\tThere's currently $COUNT repos avaliable\n\t\tInitialing $REPO_URL"
    main "$USERNAME"
    ;;
  esac
  ;;

# organization options
orgs)
  shift 1
  [[ "$1" = "help" ]] && printf_help "Usage: gitadmin org [userName] [all,push,pull,clone]"
  case "$1" in
  all)
    shift 1
    [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin org all [userName]"
    USERNAME="${1:-$USERNAME}"
    git_all_orgs_clone "$USERNAME"
    ;;

  push)
    shift 1
    [[ "$1" = "help" ]] && printf_help "Usage: gitadmin org push [userName]"
    [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && printf_exit "ERROR: GITADMIN_GITHUB_AUTH_TOKEN is not set"
    USERNAME="${1:-$USERNAME}"
    REPO_URL="$REPO_URL/$USERNAME"
    __api_user_token "$USERNAME"
    curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls "$GITHUBAPIREPO" | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
    COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l)"
    printf_green "$MESSAGE\n\t\tThere's currently $COUNT repos avaliable\n\t\tInitialing $REPO_URL"
    for i in $(cat "$GITADMIN_TEMP_FILE"); do
      if [ -d "$PROJECT_DIR/$USERNAME/$i" ]; then
        printf_purple "Now running git push $1/$i"
        ERROR="git push failed for $USERNAME/$i"
        SUCCES="git push completed for $USERNAME/$i"
        if [ -f "$PROJECT_DIR/$USERNAME/$i/gitmasterconfig" ]; then
          cp -Rf "$PROJECT_DIR/$USERNAME/$i/gitmasterconfig" "$PROJECT_DIR/$USERNAME/$i/.git/config"
        fi
        if (__devnull2 git -C "$PROJECT_DIR/$USERNAME/$i" status | grep -q "working tree clean"); then
          __getexitcode
        else
          [ -f "$PROJECT_DIR/$USERNAME/$i/version.txt" ] && date +"$VERSION_DATE_FORMAT" >"$PROJECT_DIR/$USERNAME/$i/version.txt"
          __devnull git -C "$PROJECT_DIR/$USERNAME/$i" add . &&
            __devnull git -C "$PROJECT_DIR/$USERNAME/$i" commit -a -m " ❇🦈🏠❗ General Fixes ❗🏠🦈❇ " &&
            __devnull __git_push "$PROJECT_DIR/$USERNAME/$i"
          __getexitcode
        fi
      fi
    done
    unset ERROR SUCCES
    exit ${gist_exit:-$?}
    ;;

  pull)
    shift 1
    [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin org pull [userName]"
    USERNAME="${1:-$USERNAME}"
    REPO_URL="$REPO_URL/$USERNAME"
    __api_user_token "$USERNAME"
    curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls "$GITHUBAPIREPO" | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
    COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l)"
    printf_green "$MESSAGE\n\t\tThere's currently $COUNT repos avaliable\n\t\tInitialing $REPO_URL"
    main "$USERNAME"
    ;;

  clone)
    shift 1
    [[ "$1" = "help" ]] && printf_help "Usage: gitadmin org clone [userName]"
    USERNAME="${1:-$USERNAME}"
    REPO_URL="$REPO_URL/$USERNAME"
    __api_user_token "$USERNAME"
    curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls $GITHUBAPIREPO | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
    COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l)"
    printf_green "$MESSAGE\n\t\tThere's currently $COUNT repos avaliable\n\t\tInitialing $REPO_URL"
    main "$USERNAME"
    ;;

  list)
    shift 1
    [[ "$1" = "help" ]] && printf_help "Usage: gitadmin org list [userName]"
    USERNAME="$1"
    git_all_orgs "$USERNAME"
    printf_newline
    printf_green "I have found the following organizations"
    echo "$GIT_ALL_REPOS" | tr ' ' '\n' | printf_column "5"
    ;;

  *)
    [[ "$1" = "help" ]] && printf_help "Usage: gitadmin org [userName]"
    USERNAME="${1:-$USERNAME}"
    REPO_URL="$REPO_URL/$USERNAME"
    __api_org_token "$USERNAME"
    curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls "$GITHUBAPIREPO" | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
    COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l)"
    printf_green "$MESSAGE\n\t\tThere's currently $COUNT repos avaliable\n\t\tInitialing $REPO_URL"
    main "$USERNAME"
    ;;
  esac
  ;;

# github repos commands
github) # github repo
  shift 1
  [ "$1" = "help" ] && __help
  [ -z "$1" ] && __help
  case $1 in
  init) # init a github repo
    shift 1
    if [ "$#" -ne 1 ]; then printf_exit "Usage: gitadmin github init RepoName"; fi
    if [[ "$1" = "help" ]]; then printf_exit "Create a new github project\n\t\tUsage: gitadmin github init RepoName"; fi
    do_not_add_a_url "$1"
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$1" | __sed 's/\",// ; s/\.[^.]*$// ; s#"##g')"
    __mkd "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$homerepo"
    [ -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to initialize $homerepo"
    repos_init "$homerepo"
    exit "$?"
    ;;

  clone) # Clone repo from github
    shift 1
    if [ "$#" -ne 1 ]; then printf_exit "Usage: gitadmin github clone username/projectname"; fi
    if [ "$1" = "help" ]; then printf_exit "Clone a github project\n\t\tUsage: gitadmin github clone username/projectname"; fi
    do_not_add_a_url "$1"
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$1" | __sed 's/\",// ; s/\.[^.]*$// ; s#"##g')"
    if [ -d "$homerepo/.git" ]; then
      printf_green "The repo already exists so attempting update"
      __git_pull "$homerepo"
    else
      printf_green "Cloning the repo from github.com/$1"
      mkdir -p "$homerepo"
      __git_clone "https://github.com/$1.git" "$homerepo"
    fi
    [ -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to clone $GITADMIN_WD"
    exit "$?"
    ;;

  push) # Push
    shift 1
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$1" | __sed 's/\",// ; s/\.[^.]*$// ; s#"##g')"
    git_push_single "$homerepo/$1"
    ;;

  pull) # update repo
    shift 1
    [ "$1" == "help" ] && printf_help "Usage: $APPNAME update | pull the repos"
    git_pull_single "$@"
    ;;

  remote) # add github to remote
    shift 1
    if [ "$#" -ne 2 ]; then printf_exit "Usage: gitadmin github remote username/projectname"; fi
    [ "$1" = "help" ] && printf_exit "Add a github project to remote\n\t\tUsage: gitadmin github remote username/projectname"
    do_not_add_a_url "$1"
    git remote add "$1" "https://github.com/$2.git"
    exit "$?"
    ;;
  esac
  ;;

# gitlab repos commands
gitlab)
  shift 1
  [ "$1" = "help" ] && __help
  [ -z "$1" ] && __help
  case $1 in
  init) # init a gitlab repo
