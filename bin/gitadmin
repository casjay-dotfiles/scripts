__gitlab_branch() {
  curl -q -LSsf -X POST \
    -H "PRIVATE-TOKEN: $GITADMIN_GITLAB_AUTH_TOKEN" \
    --url "https://gitlab.com/api/v4/projects/$1" \
    --data "default_branch=${GITADMIN_DEFAULT_BRANCH:-$2}" 2>/dev/null | jq -r '.'
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__update_repo_usage() {
  printf_help 'Usage: '$APPNAME' github update repo "[description,homepage,visibility]=value"'
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__update_repo() {
  local repo="" data="" json=""
  { [ $# = 0 ] || [ "$1" = "help" ]; } && __update_usage
  echo "$1" | grep -q '.*./.*.' || echo "$1" | grep -q '.*.=.*.' || __update_usage
  repo="$1" && shift 1
  while :; do
    case "$1" in
    *=*)
      data="$(echo "$1" | awk -F '=' '{print $1}')" value="$(echo "$1" | awk -F '=' '{print $2}')"
      json+='"'$data'":"'$value'"'
      shift 1
      ;;
    *)
      break
      ;;
    esac
  done
  data="$(printf '%s' "{${json//\"\"/\",\"}}")"
  curl -q -X PATCH --fail -LSsif \
    -H "Content-Type: application/json" \
    -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" \
    --data "$data" \
    "https://api.github.com/repos/$repo" 2>&1 | grep -q 'HTTP/.*.20.' &&
    {
      printf_green "Successfully updated $repo with the following data:"
      #echo "$data" | jq -r | sed 's|[\}\{]||g' | grep -v '^$' | printf_readline
      printf '%s\n' "$data" | jq -c | grep -v '^$' | printf_readline
      exitCode=0
    } || {
    printf_red "Failed to update $repo"
    exitCode=1
  }
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#set folder name based on githost
__git_hostname() {
  echo "$@" | sed -e "s/[^/]*\/\/\([^@]*@\)\?\([^:/]*\).*/\2/" |
    awk -F. '{print $(NF-1) "." $NF}' | sed 's#\..*##g'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#setup directory structure
__git_username_repo() {
  local re=""
  protocol="" separator="" hostname="" username="" userrepo="" githostname=""
  url="$1"
  re="^(https?|git|ssh)(:\/\/|@)([^\/:]+)[\/:]([^\/:]+)\/(.+)$"
  githostname="$(__git_hostname $url 2>/dev/null)"
  if [ -d "$url" ]; then
    protocol=
    separator=
    hostname=localhost
    userrepo="$(__basename "$url")"
    username="$(__basename "$(dirname "$url")")"
    folder="local"
    GITADMIN_NEW_PROJECT_DIR="${GITADMIN_DEFAULT_PROJECT_DIR:-$HOME/Projects}/$folder/$username-$userrepo"
  elif [[ $url =~ $re ]]; then
    protocol=${BASH_REMATCH[1]}
    separator=${BASH_REMATCH[2]}
    hostname=${BASH_REMATCH[3]}
    username=${BASH_REMATCH[4]}
    userrepo=${BASH_REMATCH[5]}
    folder=$githostname
    GITADMIN_NEW_PROJECT_DIR="${GITADMIN_DEFAULT_PROJECT_DIR:-$HOME/Projects}/$folder/$username/$userrepo"
  else
    return 1
  fi
  export url protocol separator hostname username userrepo
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# issues API
__api_issues_token() {
  local git_repo
  { [ $# = 2 ] && git_repo="$1/$2"; } || { [ $# = 1 ] && git_repo="$1"; }
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && export CURL_HEADER="" || export CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  ISSUE_HTML="https://github.com/$git_repo/issues"
  ISSUE_API="https://api.github.com/repos/$git_repo/issues"
  export ISSUE_HTML="${ISSUE_HTML}" ISSUE_API="${ISSUE_API}" CURL_HEADER="${CURL_HEADER}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# call the issues api
__api_issues() {
  local resp=""
  resp="$(curl -q -LSsf -X ${1:-GET} "'$CURL_HEADER'" -H "'Accept: application/vnd.github.v3+json'" "${2:-$ISSUE_API}" 2>/dev/null)"
  [ -n "$resp" ] && printf "%s" "$resp" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Gist API
__api_gist() {
  local user=""
  user="${1:-$GITADMIN_DEFAULT_USERNAME}"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "https://api.github.com/users/$user/gists"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set Message for token - user
__api_user_token() {
  local user=""
  user="${1:-$GITADMIN_DEFAULT_USERNAME}"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  if [ -n "$GITADMIN_GITHUB_AUTH_TOKEN" ]; then
    export GITHUBAPIREPO="https://api.github.com/users/$user/repos?per_page=1000&type=owner"
    export MESSAGE="Getting the repos for $user using\n\t\tgithub token $GITADMIN_GITHUB_AUTH_TOKEN"
  else
    export GITHUBAPIREPO="https://api.github.com/users/$user/repos?per_page=1000"
    export MESSAGE="Getting the repos for $GITADMIN_DEFAULT_USERNAME"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User api
__api_user() {
  local user=""
  user="${1:-$GITADMIN_DEFAULT_USERNAME}"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  __api_user_token "$user"
  __urlverify "$GITHUBAPIREPO" || return 1
  __devnull2 curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "$GITHUBAPIREPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set Message for token - org
__api_org_token() {
  local user=""
  user="${1:-$GITADMIN_DEFAULT_USERNAME}"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  if [ -n "$GITADMIN_GITHUB_AUTH_TOKEN" ]; then
    export GITHUBAPIREPO="https://api.github.com/orgs/$user/repos?per_page=1000&type=owner"
    export MESSAGE="Getting the repos for $user using\n\t\tgithub token $GITADMIN_GITHUB_AUTH_TOKEN"
  else
    export GITHUBAPIREPO="https://api.github.com/orgs/$user/repos?per_page=1000"
    export MESSAGE="Getting the repos for $user"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Organization API
__api_org() {
  local user=""
  user="${1:-$GITADMIN_DEFAULT_USERNAME}"
  [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && CURL_HEADER="" || CURL_HEADER='-H "Authorization: token '$GITADMIN_GITHUB_AUTH_TOKEN'"'
  __api_user_token "$user"
  __urlverify "$GITHUBAPIREPO" || return 1
  __devnull2 curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "$GITHUBAPIREPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Call the API
__api_url() {
  __api_user "${1:-$GITADMIN_DEFAULT_USERNAME}" || __api_org "${1:-$GITADMIN_DEFAULT_USERNAME}" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# pull function
__git_pull() {
  local git_dir="" args="" regex=""
  git_dir="${1:-$GITADMIN_CWD}" && shift 1
  args="$*"
  regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$(__git_remote_origin "$git_dir")" =~ $regex ]]; then
    if am_i_online; then
      git -C "$git_dir" pull $args -f -q &>/dev/null && return 0 || return 1
    else return 1; fi
  else
    git -C "$git_dir" pull $args -f -q &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Push function
__git_push() {
  local git_dir="" args="" regex=""
  git_dir="${1:-$GITADMIN_CWD}" && shift 1
  args="$*"
  regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  [ -f "$git_dir/.no_push" ] || return 0
  if [[ "$(__git_remote_origin "$git_dir")" =~ $regex ]]; then
    if am_i_online; then
      git -C "$git_dir" push $args -q &>/dev/null && return 0 || return 1
    else
      return 1
    fi
  else
    git -C "$git_dir" push $args -q &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Clone function
__git_clone() {
  local git_url="" git_dir="" args="" regex="" exitCode=0
  git_url="$1" && shift 1
  git_dir="$1" && shift 1
  args="$*" && shift $#
  regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$git_url" =~ $regex ]]; then
    if am_i_online; then
      [ -d "$git_dir" ] &&
        git -C "$git_dir" pull -q &>/dev/null ||
        git clone "$git_url" "$git_dir" -q $args &>/dev/null
      exitCode=$?
    else
      return 1
    fi
  else
    [ -d "$git_dir" ] &&
      git -C "$git_dir" pull -q &>/dev/null ||
      git clone "$git_url" "$git_dir" -q $args &>/dev/null
    exitCode=$?
  fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__clone_success() {
  exitCode=${1:-$?}
  git_dir="${2:-$1}"
  if [ -d "$git_dir/.git" ] && [ $exitCode = 0 ]; then
    printf_cyan "Successfully cloned to $git_dir"
  else
    printf_red "Failed to clone $git_url"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a README.md file if one doesn't exist
create_new_readme_template() {
  local git_dir="" author="" GitBaseDir="" BaseDir=""
  [ "$NOREADME" = "yes" ] && return 0
  git_dir="${1:-$GITADMIN_CWD}"
  if [ -f "$(command -v gen-readme)" ] && [ ! -f "$git_dir/README.md" ]; then
    gen-readme "$git_dir" "$(basename "${GITADMIN_DEFAULT_README:-default}")" "README.md" &>/dev/null
  else
    author="$(__git_globaluser)"
    GitBaseDir="$(__git_top_dir "$git_dir")"
    BaseDir="${GitBaseDir##*/}"
    [ -f "$CASJAYSDEVDIR/templates/readmes/projects/default.md" ] &&
      cat "$CASJAYSDEVDIR/templates/readmes/projects/default.md" >"$git_dir/README.md"
    [ -f "$git_dir/README.md" ] && __sed -i "s#ProjectName#${BaseDir}#g" "$git_dir/README.md"
    [ -f "$git_dir/README.md" ] && __sed -i "s#AuthorName#${author}#g" "$git_dir/README.md"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a license if a LICENSE.md file doesn't exist
create_new_license() {
  local git_dir="" author="" year=""
  [ "$NOLICENSE" = "yes" ] && return 0
  git_dir="${1:-$GITADMIN_CWD}"
  if [ -f "$(command -v gen-license)" ] && [ ! -f "$git_dir/LICENSE.md" ]; then
    gen-license "$git_dir" "$(basename "$GITADMIN_DEFAULT_LICENSE")" &>/dev/null
  else
    author="$(__git_globaluser)"
    year="$(date +'%Y')"
    [ -f "$GITADMIN_DEFAULT_LICENSE" ] && cat "$GITADMIN_DEFAULT_LICENSE" >"$git_dir/LICENSE.md"
    [ -f "$git_dir/LICENSE.md" ] && __sed -i "s#CURYEAR#${year}#g" "$git_dir/LICENSE.md"
    [ -f "$git_dir/LICENSE.md" ] && __sed -i "s#AuthorName#${author}#g" "$git_dir/LICENSE.md"
  fi
}
