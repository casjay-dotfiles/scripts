# Set actions based on variables

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
#requiresudo "$0" "$@" || exit 2     # exit 2 if errors
#cmd_exists --error --ask bash || exit 3 # exit 3 if not found
#am_i_online --error || exit 4           # exit 4 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
PREVREPO=""
[ -d "$GITADMIN_CWD/.git" ] && GITADMIN_CWD="$(__git_top_dir "$GITADMIN_CWD" 2>/dev/null)"
[ -f "$GITADMIN_CWD/$GITADMIN_DEFAULT_VERSION_FILE" ] && GITADMIN_DEFAULT_VERSION_FILE="$GITADMIN_CWD/$GITADMIN_DEFAULT_VERSION_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
[ -n "$GITADMIN_DEFAULT_USERNAME" ] || printf_yellow "Please set GITADMIN_DEFAULT_USERNAME or GITHUB_USERNAME variable in settings"
[ -n "$GITADMIN_GITHUB_AUTH_TOKEN" ] || printf_yellow "Please set GITADMIN_GITHUB_AUTH_TOKEN or GITHUB_ACCESS_TOKEN variable in settings"
if [ "$(git config --get user.name | wc -m)" -lt 2 ]; then
  printf_read_input "What is you Name" "120" "GIT_NAME"
  git config --global user.name "$GIT_NAME" 2>/dev/null
  unset GIT_NAME
fi
if [ "$(git config --get user.email | wc -m)" -lt 2 ]; then
  printf_read_input "What is you Email" "120" "GIT_EMAIL"
  git config --global user.email "$GIT_EMAIL" 2>/dev/null
  unset GIT_EMAIL
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
shorten) # github url shortner
  shift 1
  { [ "$1" = "help" ] || [ -z "$1" ]; } && printf_help "Usage: gitadmin shorten [url] [name]"
  git_io "$@"
  ;;

latest) # get the latest release
  shift 1
  { [ "$1" = "help" ] || [ -z "$1" ]; } && printf_help "Usage: gitadmin latest [userName] [repoName] [arch]"
  printf_red "This has been moved to install-latest"
  install-latest install "$@"
  ;;

newsite) # create a new site
  shift 1
  { [ "$1" = "help" ] || [ -z "$1" ]; } && printf_help "Usage: gitadmin newsite [sitename] [template:default]"
  make_newsite "$@"
  ;;

stow) # backup dotfiles
  shift 1
  { [ "$1" = "help" ] || [ -z "$1" ]; } && printf_help "Usage: gitadmin stow [files]"
  config "$@"
  ;;

s | status) # repo status
  shift 1
  [ "$1" = "help" ] && printf_help "Usage: gitadmin status"
  [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
  [ -d "$GITADMIN_CWD/.git" ] || printf_exit "$GITADMIN_CWD doesn't seem to be a git repo"
  __git_status "$GITADMIN_CWD"
  exit $?
  ;;

l | log) # git log
  shift 1
  [ "$1" = "help" ] && printf_help "Usage: gitadmin log"
  [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
  [ -d "$GITADMIN_CWD/.git" ] || printf_exit "$GITADMIN_CWD doesn't seem to be a git repo"
  __git_log "$GITADMIN_CWD"
  exit $?
  ;;

init) # initialize repo
  shift 1
  [ "$1" = "help" ] && printf_help "Usage: gitadmin init"
  [ -d "$1" ] && GITADMIN_CWD="$1" && shift 1
  git_init "$@"
  ;;

setup | reset) # initialize repo
  shift 1
  [ "$1" = "help" ] && printf_help "Usage: gitadmin setup [--automated]"
  [ -d "$1" ] && GITADMIN_CWD="$1" && shift 1
  if [ "$AUTOMATED" = "true" ]; then
    run_git_setup_automated "$@"
  else
    run_git_setup "$@"
  fi
  ;;

branch) # branch options
  shift 1
  case $1 in
  rename)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ] && printf_exit 1 2 "Usage: $APPNAME branch rename fromBranch toBranch - $APPNAME branch rename master main"; }
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    fromBranch="${1:-master}"
    toBranch="${2:-main}"
    git -C "$GITADMIN_CWD" branch -m $fromBranch $toBranch
    git -C "$GITADMIN_CWD" fetch origin
    git -C "$GITADMIN_CWD" branch -u origin/$fromBranch $toBranch
    git -C "$GITADMIN_CWD" remote set-head origin -a
    git -C "$GITADMIN_CWD" push --set-upstream origin $toBranch
    git -C "$GITADMIN_CWD" branch -d $fromBranch
    exit $?
    ;;

  *)
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin branch newname userName repoName"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    [ -d "$GITADMIN_CWD/.git" ] || printf_exit "$GITADMIN_CWD doesn't seem to be a git repo"
    __rename_branch "${1:-main}" "$2" "$3"
    ;;
  esac
  ;;

commit) # commit changes
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin commit [message]"
  [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
  gitcommit --dir "$GITADMIN_CWD" "${@:-all}"
  ;;

update) # update local repos
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin update [--while]"
  git_update_loop "$@"
  ;;

create) # create github repo
  shift 1
  { [ $# -le 2 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin create userName repoName Description"
  GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
  REPONAME="$2"
  ghcreate "$@"
  exit ${gist_exit:-$?}
  ;;

delete) # delete github repo
  shift 1
  { [ $# -le 2 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin delete userName repoName"
  GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
  REPO_URL="$2"
  ghdelete "$GITADMIN_DEFAULT_USERNAME" "$REPO_URL"
  exit ${gist_exit:-$?}
  ;;

push) # push a repo
  shift 1
  [ "$1" = "help" ] && printf_help "Usage: gitadmin push [MyProjectDir,all]"
  [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
  GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
  if [ "$1" = "all" ]; then
    repo_dirs="$(find "$GITADMIN_DEFAULT_PROJECT_DIR"/*/"$GITADMIN_DEFAULT_USERNAME"/* -maxdepth 0 -type d | grep '^' || echo '')"
    [ -n "$repo_dirs" ] || printf_exit "Could not find any directories for $GITADMIN_DEFAULT_USERNAME in $GITADMIN_DEFAULT_PROJECT_DIR"
    for dir in $repo_dirs; do
      git_push_single "$dir"
    done
  else
    git_push_single "${@:-$GITADMIN_CWD}"
  fi
  ;;

pull) # update repo
  shift 1
  [ "$1" = "help" ] && printf_help "Usage: gitadmin pull [MyProjectDir]"
  [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
  GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
  if [ "$1" = "all" ]; then
    repo_dirs="$(find "$GITADMIN_DEFAULT_PROJECT_DIR"/*/"$GITADMIN_DEFAULT_USERNAME"/* -maxdepth 0 -type d | grep '^' || echo '')"
    [ -n "$repo_dirs" ] || printf_exit "Could not find any directories for $GITADMIN_DEFAULT_USERNAME in $GITADMIN_DEFAULT_PROJECT_DIR"
    for dir in $repo_dirs; do
      git_pull_single "$dir"
    done
  else
    git_pull_single "${@:-$GITADMIN_CWD}"
  fi

  ;;

clone) # Clone repo from url
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin clone MyURL"
  REPO_URL="$(__strip_git_url "$1")"
  git_clone_single "${1:-$REPO_URL}" ${2:-}
  ;;

repos) # Show repos owned by user
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin repos [userName]"
  GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
  GITADMIN_DEFAULT_REPO_BASE="https://github.com/$GITADMIN_DEFAULT_USERNAME"
  __api_user_token "$GITADMIN_DEFAULT_USERNAME"
  curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls "$GITHUBAPIREPO" | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
  COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l | grep '^')"
  [ -n "$COUNT" ] || printf_exit "No repos found for $GITADMIN_DEFAULT_USERNAME"
  printf_green "$MESSAGE"
  printf_blue "There's currently $COUNT repos available"
  printf_green "Initialing $GITADMIN_DEFAULT_REPO_BASE"
  cat "$GITADMIN_TEMP_FILE" | printf_column "5"
  ;;

merge) # merge options
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin merge [toBranch] [fromBranch]"
  [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
  git -C "$GITADMIN_CWD" switch $1
  git -C "$GITADMIN_CWD" merge $2
  ;;

rebase) # rebase options
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin rebase [fromBranch] [toBranch]"
  [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
  git -C "$GITADMIN_CWD" switch $1
  git -C "$GITADMIN_CWD" rebase $2
  ;;

switch) # switch between branches
  shift 1
  case $1 in
  create)
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin switch create [branchName]"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    git -C "$GITADMIN_CWD" switch -c $1
    exit $?
    ;;

  *)
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin switch [branchName]"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    git -C "$GITADMIN_CWD" switch $1
    exit $?
    ;;
  esac
  ;;

squash) # squash options
  shift 1
  case $1 in
  head)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin squash head [number]"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    git -C "$GITADMIN_CWD" rebase -i HEAD~$1
    exit $?
    ;;
  merge)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin squash merge [hash]"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    git -C "$GITADMIN_CWD" merge --squash $1
    exit $?
    ;;
  rebase)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin squash rebase [hash]"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    git -C "$GITADMIN_CWD" rebase -i $1
    exit $?
    ;;
  *)
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin squash [hash]"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    git -C "$GITADMIN_CWD" rebase -i $1
    exit $?
    ;;
  esac
  ;;

remote) # Remote options
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin remote [show,add]"
  [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
  case "$2" in
  show)
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: gitadmin remote show [name]"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    git -C "$GITADMIN_CWD" remote show "${1:-origin}"
    ;;
  add)
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: gitadmin remote add [remoteURL] [name]"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    REPO_URL="$(__strip_git_url "$1")"
    git -C "$GITADMIN_CWD" remote add ${2:-origin} "$REPO_URL"
    ;;
  *)
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    git -C "$GITADMIN_CWD" remote show ${1:-origin}
    ;;
  esac
  ;;

list) # list user repos
  shift 1
  [ "$1" = "help" ] && printf_help "Usage: gitadmin list [username]"
  if [ "$1" = "raw" ]; then
    shift 1
    GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
    [ -n "$GITADMIN_DEFAULT_USERNAME" ] || printf_exit "Usage: $APPNAME list [raw] github_user"
    git_all_orgs "$GITADMIN_DEFAULT_USERNAME"
    echo "$GIT_ALL_REPOS" | tr ' ' '\n'
  else
    GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
    [ -n "$GITADMIN_DEFAULT_USERNAME" ] || printf_exit "Usage: $APPNAME list [raw] github_user"
    git_all_orgs "$GITADMIN_DEFAULT_USERNAME"
    printf_green "I have found the following organizations"
    echo "$GIT_ALL_REPOS" | tr ' ' '\n' | printf_column "5"
    printf_newline
  fi
  ;;

gist) # gist options
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin gist [clone,create,delete,edit,list,search,] [userName]"
  case "$1" in
  clone)
    shift 1
    [ $# -lt 1 ] && printf_help "Usage: gitadmin gist clone id [directory]\n"
    SET_REPO="$(curl -q -LSsfI "https://gist.github.com/$1" | grep 'location: https://' | head -n1 | awk -F': ' '{print $2}' | grep "$1" || echo '')"
    REPO_URL="$(__strip_git_url "$SET_REPO")"
    GIST_USER="$(basename "$(dirname "$SET_REPO")" | grep '^')"
    GISTNAME="$(basename "$REPO_URL")"
    GISTDIR="${2:-$GITADMIN_DEFAULT_PROJECT_DIR/gists/$GIST_USER/$GISTNAME}"
    printf_cyan "Cloning $REPO_URL"
    printf_yellow "to: $GISTDIR"
    __git_clone "$REPO_URL" "$GISTDIR"
    exit $?
    ;;

  create)
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: gitadmin gist create description filename text\n"
    if [ -p "/dev/stdin" ]; then
      cat - >"$GITADMIN_TEMP_FILE" 2>/dev/null
      filename="${2:-gitadmin-$(basename "$GITADMIN_TEMP_FILE")}"
      descript="${1:-$(grep -s ' @@Description' "$GITADMIN_TEMP_FILE" | awk -F ':  ' '{print $2}' | sed 's|^  ||g' | head -n1 | grep '^' || echo 'Posting new gist')}"
    else
      descript="${1:-New Gist}"
      filename="${2:-$(basename "$GITADMIN_TEMP_FILE")}"
    fi
    ghgist_create "$descript" "$filename" "$GITADMIN_TEMP_FILE"
    gist_exit=$?
    exit ${gist_exit:-$?}
    ;;

  delete)
    shift 1
    { [ $# -lt 1 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin gist delete [GIT_URL or GIST_ID]\n"
    ghgist_delete "$@"
    exit ${gist_exit:-$?}
    ;;

  edit)
    shift 1
    { [ $# -lt 3 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin gist edit GIST_ID description filename text\n"
    ghgist_edit "$@"
    exit ${gist_exit:-$?}
    ;;

  list)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin gist list GIST_USER\n"
    ghgist_list "$@"
    exit ${gist_exit:-$?}
    ;;

  search)
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin gist search GIST_USER SearchTerm"
    search_list "$@"
    exit ${gist_exit:-$?}
    ;;
  esac
  ;;

single) # Single repo options
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && __help
  case $1 in
  init) # init a github repo
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin single init RepoName"
    do_not_add_a_url "${1:-$GITADMIN_CWD}"
    if echo "${1:-$GITADMIN_CWD}" | grep -q '\.git$'; then
      homerepo="$(echo "${1:-$GITADMIN_CWD}" | grep '\.git$' | __sed 's/\",//;s/\.[^.]*$//;s#"##g')"
    else
      homerepo="$(__strip_git_url "${1:-$GITADMIN_CWD}")"
    fi
    __mkd "$homerepo" && [ ! -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to initialize $homerepo"
    repos_init "$homerepo"
    exit "$?"
    ;;

  push) # push a repo
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: $APPNAME push | push the repo"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
    if [ "$1" = "all" ]; then
      repo_dirs="$(find "$GITADMIN_DEFAULT_PROJECT_DIR"/*/"$GITADMIN_DEFAULT_USERNAME"/* -maxdepth 0 -type d | grep '^' || echo '')"
      [ -n "$repo_dirs" ] || printf_exit "Could not find any directories for $GITADMIN_DEFAULT_USERNAME in $GITADMIN_DEFAULT_PROJECT_DIR"
      for dir in $repo_dirs; do
        git_push_single "$dir"
      done
    else
      git_push_single "$@"
    fi
    ;;

  pull) # update repo
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: $APPNAME update | pull the repos"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    git_push_single "${@:-$GITADMIN_CWD}"
    ;;

  clone) # Clone repo from url
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: $APPNAME clone [URL] [directory] | clone the repos"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    [ $# -eq 0 ] && printf_help "Usage: $APPNAME clone [URL] [directory] | clone the repos"
    REPO_URL="$(__strip_git_url "$1")"
    git_clone_single "$REPO_URL" "${2:-$GITADMIN_CWD}"
    ;;
  esac
  ;;

user) # User repos
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin user [list,clone] [userName]"
  case "$1" in
  list)
    shift 1
    GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
    __api_user "$GITADMIN_DEFAULT_USERNAME" | jq '.[].full_name' 2>/dev/null | sed 's#"##g' | printf_column "5"
    ;;

  *)
    [ "$1" = "clone" ] && shift 1
    GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
    GITADMIN_DEFAULT_REPO_BASE="$GITADMIN_DEFAULT_REPO_BASE/$GITADMIN_DEFAULT_USERNAME"
    __api_user_token "$GITADMIN_DEFAULT_USERNAME"
    curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls "$GITHUBAPIREPO" | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
    COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l | grep '^')"
    [ -n "$COUNT" ] || printf_exit "No repos found for $GITADMIN_DEFAULT_USERNAME"
    printf_green "$MESSAGE"
    printf_blue "There's currently $COUNT repos available"
    printf_green "Initialing $GITADMIN_DEFAULT_REPO_BASE"
    main "$GITADMIN_DEFAULT_USERNAME"
    ;;
  esac
  ;;

orgs) # organization options
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin org [all,push,pull,clone] [userName]"
  case "$1" in
  all)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin org all [userName]"
    GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
    git_all_orgs_clone "$GITADMIN_DEFAULT_USERNAME"
    ;;

  push)
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: gitadmin org push [userName]"
    [ -z "$GITADMIN_GITHUB_AUTH_TOKEN" ] && printf_exit "ERROR: GITADMIN_GITHUB_AUTH_TOKEN is not set"
    GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
    GITADMIN_DEFAULT_REPO_BASE="$GITADMIN_DEFAULT_REPO_BASE/$GITADMIN_DEFAULT_USERNAME"
    __api_user_token "$GITADMIN_DEFAULT_USERNAME"
    curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls "$GITHUBAPIREPO" | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
    COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l | grep '^')"
    [ -n "$COUNT" ] || printf_exit "No repos found for $GITADMIN_DEFAULT_USERNAME"
    printf_green "$MESSAGE"
    printf_blue "There's currently $COUNT repos available"
    printf_green "Initialing $GITADMIN_DEFAULT_REPO_BASE"
    for i in $(<"$GITADMIN_TEMP_FILE"); do
      if [ -d "$GITADMIN_DEFAULT_PROJECT_DIR/$GITADMIN_DEFAULT_USERNAME/$i" ]; then
        printf_purple "Now running git push $1/$i"
        ERROR="git push failed for $GITADMIN_DEFAULT_USERNAME/$i"
        SUCCES="git push completed for $GITADMIN_DEFAULT_USERNAME/$i"
        if [ -f "$GITADMIN_DEFAULT_PROJECT_DIR/$GITADMIN_DEFAULT_USERNAME/$i/gitmasterconfig" ]; then
          cp -Rf "$GITADMIN_DEFAULT_PROJECT_DIR/$GITADMIN_DEFAULT_USERNAME/$i/gitmasterconfig" "$GITADMIN_DEFAULT_PROJECT_DIR/$GITADMIN_DEFAULT_USERNAME/$i/.git/config"
        fi
        if (__devnull2 git -C "$GITADMIN_DEFAULT_PROJECT_DIR/$GITADMIN_DEFAULT_USERNAME/$i" status | grep -q "working tree clean"); then
          __getexitcode "$?" "$ERROR" "$SUCCES"
        else
          [ -f "$GITADMIN_DEFAULT_PROJECT_DIR/$GITADMIN_DEFAULT_USERNAME/$i/version.txt" ] && date +"$GITADMIN_DEFAULT_VERSION_FORMAT" >"$GITADMIN_DEFAULT_PROJECT_DIR/$GITADMIN_DEFAULT_USERNAME/$i/version.txt"
          git -C "$GITADMIN_DEFAULT_PROJECT_DIR/$GITADMIN_DEFAULT_USERNAME/$i" add . |& __devnull &&
            git -C "$GITADMIN_DEFAULT_PROJECT_DIR/$GITADMIN_DEFAULT_USERNAME/$i" commit -a -m " ❇🦈🏠❗ General Fixes ❗🏠🦈❇ " |& __devnull &&
            __git_push "$GITADMIN_DEFAULT_PROJECT_DIR/$GITADMIN_DEFAULT_USERNAME/$i" |& __devnull
          __getexitcode "$?" "$ERROR" "$SUCCES"
        fi
      fi
    done
    unset ERROR SUCCES
    exit ${gist_exit:-$?}
    ;;

  pull)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin org pull [userName]"
    GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
    GITADMIN_DEFAULT_REPO_BASE="$GITADMIN_DEFAULT_REPO_BASE/$GITADMIN_DEFAULT_USERNAME"
    __api_user_token "$GITADMIN_DEFAULT_USERNAME"
    curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls "$GITHUBAPIREPO" | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
    COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l | grep '^')"
    [ -n "$COUNT" ] || printf_exit "No repos found for $GITADMIN_DEFAULT_USERNAME"
    printf_green "$MESSAGE"
    printf_blue "There's currently $COUNT repos available"
    printf_green "Initialing $GITADMIN_DEFAULT_REPO_BASE"
    main "$GITADMIN_DEFAULT_USERNAME"
    ;;

  clone)
    shift 1
    { [ $# -eq 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin org clone [userName]"
    GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
    GITADMIN_DEFAULT_REPO_BASE="$GITADMIN_DEFAULT_REPO_BASE/$GITADMIN_DEFAULT_USERNAME"
    __api_user_token "$GITADMIN_DEFAULT_USERNAME"
    curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls $GITHUBAPIREPO | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
    COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l | grep '^')"
    [ -n "$COUNT" ] || printf_exit "No repos found for $GITADMIN_DEFAULT_USERNAME"
    printf_green "$MESSAGE"
    printf_blue "There's currently $COUNT repos available"
    printf_green "Initialing $GITADMIN_DEFAULT_REPO_BASE"
    main "$GITADMIN_DEFAULT_USERNAME"
    ;;

  list)
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: gitadmin org list [userName]"
    GITADMIN_DEFAULT_USERNAME="$1"
    git_all_orgs "$GITADMIN_DEFAULT_USERNAME"
    printf_newline
    printf_green "I have found the following organizations"
    echo "$GIT_ALL_REPOS" | tr ' ' '\n' | printf_column "5"
    ;;

  *)
    [ "$1" = "help" ] && printf_help "Usage: gitadmin org [userName]"
    GITADMIN_DEFAULT_USERNAME="${1:-$GITADMIN_DEFAULT_USERNAME}"
    GITADMIN_DEFAULT_REPO_BASE="$GITADMIN_DEFAULT_REPO_BASE/$GITADMIN_DEFAULT_USERNAME"
    __api_org_token "$GITADMIN_DEFAULT_USERNAME"
    curl -q -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -Ls "$GITHUBAPIREPO" | grep -w clone_url | awk -F / '{print $NF}' | __sed 's/\",//' | __sed 's/\.[^.]*$//' >"$GITADMIN_TEMP_FILE"
    COUNT="$(cat "$GITADMIN_TEMP_FILE" | wc -l | grep '^')"
    [ -n "$COUNT" ] || printf_exit "No repos found for $GITADMIN_DEFAULT_USERNAME"
    printf_green "$MESSAGE"
    printf_blue "There's currently $COUNT repos available"
    printf_green "Initialing $GITADMIN_DEFAULT_REPO_BASE"
    main "$GITADMIN_DEFAULT_USERNAME"
    ;;
  esac
  ;;

github) # github repo
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && __help
  case $1 in
  init) # init a github repo
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin github init RepoName"
    do_not_add_a_url "$1"
    if echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$1" | grep -q '\.git$'; then
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$1" | grep '\.git$' | __sed 's/\",//;s/\.[^.]*$//;s#"##g')"
    else
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$1")"
    fi
    __mkd "$homerepo" && [ ! -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to initialize $homerepo"
    repos_init "$homerepo"
    exit "$?"
    ;;

  clone) # Clone repo from github
    shift 1
    { [ $# -lt 1 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin github clone username/projectname"
    url="$(echo "$*" | tr ' ' '/')"
    do_not_add_a_url "$url"
    remote_repo="https://github.com/$(__strip_git_url "$url").git"
    if echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$1" | grep -q '\.git$'; then
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$url" | grep '\.git$' | __sed 's/\",//;s/\.[^.]*$//;s#"##g')"
    else
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$url")"
    fi
    if [ -d "$homerepo/.git" ]; then
      printf_green "The repo already exists so attempting update"
      git_pull_single "$homerepo"
      retVal=$?
    else
      printf_green "Cloning the repo from $remote_repo"
      mkdir -p "$homerepo"
      git_clone_single "$remote_repo" "$homerepo"
      retVal=$?
    fi
    [ -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to clone to $homerepo"
    exit "$retVal"
    ;;

  push) # Push
    shift 1
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$1")"
    __mkd "$homerepo" && [ -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to push from: $homerepo"
    git_push_single "$homerepo"
    ;;

  pull) # update repo
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: $APPNAME update | pull the repos"
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITHUB/$1")"
    __mkd "$homerepo" && [ -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to pull to: $homerepo"
    git_pull_single "$homerepo"
    ;;

  remote) # add github to remote
    shift 1
    { [ $# -lt 2 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin github remote [username/projectname] [name]"
    [ -d "$1/.git" ] && GITADMIN_CWD="$1" && shift 1
    do_not_add_a_url "$1"
    git -C "$GITADMIN_CWD" remote add "${2:-orgin}" "https://github.com/$1.git"
    exit "$?"
    ;;

  update) # update repo info
    shift 1
    __update_repo "$@"
    exit $?
    ;;
  esac
  ;;

gitlab) # gitlab repos commands
  shift 1
  [ "$1" = "help" ] && __help
  [ -z "$1" ] && __help
  case $1 in
  init) # init a gitlab repo
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin gitlab init RepoName"
    do_not_add_a_url "$1"
    if echo "$GITADMIN_DEFAULT_GIT_DIR_GITLAB/$1" | grep -q '\.git$'; then
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITLAB/$1" | grep '\.git$' | __sed 's/\",//;s/\.[^.]*$//;s#"##g')"
    else
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITLAB/$1")"
    fi
    __mkd "$homerepo" && [ ! -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to initialize $homerepo"
    repos_init "$homerepo"
    exit "$?"
    ;;

  clone) # Clone repo from gitlab
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin gitlab clone username/projectname"
    do_not_add_a_url "$1"
    remote_repo="https://gitlab.com/$(__strip_git_url "$1")"
    if echo "$GITADMIN_DEFAULT_GIT_DIR_GITLAB/$1" | grep -q '\.git$'; then
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITLAB/$1" | grep '\.git$' | __sed 's/\",//;s/\.[^.]*$//;s#"##g')"
    else
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITLAB/$1")"
    fi
    if [ -d "$homerepo/.git" ]; then
      printf_green "The repo already exists so attempting update"
      __git_pull "$homerepo"
      retVal=$?
    else
      printf_green "Cloning the repo from $remote_repo"
      mkdir -p "$homerepo"
      __git_clone "$remote_repo" "$homerepo"
      retVal=$?
    fi
    __clone_success $retVal "$homerepo"
    [ -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to clone to: $homerepo"
    exit "$?"
    ;;

  push)
    shift 1
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITLAB/$1")"
    git_push_single "$homerepo"
    ;;

  pull) # update repo
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: $APPNAME update | pull the repos"
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_GITLAB/$1")"
    git_pull_single "$homerepo"
    ;;

  remote) # add gitlab to remote
    shift 1
    { [ $# -ne 0 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin gitlab remote [username/projectname] [name]"
    do_not_add_a_url "$1"
    remote_repo="https://gitlab.com/$(__strip_git_url "$1")"
    git -C "$GITADMIN_CWD" remote add "${2:-orgin}" "https://github.com/$1.git"
    exit "$?"
    ;;

  repos)
    shift 1
    __gitlab_orgs "$@"
    exit $?
    ;;

  branch)
    shift 1
    { [ $# -ne 2 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin gitlab branch projectID branch"
    __gitlab_branch "$@"
    exit $?
    ;;
  esac
  ;;

private) # private repos commands
  shift 1
  if [ $# = 0 ] || [ "$1" = "help" ] || [ -z "$GITADMIN_PERSONAL_GIT_HOST" ]; then
    [ -n "$GITADMIN_PERSONAL_GIT_HOST" ] || printf_red "You dont have the env variable GITADMIN_PERSONAL_GIT_HOST set"
    printf_green "Useful if you have a private server such as gitea"
    printf_green "Useful if you have a private server such as gitea"
    exit 0
  fi
  case $1 in
  init) # init a private repo
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin private init RepoName"
    do_not_add_a_url "$1"
    if echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1" | grep -q '\.git$'; then
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1" | grep '\.git$' | __sed 's/\",//;s/\.[^.]*$//;s#"##g')"
    else
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1")"
    fi
    __mkd "$homerepo" && [ ! -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to initialize $homerepo"
    repos_init "$homerepo"
    exit "$?"
    ;;

  clone) # Clone repo from private
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin private clone username/projectname"
    do_not_add_a_url "$1"
    remote_repo="$GITADMIN_PERSONAL_GIT_HOST/$(__strip_git_url "$1")"
    if echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1" | grep -q '\.git$'; then
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1" | grep '\.git$' | __sed 's/\",//;s/\.[^.]*$//;s#"##g')"
    else
      homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1")"
    fi
    if [ -d "$homerepo" ]; then
      printf_green "The repo already exists so attempting update"
      __git_pull "$homerepo"
      retVal=$?
    else
      printf_green "Cloning the repo from $remote_repo"
      mkdir -p "$homerepo"
      __git_clone "$remote_repo" "$homerepo"
      retVal=$?
    fi
    __clone_success $retVal "$homerepo"
    [ -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to initialize $homerepo"
    exit "$?"
    ;;

  push)
    shift 1
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1")"
    git_push_single "$homerepo"
    ;;

  pull) # update repo
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: $APPNAME update | pull the repos"
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1")"
    git_pull_single "$homerepo"
    ;;

  remote) # add private to remote
    shift 1
    { [ $# -ne 2 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin private remote username/projectname [name]"
    do_not_add_a_url "$1"
    git -C "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$2" remote add "${2:-orgin}" "https://github.com/$(__strip_git_url "$1").git"
    exit "$?"
    ;;

  update) # update repo
    shift 1
    __update_repo "$@"
    exit "$?"
    ;;

  create)
    shift 1
    case "$1" in
    repo) # create a private repo
      shift 1
      { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin private create RepoName 'description'"
      __gitea_create_repo "$@"
      exit "$?"
      ;;

    org) # create a private org
      shift 1
      { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_exit "Usage: gitadmin private create orgname 'reponame' 'description'"
      __gitea_create_org "$@"
      exit "$?"
      ;;

    esac
    ;;
  branch) # create a branch
    shift 1
    [ "$1" = "help" ] && printf_help "Usage: gitadmin private branch RepoName branch"
    __gitea_branch "$@"
    exit "$?"
    ;;

  repos) # list private repos
    shift 1
    if [ "$1" = "delete" ]; then
      shift 1
      { [ $# = 0 ] || [ "$1" = "help" ] && printf_exit "Usage: gitadmin private repos delete RepoName"; }
      __gitea_delete_repo "$@"
    else
      { [ $# = 0 ] || [ "$1" = "help" ] && printf_help "Usage: gitadmin private repos"; }
      __gitea_users "$@"
    fi
    exit "$?"
    ;;

  esac
  ;;

issues) # Issue options
  shift 1
  case "$1" in
  count)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ] && printf_help "Usage: gitadmin issues count username/projectname"; }
    __api_issues_token "$@"
    get_count="$(__api_issues "GET" | jq 'map(select(.pull_request == null)) | length' 2>/dev/null || false)"
    [ -n "$get_count" ] || printf_exit 1 1 "failed to get count"
    printf_blue "You currently have $get_count issues"
    printf_cyan "$ISSUE_HTML"
    exit $?
    ;;

  list)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ] && printf_help "Usage: gitadmin issues count username/projectname"; }
    if [ "$1" = "json" ]; then
      shift 1
      __api_issues_token "$@"
      __api_issues "GET" | jq
    else
      printf_green "Showing 10 of the most recent issues"
      __api_issues_token "$@"

      __api_issues "GET" | jq -rc '.[]|[.title,.html_url]' 2>/dev/null | sed 's|","|: |g;s|"||g;s|\]||g;s|\[||g' | head -n 10 | printf_readline "5"
    fi
    ;;

  create)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ] && printf_help "Usage: gitadmin issues count username/projectname"; }
    user="${1:-$GITADMIN_DEFAULT_USERNAME}" && shift 1
    issue_repo="$1" && shift 1
    issue_title="$1" && shift 1
    [ -f "$1" ] && issue_body="$(cat "$1" | sed 's|^| |g')" || issue_body="$1"
    shift
    content="$(printf "%s\r" "{ \"title\": \"$issue_title\", \"body\": \"$issue_body\" }" >$GITADMIN_TEMP_FILE)"
    __api_issues_token ${user} ${issue_repo:-}
    printf_green "Attempting to create a new issue "
    curl -q -X "POST" -LSs "$ISSUE_API" -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Accept: application/vnd.github.v3+json" \
      -d @$GITADMIN_TEMP_FILE 2>/dev/null | jq -r ".html_url" 2>/dev/null | grep -v 'null' | printf_readline |
      grep '^' || printf_exit 1 "Failed to create the issue on\n\t\t$ISSUE_API"
    ;;

  edit)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ] && printf_help "Usage: gitadmin issues count username/projectname"; }
    issue_number="$1" && shift 1
    user="${1:-$GITADMIN_DEFAULT_USERNAME}" && shift 1
    issue_repo="$1" && shift 1
    issue_title="$1" && shift 1
    [ -f "$1" ] && issue_body="$(cat "$1" | sed 's|^| |g')" || issue_body="$1"
    shift
    content="$(printf "%s\r" "{ \"title\": \"$issue_title\", \"body\": \"$issue_body\" }" >$GITADMIN_TEMP_FILE)"
    __api_issues_token "$user" "$issue_repo"
    printf_green "Attempting to edit issue $issue_number"
    curl -q -X "PATCH" -LSs "$ISSUE_API/$issue_number" -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" \
      -H "Accept: application/vnd.github.v3+json" -d @$GITADMIN_TEMP_FILE 2>/dev/null | jq -r ".html_url" 2>/dev/null |
      grep -v 'null' | printf_readline | grep '^' || printf_exit 1 "Failed to edit the issue at\n\t\t$ISSUE_API/$issue_number"
    ;;

  delete)
    shift 1
    { [ $# = 0 ] || [ "$1" = "help" ] && printf_help "Usage: gitadmin issues count username/projectname"; }
    printf_exit "Not implemented yet"
    issue_number="$1" && shift 1
    __api_issues_token "$@"
    ;;

  *)
    { [ $# = 0 ] || [ "$1" = "help" ] && printf_help "Usage: gitadmin issues [list,count,create] username/projectname"; }
    $APPNAME issues list "$@"
    exit $?
    ;;
  esac
  ;;

cron | updater)
  shift 1
  { [ $# = 0 ] || [ "$1" = "help" ]; } && printf_help "Usage: gitadmin cron [run,remove,add]"
  case "$1" in
  run)
    shift 1
    __run_cron "run"
    ;;
  remove)
    shift 1
    __run_cron "remove"
    ;;
  add)
    shift 1
    __run_cron "add"
    ;;
  esac
  ;;

*)
  if [ -z "$1" ]; then
    __help
  else
    $(builtin type -P git 2>/dev/null) "$@"
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set exit code
exitCode="${exitCode:-$?}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
