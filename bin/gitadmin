  printf_read_input "What is you Name" "120" "GIT_NAME"
  git config --global user.name "$GIT_NAME" 2>/dev/null
fi
if [ "$(git config --get user.email | wc -m)" -lt 2 ]; then
  printf_read_input "What is you Email" "120" "GIT_EMAIL"
  git config --global user.email "$GIT_EMAIL" 2>/dev/null
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Gist API
__api_gist() {
  curl -q -H "Authorization: token $TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "https://api.github.com/users/$USERNAME/gists"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set Message for token - user
__api_user_token() {
  local USERNAME="${1:-$USERNAME}"
  if [ -n "$TOKEN" ]; then
    GITHUBAPIREPO="https://api.github.com/users/$USERNAME/repos?per_page=1000&type=owner"
    MESSAGE="Getting the repos for $USERNAME using\n\t\tgithub token $TOKEN"
  else
    GITHUBAPIREPO="https://api.github.com/users/$USERNAME/repos?per_page=1000"
    MESSAGE="Getting the repos for $USERNAME"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User api
__api_user() {
  local USERNAME="${1:-$USERNAME}"
  __api_user_token "$USERNAME"
  __urlverify "$GITHUBAPIREPO" || return 1
  __devnull2 curl -q -H "Authorization: token $TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "$GITHUBAPIREPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set Message for token - org
__api_org_token() {
  local USERNAME="${1:-$USERNAME}"
  if [ -n "$TOKEN" ]; then
    GITHUBAPIREPO="https://api.github.com/orgs/$USERNAME/repos?per_page=1000&type=owner"
    MESSAGE="Getting the repos for $USERNAME using\n\t\tgithub token $TOKEN"
  else
    GITHUBAPIREPO="https://api.github.com/orgs/$USERNAME/repos?per_page=1000"
    MESSAGE="Getting the repos for $USERNAME"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Organization API
__api_org() {
  USERNAME="${1:-$USERNAME}"
  __api_user_token "$USERNAME"
  __urlverify "$GITHUBAPIREPO" || return 1
  __devnull2 curl -q -H "Authorization: token $TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "$GITHUBAPIREPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_url() { __api_user || __api_org || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_pull() {
  local dir="$1" && shift 1
  local args="$*"
  local regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$(__git_remote_origin "$dir")" =~ $regex ]]; then
    if __am_i_online; then
      git -C "$dir" pull "$args" -f -q &>/dev/null && return 0 || return 1
    else return 1; fi
  else
    git -C "$dir" pull "$args" -f -q &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_push() {
  local dir="$1" && shift 1
  local args="$*"
  local regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$(__git_remote_origin "$dir")" =~ $regex ]]; then
    if __am_i_online; then
      git -C "$dir" push "$args" -q &>/dev/null && return 0 || return 1
    else return 1; fi
  else
    git -C "$dir" push "$args" -q &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_clone() {
  local url="$1" && shift 1
  local dir="$1" && shift 1
  local args="$*" && shift $#
  local regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$url" =~ $regex ]]; then
    if __am_i_online; then
      git clone "$url" "$dir" -q "$args" &>>/dev/null && return 0 || return 1
    else
      return 1
    fi
  else
    git clone "$url" "$dir" -q "$args" &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a README.md file if one doesn't exist
create_new_readme_template() {
  local REPO_DIR="${1:-$REPO_DIR}"
  if [ -f "$(command -v gen-readme)" ] && [ ! -f "${REPO_DIR}/README.md" ]; then
    gen-readme "$REPO_DIR" default &>/dev/null
  else
    local author="$(__git_globaluser)"
    local GitBaseDir="$(__git_top_dir "$REPO_DIR")"
    local BaseDir="${GitBaseDir##*/}"
    [ -f "$CASJAYSDEVDIR/templates/readmes/projects/default.md" ] &&
      cat "$CASJAYSDEVDIR/templates/readmes/projects/default.md" >"${REPO_DIR}/README.md"
    [ -f "${REPO_DIR}/README.md" ] && __sed -i "s#ProjectName#${BaseDir}#g" "${REPO_DIR}/README.md"
    [ -f "${REPO_DIR}/README.md" ] && __sed -i "s#AuthorName#${author}#g" "${REPO_DIR}/README.md"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a WTFPL license if a LICENSE.md file doesn't exist
create_new_wtfpl() {
  local REPO_DIR="${1:-$REPO_DIR}"
  if [ -f "$(command -v gen-license)" ] && [ ! -f "${REPO_DIR}/LICENSE.md" ]; then
    gen-license "$REPO_DIR" "$GITADMIN_DEFAULT_LICENSE" &>/dev/null
  else
    local author="$(__git_globaluser)"
    local year="$(date +'%Y')"
    [ -f "$WTFLICENSE" ] && cat "$WTFLICENSE" >"${REPO_DIR}/LICENSE.md"
    [ -f "${REPO_DIR}/LICENSE.md" ] && __sed -i "s#CURYEAR#${year}#g" "${REPO_DIR}/LICENSE.md"
    [ -f "${REPO_DIR}/LICENSE.md" ] && __sed -i "s#AuthorName#${author}#g" "${REPO_DIR}/LICENSE.md"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# The template to create a new private github repo
create_new_private_repo_template() {
  read -r -d '' JSON_TEMPLATE <<EOF
{
  "name" : "%s",
  "description" : "%s",
  "homepage" : "%s",
  "visibility" : "private",
  "private" : true,
  "has_issues" : false,
  "has_downloads" : false,
  "has_wiki" : false,
  "has_projects" : false
}
EOF
  JSON_OUTPUT=$(printf "$JSON_TEMPLATE" "$REPO_NAME" "$DESCRIPTION" "https://$DOMAIN")
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# The template to create a new public github repo
create_new_repo_template() {
  read -r -d '' JSON_TEMPLATE <<EOF
{
  "name" : "%s",
  "description" : "%s",
  "homepage" : "%s",
  "visibility" : "public",
  "private" : false,
  "has_issues" : false,
  "has_downloads" : false,
  "has_wiki" : false,
  "has_projects" : false
}
EOF
  JSON_OUTPUT=$(printf "$JSON_TEMPLATE" "$REPO_NAME" "$DESCRIPTION" "https://$DOMAIN")
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if input is a url
do_not_add_a_url() {
  regex="(https?|ftp|file)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  string="$1"
  if [[ "$string" =~ $regex ]]; then
    printf_red "Do not provide the full url"
    printf_red "only provide the username/repo"
    exit 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# The initialize git function
run_git_init() {
  local REPO_DIR="${1:-$REPO_DIR}"
  local repo="$repo"
  local push=""
  local confirm=""
  local confirm_repo=""
  if [ -n "$repo" ]; then
    git -C "$REPO_DIR" remote add origin "$repo" &>/dev/null &&
      printf_green "$repo has been added" || printf_exit 'Failed to add repo'
    printf_read_question "3" "Should I push to the new repo? [y/n]" "1" "push"
    if printf_answer_yes "$push"; then
      printf_read_question "3" "This will overwrite the repo if it exists. Continue? [y/n]" "1" "confirm_repo"
      if printf_answer_yes "$confirm_repo"; then
        if [ -f "${REPO_DIR}/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
          cp -Rf "${REPO_DIR}/$GITADMIN_DEFAULT_MAINCONFIG" "${REPO_DIR}/.git/config"
        fi
        git -C "$REPO_DIR" push -q -f --set-upstream origin "$GIT_DEFAULT_BRANCH" &>/dev/null &&
          __git_push "$REPO_DIR" &&
          printf_green "Successfuly pushed to $repo" || printf_red "Push to $repo has failed"
      else
        printf_yellow "Not pushing due to user canceling"
      fi
    else
      printf_yellow "Not pushing due to user canceling"
    fi
  else
    printf_red "No remote repo specified"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup a new git repo
run_git_setup() {
  local REPO_DIR="$(__basedir "${1:-$REPO_DIR}/.git")"
  local PREVREPO="${PREVREPO:-}"
  local continue="${continue:-}"
  local reuse="${reuse:-}"
  local EXIT=0
  printf_green "Initializing $REPO_DIR"
  if [ -d "$REPO_DIR/.git" ]; then
    local PREVREPO="$(git -C "$REPO_DIR" remote -v | grep push | head -n 1 | awk '{print $2}' 2>/dev/null)"
    printf_error "This project already has git setup"
    if [ -n "$PREVREPO" ]; then
      printf_green "Remote repo is: $PREVREPO"
    fi
    printf_read_question "3" "Should I continue to reset this repo? [y/n]" "1" "continue"
    if printf_answer_yes "$continue"; then
      __rm_rf "$REPO_DIR/.git"
    else
      printf_red "Initialization has failed due to user"
      exit 1
    fi
  fi

  [ -f "$VERSIONFILE" ] && date +"$VERSION_DATE_FORMAT" >"$VERSIONFILE"
  ls "$REPO_DIR/README"* >/dev/null 2>&1 || create_new_readme_template "$REPO_DIR"
  ls "$REPO_DIR/LICENSE"* >/dev/null 2>&1 || create_new_wtfpl "$REPO_DIR"
  __devnull git -C "$REPO_DIR" init . &&
    __devnull git -C "$REPO_DIR" add . &&
    git -C "$REPO_DIR" commit -q -m ' 🦈🏠🐜❗ Initial Commit ❗🐜🦈🏠 ' &&
    printf_green "Success: $(__git_repobase "$REPO_DIR") has been initialized" ||
    printf_red "Failed to initialize $(__git_repobase "$REPO_DIR")"
  if [ -n "$PREVREPO" ]; then
    printf_read_question "3" "Should I reuse the remote repo? [y/n] " "1" "reuse"
  else
    PREVREPO=""
    repo=""
  fi
  if printf_answer_yes "$reuse"; then
    remote="y"
    repo="$PREVREPO"
    run_git_init "$REPO_DIR"
  else
    printf_read_question "3" "Should I add a remote repo? [y/n] " "1" "remote"
    if printf_answer_yes "$remote"; then
      printf_read_input "3" "Enter remote repo: " "120" "repo"
      if run_git_init "$REPO_DIR"; then
        EXIT=0
      else
        EXIT=1
      fi
    else
      printf_yellow "You have decided not to add a remote repository"
    fi
  fi
  if [ $EXIT -eq 0 ]; then
    exit 0
  else
    printf_red "Initialization has failed"
    exit 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run git setup with no interactions
run_git_setup_automated() {
  local REPO_DIR="$(__basedir "${1:-$REPO_DIR}/.git")"
  local PREVREPO="$(git -C "$REPO_DIR" remote -v | grep push | head -n 1 | awk '{print $2}' 2>/dev/null)"
  [ -d "$REPO_DIR" ] || __mkd "$REPO_DIR"
  if [ ! -d "$REPO_DIR/.git" ]; then
    printf_red "This does not seem to be a git repo"
    exit 1
  fi
  if [ -z "$PREVREPO" ]; then
    printf_red "Can't run in automated mode due to there not being a repo setup"
    exit 1
  fi
  printf_red "Setting up $REPO_DIR as requested" && sleep 5
  __rm_rf .git
  [ -f "$VERSIONFILE" ] && date +"$VERSION_DATE_FORMAT" >"$VERSIONFILE"
  ls "$REPO_DIR/README"* 1>/dev/null 2>&1 || create_new_readme_template "$REPO_DIR"
  ls "$REPO_DIR/LICENSE"* 1>/dev/null 2>&1 || create_new_wtfpl "$REPO_DIR"
  __devnull git -C "${REPO_DIR}" init &&
    __devnull git -C "${REPO_DIR}" remote add origin "$PREVREPO" &&
    if [ -f "$REPO_DIR/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
      __cp_rf "$REPO_DIR/$GITADMIN_DEFAULT_MAINCONFIG" "$REPO_DIR/.git/config"
    fi &&
    __devnull git -C "${REPO_DIR}" add . &&
    __devnull2 git -C "${REPO_DIR}" commit -q -m ' 🦈🏠🐜❗ Initial Commit ❗🐜🦈🏠 ' &&
    __git_push "$REPO_DIR" --set-upstream origin "$GIT_DEFAULT_BRANCH" &&
    __git_push "$REPO_DIR" &&
    printf_green "Successfuly pushed to: $PREVREPO" ||
    printf_red "Push to $PREVREPO has failed"
  echo ""
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Makes a new jeckyll site
make_newsite() {
  local REPO_DIR="$(__basedir "$REPO_DIR/.git")"
  __git_clone "$DOMAIN_TEMPLATE" "$HOME/Public/sites/$1" &&
    rm -Rf "$HOME/Public/sites/new/.git" && cd "$HOME/Public/sites/$1" && "$EDITOR" _config.yml || return 1
  gitadmin "${REPO_DIR}" setup
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Gets the organizations from the user
git_all_orgs() {
  local ORGAPI="$ORG_API_URL"
  local GITHUB_USERNAME="$1"
  local API="$(curl -q -H "Authorization: token $TOKEN" -H "Accept: application/vnd.github.v3+json" -LSs "$ORG_API_URL" | jq '.[].login' | sed 's#"##g')"
  for org in $GITHUB_USERNAME $API; do
    gitadmin --clone "$org"
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Initializes a repo with default options
repos_init() {
  REPO_DIR="$(__basedir "${1:-$REPO_DIR}/.git")"
  [ -f "$VERSIONFILE" ] && date +"$VERSION_DATE_FORMAT" >"$VERSIONFILE"
  git -C "${REPO_DIR}" add .
  if [ -f "${REPO_DIR}/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
    cp -Rf "${REPO_DIR}/$GITADMIN_DEFAULT_MAINCONFIG" "${REPO_DIR}/.git/config"
  fi
  __devnull2 git -C "${REPO_DIR}" commit -m ' 🦈🏠🐜 Initial Commit 🐜🦈🏠 '
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Initializes a repo for github
git_init() {
  local remote=""
  REPO_DIR="$(__basedir "${1:-$REPO_DIR}/.git")"
  [ "$1" = "" ] && printf_red "Usage: userName repoName\n" && return 1
  [ "$2" = "" ] && printf_red "Usage: userName repoName\n" && return 1
  git_setup "$REPO_DIR"
  [ -f "$VERSIONFILE" ] && date +"$VERSION_DATE_FORMAT" >"$VERSIONFILE"
  __devnull2 git -C "$REPO_DIR" add .
  if [ -f "$REPO_DIR/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
    cp -Rf "$REPO_DIR/$GITADMIN_DEFAULT_MAINCONFIG" "$REPO_DIR/.git/config"
  fi
  __devnull2 git -C "$REPO_DIR" commit -m ' 🦈🏠🐜 Initial Commit 🐜🦈🏠 '
  __devnull2 git -C "$REPO_DIR" remote add origin "${remote:-https://github.com/$1/$2}"
  __git_push "$REPO_DIR" -u origin "$GITADMIN_DEFAULT_BRANCH"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# List gists
ghgist_list() {
  local USERNAME="$1"
  shift 1
  __api_gist | jq ".[] | .description, .id" && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Delete gist
ghgist_delete() {
  local ID="$1"
  local EXIT="0"
  local SUCCES="Deleted gist: $ID"
  local FAILED="failed to delete gist: $ID"
  shift 1
  if [ -z "$ID" ]; then printf_exit "Please provide the gist ID"; fi
  curl -q -H "Authorization: token $TOKEN" -H "Accept: application/vnd.github.v3+json" -LSs -X DELETE "https://api.github.com/gists/$ID" >"$GITADMIN_TEMP_FILE"
  grep -viqs "Not Found" "$GITADMIN_TEMP_FILE" && EXIT=1 || EXIT=0
  __rm_rf "$GITADMIN_TEMP_FILE"
  __getexitcode $EXIT "$SUCCES" "$FAILED"
  return $EXIT
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a new gist
ghgist_create() {
  [ "$1" = "--help" ] && printf_green "Usage: --gist name description text\n" && return 1
  [ "$1" = "" ] && printf_red "Usage: --gist name description text\n" && return 1
  [ "$2" = "" ] && printf_red "Usage: --gist name description text\n" && return 1
  local TITLE="$1"
  local DESCR="$2"
  local SUCCESS="Success"
  local ERROR="Failed"
  local CONTENT="$(printf "%s\r" "{\"description\": \"$DESCR\",\"public\": true,\"files\": {\"$TITLE\": {\"content\": \"$3\"}}}" | tee >$GITADMIN_TEMP_FILE-data.txt)"
  printf_green "Creating $TITLE - $DESCR"
  curl -q -X POST -LSsi -H "Content-Type: application/json" -H "Authorization: token $TOKEN" --data @$GITADMIN_TEMP_FILE-data.txt https://api.github.com/gists |
    grep -w "html_url" | grep "gist" | awk '{print $2}' | __sed 's/\,//' >"$GITADMIN_TEMP_FILE" 2>&1 &&
    SUCCES="$(cat $GITADMIN_TEMP_FILE)" && __rm_rf "$GITADMIN_TEMP_FILE-data.txt"
  __getexitcode "$SUCCES" "$ERROR"
  return $EXIT
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Reusable function for delete
ghdelete-user() {
  local USERNAME="${1:-$USERNAME}"
  local REPONAME="${2:-$REPONAME}"
  curl -q -H "Authorization: token $TOKEN" -LSs -XDELETE "https://api.github.com/repos/$USERNAME/$REPONAME" >"$GITADMIN_TEMP_FILE" 2>/dev/null
  if grep -qs 'Not Found' "$GITADMIN_TEMP_FILE"; then
    return 0
  elif __api_user "$USERNAME" | grep -qvi "$REPONAME"; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Deletes a github repo
ghdelete() {
  [ "$1" = "--help" ] && printf_green "Usage: --delete userName repoName\n" && return 1
  [ "$1" = "" ] && printf_red "Usage: --delete userName repoName\n" && return 1
  local USERNAME="$1"
  local REPONAME="$2"
  local ERROR="Deletion of $REPONAME failed"
  local SUCCES="Deletion of $REPONAME successful"
  printf_green "Deleting $REPONAME for user $USERNAME"
  ghdelete-user "$USERNAME" "$REPONAME"
  __getexitcode "$SUCCES" "$ERROR"
  #__rm_rf "$GITADMIN_TEMP_FILE"
  return $EXIT
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Reusable function for create repo
curl_orgs_create() {
  curl -q -H "Authorization: token $TOKEN" -LSs "https://api.github.com/orgs/$USERNAME/repos" \
    -d "{\"name\": \"$REPONAME\", \"description\": \"$DESCR\"}" >"$GITADMIN_TEMP_FILE"
  if grep -qis '"full_name": "'$USERNAME'/'$REPONAME'"' "$GITADMIN_TEMP_FILE"; then
    return 0
  elif grep -qis 'name already exists on this account' "$GITADMIN_TEMP_FILE"; then
    return 0
  else
    return 1
  fi
}
curl_user_create() {
  curl -q -H "Authorization: token $TOKEN" -LSs "https://api.github.com/user/repos" \
    -d "{\"name\": \"$REPONAME\", \"description\": \"$DESCR\"}" >"$GITADMIN_TEMP_FILE"
  if grep -qis '"full_name": "'$USERNAME'/'$REPONAME'"' "$GITADMIN_TEMP_FILE"; then
    return 0
  elif grep -qis 'name already exists on this account' "$GITADMIN_TEMP_FILE"; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a new repo on github
ghcreate() {
  [ "$TOKEN" = "" ] && printf_red "No auth token set - GITHUB_ACCESS_TOKEN\n" && return 1
  [ "$1" = "--help" ] && printf_green "Usage: --create userName repoName Description\n" && return 1
  [ "$1" = "" ] && printf_red "Usage: --create userName repoName Description\n" && return 1
  [ "$2" = "" ] && printf_red "Usage: --create userName repoName Description\n" && return 1
  local EXIT=0
  local USERNAME="$1"
  local REPONAME="$2"
  local DESCR="$3"
  local ERROR="Creation of $REPONAME failed"
  local SUCCES="Creation of $REPONAME successful"
  printf_blue "This may take a few seconds."
  printf_blue "Sending your request to the github API."
  printf_green "Creating $REPONAME for user $USERNAME"
  curl_orgs_create || curl_user_create || EXIT=1
  __getexitcode "$EXIT" "$SUCCES" "$ERROR"
  return "$EXIT"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# clone a single repo from user
ghsinglerepo() {
  [ "$1" = "" ] && printf_red "Usage: --single userName repoName" && return 1
  [ "$2" = "" ] && printf_red "Usage: --single userName repoName" && return 1
  __git_clone "https://github.com/$1/$2" "${3:-}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# push local repo
git_push_single() {
  [ "$1" = "--help" ] || [ $# -eq 0 ] && printf_help "Usage: gitadmin push MyProjectDir"
  local REPO_DIR="$(__basedir "${1:-$REPO_DIR}/.git")"
  SUCCESS_MSG() { echo "Push to $(__git_remote_origin "$REPO_DIR") has completed"; }
  FAILED_MSG() { echo "Push to $(__git_remote_origin "$REPO_DIR") has failed"; }
  if [ -d "$REPO_DIR/.git" ]; then
    printf_custom "4" "Pushing the repo in $REPO_DIR"
    __git_push "$REPO_DIR" && exitCode=0 || exitCode=1
    __getexitcode $exitCode "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  else
    if [ -n "$1" ]; then
      projdir="$1"
      REPO_DIR_NAME="$(__git_hostname "$1")"
      __git_username_repo "$1"
      local username="$username"
      local userrepo="$userrepo"
    else
      projdir="$PROJECT_BASE/$REPO_DIR_NAME/$username/$userrepo"
    fi
    if [ -d "$projdir/.git" ]; then
      printf_custom "4" "Pushing the repo in $projdir"
      __git_push "$projdir" && exitCode=0 || exitCode=1
      __getexitcode $exitCode "$(SUCCESS_MSG)" "$(FAILED_MSG)"
    else
      return 1
    fi
  fi
  return "$?"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# pull a single repo
git_pull_single() {
  [ "$1" = "--help" ] || [ $# -eq 0 ] && printf_help "Usage: gitadmin pull MyProjectDir"
  local REPO_DIR="$(__basedir "${1:-$REPO_DIR}/.git")"
  if [ -d "$REPO_DIR/.git" ]; then
    SUCCESS_MSG() { echo "Pull from $(__git_remote_origin "$REPO_DIR") has completed"; }
    FAILED_MSG() { echo "Pull from $(__git_remote_origin "$REPO_DIR") has failed"; }
    printf_custom "4" "Pulling the repo in $REPO_DIR"
    __git_pull "$REPO_DIR" && exitCode=0 || exitCode=1
    __getexitcode $exitCode "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  else
    if [ -n "$1" ]; then
      projdir="$1"
      REPO_DIR_NAME="$(__git_hostname "$1")"
      __git_username_repo "$1"
    else
      projdir="$PROJECT_BASE/$REPO_DIR_NAME/$username/$userrepo"
    fi
    if [ -d "$projdir/.git" ]; then
      printf_custom "4" "Pulling the repo in $projdir"
      __git_pull "$projdir" && exitCode=0 || exitCode=1
      __getexitcode $exitCode "$(SUCCESS_MSG)" "$(FAILED_MSG)"
    else
      return 1
    fi
  fi
  exit "$?"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# clone a single repo
git_clone_single() {
  [ "$1" = "--help" ] || [ $# -eq 0 ] && printf_help "Usage: gitadmin clone MyURL"
  __git_username_repo "$1"
  local projectdir="$projectdir"
  local giturl="$1"
  local projdir="${2:-$projectdir}"
  local REPO_DIR="$(__basedir "$projdir/.git")"
  SUCCESS_MSG() { echo "Cloning from $giturl has completed"; }
  FAILED_MSG() { echo "Cloning from $giturl has failed"; }
  #printf_exit "U:$giturl P:$PROJECT_DIR p:$projdir R:$REPO_DIR"
  if [ -d "$projdir/.git" ]; then
    printf_custom "4" "Updating the repo in $projdir"
    __git_pull "$projdir" && exitCode=0 || exitCode=1
    __getexitcode $exitCode "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  else
    printf_custom "4" "Cloning the repo to $projdir"
    __git_clone "$giturl" "$projdir" && exitCode=0 || exitCode=1
    __getexitcode $exitCode "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  fi
  exit "$?"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#continue pulling
git_update_loop() {
  if [[ "$*" =~ "--while" ]]; then
    while true; do
      for project in $(ls -d ~/Projects/*/*/*); do
        printf_green "Updating $project $(__devnull __git_pull "$project") $(__getexitcode)"
      done && clear
      printf_custom "3" "Sleeping for a minute $(sleep 60)"
    done
  else
    for project in $(ls -d ~/Projects/*/*/*); do
      printf_green "Updating $project $(__devnull __git_pull "$project") $(__getexitcode)"
    done
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# cron functions
__run_cron() {
  local frequency="0 4 * * 6"
  local croncmd="$APPNAME cron run"
  case $1 in
  run)
    logr -name gitadmin 'am_i_online --console && $(expr $RANDOM \% 300) && gitadmin --all-orgs && gitadmin --user'
    ;;
  remove)
    shift 1
    removecrontab "$frequency $croncmd"
    ;;
  add)
    addtocrontab "$frequency $croncmd"
    ;;
  *)
    addtocrontab "$frequency $croncmd"
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Shorten URL
git_io() {
  if [ -z "$1" ] || [ "$1" = "help" ]; then
    printf_exit 2 0 "Usage: gitadmin shorten url name"
  else
    printf_blue "Attempting to create $1 on git.io"
    if [ -n "$2" ]; then
      curl -i https://git.io -F "url=$1" -F "code=$2" >"$GITADMIN_TEMP_FILE"
      MESSAGE="$(grep -s "$GITADMIN_TEMP_FILE" | grep 'Location: ')"
    else
      curl -i https://git.io -F "url=$1" >"$GITADMIN_TEMP_FILE"
      MESSAGE="$(grep -s "$GITADMIN_TEMP_FILE" | grep 'Location: ')"
    fi
  fi
  if [ -n "$MESSAGE" ]; then
    printf_green "$MESSAGE"
  else
    printf_return "Failed to create the shortened URL"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# rename master to main
__rename_branch() {
  local branch="$1" && shift 1
  local USER="${2:-$(basename "$(dirname "$REPO_DIR")")}"
  local REPO="${3:-$(basename "$REPO_DIR")}"
  printf_blue "Changing git branch to $branch on $REPO"
  git -C "$REPO_DIR" branch -m master "$branch" &>/dev/null
  git -C "$REPO_DIR" push -u origin "$branch" -fq &>/dev/null
  if curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER/$REPO" \
    -d '{"default_branch":"'$branch'"}' | grep -q '"default_branch": "main"' &>/dev/null; then
    git -C "$REPO_DIR" push --delete origin master -fq &>/dev/null
    printf_green "Changed the default branch on github.com/$USER/$REPO"
  fi &&
    printf_green "Successfully renamed the default branch" ||
    printf_exit 1 1 "Failed to rename the default branch"
  git config --global init.defaultBranch "$branch" &>/dev/null
  #grep -rl --exclude-dir='.git' '/raw/master/' "$REPO_DIR" | xargs sed -i 's|/raw/master/|/raw/'$branch'/|g'
  #gitcommit
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# main cloning function
main() {
  sleep 3
  local USERNAME="${1}"
  local REPO_URL="${REPO_URL}"
  local PROJECT_DIR="$PROJECT_DIR/github"
  printf_yellow "ProjectDir: $PROJECT_DIR/$USERNAME"
  printf_yellow "BaseRepo URL: $REPO_URL"
  for i in $(cat "$GITADMIN_TEMP_FILE"); do
    if [ -d "$PROJECT_DIR/$USERNAME/$i/.git" ]; then
      ERROR="Git pull $USERNAME/$i failed"
      SUCCES="Git pull $USERNAME/$i completed"
      printf_purple "Now running git pull $USERNAME/$i"
      if [ -f "$REPO_DIR/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
        cp -Rf "$REPO_DIR/$GITADMIN_DEFAULT_MAINCONFIG" "$REPO_DIR/.git/config"
      fi
      __git_pull "$PROJECT_DIR/$USERNAME/$i"
      __getexitcode "$SUCCES" "$ERROR"
    else
      ERROR="Git clone $USERNAME/$i failed"
      SUCCES="Git clone $USERNAME/$i completed"
      printf_purple "Now running git clone $USERNAME/$i"
      __git_clone "$REPO_URL/$i" "$PROJECT_DIR/$USERNAME/$i"
      __getexitcode "$SUCCES" "$ERROR"
    fi
  done
  exit "${EXIT:-$?}"
}
