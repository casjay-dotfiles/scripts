#git init
if [ "$(git config --get user.name | wc -m)" -lt 2 ]; then
  printf_read_input "What is you Name" "120" "GIT_NAME"
  git config --global user.name "$GIT_NAME" 2>/dev/null
fi
if [ "$(git config --get user.email | wc -m)" -lt 2 ]; then
  printf_read_input "What is you Email" "120" "GIT_EMAIL"
  git config --global user.email "$GIT_EMAIL" 2>/dev/null
fi
# issues API
__api_issues_token() {
  local user="${1:-$USERNAME}"
  local git_repo="$2"
  ISSUE_HTML="https://github.com/repos/$user/$git_repo/issues"
  ISSUE_API="https://api.github.com/repos/$user/$git_repo/issues"
}
__api_issues() {
  __api_issues_token "$1" "$2"
  curl -q -LSs "$ISSUE_API" \
    -H "Authorization: token $TOKEN" \
    -H "Accept: application/vnd.github.v3+json"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Gist API
__api_gist() {
  local user="${1:-$USERNAME}"
  curl -q -H "Authorization: token $TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "https://api.github.com/users/$user/gists"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set Message for token - user
__api_user_token() {
  local user="${1:-$USERNAME}"
  if [ -n "$TOKEN" ]; then
    export GITHUBAPIREPO="https://api.github.com/users/$user/repos?per_page=1000&type=owner"
    export MESSAGE="Getting the repos for $user using\n\t\tgithub token $TOKEN"
  else
    export GITHUBAPIREPO="https://api.github.com/users/$user/repos?per_page=1000"
    export MESSAGE="Getting the repos for $USERNAME"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User api
__api_user() {
  local user="${1:-$USERNAME}"
  __api_user_token "$user"
  __urlverify "$GITHUBAPIREPO" || return 1
  __devnull2 curl -q -H "Authorization: token $TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "$GITHUBAPIREPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set Message for token - org
__api_org_token() {
  local user="${1:-$USERNAME}"
  if [ -n "$TOKEN" ]; then
    export GITHUBAPIREPO="https://api.github.com/orgs/$user/repos?per_page=1000&type=owner"
    export MESSAGE="Getting the repos for $user using\n\t\tgithub token $TOKEN"
  else
    export GITHUBAPIREPO="https://api.github.com/orgs/$user/repos?per_page=1000"
    export MESSAGE="Getting the repos for $user"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Organization API
__api_org() {
  local user="${1:-$USERNAME}"
  __api_user_token "$user"
  __urlverify "$GITHUBAPIREPO" || return 1
  __devnull2 curl -q -H "Authorization: token $TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs "$GITHUBAPIREPO"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_url() { __api_user || __api_org || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_pull() {
  local git_dir="${1:-$GITADMIN_WD}" && shift 1
  local args="$*"
  local regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$(__git_remote_origin "$git_dir")" =~ $regex ]]; then
    if __am_i_online; then
      git -C "$git_dir" pull $args -f -q &>/dev/null && return 0 || return 1
    else return 1; fi
  else
    git -C "$git_dir" pull $args -f -q &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_push() {
  local git_dir="${1:-$GITADMIN_WD}" && shift 1
  local args="$*"
  local regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$(__git_remote_origin "$git_dir")" =~ $regex ]]; then
    if __am_i_online; then
      git -C "$git_dir" push $args -q &>/dev/null && return 0 || return 1
    else return 1; fi
  else
    git -C "$git_dir" push $args -q &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_clone() {
  local git_url="$1" && shift 1
  local git_dir="$1" && shift 1
  local args="$*" && shift $#
  local regex="(https?|ftp|file|git|ssh)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$git_url" =~ $regex ]]; then
    if __am_i_online; then
      git clone "$git_url" "$git_dir" -q $args &>/dev/null && return 0 || return 1
    else
      return 1
    fi
  else
    git clone "$git_url" "$git_dir" -q $args &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a README.md file if one doesn't exist
create_new_readme_template() {
  local git_dir="${1:-$GITADMIN_WD}"
  if [ -f "$(command -v gen-readme)" ] && [ ! -f "$git_dir/README.md" ]; then
    gen-readme "$git_dir" default &>/dev/null
  else
    local author="$(__git_globaluser)"
    local GitBaseDir="$(__git_top_dir "$git_dir")"
    local BaseDir="${GitBaseDir##*/}"
    [ -f "$CASJAYSDEVDIR/templates/readmes/projects/default.md" ] &&
      cat "$CASJAYSDEVDIR/templates/readmes/projects/default.md" >"$git_dir/README.md"
    [ -f "$git_dir/README.md" ] && __sed -i "s#ProjectName#${BaseDir}#g" "$git_dir/README.md"
    [ -f "$git_dir/README.md" ] && __sed -i "s#AuthorName#${author}#g" "$git_dir/README.md"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a WTFPL license if a LICENSE.md file doesn't exist
create_new_license() {
  local git_dir="${1:-$GITADMIN_WD}"
  if [ -f "$(command -v gen-license)" ] && [ ! -f "$git_dir/LICENSE.md" ]; then
    gen-license "$git_dir" "$GITADMIN_DEFAULT_LICENSE" &>/dev/null
  else
    local author="$(__git_globaluser)"
    local year="$(date +'%Y')"
    [ -f "$GITADMIN_DEFAULT_LICENSE" ] && cat "$GITADMIN_DEFAULT_LICENSE" >"$git_dir/LICENSE.md"
    [ -f "$git_dir/LICENSE.md" ] && __sed -i "s#CURYEAR#${year}#g" "$git_dir/LICENSE.md"
    [ -f "$git_dir/LICENSE.md" ] && __sed -i "s#AuthorName#${author}#g" "$git_dir/LICENSE.md"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# The template to create a new private github repo
create_new_private_repo_template() {
  read -r -d '' JSON_TEMPLATE <<EOF
{
  "name" : "%s",
  "description" : "%s",
  "homepage" : "%s",
  "visibility" : "private",
  "private" : true,
  "has_issues" : false,
  "has_downloads" : false,
  "has_wiki" : false,
  "has_projects" : false
}
EOF
  JSON_OUTPUT=$(printf "$JSON_TEMPLATE" "$REPO_NAME" "$DESCRIPTION" "https://$DOMAIN")
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# The template to create a new public github repo
create_new_repo_template() {
  read -r -d '' JSON_TEMPLATE <<EOF
{
  "name" : "%s",
  "description" : "%s",
  "homepage" : "%s",
  "visibility" : "public",
  "private" : false,
  "has_issues" : false,
  "has_downloads" : false,
  "has_wiki" : false,
  "has_projects" : false
}
EOF
  JSON_OUTPUT=$(printf "$JSON_TEMPLATE" "$REPO_NAME" "$DESCRIPTION" "https://$DOMAIN")
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if input is a url
do_not_add_a_url() {
  local string="$1"
  local regex="(https?|ftp|file)://[-A-Za-z0-9\+&@#/%?=~_|!:,.;]*[-A-Za-z0-9\+&@#/%=~_|]"
  if [[ "$string" =~ $regex ]]; then
    printf_red "Do not provide the full url"
    printf_red "only provide the username/repo"
    exit 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# The initialize git function
run_git_init() {
  local git_dir="${1:-$GITADMIN_WD}"
  local git_repo="$git_repo"
  local git_push=""
  local git_confirm=""
  local git_confirm_repo=""
  if [ -n "$git_remote_repo" ]; then
    git -C "$git_dir" remote add origin "$git_remote_repo" &>/dev/null &&
      printf_cyan "$git_remote_repo has been added" || printf_exit 'Failed to add repo'
    printf_read_question "3" "Should I push to the new repo? [y/n]" "1" "git_push"
    if printf_answer_yes "$git_push"; then
      printf_read_question "3" "This will overwrite the repo if it exists. Continue? [y/n]" "1" "git_confirm_repo"
      if printf_answer_yes "$git_confirm_repo"; then
        if [ -f "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
          cp -Rf "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" "$git_dir/.git/config"
        fi
        git -C "$git_dir" push -q -f --set-upstream origin "$GITADMIN_DEFAULT_BRANCH" &>/dev/null
        __git_push "$git_dir"
        if [ -d "$git_dir/.git" ]; then
          printf_green "Successfuly pushed to $git_remote_repo"
        else
          printf_red "Push to $git_remote_repo has failed"
        fi
      else
        printf_yellow "Not pushing due to user canceling"
      fi
    else
      printf_yellow "Not pushing due to user canceling"
    fi
  else
    printf_red "No remote repo specified"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup a new git repo
run_git_setup() {
  local git_dir="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local git_prev="$(git -C "$GITADMIN_WD" remote -v | grep push | head -n 1 | awk '{print $2}' 2>/dev/null)"
  local git_continue="${continue:-}"
  local git_reuse="${reuse:-}"
  local git_version_file="$VERSIONFILE"
  local git_version_fmt="$VERSION_DATE_FORMAT"
  local GITADMIN_EXITCODE=0
  printf_green "Initializing the repo in $git_dir"
  if [ -d "$git_dir/.git" ]; then
    local git_prev="$(git -C "$git_dir" remote -v | grep push | head -n 1 | awk '{print $2}' 2>/dev/null)"
    printf_error "This project already has git setup"
    if [ -n "$git_prev" ]; then
      printf_green "Remote repo is: $git_prev"
    fi
    printf_read_question "3" "Should I continue to reset this repo? [y/n]" "1" "git_continue"
    if printf_answer_yes "$git_continue"; then
      __rm_rf "$git_dir/.git"
    else
      printf_red "Initialization has failed due to user"
      exit 1
    fi
  fi

  [ -f "$git_version_file" ] && date +"$git_version_fmt" >"$git_version_file"
  ls "$git_dir/README"* >/dev/null 2>&1 || create_new_readme_template "$git_dir"
  ls "$git_dir/LICENSE"* >/dev/null 2>&1 || create_new_license "$git_dir"
  __devnull git -C "$git_dir" init . &&
    __devnull git -C "$git_dir" add . &&
    git -C "$git_dir" commit -q -m ' 🦈🏠🐜❗ Initial Commit ❗🐜🦈🏠 ' &&
    printf_green "Success: $(__git_repobase "$git_dir") has been initialized" ||
    printf_red "Failed to initialize $(__git_repobase "$git_dir")"
  if [ -n "$git_prev" ]; then
    printf_read_question "3" "Should I reuse the remote repo? [y/n] " "1" "git_reuse"
  else
    git_prev=""
    git_repo=""
    git_remote_repo=""
  fi
  if printf_answer_yes "$git_reuse"; then
    git_remote="y"
    git_remote_repo="$git_prev"
    run_git_init "$git_dir"
  else
    printf_read_question "3" "Should I add a remote repo? [y/n] " "1" "git_remote"
    if printf_answer_yes "$git_remote"; then
      printf_read_input "3" "Enter remote repo: " "120" "git_remote_repo"
      export git_remote_repo
      if run_git_init "$git_dir"; then
        GITADMIN_EXITCODE=0
      else
        GITADMIN_EXITCODE=1
      fi
    else
      printf_yellow "You have decided not to add a remote repository"
    fi
  fi
  if [ $GITADMIN_EXITCODE -ne 0 ]; then
    printf_red "Initialization has failed"
  fi
  exit $GITADMIN_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run git setup with no interactions
run_git_setup_automated() {
  local git_dir="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local git_prev="$(git -C "$GITADMIN_WD" remote -v | grep push | head -n 1 | awk '{print $2}' 2>/dev/null)"
  local git_version_file="$VERSIONFILE"
  local git_version_fmt="$VERSION_DATE_FORMAT"
  local GITADMIN_EXITCODE=0
  [ -d "$git_dir" ] || __mkd "$git_dir"
  if [ ! -d "$git_dir/.git" ]; then
    printf_red "This does not seem to be a git repo"
    exit 1
  fi
  if [ -z "$git_prev" ]; then
    printf_red "Can't run in automated mode due to there not being a repo setup"
    exit 1
  fi
  printf_red "Setting up $git_dir as requested" && sleep 5
  __rm_rf .git
  [ -f "$git_version_file" ] && date +"$git_version_fmt" >"$git_version_file"
  ls "$git_dir/README"* 1>/dev/null 2>&1 || create_new_readme_template "$git_dir"
  ls "$git_dir/LICENSE"* 1>/dev/null 2>&1 || create_new_license "$git_dir"
  __devnull git -C "$git_dir" init &&
    __devnull git -C "$git_dir" remote add origin "$git_prev" &&
    if [ -f "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
      __cp_rf "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" "$git_dir/.git/config"
    fi &&
    __devnull git -C "$git_dir" add . &&
    __devnull2 git -C "$git_dir" commit -q -m ' 🦈🏠🐜❗ Initial Commit ❗🐜🦈🏠 ' &&
    __git_push "$git_dir" --set-upstream origin "$GITADMIN_DEFAULT_BRANCH" &&
    __git_push "$git_dir" &&
    printf_green "Successfuly pushed to: $git_prev" ||
    printf_red "Push to $git_prev has failed"
  echo ""
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Makes a new jeckyll site
make_newsite() {
  local site_dir="$HOME/Public/sites"
  local site_folder="${1:-newsite}"
  local site_repo="$GITADMIN_DOMAIN_TEMPLATE"
  printf_green "Setting up site in: $site_dir/$site_folder"
  printf_blue "Using $site_repo as template"
  if __git_clone "$site_repo" "$site_dir/$site_folder"; then
    cd "$site_dir/$site_folder" || return 1
    __rm_rf "$site_dir/$site_folder/.git"
    [[ "$EDITOR" =~ code ]] && code . || "$EDITOR" _config.yml
    printf_pause
    gitadmin "$site_dir/$site_folder" setup
  else
    printf_error "Failed to clone $DOMAIN_TEMPLATE"
    false
  fi
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Gets the organizations from the user
git_all_orgs() {
  local git_api="$ORG_API_URL"
  local git_user="$1"
  local API="$(curl -q -H "Authorization: token $TOKEN" -H "Accept: application/vnd.github.v3+json" -LSs "$ORG_API_URL" | jq '.[].login' | sed 's#"##g')"
  for org in $git_user $API; do
    gitadmin clone "$org"
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Initializes a repo with default options
repos_init() {
  local git_dir="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local git_version_file="$VERSIONFILE"
  local git_version_fmt="$VERSION_DATE_FORMAT"
  [ -f "$git_version_file" ] && date +"$git_version_fmt" >"$git_version_file"
  git -C "$git_dir" add .
  if [ -f "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
    cp -Rf "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" "$git_dir/.git/config"
  fi
  __devnull2 git -C "$git_dir" commit -m ' 🦈🏠🐜 Initial Commit 🐜🦈🏠 '
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Initializes a repo for github
git_init() {
  local git_dir="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local git_version_file="$VERSIONFILE"
  local git_version_fmt="$VERSION_DATE_FORMAT"
  local git_remote=""
  [ "$1" = "" ] && printf_red "Usage: userName repoName\n" && return 1
  [ "$2" = "" ] && printf_red "Usage: userName repoName\n" && return 1
  git_setup "$git_dir"
  [ -f "$git_version_file" ] && date +"$git_version_fmt" >"$git_version_file"
  __devnull2 git -C "$git_dir" add .
  if [ -f "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
    cp -Rf "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" "$git_dir/.git/config"
  fi
  __devnull2 git -C "$git_dir" commit -m ' 🦈🏠🐜 Initial Commit 🐜🦈🏠 '
  __devnull2 git -C "$git_dir" remote add origin "${remote:-https://github.com/$1/$2}"
  __git_push "$git_dir" -u origin "$GITADMIN_DEFAULT_BRANCH"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# List gists
ghgist_list() {
  local user="${1:-$USERNAME}"
  shift 1
  __api_gist "$user" | jq ".[] | .description, .id" && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Delete gist
ghgist_delete() {
  local gist_id="$1"
  local gist_exit="0"
  local gist_succes="Deleted gist: $ID"
  local gist_failed="failed to delete gist: $ID"
  shift 1
  if [ -z "$gist_id" ]; then printf_exit "Please provide the gist ID"; fi
  curl -q -H "Authorization: token $TOKEN" -H "Accept: application/vnd.github.v3+json" \
    -LSs -X DELETE "https://api.github.com/gists/$gist_id" >"$GITADMIN_TEMP_FILE"
  grep -viqs "Not Found" "$GITADMIN_TEMP_FILE" && gist_exit=1 || gist_exit=0
  __rm_rf "$GITADMIN_TEMP_FILE"
  __getexitcode $gist_exit "$gist_succes" "$gist_failed"
  return $gist_exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a new gist
ghgist_create() {
  [ "$1" = "--help" ] && printf_green "Usage: --gist name description text\n" && return 1
  [ "$1" = "" ] && printf_red "Usage: --gist name description text\n" && return 1
  [ "$2" = "" ] && printf_red "Usage: --gist name description text\n" && return 1
  local gist_title="$1"
  local gist_describe="$2"
  local gist_content="$(printf "%s\r" "{\"description\": \"$gist_describe\",\"public\": true,\"files\": {\"$gist_title\": {\"content\": \"$3\"}}}" | tee >$GITADMIN_TEMP_FILE-data.txt)"
  local gist_exit=0
  printf_green "Creating $gist_title - $gist_describe"
  curl -q -X POST -LSsi -H "Content-Type: application/json" -H "Authorization: token $TOKEN" --data @$GITADMIN_TEMP_FILE-data.txt https://api.github.com/gists |
    if grep -w "html_url" | grep "gist" | awk '{print $2}' | __sed 's/\,//' >"$GITADMIN_TEMP_FILE" 2>/dev/null; then
      gist_exit=0
      gist_succes="$(cat $GITADMIN_TEMP_FILE)"
      __rm_rf "$GITADMIN_TEMP_FILE-data.txt"
    else
      gist_exit=1
      gist_failed="Failed to create the gist"
    fi
  __getexitcode $gist_exit "$gist_succes" "$gist_failed"
  return $gist_exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Reusable function for delete
ghdelete-user() {
  local git_user="${1:-$USERNAME}"
  local git_repo="${2:-$REPONAME}"
  curl -q -H "Authorization: token $TOKEN" -LSs -XDELETE "https://api.github.com/repos/$git_user/$git_repo" >"$GITADMIN_TEMP_FILE" 2>/dev/null
  if grep -qs 'Not Found' "$GITADMIN_TEMP_FILE"; then
    return 0
  elif __api_user "$git_user" | grep -qvi "$git_repo"; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Deletes a github repo
ghdelete() {
  [ "$1" = "--help" ] && printf_green "Usage: --delete userName repoName\n" && return 1
  [ "$1" = "" ] && printf_red "Usage: --delete userName repoName\n" && return 1
  local git_user="$1"
  local git_repo="$2"
  local git_failed="Deletion of $git_repo failed"
  local git_succes="Deletion of $git_repo successful"
  local GITADMIN_EXITCODE=0
  printf_green "Deleting $git_repo for user $git_user"
  if ! ghdelete-user "$git_user" "$git_repo"; then
    GITADMIN_EXITCODE=1
  fi
  __getexitcode $GITADMIN_EXITCODE "$git_succes" "$git_failed"
  #__rm_rf "$GITADMIN_TEMP_FILE"
  return $GITADMIN_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Reusable function for create repo
curl_orgs_create() {
  curl -q -H "Authorization: token $TOKEN" -LSs "https://api.github.com/orgs/$USERNAME/repos" \
    -d "{\"name\": \"$REPONAME\", \"description\": \"$DESCR\"}" >"$GITADMIN_TEMP_FILE"
  if grep -qis '"full_name": "'$USERNAME'/'$REPONAME'"' "$GITADMIN_TEMP_FILE"; then
    return 0
  elif grep -qis 'name already exists on this account' "$GITADMIN_TEMP_FILE"; then
    return 0
  else
    return 1
  fi
}
curl_user_create() {
  curl -q -H "Authorization: token $TOKEN" -LSs "https://api.github.com/user/repos" \
    -d "{\"name\": \"$REPONAME\", \"description\": \"$DESCR\"}" >"$GITADMIN_TEMP_FILE"
  if grep -qis '"full_name": "'$USERNAME'/'$REPONAME'"' "$GITADMIN_TEMP_FILE"; then
    return 0
  elif grep -qis 'name already exists on this account' "$GITADMIN_TEMP_FILE"; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Creates a new repo on github
ghcreate() {
  [ "$TOKEN" = "" ] && printf_red "No auth token set - GITHUB_ACCESS_TOKEN\n" && return 1
  [ "$1" = "--help" ] && printf_green "Usage: --create userName repoName Description\n" && return 1
  [ "$1" = "" ] && printf_red "Usage: --create userName repoName Description\n" && return 1
  [ "$2" = "" ] && printf_red "Usage: --create userName repoName Description\n" && return 1
  local git_user="$1"
  local git_repo="$2"
  local git_describe="$3"
  local git_failed="Creation of $git_repo failed"
  local git_succes="Creation of $git_repo successful"
  local GITADMIN_EXITCODE=0
  printf_blue "This may take a few seconds."
  printf_blue "Sending your request to the github API."
  printf_green "Creating $git_repo for user $git_user"
  if curl_orgs_create || curl_user_create; then
    GITADMIN_EXITCODE=0
  else
    GITADMIN_EXITCODE=1
  fi
  __getexitcode "$GITADMIN_EXITCODE" "$git_succes" "$git_failed"
  return "$GITADMIN_EXITCODE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# clone a single repo from user
ghsinglerepo() {
  [ "$1" = "" ] && printf_red "Usage: --single userName repoName" && return 1
  [ "$2" = "" ] && printf_red "Usage: --single userName repoName" && return 1
  __git_clone "https://github.com/$1/$2" "${3:-}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# push local repo
git_push_single() {
  SUCCESS_MSG() { echo "Push to $(__git_remote_origin "$git_dir") has completed"; }
  FAILED_MSG() { echo "Push to $(__git_remote_origin "$git_dir") has failed"; }
  [ "$1" = "help" ] && printf_help "Usage: gitadmin push MyProjectDir"
  local git_dir="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  local GITADMIN_EXITCODE=0
  if [ -d "$git_dir/.git" ]; then
    printf_custom "4" "Pushing the repo in $git_dir"
    __git_push "$git_dir" && GITADMIN_EXITCODE=0 || GITADMIN_EXITCODE=1
    __getexitcode $GITADMIN_EXITCODE "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  else
    if [ -n "$1" ]; then
      projdir="$1"
      GITADMIN_WD_NAME="$(__git_hostname "$1")"
      __git_username_repo "$1"
      local username="$username"
      local userrepo="$userrepo"
    else
      projdir="$PROJECT_BASE/$GITADMIN_WD_NAME/$username/$userrepo"
    fi
    if [ -d "$projdir/.git" ]; then
      printf_custom "4" "Pushing the repo in $projdir"
      __git_push "$projdir" && GITADMIN_EXITCODE=0 || GITADMIN_EXITCODE=1
      __getexitcode $GITADMIN_EXITCODE "$(SUCCESS_MSG)" "$(FAILED_MSG)"
    else
      GITADMIN_EXITCODE=1
    fi
  fi
  return $GITADMIN_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# pull a single repo
git_pull_single() {
  SUCCESS_MSG() { echo "Pull from $(__git_remote_origin "$git_dir") has completed"; }
  FAILED_MSG() { echo "Pull from $(__git_remote_origin "$git_dir") has failed"; }
  [ "$1" = "help" ] && printf_help "Usage: gitadmin pull MyProjectDir"
  local GITADMIN_WD="$(__basedir "${1:-$GITADMIN_WD}/.git")"
  if [ -d "$GITADMIN_WD/.git" ]; then
    printf_custom "4" "Pulling the repo in $GITADMIN_WD"
    __git_pull "$GITADMIN_WD" && exitCode=0 || exitCode=1
    __getexitcode $exitCode "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  else
    if [ -n "$1" ]; then
      projdir="$1"
      GITADMIN_WD_NAME="$(__git_hostname "$1")"
      __git_username_repo "$1"
    else
      projdir="$PROJECT_BASE/$GITADMIN_WD_NAME/$username/$userrepo"
    fi
    if [ -d "$projdir/.git" ]; then
      printf_custom "4" "Pulling the repo in $projdir"
      __git_pull "$projdir" && exitCode=0 || exitCode=1
      __getexitcode $exitCode "$(SUCCESS_MSG)" "$(FAILED_MSG)"
    else
      return 1
    fi
  fi
  exit "$?"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# clone a single repo
git_clone_single() {
  SUCCESS_MSG() { echo "Cloning from $giturl has completed"; }
  FAILED_MSG() { echo "Cloning from $giturl has failed"; }
  [ "$1" = "help" ] || [ $# -eq 0 ] && printf_help "Usage: gitadmin clone MyURL"
  __git_username_repo "$1"
  local projectdir="$projectdir"
  local giturl="$1"
  local projdir="${2:-$projectdir}"
  local git_dir="$(__basedir "$projdir/.git")"
  #printf_exit "U:$giturl P:$PROJECT_DIR p:$projdir R:$GITADMIN_WD"
  if [ -d "$projdir/.git" ]; then
    printf_custom "4" "Updating the repo in $projdir"
    __git_pull "$projdir" && exitCode=0 || exitCode=1
    __getexitcode $exitCode "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  else
    printf_custom "4" "Cloning the repo to $projdir"
    __git_clone "$giturl" "$projdir" && exitCode=0 || exitCode=1
    __getexitcode $exitCode "$(SUCCESS_MSG)" "$(FAILED_MSG)"
  fi
  exit "$?"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#continue pulling
git_update_loop() {
  if [[ "$*" =~ "--while" ]]; then
    while true; do
      for project in $(ls -d "$HOME"/Projects/*/*/*); do
        printf_green "Updating $project $(__devnull __git_pull "$project") $(__getexitcode)"
      done && clear
      printf_custom "3" "Sleeping for a minute $(sleep 60)"
    done
  else
    for project in $(ls -d "$HOME"/Projects/*/*/*); do
      printf_green "Updating $project $(__devnull __git_pull "$project") $(__getexitcode)"
    done
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# cron functions
__run_cron() {
  local frequency="0 4 * * 6"
  local croncmd="$APPNAME cron run"
  case $1 in
  run)
    logr -name gitadmin 'am_i_online --console && $(expr $RANDOM \% 300) && gitadmin --all-orgs && gitadmin --user'
    ;;
  remove)
    shift 1
    removecrontab "$frequency $croncmd"
    ;;
  add)
    addtocrontab "$frequency $croncmd"
    ;;
  *)
    addtocrontab "$frequency $croncmd"
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Shorten URL
git_io() {
  local short_url="$1"
  local short_name="$2"
  if [ -z "$short_url" ] || [ "$short_url" = "help" ]; then
    printf_exit 2 0 "Usage: gitadmin shorten url name"
  else
    printf_blue "Attempting to create $short_url on git.io"
    if [ -n "$short_name" ]; then
      curl -i https://git.io -F "url=$short_url" -F "code=$short_name" >"$GITADMIN_TEMP_FILE"
      MESSAGE="$(grep -s "$GITADMIN_TEMP_FILE" | grep 'Location: ')"
    else
      curl -i https://git.io -F "url=$short_url" >"$GITADMIN_TEMP_FILE"
      MESSAGE="$(grep -s "$GITADMIN_TEMP_FILE" | grep 'Location: ')"
    fi
  fi
  if [ -n "$MESSAGE" ]; then
    printf_green "$MESSAGE"
  else
    printf_return "Failed to create the shortened URL"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# rename api
__rename_branch_api() {
  local git_branch="$1"
  local git_user="${2:-$(basename "$(dirname "$GITADMIN_WD")")}"
  local git_repo="${3:-$(basename "$GITADMIN_WD")}"
  curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITADMIN_TOKEN" "https://api.github.com/repos/$git_user/$git_repo" \
    -d '{"default_branch":"'$git_branch'"}' | grep -qs '"default_branch": "'$git_branch'"' &>/dev/null &&
    git -C "$GITADMIN_WD" push --delete origin ${git_old_branch:-master} -fq &>/dev/null &&
    return 0 ||
    return 1
}
# rename master to main
__rename_branch() {
  local git_branch="$1"
  local git_user="${2:-$(basename "$(dirname "$GITADMIN_WD")")}"
  local git_repo="${3:-$(basename "$GITADMIN_WD")}"
  printf_blue "Changing git branch to $git_branch on $git_repo"
  git -C "$GITADMIN_WD" branch -m ${git_old_branch:-master} "$git_branch" &>/dev/null
  git -C "$GITADMIN_WD" push -u origin "$git_branch" -fq &>/dev/null
  if __rename_branch_api "$git_branch" "$git_user" "$git_repo"; then
    printf_green "Changed the default branch on github.com/$git_user/$git_repo"
  fi &&
    printf_green "Successfully renamed the default branch" ||
    printf_exit 1 1 "Failed to rename the default branch"
  git config init.defaultBranch "$git_branch" &>/dev/null
  #grep -rl --exclude-dir='.git' '/raw/'${git_old_branch:-master}'/' "$GITADMIN_WD" | xargs sed -i 's|/raw/'${git_old_branch:-master}'/|/raw/'$branch'/|g'
  #gitcommit
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# main cloning function
main() {
  sleep 3
  local git_user="$1"
  local git_repo="${2:-$REPO_URL}"
  local git_base="$PROJECT_DIR/github"
  printf_yellow "ProjectDir: $PROJECT_DIR/$USERNAME"
  printf_yellow "BaseRepo URL: $REPO_URL"
  for i in $(cat "$GITADMIN_TEMP_FILE"); do
    local git_dir="$git_base/$git_user/$i"
    if [ -d "$git_base/$git_user/$i/.git" ]; then
      local git_failed="Git pull $git_user/$i failed"
      local git_sucess="Git pull $git_user/$i completed"
      printf_purple "Now running git pull $git_user/$i"
      if [ -f "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" ]; then
        cp -Rf "$git_dir/$GITADMIN_DEFAULT_MAINCONFIG" "$git_dir/.git/config"
      fi
      __git_pull "$git_dir"
      __getexitcode "$SUCCES" "$ERROR"
    else
      ERROR="Git clone $git_user/$i failed"
      SUCCES="Git clone $git_user/$i completed"
      printf_purple "Now running git clone $git_user/$i"
      __git_clone "$git_repo/$i" "$git_dir"
      __getexitcode "$git_sucess" "$git_failed"
    fi
  done
  exit "${EXIT:-$?}"
}
