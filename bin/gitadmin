    ;;
  esac
  ;;

# private repos commands
private)
  shift 1
  if [ -z "$GITADMIN_PERSONAL_GIT_HOST" ]; then printf_exit "You dont have the env variable GITADMIN_PERSONAL_GIT_HOST set"; fi
  [ "$1" = "help" ] && printf_green "Useful if you have a private server such as gitea" && exit 0
  [ -z "$1" ] && printf_green "Useful if you have a private server such as gitea" && exit 0
  case $1 in
  init) # init a private repo
    shift 1
    if [ "$#" -ne 1 ]; then printf_exit "Usage: gitadmin private init RepoName"; fi
    if [[ "$1" = "help" ]]; then printf_exit "Create a new private project\n\t\tUsage: gitadmin private init RepoName"; fi
    do_not_add_a_url "$1"
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1" | __sed 's/\",// ; s/\.[^.]*$// ; s#"##g')"
    __mkd "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1"
    [ -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to initialize $GITADMIN_WD"
    repos_init "$GITADMIN_WD"
    exit "$?"
    ;;

  clone) # Clone repo from private
    shift 1
    if [ "$#" -ne 1 ]; then printf_exit "Usage: gitadmin private clone username/projectname"; fi
    if [ "$1" = "help" ]; then printf_exit "Clone a private project\n\t\tUsage: gitadmin private clone username/projectname"; fi
    do_not_add_a_url "$1"
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1" | __sed 's/\",// ; s/\.[^.]*$// ; s#"##g')"
    if [ -d "$homerepo" ]; then
      printf_green "The repo already exists so attempting update"
      __git_pull "$homerepo"
    else
      printf_green "Cloning the repo from $GITADMIN_PERSONAL_GIT_HOST/$1"
      mkdir -p "$homerepo"
      __git_clone "$GITADMIN_PERSONAL_GIT_HOST/$1.git" "$homerepo"
    fi
    [ -d "$homerepo/.git" ] && __cd_into "$homerepo" || printf_exit 1 1 "failed to clone $GITADMIN_WD"
    exit "$?"
    ;;

  push)
    shift 1
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1" | __sed 's/\",// ; s/\.[^.]*$// ; s#"##g')"
    git_push_single "$homerepo/$1"
    ;;

  pull) # update repo
    shift 1
    [ "$1" == "help" ] && printf_help "Usage: $APPNAME update | pull the repos"
    homerepo="$(echo "$GITADMIN_DEFAULT_GIT_DIR_PRIVATE/$1" | __sed 's/\",// ; s/\.[^.]*$// ; s#"##g')"
    git_pull_single "$homerepo/$1"
    ;;

  remote) # add private to remote
    shift 1
    if [ "$#" -ne 2 ]; then printf_exit "Usage: gitadmin private remote username/projectname"; fi
    [ "$1" = "help" ] && printf_exit "Add a private project to remote\n\t\tUsage: gitadmin private remote username/projectname"
    do_not_add_a_url "$1"
    git remote add "$1" "$GITADMIN_PERSONAL_GIT_HOST/$2.git"
    exit "$?"
    ;;
  esac
  ;;

issues) # Issue options
  shift 1
  [ "$1" = "help" ] && __help
  [ -z "$1" ] && __help
  case "$1" in
  count)
    shift 1
    get_count="$(__api_issues "$1" "$2" | jq 'map(select(.pull_request == null)) | length' 2>/dev/null)"
    printf_blue "You currently have $get_count issues on"
    printf_cyan "https://github.com/repos/$1/$2/issues"
    ;;

  list)
    shift 1
    if [ "$1" = "json" ]; then
      shift 1
      __api_issues "$1" "$2" | jq
    else
      printf_green "Showing 10 of the most recent issues"
      __api_issues "$1" "$2" | jq -r .[]'.html_url' 2>/dev/null | head -n 10 | printf_readline "5"
    fi
    ;;

  create)
    shift 1
    user="${1:-$USERNAME}" && shift 1
    issue_repo="$1" && shift 1
    issue_title="$1" && shift 1
    [ -f "$1" ] && issue_body="$(cat "$1" | sed 's|^| |g')" || issue_body="$1"
    shift
    content="$(printf "%s\r" "{ \"title\": \"$issue_title\", \"body\": \"$issue_body\" }" >$GITADMIN_TEMP_FILE)"
    __api_issues_token "$user" "$issue_repo"
    printf_green "Attempting to create a new issue "
    curl -q -X "POST" -LSs "$ISSUE_API" -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Accept: application/vnd.github.v3+json" \
      -d @$GITADMIN_TEMP_FILE 2>/dev/null | jq -r ".html_url" | grep -v 'null' | printf_readline |
      grep '^' || printf_exit 1 "Failed to create the issue on\n\t\t$ISSUE_API"
    ;;

  edit)
    shift 1
    issue_number="$1" && shift 1
    user="${1:-$USERNAME}" && shift 1
    issue_repo="$1" && shift 1
    issue_title="$1" && shift 1
    [ -f "$1" ] && issue_body="$(cat "$1" | sed 's|^| |g')" || issue_body="$1"
    shift
    content="$(printf "%s\r" "{ \"title\": \"$issue_title\", \"body\": \"$issue_body\" }" >$GITADMIN_TEMP_FILE)"
    __api_issues_token "$user" "$issue_repo"
    printf_green "Attempting to edit issue $issue_number"
    curl -q -X "PATCH" -LSs "$ISSUE_API/$issue_number" -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" -H "Authorization: token $GITADMIN_GITHUB_AUTH_TOKEN" \
      -H "Accept: application/vnd.github.v3+json" -d @$GITADMIN_TEMP_FILE 2>/dev/null | jq -r ".html_url" |
      grep -v 'null' | printf_readline | grep '^' || printf_exit 1 "Failed to edit the issue at\n\t\t$ISSUE_API/$issue_number"
    ;;
  *)
    printf_help "Usage: $APPNAME [list,count,create] username reponame "
    ;;
  esac
  ;;

cron | updater)
  shift 1
  [[ "$1" = "help" || -z "$1" ]] && printf_help "Usage: gitadmin cron [run,remove,add]"
  case "$1" in
  run)
    shift 1
    __run_cron "run"
    ;;
  remove)
    shift 1
    __run_cron "remove"
    ;;
  add)
    shift 1
    __run_cron "add"
    ;;
  esac
  ;;

*)
  if [[ -z "$1" ]]; then
    __help
  else
    $(builtin type -P git 2>/dev/null) "$@"
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
