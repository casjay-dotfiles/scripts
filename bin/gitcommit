# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE"
  [ -d "$GITCOMMIT_CONFIG_DIR" ] || mkdir -p "$GITCOMMIT_CONFIG_DIR"
  [ -d "$GITCOMMIT_CONFIG_BACKUP_DIR" ] || mkdir -p "$GITCOMMIT_CONFIG_BACKUP_DIR"
  [ -f "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" ] &&
    cp -Rf "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" "$GITCOMMIT_CONFIG_BACKUP_DIR/$GITCOMMIT_CONFIG_FILE.$$"
  cat <<EOF >"$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE"
# Settings for gitcommit
GITCOMMIT_API_URL="${GIT_API_URL:-https://api.casjay.vercel.app/api/v1/commit/txt/}"
GITCOMMIT_MAIN_CONFIG=${GITCOMMIT_MAIN_CONFIG:-gitmainconfig}
GITCOMMIT_NO_CONFIRM="\${GITCOMMIT_NO_CONFIRM:-true}"
GITCOMMIT_PROJECT_DIR="\${GIT_PROJECT_DIR:-$HOME/Projects}"
GITCOMMIT_VERSION_FORMAT="\${VERSION_DATE_FORMAT:-%Y%m%d%H%M-git}"
GITCOMMIT_VERSION_FILE="\${GIT_VERSION_FILE:-version.txt}"

# Notification settings
GITCOMMIT_GOOD_MESSAGE="${GITCOMMIT_GOOD_MESSAGE:-Everything Went OK}"
GITCOMMIT_ERROR_MESSAGE="${GITCOMMIT_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GITCOMMIT_NOTIFY_ENABLED="${GITCOMMIT_NOTIFY_ENABLED:-yes}"
GITCOMMIT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GITCOMMIT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GITCOMMIT_NOTIFY_CLIENT_ICON}"

# Colorization settings
GITCOMMIT_OUTPUT_COLOR="${GITCOMMIT_OUTPUT_COLOR:-5}"
GITCOMMIT_OUTPUT_COLOR_GOOD="${GITCOMMIT_OUTPUT_COLOR_GOOD:-2}"
GITCOMMIT_OUTPUT_COLOR_ERROR="${GITCOMMIT_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__emj_check() { sed 's/\xf0\x9f/\r&/g; s/\s*\r.//g'; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_push() {
  git_cherry="$(git -C "$GITCOMMIT_CWD" cherry -v 2>&1 | grep -q 'usage: ' && return 1 || echo '0')"
  if { [ -n "$git_cherry" ] && [ -n "$GITCOMMIT_RAN" ]; } || [ "$PUSH_ENABLE" = "true" ]; then
    __git_push "$@"
  fi
  export PUSH_ENABLE=""
  export GITCOMMIT_PUSH="TRUE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tag_release() {
  local release="${1:-$(date +'%Y.%m.%d')}"
  local message="${2:-🚀🌟 Updated to version $release 🚀🌟}"
  local eCode="1"
  [[ -n "$release" ]] || printf_exit "Usage: $APPNAME release [version] [message]"
  git -C "$GITCOMMIT_CWD" tag "$release" -a -m "$message" &&
    git -C "$GITCOMMIT_CWD" push origin "$release" && eCode=0
  if [[ "$eCode" = 0 ]]; then
    printf_green "Successfully created new tag"
  else
    printf_red "Failed to create tag"
  fi
  return $eCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tar_release() {
  local release="${1:-$(date +'%Y.%m.%d')}"
  local backup_dir="$HOME/.local/backups/$APPNAME"
  local eCode="1"
  [ -d "$backup_dir" ] || mkdir -p "$backup_dir"
  printf_cyan "Creating backup from $GITCOMMIT_CWD to $backup_dir/$release.tar.gz "
  tar -cvf "$backup_dir/$release.tar.gz" "$GITCOMMIT_CWD" && eCode=0
  if [[ "$eCode" = 0 ]]; then
    printf_green "Successfully created tar file"
  else
    printf_red "Failed to create archive"
  fi
  return $eCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__changelog_create() { # Not yet enabled
  return
  local gitmessage_file="$GITCOMMIT_CWD/${GITCOMMIT_CHANGELOG:-CHANGELOG.md}"
  local gitmessage_file_tmp="$GITCOMMIT_TEMP_DIR/${GITCOMMIT_CHANGELOG:-CHANGELOG.tmp}"
  printf '### Changelog: %s\n\n' "$(date +'%Y-%m-%d at %H:%M')" >"$gitmessage_file_tmp"
  [[ $# -eq 0 || -z "$1" ]] || printf '%s\n\n' "$*" >>"$gitmessage_file_tmp"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__changelog_update() { # Not yet enabled
  return
  local change_message="${change_message:-$*}"
  local changed_files="${changed_files:-$(__changed_files)}"
  local gitmessage_file="$GITCOMMIT_CWD/${GITCOMMIT_CHANGELOG:-CHANGELOG.md}"
  local gitmessage_file_tmp="$GITCOMMIT_TEMP_DIR/${GITCOMMIT_CHANGELOG:-CHANGELOG.tmp}"
  for change in $changed_files; do
    printf '%s\n' "$change_message" >>"$gitmessage_file_tmp"
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__changelog_end() { # Not yet enabled
  return 0
  local gitmessage_file="$GITCOMMIT_CWD/${GITCOMMIT_CHANGELOG:-CHANGELOG.md}"
  local gitmessage_file_tmp="$GITCOMMIT_TEMP_DIR/${GITCOMMIT_CHANGELOG:-CHANGELOG.tmp}"
  printf '\n### End\n' >>"$gitmessage_file_tmp"
  cat "$gitmessage_file_tmp" >>"$gitmessage_file"
  rm -Rf "$gitmessage_file_tmp"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitmessage() {
  local message="$(echo -e "$*")"
  commitmess="$(echo -e "$message")"
  commitfile="${gitmessage_file:-$GITCOMMIT_CWD/.git/COMMIT_MESS}"
  testmessage="${commitmess:-$mess}"
  if [ ${#testmessage} -ge 75 ]; then
    commitmess="...${testmessage:0:69}..."
    printf '%s\n' "${testmessage}" | sed 's|^||g' >"$commitfile"
    export nomessage="true"
  else
    printf '%s\n' "${commitmess:-$mess}" | sed 's|^||g' >"$commitfile"
  fi
  if [ -n "${longmessage:-$fullcommit_message}" ]; then
    longmessage="$(echo -e "$fullcommit_message")"
    printf '\n%s\n\n' "${longmessage:-}" | sed 's|^||g' >>"$commitfile"
  fi
  export testmessage commitmess longmessage message_set="TRUE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

__gitcommit_cmd() {
  if [ -n "$GITCOMMIT_AMEND" ] || [ "$GITCOMMIT_AMEND" = "true" ]; then
    git -C "$GITCOMMIT_CWD" commit --untracked=no -q -S --amend -m "$(<"$commitfile")" 2>"$GITCOMMIT_TEMP_FILE" || return 1
  else
    git -C "$GITCOMMIT_CWD" commit --untracked=no -q -S -m "$(<"$commitfile")" 2>"$GITCOMMIT_TEMP_FILE" || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitcommit() {
  __git_porcelain "$GITCOMMIT_CWD" &>/dev/null && return
  local mess="${commitmess:-}"
  local succ="Successfully committed the changes to"
  local fail="Failed to commit the changes to"
  local column_length=$(($(tput cols) - 20))
  local removemess="${commitmess:10:30}"
  [ -n "$message_set" ] || __gitmessage "$mess"
  [ -n "$nomessage" ] || show_message="$(grep -svE "$removemess" "$commitfile" | grep -v '^$' | tr '\n' ' ' | grep '^')"
  [ -n "$message_set" ] && [ -s "$commitfile" ] || printf_return "The commit message is empty"
  printf_cyan "🧾 Committing Changes with the following message: 🧾"
  printf_yellow "${commitmess:-$mess}"
  [ -n "$show_message" ] && printf_blue "${show_message:0:$column_length}"
  if __gitcommit_cmd; then
    if [ "$NO_MESSAGE" != "true" ]; then
      if __getexitcode "${GITCOMMIT_EXITCODE:-$?}" "🔗 $succ $(__git_repobase "$GITCOMMIT_CWD") 🔗" "🚫 $fail $(__git_repobase "$GITCOMMIT_CWD") 🚫"; then
        printf_green "🆔commit ID: $(__git_commitid "$GITCOMMIT_CWD") 🆔"
        COMMIT_ID="$(__git_commitid "$GITCOMMIT_CWD")"
      fi
    fi
  else
    printf_readline "5" <"$GITCOMMIT_TEMP_FILE"
    printf_exit "Failed to commit the changes"
  fi
  [ -f "$commitfile" ] && rm -Rf $commitfile
  export GITCOMMIT_RAN="true"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_init() {
  export fullcommit_message="$(echo -e "New repo created in $(date +'%Y-%m-%d at %H:%M')\n\n$*\n")"
  action="${set_action:-📂 Initial Commit}"
  icon="${set_icon:- 📂}"
  initm="$action$icon"
  git -C "$GITCOMMIT_CWD" init &>/dev/null
  __gitignore_init "$GITCOMMIT_CWD" &>/dev/null
  git -C "$GITCOMMIT_CWD" add -A &>/dev/null && __gitcommit "$initm" || return 1
  export PUSH_ENABLE=true
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__changed_files() {
  local files=""
  if [ "$1" = "message" ]; then
    git -C "$GITCOMMIT_CWD" status -b -s | grep -v '^$' | sed '/^\#/d;s,^ ,,g;s,??,A,g' | tr '\n' ' | ' | sed 's# | $# #g' | sed 's|  | |g' | grep '^' || return 1
  elif [ "$1" = "added" ]; then
    git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -Ew ^'\?\?|A|AA' | awk '{print $2}' | sort -u | grep -v '^$' | grep '^' || return 1
  elif [ "$1" = "renamed" ]; then
    git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -Ew ^'R|RM| R' | awk '{print $2}' | sort -u | grep -v '^$' | grep '^' || return 1
  elif [ "$1" = "modified" ]; then
    git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -Ew ^'M|MM| M' | awk '{print $2}' | sort -u | grep -v '^$' | grep '^' || return 1
  elif [ "$1" = "deleted" ]; then
    git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -E ^'[M, ]D|DD' | awk '{print $2}' | sort -u | grep -v '^$' | grep '^' || return 1
  else
    files+="$(__changed_files added) "
    files+="$(__changed_files modified) "
    files+="$(__changed_files deleted) "
    files+="$(__changed_files renamed) "
    echo -e "$files" | tr ' ' '\n' | sort -u | grep -v '^$' | grep '^'
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__default_git_action() {
  local modified added deleted message
  message="$(echo -e "$*")"
  added="$(__changed_files added)"
  deleted="$(__changed_files deleted)"
  modified="$(__changed_files modified)"
  for a in $added; do __git_add "$message"; done
  for m in $modified; do __git_mod "$message"; done
  for d in $deleted; do __git_del "$message"; done
  export PUSH_ENABLE=true
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_updated() {
  export NO_ERROR=true
  __git_add "$(echo -e "$*")"
  __git_mod "$(echo -e "$*")"
  export PUSH_ENABLE=true
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_mod() {
  export fullcommit_message="$(echo -e "$*")"
  action="${set_action:-🗃 Modified:}"
  icon="${set_icon:-🗃}"
  modified="$(__changed_files modified)"
  [ -n "$modified" ] || { [ "$NO_ERROR" != "true" ] && printf_return "No files have been modified" || return 1; }
  export changed_files="$modified"
  __changelog_update "$action $changed_files $icon"
  for f in $modified; do
    setmess="$(echo "${action:-} $f ${icon:-}" | sed "s|$f.*.$f|$f|g")"
    __gitmessage "$setmess"
    git -C "$GITCOMMIT_CWD" add $f &>/dev/null
    __gitcommit || exitCode+="1"
  done
  export PUSH_ENABLE=true
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_add() {
  export fullcommit_message="$(echo -e "$*")"
  action="${set_action:-❓ Added:}"
  icon="${set_icon:-❓}"
  added="$(__changed_files added)"
  [ -n "$added" ] || { [ "$NO_ERROR" != "true" ] && printf_return "No files have been added" || return 1; }
  export changed_files="$added"
  __changelog_update "$action $changed_files $icon"
  for f in $added; do
    setmess="$(echo -e "${action:-} $f ${icon:-}" | sed "s|$f.*.$f|$f|g")"
    __gitmessage "$setmess"
    git -C "$GITCOMMIT_CWD" add $f &>/dev/null
    __gitcommit || exitCode+="1"
  done
  exit
  export PUSH_ENABLE=true
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_del() {
  action="${set_action:-➖ Deleted:}"
  icon="${set_icon:-➖}"
  deleted="$(__changed_files deleted | grep -v '$^' | tr '\n' ' ')"
  export fullcommit_message="$(printf '\n\n%s\n' "$deleted" | tr ' ' '\n' && echo -e "$*")"
  [ -n "$deleted" ] || { [ "$NO_ERROR" != "true" ] && printf_return "No files have been deleted" || return 1; }
  setmess="$(echo -e "${action:-} ${deleted:0:75} ${icon:-}")"
  export changed_files="$deleted"
  __changelog_update "$action $changed_files $icon"
  __gitmessage "$setmess"
  git -C "$GITCOMMIT_CWD" rm $deleted -rf &>/dev/null
  __gitcommit
  export PUSH_ENABLE=true
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_renamed() {
  export fullcommit_message="$(echo -e "$*")"
  action="${set_action:-✔️ Renamed: ${1} ➡ ${2}:}"
  icon="${set_icon:-✔️}"
  [ -f "$1" ] && mv -f "$1" "$2" &>/dev/null
  setmess="$(echo -e "${action:-} ${icon:-}")"
  __gitmessage "$setmess"
  git -C "$GITCOMMIT_CWD" rm $1 -rf &>/dev/null
  git -C "$GITCOMMIT_CWD" add $2 &>/dev/null && __gitcommit "$3"
  export PUSH_ENABLE=true
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__files() {
  export fullcommit_message="$(echo -e "$*")"
  action="${set_action:-➖:}"
  icon="${set_icon:-➖}"
  setmess="${action:-} ${icon:-}"
  __gitmessage "$setmess"
  git -C "$GITCOMMIT_CWD" add $(__changed_files added) &>/dev/null
  git -C "$GITCOMMIT_CWD" rm $(__changed_files deleted) &>/dev/null
  __gitcommit
  export PUSH_ENABLE=true
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitignore_init() {
  [ -e "${1:-$GITCOMMIT_CWD}/.gitignore" ] && return
  [ -d "${1:-$GITCOMMIT_CWD}/node_modules" ] &&
    gitignore "${1:-$GITCOMMIT_CWD}" dirignore default node ||
    gitignore "${1:-$GITCOMMIT_CWD}" dirignore default
  printf '# ignore commit message\n.gitcommit\n' >>"$GITCOMMIT_CWD/.gitignore"
  if [ -d "${1:-$GITCOMMIT_CWD}/.git" ]; then
    git -C "${1:-$GITCOMMIT_CWD}" add .gitignore &>/dev/null
    git -C "${1:-$GITCOMMIT_CWD}" commit -q -S -m "🤖 Added .gitignore 🤖" ".gitignore" || return 1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__test_gitignore() {
  if ! grep -sq '.gitcommit' "$GITCOMMIT_CWD/.gitignore"; then
    printf '# ignore commit message\n.gitcommit\n' >>"$GITCOMMIT_CWD/.gitignore"
    git -C "${1:-$GITCOMMIT_CWD}" add .gitignore &>/dev/null
    git -C "$GITCOMMIT_CWD" commit -q -S -m "🤖 Added .gitcommit 🤖" ".gitignore" || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_dir() {
  local git_dir="${1:-$GITCOMMIT_CWD}"
  local makerepo=""
  if [ "$(git -C "$git_dir" rev-parse --is-inside-work-tree 2>/dev/null)" == "" ]; then
    printf_error "You are not in a git repo"
    printf_read_question "4" "Would you like to turn $git_dir into a git repo? y/N" "1" "makerepo"
    if printf_answer_yes "$makerepo"; then
      __gitignore_init "$git_dir"
      gitadmin "$git_dir" setup
      exit $?
    else
      exit
    fi
  fi
  [ -d "$git_dir" ] || printf_exit "$git_dir doesn't seem to be a directory"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_commitid() {
  echo -n "$(git -C "${1:-$GITCOMMIT_CWD}" rev-parse --short HEAD)"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_check_cherry() { git -C "$GITCOMMIT_CWD" cherry -v 2>&1 | grep -q 'usage: ' && return 1 || echo '0'; }
__git_check_branch() { git -C "$GITCOMMIT_CWD" branch -avvv 2>&1 | grep -q ': ahead ' && return || return 1; }
__git_check_ahead() { git -C "$GITCOMMIT_CWD" log --oneline origin..HEAD 2>&1 | wc -l | grep -q '0' && return 0 || return 1; }
__git_cherry() { { [ -z "$(__git_check_cherry)" ] && [ -z "$GITCOMMIT_RAN" ]; } && return 0 || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_push_check() {
  if __git_check_branch || __git_check_ahead || __git_cherry || [ "$PUSH_ENABLE" != "true" ]; then
    return 1
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_push() {
  local GITCOMMIT_EXITCODE=0
  local git_dir="${1:-$GITCOMMIT_CWD}"
  local git_repo="$(__git_remote_fetch "$GITCOMMIT_CWD")"
  local git_remote="$(git -C "$GITCOMMIT_CWD" remote show | grep '^' || false)"
  local git_failed="😿 Failed to push the changes to $git_repo 😿"
  local git_succes="㊗️ Successfully pushed the changes for commit ID: ㊗️"
  local git_push=""
  if [ "$PUSH_ENABLE" != "true" ] || __git_push_check; then
    printf_exit "🛠 No changes to push 🛠"
  fi
  [[ -n "$git_remote" ]] || return 0
  [[ -f "$git_dir/.nopush" ]] && return
  am_i_online --error -m "🚫 No internet connection. Skipping push 🚫" || exit 1
  if [ "$git_repo" != "localdir" ]; then
    if [[ "$*" =~ --automated ]] || [[ "$*" =~ --force ]]; then
      printf_green "🔼 Pushing the changes to $git_repo 🔼"
      git -C "$git_dir" push -q &>/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
      __getexitcode $GITCOMMIT_EXITCODE "$git_succes $(__git_commitid "$git_dir")" "$git_failed"
    else
      if [ "$GITCOMMIT_NO_CONFIRM" != "true" ]; then
        printf_read_question "3" "Should I push to $git_repo? [y/n]" "1" "git_push"
      else
        git_push="Y"
      fi
      if printf_answer_yes "$git_push"; then
        printf_green "📍 Pushing the changes to $git_repo 📍"
        git -C "$git_dir" push -q &>/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
        __getexitcode $GITCOMMIT_EXITCODE "$git_succes $(__git_commitid "$git_dir")" "$git_failed"
      fi
    fi
  fi
  return $GITCOMMIT_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__commit_version() {
  local -a args=("$@")
  if [[ -n "$ARGS" ]]; then
    git -C "$GITCOMMIT_CWD" commit -q -S -m "$git_versionbump" "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE" "$ARGS" || return 1
  else
    git -C "$GITCOMMIT_CWD" commit -q -S -m "$git_versionbump" "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE" || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__write_version() {
  [ "$1" = "--force" ] || [ -f "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE" ] || return 1
  date +"$GITCOMMIT_VERSION_FORMAT" >"$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE"
  git_versionbump="🚀 Version Bump: $(cat "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE") 🚀 "
  printf_blue "$git_versionbump"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__set_version() {
  if [ "$1" = "--force" ] || [ -f "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE" ]; then
    local git_dir="$GITCOMMIT_CWD"
    local git_sucess="Successfully committed the new version to"
    local git_failed="Failed to commit the version change in"
    local GITCOMMIT_MESSAGE="🚀 Version Bump: $(cat "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE") 🚀 "
    local GITCOMMIT_EXITCODE=0
    __write_version "$1" || printf_exit "Version files doesn't exist"
    git -C "$GITCOMMIT_CWD" add "$GITCOMMIT_VERSION_FILE" &>/dev/null &&
      git -C "$GITCOMMIT_CWD" commit -m "$GITCOMMIT_MESSAGE" &>/dev/null &&
      GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
    __getexitcode $GITCOMMIT_EXITCODE "🔗 $git_sucess $(__git_repobase "$git_dir")🔗 " "🚫 $git_failed ${git_dir//$PWD/.} 🚫"
  fi
  export NO_MESSAGE=true PUSH_ENABLE=true
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__rename_branch() {
  local branch="$1" && shift 1
  local USER="${2:-$(basename "$(dirname "$GITCOMMIT_CWD")")}"
  local REPO="${3:-$(basename "$GITCOMMIT_CWD")}"
  printf_blue "Changing git branch to $branch on $REPO"
  git -C "$GITCOMMIT_CWD" branch -m master "$branch" &>/dev/null
  git -C "$GITCOMMIT_CWD" push -u origin "$branch" -fq &>/dev/null
  if curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER/$REPO" \
    -d '{"default_branch":"'$branch'"}' | grep -q '"default_branch": "main"' &>/dev/null; then
    git -C "$GITCOMMIT_CWD" push --delete origin master -fq &>/dev/null
    printf_green "Changed the default branch on github.com/$USER/$REPO"
  fi &&
    printf_green "Successfully renamed the default branch" ||
    printf_exit 1 1 "Failed to rename the default branch"
  git config --global init.defaultBranch "$branch" &>/dev/null
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_branch() {
  local branch="$1"
  local USER="${2:-$(basename "$(dirname "$GITCOMMIT_CWD")")}"
  local REPO="${3:-$(basename "$GITCOMMIT_CWD")}"
  local GITCOMMIT_EXITCODE=0
  printf_exit "$USER"/"$REPO"
  curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER/$REPO" \
    -d '{"default_branch":"'$branch'"}' &>/dev/null || GITCOMMIT_EXITCODE=1
  return $GITCOMMIT_EXITCODE
}
