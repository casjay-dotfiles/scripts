# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -s "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$GITCOMMIT_REQUIRE_SUDO" = "yes" ] && [ -z "$GITCOMMIT_REQUIRE_SUDO_RUN" ]; then
    export GITCOMMIT_REQUIRE_SUDO="no"
    export GITCOMMIT_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "$(basename "$SUDO" 2>/dev/null)" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-$?}
  [ -f "$GITCOMMIT_TEMP_FILE" ] && rm -Rf "$GITCOMMIT_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__emj_check() {
  sed 's/\xf0\x9f/\r&/g; s/\s*\r.//g'
}
__sanitize_url() {
  sed 's|://*.*:|://|g'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_push() {
  [ -f "$GITCOMMIT_CWD/.no_push" ] && printf_yellow "㊗️ Push is disabled for $GITCOMMIT_CWD ㊗️ " && exit 0
  __git_push "$@" &&
    export PUSH_ENABLE="" &&
    export GITCOMMIT_PUSH="TRUE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tag_release() {
  local release="" message="" eCode=""
  release="${1:-$(date +'%Y.%m')}"
  message="${2:-🚀🌟 Updated to version $release 🚀🌟}"
  eCode="1"
  [ -n "$release" ] || printf_exit "Usage: $APPNAME release [version] [message]"
  git -C "$GITCOMMIT_CWD" tag "$release" -a -m "$message" &&
    git -C "$GITCOMMIT_CWD" push origin "$release" && eCode=0
  if [ "$eCode" = 0 ]; then
    printf_green "Successfully created new tag"
  else
    printf_red "Failed to create tag"
  fi
  return $eCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tar_release() {
  local release="" backup_dir="" eCode=""
  release="${1:-$(date +'%Y.%m.%d')}"
  backup_dir="$HOME/.local/backups/$APPNAME"
  eCode="1"
  [ -d "$backup_dir" ] || mkdir -p "$backup_dir"
  printf_cyan "Creating backup from $GITCOMMIT_CWD to $backup_dir/$release.tar.gz "
  tar -cvf "$backup_dir/$release.tar.gz" "$GITCOMMIT_CWD" && eCode=0
  if [ "$eCode" = 0 ]; then
    printf_green "Successfully created tar file"
  else
    printf_red "Failed to create archive"
  fi
  return $eCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# TODO: Turn this into a seperate script
__changelog_create() {
  local gitmessage_file="" gitmessage_file_tmp="" git_commit_mess="" set_commit_message=()
  [ -n "$append_changelog_message" ] && changelog_message="$changelog_message - $append_changelog_message"
  changelog_name="${GITCOMMIT_CHANGELOG_FILE_NAME:-CHANGELOG.md}"
  set_commit_mess="${GITCOMMIT_MESSAGE_SHORT:-$GITCOMMIT_MESSAGE}"
  git_commit_mess="${set_commit_mess:-$changelog_message}"
  changed_files="${changed_files:-$(__changed_files "$1")}"
  changed_icon="${icon:-$GITCOMMIT_CHANGELOG_ICON}"
  [ -f "$changelog_name" ] || return 0
  [ -n "$git_commit_mess" ] || return 0
  CHANGELOG_DATE="$(date +'%Y-%m-%d at %H:%M:%S')"
  gitmessage_file="$GITCOMMIT_CWD/$changelog_name"
  gitmessage_file_tmp="$GITCOMMIT_TEMP_DIR/${APPNAME}-${changelog_name}.tmp"
  printf '#### Changelog: %s  \n\n' "$CHANGELOG_DATE" >"$gitmessage_file_tmp"
  printf '' >"$GITCOMMIT_CWD/.git/prev_commit_files.txt"
  if [ -f "$gitmessage_file_tmp" ]; then
    for changed in $changed_files; do
      if [ -n "$changed" ]; then
        printf '%s  \n' "$changed : $git_commit_mess ${changed_icon// /}" >>"$gitmessage_file_tmp"
        printf '%s\n' "$changed" >>"$GITCOMMIT_CWD/.git/prev_commit_files.txt"
        set_commit_message+=("$changed : $git_commit_mess")
      fi
    done
    printf '  \n#### End of changes for %s - %s  \n  \n----  \n  \n' "$GITCOMMIT_VERSION_CURRENT" "$CHANGELOG_DATE" >>"$gitmessage_file_tmp"
    [ -f "$gitmessage_file" ] && cat "$gitmessage_file" >>"$gitmessage_file_tmp"
    mv -f "$gitmessage_file_tmp" "$gitmessage_file" &&
      rm -Rf "$gitmessage_file_tmp" &&
      export fullcommit_message="$(printf '%s\n' "${set_commit_message[@]}")"
    git -C "$GITCOMMIT_CWD" add "CHANGELOG.md"
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitmessage() {
  local message=""
  message="$(echo -e "$*")"
  commitmess="$(echo -e "$message")"
  commitfile="${gitmessage_file:-$GITCOMMIT_CWD/.git/COMMIT_MESS}"
  testmessage="${commitmess:-$mess}"
  if [ ${#testmessage} -ge 75 ]; then
    commitmess="...${testmessage:0:69}..."
    printf '%s\n' "${testmessage}" | sed 's|^||g' >"$commitfile"
    GITCOMMIT_MESSAGE_SHORT="$commitmess"
    nomessage="true"
  else
    printf '%s\n' "${commitmess:-$mess}" | sed 's|^||g' >"$commitfile"
    GITCOMMIT_MESSAGE_SHORT="${commitmess:-$mess}"
    nomessage="true"
  fi
  if [ -n "${longmessage:-$fullcommit_message}" ]; then
    longmessage="$(echo -e "${longmessage:-$fullcommit_message}")"
    GITCOMMIT_MESSAGE_SHORT="${GITCOMMIT_MESSAGE_SHORT:-$commitmess}"
    GITCOMMIT_MESSAGE_LONG="$longmessage"
    printf '\n%s\n\n' "${longmessage:-}" | sed 's|^||g' >>"$commitfile"
  fi
  export nomessage testmessage commitmess longmessage message_set="TRUE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitcommit_cmd() {
  local git_amend="$GITCOMMIT_AMEND"
  local changelog_file="$GITCOMMIT_CWD/${GITCOMMIT_CHANGELOG_FILE_NAME:-CHANGELOG.md}"
  if [ -f "$changelog_file" ] && [ "$git_amend" = "true" ]; then
    git -C "$GITCOMMIT_CWD" commit --untracked=no -q -S --amend --no-edit &>"$GITCOMMIT_TEMP_FILE" || return 1
  elif [ -f "$commitfile" ]; then
    git -C "$GITCOMMIT_CWD" commit -q -S -m "$(<"$commitfile")" &>"$GITCOMMIT_TEMP_FILE" || return 1
  else
    git -C "$GITCOMMIT_CWD" commit -q -S -m "${1:-$mess}" &>"$GITCOMMIT_TEMP_FILE"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitcommit() {
  local mess="" succ="" fail="" column_length="" removemess="" add_changelog_to_commit=""
  __git_porcelain "$GITCOMMIT_CWD" &>/dev/null && return
  mess="${commitmess:-}"
  succ="Successfully committed the changes to"
  fail="Failed to commit the changes to"
  column_length=$(($(tput cols) - 20))
  removemess="${commitmess:10:30}"
  add_changelog_to_commit=""
  [ -n "$message_set" ] || __gitmessage "$mess"
  [ -n "$nomessage" ] || show_message="$(grep -svE "$removemess" "$commitfile" | grep -v '^$' | tr '\n' ' ' | grep '^')"
  [ -n "$message_set" ] && [ -s "$commitfile" ] || printf_return "The commit message is empty"
  printf_cyan "👊 Committing Changes with the following message: 👊"
  printf_yellow "${commitmess:-$mess}"
  [ -n "$show_message" ] && printf_blue "${show_message:0:$column_length}"
  if __gitcommit_cmd "$mess"; then
    if [ "$NO_MESSAGE" != "true" ]; then
      if __getexitcode "${GITCOMMIT_EXITCODE:-$?}" "🔗 $succ $(__git_repobase "$GITCOMMIT_CWD") 🔗" "🚫 $fail $(__git_repobase "$GITCOMMIT_CWD") 🚫"; then
        printf_green "🆔 commit ID: $(__git_commitid "$GITCOMMIT_CWD") 🆔"
        COMMIT_ID="$(__git_commitid "$GITCOMMIT_CWD")"
      fi
    fi
  else
    printf_readline "5" <"$GITCOMMIT_TEMP_FILE"
    printf_exit "Failed to commit the changes"
  fi
  add_changelog_to_commit="$(__changed_files changelog | grep '^' || echo '')"
  if [ -n "$add_changelog_to_commit" ]; then
    git -C "$GITCOMMIT_CWD" add "CHANGELOG.md" &>/dev/null &&
      git -C "$GITCOMMIT_CWD" commit --amend --no-edit &>/dev/null
  fi
  [ -f "$commitfile" ] && rm -Rf "$commitfile"
  export GITCOMMIT_RAN="true"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_init() {
  local exitCode=""
  is_url "$1" && REPO="$1" && shift 1
  fullcommit_message="$(echo -e "New repo created on $(date +'%Y-%m-%d at %H:%M')\n\n$*\n")"
  action="${set_action:-📂 $fullcommit_message}"
  icon="${set_icon:- 📂}"
  initm="$action$icon"
  GITCOMMIT_MESSAGE="$initm"
  export PUSH_ENABLE GITCOMMIT_MESSAGE fullcommit_message __gitmessage
  __gitignore_init "$GITCOMMIT_CWD" &>/dev/null
  gitadmin --dir "$GITCOMMIT_CWD" setup "${REPO:-}" && exitCode=0 || exitCode=1
  PUSH_ENABLE="true"
  exit ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__changed_files() {
  local files=""
  while :; do
    case $1 in
    message)
      shift
      git -C "$GITCOMMIT_CWD" status -b -s | grep -v '^$' | sed '/^\#/d;s,^ ,,g;s,??,A,g' | tr '\n' ' | ' | sed 's# | $# #g' | sed 's|  | |g' | grep -v '^CHANGELOG.md' | grep '^' || return 1
      ;;
    added)
      shift
      git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -Ew ^'\?\?|A|AA' | awk '{print $2}' | sort -u | grep -v '^$' | grep -v '^CHANGELOG.md' | grep '^' || return 1
      ;;
    renamed)
      shift
      git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -Ew ^'R|RM| R' | awk '{print $2}' | sort -u | grep -v '^$' | grep -v '^CHANGELOG.md' | grep '^' || return 1
      ;;
    modified)
      shift
      git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -Ew ^'M|MM| M' | awk '{print $2}' | sort -u | grep -v '^$' | grep -v '^CHANGELOG.md' | grep '^' || return 1
      ;;
    deleted)
      shift
      git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -E ^'[M, ]D|DD' | awk '{print $2}' | sort -u | grep -v '^$' | grep -v '^CHANGELOG.md' | grep '^' || return 1
      ;;
    changelog)
      shift
      files+="$(__changed_files added | grep '^CHANGELOG.md') "
      files+="$(__changed_files modified | grep '^CHANGELOG.md') "
      files+="$(__changed_files deleted | grep '^CHANGELOG.md') "
      files+="$(__changed_files renamed | grep '^CHANGELOG.md') "
      results="$(echo -e "$files" | tr ' ' '\n' | sort -u | grep -v '^$' | grep '^')"
      [ -n "$results" ] && echo "$results"
      ;;
    all)
      shift 1
      files+="$(__changed_files added) "
      files+="$(__changed_files modified) "
      files+="$(__changed_files deleted) "
      files+="$(__changed_files renamed) "
      echo -e "$files" | tr ' ' '\n' | sort -u | grep -v '^$' | grep '^'
      ;;
    *)
      break
      ;;
    esac
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__default_git_action() {
  local modified added deleted message
  if [ "$1" = "--add-all-files" ]; then
    shift 1
    message="$(echo -e "$*")"
    __git_all "$message"
  else
    message="$(echo -e "$*")"
    added="$(__changed_files added)"
    deleted="$(__changed_files deleted)"
    renamed="$(__changed_files modified)"
    modified="$(__changed_files modified)"
    for a in $added; do __git_add "$message"; done
    for m in $modified; do __git_mod "$message"; done
    for d in $deleted; do __git_del "$message"; done
    for r in $renamed; do __git_renamed "$message"; done
  fi
  export PUSH_ENABLE=true
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_updated() {
  export NO_ERROR="true"
  __git_add "$(echo -e "$*")"
  __git_mod "$(echo -e "$*")"
  export PUSH_ENABLE=true
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_all() {
  local message="$1"
  fullcommit_message="$(echo -e "${fullcommit_message:-$*}")"
  action="${set_action:-🗃 }"
  icon="${set_icon:-🗃}"
  modified="$(__changed_files all)"
  [ -n "$modified" ] || { [ "$NO_ERROR" != "true" ] &&
    printf_return "🙁 No files have been modified in $GITCOMMIT_CWD 🙁" || return 1; }
  export PUSH_ENABLE=true fullcommit_message
  setmess="$(printf '%s\n' "${action:-} ${icon:-}")"
  __gitmessage "$setmess"
  git -C "$GITCOMMIT_CWD" add . &>/dev/null
  __gitcommit || exitCode+="1"
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_mod() {
  fullcommit_message="$(echo -e "${fullcommit_message:-$*}")"
  action="${set_action:-🗃 Modified:}"
  icon="${set_icon:-🗃}"
  modified="$(__changed_files modified)"
  [ -n "$modified" ] || { [ "$NO_ERROR" != "true" ] &&
    printf_return "🙁 No files have been modified in $GITCOMMIT_CWD 🙁" || return 1; }
  export PUSH_ENABLE=true fullcommit_message
  for f in $modified; do
    setmess="$(echo "${action:-} $f ${icon:-}" | sed "s|$f.*.$f|$f|g")"
    __gitmessage "$setmess"
    git -C "$GITCOMMIT_CWD" add "$f" &>/dev/null
    __gitcommit || exitCode+="1"
  done
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_add() {
  fullcommit_message="$(echo -e "${fullcommit_message:-$*}")"
  action="${set_action:-❓ Added:}"
  icon="${set_icon:-❓}"
  added="$(__changed_files added)"
  [ -n "$added" ] || { [ "$NO_ERROR" != "true" ] &&
    printf_return "🙁 No files have been added in $GITCOMMIT_CWD 🙁" || return 1; }
  export PUSH_ENABLE=true fullcommit_message
  for f in $added; do
    setmess="$(echo -e "${action:-} $f ${icon:-}" | sed "s|$f.*.$f|$f|g")"
    __gitmessage "$setmess"
    git -C "$GITCOMMIT_CWD" add $f &>/dev/null
    __gitcommit || exitCode+="1"
  done
  #  exit
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_del() {
  fullcommit_message="$(echo -e "${fullcommit_message:-$*}")"
  action="${set_action:-➖ Deleted:}"
  icon="${set_icon:-➖}"
  deleted="$(__changed_files deleted)"
  [ -n "$deleted" ] || { [ "$NO_ERROR" != "true" ] &&
    printf_return "🙁 No files have been deleted in $GITCOMMIT_CWD 🙁" || return 1; }
  export PUSH_ENABLE=true fullcommit_message
  for f in $deleted; do
    setmess="$(echo -e "${action:-} ${f:0:75} ${icon:-}")"
    __gitmessage "$setmess"
    git -C "$GITCOMMIT_CWD" rm -rf "$f" --ignore-unmatch --cached &>/dev/null
    __gitcommit || exitCode+="1"
  done
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_renamed() {
  fullcommit_message="$(echo -e "${fullcommit_message:-$*}")"
  export fullcommit_message
  action="${set_action:-✔️ Renamed: ${1} ➡ ${2}:}"
  icon="${set_icon:-✔️}"
  [ -d "$1" ] && mkdir -p "$(dirname "$2")"
  [ -e "$1" ] && mv -f "$1" "$2" &>/dev/null
  setmess="$(echo -e "${action:-} ${icon:-}")"
  __gitmessage "$setmess"
  git -C "$GITCOMMIT_CWD" rm "$1" -rf &>/dev/null
  git -C "$GITCOMMIT_CWD" add "$2" &>/dev/null && __gitcommit "$3"
  export PUSH_ENABLE=true
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__files() {
  fullcommit_message="$(echo -e "${fullcommit_message:-$*}")"
  export
  action="${set_action:-➖}"
  icon="${set_icon:-➖}"
  setmess="${action:-} ${icon:-}"
  __gitmessage "$setmess"
  git -C "$GITCOMMIT_CWD" add $(__changed_files added) &>/dev/null
  git -C "$GITCOMMIT_CWD" rm $(__changed_files deleted) &>/dev/null
  __gitcommit
  export PUSH_ENABLE=true
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitignore_init() {
  [ -e "${1:-$GITCOMMIT_CWD}/.gitignore" ] && return
  [ -d "${1:-$GITCOMMIT_CWD}/node_modules" ] &&
    gitignore "${1:-$GITCOMMIT_CWD}" dirignore default node ||
    gitignore "${1:-$GITCOMMIT_CWD}" dirignore default
  printf '# ignore commit message\n.gitcommit\n' >>"$GITCOMMIT_CWD/.gitignore"
  if [ -d "${1:-$GITCOMMIT_CWD}/.git" ]; then
    git -C "${1:-$GITCOMMIT_CWD}" add .gitignore &>/dev/null
    git -C "${1:-$GITCOMMIT_CWD}" commit -q -S -m "🤖 Added .gitignore 🤖" ".gitignore" || return 1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__test_gitignore() {
  if ! grep -sq '.gitcommit' "${1:-$GITCOMMIT_CWD}/.gitignore"; then
    printf '# ignore commit message\n.gitcommit\n' >>"$GITCOMMIT_CWD/.gitignore"
    git -C "${1:-$GITCOMMIT_CWD}" add .gitignore &>/dev/null
    git -C "${1:-$GITCOMMIT_CWD}" commit -q -S -m "🤖 Added .gitcommit 🤖" ".gitignore" || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_dir() {
  local git_dir="" makerepo=""
  git_dir="${1:-$GITCOMMIT_CWD}"
  makerepo=""
  if [ "$(git -C "$git_dir" rev-parse --is-inside-work-tree 2>/dev/null)" == "" ]; then
    printf_error "You are not in a git repo"
    printf_read_question "4" "Would you like to turn $git_dir into a git repo? y/N" "1" "makerepo"
    if printf_answer_yes "$makerepo"; then
      __gitignore_init "$git_dir"
      gitadmin --dir "$git_dir" setup
      exit $?
    else
      exit
    fi
  fi
  [ -d "$git_dir" ] || printf_exit "$git_dir doesn't seem to be a directory"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_commitid() {
  echo -n "$(git -C "${1:-$GITCOMMIT_CWD}" rev-parse --short HEAD)"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_check_cherry() {
  git -C "$GITCOMMIT_CWD" cherry -v 2>&1 | wc -l | grep -q '0' && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_check_ahead() {
  git -C "$GITCOMMIT_CWD" log --oneline origin..HEAD 2>&1 | wc -l | grep -q '0' && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_check_branch() {
  git -C "$GITCOMMIT_CWD" branch -avvv 2>&1 | grep -q ': ahead ' && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_check_push() {
  local exitCode=""
  if [ "$(git -C "$GITCOMMIT_CWD" diff --stat origin/main 2>/dev/null | wc -l)" -ne 0 ]; then
    exitCode=0
  elif __git_check_ahead; then
    exitCode=0
  else
    exitCode=1
  fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_push_check() {
  if __git_check_push; then
    return 0
  elif __git_check_cherry; then
    return 0
  elif __git_check_ahead; then
    return 0
  elif __git_check_branch; then
    return 0
  elif git s | grep -v '## ' | grep -q '^'; then
    return 0
  elif [ -n "$GITCOMMIT_RAN" ]; then
    return 0
  elif [ "$PUSH_ENABLE" = "true" ]; then
    return 0
  elif [ -n "$FORCE_PUSH" ]; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_custom_pull() {
  [ -d "${1:-GITCOMMIT_CWD}/.git" ] && gitadmin pull "${1:-GITCOMMIT_CWD}" 2>/dev/null
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_custom_push() {
  [ -d "${1:-GITCOMMIT_CWD}/.git" ] && gitadmin push "${1:-GITCOMMIT_CWD}" 2>/dev/null
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_push() {
  local GITCOMMIT_EXITCODE=0 git_dir="" git_repo="" git_remote=""
  local git_failed="" git_succes="" git_push="" git_repo_clean=""
  git_dir="${1:-$GITCOMMIT_CWD}"
  git_repo="$(__git_remote_fetch "$GITCOMMIT_CWD")"
  git_remote="$(git -C "$GITCOMMIT_CWD" remote show | grep '^' || false)"
  git_failed="Failed to push the changes to $git_repo"
  git_succes="Successfully pushed the changes for commit ID:"
  git_push=""
  git_repo_clean="$(echo "$git_repo" | __sanitize_url)"
  if __git_push_check; then
    [ -n "$git_remote" ] || return 0
    [ -f "$git_dir/.nopush" ] && return
    am_i_online --error -m "🚫 No internet connection. Skipping push 🚫" || exit 1
    if [ "$git_repo" != "localdir" ]; then
      if [ -n "$FORCE_PUSH" ]; then
        printf_green "🔼 Pushing the changes to $git_repo_clean 🔼"
        git -C "$git_dir" push -f -q &>/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
        __getexitcode $GITCOMMIT_EXITCODE "$git_succes $(__git_commitid "$git_dir")" "$git_failed"
      elif [[ "$*" =~ --automated ]] || [[ "$*" =~ --force ]]; then
        printf_green "🔼 Pushing the changes to $git_repo_clean 🔼"
        git -C "$git_dir" push -q &>/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
        __getexitcode $GITCOMMIT_EXITCODE "$git_succes $(__git_commitid "$git_dir")" "$git_failed"
      else
        if [ "$GITCOMMIT_NO_CONFIRM" != "true" ]; then
          printf_read_question "3" "Should I push to $git_repo_clean? [y/n]" "1" "git_push"
        else
          git_push="Y"
        fi
        if printf_answer_yes "$git_push"; then
          printf_green "📍 Pushing the changes to $git_repo_clean 📍"
          git -C "$git_dir" push -q &>/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
          __getexitcode $GITCOMMIT_EXITCODE "㊗️ $git_succes $(__git_commitid "$git_dir") ㊗️" "😿 $git_failed 😿"
        fi
      fi
    else
      printf_red "⚠️ Doesn't seem to have a remote setup ⚠️"
      GITCOMMIT_EXITCODE=0
    fi
  else
    printf_red "🛠 No changes to push in $GITCOMMIT_CWD 🛠"
    GITCOMMIT_EXITCODE=1
  fi
  return $GITCOMMIT_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__commit_custom_cmd() {
  if [ "$1" = "" ]; then
    git -C "$GITCOMMIT_CWD" add "${1:-GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE}" &&
      git -C "$GITCOMMIT_CWD" commit -q -S -m "$GITCOMMIT_MESSAGE" "${1:-$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE}" &>/dev/null || return 1
    exitCode=$?
  elif [ -n "$GITCOMMIT_MESSAGE_LONG" ]; then
    GITCOMMIT_MESSAGE="$(printf '%s \n\n\n%s' "$GITCOMMIT_MESSAGE_SHORT" "$GITCOMMIT_MESSAGE_LONG")"
    printf_cyan "$GITCOMMIT_MESSAGE_SHORT"
    git -C "$GITCOMMIT_CWD" add "${*:-.}" &>/dev/null &&
      git -C "$GITCOMMIT_CWD" commit -q -S -m "$GITCOMMIT_MESSAGE" &>/dev/null || return 1
    exitCode=$?
  else
    git -C "$GITCOMMIT_CWD" add "${*:-.}" &>/dev/null &&
      git -C "$GITCOMMIT_CWD" commit -q -S -m "$GITCOMMIT_MESSAGE" "${*}" &>/dev/null || return 1
    exitCode=$?
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__commit_custom() {
  local git_repo="" git_failed="" git_succes="" git_repo_clean=""
  export PUSH_ENABLE="true"
  GITCOMMIT_MESSAGE_SHORT="$GITCOMMIT_MESSAGE"
  [ "$FORCE_PUSH" ] && ARGS="-f"
  if __git_check_cherry; then
    printf_yellow "😿 No changes to commit 😿"
    exitCode=0
  else
    printf_cyan "👊 Committing Changes with the following message: 👊"
    printf_yellow "${GITCOMMIT_MESSAGE_SHORT:-$GITCOMMIT_MESSAGE}"
    __write_version
    __gitmessage "$GITCOMMIT_MESSAGE_SHORT"
    __commit_custom_cmd "$@"
    if [ -f "$GITCOMMIT_CWD/$GITCOMMIT_CHANGELOG_FILE_NAME" ]; then
      GITCOMMIT_AMEND="true" __gitcommit_cmd
    fi
    exitCode=$?
  fi
  if [ "$exitCode" = 0 ]; then
    if [ ! -f "$GITCOMMIT_CWD/.no_push" ] && __git_check_push; then
      git_repo="$(__git_remote_fetch "$GITCOMMIT_CWD")"
      git_failed="Failed to push the changes to $git_repo"
      git_succes="Successfully pushed the changes for commit ID:"
      git_repo_clean="$(echo "$git_repo" | __sanitize_url)"
      printf_green "📍 Pushing the changes to $git_repo_clean 📍"
      git -C "$GITCOMMIT_CWD" push $ARGS -q &>/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
      __getexitcode $GITCOMMIT_EXITCODE "㊗️ $git_succes $(__git_commitid "$GITCOMMIT_CWD") ㊗️" "😿 $git_failed 😿"
    fi
  else
    printf_exit "😿 Failed to commit the changes 😿"
  fi
  exit "${exitCode:-$?}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__write_version() {
  [ "$1" = "--force" ] && shift 1 || [ -f "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE" ] || return 1
  set_new_version="$(date +"$GITCOMMIT_VERSION_FORMAT")"
  printf '%s\n' "$set_new_version" >"$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE"
  get_new_version="$(<"$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE")"
  [ "$set_new_version" = "$get_new_version" ] &&
    new_version="$get_new_version" || printf_exit "Something went wrong while setting ther version"
  [ -n "$GITCOMMIT_MESSAGE" ] || GITCOMMIT_MESSAGE="🚀 Version Bump: $new_version 🚀 "
  [ -n "$GITCOMMIT_MESSAGE" ] || printf_blue "$GITCOMMIT_MESSAGE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__set_version() {
  local GITCOMMIT_EXITCODE="" git_dir="" git_succes="" git_failed=""
  if [ "$1" = "--force" ] || [ -f "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE" ]; then
    GITCOMMIT_EXITCODE=0
    git_dir="$GITCOMMIT_CWD"
    git_succes="Successfully committed the new version to"
    git_failed="Failed to commit the version change in"
    __write_version "$1" || printf_exit "Version files doesn't exist"
    git -C "$GITCOMMIT_CWD" add "$GITCOMMIT_VERSION_FILE" &>/dev/null &&
      git -C "$GITCOMMIT_CWD" commit -m "$GITCOMMIT_MESSAGE" &>/dev/null &&
      GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
    __getexitcode $GITCOMMIT_EXITCODE "🔗 $git_succes $(__git_repobase "$git_dir")🔗 " "🚫 $git_failed ${git_dir//$PWD/.} 🚫"
  fi
  export NO_MESSAGE=true PUSH_ENABLE=true
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__rename_branch() {
  local fromBranch="" toBranch="" USER="" REPO=""
  fromBranch="$1" && shift 1
  toBranch="$1" && shift 1
  if [ $# -eq 1 ] && echo "$1" | grep -q '/'; then
    USER_REPO="$1"
  elif echo "$*" | grep -q ' '; then
    USER_REPO="$2/$3"
  else
    USER_REPO="$(basename "$(dirname "$GITCOMMIT_CWD")")/$(basename "$GITCOMMIT_CWD")"
  fi
  echo $USER_REPO | awk -F'/' '{print $2}' | grep -q '^' || printf_exit "Usage:"
  changelog_message="Renamed branch from $fromBranch to $toBranch"
  printf_blue "Changing git $fromBranch to $toBranch on $USER_REPO"
  git -C "$GITCOMMIT_CWD" branch -m $fromBranch "$toBranch" &>/dev/null
  git -C "$GITCOMMIT_CWD" push -u origin "$toBranch" -fq &>/dev/null
  if curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER_$REPO" \
    -d '{"default_branch":"'$toBranch'"}' | grep -q '"default_branch": "'$fromBranch'"' &>/dev/null; then
    git -C "$GITCOMMIT_CWD" push --delete origin $fromBranch -fq &>/dev/null
    printf_green "Changed the default branch on github.com/$USER_$REPO"
  fi &&
    printf_green "Successfully renamed the default branch" ||
    printf_exit 1 1 "Failed to rename the default branch"
  git config --global init.defaultBranch "$toBranch" &>/dev/null
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_branch() {
  local branch="" USER="" REPO="" GITCOMMIT_EXITCODE=""
  branch="$1"
  if [ $# -eq 1 ] && echo "$1" | grep -q '/'; then
    USER_REPO="$1"
  elif echo "$*" | grep -q ' '; then
    USER_REPO="$2/$3"
  else
    USER_REPO="$(basename "$(dirname "$GITCOMMIT_CWD")")/$(basename "$GITCOMMIT_CWD")"
  fi
  echo $USER_REPO | awk -F'/' '{print $2}' | grep -q '^' || printf_exit "Usage:"
  GITCOMMIT_EXITCODE=0
  printf_exit "$USER"/"$REPO"
  curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER_REPO" \
    -d '{"default_branch":"'$branch'"}' &>/dev/null || GITCOMMIT_EXITCODE=1
  return $GITCOMMIT_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__search() {
  [ -n "$1" ] || printf_exit "Usage: $APPNAME search [query] [optionalPath]"
  printf '\r%b ' "${YELLOW}Searching for $1${NC}"
  results="$(git grep -w -p --cached "$1" $2 | grep '^')"
  printf '\n'
  [ -n "$results" ] && printf_blue "$results" || printf_exit "Your search provided not results"
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_random_message() {
  local random_message="$(curl -q -LSsf --max-time 3 "$GITCOMMIT_RANDOM_API_URL" 2>/dev/null || curl -q -LSsf --max-time 3 "$GITCOMMIT_RANDOM_API_BAK_URL" 2>/dev/null || false)"
  if [ -n "$random_message" ]; then
    echo "$random_message"
  else
    echo "Well I did things"
  fi
  return 0
}
