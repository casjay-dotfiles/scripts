  __gitcommit "$mess"
  ;;

bug | bugs)
  shift 1
  ARGS="${*:-} "
  mess="🐛🦈🏠❗ Bug Fixes ${ARGS}❗🏠🦈🐛 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

alot | fixes)
  shift 1
  ARGS="${*:-} "
  mess="🦈🏠🐜❗ Fixes and Updates ${ARGS}❗🐜🦈🏠 "
