# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -s "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$GITCOMMIT_REQUIRE_SUDO" = "yes" ] && [ -z "$GITCOMMIT_REQUIRE_SUDO_RUN" ]; then
    export GITCOMMIT_REQUIRE_SUDO="no"
    export GITCOMMIT_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "$(basename "$SUDO" 2>/dev/null)" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%b\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-0}
  [ -f "$GITCOMMIT_TEMP_FILE" ] && rm -Rf "$GITCOMMIT_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__sanitize_url() { sed 's|://*.*:|://|g'; }
__emj_check() { sed 's/\xf0\x9f/\r&/g; s/\s*\r.//g'; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_push() {
  [ -f "$GITCOMMIT_CWD/.no_push" ] && printf_yellow "㊗️ Push is disabled for $GITCOMMIT_CWD ㊗️ " && exit 0
  __git_push "$@" && export PUSH_ENABLE="" && export GITCOMMIT_PUSH="TRUE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tag_release() {
  local release="" message="" eCode=""
  release="${1:-$(date +'%Y.%m')}"
  message="${2:-🚀🌟 Updated to version $release 🚀🌟}"
  eCode="1"
  [ -n "$release" ] || printf_exit "Usage: $APPNAME release [version] [message]"
  git -C "$GITCOMMIT_CWD" tag "$release" -a -m "$message" &&
    git -C "$GITCOMMIT_CWD" push origin "$release" && eCode=0
  if [ "$eCode" = 0 ]; then
    printf_green "Successfully created new tag"
  else
    printf_red "Failed to create tag"
  fi
  return $eCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tar_release() {
  local release="" backup_dir="" eCode=""
  release="${1:-$(date +'%Y.%m.%d')}"
  backup_dir="$HOME/.local/backups/$APPNAME"
  eCode="1"
  [ -d "$backup_dir" ] || mkdir -p "$backup_dir"
  printf_cyan "Creating backup from $GITCOMMIT_CWD to $backup_dir/$release.tar.gz "
  tar -cvf "$backup_dir/$release.tar.gz" "$GITCOMMIT_CWD" && eCode=0
  if [ "$eCode" = 0 ]; then
    printf_green "Successfully created tar file"
  else
    printf_red "Failed to create archive"
  fi
  return $eCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# TODO: Turn this into a seperate script
__changelog_create() {
  __cmd_exists gen-changelog || return 0
  local get_changed_files="$1"
  set_commit_mess="${GITCOMMIT_MESSAGE_SHORT:-$GITCOMMIT_MESSAGE_FULL}"
  git_commit_mess="${set_commit_mess:-$changelog_message}"
  changed_files="${set_changed_files:-changed_files}"
  changed_files="${changed_files:-$(__changed_files "$get_changed_files")}"
  changed_icon="${icon:-$GITCOMMIT_CHANGELOG_ICON}"
  gen-changelog --silent --message "$git_commit_mess" --files "$changed_files" --icon "$changed_icon"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitmessage() {
  [ "$git_message_processed" = "true" ] && return
  local test_long_message="" test_short_message="" test_full_message=""
  local set_full_message="$GITCOMMIT_MESSAGE_FULL"
  local set_long_message="${fullcommit_message:-$GITCOMMIT_MESSAGE_LONG}"
  local set_short_message="${*:-${git_message:-$GITCOMMIT_MESSAGE_SHORT}}"
  local set_commitfile="${GITADMIN_DEFAULT_COMMIT_FILE:-$GITCOMMIT_CWD/.git/COMMIT_MESS}"
  test_full_message="$(echo "$set_full_message" | grep -v '^$' | head -n1 | grep '^' || false)"
  test_long_message="$(echo "$set_long_message" | grep -v '^$' | head -n1 | grep '^' || false)"
  test_short_message="$(echo "$set_short_message" | grep -v '^$' | head -n1 | grep '^' || false)"
  if [ -n "$test_full_message" ]; then
    nomessage="true"
    test_long_message="yes"
    set_full_message="$(printf '%s\n' "$set_full_message")"
    set_short_message="$(printf '%s\n' "${set_full_message:0:69}" | grep -v '^$' | head -n1)"
    GITCOMMIT_MESSAGE_FULL="$(printf '%s\n' "$set_full_message")"
    printf '\n%s\n\n' "$set_full_message" | sed 's|^||g' >"$set_commitfile"
  elif [ ${#set_short_message} -ge 75 ]; then
    nomessage="true"
    set_short_message="...${set_short_message:0:69}..."
    printf '%s\n' "${set_short_message}" | sed 's|^||g' >"$set_commitfile"
  else
    nomessage="true"
    printf '%s\n' "$set_short_message" | sed 's|^||g' >"$set_commitfile"
  fi
  if [ -n "$test_long_message" ]; then
    set_long_message="$(printf '%b\n' "$set_long_message")"
    GITCOMMIT_MESSAGE_FULL="$(printf '%s \n\n\n%s' "$set_short_message" "$set_long_message")"
    printf '%s \n\n\n%s' "$set_short_message" "$set_long_message" | sed 's|^||g' >"$set_commitfile"
  fi
  [ "$set_long_message" = "$set_short_message" ] && unset set_long_message
  [ -n "$set_long_message" ] && GITCOMMIT_MESSAGE_LONG="$set_long_message"
  [ -n "$set_short_message" ] && GITCOMMIT_MESSAGE_SHORT="$set_short_message"
  [ -n "$GITCOMMIT_MESSAGE_FULL" ] || GITCOMMIT_MESSAGE_FULL="$(<"$set_commitfile")"
  unset set_short_message set_long_message set_full_message
  unset test_short_message test_long_message test_full_message
  export GITCOMMIT_MESSAGE_FULL GITCOMMIT_MESSAGE_SHORT GITCOMMIT_MESSAGE_LONG
  export nomessage message_set="TRUE" git_message_processed="true" GITADMIN_DEFAULT_COMMIT_FILE="$set_commitfile"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitcommit_cmd() {
  local git_amend="$GITCOMMIT_AMEND"
  local changelog_file="$GITCOMMIT_CWD/${GITCOMMIT_CHANGELOG_FILE_NAME:-CHANGELOG.md}"
  if [ -f "$changelog_file" ] && [ "$git_amend" = "true" ]; then
    git -C "$GITCOMMIT_CWD" commit --untracked=no -q -S --amend --no-edit &>"$GITCOMMIT_TEMP_FILE" || return 1
  elif [ -s "$GITADMIN_DEFAULT_COMMIT_FILE" ]; then
    git -C "$GITCOMMIT_CWD" commit -q -S -m "$(<"$GITADMIN_DEFAULT_COMMIT_FILE")" &>"$GITCOMMIT_TEMP_FILE" || return 1
  else
    git -C "$GITCOMMIT_CWD" commit -q -S -m "$GITCOMMIT_MESSAGE_FULL" &>"$GITCOMMIT_TEMP_FILE"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitcommit() {
  __git_porcelain "$GITCOMMIT_CWD" &>/dev/null && return
  local mess="${*:-${git_message:-$GITCOMMIT_MESSAGE_SHORT}}"
  local succ="Successfully committed the changes to"
  local fail="Failed to commit the changes to"
  local column_length=$(($(tput cols) - 20))
  local removemess="${mess:10:30}"
  local add_changelog_to_commit=""
  [ -n "$message_set" ] || __gitmessage "$mess"
  [ -n "$message_set" ] && [ -s "$GITADMIN_DEFAULT_COMMIT_FILE" ] || printf_return "The commit message is empty"
  [ -n "$nomessage" ] || show_message="$(grep -svE "$removemess" "$GITADMIN_DEFAULT_COMMIT_FILE" | grep -v '^$' | tr '\n' ' ' | grep '^')"
  printf_cyan "👊 Committing Changes with the following message: 👊"
  printf_yellow "$mess"
  [ -n "$show_message" ] && [ "$show_message" != "$mess" ] && printf_blue "${show_message:0:$column_length}"
  if __gitcommit_cmd; then
    if [ "$NO_MESSAGE" != "true" ]; then
      if __getexitcode "${GITCOMMIT_EXITCODE:-$?}" "🔗 $succ $(__git_repobase "$GITCOMMIT_CWD") 🔗" "🚫 $fail $(__git_repobase "$GITCOMMIT_CWD") 🚫"; then
        printf_green "🆔 Commit ID: $(__git_commitid "$GITCOMMIT_CWD") 🆔"
        COMMIT_ID="$(__git_commitid "$GITCOMMIT_CWD")"
      fi
    fi
  else
    printf_readline "5" <"$GITCOMMIT_TEMP_FILE"
    printf_exit "Failed to commit the changes"
  fi
  add_changelog_to_commit="$(__changed_files changelog | grep '^' || echo '')"
  if [ -n "$add_changelog_to_commit" ]; then
    git -C "$GITCOMMIT_CWD" add "CHANGELOG.md" &>/dev/null && git -C "$GITCOMMIT_CWD" commit --amend --no-edit &>/dev/null
  fi
  [ -f "$GITADMIN_DEFAULT_COMMIT_FILE" ] && rm -Rf "$GITADMIN_DEFAULT_COMMIT_FILE"
  export GITCOMMIT_RAN="true" GITADMIN_NO_ERROR_MESSAGE="true"
  set +x
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_init() {
  local exitCode=""
  is_url "$1" && REPO="$1" && shift 1
  message="$*"
  icon="${set_icon:-📂}"
  action="${set_action:-📂}"
  timem="$(date +'%H:%M')"
  datem="$(date +'%Y-%m-%d')"
  initm="New repo created on $datem at $timem"
  message="%{setmess:-$(printf '%b\n' "$initm")}"
  setmess="$(printf '%b\n' "$action $message $icon")"
  fullcommit_message="%{fullcommit_message:-$(printf '%b\n' "$setmess\n\n$message\n")}"
  export PUSH_ENABLE
  __gitmessage "$setmess"
  __gitignore_init "$GITCOMMIT_CWD" &>/dev/null
  gitadmin --dir "$GITCOMMIT_CWD" setup "${REPO:-}" --message="$setmess" && exitCode=0 || exitCode=1
  exit ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__changed_files() {
  local files=""
  while :; do
    case $1 in
    message)
      shift
      git -C "$GITCOMMIT_CWD" status -b -s | grep -v '^$' | sed '/^\#/d;s,^ ,,g;s,??,A,g' | tr '\n' ' | ' | sed 's# | $# #g' | sed 's|  | |g' | grep -v '^CHANGELOG.md' | grep '^' || return 1
      ;;
    added)
      shift
      git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -Ew ^'\?\?|A|AA' | awk '{print $2}' | sort -u | grep -v '^$' | grep -v '^CHANGELOG.md' | grep '^' || return 1
      ;;
    renamed)
      shift
      git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -Ew ^'R|RM| R' | awk '{print $2}' | sort -u | grep -v '^$' | grep -v '^CHANGELOG.md' | grep '^' || return 1
      ;;
    modified)
      shift
      git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -Ew ^'M|MM| M' | awk '{print $2}' | sort -u | grep -v '^$' | grep -v '^CHANGELOG.md' | grep '^' || return 1
      ;;
    deleted)
      shift
      git -C "$GITCOMMIT_CWD" status -s 2>/dev/null | grep -E ^'[M, ]D|DD' | awk '{print $2}' | sort -u | grep -v '^$' | grep -v '^CHANGELOG.md' | grep '^' || return 1
      ;;
    changelog)
      shift
      files+="$(__changed_files added | grep '^CHANGELOG.md') "
      files+="$(__changed_files modified | grep '^CHANGELOG.md') "
      files+="$(__changed_files deleted | grep '^CHANGELOG.md') "
      files+="$(__changed_files renamed | grep '^CHANGELOG.md') "
      results="$(printf '%b\n' "$files" | tr ' ' '\n' | sort -u | grep -v '^$' | grep '^')"
      [ -n "$results" ] && echo "$results"
      ;;
    all)
      shift 1
      files+="$(__changed_files added) "
      files+="$(__changed_files modified) "
      files+="$(__changed_files deleted) "
      files+="$(__changed_files renamed) "
      printf '%b\n' "$files" | tr ' ' '\n' | sort -u | grep -v '^$' | grep '^'
      ;;
    *)
      break
      ;;
    esac
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__default_git_action() {
  local modified added deleted message
  if [ "$1" = "--add-all-files" ]; then
    shift 1
    message="$(printf '%b\n' "$*")"
    __git_all "$message"
  else
    message="$(printf '%b\n' "$*")"
    added="$(__changed_files added)"
    deleted="$(__changed_files deleted)"
    renamed="$(__changed_files renamed)"
    modified="$(__changed_files modified)"
    [ -n "$added" ] && for a in $added; do __git_add "$message"; done
    [ -n "$modified" ] && for m in $modified; do __git_mod "$message"; done
    [ -n "$deleted" ] && for d in $deleted; do __git_del "$message"; done
    [ -n "$renamed" ] && for r in $renamed; do __git_mod "$message"; done
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_updated() {
  local message="$*"
  append_changelog_message="$message"
  prepend="${prepend_name:-$prepend}"
  changelog_message="${changelog_message:-${prepend:-Updated}}"
  changed_files="$(__changed_files modified)"
  __git_add "$(printf '%b\n' "$message")"
  __git_mod "$(printf '%b\n' "$message")"
  unset prepend
  export GITADMIN_NO_ERROR="${GITADMIN_NO_ERROR:-true}"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_all() {
  local message="$*"
  local icon="${set_icon:-🗃}"
  local action="${set_action:-🗃}"
  local prepend="${prepend_name:-}"
  local local_set_mess="$(printf '%b\n' "$message")"
  changed_files="${changed_files:-$(__changed_files all)}"
  if [ -z "$changed_files" ] || [ "$GITADMIN_NO_ERROR" != "true" ]; then
    [ "$GITADMIN_NO_ERROR_MESSAGE" = "true" ] || printf_return "🙁 No files have changed in $GITCOMMIT_CWD 🙁"
    export GITADMIN_NO_ERROR_MESSAGE="true"
    return 1
  fi
  [ -n "$local_set_mess" ] || local_set_mess="$prepend"
  changelog_message="$prepend"
  set_changed_files="$changed_files"
  append_changelog_message="$local_set_mess"
  setmess="$(printf '%b\n' "$action $prepend $icon")"
  fullcommit_message="${fullcommit_message:-$set_changed_files}"
  __gitmessage "$setmess"
  __changelog_create
  git -C "$GITCOMMIT_CWD" add . &>/dev/null
  __gitcommit "$setmess" && export PUSH_ENABLE=true || exitCode+="1"
  unset changed_files prepend
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_mod() {
  local message="$*"
  local icon="${set_icon:-🗃}"
  local action="${set_action:-🗃}"
  local prepend="${prepend_name:-Modified}"
  local local_set_mess="$(printf '%b\n' "$message")"
  changed_files="${changed_files:-$(__changed_files all)}"
  if [ -z "$changed_files" ] || [ "$GITADMIN_NO_ERROR" != "true" ]; then
    [ "$GITADMIN_NO_ERROR_MESSAGE" = "true" ] || printf_return "🙁 No files have changed in $GITCOMMIT_CWD 🙁"
    export GITADMIN_NO_ERROR_MESSAGE="true"
    return 1
  fi
  for f in $changed_files; do
    set_changed_files="$f"
    changelog_message="$prepend"
    [ -n "$local_set_mess" ] || local_set_mess="$prepend $f"
    setmess="$(printf '%b\n' "$action $local_set_mess $icon")"
    fullcommit_message="$(printf '%b\n' "$action $prepend $f $icon" | sed "s|$f.*.$f|$f|g")"
    append_changelog_message="$setmess"
    __gitmessage "$setmess"
    __changelog_create
    git -C "$GITCOMMIT_CWD" add "$f" &>/dev/null
    __gitcommit "$setmess" && export PUSH_ENABLE="true" || exitCode+="1"
  done
  unset changed_files prepend
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_add() {
  local message="$*"
  local icon="${set_icon:-❓}"
  local action="${set_action:-❓}"
  local prepend="${prepend_name:-Added}"
  local local_set_mess="$(printf '%b\n' "$message")"
  changed_files="${changed_files:-$(__changed_files all)}"
  if [ -z "$changed_files" ] || [ "$GITADMIN_NO_ERROR" != "true" ]; then
    [ "$GITADMIN_NO_ERROR_MESSAGE" = "true" ] || printf_return "🙁 No files have been added in $GITCOMMIT_CWD 🙁"
    export GITADMIN_NO_ERROR_MESSAGE="true"
    return 1
  fi
  for f in $changed_files; do
    set_changed_files="$f"
    [ -n "$local_set_mess" ] || local_set_mess="$prepend $f"
    setmess="$(printf '%b\n' "$action $local_set_mess $icon")"
    fullcommit_message="$(printf '%b\n' "$action $prepend $f $icon" | sed "s|$f.*.$f|$f|g")"
    __gitmessage "$setmess"
    __changelog_create
    git -C "$GITCOMMIT_CWD" add "$f" &>/dev/null
    __gitcommit "$setmess" || exitCode+="1"
  done
  unset changed_files prepend
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_del() {
  local message="$*"
  local icon="${set_icon:-➖}"
  local action="${set_action:-➖}"
  local prepend="${prepend_name:-Committing}"
  local local_set_mess="$(printf '%b\n' "$message")"
  changed_files="${changed_files:-$(__changed_files all)}"
  if [ -z "$changed_files" ] || [ "$GITADMIN_NO_ERROR" != "true" ]; then
    [ "$GITADMIN_NO_ERROR_MESSAGE" = "true" ] || printf_return "🙁 No files have been deleted in $GITCOMMIT_CWD 🙁"
    export GITADMIN_NO_ERROR_MESSAGE="true"
    return 1
  fi
  for f in $changed_files; do
    set_changed_files="$f"
    [ -n "$local_set_mess" ] || local_set_mess="$prepend $f"
    setmess="$(printf '%b\n' "$action $local_set_mess $icon")"
    fullcommit_message="$(printf '%b\n' "$action $prepend $f $icon" | sed "s|$f.*.$f|$f|g")"
    __gitmessage "$setmess"
    __changelog_create
    git -C "$GITCOMMIT_CWD" add "$f" &>/dev/null
    __gitcommit "$setmess" || exitCode+="1"
  done
  unset changed_files prepend
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_renamed() {
  local file_from="$1" && shift 1
  local file_move="$1" && shift 1
  local message="$*"
  local icon="${set_icon:-✔️}"
  local action="${set_action:-✔️}"
  local prepend="${prepend_name:-Renamed}:"
  local local_set_mess="$(printf '%b\n' "$message")"
  local create_dir="$(dirname "$(realpath "$file_move")")"
  [ -n "" ] && [ -n "" ] || return 1
  [ -d "$create_dir" ] || mkdir -p "$(dirname "$create_dir")"
  [ -e "$file_move" ] && mv -f "$file_from" "$file_move" &>/dev/null
  [ -n "$local_set_mess" ] || local_set_mess="$prepend $file_from ➡ $file_move"
  setmess="$(printf '%b\n' "$action $local_set_mess $icon")"
  fullcommit_message="$(printf '%b\n' "$action $prepend $file_from ➡ $file_move $icon" | sed "s|$f.*.$f|$f|g")"
  __gitmessage "$setmess"
  __changelog_create
  git -C "$GITCOMMIT_CWD" rm "$file_from" -rf &>/dev/null
  git -C "$GITCOMMIT_CWD" add "$file_move" &>/dev/null && __gitcommit "$setmess" && export PUSH_ENABLE=true
  unset prepend
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__files() {
  local message="$*"
  local icon="${set_icon:-➖}"
  local action="${set_action:-➖}"
  local local_set_mess="$(printf '%b\n' "$message")"
  local added_files="$(__changed_files added)"
  local deleted_files="$(__changed_files deleted)"
  local all_files="$(printf '%s\n%s\n' "$added_files" "$deleted_files" | grep -v '^$' | grep '^')"
  setmess="$(printf '%b\n' "$action $local_set_mess $icon")"
  fullcommit_message="$(printf '%b\n' "$all_files")"
  __gitmessage "$setmess"
  [ -n "$added_files" ] && git -C "$GITCOMMIT_CWD" add $added_files &>/dev/null || added_files=""
  [ -n "$deleted_files" ] && git -C "$GITCOMMIT_CWD" rm $deleted_files &>/dev/null || deleted_files=""
  { [ -n "$added_files" ] || [ -n "$deleted_files" ]; } && __gitcommit "$setmess" && export PUSH_ENABLE="true"
  unset prepend
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitignore_init() {
  [ -e "${1:-$GITCOMMIT_CWD}/.gitignore" ] && return
  [ -d "${1:-$GITCOMMIT_CWD}/node_modules" ] &&
    gitignore "${1:-$GITCOMMIT_CWD}" dirignore default node ||
    gitignore "${1:-$GITCOMMIT_CWD}" dirignore default
  printf '# ignore commit message\n.gitcommit\n' >>"$GITCOMMIT_CWD/.gitignore"
  if [ -d "${1:-$GITCOMMIT_CWD}/.git" ]; then
    git -C "${1:-$GITCOMMIT_CWD}" add .gitignore &>/dev/null
    git -C "${1:-$GITCOMMIT_CWD}" commit -q -S -m "🤖 Added .gitignore 🤖" ".gitignore" || return 1
  fi
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__test_gitignore() {
  if ! grep -sq '.gitcommit' "${1:-$GITCOMMIT_CWD}/.gitignore"; then
    printf '# ignore commit message\n.gitcommit\n' >>"$GITCOMMIT_CWD/.gitignore"
    git -C "${1:-$GITCOMMIT_CWD}" add .gitignore &>/dev/null
    git -C "${1:-$GITCOMMIT_CWD}" commit -q -S -m "🤖 Added .gitcommit 🤖" ".gitignore" || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_dir() {
  local git_dir="" makerepo=""
  git_dir="${1:-$GITCOMMIT_CWD}"
  makerepo=""
  if [ "$(git -C "$git_dir" rev-parse --is-inside-work-tree 2>/dev/null)" == "" ]; then
    printf_error "You are not in a git repo"
    printf_read_question "4" "Would you like to turn $git_dir into a git repo? y/N" "1" "makerepo"
    if printf_answer_yes "$makerepo"; then
      __gitignore_init "$git_dir"
      gitadmin --dir "$git_dir" setup
      exit $?
    else
      exit
    fi
  fi
  [ -d "$git_dir" ] || printf_exit "$git_dir doesn't seem to be a directory"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_commitid() {
  echo -n "$(git -C "${1:-$GITCOMMIT_CWD}" rev-parse --short HEAD)"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_check_cherry() {
  git -C "$GITCOMMIT_CWD" cherry -v 2>&1 | wc -l | grep -q '0' && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_check_ahead() {
  git -C "$GITCOMMIT_CWD" log --oneline origin..HEAD 2>&1 | wc -l | grep -q '0' && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_check_branch() {
  git -C "$GITCOMMIT_CWD" branch -avvv 2>&1 | grep -q ': ahead ' && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_check_push() {
  local exitCode=""
  if [ "$(git -C "$GITCOMMIT_CWD" diff --stat origin/main 2>/dev/null | wc -l)" -ne 0 ]; then
    exitCode=0
  elif __git_check_ahead; then
    exitCode=0
  else
    exitCode=1
  fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_push_check() {
  if __git_check_push; then
    return 0
  elif __git_check_cherry; then
    return 0
  elif __git_check_ahead; then
    return 0
  elif __git_check_branch; then
    return 0
  elif git s | grep -v '## ' | grep -q '^'; then
    return 0
  elif [ -n "$GITCOMMIT_RAN" ]; then
    return 0
  elif [ "$PUSH_ENABLE" = "true" ]; then
    return 0
  elif [ -n "$FORCE_PUSH" ]; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_custom_pull() {
  [ -d "${1:-GITCOMMIT_CWD}/.git" ] && gitadmin --dir "${1:-GITCOMMIT_CWD}" pull 2>/dev/null
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_custom_push() {
  [ -d "${1:-GITCOMMIT_CWD}/.git" ] && gitadmin --dir "${1:-GITCOMMIT_CWD}" push 2>/dev/null
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_push() {
  local GITCOMMIT_EXITCODE=0 git_dir="" git_repo="" git_remote=""
  local git_failed="" git_succes="" git_push="" git_repo_clean=""
  git_dir="${1:-$GITCOMMIT_CWD}"
  errorlog="$GITCOMMIT_ERROR_LOG"
  git_icon_succes="㊗️ "
  git_icon_failed="😿 "
  git_repo="$(__git_remote_fetch "$GITCOMMIT_CWD" || echo "$REMOTE_REPO")"
  git_repo_clean="$(echo "$git_repo" | __sanitize_url)"
  git_failed="Failed to push the changes to $git_repo:"
  git_succes="Successfully pushed the changes for commit ID:"
  git_remote="$(git -C "$GITCOMMIT_CWD" remote show | grep '^' || false)"
  if __git_push_check; then
    [ -n "$git_remote" ] || return 0
    [ -f "$git_dir/.nopush" ] && return
    am_i_online --error -m "🚫 No internet connection. Skipping push 🚫" || exit 1
    if [ "$git_repo" != "localdir" ]; then
      if [ -n "$FORCE_PUSH" ]; then
        printf_green "🔼 Pushing the changes to $git_repo_clean 🔼"
        git -C "$git_dir" push -f -q 2>"$GITCOMMIT_ERROR_LOG" >/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
        __getexitcode $GITCOMMIT_EXITCODE "$git_icon_succes$git_succes $(__git_commitid "$git_dir")$git_icon_succes" "$git_icon_failed$git_failed $(<"$errorlog") $git_icon_failed"
      elif [[ "$*" =~ --automated ]] || [[ "$*" =~ --force ]]; then
        printf_green "🔼 Pushing the changes to $git_repo_clean 🔼"
        git -C "$git_dir" push -q 2>"$GITCOMMIT_ERROR_LOG" >/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
        __getexitcode $GITCOMMIT_EXITCODE "$git_icon_succes$git_succes $(__git_commitid "$git_dir")$git_icon_succes" "$git_icon_failed$git_failed $(<"$errorlog") $git_icon_failed"
      else
        if [ "$GITCOMMIT_NO_CONFIRM" != "true" ]; then
          printf_read_question "3" "Should I push to $git_repo_clean? [y/n]" "1" "git_push"
        else
          git_push="Y"
        fi
        if printf_answer_yes "$git_push"; then
          printf_green "📍 Pushing the changes to $git_repo_clean 📍"
          git -C "$git_dir" push -q 2>"$GITCOMMIT_ERROR_LOG" >/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
          __getexitcode $GITCOMMIT_EXITCODE "$git_icon_succes$git_succes $(__git_commitid "$git_dir") $git_icon_succes" "$git_icon_failed $git_failed $git_icon_failed"
        fi
      fi
    else
      printf_red "⚠️ Doesn't seem to have a remote setup ⚠️"
      GITCOMMIT_EXITCODE=0
    fi
  else
    printf_red "🛠 No changes to push in $GITCOMMIT_CWD 🛠"
    GITCOMMIT_EXITCODE=1
  fi
  return $GITCOMMIT_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__commit_custom_cmd() {
  if [ "$1" = "update_version" ]; then
    shift 1
    version_update="update_version"
    version_file="${1:-$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE}"
  else
    op="${*:-.}"
  fi
  if [ "$version_update" = "update_version" ]; then
    git -C "$GITCOMMIT_CWD" add "$version_file" &&
      git -C "$GITCOMMIT_CWD" commit -q -S -m "$GITCOMMIT_MESSAGE_FULL" "$version_file" &>/dev/null && return 0 || return 1
  elif [ -n "$GITCOMMIT_MESSAGE_LONG" ]; then
    git -C "$GITCOMMIT_CWD" add $op &>/dev/null &&
      git -C "$GITCOMMIT_CWD" commit -q -S -m "$GITCOMMIT_MESSAGE_FULL" &>/dev/null && return 0 || return 1
  else
    git -C "$GITCOMMIT_CWD" add $op &>/dev/null &&
      git -C "$GITCOMMIT_CWD" commit -q -S -m "$GITCOMMIT_MESSAGE_FULL" &>/dev/null && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__commit_custom() {
  local git_repo=""
  local git_failed=""
  local git_succes=""
  local git_repo_clean=""
  local icon="${set_icon:-🗃️}"
  local action="${set_action:-🗃️}"
  local prepend="${prepend_name:-All}"
  local message="${git_message:-Committing everything that changed}"
  local local_set_mess="$(printf '%b\n' "$message")"
  changed_files="${changed_files:-$(__changed_files all)}"
  if [ -z "$changed_files" ] || [ "$GITADMIN_NO_ERROR" != "true" ]; then
    [ "$GITADMIN_NO_ERROR_MESSAGE" = "true" ] || printf_return "🙁 No files have changed in $GITCOMMIT_CWD 🙁"
    export GITADMIN_NO_ERROR_MESSAGE="true"
    return 1
  fi
  [ "$FORCE_PUSH" ] && ARGS="-f"
  [ -n "$local_set_mess" ] || local_set_mess="$prepend"
  changelog_message="$prepend"
  set_changed_files="$changed_files"
  append_changelog_message="$local_set_mess"
  setmess="$(printf '%b\n' "$action $local_set_mess $icon")"
  fullcommit_message="${fullcommit_message:-$set_changed_files}"
  __gitmessage "$setmess"
  __changelog_create
  printf_cyan "👊 Committing Changes with the following message: 👊"
  printf_yellow "$GITCOMMIT_MESSAGE_SHORT"
  __commit_custom_cmd "$@"
  exitCode=$?
  if [ "$exitCode" = 0 ]; then
    export PUSH_ENABLE=true
    if [ -f "$GITCOMMIT_CWD/$GITCOMMIT_CHANGELOG_FILE_NAME" ]; then
      GITCOMMIT_AMEND="true" __gitcommit_cmd
    fi
    if [ ! -f "$GITCOMMIT_CWD/.no_push" ] && __git_check_push; then
      git_repo="$(__git_remote_fetch "$GITCOMMIT_CWD")"
      git_failed="Failed to push the changes to $git_repo"
      git_succes="Successfully pushed the changes for commit ID:"
      git_repo_clean="$(echo "$git_repo" | __sanitize_url)"
      printf_green "📍 Pushing the changes to $git_repo_clean 📍"
      git -C "$GITCOMMIT_CWD" push $ARGS -q &>/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
      __getexitcode $GITCOMMIT_EXITCODE "㊗️ $git_succes $(__git_commitid "$GITCOMMIT_CWD") ㊗️" "😿 $git_failed 😿"
    fi
  else
    printf_exit "😿 Failed to commit the changes 😿"
  fi
  unset changed_files prepend
  exit "${exitCode:-0}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__write_version() {
  local icon="${set_icon:-🚀}"
  local eicon="${set_eicon:-⚠️}"
  [ "$GITCOMMIT_NEW_VERSION" != "true" ] || return
  [ "$1" = "--force" ] && shift 1 || [ -f "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE" ] || return 1
  set_new_version="$(date +"$GITCOMMIT_VERSION_FORMAT")"
  printf '%b\n' "$set_new_version" >"$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE"
  get_new_version="$(<"$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE")"
  if [ "$set_new_version" = "$get_new_version" ]; then
    new_version="$get_new_version"
  else
    printf_exit "$eicon Something went wrong while setting the version $eicon"
  fi
  [ -n "$GITCOMMIT_MESSAGE_VERSION" ] || GITCOMMIT_MESSAGE_VERSION="$icon Version Bump: $new_version $icon"
  [ -n "$GITCOMMIT_MESSAGE_VERSION" ] || printf_blue "$GITCOMMIT_MESSAGE_VERSION"
  export GITCOMMIT_NEW_VERSION="true" GITCOMMIT_MESSAGE_VERSION
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__set_version() {
  local GITCOMMIT_EXITCODE="" git_dir="" git_succes="" git_failed=""
  if [ "$1" = "--force" ] || [ -f "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE" ]; then
    GITCOMMIT_EXITCODE=0
    git_dir="$GITCOMMIT_CWD"
    git_succes="Successfully committed the new version to"
    git_failed="Failed to commit the version change in"
    __commit_custom_cmd "update_version" "$GITCOMMIT_CWD/$GITCOMMIT_VERSION_FILE" && GITCOMMIT_EXITCODE=0 && export PUSH_ENABLE="true" || GITCOMMIT_EXITCODE=1
    __getexitcode $GITCOMMIT_EXITCODE "🔗 $git_succes $(__git_repobase "$git_dir")🔗 " "🚫 $git_failed ${git_dir//$PWD/.} 🚫"
  fi
  export NO_MESSAGE="true"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__rename_branch() {
  local fromBranch="" toBranch="" USER="" REPO=""
  fromBranch="$1" && shift 1
  toBranch="$1" && shift 1
  if [ $# -eq 1 ] && echo "$1" | grep -q '/'; then
    USER_REPO="$1"
  elif echo "$*" | grep -q ' '; then
    USER_REPO="$2/$3"
  else
    USER_REPO="$(basename "$(dirname "$GITCOMMIT_CWD")")/$(basename "$GITCOMMIT_CWD")"
  fi
  echo $USER_REPO | awk -F'/' '{print $2}' | grep -q '^' || printf_exit "Usage:"
  changelog_message="Renamed branch from $fromBranch to $toBranch"
  printf_blue "Changing git $fromBranch to $toBranch on $USER_REPO"
  git -C "$GITCOMMIT_CWD" branch -m $fromBranch "$toBranch" &>/dev/null
  git -C "$GITCOMMIT_CWD" push -u origin "$toBranch" -fq &>/dev/null
  if curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER_$REPO" \
    -d '{"default_branch":"'$toBranch'"}' | grep -q '"default_branch": "'$fromBranch'"' &>/dev/null; then
    git -C "$GITCOMMIT_CWD" push --delete origin $fromBranch -fq &>/dev/null
    printf_green "Changed the default branch on github.com/$USER_$REPO"
  fi &&
    printf_green "Successfully renamed the default branch" ||
    printf_exit 1 1 "Failed to rename the default branch"
  git config --global init.defaultBranch "$toBranch" &>/dev/null
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_branch() {
  local branch="" USER="" REPO="" GITCOMMIT_EXITCODE=""
  branch="$1"
  if [ $# -eq 1 ] && echo "$1" | grep -q '/'; then
    USER_REPO="$1"
  elif echo "$*" | grep -q ' '; then
    USER_REPO="$2/$3"
  else
    USER_REPO="$(basename "$(dirname "$GITCOMMIT_CWD")")/$(basename "$GITCOMMIT_CWD")"
  fi
  echo $USER_REPO | awk -F'/' '{print $2}' | grep -q '^' || printf_exit "Usage:"
  GITCOMMIT_EXITCODE=0
  printf_exit "$USER"/"$REPO"
  curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER_REPO" \
    -d '{"default_branch":"'$branch'"}' &>/dev/null || GITCOMMIT_EXITCODE=1
  return $GITCOMMIT_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__search() {
  [ -n "$1" ] || printf_exit "Usage: $APPNAME search [query] [optionalPath]"
  printf '\r%b ' "${YELLOW}Searching for $1${NC}"
  results="$(git grep -w -p --cached "$1" $2 | grep '^')"
  printf '\n'
  [ -n "$results" ] && printf_blue "$results" || printf_exit "Your search provided not results"
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_random_message() {
  local random_message="$(curl -q -LSsf --max-time 3 "$GITCOMMIT_RANDOM_API_URL" 2>/dev/null || curl -q -LSsf --max-time 3 "$GITCOMMIT_RANDOM_API_BAK_URL" 2>/dev/null || false)"
  if [ -n "$random_message" ]; then
    echo "$random_message"
  else
    echo "Well I did things"
  fi
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_status() { git -C "${1:-.}" status -b -s 2>/dev/null && return 0 || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_log() { git -C "${1:-.}" log --pretty='%C(magenta)%h%C(red)%d %C(yellow)%ar %C(green)%s %C(yellow)(%an)' 2>/dev/null && return 0 || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_clean() { __git_status "$1" | grep -v '##' | grep -q '^' && return 1 || return 0; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_dirty() { __git_status "$1" | grep -v '##' | grep -q '^' && return 0 || return 1; }
