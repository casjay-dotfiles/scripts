# begin main app
case "$1" in
amend) #
  shift 1
  GITCOMMIT_AMEND="true"
  ;;
esac

case "$1" in
s | status) #
  shift 1
  __git_status "$GITCOMMIT_CWD"
  exit $?
  ;;

l | log) #
  shift 1
  __git_log "$GITCOMMIT_CWD"
  exit $?
  ;;

is) # repo status is? clean,dirty
  shift 1
  case "$1" in
  clean) # returns 1 if repo changed
    shift 1
    __is_clean "${1:-$GITADMIN_CWD}"
    exit $?
    ;;
  dirty) # returns 0 if repo changed
    shift 1
    __is_dirty "${1:-$GITADMIN_CWD}"
    exit $?
    ;;
  *) # same as clean
    __is_clean "${1:-$GITADMIN_CWD}"
    exit $?
    ;;
  esac
  ;;

search) #
  shift 1
  __search "$1" "$2"
  ;;

init) #
  shift 1
  set_action="🦈🏠🐜❗"
  set_icon="📍🐜🦈🏠"
  git_message="${*:-$GITCOMMIT_MESSAGE_SHORT}"
  __git_init "${git_message:-}"
  ;;

setup) #
  shift 1
  gitadmin --dir "$GITCOMMIT_CWD" setup "$@"
  exit $?
  ;;

reset) #
  shift 1
  printf_read_question "3" "Should I reset? [y/n]" "1" "git_reset"
  if printf_answer_yes "$git_reset"; then
    git -C "$GITCOMMIT_CWD" reset --hard
  else
    printf_return "Not resetting: user aborted"
  fi
  exit $?
  ;;

tag) #
  shift 1
  __tag_release "$@"
  ;;

tar) #
  shift 1
  __tar_release "$@"
  ;;

branch) #
  shift 1
  __rename_branch "${1:-master}" "${2:-main}" $3 $4
  exit $?
  ;;

pull) #
  shift 1
  __git_custom_pull "$GITCOMMIT_CWD"
  exit $?
  ;;

push) #
  shift 1
  __git_custom_push "$GITCOMMIT_CWD"
  exit $?
  ;;

version) #
  shift 1
  git_message="${*:-$GITCOMMIT_MESSAGE_SHORT}"
  changed_files="$(__changed_files all | grep '^' || echo "")"
  changelog_message="$git_message"
  append_changelog_message="$new_version"
  fullcommit_message="$changed_files"
  __changelog_create
  __write_version
  __set_version --force
  __run_push "$GITCOMMIT_CWD" --automated
  exit $?
  ;;

