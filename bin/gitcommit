# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE"
  [ -d "$GITCOMMIT_CONFIG_DIR" ] || mkdir -p "$GITCOMMIT_CONFIG_DIR"
  [ -d "$GITCOMMIT_CONFIG_BACKUP_DIR" ] || mkdir -p "$GITCOMMIT_CONFIG_BACKUP_DIR"
  [ -f "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" ] &&
    cp -Rf "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" "$GITCOMMIT_CONFIG_BACKUP_DIR/$GITCOMMIT_CONFIG_FILE.$$"
  cat <<EOF >"$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE"
# Settings for gitcommit
GITCOMMIT_MAINCONFIG=${GITCOMMIT_MAINCONFIG:-gitmainconfig}
GITCOMMIT_NO_CONFIRM="\${GITCOMMIT_NO_CONFIRM:-true}"
GITCOMMIT_PROJECT_DIR="\${GIT_PROJECT_DIR:-$HOME/Projects}"
GITCOMMIT_VERSION_FORMAT="\${VERSION_DATE_FORMAT:-%Y%m%d%H%M-git}"
GITCOMMIT_VERSION_FILE="\${GIT_VERSION_FILE:-version.txt}"

# Notification settings
GITCOMMIT_GOOD_MESSAGE="${GITCOMMIT_GOOD_MESSAGE:-Everything Went OK}"
GITCOMMIT_ERROR_MESSAGE="${GITCOMMIT_ERROR_MESSAGE:-Well that didn\'t work}"
GITCOMMIT_NOTIFY_ENABLED="${GITCOMMIT_NOTIFY_ENABLED:-yes}"
GITCOMMIT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GITCOMMIT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GITCOMMIT_NOTIFY_CLIENT_ICON}"

# Colorization settings
GITCOMMIT_OUTPUT_COLOR="${GITCOMMIT_OUTPUT_COLOR:-5}"
GITCOMMIT_OUTPUT_COLOR_GOOD="${GITCOMMIT_OUTPUT_COLOR_GOOD:-2}"
GITCOMMIT_OUTPUT_COLOR_ERROR="${GITCOMMIT_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for gitcommit has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__gitcommit() {
  __git_porcelain "$GITCOMMIT_WD" && return
  local mess="${1:-$mess}"
  local succ="Successfully committed the changes to"
  local fail="Failed to commit the changes to"
  export GITCOMMIT_RAN="true"
  printf_cyan "Committing Changes with the following message:"
  printf_yellow "$mess"
  if git -C "$GITCOMMIT_WD" commit --untracked=no -q -S -m "$mess" 2>"$GITCOMMIT_TEMP_FILE"; then
    if __getexitcode "${GITCOMMIT_EXITCODE:-$?}" "$succ $(__git_repobase "$GITCOMMIT_WD")" "$fail $(__git_repobase "$GITCOMMIT_WD")"; then
      printf_green "commit ID: $(__git_commitid "$GITCOMMIT_WD")"
      COMMIT_ID="$(__git_commitid "$GITCOMMIT_WD")"
    fi
  else
    printf_readline "5" <"$GITCOMMIT_TEMP_FILE"
    printf_exit "Failed to commit the changes"
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_add() {
  local -a files="$*"
  [ -e "$1" ] || git -C "$GITCOMMIT_WD" add "."
  for f in $files; do
    if [ -e "$f" ]; then
      git -C "$GITCOMMIT_WD" add "$f" -f &>/dev/null
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_del() {
  local -a files="$*"
  for f in $files; do
    if [ ! -e "$f" ]; then
      git -C "$GITCOMMIT_WD" rm "$f" -f &>/dev/null
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_dir() {
  local git_dir="${1:-$GITCOMMIT_WD}"
  local makerepo=""
  if [ "$(git -C "$git_dir" rev-parse --is-inside-work-tree 2>/dev/null)" == "" ]; then
    printf_error "You are not in a git repo"
    printf_read_question "4" "Would you like to turn $git_dir into a git repo? y/N" "1" "makerepo"
    if printf_answer_yes "$makerepo"; then
      gitadmin "$git_dir" setup
      exit $?
    else
      exit
    fi
  fi
  [ -d "$git_dir" ] || printf_exit "$git_dir doesn't seem to be a git repo"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_commitid() {
  echo -n "$(git -C "${1:-$GITCOMMIT_WD}" rev-parse --short HEAD)"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_push() {
  local git_dir="${1:-$GITCOMMIT_WD}"
  local git_repo="$(__git_remote_fetch "$GITCOMMIT_WD")"
  local git_failed="Failed to push the changes to $git_repo"
  local git_succes="Successfully pushed the changes for commit ID:"
  local GITCOMMIT_EXITCODE=0
  local git_push=""
  [[ -f "$git_dir/.nopush" ]] && return
  am_i_online --error || exit 1
  if [ "$git_repo" != "localdir" ]; then
    if [[ "$*" =~ --automated ]] || [[ "$*" =~ --force ]]; then
      printf_green "Pushing the changes to $git_repo"
      git -C "$git_dir" push -q &>/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
      __getexitcode $GITCOMMIT_EXITCODE "$git_succes $(__git_commitid "$git_dir")" "$git_failed"
    else
      if [ "$GITCOMMIT_NO_CONFIRM" != "true" ]; then
        printf_read_question "3" "Should I push to $git_repo? [y/n]" "1" "git_push"
      else
        git_push="Y"
      fi
      if printf_answer_yes "$git_push"; then
        printf_green "Pushing the changes to $git_repo"
        git -C "$git_dir" push -q &>/dev/null && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
        __getexitcode $GITCOMMIT_EXITCODE "$git_succes $(__git_commitid "$git_dir")" "$git_failed"
      fi
    fi
  fi
  return $GITCOMMIT_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__set_version() {
  if [ -f "$GITCOMMIT_VERSION_FILE" ]; then
    local git_dir="$GITCOMMIT_WD"
    local git_sucess="Successfully committed the new version to"
    local git_failed="Failed to commit the version change in"
    local GITCOMMIT_EXITCODE=0
    date +"$GITCOMMIT_VERSION_FORMAT" >"$GITCOMMIT_VERSION_FILE"
    git_versionbump="🚀 Version Bump: $(cat "$GITCOMMIT_VERSION_FILE") 🚀 "
    printf_blue "$git_versionbump"
    __git_add "$GITCOMMIT_WD/version.txt" &&
      git -C "$GITCOMMIT_WD" commit -q -S -m "$git_versionbump" "$GITCOMMIT_VERSION_FILE" &&
      GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
    __getexitcode $GITCOMMIT_EXITCODE "$git_sucess $(__git_repobase "$git_dir")" "$git_failed ${git_dir//$PWD/.}"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__rename_branch() {
  local branch="$1" && shift 1
  local USER="${2:-$(basename "$(dirname "$GITCOMMIT_WD")")}"
  local REPO="${3:-$(basename "$GITCOMMIT_WD")}"
  printf_blue "Changing git branch to $branch on $REPO"
  git -C "$GITCOMMIT_WD" branch -m master "$branch" &>/dev/null
  git -C "$GITCOMMIT_WD" push -u origin "$branch" -fq &>/dev/null
  if curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER/$REPO" \
    -d '{"default_branch":"'$branch'"}' | grep -q '"default_branch": "main"' &>/dev/null; then
    git -C "$GITCOMMIT_WD" push --delete origin master -fq &>/dev/null
    printf_green "Changed the default branch on github.com/$USER/$REPO"
  fi &&
    printf_green "Successfully renamed the default branch" ||
    printf_exit 1 1 "Failed to rename the default branch"
  git config --global init.defaultBranch "$branch" &>/dev/null
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_branch() {
  local branch="$1"
  local USER="${2:-$(basename "$(dirname "$GITCOMMIT_WD")")}"
  local REPO="${3:-$(basename "$GITCOMMIT_WD")}"
  local GITCOMMIT_EXITCODE=0
  printf_exit "$USER"/"$REPO"
  curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER/$REPO" \
    -d '{"default_branch":"'$branch'"}' &>/dev/null || GITCOMMIT_EXITCODE=1
  return $GITCOMMIT_EXITCODE
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
GITCOMMIT_LOG_DIR="${GITCOMMIT_LOG_DIR:-$HOME/.local/log/gitcommit}"
GITCOMMIT_CACHE_DIR="${GITCOMMIT_CACHE_DIR:-$HOME/.cache/gitcommit}"
GITCOMMIT_CONFIG_DIR="${GITCOMMIT_CONFIG_DIR:-$HOME/.config/myscripts/gitcommit}"
GITCOMMIT_CONFIG_BACKUP_DIR="${GITCOMMIT_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/gitcommit/backups}"
GITCOMMIT_TEMP_DIR="${GITCOMMIT_TEMP_DIR:-$HOME/.local/tmp/system_scripts/gitcommit}"
GITCOMMIT_OPTIONS_DIR="${GITCOMMIT_OPTIONS_DIR:-$HOME/.local/share/myscripts/gitcommit/options}"
GITCOMMIT_TEMP_FILE="${GITCOMMIT_TEMP_FILE:-$(mktemp $GITCOMMIT_TEMP_DIR/XXXXXX 2>/dev/null)}"
GITCOMMIT_CONFIG_FILE="${GITCOMMIT_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
GITCOMMIT_OUTPUT_COLOR="${GITCOMMIT_OUTPUT_COLOR:-4}"
GITCOMMIT_OUTPUT_COLOR_2="${GITCOMMIT_OUTPUT_COLOR:-6}"
GITCOMMIT_OUTPUT_COLOR_GOOD="${GITCOMMIT_OUTPUT_COLOR_GOOD:-2}"
GITCOMMIT_OUTPUT_COLOR_ERROR="${GITCOMMIT_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
GITCOMMIT_GOOD_MESSAGE="${GITCOMMIT_GOOD_MESSAGE:-Everything Went OK}"
GITCOMMIT_ERROR_MESSAGE="${GITCOMMIT_ERROR_MESSAGE:-Well that didn\'t work}"
GITCOMMIT_NOTIFY_ENABLED="${GITCOMMIT_NOTIFY_ENABLED:-yes}"
GITCOMMIT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GITCOMMIT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GITCOMMIT_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
GITCOMMIT_PROJECT_DIR="${GIT_PROJECT_DIR:-$HOME/Projects}"
GITCOMMIT_VERSION_FORMAT="${VERSION_DATE_FORMAT:-%Y%m%d%H%M-git}"
GITCOMMIT_VERSION_FILE="${GIT_VERSION_FILE:-version.txt}"
GITCOMMIT_GITHUB_TOKEN="$GITHUB_ACCESS_TOKEN"
GITCOMMIT_MAINCONFIG=${GITCOMMIT_MAINCONFIG:-gitmainconfig}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" ] && . "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$GITCOMMIT_LOG_DIR" ] || mkdir -p "$GITCOMMIT_LOG_DIR" &>/dev/null
[ -d "$GITCOMMIT_TEMP_DIR" ] || mkdir -p "$GITCOMMIT_TEMP_DIR" &>/dev/null
[ -d "$GITCOMMIT_CACHE_DIR" ] || mkdir -p "$GITCOMMIT_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" ] && [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="m:"
LONGOPTS="options,config,version,help,dir:,mess:,message:"
ARRAY="status log push version files modified deleted added changed new improved "
ARRAY+="fixed release docs test breaking refactor permissions bugs alot docker node "
ARRAY+="ruby php perl python scratchpad todo notes blog emojify random custom setup reset "
AARAY+="updated enhanced "
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    GITCOMMIT_CWD="$2"
    shift 2
    ;;
  -m | --mess | --message)
    shift 1
    newmess="$2"
    shift 1
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$GITCOMMIT_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${GITCOMMIT_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${GITCOMMIT_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${GITCOMMIT_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${GITCOMMIT_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash git || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -d "$1" ]; then
  GITCOMMIT_WD="$1"
  [ -d "$GITCOMMIT_WD" ] || printf_exit "$GITCOMMIT_WD doesn't seem to be a directory"
  shift 1
else
  GITCOMMIT_WD="$PWD"
fi
if [ "$GITCOMMIT_WD" = "." ]; then
  GITCOMMIT_WD="$(__basedir ".")"
fi
topdir="$(__git_top_dir $GITCOMMIT_WD 2>/dev/null)"
GITCOMMIT_WD="${topdir:-$GITCOMMIT_WD}"
versionfile="$GITCOMMIT_WD/$GITCOMMIT_VERSION_FILE"
repo="$(__git_remote_fetch $GITCOMMIT_WD)"
basedir="$(basename $GITCOMMIT_WD)"
gituser="$(basename "$(dirname "$GITCOMMIT_WD")")"
gitversion="$GITCOMMIT_VERSION_FORMAT"
gitprojectdir="$GITCOMMIT_PROJECT_DIR"
[ -n "$repo" ] || repo="localdir"
__git_dir "$GITCOMMIT_WD"
MESSAGE="${newmess:-$1}"
GITCOMMIT_RAN=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case $MESSAGE in
s | status)
  shift 1
  __git_status "$GITCOMMIT_WD"
  exit $?
  ;;

l | log)
  shift 1
  __git_log "$GITCOMMIT_WD"
  exit $?
  ;;

reset)
  shift 1
  printf_read_question "3" "Should I reset? [y/n]" "1" "git_reset"
  if printf_answer_yes "$git_reset"; then
    git -C "$GITCOMMIT_WD" reset --hard
  else
    printf_return "Not resetting: user aborted"
  fi
  exit $?
  ;;

branch)
  shift 1
  __rename_branch "${1:-main}" "$2" "$3"
  exit $?
  ;;

push)
  shift 1
  __git_push "$*"
  exit $?
  ;;

version)
  shift 1
  __set_version
  __git_push "$GITCOMMIT_WD" --automated
  exit $?
  ;;

files)
  shift
  [ "$1" != "help" ] || printf_exit "Usage: $APPNAME files"
  if ! __git_porcelain "$GITCOMMIT_WD"; then
    files="$(git -C "$GITCOMMIT_WD" status -s -b | grep 'M \| D \|??' | sed 's|^ ||g' | awk -F' ' '{print $2}')"
    filesmsg="$(git -C "$GITCOMMIT_WD" status -b -s | sed '/^\#/d;s,^ ,,g;s,??,A,g' | tr '\n' '|' | sed 's#|$##g' | grep '^')"
    mess="➕ ${*:-$filesmsg} ➕ "
    __git_del "$files"
    __git_add "$files"
    __gitcommit "$mess"
  else
    printf_exit 1 0 "Nothing has been changed in $GITCOMMIT_WD"
  fi
  ;;

modified)
  shift
  [ "$1" != "help" ] || printf_exit "Usage: $APPNAME modified"
  if git -C "$GITCOMMIT_WD" status -s -b | grep -F 'M ' >/dev/null 2>&1; then
    files="$(git -C "$GITCOMMIT_WD" status -s -b | grep -F 'M ' | sed 's|^ ||g' | awk -F' ' '{print $2}')"
    mess="🗃 Modified: $(echo "${*:-$files}" | tr '\n' ' ') 🗃 "
    __git_add "$files"
    __gitcommit "$mess"
  else
    printf_exit 1 0 "Nothing has been modified in $GITCOMMIT_WD"
  fi
  ;;

updated)
  shift
  [ "$1" != "help" ] || printf_exit "Usage: $APPNAME updated"
  if git -C "$GITCOMMIT_WD" status -s -b | grep -F 'M ' >/dev/null 2>&1; then
    files="$(git -C "$GITCOMMIT_WD" status -s -b | grep 'M \|D\|A ' | sed 's|^ ||g' | awk -F' ' '{print $2}')"
    mess="🗃 Updated: $(echo "${*:-$files}" | tr '\n' ' ') 🗃 "
    __git_add "$files"
    __gitcommit "$mess"
  else
    printf_exit 1 0 "Nothing has been update in $GITCOMMIT_WD"
  fi
  ;;

deleted)
  shift
  [ "$1" != "help" ] || printf_exit "Usage: $APPNAME deleted"
  if git -C "$GITCOMMIT_WD" status -s -b | grep -F ' D ' >/dev/null 2>&1; then
    files="$(git -C "$GITCOMMIT_WD" status -s -b | grep -F ' D ' | sed 's|^ ||g' | awk -F' ' '{print $2}')"
    mess="➖ Deleted: $(echo "${*:-$files}" | tr '\n' ' ') ➖ "
    __git_del "$files"
    __gitcommit "$mess"
  else
    printf_exit 1 0 "Nothing has been deleted in $GITCOMMIT_WD"
  fi
  ;;

added)
  shift
  [ "$1" != "help" ] || printf_exit "Usage: $APPNAME added"
  if git -C "$GITCOMMIT_WD" status -s -b | grep -F '?? ' >/dev/null 2>&1; then
    files="$(git -C "$GITCOMMIT_WD" status -s -b | grep -F '?? ' | awk '{print $2}' | tr '\n' ' ')"
    mess="❓ Added: $(echo "${*:-$files}" | tr '\n' ' ') ❓"
    __git_add "$files"
    __gitcommit "$mess"
  else
    printf_exit 1 0 "Nothing has been added in $GITCOMMIT_WD"
  fi
  ;;

changed)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME changed filename[s]"
  ARGS="${*:-} "
  mess="✔️🐛 Changed: ${ARGS}🐛✔️"
  __git_add $ARGS
  __gitcommit "$mess"
  ;;

new)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME new filename[s]"
  ARGS="${*:-} "
  mess="🆕📦 NEW: ${ARGS}📦🆕 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

improved)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME improved filename[s]"
  ARGS="${*:-} "
  mess="👌 IMPROVE: ${ARGS}👌 "
  __git_add "$ARGS"
  ;;

fixed)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME fixed filename[s]"
  ARGS="${*:-} "
  mess="🐛 FIXED: ${ARGS}🐛 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

release)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME release filename[s]"
  ARGS="${*:-} "
  mess="🚀 RELEASE: ${ARGS}🚀 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

docs)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME docs filename[s]"
  ARGS="${*} "
  mess="📖 DOCS: ${ARGS}📖 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

test)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME test filename[s]"
  ARGS="${*:-} "
  mess="🤖 TEST: ${ARGS}🤖"
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

breaking)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME breaking filename[s]"
  ARGS="${*:-} "
  mess="⚒️ BREAKING: ${ARGS}⚒️ "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

refactor)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME refactor filename[s]"
  ARGS="${*:-} "
  mess="✔️ 〰️ Refactor Code ${ARGS}〰️ ✔️  "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

performance)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME performance filename[s]"
  ARGS="${*:-} "
  mess="🚤 Preformance boost ${ARGS}⏩"
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

permission | permissions)
  shift 1
  ARGS="${*:-} "
  mess="🏠🔥❗ Fixed Permissions ${ARGS}❗🔥🏠 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

bug | bugs)
  shift 1
  ARGS="${*:-} "
  mess="🐛🦈🏠❗ Bug Fixes ${ARGS}❗🏠🦈🐛 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

alot | fixes)
  shift 1
  ARGS="${*:-} "
  mess="🦈🏠🐜❗ Fixes and Updates ${ARGS}❗🐜🦈🏠 "
  __git_add "."
  __gitcommit "$mess"
  ;;

docker)
  shift 1
  ARGS="${*:-} "
  mess="🐜❇🦈🏠❗ Added Docker Workflow ${ARGS}❗🏠🦈❇🐜 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

node)
  shift 1
  ARGS="${*:-} "
  mess="🐜❇🦈🏠❗ Added nodejs Workflow ${ARGS}🏠🦈❇🐜 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

ruby)
  shift 1
  ARGS="${*:-} "
  mess="🐜❇🦈🏠❗ Added ruby Workflow ${ARGS}❗🏠🦈❇🐜 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

php)
  shift 1
  ARGS="${*:-} "
  mess="🐜❇🦈🏠❗ Added php Workflow ${ARGS}❗🏠🦈❇🐜 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

perl)
  shift 1
  ARGS="${*:-} "
  mess="🐜❇🦈🏠❗ Added perl Workflow ${ARGS}❗🏠🦈❇🐜 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

python)
  shift 1
  ARGS="${*:-} "
  mess="🐜❇🦈🏠❗ Added python Workflow ${ARGS}❗🏠🦈❇🐜 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

scratchpad)
  shift 1
  msg="${1:-}"
  shift 1
  ARGS=" ${*:-} "
  mess="🐜📓❇📓 ${msg:-Modified my scratchpad} ${ARGS}📓❇📓🐜 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

todo)
  shift 1
  msg="${1:-}"
  shift 1
  ARGS=" ${*:-} "
  mess="🐜📓❇📓 ${mesg:-Modified my todo list} ${ARGS}📓❇📓🐜 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

notes)
  shift 1
  msg="${1:-}"
  shift 1
  ARGS=" ${*:-} "
  mess="🐜📓❇📓 ${msg:-Modified my notes} ${ARGS}📓❇📓🐜 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

blog)
  shift 1
  msg="${1:-}"
  shift 1
  ARGS=" ${*:-} "
  mess="🐜📓❇📓 ${msg:-New blog post} ${ARGS}📓❇📓🐜 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

init)
  shift 1
  msg="${*}"
  mess="${msg:-🦈🏠🐜❗ Initial Commit 📍🐜🦈🏠} "
  ;;

emj | emojy | emojify)
  cmd_exists emojify && setemj="$(emojify "$*")" || setemj="$*"
  mess="${setemj:-🦈🏠🐜❗ Well I did some things ❗🐜🦈🏠 }"
  ;;

random)
  shift 1
  mess="🐜➡️  Random: $(curl -s https://commitment.herokuapp.com/index.txt) ⬅️ 🐜 "
  ;;

custom)
  shift 1
  if [ -n "$1" ]; then
    mess=" $1 "
  else
    printf_exit "You must specify your commit message"
  fi
  ;;

setup)
  shift 1
  gitadmin "$GITCOMMIT_WD" setup "$@"
  exit
  ;;

*)
  setmessage="${newmess:-$mess}"
  if [ -n "$setmessage" ]; then
    [ ! "$(echo "$setmessage" | wc -m)" -lt "4" ] || printf_exit "Message must be longer than 4 characters"
    mess="$setmessage"
  else
    mess="🦈🏠❗ Well I did things - Hopefully nothing breaks ❗🏠🦈 "
  fi
  ;;
esac
shift
#
if __git_porcelain "$GITCOMMIT_WD"; then
  [ -n "$GITCOMMIT_RAN" ] && true || printf_red "There are no changes to commit in ${basedir}"
else
  if [ -f "$GITCOMMIT_WD/$GITCOMMIT_MAINCONFIG" ] && [ -d "$GITCOMMIT_WD/.git" ]; then
    cp -Rf "$GITCOMMIT_WD/$GITCOMMIT_MAINCONFIG" "$GITCOMMIT_WD/.git/config"
  fi
  if [ -z "$files" ]; then
    git -C "$GITCOMMIT_WD" add . >/dev/null 2>&1
  fi
  if [ -z "$mess" ]; then
    if [ -z "$GITCOMMIT_RAN" ]; then
      __gitcommit "🦈🏠🐜 Fixes and Updates 🐜🦈🏠 "
      GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
    else
      GITCOMMIT_EXITCODE=1
    fi
  else
    if [ -z "$GITCOMMIT_RAN" ]; then
      __gitcommit "$mess" && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
    else
      GITCOMMIT_EXITCODE=1
    fi
  fi
fi
#
git_cherry="$(git -C "$GITCOMMIT_WD" cherry -v 2>/dev/null)"
if [ -n "$git_cherry" ]; then
  if am_i_online --error -m "No internet connection. Skipping push"; then
    [ -z "$GITCOMMIT_RAN" ] || __git_push
  fi
fi
printf_newline
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
