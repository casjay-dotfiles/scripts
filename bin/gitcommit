  [ "$1" = "help" ] && printf_exit "Usage: $APPNAME files"
  __git_del "$(printf '%b\n' "$git_message")" || exitCode=$((${exitCode:-0} + 1))
  __git_add "$(printf '%b\n' "$git_message")" || exitCode=$((${exitCode:-0} + 1))
  __git_mod "$(printf '%b\n' "$git_message")" || exitCode=$((${exitCode:-0} + 1))
  __run_push "$git_message"
  exit ${exitCode:-0}
