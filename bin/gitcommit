__git_dir "$REPO_DIR"
MESSAGE="${newmess:-$1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case $MESSAGE in
s | status)
  shift 1
  __git_status "$REPO_DIR"
  exit $?
  ;;

l | log)
  shift 1
  __git_log "$REPO_DIR"
  exit $?
  ;;

reset)
  shift 1
  printf_read_question "3" "Should I reset? [y/n]" "1" "reset"
  if printf_answer_yes "$reset"; then
    git -C "$REPO_DIR" reset --hard
  else
    printf_return "Not resetting: user aborted"
  fi
  exit $?
  ;;

branch)
  shift 1
  __rename_branch "${1:-main}" "$2" "$3"
  ;;

push)
  shift 1
  __git_push "$*"
  exit $?
  ;;

version)
  shift 1
  # if __git_porcelain "$REPO_DIR"; then
  #   printf_red "There are no changes to commit"
  #   exit
  # fi
  __set_version
  __git_push "$REPO_DIR" --automated
  exit $?
  ;;

files)
  shift
  [ "$1" != "help" ] || printf_exit "Usage: $APPNAME files"
  if ! __git_porcelain "$REPO_DIR"; then
    files="$(git -C "$REPO_DIR" status -s -b | grep 'M \| D \|??' | sed 's|^ ||g' | awk -F' ' '{print $2}')"
    filesmsg="$(git -C "$REPO_DIR" status -b -s | sed '/^\#/d;s,^ ,,g;s,??,A,g' | tr '\n' '|' | sed 's#|$##g' | grep '^')"
    mess="➕ ${*:-$filesmsg} ➕ "
    __git_del "$files"
    __git_add "$files"
    __gitcommit "$mess"
  else
    printf_exit 1 0 "Nothing has been changed in $REPO_DIR"
  fi
  ;;

modified)
  shift
  [ "$1" != "help" ] || printf_exit "Usage: $APPNAME modified"
  if git -C "$REPO_DIR" status -s -b | grep -F 'M ' >/dev/null 2>&1; then
    files="$(git -C "$REPO_DIR" status -s -b | grep -F 'M ' | sed 's|^ ||g' | awk -F' ' '{print $2}')"
    mess="🗃 Modified: $(echo "${*:-$files}" | tr '\n' ' ') 🗃 "
    __git_add "$files"
    __gitcommit "$mess"
  else
    printf_exit 1 0 "Nothing has been modified in $REPO_DIR"
  fi
  ;;

updated)
  shift
  [ "$1" != "help" ] || printf_exit "Usage: $APPNAME updated"
  if git -C "$REPO_DIR" status -s -b | grep -F 'M ' >/dev/null 2>&1; then
    files="$(git -C "$REPO_DIR" status -s -b | grep 'M \|D\|A ' | sed 's|^ ||g' | awk -F' ' '{print $2}')"
    mess="🗃 Updated: $(echo "${*:-$files}" | tr '\n' ' ') 🗃 "
    __git_add "$files"
    __gitcommit "$mess"
  else
    printf_exit 1 0 "Nothing has been update in $REPO_DIR"
  fi
  ;;

deleted)
  shift
  [ "$1" != "help" ] || printf_exit "Usage: $APPNAME deleted"
  if git -C "$REPO_DIR" status -s -b | grep -F ' D ' >/dev/null 2>&1; then
    files="$(git -C "$REPO_DIR" status -s -b | grep -F ' D ' | sed 's|^ ||g' | awk -F' ' '{print $2}')"
    mess="➖ Deleted: $(echo "${*:-$files}" | tr '\n' ' ') ➖ "
    __git_del "$files"
    __gitcommit "$mess"
  else
    printf_exit 1 0 "Nothing has been deleted in $REPO_DIR"
  fi
  ;;

added)
  shift
  [ "$1" != "help" ] || printf_exit "Usage: $APPNAME added"
  if git -C "$REPO_DIR" status -s -b | grep -F '?? ' >/dev/null 2>&1; then
    files="$(git -C "$REPO_DIR" status -s -b | grep -F '?? ' | awk '{print $2}' | tr '\n' ' ')"
    mess="❓ Added: $(echo "${*:-$files}" | tr '\n' ' ') ❓"
    __git_add "$files"
    __gitcommit "$mess"
  else
    printf_exit 1 0 "Nothing has been added in $REPO_DIR"
  fi
  ;;

changed)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME changed filename[s]"
  ARGS="${*:-} "
  mess="✔️🐛 Changed: ${ARGS}🐛✔️"
  __git_add $ARGS
  __gitcommit "$mess"
  ;;

new)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME new filename[s]"
  ARGS="${*:-} "
  mess="🆕📦 NEW: ${ARGS}📦🆕 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

improved)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME improved filename[s]"
  ARGS="${*:-} "
  mess="👌 IMPROVE: ${ARGS}👌 "
  __git_add "$ARGS"
  ;;

fixed)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME fixed filename[s]"
  ARGS="${*:-} "
  mess="🐛 FIXED: ${ARGS}🐛 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

release)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME release filename[s]"
  ARGS="${*:-} "
  mess="🚀 RELEASE: ${ARGS}🚀 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

docs)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME docs filename[s]"
  ARGS="${*} "
  mess="📖 DOCS: ${ARGS}📖 "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

test)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME test filename[s]"
  ARGS="${*:-} "
  mess="🤖 TEST: ${ARGS}🤖"
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

breaking)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME breaking filename[s]"
  ARGS="${*:-} "
  mess="⚒️ BREAKING: ${ARGS}⚒️ "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

refactor)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME refactor filename[s]"
  ARGS="${*:-} "
  mess="✔️ 〰️ Refactor Code ${ARGS}〰️ ✔️  "
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

performance)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME performance filename[s]"
  ARGS="${*:-} "
  mess="🚤 Preformance boost ${ARGS}⏩"
  __git_add "$ARGS"
  __gitcommit "$mess"
  ;;

permission | permissions)
  shift 1
  ARGS="${*:-} "
  mess="🏠🔥❗ Fixed Permissions ${ARGS}❗🔥🏠 "
