# APP Variables
if [ -d "$REPO_DIR" ]; then
  cd "$REPO_DIR" || true
else
  REPO_DIR="$PWD"
fi
topdir="$(__git_top_dir $REPO_DIR 2>/dev/null)"
REPO_DIR="${topdir:-$REPO_DIR}"
versionfile="$REPO_DIR/$GITCOMMIT_VERSION_FILE"
repo="$(__git_remote_fetch $REPO_DIR)"
basedir="$(basename $REPO_DIR)"
