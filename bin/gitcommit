  append_changelog_message="$*"
  changed_files="$(__changed_files deleted added modified)"
  __changelog_create
  [ "$1" = "help" ] && printf_exit "Usage: $APPNAME files"
  __git_del "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" || exitCode=$((${exitCode:-0} + 1))
  __git_add "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" || exitCode=$((${exitCode:-0} + 1))
  __git_mod "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" || exitCode=$((${exitCode:-0} + 1))
  __run_push "$GITCOMMIT_MESSAGE"
  exit ${exitCode:-0}
  ;;

modified)
  shift
  [ "$1" = "help" ] && printf_exit "Usage: $APPNAME modified"
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 Nothing has been modified in $GITCOMMIT_CWD 🎊"
  set_action="🗃️ modified:"
  set_icon="🗃️"
  changelog_message="Modified"
  append_changelog_message="$*"
  changed_files="$(__changed_files modified)"
  __changelog_create
  __git_mod "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

updated)
  shift
  [ "$1" = "help" ] && printf_exit "Usage: $APPNAME updated"
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 Nothing has been updated in $GITCOMMIT_CWD 🎊"
  set_action="📁 Updated:"
  set_icon="📁"
  changelog_message="Updated"
  append_changelog_message="$*"
  changed_files="$(__changed_files modified)"
  __changelog_create
  __git_updated "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

deleted)
  shift
  [ "$1" = "help" ] && printf_exit "Usage: $APPNAME deleted"
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 Nothing has been deleted in $GITCOMMIT_CWD 🎊"
  __is_deleted="$(__changed_files deleted &>/dev/null && echo 'TRUE')"
  if [[ "$__is_deleted" = "TRUE" ]]; then
    set_action="➖ Deleted:"
    set_icon="➖"
    changelog_message="Deleted"
    append_changelog_message="$*"
    changed_files="$(__changed_files deleted)"
    __changelog_create
    __git_del "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  else
    printf_exit 1 0 "🎊 $GITCOMMIT_CWD 🎊"
  fi
  exit $?
  ;;

added)
  shift
  [ "$1" = "help" ] && printf_exit "Usage: $APPNAME added"
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 Nothing has been added in $GITCOMMIT_CWD 🎊"
  set_action="➕ Added:"
  set_icon="➕"
  changelog_message="Added"
  append_changelog_message="$*"
  changed_files="$(__changed_files added)"
  __changelog_create
  __git_add "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
