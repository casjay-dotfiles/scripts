  ;;

blog)
  shift 1
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been changed in $GITCOMMIT_CWD 🎊"
  msg="${1:-}"
  shift 1
  set_action="🐜📓❇📓 ${msg:-New blog post}:"
  set_icon="📓❇📓🐜"
  __changelog_create "$*"
  __git_updated "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

random)
  shift 1
  set_action="🐜➡️ Random: $(curl -q -LSsf "$GITCOMMIT_API_URL")"
  set_icon="⬅️🐜"
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been changed in $GITCOMMIT_CWD 🎊"
  __changelog_create "$*"
  __default_git_action "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

emj | emojy | emojify)
  shift 1
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been changed in $GITCOMMIT_CWD 🎊"
  cmd_exists emojify && setemj="$(emojify "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")")"
  set_action="${setemj:-🦈🏠🐜❗}"
  set_icon="${setemj:-❗🐜🦈🏠}"
  __changelog_create "$*"
  __default_git_action "$(echo -e "${GITCOMMIT_MESSAGE:-$*}" | __emj_check)" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

custom)
  shift 1
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been changed in $GITCOMMIT_CWD 🎊"
  if [ -n "$1" ]; then
    __changelog_create "$*"
    __default_git_action "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  else
    printf_exit "You must specify your commit message"
  fi
  exit $?
  ;;
*)
  [ $# -ne 0 ] || printf_exit "Usage: $APPNAME [option] [message]"
  setmessage="${newmess:-$mess}"
  if [ -n "$setmessage" ]; then
    [ ! "$(echo "$setmessage" | wc -m)" -lt "4" ] || printf_exit "Message must be longer than 4 characters"
    GITCOMMIT_MESSAGE="$setmessage"
  fi
  __changelog_create "$*"
  __default_git_action "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")"
  ;;
esac
shift
#
if __git_porcelain "$GITCOMMIT_CWD"; then
  [ -n "$GITCOMMIT_RAN" ] && true || printf_return "There are no changes to commit in ${basedir}"
else
  if [ -f "$GITCOMMIT_CWD/$GITCOMMIT_MAIN_CONFIG" ] && [ -d "$GITCOMMIT_CWD/.git" ]; then
    cp -Rf "$GITCOMMIT_CWD/$GITCOMMIT_MAIN_CONFIG" "$GITCOMMIT_CWD/.git/config"
  fi
  if [ -z "$mess" ]; then
    if [ -z "$GITCOMMIT_RAN" ]; then
      __gitcommit "🦈🏠🐜 Fixes and Updates 🐜🦈🏠 "
      GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
    else
      GITCOMMIT_EXITCODE=1
    fi
  else
    if [ -z "$GITCOMMIT_RAN" ]; then
      __gitcommit "$mess" && GITCOMMIT_EXITCODE=0 || GITCOMMIT_EXITCODE=1
    else
      GITCOMMIT_EXITCODE=1
    fi
  fi
fi
#
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_push || exitCode=1
printf_newline
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
