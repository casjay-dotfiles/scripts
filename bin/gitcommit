# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE"
  [ -d "$GITCOMMIT_CONFIG_DIR" ] || mkdir -p "$GITCOMMIT_CONFIG_DIR"
  [ -d "$GITCOMMIT_CONFIG_BACKUP_DIR" ] || mkdir -p "$GITCOMMIT_CONFIG_BACKUP_DIR"
  [ -f "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" ] &&
    cp -Rf "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE.$$"
  cat <<EOF >"$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE"
# Settings for gitcommit
GITCOMMIT_MAINCONFIG=${GITCOMMIT_MAINCONFIG:-gitmainconfig}
GITCOMMIT_NO_CONFIRM="\${GITCOMMIT_NO_CONFIRM:-true}"
GITCOMMIT_PROJECT_DIR="\${GIT_PROJECT_DIR:-$HOME/Projects}"
GITCOMMIT_VERSION_FORMAT="\${VERSION_DATE_FORMAT:-%Y%m%d%H%M-git}"
GITCOMMIT_VERSION_FILE="\${GIT_VERSION_FILE:-version.txt}"
GITCOMMIT_TEMP_FILE="${TMPDIR:-/tmp}/gitcommit"
GITCOMMIT_NOTIFY_ENABLED="yes"
GITCOMMIT_NOTIFY_CLIENT_NAME="\${NOTIFY_CLIENT_NAME:-\$APPNAME}"
GITCOMMIT_NOTIFY_CLIENT_ICON="\${NOTIFY_CLIENT_ICON:-\$GITCOMMIT_NOTIFY_CLIENT_ICON}"

EOF
  if [ -f "$GITCOMMIT_CONFIG_DIR/$GITCOMMIT_CONFIG_FILE" ]; then
    printf_green "Your config file for gitcommit has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__list_available() { echo -e "$ARRAY" | tr ' ' '\n'; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitcommit() {
  __git_porcelain "$REPO_DIR" && return
  local mess="${1:-$mess}"
  local succ="Successfuly committed the changes to"
  local fail="Failed to commit the changes to"
  export COMMIT="true"
  printf_cyan "Commiting Changes with the following message:"
  printf_yellow "$mess"
  if git -C "$REPO_DIR" commit --untracked=no -q -S -m "$mess" 2>"$GITCOMMIT_TEMP_FILE"; then
    if __getexitcode "$exitCode" "$succ $(__git_repobase "$REPO_DIR")" "$fail $(__git_repobase "$REPO_DIR")"; then
      printf_green "commit ID: $(__git_commitid "$REPO_DIR")"
      COMMIT_ID="$(__git_commitid "$REPO_DIR")"
    fi
  else
    cat "$GITCOMMIT_TEMP_FILE" | printf_readline "5"
    printf_exit "Failed to commit the changes"
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_add() {
  local -a files="$*"
  for f in $files; do
    if [ -e "$f" ]; then
      git -C "$REPO_DIR" add "$f" -f &>/dev/null
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_del() {
  local -a files="$*"
  for f in $files; do
    if [ ! -e "$f" ]; then
      git -C "$REPO_DIR" rm "$f" -f &>/dev/null
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_dir() {
  local REPO_DIR="${1:-$REPO_DIR}"
  local makerepo=""
  if [ "$(git -C "$REPO_DIR" rev-parse --is-inside-work-tree 2>/dev/null)" == "" ]; then
    printf_error "You are not in a git repo"
    printf_read_question "4" "Would you like to turn $REPO_DIR into a git repo? y/N" "1" "makerepo"
    if printf_answer_yes "$makerepo"; then
      gitadmin "$REPO_DIR" setup
      exit $?
    else
      exit
    fi
  fi
  [ -d "$REPO_DIR" ] || printf_exit "$REPO_DIR doesn't seem to be a git repo"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_commitid() {
  echo -n "$(git -C "${1:-$REPO_DIR}" rev-parse --short HEAD)"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_push() {
  local push=""
  local REPO_DIR="${1:-$REPO_DIR}"
  local repo="$(__git_remote_fetch "$REPO_DIR")"
  am_i_online --error || exit 1
  if [ "$repo" != "localdir" ]; then
    if [[ "$*" =~ --automated ]] || [[ "$*" =~ --force ]]; then
      printf_green "Pushing the changes to $repo"
      git -C "$REPO_DIR" push -q >/dev/null 2>&1 && exitCode=0 || exitCode=1
      __getexitcode $exitCode "Successfuly pushed the changes for commit ID: $(__git_commitid "$REPO_DIR")" "Failed to push the changes"
    else
      if [ "$GITCOMMIT_NO_CONFIRM" != "true" ]; then
        printf_read_question "3" "Should I push to $repo? [y/n]" "1" "push"
      else
        push="Y"
      fi
      if printf_answer_yes "$push"; then
        printf_green "Pushing the changes to $repo"
        git -C "$REPO_DIR" push -q >/dev/null 2>&1 && exitCode=0 || exitCode=1
        __getexitcode $exitCode "Successfuly pushed the changes for commit ID: $(__git_commitid "$REPO_DIR")" "Failed to push the changes"
      fi
    fi
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__set_version() {
  if [ -f "$versionfile" ]; then
    date +"$gitversion" >"$versionfile"
    versionbump="🚀 Version Bump: $(cat "$versionfile") 🚀 "
    printf_blue "$versionbump"
    __git_add "$REPO_DIR/version.txt" && git -C "$REPO_DIR" commit -q -S -m "$versionbump" -- "$versionfile" && true || false
    __getexitcode $exitCode "Successfuly committed the new version to $(__git_repobase "$REPO_DIR")" \
      "Failed to commit the version change in ${REPO_DIR//$PWD/.}"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__rename_branch() {
  local branch="$1" && shift 1
  local USER="${2:-$(basename "$(dirname "$REPO_DIR")")}"
  local REPO="${3:-$(basename "$REPO_DIR")}"
  printf_blue "Changing git branch to $branch on $REPO"
  git -C "$REPO_DIR" branch -m master "$branch" &>/dev/null
  git -C "$REPO_DIR" push -u origin "$branch" -fq &>/dev/null
  if curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER/$REPO" \
    -d '{"default_branch":"'$branch'"}' | grep -q '"default_branch": "main"' &>/dev/null; then
    git -C "$REPO_DIR" push --delete origin master -fq &>/dev/null
    printf_green "Changed the default branch on github.com/$USER/$REPO"
  fi &&
    printf_green "Successfully renamed the default branch" ||
    printf_exit 1 1 "Failed to rename the default branch"
  git config --global init.defaultBranch "$branch" &>/dev/null
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_branch() {
  local branch="$1"
  local USER="${2:-$(basename "$(dirname "$REPO_DIR")")}"
  local REPO="${3:-$(basename "$REPO_DIR")}"
  printf_exit "$USER"/"$REPO"
  if cmd_exists github-renaming; then
    github-renaming default-branch master "$branch" -t "$GITCOMMIT_GITHUB_TOKEN" -r "$USER"/"$REPO"
  else
    curl -q -LSs -X PATCH -H "Accept: application/vnd.github.v3+json" \
      -H "Authorization: token $GITCOMMIT_GITHUB_TOKEN" "https://api.github.com/repos/$USER/$REPO" \
      -d '{"default_branch":"'$branch'"}' &>/dev/null || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Defaults
exitCode=""
GITCOMMIT_CONFIG_FILE="settings.conf"
