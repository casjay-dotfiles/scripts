  exit $?
  ;;

python)
  shift 1
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been changed in $GITCOMMIT_CWD 🎊"
  set_action="🐜❇🦈🏠❗ Added python Workflow:"
  set_icon="❗🏠🦈❇🐜"
  __changelog_create "$*"
  __git_updated "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

scratchpad)
  shift 1
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been changed in $GITCOMMIT_CWD 🎊"
  msg="${1:-}"
  shift 1
  set_action="🐜📓❇📓 ${msg:-Modified my scratchpad}:"
  set_icon="📓❇📓🐜"
  __changelog_create "$*"
  __git_updated "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

todo)
  shift 1
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been changed in $GITCOMMIT_CWD 🎊"
  msg="${1:-}"
  shift 1
  set_action="🐜📓❇📓 ${mesg:-Modified my todo list}:"
  set_icon="📓❇📓🐜"
  __changelog_create "$*"
  __git_updated "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

notes)
  shift 1
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been changed in $GITCOMMIT_CWD 🎊"
  msg="${1:-}"
  shift 1
  set_action="🐜📓❇📓 ${msg:-Modified my notes}:"
  set_icon="📓❇📓🐜"
  __changelog_create "$*"
  __git_updated "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
