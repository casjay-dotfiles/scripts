renamed)
  shift 1
  [ $# -ne 2 ] && printf_exit "Usage: $APPNAME renamed oldfile newfile"
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been renamed in $GITCOMMIT_CWD 🎊"
  set_action="✔️ Renamed: ${1} ➡ ${2}"
  set_icon="✔️"
  changelog_message="Renamed"
  append_changelog_message="$*"
  changed_files="$(__changed_files renamed)"
  __changelog_create
  __git_renamed "$1" "$2" "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

changed)
  shift 1
  [ "$1" = "help" ] && printf_exit "Usage: $APPNAME changed filename[s]"
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been changed in $GITCOMMIT_CWD 🎊"
  set_action="📁✔️ Changed:"
  set_icon="📁✔️"
  changelog_message="Changed"
  append_changelog_message="$*"
  changed_files="$(__changed_files modified)"
  __changelog_create
  __git_mod "$(echo -e "${GITCOMMIT_MESSAGE:-$*}")" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

new)
  shift 1
  [ "$1" = "help" ] && printf_exit "Usage: $APPNAME new filename[s]"
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No new files in $GITCOMMIT_CWD 🎊"
  set_action="🆕📦 New:"
  set_icon="📦🆕"
  changelog_message="New"
  append_changelog_message="$*"
  changed_files="$(__changed_files added)"
  __changelog_create
  __git_add "${*}" && __run_push "$GITCOMMIT_MESSAGE"
  exit $?
  ;;

improved)
  shift 1
  [ "$1" = "help" ] && printf_exit "Usage: $APPNAME improved filename[s]"
  __changed_files message &>/dev/null || printf_exit 1 0 "🎊 No files have been changed in $GITCOMMIT_CWD 🎊"
  set_action="👌 IMPROVE:"
  set_icon="👌"
  changelog_message="Improved"
  append_changelog_message="$*"
  changed_files="$(__changed_files modified)"
