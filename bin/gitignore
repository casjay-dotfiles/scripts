# @File          : gitignore
# @Description   : Generate a .gitignore file
# @TODO          : Make this work locally
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$GITIGNORE_CONFIG_DIR/$GITIGNORE_CONFIG_FILE"
  [ -d "$GITIGNORE_CONFIG_DIR" ] || mkdir -p "$GITIGNORE_CONFIG_DIR"
  [ -d "$GITIGNORE_CONFIG_BACKUP_DIR" ] || mkdir -p "$GITIGNORE_CONFIG_BACKUP_DIR"
  [ -f "$GITIGNORE_CONFIG_DIR/$GITIGNORE_CONFIG_FILE" ] &&
    cp -Rf "$GITIGNORE_CONFIG_DIR/$GITIGNORE_CONFIG_FILE" "$GITIGNORE_CONFIG_BACKUP_DIR/$GITIGNORE_CONFIG_FILE.$$"
  cat <<EOF >"$GITIGNORE_CONFIG_DIR/$GITIGNORE_CONFIG_FILE"
# Settings for gitignore
GITIGNORE_TEMPLATE_DIR="${GITIGNORE_TEMPLATE_DIR:-$GITIGNORE_CONFIG_DIR/templates}"
GITIGNORE_URL="${GITIGNORE_URL:-https://www.toptal.com/developers/gitignore/api}"

# Notification settings
GITIGNORE_GOOD_MESSAGE="${GITIGNORE_GOOD_MESSAGE:-Everything Went OK}"
GITIGNORE_ERROR_MESSAGE="${GITIGNORE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GITIGNORE_NOTIFY_ENABLED="${GITIGNORE_NOTIFY_ENABLED:-yes}"
GITIGNORE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GITIGNORE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GITIGNORE_NOTIFY_CLIENT_ICON}"

# Colorization settings
GITIGNORE_OUTPUT_COLOR="${GITIGNORE_OUTPUT_COLOR:-5}"
GITIGNORE_OUTPUT_COLOR_GOOD="${GITIGNORE_OUTPUT_COLOR_GOOD:-2}"
GITIGNORE_OUTPUT_COLOR_ERROR="${GITIGNORE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$GITIGNORE_CONFIG_DIR/$GITIGNORE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__dirignore() {
  if grep -qvs "ignoredirmessage" "$GITIGNORE_CWD/.gitignore"; then
    printf '# Disable reminder in prompt\nignoredirmessage\n\n'
  fi
  if grep -qs '# Disable reminder in prompt' "$GITIGNORE_CWD/.gitignore"; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__default_ignore() {
  if grep -qvs "# OS generated files" "$GITIGNORE_CWD/.gitignore"; then
    echo '# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Other
.installed
'
  fi
  if grep -qs '# OS generated files' "$GITIGNORE_CWD/.gitignore"; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
ignore_list() {
  IGNORELIST="$(echo "$@" | tr ' ' ',')"
  IGNOREFILES="${IGNORELIST//,/ }"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
fetch_file() {
  gi_args=()
  for arg; do
    if [[ $arg = -- ]]; then
      curl_args=("${gi_args[@]}")
      gi_args=()
    else
      gi_args+=("$arg")
    fi
  done
  IFS=,
  curl -q -LSs "${curl_args[@]}" $GITIGNORE_URL/"${gi_args[*]}" |
    grep -vE '# Created by |# Edit at |# End of |^$'
  printf '\n'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
fetch_ignore() {
  local IGNOREFILES="$IGNOREFILES"
  for file in $IGNOREFILES; do
    if [ "$file" = "dirignore" ]; then
      __dirignore
    elif [ "$file" = "default" ]; then
      __default_ignore
    elif grep -sEvq '#.*|^$' "$GITIGNORE_TEMPLATE_DIR/$file"; then
      cat "$GITIGNORE_TEMPLATE_DIR/$file"
    else
      fetch_file "$file"
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
ignore_overwrite() {
  if [[ "$automated" = "Y" ]]; then
    overwrite=Y
  fi
  if [ -f "$GITIGNORE_CWD/.gitignore" ] && [ -z "$overwrite" ]; then
    printf_read_question "2" "Should I overwrite your git ignore? [y/n]" "1" "overwrite"
    if printf_answer_yes "$overwrite"; then
      __rm_rf "$GITIGNORE_CWD/.gitignore"
    else
      printf_red "User aborted, not overwriting your .gitignore"
      exit 1
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
print_gitignore() {
  ignore_list "$@"
  printf_green "Fetching $IGNORELIST"
  fetch_ignore "$@"
  printf '\n'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
create_gitignore() {
  ignore_list "$@"
  printf '# gitignore created on %s\n' "$(date +'%D at %H:%M')" >"$GITIGNORE_CWD/.gitignore"
  fetch_ignore "$@" >>"$GITIGNORE_CWD/.gitignore"
  printf '\n' >>"$GITIGNORE_CWD/.gitignore"
  printf_green "Added $IGNORELIST to your .gitignore"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__list_ignores() {
  if am_i_online; then
    curl -q -LSs $GITIGNORE_URL/list
  else
    __list_ignores "$@"
  fi
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__update_files() {
  __message_bad() { printf_red "Failed to create $dir/${1:-$line}" && return 0 || return 1; }
  __message_good() { printf_green "Created ${1:-$line}" && return 0 || return 1; }
  local dir="$GITIGNORE_TEMPLATE_DIR"
  curl -q -LSs $GITIGNORE_URL/list | tr ',' ' ' | tr ' ' '\n' >"$GITIGNORE_TEMP_FILE"
  mkdir -p "$dir"
  printf_cyan "Retrieving the files from gitignore.io and saving"
  printf_cyan "them to $dir"
  cat "$GITIGNORE_TEMP_FILE" | while read line || [[ -n $line ]]; do
    fetch_file "$line" | grep -v -E '(^# .*$)|(^$)' >"$dir/$line" &&
      printf '\n' >>"$dir/$line" && __message_good "$line" || __message_bad "$line"
  done
  printf "# Disable reminder in prompt\nignoredirmessage\n\n" >"$dir/dirignore" &&
    __message_good "dirignore" || __message_bad "dirignore"
  if [ -f "$GITIGNORE_TEMP_FILE" ]; then
    rm "$GITIGNORE_TEMP_FILE"
  fi
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
GITIGNORE_LOG_DIR="${GITIGNORE_LOG_DIR:-$HOME/.local/log/gitignore}"
GITIGNORE_CACHE_DIR="${GITIGNORE_CACHE_DIR:-$HOME/.cache/gitignore}"
GITIGNORE_CONFIG_DIR="${GITIGNORE_CONFIG_DIR:-$HOME/.config/myscripts/gitignore}"
GITIGNORE_CONFIG_BACKUP_DIR="${GITIGNORE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/gitignore/backups}"
GITIGNORE_TEMP_DIR="${GITIGNORE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/gitignore}"
GITIGNORE_OPTIONS_DIR="${GITIGNORE_OPTIONS_DIR:-$HOME/.local/share/myscripts/gitignore/options}"
GITIGNORE_CONFIG_FILE="${GITIGNORE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
GITIGNORE_OUTPUT_COLOR="${GITIGNORE_OUTPUT_COLOR:-4}"
GITIGNORE_OUTPUT_COLOR_2="${GITIGNORE_OUTPUT_COLOR:-6}"
GITIGNORE_OUTPUT_COLOR_GOOD="${GITIGNORE_OUTPUT_COLOR_GOOD:-2}"
GITIGNORE_OUTPUT_COLOR_ERROR="${GITIGNORE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
GITIGNORE_GOOD_MESSAGE="${GITIGNORE_GOOD_MESSAGE:-Everything Went OK}"
GITIGNORE_ERROR_MESSAGE="${GITIGNORE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
GITIGNORE_NOTIFY_ENABLED="${GITIGNORE_NOTIFY_ENABLED:-yes}"
GITIGNORE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
GITIGNORE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$GITIGNORE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
GITIGNORE_TEMPLATE_DIR="${GITIGNORE_TEMPLATE_DIR:-$GITIGNORE_CONFIG_DIR/templates}"
GITIGNORE_URL="${GITIGNORE_URL:-https://www.toptal.com/developers/gitignore/api}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$GITIGNORE_CONFIG_DIR/$GITIGNORE_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$GITIGNORE_CONFIG_DIR/$GITIGNORE_CONFIG_FILE" ] && . "$GITIGNORE_CONFIG_DIR/$GITIGNORE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$GITIGNORE_LOG_DIR" ] || mkdir -p "$GITIGNORE_LOG_DIR" &>/dev/null
[ -d "$GITIGNORE_TEMP_DIR" ] || mkdir -p "$GITIGNORE_TEMP_DIR" &>/dev/null
[ -d "$GITIGNORE_CACHE_DIR" ] || mkdir -p "$GITIGNORE_CACHE_DIR" &>/dev/null
GITIGNORE_TEMP_FILE="${GITIGNORE_TEMP_FILE:-$(mktemp $GITIGNORE_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$GITIGNORE_TEMP_FILE" ] && [ -f "$GITIGNORE_TEMP_FILE" ] && rm -Rf "$GITIGNORE_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$GITIGNORE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${GITIGNORE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${GITIGNORE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${GITIGNORE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${GITIGNORE_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="f"
LONGOPTS="options,config,version,help,dir:,automated"
ARRAY="console update save add search list"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    GITIGNORE_CWD="$2"
    shift 2
    ;;
  --automated | -f)
    shift 1
    automated="Y"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash git curl || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -d "$1" ]; then
  GITIGNORE_CWD="$1"
  shift 1
elif [ "$1" = "-d" ] || [ "$1" = "-dir" ] || [ "$1" = "--dir" ]; then
  GITIGNORE_CWD="$2"
  __mkd "$GITIGNORE_CWD"
  shift 2
  [ -d "$GITIGNORE_CWD" ] || printf_exit "$GITIGNORE_CWD doesn't seem to be a directory"
else
  GITIGNORE_CWD="$PWD"
fi
if [ "$GITIGNORE_CWD" = "." ]; then GITIGNORE_CWD="$(__basedir ".")"; fi
GITIGNORE_CWD="$(__git_top_dir "$GITIGNORE_CWD" 2>/dev/null || echo "$GITIGNORE_CWD")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
list)
  shift 1
  __list_ignores | tr ',' ' ' | tr ' ' '\n' | printf_column $GITIGNORE_OUTPUT_COLOR
  ;;

search)
  shift 1
  __list_ignores | tr ',' ' ' | tr ' ' '\n' | grep -i "$@" | printf_column $GITIGNORE_OUTPUT_COLOR
  ;;

console)
  shift 1
  print_gitignore "$@" | printf_readline "5"
  exit
  ;;

update)
  shift 1
  __update_files
  ;;

save)
  shift 1
  create_gitignore "$@" && true || false
  exit $?
  ;;

add)
  shift 1
  ignore_list "$@"
  printf_green "Adding $IGNORELIST to:"
  printf_green "$GITIGNORE_CWD/.gitignore"
  fetch_ignore >>"$GITIGNORE_CWD/.gitignore" && true || false
  exit $?
  ;;

*)
  [ -n "$1" ] || __update_files
  ignore_overwrite "$@"
  [ $# -ne 0 ] && create_gitignore "$@" && true || false
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
