#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -xo pipefail && export DEBUGGING="true"
trap 'exitCode=${exitCode:-$?};[ -f "$HUE_TEMP_FILE" ] && rm -Rf "$HUE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : hue --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : hue
# @Description   : Manage hue lights
# @TODO          :
# @Other         :
# @Resource      : http://hkionline.net/posts/using-phillips-hue-from-the-command-line
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$HUE_CONFIG_DIR/$HUE_CONFIG_FILE"
  [ -d "$HUE_CONFIG_DIR" ] || mkdir -p "$HUE_CONFIG_DIR"
  [ -d "$HUE_CONFIG_BACKUP_DIR" ] || mkdir -p "$HUE_CONFIG_BACKUP_DIR"
  [ -f "$HUE_CONFIG_DIR/$HUE_CONFIG_FILE" ] &&
    cp -Rf "$HUE_CONFIG_DIR/$HUE_CONFIG_FILE" "$HUE_CONFIG_BACKUP_DIR/$HUE_CONFIG_FILE.$$"
  cat <<EOF >"$HUE_CONFIG_DIR/$HUE_CONFIG_FILE"
# Settings for hue
HUE_DEFAULT_DEVICE_NAME="${HUE_DEFAULT_DEVICE_NAME:-$HUE_DEFAULT_DEVICE}"
HUE_DEFAULT_GROUP="${HUE_DEFAULT_GROUP:-0}"
HUE_HUB_API_KEY="${HUE_ACCESS_TOKEN:-$HUE_HUB_API_KEY}"

# Notification settings
HUE_GOOD_MESSAGE="${HUE_GOOD_MESSAGE:-Everything Went OK}"
HUE_ERROR_MESSAGE="${HUE_ERROR_MESSAGE:-Well that didn\'t work}"
HUE_NOTIFY_ENABLED="${HUE_NOTIFY_ENABLED:-yes}"
HUE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
HUE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$HUE_NOTIFY_CLIENT_ICON}"

# Colorization settings
HUE_OUTPUT_COLOR="${HUE_OUTPUT_COLOR:-5}"
HUE_OUTPUT_COLOR_GOOD="${HUE_OUTPUT_COLOR_GOOD:-2}"
HUE_OUTPUT_COLOR_ERROR="${HUE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$HUE_CONFIG_DIR/$HUE_CONFIG_FILE" ]; then
    printf_green "Your config file for hue has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__getstate() { [ -f "$HUE_STATE_FILE" ] && cat "$HUE_STATE_FILE" || echo; }
__curlcmd() { curl --disable -LSsfk --connect-timeout 3 --retry 0 --fail "$@"; }
__curlapi() { __return_ok "$1" "$2" "$3" || __return_error "$4"; }
__return_ok() { __curlcmd -X PUT "$HUE_HUB_API/action" -d '{"'$1'": '$2'}' | grep -q success && printf_green "Telling $HUE_DEFAULT_DEVICE_NAME to $3"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__return_error() {
  printf_error "Failed to send the command ${1} to:"
  printf_error "$HUE_HUB_API"
  printf_newline "\n"
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
hue_on() {
  __curlapi "on" "true" "turn on the lights" "on" && echo on >"$HUE_STATE_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
hue_off() {
  __curlapi "on" "false" "turn off the lights" "off" && echo off >"$HUE_STATE_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
hue_toggle() {
  if [ "$(cat $HUE_STATE_FILE)" = on ]; then
    hue_off
  elif [ "$(cat $HUE_STATE_FILE)" = off ]; then
    hue_on
  else
    hue on
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
HUE_LOG_DIR="${HUE_LOG_DIR:-$HOME/.local/log/hue}"
HUE_CACHE_DIR="${HUE_CACHE_DIR:-$HOME/.cache/hue}"
HUE_CONFIG_DIR="${HUE_CONFIG_DIR:-$HOME/.config/myscripts/hue}"
HUE_CONFIG_BACKUP_DIR="${HUE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/hue/backups}"
HUE_TEMP_DIR="${HUE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/hue}"
HUE_OPTIONS_DIR="${HUE_OPTIONS_DIR:-$HOME/.local/share/myscripts/hue/options}"
HUE_TEMP_FILE="${HUE_TEMP_FILE:-$(mktemp $HUE_TEMP_DIR/XXXXXX 2>/dev/null)}"
HUE_CONFIG_FILE="${HUE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
HUE_OUTPUT_COLOR="${HUE_OUTPUT_COLOR:-4}"
HUE_OUTPUT_COLOR_2="${HUE_OUTPUT_COLOR:-6}"
HUE_OUTPUT_COLOR_GOOD="${HUE_OUTPUT_COLOR_GOOD:-2}"
HUE_OUTPUT_COLOR_ERROR="${HUE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
HUE_GOOD_MESSAGE="${HUE_GOOD_MESSAGE:-Everything Went OK}"
HUE_ERROR_MESSAGE="${HUE_ERROR_MESSAGE:-Well that didn\'t work}"
HUE_NOTIFY_ENABLED="${HUE_NOTIFY_ENABLED:-yes}"
HUE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
HUE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$HUE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
HUE_STATE_FILE="$HUE_CACHE_DIR/automate_hue"
HUE_DEFAULT_DEVICE_NAME="${HUE_DEFAULT_DEVICE_NAME:-$HUE_DEFAULT_DEVICE}"
HUE_DEFAULT_DEVICE="$(__hostname2ip ${HUE_HUB_DEVICE:-$HUE_DEFAULT_DEVICE_NAME})"
HUE_DEFAULT_GROUP="${HUE_DEFAULT_GROUP:-0}"
HUE_HUB_API_KEY="${HUE_ACCESS_TOKEN:-$HUE_HUB_API_KEY}"
HUE_HUB_API="${HUE_HUB_API:-http://$HUE_DEFAULT_DEVICE/api/$HUE_HUB_API_KEY/groups/$HUE_DEFAULT_GROUP}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$HUE_CONFIG_DIR/$HUE_CONFIG_FILE" ] && . "$HUE_CONFIG_DIR/$HUE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$HUE_LOG_DIR" ] || mkdir -p "$HUE_LOG_DIR" &>/dev/null
[ -d "$HUE_TEMP_DIR" ] || mkdir -p "$HUE_TEMP_DIR" &>/dev/null
[ -d "$HUE_CACHE_DIR" ] || mkdir -p "$HUE_CACHE_DIR" &>/dev/null
[ -s "$HUE_STATE_FILE" ] || echo on >"$HUE_STATE_FILE" 2>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$HUE_CONFIG_DIR/$HUE_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
[ -n "$HUE_HUB_API_KEY" ] || printf_exit "Please set your hue api key"
[ -n "${HUE_DEFAULT_DEVICE:-$2}" ] || printf_exit "Please enter the hostname of your hue hub"
[ -n "${HUE_DEFAULT_DEVICE:-$2}" ] || printf_exit "Please enter the the command you want to send to your hue"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    HUE_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$HUE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${HUE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${HUE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${HUE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${HUE_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
HUE_DEFAULT_DEVICE_NAME="${HUE_HUB_DEVICE:-${2:-$HUE_DEFAULT_DEVICE_NAME}}"
HUE_DEFAULT_DEVICE="$(__hostname2ip ${HUE_HUB_DEVICE:-${2:-$HUE_DEFAULT_DEVICE_NAME}})"
HUE_DEFAULT_GROUP="${HUE_DEFAULT_GROUP:-$3}"
HUE_HUB_API="${HUE_HUB_API:-http://$HUE_DEFAULT_DEVICE/api/$HUE_HUB_API_KEY/groups/$HUE_DEFAULT_GROUP}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
on | true | 0 | stop)
  hue_on
  ;;

off | false | 1 | play)
  hue_off
  ;;

toggle)
  hue_toggle
  ;;

state)
  case "$2" in

  text) echo -e "$(__getstate)" ;;

  json | *) echo -e '{"status":"'$(__getstate)'"}' ;;
  esac

  ;;

brightness | bright | b)
  shift 1
  opts="${1:-0}"
  shift
  [ "$opts" -gt "255" ] && printf_exit "Enter a number between 0 and 255"
  hue_on >/dev/null && __curlapi "bri" "$opts" "set the brightness to $opts" '{"bri": '"$opts"'}'
  ;;

sat | s)
  shift 1
  opts="${1:-0}"
  shift
  [ "$opts" -gt "255" ] && printf_exit "Enter a number between 0 and 255"
  hue_on >/dev/null && __curlapi "sat" "$opts" "set the saturation to $opts" '{"sat": '"$opts"'}'
  ;;

hue | h)
  shift 1
  opts="${1:-0}"
  shift
  hue_on >/dev/null && __curlapi "hue" "$opts" "set the hue to $opts" '{"hue": '"$opts"'}'
  ;;

effect | e)
  shift 1
  opts="${1:-0}"
  shift
  #curl -LSsq -X PUT "$HUE_HUB_API/action" -d '{"effect": "'$1'"}'
  hue_on >/dev/null && __curlapi "hue" "$opts" "set the effect to $opts" '{"effect": "'$opts'"}'
  ;;

info)
  printf_green "Getting info for group $HUE_DEFAULT_GROUP from $HUE_DEFAULT_DEVICE_NAME"
  __curlcmd "$HUE_HUB_API" | jq
  ;;

*)
  hue_toggle
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
