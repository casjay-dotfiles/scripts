#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$IFINSTALLED_TEMP_FILE" ] && rm -Rf "$IFINSTALLED_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : ifinstalled --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : ifinstalled
# @Description   : check if file exists and send notification if it does not
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Generating the config file in"
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "$IFINSTALLED_CONFIG_DIR/$IFINSTALLED_CONFIG_FILE"
  [ -d "$IFINSTALLED_CONFIG_DIR" ] || mkdir -p "$IFINSTALLED_CONFIG_DIR"
  [ -d "$IFINSTALLED_CONFIG_BACKUP_DIR" ] || mkdir -p "$IFINSTALLED_CONFIG_BACKUP_DIR"
  [ -f "$IFINSTALLED_CONFIG_DIR/$IFINSTALLED_CONFIG_FILE" ] &&
    cp -Rf "$IFINSTALLED_CONFIG_DIR/$IFINSTALLED_CONFIG_FILE" "$IFINSTALLED_CONFIG_BACKUP_DIR/$IFINSTALLED_CONFIG_FILE.$$"
  cat <<EOF >"$IFINSTALLED_CONFIG_DIR/$IFINSTALLED_CONFIG_FILE"
# Settings for ifinstalled

# Notification settings
IFINSTALLED_GOOD_MESSAGE="${IFINSTALLED_GOOD_MESSAGE:-Everything Went OK}"
IFINSTALLED_ERROR_MESSAGE="${IFINSTALLED_ERROR_MESSAGE:-Well that didn\'t work}"
IFINSTALLED_NOTIFY_ENABLED="${IFINSTALLED_NOTIFY_ENABLED:-yes}"
IFINSTALLED_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
IFINSTALLED_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$IFINSTALLED_NOTIFY_CLIENT_ICON}"

# Colorization settings
IFINSTALLED_OUTPUT_COLOR="${IFINSTALLED_OUTPUT_COLOR:-5}"
IFINSTALLED_OUTPUT_COLOR_GOOD="${IFINSTALLED_OUTPUT_COLOR_GOOD:-2}"
IFINSTALLED_OUTPUT_COLOR_ERROR="${IFINSTALLED_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$IFINSTALLED_CONFIG_DIR/$IFINSTALLED_CONFIG_FILE" ]; then
    [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Your config file for ifinstalled has been created"
    $APPNAME "$*" && exitCode=0 || exitCode=$?
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  exit ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__notinstalled() {
  local exitCode=0
  __notifications "📦 $1" "must be installed for this function."
  if ask_yes_no_question "Would you like to try to install $1?"; then
    if pkmgr silent install "$1"; then
      __notifications "📦 $1" "has been installed."
      exitCode=0
    else
      __notifications "📦 $1" "failed to install."
      exitCode=1
    fi
  else
    exitCode=1
  fi
  return ${exitCode:$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
IFINSTALLED_LOG_DIR="${IFINSTALLED_LOG_DIR:-$HOME/.local/log/ifinstalled}"
IFINSTALLED_CACHE_DIR="${IFINSTALLED_CACHE_DIR:-$HOME/.cache/ifinstalled}"
IFINSTALLED_CONFIG_DIR="${IFINSTALLED_CONFIG_DIR:-$HOME/.config/myscripts/ifinstalled}"
IFINSTALLED_CONFIG_BACKUP_DIR="${IFINSTALLED_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/ifinstalled/backups}"
IFINSTALLED_TEMP_DIR="${IFINSTALLED_TEMP_DIR:-$HOME/.local/tmp/system_scripts/ifinstalled}"
IFINSTALLED_OPTIONS_DIR="${IFINSTALLED_OPTIONS_DIR:-$HOME/.local/share/myscripts/ifinstalled/options}"
IFINSTALLED_TEMP_FILE="${IFINSTALLED_TEMP_FILE:-$(mktemp $IFINSTALLED_TEMP_DIR/XXXXXX 2>/dev/null)}"
IFINSTALLED_CONFIG_FILE="${IFINSTALLED_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
IFINSTALLED_OUTPUT_COLOR="${IFINSTALLED_OUTPUT_COLOR:-4}"
IFINSTALLED_OUTPUT_COLOR_2="${IFINSTALLED_OUTPUT_COLOR:-6}"
IFINSTALLED_OUTPUT_COLOR_GOOD="${IFINSTALLED_OUTPUT_COLOR_GOOD:-2}"
IFINSTALLED_OUTPUT_COLOR_ERROR="${IFINSTALLED_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
IFINSTALLED_GOOD_MESSAGE="${IFINSTALLED_GOOD_MESSAGE:-Everything Went OK}"
IFINSTALLED_ERROR_MESSAGE="${IFINSTALLED_ERROR_MESSAGE:-Well that didn\'t work}"
IFINSTALLED_NOTIFY_ENABLED="${IFINSTALLED_NOTIFY_ENABLED:-yes}"
IFINSTALLED_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
IFINSTALLED_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$IFINSTALLED_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$IFINSTALLED_CONFIG_DIR/$IFINSTALLED_CONFIG_FILE" ] && . "$IFINSTALLED_CONFIG_DIR/$IFINSTALLED_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$IFINSTALLED_LOG_DIR" ] || mkdir -p "$IFINSTALLED_LOG_DIR" &>/dev/null
[ -d "$IFINSTALLED_TEMP_DIR" ] || mkdir -p "$IFINSTALLED_TEMP_DIR" &>/dev/null
[ -d "$IFINSTALLED_CACHE_DIR" ] || mkdir -p "$IFINSTALLED_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$IFINSTALLED_CONFIG_DIR/$IFINSTALLED_CONFIG_FILE" ] || SHOW_CONFIG_MESSAGE=NO __gen_config "$*"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    IFINSTALLED_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$IFINSTALLED_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${IFINSTALLED_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${IFINSTALLED_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${IFINSTALLED_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${IFINSTALLED_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if cmd_exists "$1"; then
  exitCode+=0
else
  __notinstalled "$1" && exitCode+=0 || exitCode+=1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
