#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$IFTTT_TEMP_FILE" ] && rm -Rf "$IFTTT_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : ifttt --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : ifttt
# @Description   : if this then that script - https://ifttt.com/maker_webhooks/settings
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Generating the config file in"
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "$IFTTT_CONFIG_DIR/$IFTTT_CONFIG_FILE"
  [ -d "$IFTTT_CONFIG_DIR" ] || mkdir -p "$IFTTT_CONFIG_DIR"
  [ -d "$IFTTT_CONFIG_BACKUP_DIR" ] || mkdir -p "$IFTTT_CONFIG_BACKUP_DIR"
  [ -f "$IFTTT_CONFIG_DIR/$IFTTT_CONFIG_FILE" ] &&
    cp -Rf "$IFTTT_CONFIG_DIR/$IFTTT_CONFIG_FILE" "$IFTTT_CONFIG_BACKUP_DIR/$IFTTT_CONFIG_FILE.$$"
  cat <<EOF >"$IFTTT_CONFIG_DIR/$IFTTT_CONFIG_FILE"
# Settings for ifttt
IFTTT_DEFAULT_WEBHOOK="${IFTTT_DEFAULT_WEBHOOK:-shell}"
IFTTT_ACCESS_TOKEN="${IFTTT_ACCESS_TOKEN:-}"
IFTTT_SERVER_ADDRESS="${IFTTT_SERVER_ADDRESS:-https://maker.ifttt.com}"

# Notification settings
IFTTT_GOOD_MESSAGE="${IFTTT_GOOD_MESSAGE:-Everything Went OK}"
IFTTT_ERROR_MESSAGE="${IFTTT_ERROR_MESSAGE:-Well that didn\'t work}"
IFTTT_NOTIFY_ENABLED="${IFTTT_NOTIFY_ENABLED:-yes}"
IFTTT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
IFTTT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$IFTTT_NOTIFY_CLIENT_ICON}"

# Colorization settings
IFTTT_OUTPUT_COLOR="${IFTTT_OUTPUT_COLOR:-5}"
IFTTT_OUTPUT_COLOR_GOOD="${IFTTT_OUTPUT_COLOR_GOOD:-2}"
IFTTT_OUTPUT_COLOR_ERROR="${IFTTT_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$IFTTT_CONFIG_DIR/$IFTTT_CONFIG_FILE" ]; then
    [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Your config file for ifttt has been created"
    $APPNAME "$*" && exitCode=0 || exitCode=$?
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  exit ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__send() {
  if [ "$COMMANDS" = 2 ] || [ "$COMMANDS" = 3 ]; then
    data="{\"value1\": \"${webhook_value1:-$2}\", \"value2\": \"${webhook_value2:-$3}\"}"
  elif [ "$COMMANDS" = 4 ]; then
    data="{\"value1\": \"${webhook_value1:-$2}\", \"value2\": \"${webhook_value2:-$3}\", \"value3\": \"${webhook_value3:-$4}\"}"
  fi
  curl -q -LSs -X POST -H "Content-Type: application/json" -d "$data" \
    "$IFTTT_SERVER_ADDRESS/trigger/${webhook_name:-$1}/with/key/$IFTTT_ACCESS_TOKEN" | grep -q 'Congratulations!' &&
    return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
IFTTT_LOG_DIR="${IFTTT_LOG_DIR:-$HOME/.local/log/ifttt}"
IFTTT_CACHE_DIR="${IFTTT_CACHE_DIR:-$HOME/.cache/ifttt}"
IFTTT_CONFIG_DIR="${IFTTT_CONFIG_DIR:-$HOME/.config/myscripts/ifttt}"
IFTTT_CONFIG_BACKUP_DIR="${IFTTT_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/ifttt/backups}"
IFTTT_TEMP_DIR="${IFTTT_TEMP_DIR:-$HOME/.local/tmp/system_scripts/ifttt}"
IFTTT_OPTIONS_DIR="${IFTTT_OPTIONS_DIR:-$HOME/.local/share/myscripts/ifttt/options}"
IFTTT_TEMP_FILE="${IFTTT_TEMP_FILE:-$(mktemp $IFTTT_TEMP_DIR/XXXXXX 2>/dev/null)}"
IFTTT_CONFIG_FILE="${IFTTT_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
IFTTT_OUTPUT_COLOR="${IFTTT_OUTPUT_COLOR:-4}"
IFTTT_OUTPUT_COLOR_2="${IFTTT_OUTPUT_COLOR:-6}"
IFTTT_OUTPUT_COLOR_GOOD="${IFTTT_OUTPUT_COLOR_GOOD:-2}"
IFTTT_OUTPUT_COLOR_ERROR="${IFTTT_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
IFTTT_GOOD_MESSAGE="${IFTTT_GOOD_MESSAGE:-Everything Went OK}"
IFTTT_ERROR_MESSAGE="${IFTTT_ERROR_MESSAGE:-Well that didn\'t work}"
IFTTT_NOTIFY_ENABLED="${IFTTT_NOTIFY_ENABLED:-yes}"
IFTTT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
IFTTT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$IFTTT_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
IFTTT_ACCESS_TOKEN="${IFTTT_ACCESS_TOKEN:-}"
IFTTT_SERVER_ADDRESS="${IFTTT_SERVER_ADDRESS:-https://maker.ifttt.com}"
IFTTT_DEFAULT_WEBHOOK="${IFTTT_DEFAULT_WEBHOOK:-shell}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$IFTTT_CONFIG_DIR/$IFTTT_CONFIG_FILE" ] && . "$IFTTT_CONFIG_DIR/$IFTTT_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$IFTTT_LOG_DIR" ] || mkdir -p "$IFTTT_LOG_DIR" &>/dev/null
[ -d "$IFTTT_TEMP_DIR" ] || mkdir -p "$IFTTT_TEMP_DIR" &>/dev/null
[ -d "$IFTTT_CACHE_DIR" ] || mkdir -p "$IFTTT_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$IFTTT_CONFIG_DIR/$IFTTT_CONFIG_FILE" ] || SHOW_CONFIG_MESSAGE=NO __gen_config "$*"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    IFTTT_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$IFTTT_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${IFTTT_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${IFTTT_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${IFTTT_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${IFTTT_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash curl || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[ -n "$IFTTT_ACCESS_TOKEN" ] || __help
[ $# -lt 2 ] && __help
[[ $# -gt 4 ]] && printf_exit "To many options sent"
if [ $# = 3 ] || [ $# = 4 ]; then
  webhook_value1="$1"
  webhook_value2="$2"
  webhook_value3="$3"
  webhook_name="${4:-$IFTTT_DEFAULT_WEBHOOK}"
  COMMANDS=4
elif [ $# -lt 3 ]; then
  webhook_value1="$1"
  webhook_value2="$2"
  webhook_name="${3:-$IFTTT_DEFAULT_WEBHOOK}"
  COMMANDS=3
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if __send "$webhook_name"; then
  printf_green "Your message has been sent"
  exitCode=0
else
  printf_red "Failed to send your message"
  exitCode=1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
