#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$IMAGES_TEMP_FILE" ] && rm -Rf "$IMAGES_TEMP_FILE" &>/dev/null' EXIT
[ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# = 0 ]; } && TERMINAL_APP="TRUE" myterminal -e "$APPNAME" "$*" && { exit || exit 1; }
shopt -s extglob
trap '' SIGINT
trap '' SIGQUIT
trap '' SIGTSTP

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : images --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : images
# @Description   : open images
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Generating the config file in"
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "$IMAGES_CONFIG_DIR/$IMAGES_CONFIG_FILE"
  [ -d "$IMAGES_CONFIG_DIR" ] || mkdir -p "$IMAGES_CONFIG_DIR"
  [ -d "$IMAGES_CONFIG_BACKUP_DIR" ] || mkdir -p "$IMAGES_CONFIG_BACKUP_DIR"
  [ -f "$IMAGES_CONFIG_DIR/$IMAGES_CONFIG_FILE" ] &&
    cp -Rf "$IMAGES_CONFIG_DIR/$IMAGES_CONFIG_FILE" "$IMAGES_CONFIG_BACKUP_DIR/$IMAGES_CONFIG_FILE.$$"
  cat <<EOF >"$IMAGES_CONFIG_DIR/$IMAGES_CONFIG_FILE"
# Settings for images
IMAGES_COUNTDOWN_TIME="${IMAGES_COUNTDOWN_TIME:-3}"

# Notification settings
IMAGES_GOOD_MESSAGE="${IMAGES_GOOD_MESSAGE:-Everything Went OK}"
IMAGES_ERROR_MESSAGE="${IMAGES_ERROR_MESSAGE:-Well that didn\'t work}"
IMAGES_NOTIFY_ENABLED="${IMAGES_NOTIFY_ENABLED:-yes}"
IMAGES_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
IMAGES_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$IMAGES_NOTIFY_CLIENT_ICON}"

# Colorization settings
IMAGES_OUTPUT_COLOR="${IMAGES_OUTPUT_COLOR:-5}"
IMAGES_OUTPUT_COLOR_GOOD="${IMAGES_OUTPUT_COLOR_GOOD:-2}"
IMAGES_OUTPUT_COLOR_ERROR="${IMAGES_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$IMAGES_CONFIG_DIR/$IMAGES_CONFIG_FILE" ]; then
    [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Your config file for images has been created"
    exitCode=0
    exec $APPNAME "$*"
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
IMAGES_LOG_DIR="${IMAGES_LOG_DIR:-$HOME/.local/log/images}"
IMAGES_CACHE_DIR="${IMAGES_CACHE_DIR:-$HOME/.cache/images}"
IMAGES_CONFIG_DIR="${IMAGES_CONFIG_DIR:-$HOME/.config/myscripts/images}"
IMAGES_CONFIG_BACKUP_DIR="${IMAGES_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/images/backups}"
IMAGES_TEMP_DIR="${IMAGES_TEMP_DIR:-$HOME/.local/tmp/system_scripts/images}"
IMAGES_OPTIONS_DIR="${IMAGES_OPTIONS_DIR:-$HOME/.local/share/myscripts/images/options}"
IMAGES_TEMP_FILE="${IMAGES_TEMP_FILE:-$(mktemp $IMAGES_TEMP_DIR/XXXXXX 2>/dev/null)}"
IMAGES_CONFIG_FILE="${IMAGES_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
IMAGES_OUTPUT_COLOR="${IMAGES_OUTPUT_COLOR:-4}"
IMAGES_OUTPUT_COLOR_2="${IMAGES_OUTPUT_COLOR:-6}"
IMAGES_OUTPUT_COLOR_GOOD="${IMAGES_OUTPUT_COLOR_GOOD:-2}"
IMAGES_OUTPUT_COLOR_ERROR="${IMAGES_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
IMAGES_GOOD_MESSAGE="${IMAGES_GOOD_MESSAGE:-Everything Went OK}"
IMAGES_ERROR_MESSAGE="${IMAGES_ERROR_MESSAGE:-Well that didn\'t work}"
IMAGES_NOTIFY_ENABLED="${IMAGES_NOTIFY_ENABLED:-yes}"
IMAGES_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
IMAGES_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$IMAGES_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
IMAGES_COUNTDOWN_TIME="${IMAGES_COUNTDOWN_TIME:-3}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$IMAGES_CONFIG_DIR/$IMAGES_CONFIG_FILE" ] && . "$IMAGES_CONFIG_DIR/$IMAGES_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$IMAGES_LOG_DIR" ] || mkdir -p "$IMAGES_LOG_DIR" &>/dev/null
[ -d "$IMAGES_TEMP_DIR" ] || mkdir -p "$IMAGES_TEMP_DIR" &>/dev/null
[ -d "$IMAGES_CACHE_DIR" ] || mkdir -p "$IMAGES_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$IMAGES_CONFIG_DIR/$IMAGES_CONFIG_FILE" ] || SHOW_CONFIG_MESSAGE=NO __gen_config "$*"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    IMAGES_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$IMAGES_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${IMAGES_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${IMAGES_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${IMAGES_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${IMAGES_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -z "$DISPLAY" ]; then printf_exit "No display server found.......exiting $(sleep 2)"; fi
xine-ui() { xine || xine-ui || false; }

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
while :; do
  # show menu
  clear
  shift 1
  printf_newline "\n\n\n\n"
  printf_head "Image Menu"
  printf_green "a. launch gimp"
  printf_green "b. launch shotwell"
  printf_green "c. launch sxiv"
  printf_green "d. launch ristretto"
  printf_green "e. launch kphotoalbum"
  printf_green "f. launch gomephotos"
  printf_green "y. launch custom application"
  printf_green "z. or escape to Exit"
  printf_green "---------------------------------"
  printf_read_question_nt "6" "Enter your choice [a-z] : " "1" "main"
  printf_newline

  # take action
  case "$main" in

  a)
    shift 1
    __open_file_menus gimp "$@"
    ;;
  b)
    shift 1
    __open_file_menus shotwell "$@"
    ;;
  c)
    shift 1
    __open_file_menus sxiv "$@"
    ;;
  d)
    shift 1
    __open_file_menus ristretto "$@"
    ;;
  e)
    shift 1
    __open_file_menus kphotoalbum "$@"
    ;;
  f)
    shift 1
    __open_file_menus gomephotos "$@"
    ;;
  y)
    shift 1
    __custom_menus "$@"
    ;;
  $'\E' | $'\e' | z)
    shift 1
    clear
    break
    ;;
  *) shift ;;

  esac
  clear
  printf_newline "\n\n"
  printf_counter "$IMAGES_OUTPUT_COLOR" "$IMAGES_COUNTDOWN_TIME" "Re-loading menu in"
done
clear
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
