#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$IMPERIAL2METRIC_TEMP_FILE" ] && rm -Rf "$IMPERIAL2METRIC_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : imperial2metric --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : imperial2metric
# @Description   : convert Celcius to Fahrenheit
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Generating the config file in"
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "$IMPERIAL2METRIC_CONFIG_DIR/$IMPERIAL2METRIC_CONFIG_FILE"
  [ -d "$IMPERIAL2METRIC_CONFIG_DIR" ] || mkdir -p "$IMPERIAL2METRIC_CONFIG_DIR"
  [ -d "$IMPERIAL2METRIC_CONFIG_BACKUP_DIR" ] || mkdir -p "$IMPERIAL2METRIC_CONFIG_BACKUP_DIR"
  [ -f "$IMPERIAL2METRIC_CONFIG_DIR/$IMPERIAL2METRIC_CONFIG_FILE" ] &&
    cp -Rf "$IMPERIAL2METRIC_CONFIG_DIR/$IMPERIAL2METRIC_CONFIG_FILE" "$IMPERIAL2METRIC_CONFIG_BACKUP_DIR/$IMPERIAL2METRIC_CONFIG_FILE.$$"
  cat <<EOF >"$IMPERIAL2METRIC_CONFIG_DIR/$IMPERIAL2METRIC_CONFIG_FILE"
# Settings for imperial2metric
IMPERIAL2METRIC_EURO_RATE="${IMPERIAL2METRIC_EURO_RATE:-}"

# Notification settings
IMPERIAL2METRIC_GOOD_MESSAGE="${IMPERIAL2METRIC_GOOD_MESSAGE:-Everything Went OK}"
IMPERIAL2METRIC_ERROR_MESSAGE="${IMPERIAL2METRIC_ERROR_MESSAGE:-Well that didn\'t work}"
IMPERIAL2METRIC_NOTIFY_ENABLED="${IMPERIAL2METRIC_NOTIFY_ENABLED:-yes}"
IMPERIAL2METRIC_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
IMPERIAL2METRIC_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$IMPERIAL2METRIC_NOTIFY_CLIENT_ICON}"

# Colorization settings
IMPERIAL2METRIC_OUTPUT_COLOR="${IMPERIAL2METRIC_OUTPUT_COLOR:-5}"
IMPERIAL2METRIC_OUTPUT_COLOR_GOOD="${IMPERIAL2METRIC_OUTPUT_COLOR_GOOD:-2}"
IMPERIAL2METRIC_OUTPUT_COLOR_ERROR="${IMPERIAL2METRIC_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$IMPERIAL2METRIC_CONFIG_DIR/$IMPERIAL2METRIC_CONFIG_FILE" ]; then
    [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Your config file for imperial2metric has been created"
    exitCode=0
    exec $APPNAME "$*"
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__bc() { bc -q; }

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
IMPERIAL2METRIC_LOG_DIR="${IMPERIAL2METRIC_LOG_DIR:-$HOME/.local/log/imperial2metric}"
IMPERIAL2METRIC_CACHE_DIR="${IMPERIAL2METRIC_CACHE_DIR:-$HOME/.cache/imperial2metric}"
IMPERIAL2METRIC_CONFIG_DIR="${IMPERIAL2METRIC_CONFIG_DIR:-$HOME/.config/myscripts/imperial2metric}"
IMPERIAL2METRIC_CONFIG_BACKUP_DIR="${IMPERIAL2METRIC_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/imperial2metric/backups}"
IMPERIAL2METRIC_TEMP_DIR="${IMPERIAL2METRIC_TEMP_DIR:-$HOME/.local/tmp/system_scripts/imperial2metric}"
IMPERIAL2METRIC_OPTIONS_DIR="${IMPERIAL2METRIC_OPTIONS_DIR:-$HOME/.local/share/myscripts/imperial2metric/options}"
IMPERIAL2METRIC_TEMP_FILE="${IMPERIAL2METRIC_TEMP_FILE:-$(mktemp $IMPERIAL2METRIC_TEMP_DIR/XXXXXX 2>/dev/null)}"
IMPERIAL2METRIC_CONFIG_FILE="${IMPERIAL2METRIC_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
IMPERIAL2METRIC_OUTPUT_COLOR="${IMPERIAL2METRIC_OUTPUT_COLOR:-4}"
IMPERIAL2METRIC_OUTPUT_COLOR_2="${IMPERIAL2METRIC_OUTPUT_COLOR:-6}"
IMPERIAL2METRIC_OUTPUT_COLOR_GOOD="${IMPERIAL2METRIC_OUTPUT_COLOR_GOOD:-2}"
IMPERIAL2METRIC_OUTPUT_COLOR_ERROR="${IMPERIAL2METRIC_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
IMPERIAL2METRIC_GOOD_MESSAGE="${IMPERIAL2METRIC_GOOD_MESSAGE:-Everything Went OK}"
IMPERIAL2METRIC_ERROR_MESSAGE="${IMPERIAL2METRIC_ERROR_MESSAGE:-Well that didn\'t work}"
IMPERIAL2METRIC_NOTIFY_ENABLED="${IMPERIAL2METRIC_NOTIFY_ENABLED:-yes}"
IMPERIAL2METRIC_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
IMPERIAL2METRIC_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$IMPERIAL2METRIC_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
IMPERIAL2METRIC_EURO_RATE="${IMPERIAL2METRIC_EURO_RATE:-0.854824}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$IMPERIAL2METRIC_CONFIG_DIR/$IMPERIAL2METRIC_CONFIG_FILE" ] && . "$IMPERIAL2METRIC_CONFIG_DIR/$IMPERIAL2METRIC_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$IMPERIAL2METRIC_LOG_DIR" ] || mkdir -p "$IMPERIAL2METRIC_LOG_DIR" &>/dev/null
[ -d "$IMPERIAL2METRIC_TEMP_DIR" ] || mkdir -p "$IMPERIAL2METRIC_TEMP_DIR" &>/dev/null
[ -d "$IMPERIAL2METRIC_CACHE_DIR" ] || mkdir -p "$IMPERIAL2METRIC_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$IMPERIAL2METRIC_CONFIG_DIR/$IMPERIAL2METRIC_CONFIG_FILE" ] || SHOW_CONFIG_MESSAGE=NO __gen_config "$*"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY="dollars pounds miles yards feet inches f"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    IMPERIAL2METRIC_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$IMPERIAL2METRIC_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${IMPERIAL2METRIC_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${IMPERIAL2METRIC_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${IMPERIAL2METRIC_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${IMPERIAL2METRIC_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash bc || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
math="$2"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case $1 in
f)
  shift 1
  tf=$(echo "scale=2; ($math - 32) * 5/9" | __bc)
  message="$math fahrenheit is $tf celcius"
  printf_green "$message"
  __notifications "$message"
  ;;

inches)
  shift 1
  tf=$(echo "scale=2; ($math * 2.54)/1" | __bc)
  message="$math inches is $tf centimeters"
  printf_green "$message"
  __notifications "$message"
  ;;

feet)
  shift 1
  tf=$(echo "scale=2; ($math * 0.3048)/1" | __bc)
  message="$math feet is $tf meters"
  printf_green "$message"
  __notifications "$message"
  ;;

yards)
  shift 1
  tf=$(echo "scale=2; ($math*0.9144)/1" | __bc)
  message="$math yards is $tf meters"
  printf_green "$message"
  __notifications "$message"
  ;;

miles)
  shift 1
  tf=$(echo "scale=2; ($math * 1.609344)/1" | __bc)
  message="$math miles is $tf kilometer"
  printf_green "$message"
  __notifications "$message"
  ;;

pounds)
  shift 1
  tf=$(echo "scale=2; ($math * 0.4536)/1" | __bc)
  message="$math lbs is $tf kilograms"
  printf_green "$message"
  __notifications "$message"
  ;;

dollars)
  shift 1
  tf=$(echo "scale=2; ($math * $IMPERIAL2METRIC_EURO_RATE)/1" | __bc)
  message="$math dollars is $tf euros €"
  printf_green "$message"
  __notifications "$message"
  ;;

*)
  __help
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
