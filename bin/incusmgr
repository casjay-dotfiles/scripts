# @@Copyright        :  Copyright: (c) 2026 Jason Hempstead, Casjays Developments
# @@Created          :  Thursday, Feb 20, 2025 00:31 EST
# @@File             :  incusmgr
# @@Description      :  Incus container and VM manager
# @@Changelog        :  Rewrite: self-contained, no external function sourcing
# @@TODO             :
# @@Other            :
# @@Resource         :
# @@sudo/root        :  no
# @@Template         :  bash/system
# - - - - - - - - - - - - - - - - - - - - - - - - -
# shellcheck disable=SC1001,SC1003,SC2001,SC2003,SC2016,SC2031,SC2120,SC2155,SC2199,SC2317,SC2329
# - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="${0##*/}"
VERSION="202606021538-git"
USER="${SUDO_USER:-$USER}"
RUN_USER="${RUN_USER:-$USER}"
USER_HOME="${USER_HOME:-$HOME}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [ "$1" = "--debug" ]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap '__trap_exit' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Send output to /dev/null
__devnull() { "$@" &>/dev/null; return $?; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# See if the executable exists
__cmd_exists() {
  local exitCode=0
  [ -n "$1" ] || return 0
  for cmd in "$@"; do
    if builtin command -v "$cmd" &>/dev/null; then
      exitCode=$((exitCode + 0))
    else
      exitCode=$((exitCode + 1))
    fi
  done
  [ $exitCode -eq 0 ] || exitCode=3
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for a valid internet connection
__am_i_online() {
  local exitCode=0
  curl -q -LSsfI --max-time 2 --retry 1 "${1:-https://1.1.1.1}" 2>&1 | grep -qi 'server:.*cloudflare' || exitCode=4
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ "$(id -u)" -eq 0 ] || [ "$EUID" -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Colorization — respects NO_COLOR and --no-color
if [ -n "${NO_COLOR+x}" ] || [ "$SHOW_RAW" = "true" ]; then
  NC=""
  RESET=""
  printf_column() { tee | grep '^'; }
  printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
else
  printf_column() { tee | column -t; }
  printf_color() { printf "%b" "$(tput setaf "${2:-7}" 2>/dev/null)" "$1" "$(tput sgr0 2>/dev/null)"; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Color printf functions
printf_blue()     { printf_color "$1\n" 4; }
printf_cyan()     { printf_color "$1\n" 6; }
printf_green()    { printf_color "$1\n" 2; }
printf_yellow()   { printf_color "$1\n" 3; }
printf_red()      { printf_color "$1\n" 1; }
printf_purple()   { printf_color "$1\n" 5; }
printf_newline()  { printf '\n'; }
printf_readline() { printf '%s\n' "$(cat -)"; }
printf_exit()     { printf_red "${1:-fatal error}" && exit "${2:-1}"; }
printf_return()   { printf_red "${1:-error}" && return "${2:-1}"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Help section header helpers
__printf_head() { printf_blue "$1"; }
__printf_opts() { printf_purple "$1"; }
__printf_line() { printf_cyan "$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Output version
__version() { printf_cyan "$VERSION"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Trap: clean up temp files on exit
__trap_exit() {
  exitCode=${exitCode:-$?}
  [ -n "$INCUSMGR_TEMP_FILE" ] && [ -f "$INCUSMGR_TEMP_FILE" ] && rm -f "$INCUSMGR_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Sleep wrapper using read timeout (no subshell)
__sleep() { read -r -t "${1:-1}" _ </dev/null; :; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Incus wrapper — routes through configured binary, optional remote/project
__incus() {
  local bin="${INCUSMGR_INCUS_BIN:-incus}"
  if [ -n "$INCUSMGR_REMOTE" ]; then
    command "$bin" "$@" --project "${INCUSMGR_PROJECT:-default}"
  else
    command "$bin" "$@"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if an instance exists
__instance_exists() { __incus list -c n -f csv 2>/dev/null | grep -qx "$1" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if an instance is running
__instance_is_running() { __incus list -c n,s -f csv 2>/dev/null | grep -qx "$1,RUNNING" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if a storage pool exists
__storage_exists() { __incus storage list -f csv -c n 2>/dev/null | grep -qx "$1" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if a network exists
__network_exists() { __incus network list -f csv -c n 2>/dev/null | grep -qx "$1" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if a profile exists
__profile_exists() { __incus profile list -f csv -c n 2>/dev/null | grep -qx "$1" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Confirm a destructive action unless INCUSMGR_FORCE is set
__confirm() {
  local msg="${1:-Are you sure?}"
  [ "$INCUSMGR_FORCE" = "true" ] && return 0
  printf_yellow "$msg [y/N] "
  read -r yn </dev/tty
  case "$yn" in
  [yY]*) return 0 ;;
  *) printf_red "Aborted" && return 1 ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Delete all instances, all volumes from all pools, and all images
__prune_all() {
  local incus_list pool volume incus_images count=0

  printf_purple "========================================="
  printf_cyan "Starting full prune..."
  printf_purple "========================================="

  incus_list="$(__incus list -c n --format csv 2>/dev/null)"
  if [ -n "$incus_list" ]; then
    printf_yellow "Deleting instances..."
    for c in $incus_list; do
      printf_cyan "  Deleting instance: $c"
      __incus delete --force "$c" 2>/dev/null \
        && printf_green "  ✓ Deleted: $c" \
        || printf_red "  ✗ Failed to delete: $c"
      count=$((count + 1))
    done
    printf_green "Deleted $count instance(s)"
    count=0
  else
    printf_blue "No instances found"
  fi

  printf_yellow "Deleting storage volumes..."
  for pool in $(__incus storage list -c n --format csv 2>/dev/null); do
    for volume in $(__incus storage volume list "$pool" -c n --format csv 2>/dev/null); do
      printf_cyan "  Deleting volume: $pool/$volume"
      __incus storage volume delete "$pool" "$volume" 2>/dev/null \
        && printf_green "  ✓ Deleted: $pool/$volume" \
        || printf_red "  ✗ Failed: $pool/$volume"
      count=$((count + 1))
    done
  done
  [ $count -gt 0 ] && printf_green "Deleted $count volume(s)" || printf_blue "No volumes found"
  count=0

  incus_images="$(__incus image list -c f --format csv 2>/dev/null)"
  if [ -n "$incus_images" ]; then
    printf_yellow "Deleting images..."
    for i in $incus_images; do
      printf_cyan "  Deleting image: $i"
      __incus image delete "$i" 2>/dev/null \
        && printf_green "  ✓ Deleted: $i" \
        || printf_red "  ✗ Failed: $i"
      count=$((count + 1))
    done
    printf_green "Deleted $count image(s)"
  else
    printf_blue "No images found"
  fi

  printf_purple "========================================="
  printf_green "Prune complete"
  printf_purple "========================================="
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Delete all instances only
__prune_instances() {
  local instances count=0
  instances="$(__incus list -c n -f csv 2>/dev/null)"
  if [ -n "$instances" ]; then
    printf_yellow "Deleting instances..."
    while IFS= read -r instance; do
      [ -z "$instance" ] && continue
      printf_cyan "  Deleting: $instance"
      __incus delete "$instance" --force &>/dev/null \
        && printf_green "  ✓ Deleted $instance" \
        || printf_red "  ✗ Failed to delete $instance"
      count=$((count + 1))
    done <<<"$instances"
    printf_green "Deleted $count instance(s)"
  else
    printf_yellow "No instances to remove"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Delete volumes from all storage pools
__prune_volumes() {
  local pool volume count=0
  printf_yellow "Deleting storage volumes..."
  for pool in $(__incus storage list -c n --format csv 2>/dev/null); do
    for volume in $(__incus storage volume list "$pool" -c n --format csv 2>/dev/null); do
      printf_cyan "  Deleting: $pool/$volume"
      __incus storage volume delete "$pool" "$volume" &>/dev/null \
        && printf_green "  ✓ Deleted $pool/$volume" \
        || printf_red "  ✗ Failed $pool/$volume"
      count=$((count + 1))
    done
  done
  [ $count -gt 0 ] && printf_green "Deleted $count volume(s)" || printf_yellow "No volumes to remove"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Delete all images
__prune_images() {
  local images count=0
  images="$(__incus image list -c f -f csv 2>/dev/null)"
  if [ -n "$images" ]; then
    printf_yellow "Deleting images..."
    while IFS= read -r fingerprint; do
      [ -z "$fingerprint" ] && continue
      printf_cyan "  Deleting: $fingerprint"
      __incus image delete "$fingerprint" &>/dev/null \
        && printf_green "  ✓ Deleted $fingerprint" \
        || printf_red "  ✗ Failed $fingerprint"
      count=$((count + 1))
    done <<<"$images"
    printf_green "Deleted $count image(s)"
  else
    printf_yellow "No images to remove"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Update packages inside one or all running instances
__update_instances() {
  local targets name
  if [ -n "$1" ]; then
    targets="$1"
  else
    targets="$(__incus list -c n,s --format csv 2>/dev/null | grep ',RUNNING' | cut -d',' -f1)"
  fi
  [ -n "$targets" ] || { printf_yellow "No running instances to update"; return 0; }
  for name in $targets; do
    if __instance_is_running "$name"; then
      printf_cyan "Updating $name..."
      __incus exec "$name" -- sh -c \
        'command -v apt-get >/dev/null 2>&1 && apt-get update -qq && apt-get upgrade -y ||
         command -v dnf     >/dev/null 2>&1 && dnf upgrade -y ||
         command -v apk     >/dev/null 2>&1 && apk upgrade ||
         echo "No supported package manager found"' \
        && printf_green "Updated $name" \
        || printf_red "Failed to update $name"
    else
      printf_yellow "Skipping $name (not running)"
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__show_status() {
  if __incus list &>/dev/null; then
    printf_green "✓ Incus daemon is running"
    printf_newline
    printf_cyan "Instances:"
    __incus list 2>/dev/null || printf_yellow "No instances"
    printf_newline
    printf_cyan "Storage pools:"
    __incus storage list 2>/dev/null || printf_yellow "No storage pools"
    printf_newline
    printf_cyan "Networks:"
    __incus network list 2>/dev/null || printf_yellow "No networks"
  else
    printf_red "✗ Incus daemon is not running or not accessible"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__show_network_info() {
  local network="${1:-$INCUSMGR_DEFAULT_NETWORK}"
  if ! __network_exists "$network"; then
    printf_exit "Network '$network' does not exist"
  fi
  printf_cyan "Network: $network"
  __incus network show "$network" 2>/dev/null
  printf_newline
  printf_cyan "Instances on $network:"
  __incus list -c ns4 2>/dev/null || printf_yellow "No instances"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [ "$INIT_CONFIG" = "TRUE" ] || printf_green "Generating config: $INCUSMGR_CONFIG_DIR/$INCUSMGR_CONFIG_FILE"
  [ -d "$INCUSMGR_CONFIG_DIR" ] || mkdir -p "$INCUSMGR_CONFIG_DIR"
  [ -d "$INCUSMGR_CONFIG_BACKUP_DIR" ] || mkdir -p "$INCUSMGR_CONFIG_BACKUP_DIR"
  [ -f "$INCUSMGR_CONFIG_DIR/$INCUSMGR_CONFIG_FILE" ] &&
    cp -Rf "$INCUSMGR_CONFIG_DIR/$INCUSMGR_CONFIG_FILE" "$INCUSMGR_CONFIG_BACKUP_DIR/$INCUSMGR_CONFIG_FILE.$$"
  cat <<EOF >"$INCUSMGR_CONFIG_DIR/$INCUSMGR_CONFIG_FILE"
# incusmgr settings
INCUSMGR_INCUS_BIN="${INCUSMGR_INCUS_BIN:-incus}"
INCUSMGR_DEFAULT_STORAGE="${INCUSMGR_DEFAULT_STORAGE:-default}"
INCUSMGR_DEFAULT_NETWORK="${INCUSMGR_DEFAULT_NETWORK:-incusbr0}"
INCUSMGR_DEFAULT_PROFILE="${INCUSMGR_DEFAULT_PROFILE:-default}"
INCUSMGR_REMOTE="${INCUSMGR_REMOTE:-}"
INCUSMGR_PROJECT="${INCUSMGR_PROJECT:-}"
EOF
  if [ -f "$INCUSMGR_CONFIG_DIR/$INCUSMGR_CONFIG_FILE" ]; then
    [ "$INIT_CONFIG" = "TRUE" ] || printf_green "Config created"
    return 0
  else
    printf_red "Failed to create config"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__init() {
  __cmd_exists incus || printf_exit "incus is not installed"
  if ! __incus list &>/dev/null; then
    printf_cyan "Initializing Incus..."
    if __incus admin init --auto &>/dev/null; then
      printf_green "Incus initialized successfully"
    else
      printf_red "Failed to initialize Incus"
      return 1
    fi
  else
    printf_green "Incus is already initialized"
  fi
  __gen_config
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__help() {
  __printf_head "##################################################"
  __printf_head "####               incusmgr                  ####"
  __printf_head "##################################################"
  printf_newline
  __printf_opts "Usage: $APPNAME [options] <command> [args]"
  printf_newline
  __printf_head "------------ Instance Commands -------------------"
  __printf_line "list [filter]                          - List all instances"
  __printf_line "ps                                     - List running instances"
  __printf_line "inactive                               - List stopped instances"
  __printf_line "info <name>                            - Show detailed instance info"
  __printf_line "status [name]                          - Show instance or overall status"
  __printf_line "start <name>                           - Start an instance"
  __printf_line "stop <name>                            - Stop an instance"
  __printf_line "restart <name>                         - Restart an instance"
  __printf_line "launch <image> [name]                  - Create and start an instance"
  __printf_line "init <image> [name]                    - Create (do not start) an instance"
  __printf_line "install <image> [name]                 - Alias for launch"
  __printf_line "delete <name> [--force]                - Delete an instance"
  __printf_line "rm <name> [--force]                    - Alias for delete"
  __printf_line "remove <name>                          - Alias for delete"
  __printf_line "copy <src> <dst>                       - Copy/clone an instance"
  __printf_line "rename <old> <new>                     - Rename an instance"
  __printf_line "move <src> <dst>                       - Move an instance"
  printf_newline
  __printf_head "------------ Interaction -------------------------"
  __printf_line "exec <name> [cmd]                      - Run command in instance (default: bash)"
  __printf_line "enter <name>                           - Enter instance shell (starts if stopped)"
  __printf_line "shell <name>                           - Alias for enter"
  __printf_line "console <name>                         - Attach to instance console"
  __printf_line "log <name>                             - Show instance log output"
  __printf_line "update [name]                          - Update packages in instance(s)"
  printf_newline
  __printf_head "------------ Snapshot Commands -------------------"
  __printf_line "snapshot <name> [snap]                 - Create a snapshot"
  __printf_line "restore <name> <snap>                  - Restore a snapshot"
  __printf_line "snapshots <name>                       - List snapshots for an instance"
  __printf_line "delsnapshot <name> <snap>              - Delete a snapshot"
  printf_newline
  __printf_head "------------ Image Commands ----------------------"
  __printf_line "image list [remote:]                   - List images"
  __printf_line "image info <image>                     - Show image information"
  __printf_line "image delete <fp>                      - Delete an image by fingerprint"
  __printf_line "image copy <src> <dst>                 - Copy image between remotes"
  __printf_line "remote list                            - List configured remotes"
  __printf_line "remote add <name> <url>                - Add a remote"
  __printf_line "remote remove <name>                   - Remove a remote"
  printf_newline
  __printf_head "------------ Network / Storage / Profile ---------"
  __printf_line "network [list|show|create|delete] [name]"
  __printf_line "storage [list|show|create|delete] [pool]"
  __printf_line "volume list <pool>                     - List storage volumes in a pool"
  __printf_line "profile [list|show|create|delete] [name]"
  __printf_line "project [list|show] [name]             - Manage projects"
  printf_newline
  __printf_head "------------ Maintenance -------------------------"
  __printf_line "init [force]                           - Initialize Incus environment"
  __printf_line "prune                                  - Delete all instances, volumes, and images"
  __printf_line "prune instances                        - Delete all instances"
  __printf_line "prune volumes                          - Delete all storage volumes (all pools)"
  __printf_line "prune images                           - Delete all images"
  __printf_line "prune all                              - Alias for bare prune"
  printf_newline
  __printf_head "------------ Options -----------------------------"
  __printf_opts "  --force / -f                  - Skip confirmation prompts"
  __printf_opts "  --no-color                    - Disable color output"
  __printf_opts "  --debug                       - Enable bash -x tracing"
  __printf_opts "  --config                      - Generate/reset config file"
  __printf_opts "  --version                     - Show version"
  __printf_opts "  --help                        - Show this message"
  printf_newline
  __printf_head "------------ Examples ----------------------------"
  __printf_line "incusmgr launch images:ubuntu/22.04 mybox"
  __printf_line "incusmgr enter mybox"
  __printf_line "incusmgr update mybox"
  __printf_line "incusmgr snapshot mybox before-upgrade"
  __printf_line "incusmgr prune --force"
  printf_newline
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Config / environment defaults
INCUSMGR_CONFIG_DIR="${INCUSMGR_CONFIG_DIR:-$HOME/.config/myscripts/incusmgr}"
INCUSMGR_CONFIG_BACKUP_DIR="${INCUSMGR_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/incusmgr/backups}"
INCUSMGR_CONFIG_FILE="${INCUSMGR_CONFIG_FILE:-settings.conf}"
INCUSMGR_LOG_DIR="${INCUSMGR_LOG_DIR:-$HOME/.local/log/incusmgr}"
INCUSMGR_CACHE_DIR="${INCUSMGR_CACHE_DIR:-$HOME/.cache/incusmgr}"
INCUSMGR_TEMP_DIR="${INCUSMGR_TEMP_DIR:-$HOME/.local/tmp/system_scripts/incusmgr}"
INCUSMGR_INCUS_BIN="${INCUSMGR_INCUS_BIN:-incus}"
INCUSMGR_DEFAULT_STORAGE="${INCUSMGR_DEFAULT_STORAGE:-default}"
INCUSMGR_DEFAULT_NETWORK="${INCUSMGR_DEFAULT_NETWORK:-incusbr0}"
INCUSMGR_DEFAULT_PROFILE="${INCUSMGR_DEFAULT_PROFILE:-default}"
INCUSMGR_REMOTE="${INCUSMGR_REMOTE:-}"
INCUSMGR_PROJECT="${INCUSMGR_PROJECT:-}"
INCUSMGR_FORCE="false"
exitCode=0
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Bootstrap dirs and config
[ -d "$INCUSMGR_LOG_DIR" ]   || mkdir -p "$INCUSMGR_LOG_DIR"   &>/dev/null
[ -d "$INCUSMGR_TEMP_DIR" ]  || mkdir -p "$INCUSMGR_TEMP_DIR"  &>/dev/null
[ -d "$INCUSMGR_CACHE_DIR" ] || mkdir -p "$INCUSMGR_CACHE_DIR" &>/dev/null
[ -f "$INCUSMGR_CONFIG_DIR/$INCUSMGR_CONFIG_FILE" ] || [ "$*" = "--config" ] || INIT_CONFIG="TRUE" __gen_config
[ -f "$INCUSMGR_CONFIG_DIR/$INCUSMGR_CONFIG_FILE" ] && . "$INCUSMGR_CONFIG_DIR/$INCUSMGR_CONFIG_FILE"
INCUSMGR_TEMP_FILE="$(mktemp "$INCUSMGR_TEMP_DIR/XXXXXX" 2>/dev/null)"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Require incus
__cmd_exists incus || printf_exit "incus is not installed or not in PATH"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Parse global flags before main dispatch
SHORTOPTS="fhv"
LONGOPTS="force,help,version,config,debug,no-color"
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --no-color)
    shift 1
    export SHOW_RAW="true"
    ;;
  --debug)
    shift 1
    set -xo pipefail
    export SCRIPT_OPTS="--debug" _DEBUG="on"
    ;;
  -f | --force)
    shift 1
    INCUSMGR_FORCE="true"
    ;;
  -h | --help)
    shift 1
    __help
    exit 0
    ;;
  -v | --version)
    shift 1
    __version
    exit 0
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Main command dispatcher
case "$1" in
# ---- List / status -------------------------------------------------------
list | ls)
  shift 1
  __incus list "$@"
  exit $?
  ;;

ps | active)
  shift 1
  __incus list --filter status=running "$@"
  exit $?
  ;;

inactive | stopped)
  shift 1
  __incus list --filter status=stopped "$@"
  exit $?
  ;;

status)
  shift 1
  if [ -n "$1" ]; then
    __incus info "$1"
  else
    __show_status
  fi
  exit $?
  ;;

info)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME info <name>"
  __incus info "$@"
  exit $?
  ;;

version)
  shift 1
  __incus version
  exit $?
  ;;

# ---- Lifecycle -----------------------------------------------------------
start)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME start <name>"
  __incus start "$@"
  exit $?
  ;;

stop)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME stop <name>"
  __incus stop "$@"
  exit $?
  ;;

restart)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME restart <name>"
  __incus restart "$@"
  exit $?
  ;;

# ---- Create / delete -----------------------------------------------------
launch | install | run)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME launch <image> [name]"
  printf_cyan "Launching from ${1}..."
  __incus launch "$@" && printf_green "Launched" || printf_exit "Failed to launch"
  exit $?
  ;;

init)
  shift 1
  if [ "$1" = "force" ] || [ "$1" = "setup" ] || [ $# -eq 0 ]; then
    __init
  else
    printf_cyan "Initializing from ${1} (not started)..."
    __incus init "$@" && printf_green "Initialized" || printf_exit "Failed to init"
  fi
  exit $?
  ;;

delete | rm | remove)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME delete <name> [--force]"
  name="$1"
  shift 1
  if [ "$1" = "--force" ] || [ "$INCUSMGR_FORCE" = "true" ]; then
    __incus delete --force "$name" && printf_green "Deleted $name" || printf_exit "Failed to delete $name"
  else
    __confirm "Delete instance '$name'?" || exit 0
    __incus delete "$name" && printf_green "Deleted $name" || printf_exit "Failed to delete $name (try --force if running)"
  fi
  exit $?
  ;;

copy | clone)
  shift 1
  [ $# -lt 2 ] && printf_exit "Usage: $APPNAME copy <src> <dst>"
  __incus copy "$@" && printf_green "Copied $1 to $2" || printf_exit "Failed to copy"
  exit $?
  ;;

rename | mv)
  shift 1
  [ $# -ne 2 ] && printf_exit "Usage: $APPNAME rename <old> <new>"
  __incus rename "$@" && printf_green "Renamed $1 to $2" || printf_exit "Failed to rename"
  exit $?
  ;;

move)
  shift 1
  [ $# -lt 2 ] && printf_exit "Usage: $APPNAME move <src> <dst>"
  __incus move "$@" && printf_green "Moved" || printf_exit "Failed to move"
  exit $?
  ;;

# ---- Interaction ---------------------------------------------------------
exec)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME exec <name> [cmd]"
  instance="$1"
  shift 1
  cmd="${*:-bash}"
  if __instance_exists "$instance" && __instance_is_running "$instance"; then
    __incus exec "$instance" -- $cmd
  else
    printf_exit "Instance '$instance' does not exist or is not running"
  fi
  exit $?
  ;;

enter | shell)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME enter <name>"
  instance="$1"
  shift 1
  if __instance_exists "$instance"; then
    if ! __instance_is_running "$instance"; then
      printf_cyan "Starting $instance..."
      __incus start "$instance" &>/dev/null
      __sleep 2
    fi
    __incus exec "$instance" -- /bin/bash 2>/dev/null || __incus exec "$instance" -- /bin/sh
  else
    printf_exit "Instance '$instance' does not exist"
  fi
  exit $?
  ;;

console)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME console <name>"
  __incus console "$1"
  exit $?
  ;;

log | logs)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME log <name>"
  __incus console "$1" --show-log
  exit $?
  ;;

update)
  shift 1
  __update_instances "${1:-}"
  exit $?
  ;;

# ---- Snapshots -----------------------------------------------------------
snapshot)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME snapshot <name> [snap]"
  __incus snapshot "$@"
  exit $?
  ;;

restore)
  shift 1
  [ $# -lt 2 ] && printf_exit "Usage: $APPNAME restore <name> <snap>"
  __confirm "Restore $1 to snapshot '$2'?" || exit 0
  __incus restore "$@" && printf_green "Restored $1 to $2" || printf_exit "Failed to restore"
  exit $?
  ;;

snapshots)
  shift 1
  [ $# -eq 0 ] && printf_exit "Usage: $APPNAME snapshots <name>"
  __incus info "$1" | grep -A999 '^Snapshots:'
  exit $?
  ;;

delsnapshot)
  shift 1
  [ $# -lt 2 ] && printf_exit "Usage: $APPNAME delsnapshot <name> <snap>"
  __incus delete "${1}/${2}" && printf_green "Deleted snapshot $2" || printf_exit "Failed to delete snapshot"
  exit $?
  ;;

# ---- Images --------------------------------------------------------------
image)
  shift 1
  case "${1:-list}" in
  list | ls)   shift 1 ; __incus image list "$@" ;;
  info | show) shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME image info <image>" ; __incus image info "$@" ;;
  delete | rm) shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME image delete <fp>" ; __incus image delete "$@" ;;
  copy | cp)   shift 1 ; [ $# -lt 2 ] && printf_exit "Usage: $APPNAME image copy <src> <dst>" ; __incus image copy "$@" ;;
  *)           __incus image "$@" ;;
  esac
  exit $?
  ;;

remote)
  shift 1
  case "${1:-list}" in
  list | ls)     shift 1 ; __incus remote list ;;
  add)           shift 1 ; [ $# -lt 2 ] && printf_exit "Usage: $APPNAME remote add <name> <url>" ; __incus remote add "$@" ;;
  remove | rm)   shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME remote remove <name>" ; __incus remote remove "$@" ;;
  *)             __incus remote "$@" ;;
  esac
  exit $?
  ;;

# ---- Network / Storage / Profile / Project -------------------------------
network)
  shift 1
  case "${1:-list}" in
  list | ls)     shift 1 ; __incus network list ;;
  show | info)   shift 1 ; [ $# -eq 0 ] && __show_network_info "$INCUSMGR_DEFAULT_NETWORK" || __show_network_info "$1" ;;
  create)        shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME network create <name>" ; __incus network create "$@" ;;
  delete | rm)   shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME network delete <name>" ; __incus network delete "$@" ;;
  *)             __incus network "$@" ;;
  esac
  exit $?
  ;;

storage)
  shift 1
  case "${1:-list}" in
  list | ls)     shift 1 ; __incus storage list ;;
  show | info)   shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME storage show <pool>" ; __incus storage show "$@" ;;
  create)        shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME storage create <name>" ; __incus storage create "$@" ;;
  delete | rm)   shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME storage delete <name>" ; __incus storage delete "$@" ;;
  *)             __incus storage "$@" ;;
  esac
  exit $?
  ;;

volume)
  shift 1
  case "${1:-list}" in
  list)
    shift 1
    [ $# -eq 0 ] && printf_exit "Usage: $APPNAME volume list <pool>"
    __incus storage volume list "$@"
    ;;
  *)
    __incus storage volume "$@"
    ;;
  esac
  exit $?
  ;;

profile)
  shift 1
  case "${1:-list}" in
  list | ls)     shift 1 ; __incus profile list ;;
  show | info)   shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME profile show <name>" ; __incus profile show "$@" ;;
  create)        shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME profile create <name>" ; __incus profile create "$@" ;;
  delete | rm)   shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME profile delete <name>" ; __incus profile delete "$@" ;;
  *)             __incus profile "$@" ;;
  esac
  exit $?
  ;;

project)
  shift 1
  case "${1:-list}" in
  list | ls)     shift 1 ; __incus project list ;;
  show | info)   shift 1 ; [ $# -eq 0 ] && printf_exit "Usage: $APPNAME project show <name>" ; __incus project show "$@" ;;
  *)             __incus project "$@" ;;
  esac
  exit $?
  ;;

# ---- Maintenance ---------------------------------------------------------
prune)
  shift 1
  [ "$1" = "--force" ] && INCUSMGR_FORCE="true" && shift 1
  case "${1:-all}" in
  instances | containers)
    __confirm "Delete all instances?" || exit 0
    __prune_instances
    ;;
  volumes | storage)
    __confirm "Delete all storage volumes?" || exit 0
    __prune_volumes
    ;;
  images)
    __confirm "Delete all images?" || exit 0
    __prune_images
    ;;
  all | "")
    __confirm "Delete ALL instances, volumes, and images?" || exit 0
    __prune_all
    ;;
  *)
    printf_exit "Usage: $APPNAME prune [instances|volumes|images|all]"
    ;;
  esac
  exit $?
  ;;

# ---- Config --------------------------------------------------------------
config)
  shift 1
  __gen_config
  exit $?
  ;;

# ---- Catch-all -----------------------------------------------------------
help | --help | -h | "")
  __help
  exit 0
  ;;

*)
  if [ $# -ne 0 ]; then
    __incus "$@"
  else
    __help
  fi
  exit $?
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
exit ${exitCode:-0}
# - - - - - - - - - - - - - - - - - - - - - - - - -
