#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$KILLZOMBIES_TEMP_FILE" ] && rm -Rf "$KILLZOMBIES_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : killzombies --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : killzombies
# @Description   : kill zombie proccesses
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$KILLZOMBIES_CONFIG_DIR/$KILLZOMBIES_CONFIG_FILE"
  [ -d "$KILLZOMBIES_CONFIG_DIR" ] || mkdir -p "$KILLZOMBIES_CONFIG_DIR"
  [ -d "$KILLZOMBIES_CONFIG_BACKUP_DIR" ] || mkdir -p "$KILLZOMBIES_CONFIG_BACKUP_DIR"
  [ -f "$KILLZOMBIES_CONFIG_DIR/$KILLZOMBIES_CONFIG_FILE" ] &&
    cp -Rf "$KILLZOMBIES_CONFIG_DIR/$KILLZOMBIES_CONFIG_FILE" "$KILLZOMBIES_CONFIG_BACKUP_DIR/$KILLZOMBIES_CONFIG_FILE.$$"
  cat <<EOF >"$KILLZOMBIES_CONFIG_DIR/$KILLZOMBIES_CONFIG_FILE"
# Settings for killzombies

# Notification settings
KILLZOMBIES_GOOD_MESSAGE="${KILLZOMBIES_GOOD_MESSAGE:-Everything Went OK}"
KILLZOMBIES_ERROR_MESSAGE="${KILLZOMBIES_ERROR_MESSAGE:-Well that didn\'t work}"
KILLZOMBIES_NOTIFY_ENABLED="${KILLZOMBIES_NOTIFY_ENABLED:-yes}"
KILLZOMBIES_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
KILLZOMBIES_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$KILLZOMBIES_NOTIFY_CLIENT_ICON}"

# Colorization settings
KILLZOMBIES_OUTPUT_COLOR="${KILLZOMBIES_OUTPUT_COLOR:-5}"
KILLZOMBIES_OUTPUT_COLOR_GOOD="${KILLZOMBIES_OUTPUT_COLOR_GOOD:-2}"
KILLZOMBIES_OUTPUT_COLOR_ERROR="${KILLZOMBIES_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$KILLZOMBIES_CONFIG_DIR/$KILLZOMBIES_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for killzombies has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
KILLZOMBIES_LOG_DIR="${KILLZOMBIES_LOG_DIR:-$HOME/.local/log/killzombies}"
KILLZOMBIES_CACHE_DIR="${KILLZOMBIES_CACHE_DIR:-$HOME/.cache/killzombies}"
KILLZOMBIES_CONFIG_DIR="${KILLZOMBIES_CONFIG_DIR:-$HOME/.config/myscripts/killzombies}"
KILLZOMBIES_CONFIG_BACKUP_DIR="${KILLZOMBIES_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/killzombies/backups}"
KILLZOMBIES_TEMP_DIR="${KILLZOMBIES_TEMP_DIR:-$HOME/.local/tmp/system_scripts/killzombies}"
KILLZOMBIES_OPTIONS_DIR="${KILLZOMBIES_OPTIONS_DIR:-$HOME/.local/share/myscripts/killzombies/options}"
KILLZOMBIES_TEMP_FILE="${KILLZOMBIES_TEMP_FILE:-$(mktemp $KILLZOMBIES_TEMP_DIR/XXXXXX 2>/dev/null)}"
KILLZOMBIES_CONFIG_FILE="${KILLZOMBIES_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
KILLZOMBIES_OUTPUT_COLOR="${KILLZOMBIES_OUTPUT_COLOR:-4}"
KILLZOMBIES_OUTPUT_COLOR_2="${KILLZOMBIES_OUTPUT_COLOR:-6}"
KILLZOMBIES_OUTPUT_COLOR_GOOD="${KILLZOMBIES_OUTPUT_COLOR_GOOD:-2}"
KILLZOMBIES_OUTPUT_COLOR_ERROR="${KILLZOMBIES_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
KILLZOMBIES_GOOD_MESSAGE="${KILLZOMBIES_GOOD_MESSAGE:-Everything Went OK}"
KILLZOMBIES_ERROR_MESSAGE="${KILLZOMBIES_ERROR_MESSAGE:-Well that didn\'t work}"
KILLZOMBIES_NOTIFY_ENABLED="${KILLZOMBIES_NOTIFY_ENABLED:-yes}"
KILLZOMBIES_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
KILLZOMBIES_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$KILLZOMBIES_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$KILLZOMBIES_CONFIG_DIR/$KILLZOMBIES_CONFIG_FILE" ] && . "$KILLZOMBIES_CONFIG_DIR/$KILLZOMBIES_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$KILLZOMBIES_LOG_DIR" ] || mkdir -p "$KILLZOMBIES_LOG_DIR" &>/dev/null
[ -d "$KILLZOMBIES_TEMP_DIR" ] || mkdir -p "$KILLZOMBIES_TEMP_DIR" &>/dev/null
[ -d "$KILLZOMBIES_CACHE_DIR" ] || mkdir -p "$KILLZOMBIES_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$KILLZOMBIES_CONFIG_DIR/$KILLZOMBIES_CONFIG_FILE" ] || INIT_CONFIG=TRUE __gen_config "${SETARGS:-$*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    KILLZOMBIES_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$KILLZOMBIES_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${KILLZOMBIES_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${KILLZOMBIES_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${KILLZOMBIES_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${KILLZOMBIES_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
admin)
  stat=$(ps ax | awk '{print $1}' | grep -v "PID" | xargs -n 1 ps lOp | grep -v "UID" | awk '{print"pid: "$3" *** parent_pid: "$4" *** status: "$10" *** process: "$13}' | grep ": Z")
  if ((${#stat} > 0)); then
    printf_red "zombie processes found:"
    ps ax | awk '{print $1}' | grep -v "PID" | xargs -n 1 ps lOp | grep -v "UID" | awk '{print"pid: "$3" *** parent_pid: "$4" *** status: "$10" *** process: "$13}' | grep ": Z"
    printf_read_question "3" "Kill zombies? [y/n]: " 1 keyb '-s'
    if [ $keyb == 'y' ]; then
      printf_red "killing zombies.."
      ps ax | awk '{print $1}' | grep -v "PID" | xargs -n 1 ps lOp | grep -v "UID" | awk '{print$4" status:"$10}' | grep "status:Z" | awk '{print $1}' | xargs -n 1 kill -9
    else
      printf_red "User canceled.."
    fi
  else
    printf_green "No zombies found"
  fi
  ;;

cron)
  stat=$(ps ax | awk '{print $1}' | grep -v "PID" | xargs -n 1 ps lOp | grep -v "UID" | awk '{print"pid: "$3" *** parent_pid: "$4" *** status: "$10" *** process: "$13}' | grep ": Z")
  if ((${#stat} > 0)); then
    ps ax | awk '{print $1}' | grep -v "PID" | xargs -n 1 ps lOp | grep -v "UID" | awk '{print$4" status:"$10}' | grep "status:Z" | awk '{print $1}' | xargs -n 1 kill -9
    echo $(date)": killed some zombie proceses!" >>"$KILLZOMBIES_LOG_DIR/kill.log"
  fi
  ;;

*)
  printf_green "Usage: killzombies [cron|admin]"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
