# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$LATEST_ISO_CONFIG_DIR/$LATEST_ISO_CONFIG_FILE"
  [ -d "$LATEST_ISO_CONFIG_DIR" ] || mkdir -p "$LATEST_ISO_CONFIG_DIR"
  [ -d "$LATEST_ISO_CONFIG_BACKUP_DIR" ] || mkdir -p "$LATEST_ISO_CONFIG_BACKUP_DIR"
  [ -f "$LATEST_ISO_CONFIG_DIR/$LATEST_ISO_CONFIG_FILE" ] &&
    cp -Rf "$LATEST_ISO_CONFIG_DIR/$LATEST_ISO_CONFIG_FILE" "$LATEST_ISO_CONFIG_BACKUP_DIR/$LATEST_ISO_CONFIG_FILE.$$"
  cat <<EOF >"$LATEST_ISO_CONFIG_DIR/$LATEST_ISO_CONFIG_FILE"
# Settings for latest-iso
LATEST_ISO_DOWNLOAD_DIR="${LATEST_ISO_DOWNLOAD_DIR:-$HOME/Downloads/ISOs}"

# URLs
LATEST_ISO_ALMA_URL="${LATEST_ISO_ALMA_URL:-http://mirror.vtti.vt.edu/almalinux}"
LATEST_ISO_ALPINE_URL="${LATEST_ISO_ALPINE_URL:-https://alpinelinux.org/downloads}"
LATEST_ISO_ARCOLINUX_URL="${LATEST_ISO_ARCOLINUX_URL:-https://sourceforge.net/projects/arcolinux/files/ArcoLinuxL}"
LATEST_ISO_DEBIAN_URL="${LATEST_ISO_DEBIAN_URL:-https://www.debian.org/download}"
LATEST_ISO_ENDEAVOUR_URL="${LATEST_ISO_ENDEAVOUR_URL:-https://mirror.linux.pizza/endeavouros/iso}"
LATEST_ISO_FEDORA_URL="${LATEST_ISO_FEDORA_URL:-https://spins.fedoraproject.org/xfce/download/index.html}"
LATEST_ISO_HEADS_URL="${LATEST_ISO_HEADS_URL:-https://files.dyne.org/heads}"
LATEST_ISO_KALI_URL="${LATEST_ISO_KALI_URL:-https://www.kali.org/get-kali}"
LATEST_ISO_MANJARO_URL="${LATEST_ISO_MANJARO_URL:-https://manjaro.org/download/}"
LATEST_ISO_PARROT_URL="${LATEST_ISO_PARROT_URL:-https://cdimage.parrotsec.org/parrot/iso/current}"
LATEST_ISO_PEPPERMINT_URL="${LATEST_ISO_PEPPERMINT_URL:-https://sourceforge.net/projects/peppermintos/files}"
LATEST_ISO_PHOTON_URL="${LATEST_ISO_PHOTON_URL:-https://github.com/vmware/photon/wiki/Downloading-Photon-OS}"
LATEST_ISO_PROXMOX_URL="${LATEST_ISO_PROXMOX_URL:-http://download.proxmox.com/iso}"
LATEST_ISO_ROCKY_URL="${LATEST_ISO_ROCKY_URL:-https://download.rockylinux.org/pub/rocky}"
LATEST_ISO_UBUNTU_URL="${LATEST_ISO_UBUNTU_URL:-https://mirror.us.leaseweb.net/ubuntu-cdimage/xubuntu/releases}"
LATEST_ISO_TAILS_URL="${LATEST_ISO_TAILS_URL:-https://tails.boum.org/install/dvd/index.en.html}"
LATEST_ISO_TINYCORE_URL="${LATEST_ISO_TINYCORE_URL:-http://tinycorelinux.net/13.x/x86_64/release/TinyCorePure64-current.iso}"

# Notification settings
LATEST_ISO_GOOD_MESSAGE="${LATEST_ISO_GOOD_MESSAGE:-Everything Went OK}"
LATEST_ISO_ERROR_MESSAGE="${LATEST_ISO_ERROR_MESSAGE:-Well something seems to have gone wrong}"
LATEST_ISO_NOTIFY_ENABLED="${LATEST_ISO_NOTIFY_ENABLED:-yes}"
LATEST_ISO_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
LATEST_ISO_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$LATEST_ISO_NOTIFY_CLIENT_ICON}"

# Colorization settings
LATEST_ISO_OUTPUT_COLOR="${LATEST_ISO_OUTPUT_COLOR:-5}"
LATEST_ISO_OUTPUT_COLOR_GOOD="${LATEST_ISO_OUTPUT_COLOR_GOOD:-2}"
LATEST_ISO_OUTPUT_COLOR_ERROR="${LATEST_ISO_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$LATEST_ISO_CONFIG_DIR/$LATEST_ISO_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__test_iso() {
  set -o pipefail
  local test="" verify=""
  [[ -n "$1" ]] && test="$(echo "$1" | grep -aE 'http|ftp' | grep -a '.iso$' | grep '^' || echo '')"
  [[ -n "$test" ]] && verify="$([[ -n "$test" ]] && __urlcheck "$test" &>/dev/null && echo 'valid' || echo '')"
  if [[ "$verify" = "valid" ]]; then
    return 0
  else
    verify=""
    test=""
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__sort_v() {
  set -o pipefail
  __strip_tags |
    grep '^[0-9]' |
    sort -rV |
    head -n1 |
    sed 's|/$||g' |
    sed 's|//|/|g'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__strip_iso() {
  set -o pipefail
  grep -aE '[_|-|.]*.*[_|-|.]' |
    grep -av 'torrent' |
    grep -av 'target' |
    grep -av 'ti-download' |
    grep -a '.iso'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__strip_tags() {
  set -o pipefail
  sed -r 's/.*href="([^"]+).*/\1/g' |
    sed 's|^<a href=||g;s|"||g' |
    sed 's/<..*=//g' |
    sed 's|>$||g' |
    sed 's|\\/|/|g' |
    sed 's|&#x2F;&#x2F;|//|g;s|&#x2F;|/|g' |
    sed 's|<.*||g' |
    sed 's|>.*||g' |
    sed "s|$iso/download$|$iso|g" |
    sed 's|.iso.torrent|.iso|g' |
    grep -v '^$'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__verify_arch() {
  set -o pipefail
  local latest="${1:-$latest}"
  if echo "$latest" | grep -q 'x86_64'; then
    arch="x86_64"
  elif echo "$latest" | grep -q 'amd64'; then
    arch="x86_64"
  elif echo "$latest" | grep -qE 'i[1-9]86'; then
    arch="i386"
  elif echo "$latest" | grep -q 'aarch64'; then
    arch="aarch64"
  elif echo "$latest" | grep -q 'arm*'; then
    arch="arm"
  else
    arch="x86_64"
  fi
  echo "$arch"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_arch() {
  get_arch=$(uname -i | grep -v 'unknown' | grep '^' || uname -m | grep '^' || uname -p | grep '^')
  if [[ $get_arch == x86_64* ]]; then
    echo "x86_64"
  elif [[ $get_arch == i*86 ]]; then
    echo "i386"
  elif [[ $arch = aarch64 ]]; then
    echo "aarch64"
  elif [[ $get_arch == arm* ]]; then
    echo "arm"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__find_iso() {
  set -o pipefail
  local url="$1"
  local iso_url=""
  local arch="$(__get_arch)"
  if __test_iso "$url"; then
    iso_url="$url"
  else
    iso_url="$(curl -q -LSsf "$url" 2>/dev/null | grep "$arch" | grep 'href="*.*"' | grep -E '[http,ftp]*.*\.iso' | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
    [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    if [ -z "$iso_url" ]; then
      iso_url="$(curl -q -LSsf "$url" 2>/dev/null | grep 'href="*.*"' | grep -iE "$arch" | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      iso_url="$(curl -q -LSsf "$url" 2>/dev/null | grep -E 'x86_64|amd64' | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      iso_url="$(curl -q -LSsf "$url" 2>/dev/null | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      isor="$(curl -q -LSsf "$url" 2>/dev/null | grep '\.iso' | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
      iso_url="$url/$isor"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      iso_url="$(curl -q -LSsf "$url" 2>/dev/null | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
  fi
  if [ -n "$iso_url" ] && __test_iso "$iso_url"; then
    echo "$iso_url"
  else
    echo ""
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__latest_iso() {
  local latest
  local exitCode="0"
  url="${1:-$url}"
  file="${2:-$file}"
  if [[ ! -f "$file" ]]; then
    printf_green "Attemping to locate the ISO from: "
    printf_cyan "$url"
  fi
  latest=$(__find_iso "${url}")
  localname=$(basename "$latest" 2>/dev/null)
  download_dir=$(dirname "${2:-$LATEST_ISO_DOWNLOAD_DIR/$localname}" 2>/dev/null)
  download_file="$download_dir/${file//$download_dir\//}"
  [ -d "$LATEST_ISO_DOWNLOAD_DIR" ] || mkdir -p "$LATEST_ISO_DOWNLOAD_DIR"
  [ -n "$latest" ] || printf_exit "No iso found on $url\n"
  [ -d "$LATEST_ISO_DOWNLOAD_DIR" ] || printf_exit "The download file should not be a directory: $LATEST_ISO_DOWNLOAD_DIR\n"
  echo "$latest" | grep -q '.iso$' || printf_exit "$latest seems to be invalid\n"
  __grab_iso "$latest" "$download_file" && exitCode=0 || exitCode=1
  if [[ "$exitCode" = 0 ]] && [ -f "$download_file" ]; then
    return 0
  else
    return 2
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__grab_iso() {
  set -x
  local exitCode="10"
  local latest="${1:-$latest}"
  local download_file="${2:-$download_file}"
  local filesize="$(__filesize "$latest")"
  local system_arch="$(__get_arch)"
  local iso_arch="$(__verify_arch "$latest")"
  [[ -z "$FORCE_INST" ]] || __rm_rf "$download_file"
  [[ -d "$LATEST_ISO_DOWNLOAD_DIR" ]] || mkdir -p "$LATEST_ISO_DOWNLOAD_DIR"
  [[ "$system_arch" = "$iso_arch" ]] && arch="$system_arch" || arch="$iso_arch"
  if [[ "$filesize" = "0" || "$filesize" = "0B" ]]; then
    printf_red "URL $latest"
    printf_error "doesn't seem to be a valid ISO image"
    return 4
  elif [ -f "$download_file" ] && [ "$LATEST_ISO_OVERWRITE" != "yes" ]; then
    printf_cyan "File already exists: $download_file"
    __filesize_local "$download_file"
    return 5
  elif [ -n "$latest" ]; then
    printf_cyan "Grabbing iso for $arch from:"
    printf_green "$latest"
    printf_purple "and saving it to $download_file"
    printf_blue "The size of the remote ISO is: $filesize"
    if [ -f "$download_file" ] && [ "$LATEST_ISO_OVERWRITE" = "yes" ]; then
      curl -q -LSsf -o "$download_file" -C - "$latest" 2>/dev/null && success="true" || success=""
    else
      curl -q -LSsf -o "$download_file" "$latest" 2>/dev/null && success="true" || success=""
    fi
    if [ "$success" = "true" ]; then
      __filesize_local "$download_file"
      printf_green "Downloading of the ISO was successful"
      exitCode=0
    else
      printf_red "Error downloading the ISO"
      exitCode=1
    fi
  fi
  echo ""
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__filesize_local() {
  set -o pipefail
  local local_file="${1:-$download_file}"
  local local_file_size=""
  if [[ -f "$local_file" ]]; then
    local_file_size="$(ls -lha "$local_file" 2>/dev/null | awk '{print $5}' | grep -v '^$' || echo '')"
    [[ -n "$local_file_size" ]] && printf_green "The size of the local file is: $local_file_size"
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__filesize() {
  set -o pipefail
  local head="$(curl -q -LSsfI "$1" 2>/dev/null)"
  local content_length_count="$(echo "$head" | grep -ic 'content-length' || echo 1)"
  if [[ $content_length_count = 1 ]]; then
    content_length="$(echo "$head" | grep -ai 'content-length' | head -n1 | awk -v IGNORECASE=1 'BEGIN{RS="\r\n"} /^content-length/ { print $2 }')"
  elif [[ "$content_length_count" != 1 ]]; then
    content_length="$(echo "$head" | grep -ai 'content-length' | tail -n1 | awk -v IGNORECASE=1 'BEGIN{RS="\r\n"} /^content-length/ { print $2 }')"
  fi
  if [[ "$content_length" = 0B ]]; then
    content_length=""
  fi
  [ -n "$content_length" ] || content_length=0
  if cmd_exists numfmt; then
    numfmt --to=iec-i --suffix=B "$content_length"
  elif cmd_exists gnumfmt; then
    gnumfmt --to=iec-i --suffix=B "$content_length"
  else
    echo "$content_length"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_iso() {
  set -o pipefail
  curl -q -LSsf "$1" 2>/dev/null | grep -a "$2" | __strip_tags | __strip_iso | head -n1 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
LATEST_ISO_LOG_DIR="${LATEST_ISO_LOG_DIR:-$HOME/.local/log/latest-iso}"
LATEST_ISO_CACHE_DIR="${LATEST_ISO_CACHE_DIR:-$HOME/.cache/latest-iso}"
LATEST_ISO_CONFIG_DIR="${LATEST_ISO_CONFIG_DIR:-$HOME/.config/myscripts/latest-iso}"
LATEST_ISO_OPTIONS_DIR="${LATEST_ISO_OPTIONS_DIR:-$HOME/.local/share/myscripts/latest-iso/options}"
LATEST_ISO_CONFIG_BACKUP_DIR="${LATEST_ISO_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/latest-iso/backups}"
LATEST_ISO_TEMP_DIR="${LATEST_ISO_TEMP_DIR:-$HOME/.local/tmp/system_scripts/latest-iso}"
LATEST_ISO_CONFIG_FILE="${LATEST_ISO_CONFIG_FILE:-settings.conf}"
LATEST_ISO_GOOD_MESSAGE="${LATEST_ISO_GOOD_MESSAGE:-Everything Went OK}"
LATEST_ISO_ERROR_MESSAGE="${LATEST_ISO_ERROR_MESSAGE:-Well something seems to have gone wrong}"
LATEST_ISO_NOTIFY_ENABLED="${LATEST_ISO_NOTIFY_ENABLED:-yes}"
LATEST_ISO_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
LATEST_ISO_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$LATEST_ISO_NOTIFY_CLIENT_ICON}"
LATEST_ISO_OUTPUT_COLOR="${LATEST_ISO_OUTPUT_COLOR:-5}"
LATEST_ISO_OUTPUT_COLOR_GOOD="${LATEST_ISO_OUTPUT_COLOR_GOOD:-2}"
LATEST_ISO_OUTPUT_COLOR_ERROR="${LATEST_ISO_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Enviroment overrides
LATEST_ISO_DOWNLOAD_DIR="${LATEST_ISO_DOWNLOAD_DIR:-$HOME/Downloads/ISOs}"
LATEST_ISO_ALMA_URL="${LATEST_ISO_ALMA_URL:-http://mirror.vtti.vt.edu/almalinux}"
LATEST_ISO_ALPINE_URL="${LATEST_ISO_ALPINE_URL:-https://alpinelinux.org/downloads}"
LATEST_ISO_ARCOLINUX_URL="${LATEST_ISO_ARCOLINUX_URL:-https://sourceforge.net/projects/arcolinux/files/ArcoLinuxL}"
LATEST_ISO_DEBIAN_URL="${LATEST_ISO_DEBIAN_URL:-https://www.debian.org/download}"
LATEST_ISO_ENDEAVOUR_URL="${LATEST_ISO_ENDEAVOUR_URL:-https://mirror.linux.pizza/endeavouros/iso}"
LATEST_ISO_FEDORA_URL="${LATEST_ISO_FEDORA_URL:-https://spins.fedoraproject.org/xfce/download/index.html}"
LATEST_ISO_HEADS_URL="${LATEST_ISO_HEADS_URL:-https://files.dyne.org/heads}"
LATEST_ISO_KALI_URL="${LATEST_ISO_KALI_URL:-https://www.kali.org/get-kali}"
LATEST_ISO_MANJARO_URL="${LATEST_ISO_MANJARO_URL:-https://manjaro.org/download/}"
LATEST_ISO_PARROT_URL="${LATEST_ISO_PARROT_URL:-https://cdimage.parrotsec.org/parrot/iso/current}"
LATEST_ISO_PEPPERMINT_URL="${LATEST_ISO_PEPPERMINT_URL:-https://sourceforge.net/projects/peppermintos/files}"
LATEST_ISO_PHOTON_URL="${LATEST_ISO_PHOTON_URL:-https://github.com/vmware/photon/wiki/Downloading-Photon-OS}"
LATEST_ISO_PROXMOX_URL="${LATEST_ISO_PROXMOX_URL:-http://download.proxmox.com/iso}"
LATEST_ISO_ROCKY_URL="${LATEST_ISO_ROCKY_URL:-https://download.rockylinux.org/pub/rocky}"
LATEST_ISO_UBUNTU_URL="${LATEST_ISO_UBUNTU_URL:-https://mirror.us.leaseweb.net/ubuntu-cdimage/xubuntu/releases}"
LATEST_ISO_TAILS_URL="${LATEST_ISO_TAILS_URL:-https://tails.boum.org/install/dvd/index.en.html}"
LATEST_ISO_TINYCORE_URL="${LATEST_ISO_TINYCORE_URL:-http://tinycorelinux.net/13.x/x86_64/release/TinyCorePure64-current.iso}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$LATEST_ISO_CONFIG_DIR/$LATEST_ISO_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$LATEST_ISO_CONFIG_DIR/$LATEST_ISO_CONFIG_FILE" ] && . "$LATEST_ISO_CONFIG_DIR/$LATEST_ISO_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$LATEST_ISO_LOG_DIR" ] || mkdir -p "$LATEST_ISO_LOG_DIR" &>/dev/null
[ -d "$LATEST_ISO_TEMP_DIR" ] || mkdir -p "$LATEST_ISO_TEMP_DIR" &>/dev/null
[ -d "$LATEST_ISO_CACHE_DIR" ] || mkdir -p "$LATEST_ISO_CACHE_DIR" &>/dev/null
LATEST_ISO_TEMP_FILE="${LATEST_ISO_TEMP_FILE:-$(mktemp $LATEST_ISO_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$LATEST_ISO_TEMP_FILE" ] && [ -f "$LATEST_ISO_TEMP_FILE" ] && rm -Rf "$LATEST_ISO_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$LATEST_ISO_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${LATEST_ISO_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${LATEST_ISO_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${LATEST_ISO_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${LATEST_ISO_NOTIFY_CLIENT_ICON}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="C"
LONGOPTS="options,config,version,help,dir:,force,all,ask"
ARRAY="iso alma alpine arco debian endeavour fedora heads kali parrot "
ARRAY+="peppermint photon rocky ubuntu tails tiny "
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    __help
    shift 1
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    LATEST_ISO_CWD="$2"
    shift 2
    ;;
  --force)
    shift 1
    FORCE_INST="yes"
    ;;
  --all)
    shift 1
    export PATH="/home/jason/Projects/github/casjay-dotfiles/scripts/bin:$PATH"
    isos="$(echo "$ARRAY" | tr ' ' '\n' | sort | grep -Ev 'iso')"
    for d in $isos; do eval $APPNAME $d; done
    exit $?
    ;;
  --ask)
    shift 1
    echo "$ARRAY"
    exit
    ;;
  -C)
    shift 1
    LATEST_ISO_OVERWRITE="yes"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case $1 in
iso)
  shift 1
  [ $# -eq 2 ] || printf_exit "Usage: $APPNAME iso <url> <filename>"
  __grab_iso "$1" "$2"
  ;;
alma)
  shift 1
  isourl="$(curl -q -LSsf "$LATEST_ISO_ALMA_URL" 2>/dev/null | __sort_v)/isos/x86_64"
  isoname="$LATEST_ISO_ALMA_URL/$isourl/$(curl -q -LSsf "$LATEST_ISO_ALMA_URL/$isourl" 2>/dev/null | __strip_tags | grep 'minimal.iso$' | head -n1)"
  __grab_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/alma.iso"
  ;;
alpine)
  shift 1
  __latest_iso "$LATEST_ISO_ALPINE_URL" "$LATEST_ISO_DOWNLOAD_DIR/alpine.iso"
  ;;
arco)
  shift 1
  __latest_iso "$LATEST_ISO_ARCOLINUX_URL" "$LATEST_ISO_DOWNLOAD_DIR/arcolinux.iso"
  ;;
debian)
  shift 1
  __latest_iso "$LATEST_ISO_DEBIAN_URL" "$LATEST_ISO_DOWNLOAD_DIR/debian.iso"
  ;;
endeavour)
  shift 1
  isourl="$(curl -q -LSsf "$LATEST_ISO_ENDEAVOUR_URL" | __strip_tags | grep 'iso$' | grep "Artemis" | head -n1)"
  isoname="$LATEST_ISO_ENDEAVOUR_URL/$isourl"
  __grab_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/endeavour.iso"
  ;;
fedora)
  shift 1
  __latest_iso "$LATEST_ISO_FEDORA_URL" "$LATEST_ISO_DOWNLOAD_DIR/fedora.iso"
  ;;
heads)
  shift 1
  __latest_iso "$LATEST_ISO_HEADS_URL" "$LATEST_ISO_DOWNLOAD_DIR/heads.iso"
  ;;
kali)
  shift 1
  __latest_iso "$LATEST_ISO_KALI_URL" "$LATEST_ISO_DOWNLOAD_DIR/kali.iso"
  ;;
manjaro)
  shift 1
  isoname="$(curl -q -LSsf "$LATEST_ISO_MANJARO_URL" | __strip_tags | grep xfce | grep 'iso$' | sort -V)"
  __latest_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/manjaro.iso"
  ;;
parrot)
  shift 1
  isoname="$LATEST_ISO_PARROT_URL/$(__get_iso "$LATEST_ISO_PARROT_URL" "security" | head -n1)"
  __latest_iso "${isoname}" "$LATEST_ISO_DOWNLOAD_DIR/parrot.iso"
  ;;
peppermint)
  shift 1
  __latest_iso "$LATEST_ISO_PEPPERMINT_URL" "$LATEST_ISO_DOWNLOAD_DIR/peppermint.iso"
  ;;
photon)
  shift 1
  __latest_iso "$LATEST_ISO_PHOTON_URL" "$LATEST_ISO_DOWNLOAD_DIR/photon.iso"
  ;;
proxmox)
  shift 1
  isourl="$(curl -q -LSsf "$LATEST_ISO_PROXMOX_URL" 2>/dev/null | grep 'proxmox-ve_' | __sort_v)"
  __latest_iso "$LATEST_ISO_PROXMOX_URL/$isourl" "$LATEST_ISO_DOWNLOAD_DIR/proxmox.iso"
  ;;
rocky)
  shift 1
  isourl="$(curl -q -LSsf "$LATEST_ISO_ROCKY_URL" 2>/dev/null | __sort_v)/isos/x86_64"
  isoname="$LATEST_ISO_ROCKY_URL/$isourl/$(curl -q -LSsf "$LATEST_ISO_ROCKY_URL/$isourl" 2>/dev/null | __strip_tags | grep 'minimal.iso$')"
  __latest_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/rocky.iso"
  ;;
ubuntu)
  shift 1
  isoname="$LATEST_ISO_UBUNTU_URL/$(curl -q -LSsf "$LATEST_ISO_UBUNTU_URL" 2>/dev/null | __sort_v)/release"
  __latest_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/ubuntu.iso"
  ;;
tails)
  shift 1
  __latest_iso "$LATEST_ISO_TAILS_URL" "$LATEST_ISO_DOWNLOAD_DIR/tails.iso"
  ;;
tiny)
  shift 1
  __grab_iso "$LATEST_ISO_TINYCORE_URL" "$LATEST_ISO_DOWNLOAD_DIR/tinylinux.iso"
  ;;
*)
  { [ $# = 0 ] || [[ $# = 2 ]]; } && __grab_iso "$1" "$2" || __help
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
