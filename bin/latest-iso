# Set actions based on variables

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
#requiresudo "$0" "$@" || exit 2     # exit 2 if errors
#cmd_exists --error --ask bash || exit 3 # exit 3 if not found
#am_i_online --error || exit 4           # exit 4 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
set_system_arch="$(__get_arch)"
if __user_is_root; then
  if [ -d "/var/lib/vz/template/iso" ]; then
    LATEST_ISO_DOWNLOAD_DIR="/var/lib/vz/template/iso"
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
[ "$RUN_ALL" = "true" ] && __run_all
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
iso)
  shift 1
  if [ $# -eq 0 ]; then
    __gui
  elif [ $# -le 2 ]; then
    __latest_iso "$1" "$LATEST_ISO_DOWNLOAD_DIR/$(basename "${2:-$1}")"
  else
    printf_exit "Usage: $APPNAME iso <url> <filename>"
  fi
  exit $?
  ;;

*)
  __latest_list "$@"
  ;;
esac
