# User defined functions
__sed() { sed "$@" 2>/dev/null; }
__grep() { grep "$@" 2>/dev/null; }
__cd() { [ -d "$iso_dir" ] && builtin cd "$1" || return 1; }
__strip_href() { __sed 's|.*href="||g;s|".*||g' | __grep -v 'data:image/png' | __grep '^' 2>/dev/null || return 1; }
__rm_rf() { if [ -e "$1" ]; then rm -Rf "$1" && return 0 || return 1; fi; }
__curl() { \curl -q -LSsf --fail-early --connect-timeout "${LATEST_ISO_CONNECT_TIMEOUT:-2}" --retry "${LATEST_ISO_RETRY_COUNT:-5}" --retry-delay "${LATEST_ISO_RETRY_DELAY:-3}" "$@" 2>/dev/null || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__test_arch() {
  local test_arch="" exclude_arch="" a="" output=""
  local arch="${LATEST_ISO_SYSTEM_ARCH:-$(uname -m)}"
  arch="${arch,,}"
  local -a input=()
  # Read from arguments or stdin
  if [ $# -gt 0 ]; then
    input=("$@")
  else
    while IFS= read -r line; do
      [ -n "$line" ] && input+=("$line")
    done
  fi
  [ ${#input[@]} -eq 0 ] && return 1
  if [ "$arch" = "x86_64" ]; then
    test_arch="amd64 x86_64 x64"
    exclude_arch="i386|i686|arm64|aarch64|arm"
  elif [ "$arch" = "aarch64" ] || [ "$arch" = "arm64" ]; then
    test_arch="aarch64 arm64"
    exclude_arch="i386|i686|x86_64|amd64|x64"
  else
    test_arch="$arch"
    exclude_arch="aarch64|arm64|x86_64|amd64"
  fi
  # Try to find arch-specific match first
  for a in $test_arch; do
    output="$(printf '%s\n' "${input[@]}" | tr ' ' '\n' | __grep -i "$a" | head -n1)"
    [ -n "$output" ] && echo "$output" && return 0
  done
  # Fallback: return first result that doesn't match other architectures
  output="$(printf '%s\n' "${input[@]}" | tr ' ' '\n' | __grep -vE "$exclude_arch" | head -n1)"
  [ -n "$output" ] && echo "$output"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__unarchive() {
  local archive="${archive_file:-$1}"
  local extract_dir="${archive%/*}"
  local extracted_file=""
  case "$archive" in
  *.tar | *.tar.gz | *.tar.bz2 | *.tar.xz)
    tar xfv "$archive" -C "$extract_dir" && rm -f "$archive"
    return $?
    ;;
  *.xz)
    # For .xz files (like .img.xz), decompress in place and remove archive
    xz -fd "$archive"
    return $?
    ;;
  *.gz)
    gzip -fd "$archive"
    return $?
    ;;
  *.bz2)
    bzip2 -fd "$archive"
    return $?
    ;;
  *.zip)
    unzip -o "$archive" -d "$extract_dir" && rm -f "$archive"
    return $?
    ;;
  *.7z)
    7z x "$archive" -o"$extract_dir" && rm -f "$archive"
    return $?
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__ex() {
  local d="$PWD"
  download_file="${1:-$download_file}"
  archive="$(realpath "$2" 2>/dev/null || echo '')"
  local tmp_iso_dir="${archive%/*}"
  local extracted_file=""
  if [ -f "$archive" ]; then
    __cd "$tmp_iso_dir"
    printf_cyan "Extracting $archive"
    echo "extracting $archive" >"$LATEST_ISO_LOG_DIR/ex.log"
    __unarchive "$archive" &>>"$LATEST_ISO_LOG_DIR/ex.log"
    # Look for .iso files after extraction (search recursively)
    extracted_file="$(find "$tmp_iso_dir" -type f -name '*.iso' 2>/dev/null | head -n1 || echo '')"
    __cd "$d"
    if [ -n "$extracted_file" ] && [ -f "$extracted_file" ]; then
      iso_dirname="${download_file%/*}"
      [ -d "$iso_dirname" ] || mkdir -p "$iso_dirname"
      # Ensure output has .iso extension
      # Replace archive extension with .iso
      case "$download_file" in
      *.zip) download_file="${download_file%.zip}.iso" ;;
      *.xz) download_file="${download_file%.xz}.iso" ;;
      *.gz) download_file="${download_file%.gz}.iso" ;;
      esac
      if [ "$extracted_file" != "$download_file" ]; then
        printf_cyan "Moving $extracted_file to $download_file"
        if mv -f "$extracted_file" "$download_file"; then
          # Clean up extracted directory if it was a subdirectory
          find "$tmp_iso_dir" -mindepth 1 -type d -empty -delete 2>/dev/null
          [ -f "$archive" ] && rm -Rf "$archive"
          [ -f "$LATEST_ISO_LOG_DIR/ex.log" ] && rm -Rf "$LATEST_ISO_LOG_DIR/ex.log"
          printf_green "Extraction complete: $download_file"
        fi
      fi
    else
      printf_red "Could not find .iso file in $archive - check $LATEST_ISO_LOG_DIR/ex.log for details"
      printf_newline
      return 1
    fi
  fi
  [ -f "$download_file" ] && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__strip_url() { __grep -v '^$' | head -n1 | __grep '^'; }
__set_filename() {
  local file="$1" arch="$2"
  # Handle various archive/image extensions: .iso, .img.xz, .tar.gz, etc.
  # Insert arch before extension
  case "$file" in
  *.img.xz | *.img.gz | *.img.bz2 | *.tar.xz | *.tar.gz | *.tar.bz2)
    # Insert $arch between the family (img/tar) and compressor (xz/gz/bz2).
    if [[ "$file" =~ ^(.+)\.(img|tar)\.(xz|gz|bz2)$ ]]; then
      echo "${BASH_REMATCH[1]}.${arch}.${BASH_REMATCH[2]}.${BASH_REMATCH[3]}"
    else
      echo "$file"
    fi
    ;;
  *.iso)
    echo "${file%.iso}.${arch}.iso"
    ;;
  *.xz) echo "${file%.xz}.${arch}.xz" ;;
  *.gz) echo "${file%.gz}.${arch}.gz" ;;
  *.bz2) echo "${file%.bz2}.${arch}.bz2" ;;
  *.7z) echo "${file%.7z}.${arch}.7z" ;;
  *.zip) echo "${file%.zip}.${arch}.zip" ;;
  *)
    echo "$file"
    ;;
  esac
}
__get_filename() { __grep -E '\.iso$|\.dmg$|\.tar$|\.gz$|\.xz$|\.bz2$|\.7z$|\.zip$|\.torrent$' | __grep $1 '^' || return 2; }
# - - - - - - - - - - - - - - - - - - - - - - - - -

# - - - - - - - - - - - - - - - - - - - - - - - - -
__gui() {
  [ -n "$DISPLAY" ] || return 1
  [ -z "$SSH_CONNECTION" ] || return 1
  url="$(INPUT_NAME="$APPNAME" ask_for_input "What is the url to the iso?" || echo '')"
  iso="$(INPUT_NAME="$APPNAME" ask_for_input "Saved name relative to\n$LATEST_ISO_DOWNLOAD_DIR" || echo '')"
  file=$LATEST_ISO_DOWNLOAD_DIR/${iso%.*}.iso
  [ -n "$url" ] || printf_exit "URL is missing or invalid"
  [ -n "$iso" ] || printf_exit "Filename is missing"
  __notifications "Downloading from $url"
  if [ -n "$url" ] && [ -n "$iso" ]; then
    __latest_iso "$url" "$file" &>"$LATEST_ISO_LOG_DIR/gui.log"
    exitCode=$?
  else
    __notifications "Failed to get file from\n$url"
  fi
  if [ "$exitCode" -eq 0 ]; then
    __notifications "Download saved to $file"
  else
    __notifications "Download has failed"
  fi
  exit $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__run_all() {
  local statusCode=0
  isos="$(tr ' ' '\n' <<< "${ARRAY//,/ }" | sort -u | __grep -Ev '^(iso|gui|all)$' | tr '\n' ' ')"
  for iso in $isos; do
    export LATEST_ISO_FORCE_INST="$LATEST_ISO_FORCE_INST"
    export LATEST_ISO_SYSTEM_ARCH="$LATEST_ISO_SYSTEM_ARCH"
    eval "$0 $iso" || statusCode=$((statusCode + 1))
  done
  return $statusCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__test_iso() {
  local test=""
  local verify=""
  local get_status=""
  # Handle rsync URLs - if URL ends with bootable/archive extension, assume valid
  # Handle rsync URLs - if URL ends with bootable/archive extension, assume valid
  if [[ "$1" == rsync://*.iso ]] || [[ "$1" == rsync://*.xz ]] || [[ "$1" == rsync://*.gz ]] || [[ "$1" == rsync://*.bz2 ]] || [[ "$1" == rsync://*.7z ]]; then
    return 0
  fi
  # URL must be http(s)/ftp and end in a recognized ISO/archive/torrent extension.
  if [ -n "$1" ] && [[ "$1" =~ ^(https?|ftp):// ]] && [[ "$1" =~ \.(iso|dmg|tar|gz|xz|bz2|7z|zip|torrent)$ ]]; then
    test="$1"
  fi
  [ -n "$test" ] && get_status="$(__curl -I "$test" || return 1)"
  if [[ "$get_status" == *"HTTP/"*" 200"* ]]; then
    verify="valid"
  else
    verify=""
  fi
  if [ "$verify" = "valid" ]; then
    return 0
  else
    verify=""
    test=""
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__grep_size_large() { __sort_size | __grep "$@"; }
__awk_nf() { awk '{print $NF}' 2>/dev/null | head -n1; }
__tr_split() { tr '=' '\n' 2>/dev/null | __strip_tags; }
__iso_is_archive() { __grep -E '\.tar$|\.xz$|\.gz$|\.zip$|\.bz2$|\.7z$'; }
__sort_rv() { __strip_tags 2>/dev/null | sort -rV | head -n1 | __sed 's|/$||g' | __sed 's|//|/|g' | __grep '^' 2>/dev/null || false; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__sort_v() { __strip_tags 2>/dev/null | __grep '^[0-9]' | sort -rV | __sed 's|/$||g' | __sed 's|//|/|g' | __grep '^' 2>/dev/null || false; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__sort_size() { sort -k2 -t' ' -rn 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__strip_iso() { __grep -aE '[_.-].*[_.-]' | __grep -Ev 'torrent|target|ti-download|^$' | __get_filename | head -n1 | __grep '^' || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__get_link() { __grep 'href=' | __sed 's/<\/\?[^>]\+>//g;s|(.*)||g' | awk -F ' ' '{print $1}' | __grep '\.iso$'; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__strip_tags() {
  iso="${iso:-}"
  __sed -r 's/.*href="([^"]+).*/\1/g' |
    __sed 's|^<a href=||g;s|"||g' |
    __sed 's/<..*=//g' |
    __sed 's|>$||g' |
    __sed 's|\\/|/|g' |
    __sed 's|&#x2F;&#x2F;|//|g;s|&#x2F;|/|g' |
    __sed 's|<.*||g' |
    __sed 's|>.*||g' |
    __sed "s|$iso/download$|$iso|g" |
    __sed 's|.iso.torrent|.iso|g' |
    __sed 's|\t||g' |
    __sed 's| *||g' |
    __sed 's|/index.html||g' |
    __sed "s|'||g" | __grep -v '^$' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__verify_arch() {
  # Returns standardized arch for filename: amd64, arm64, arm, i386
  latest="${1:-$latest}"
  local latest_lower="${latest,,}"
  if [[ "$latest_lower" == *x86_64* ]]; then
    verify_arch="amd64"
  elif [[ "$latest_lower" == *amd64* ]]; then
    verify_arch="amd64"
  elif [[ "$latest_lower" == *aarch64* ]]; then
    verify_arch="arm64"
  elif [[ "$latest_lower" == *arm64* ]]; then
    verify_arch="arm64"
  elif [[ "$latest_lower" == *-arm-* ]]; then
    # Handle patterns like "Manjaro-ARM-"
    verify_arch="arm64"
  elif [[ "$latest_lower" == *arm* ]]; then
    verify_arch="arm"
  elif [[ "$latest_lower" =~ i[1-9]86|x86 ]]; then
    verify_arch="i386"
  else
    verify_arch="amd64"
  fi
  echo "$verify_arch"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__get_arch() {
  get_arch=$(uname -i | __grep -v 'unknown' | __grep '^' || uname -m | __grep '^' || uname -p | __grep '^')
  if [[ "$get_arch" =~ x86_64* ]]; then
    echo "x86_64"
  elif [[ "$get_arch" =~ i*86 ]]; then
    echo "i386"
  elif [[ "$get_arch" =~ aarch64 ]]; then
    echo "aarch64"
  elif [[ "$get_arch" =~ arm* ]]; then
    echo "$get_arch"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Display architecture not supported message
__arch_not_supported() {
  local msg="${1:-This distribution does not support the requested architecture}"
  printf_red "$msg"
  statusCode=$((1 + ${statusCode:-0}))
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Filter out unstable versions (beta, rc, alpha, dev, test, preview, unstable, nightly)
__filter_stable() {
  __grep -viE '(beta|alpha|rc[0-9]|[-.]rc[-.]|dev|test|preview|unstable|nightly|snapshot|pre[0-9])'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Generic HTML directory listing parser
# Usage: __parse_html <url> [include_pattern] [exclude_pattern] [options]
# Options: nojs (append ?nojs=1), filename (return filename only)
__parse_html() {
  local url="${1:-}"
  local include="${2:-}"
  local exclude="${3:-^$}"
  local options="${4:-}"
  local result=""
  [ -n "$url" ] || return 1
  [[ "$options" == *"nojs"* ]] && url="${url}?nojs=1"
  result="$(__curl "$url" | __grep -oE '[a-zA-Z0-9._-]+\.(iso|img|raw|qcow2|tar\.[gx]z|zip)' | __grep -E "$include" | __grep -vE "$exclude" | __filter_stable | sort -rV | __test_arch | head -n1)"
  [ -n "$result" ] && echo "$result"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Generic JSON API parser
# Usage: __parse_json <url> <jq_filter> [include_pattern] [exclude_pattern]
__parse_json() {
  local url="${1:-}"
  local jq_filter="${2:-.}"
  local include="${3:-}"
  local exclude="${4:-^$}"
  local result=""
  [ -n "$url" ] || return 1
  result="$(__curl "$url" | jq -r "$jq_filter" 2>/dev/null | __grep -E "$include" | __grep -vE "$exclude" | __filter_stable | sort -rV | __test_arch | head -n1)"
  [ -n "$result" ] && echo "$result"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# GitHub releases API
# Usage: __github <owner/repo> [include_pattern] [exclude_pattern]
__github() {
  local repo="${1:-}"
  local include="${2:-\.iso}"
  local exclude="${3:-^$}"
  local api_url="" result=""
  [ -n "$repo" ] || return 1
  # Clean repo format (remove URL parts if full URL given)
  repo="${repo##*github.com/}"
  repo="${repo%%/}"
  api_url="https://api.github.com/repos/$repo/releases/latest"
  result="$(__curl -H "Accept: application/vnd.github+json" "$api_url" | jq -r '.assets[].browser_download_url' 2>/dev/null | __grep -E "$include" | __grep -vE "$exclude" | __filter_stable | sort -rV | __test_arch | head -n1)"
  [ -n "$result" ] && echo "$result"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# GitLab releases API
# Usage: __gitlab <instance> <project_id_or_path> [include_pattern] [exclude_pattern]
__gitlab() {
  local instance="${1:-gitlab.com}"
  local project="${2:-}"
  local include="${3:-\.iso}"
  local exclude="${4:-^$}"
  local api_url="" result=""
  [ -n "$project" ] || return 1
  # URL encode project path if it contains /
  project="${project//\//%2F}"
  api_url="https://$instance/api/v4/projects/$project/releases"
  result="$(__curl "$api_url" | jq -r '.[0].assets.links[].url' 2>/dev/null | __grep -E "$include" | __grep -vE "$exclude" | __filter_stable | sort -rV | __test_arch | head -n1)"
  [ -n "$result" ] && echo "$result"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# SourceForge project releases
# Usage: __sourceforge <project> [subdir] [version_pattern]
__sourceforge() {
  local project="${1:-}"
  local subdir="${2:-}"
  local version_pattern="${3:-stable|[0-9].[0-9]|[a-z].*[0-9]}"
  local sf_base="https://sourceforge.net/projects/$project/files"
  local sf_path="$sf_base"
  local get_dirs="" get_isos=""
  [ -n "$project" ] || return 1
  [ -n "$subdir" ] && sf_path="$sf_base/$subdir"
  # Get version/release directory
  get_dirs="$(__curl "$sf_path/" | __grep 'net.sf.files' | head -1 | __sed 's|.*= ||g' | jq -rc '.[].name' 2>/dev/null | __grep -E "$version_pattern" | __filter_stable | __grep -v '^$' | sort -rV | head -n1)"
  if [ -n "$get_dirs" ]; then
    # Try to get ISO from version subdirectory
    get_isos="$(__curl "$sf_path/$get_dirs/" | __grep 'net.sf.files' | head -1 | __sed 's|.*= ||g' | jq -rc '.[].name' 2>/dev/null | __grep -iE '\.(iso|img)$' | __test_arch | sort -rV | head -n1)"
    [ -n "$get_isos" ] && echo "$sf_path/$get_dirs/$get_isos" && return 0
  fi
  # Fallback: ISO directly in path
  get_isos="$(__curl "$sf_path/" | __grep 'net.sf.files' | head -1 | __sed 's|.*= ||g' | jq -rc '.[].name' 2>/dev/null | __grep -iE '\.(iso|img)$' | __test_arch | sort -rV | head -n1)"
  [ -n "$get_isos" ] && echo "$sf_path/$get_isos"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__find_iso() {
  url="$1"
  iso_url=""
  LATEST_ISO_SYSTEM_ARCH="${LATEST_ISO_SYSTEM_ARCH:-$(__get_arch)}"
  if __test_iso "$url"; then
    iso_url="$url"
  else
    iso_url="$(__curl "$url" 2>/dev/null | __grep -i "${LATEST_ISO_SYSTEM_ARCH:-^}" | __grep 'href=".*"' | __grep -E '[http,ftp]*.*\.iso' | __strip_tags | __strip_iso || echo '')"
    [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    if [ -z "$iso_url" ]; then
      iso_url="$(__curl "$url" 2>/dev/null | __grep -i "${LATEST_ISO_SYSTEM_ARCH:-^}" | __grep 'href=".*"' | __strip_tags | __strip_iso || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      iso_url="$(__curl "$url" 2>/dev/null | __grep -E 'x86_64|amd64' | __strip_tags | __strip_iso || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      iso_url="$(__curl "$url" 2>/dev/null | __strip_tags | __strip_iso || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      isor="$(__curl "$url" 2>/dev/null | __grep '\.iso' | __strip_tags | __strip_iso || echo '')"
      iso_url="$url/$isor"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      iso_url="$(__curl "$url" 2>/dev/null | __strip_tags | __strip_iso || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    # Torrent fallback: if all HTTP .iso/archive scrapes failed, scan the same body
    # for matching .torrent files (e.g. Parrot-security-6.1_amd64.iso.torrent). Accepts
    # both native ("x86_64") and Debian-style ("amd64") arch tokens.
    if [ -z "$iso_url" ]; then
      local torrent_body="" arch_alt=""
      case "${LATEST_ISO_SYSTEM_ARCH:-}" in
        x86_64|amd64|x64) arch_alt="x86_64|amd64|x64" ;;
        aarch64|arm64) arch_alt="aarch64|arm64" ;;
        i386|i686|x86) arch_alt="i386|i686|x86" ;;
        *) arch_alt="${LATEST_ISO_SYSTEM_ARCH:-.}" ;;
      esac
      torrent_body="$(__curl "$url" 2>/dev/null)"
      if [ -n "$torrent_body" ]; then
        # Use __strip_href (not __strip_tags) because __strip_tags rewrites ".iso.torrent"
        # back to ".iso", which hides the very pattern we need to find here.
        # Preference order: arch-matching .iso.torrent -> arch-matching any archive.torrent ->
        # any .iso.torrent -> any archive.torrent. Prefer .iso because users asked for ISOs.
        iso_url="$(printf '%s' "$torrent_body" | __strip_href | __grep -iE "($arch_alt)" | __grep -E '\.iso\.torrent$' | head -n1)"
        [ -n "$iso_url" ] || iso_url="$(printf '%s' "$torrent_body" | __strip_href | __grep -iE "($arch_alt)" | __grep -E '\.(iso|img|dmg|tar|gz|xz|bz2|7z|zip)\.torrent$' | head -n1)"
        [ -n "$iso_url" ] || iso_url="$(printf '%s' "$torrent_body" | __strip_href | __grep -E '\.iso\.torrent$' | head -n1)"
        [ -n "$iso_url" ] || iso_url="$(printf '%s' "$torrent_body" | __strip_href | __grep -E '\.(iso|img|dmg|tar|gz|xz|bz2|7z|zip)\.torrent$' | head -n1)"
        if [ -n "$iso_url" ]; then
          [[ "$iso_url" == http*://* ]] || iso_url="${url%/}/$iso_url"
          __test_iso "$iso_url" || iso_url=""
        fi
      fi
    fi
    # Direct-URL torrent fallback: if input was a concrete .iso/archive URL that 404s,
    # try the same URL with .torrent appended (e.g. foo.iso -> foo.iso.torrent).
    if [ -z "$iso_url" ] && [[ "$url" =~ \.(iso|img|dmg|tar|gz|xz|bz2|7z|zip)$ ]]; then
      if __test_iso "${url}.torrent"; then
        iso_url="${url}.torrent"
      fi
    fi
  fi
  if [ -n "$iso_url" ]; then
    echo "$iso_url"
    return 0
  else
    echo ""
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Get macOS recovery image URL from Apple's software update catalog
# Usage: __get_macos_iso <arch> [catalog_url]
# Returns: URL to BaseSystem.dmg and sets MACOS_VERSION variable
__get_macos_iso() {
  local arch="${1:-x86_64}"
  local catalog_url="${2:-$LATEST_ISO_MACOS_CATALOG_URL}"
  local catalog="" all_urls="" url="" ver="" major_ver="" best_url="" best_ver=""
  MACOS_VERSION=""
  # Fetch Apple's software update catalog
  catalog="$(__curl "$catalog_url")"
  [ -z "$catalog" ] && return 1
  # Get all BaseSystem.dmg URLs
  all_urls="$(echo "$catalog" | __grep -oE 'https://[^<]+BaseSystem\.dmg' | sort -u)"
  [ -z "$all_urls" ] && return 1
  # Check each URL's version via the .smd metadata file
  for url in $all_urls; do
    local smd_url="${url/BaseSystem.dmg/InstallAssistantAuto.smd}"
    ver="$(__curl "$smd_url" 2>/dev/null | __grep -A1 'CFBundleShortVersionString' | __grep string | __sed 's/.*<string>\(.*\)<\/string>.*/\1/')"
    [ -z "$ver" ] && continue
    major_ver="${ver%%.*}"
    # If the user pinned a specific macOS major version, accept only that
    if [ -n "${LATEST_ISO_MACOS_VERSION_PIN:-}" ]; then
      [ "$major_ver" = "${LATEST_ISO_MACOS_VERSION_PIN%%.*}" ] || continue
    fi
    # Apple Silicon requires macOS 11+ (Big Sur or later with Universal binaries)
    if [ "$arch" = "arm64e" ]; then
      if [ "$major_ver" -ge 11 ] 2>/dev/null; then
        if [ -z "$best_ver" ] || __version_gt "$ver" "$best_ver"; then
          best_url="$url"
          best_ver="$ver"
        fi
      fi
    else
      if [ -z "$best_ver" ] || __version_gt "$ver" "$best_ver"; then
        best_url="$url"
        best_ver="$ver"
      fi
    fi
  done
  if [ -n "$best_url" ]; then
    MACOS_VERSION="$best_ver"
    echo "$best_url"
    return 0
  fi
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Compare versions: returns true if $1 > $2
__version_gt() {
  [ "$(printf '%s\n%s' "$1" "$2" | sort -V | tail -n1)" = "$1" ] && [ "$1" != "$2" ]
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Parse version from CLI arg (distro=version) or fall back to a named global env var.
# Returns empty string when neither is set, so callers can still fetch "latest".
# Sets LATEST_ISO_VERSION_SOURCE to cli|env|default for downstream use.
# Usage: __parse_version "$system_iso" "LATEST_ISO_ALMA_RELEASE"; version="$LATEST_ISO_VERSION"
__parse_version() {
  local input="${1:-}"
  local global_var="${2:-}"
  LATEST_ISO_VERSION_SOURCE="default"
  LATEST_ISO_VERSION=""
  if [[ "$input" == *"="* ]]; then
    LATEST_ISO_VERSION="${input#*=}"
    LATEST_ISO_VERSION_SOURCE="cli"
  elif [ -n "$global_var" ] && [ -n "${!global_var:-}" ]; then
    LATEST_ISO_VERSION="${!global_var}"
    LATEST_ISO_VERSION_SOURCE="env"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Emit a friendly notice when a rolling-release distro was given a CLI version that
# the upstream URL structure cannot honor. Does nothing if no version or version came from env/default.
__rolling_version_warn() {
  local distro="${1:-unknown}"
  local version="${2:-}"
  if [ -n "$version" ] && [ "${LATEST_ISO_VERSION_SOURCE:-default}" = "cli" ]; then
    printf_yellow "Note: $distro is a rolling/latest-only release; version '$version' ignored, fetching latest"
  fi
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# When a case-level flavor-filtered scrape comes back empty, look for the matching
# .torrent on the same page. Uses the case's own flavor pattern so we pick the right
# variant (e.g. security over home for Parrot). Echoes the matched filename on success.
# Usage: filename="$(__try_torrent_fallback "$listing_url" "$flavor_pattern")"
__try_torrent_fallback() {
  local url="${1:-}" pattern="${2:-^}" body result
  [ -n "$url" ] || return 1
  body="$(__curl "$url" 2>/dev/null)"
  [ -n "$body" ] || return 1
  # Prefer .iso.torrent over other archive.torrent variants; honor the flavor pattern.
  result="$(printf '%s' "$body" | __strip_href | __grep -i "$pattern" | __grep -E '\.iso\.torrent$' | head -n1)"
  [ -n "$result" ] || result="$(printf '%s' "$body" | __strip_href | __grep -i "$pattern" | __grep -E '\.(iso|img|dmg|tar|gz|xz|bz2|7z|zip)\.torrent$' | head -n1)"
  [ -n "$result" ] || return 1
  printf '%s' "$result"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# --test mode: pretty-print a header row once per run. Header gets gated via an exported
# sentinel so child processes spawned by __run_all don't reprint it.
__test_print_header() {
  [ "${LATEST_ISO_TEST_HEADER_PRINTED:-}" = "true" ] && return 0
  export LATEST_ISO_TEST_HEADER_PRINTED="true"
  printf '%-15s %-13s %-8s %-8s %s\n' "DISTRO" "VERSION" "SOURCE" "STATUS" "FILE / URL" >&2
  local cols="${COLUMNS:-80}" line=""
  printf -v line '%*s' "$cols" ''
  printf '%s\n' "${line// /-}" >&2
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Pretty-print one row. Truncates the detail field (filename or URL) to whatever fits
# in COLUMNS so the line never wraps. Colors STATUS: green for 2xx/3xx, red for anything else.
__test_print_row() {
  local distro="${1:-?}" version="${2:-(latest)}" source="${3:-default}" status="${4:-?}" detail="${5:-}"
  local cols="${COLUMNS:-120}" prefix_len=48 max_detail status_col status_num
  max_detail=$((cols - prefix_len))
  [ "$max_detail" -lt 20 ] && max_detail=20
  if [ "${#detail}" -gt "$max_detail" ]; then
    detail="${detail:0:$((max_detail - 1))}…"
  fi
  status_col="$(printf '%-8s' "$status")"
  status_num="${status%% *}"
  local success="false"
  if [[ "$status_num" =~ ^[0-9]+$ ]] && [ "$status_num" -ge 200 ] && [ "$status_num" -lt 400 ]; then
    success="true"
  elif [ "$status_num" = "RSYNC" ] || [ "$status_num" = "TORRENT" ]; then
    success="true"
  fi
  if [ "$success" = "true" ]; then
    status_col="${_TPUT_FG[2]}${status_col}${_TPUT_RESET}"
  else
    status_col="${_TPUT_FG[1]}${status_col}${_TPUT_RESET}"
  fi
  printf '%-15s %-13s %-8s %s %s\n' "$distro" "$version" "$source" "$status_col" "$detail" >&2
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Resolve the HEAD of $1, emit one row. Pulls distro name from ISOFILE and
# version/source from the globals set by __parse_version. Returns 0 on 2xx/3xx, 1 otherwise.
__test_url() {
  local url="$1" distro="" head_out="" status_code="" status_text="" detail=""
  local timeout="${LATEST_ISO_TEST_TIMEOUT:-5}"
  distro="${ISOFILE##*/}"
  distro="${distro%.iso}"
  distro="${distro%.zip}"
  distro="${distro%.dmg}"
  [ -n "$distro" ] || distro="?"
  if [ -z "$url" ]; then
    __test_print_row "$distro" "${LATEST_ISO_VERSION:-(latest)}" "${LATEST_ISO_VERSION_SOURCE:-default}" "NOURL" "could not resolve upstream"
    return 1
  fi
  # rsync:// URLs use the rsync daemon protocol - curl cannot HEAD them. Use rsync --list-only.
  if [[ "$url" == rsync://* ]]; then
    if rsync --list-only --timeout "$timeout" --contimeout "$timeout" "$url" &>/dev/null; then
      detail="${url##*/}"
      __test_print_row "$distro" "${LATEST_ISO_VERSION:-(latest)}" "${LATEST_ISO_VERSION_SOURCE:-default}" "RSYNC" "$detail"
      return 0
    fi
    __test_print_row "$distro" "${LATEST_ISO_VERSION:-(latest)}" "${LATEST_ISO_VERSION_SOURCE:-default}" "FAIL" "$url"
    return 1
  fi
  head_out="$(\curl -q -LSsI --connect-timeout "$timeout" --max-time "$((timeout * 2))" --retry 0 "$url" 2>&1 | __grep -E '^HTTP/' | tail -n1)"
  if [[ "$head_out" =~ HTTP/[0-9.]+[[:space:]]+([0-9]+)([[:space:]]+([^$'\r'$'\n']*))? ]]; then
    status_code="${BASH_REMATCH[1]}"
    status_text="${BASH_REMATCH[3]}"
    if [ "$status_code" -ge 200 ] && [ "$status_code" -lt 400 ]; then
      detail="${url##*/}"
      # Surface torrent fallbacks with a distinct status so the user can see at a
      # glance that raw HTTP wasn't available for this pin.
      if [[ "$url" == *.torrent ]]; then
        __test_print_row "$distro" "${LATEST_ISO_VERSION:-(latest)}" "${LATEST_ISO_VERSION_SOURCE:-default}" "TORRENT" "$detail"
      else
        __test_print_row "$distro" "${LATEST_ISO_VERSION:-(latest)}" "${LATEST_ISO_VERSION_SOURCE:-default}" "$status_code" "$detail"
      fi
      return 0
    fi
    __test_print_row "$distro" "${LATEST_ISO_VERSION:-(latest)}" "${LATEST_ISO_VERSION_SOURCE:-default}" "$status_code" "$url"
    return 1
  fi
  __test_print_row "$distro" "${LATEST_ISO_VERSION:-(latest)}" "${LATEST_ISO_VERSION_SOURCE:-default}" "FAIL" "$url"
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__latest_iso() {
  local exitCode="0"
  # In --test mode the goal is to HEAD the resolved URL, never to actually download.
  # __get_torrent kicks off a real download when the URL ends in .torrent, so skip it here.
  if [ "${LATEST_ISO_TEST_MODE:-}" = "true" ]; then
    url="${1:-$url}"
    file="${2:-$file}"
    archive_iso_name="${3:-$archive_iso_name}"
    latest="$(__find_iso "$url")"
    # If __find_iso didn't resolve but input was already concrete, treat it as the final URL.
    [ -n "$latest" ] || latest="$url"
    __test_url "$latest"
    local test_rc=$?
    unset url latest ISOFILE LATEST_ISO_VERSION LATEST_ISO_VERSION_SOURCE
    return $test_rc
  fi
  __get_torrent "$1" || exitCode=3
  if [ "$LATEST_ISO_IS_TORRENT" = "no" ]; then
    url="${1:-$url}"
    file="${2:-$file}"
    archive_iso_name="${3:-$archive_iso_name}"
    latest=$(__find_iso "$url")
    localname=${latest##*/}
    download_dir="${2:-$LATEST_ISO_DOWNLOAD_DIR/$localname}"
    download_dir="${download_dir%/*}"
    download_file="$download_dir/${file//$download_dir\//}"
    [ -d "$download_file" ] && rm -Rf "$download_file"
    [ -d "$download_dir" ] || mkdir -p "$download_dir"
    [ -d "$LATEST_ISO_DOWNLOAD_DIR" ] || mkdir -p "$LATEST_ISO_DOWNLOAD_DIR"
    [ -d "$LATEST_ISO_DOWNLOAD_DIR" ] || { printf_red "The download file should not be a directory: $LATEST_ISO_DOWNLOAD_DIR\n" && return 1; }
    [ -n "$latest" ] || { printf_red "No iso found on ${url:-$real_url}\n" && return 1; }
    # Validate that $latest ends in a recognized ISO/archive/torrent extension without forking.
    [[ "$latest" =~ \.(iso|dmg|tar|gz|xz|bz2|7z|zip|torrent)$ ]] || { printf_red "$latest seems to be invalid\n" && return 1; }
    __grab_iso "$latest" "$download_file" "$archive_iso_name" && exitCode="0" || exitCode="2"
  fi
  if [ "$exitCode" = 0 ]; then
    exitCode=0
  else
    exitCode=2
  fi
  unset url latest latest_file remote_filesize system_arch iso_arch download_file save_message local_iso_name remote_iso_name save_message ISOFILE LATEST_ISO_NAME LATEST_RELEASE_VERSION
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Helper: Setup download paths and variables
__setup_download_paths() {
  local url_arg="$1"
  local file_arg="$2"
  local archive_arg="$3"

  GRAB_URL="${url_arg:-$GRAB_URL}"
  GRAB_LATEST="${url_arg:-$GRAB_LATEST}"
  GRAB_LATEST_FILE="${file_arg:-$GRAB_DOWNLOAD_FILE}"
  GRAB_ARCHIVE_NAME="${archive_arg:-$GRAB_ARCHIVE_NAME}"
  GRAB_SYSTEM_ARCH="$(__get_arch)"
  GRAB_REMOTE_ISO_NAME="${GRAB_LATEST##*/}"
  GRAB_ISO_ARCH="$(__verify_arch "$GRAB_LATEST")"
  GRAB_DOWNLOAD_FILE="$(__set_filename "${GRAB_LATEST_FILE:-$GRAB_DOWNLOAD_FILE}" "$GRAB_ISO_ARCH")"
  GRAB_LOCAL_ISO_NAME="${GRAB_DOWNLOAD_FILE##*/}"
  GRAB_LATEST_FILE_DIR="${GRAB_LATEST_FILE%/*}"
  GRAB_LOG_FILE="$LATEST_ISO_LOG_DIR/$GRAB_LOCAL_ISO_NAME"

  __remote_filesize "$GRAB_LATEST"
  [ -d "$GRAB_LATEST_FILE_DIR" ] || mkdir -p "$GRAB_LATEST_FILE_DIR"
  [ -d "$LATEST_ISO_DOWNLOAD_DIR" ] || mkdir -p "$LATEST_ISO_DOWNLOAD_DIR"
  [ -f "$GRAB_DOWNLOAD_FILE" ] && [ "$LATEST_ISO_FORCE_INST" = "true" ] && __rm_rf "$GRAB_DOWNLOAD_FILE"

  [ "$GRAB_SYSTEM_ARCH" = "$GRAB_ISO_ARCH" ] && LATEST_ISO_SYSTEM_ARCH="$GRAB_SYSTEM_ARCH" || LATEST_ISO_SYSTEM_ARCH="$GRAB_ISO_ARCH"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Helper: Determine download type and set messages
__determine_download_type() {
  case "$GRAB_LATEST" in
  *.tar | *.xz | *.gz | *.zip | *.bz2 | *.7z)
    [ -z "$GRAB_ARCHIVE_NAME" ] && GRAB_ARCHIVE_NAME="$LATEST_ISO_TEMP_DIR/$GRAB_REMOTE_ISO_NAME"
    GRAB_CURL_FILE="$GRAB_ARCHIVE_NAME"
    GRAB_SAVE_MESSAGE="Attempting to download the compressed ISO from: ${GRAB_LATEST%/*}"
    ;;
  *.iso)
    GRAB_CURL_FILE="$GRAB_DOWNLOAD_FILE"
    GRAB_SAVE_MESSAGE="Attempting to download the ISO from: ${GRAB_LATEST%/*}"
    ;;
  *)
    GRAB_CURL_FILE="$GRAB_DOWNLOAD_FILE"
    GRAB_SAVE_MESSAGE="Attempting to download the file from: ${GRAB_LATEST%/*}"
    ;;
  esac
  GRAB_DOWNLOAD_MESSAGE="Size of $GRAB_REMOTE_ISO_NAME is $remote_filesize and saving it to: $GRAB_DOWNLOAD_FILE"
  mkdir -p "${GRAB_CURL_FILE%/*}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Helper: Execute the download with retry logic (resumes partial downloads)
__execute_download() {
  local success="" attempt=0
  local max_retries="${LATEST_ISO_DOWNLOAD_RETRIES:-2}"
  local retry_delay="${LATEST_ISO_DOWNLOAD_RETRY_DELAY:-5}"
  while [ "$attempt" -le "$max_retries" ]; do
    if [ "$attempt" -gt 0 ]; then
      printf_yellow "Download failed, resuming in ${retry_delay}s (attempt $((attempt + 1)) of $((max_retries + 1)))..."
      sleep "$retry_delay"
    fi
    if [[ "$GRAB_LATEST" == rsync://* ]]; then
      __rsync_download "$GRAB_LATEST" "$GRAB_CURL_FILE" && success="true" || success=""
    else
      __download_with_progress "$GRAB_LATEST" "$GRAB_CURL_FILE" "$remote_file_size_raw" && success="true" || success=""
    fi
    if [ "$success" = "true" ]; then
      return 0
    fi
    attempt=$((attempt + 1))
  done
  # Only delete partial file after all retries exhausted
  [ -f "$GRAB_CURL_FILE" ] && rm -f "$GRAB_CURL_FILE"
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Helper: Verify download and return exit code
__verify_download() {
  local exitCode=0

  case "$GRAB_LATEST" in
  *.tar | *.xz | *.gz | *.zip | *.bz2 | *.7z)
    __ex "$GRAB_DOWNLOAD_FILE" "$GRAB_CURL_FILE"
    # Update GRAB_DOWNLOAD_FILE to the extracted .iso path
    case "$GRAB_DOWNLOAD_FILE" in
    *.zip) GRAB_DOWNLOAD_FILE="${GRAB_DOWNLOAD_FILE%.zip}.iso" ;;
    *.xz) GRAB_DOWNLOAD_FILE="${GRAB_DOWNLOAD_FILE%.xz}.iso" ;;
    *.gz) GRAB_DOWNLOAD_FILE="${GRAB_DOWNLOAD_FILE%.gz}.iso" ;;
    esac
    ;;
  esac

  # Check if downloaded file exists (could be the archive or extracted file)
  local verify_file=""
  if [ -f "$GRAB_DOWNLOAD_FILE" ]; then
    verify_file="$GRAB_DOWNLOAD_FILE"
  elif [ -f "$GRAB_CURL_FILE" ]; then
    verify_file="$GRAB_CURL_FILE"
  else
    printf_red "Downloading of $GRAB_LOCAL_ISO_NAME has failed: no file created"
    printf_newline
    return 2
  fi

  __filesize_local "$verify_file"

  if [ -f "$GRAB_DOWNLOAD_FILE" ]; then
    # For compressed files (like .img.xz), extracted size is always larger - skip size check
    if [[ "$GRAB_LATEST" == *.tar || "$GRAB_LATEST" == *.xz || "$GRAB_LATEST" == *.gz || "$GRAB_LATEST" == *.zip || "$GRAB_LATEST" == *.bz2 || "$GRAB_LATEST" == *.7z ]]; then
      # For archives: just verify file exists and has reasonable size (> 10MB)
      if [ "$local_file_size_raw" -gt 10000000 ]; then
        printf_green "Downloading and extraction of $GRAB_LOCAL_ISO_NAME was successful"
        exitCode=0
      else
        printf_red "Extraction of $GRAB_LOCAL_ISO_NAME has failed: extracted file too small"
        exitCode=1
      fi
    elif [[ "$GRAB_LATEST" == *.dmg ]] && [ "$remote_file_size_raw" = "0" ]; then
      # For DMG files where Apple CDN doesn't return Content-Length, just verify reasonable size (> 400MB)
      if [ "$local_file_size_raw" -gt 400000000 ]; then
        printf_green "Downloading of $GRAB_LOCAL_ISO_NAME was successful"
        exitCode=0
      else
        printf_red "Downloading of $GRAB_LOCAL_ISO_NAME has failed: file too small (got $local_file_size)"
        exitCode=1
      fi
    elif __verify_filesizes "$local_file_size_raw" "$remote_file_size_raw"; then
      printf_green "Downloading of $GRAB_LOCAL_ISO_NAME was successful"
      exitCode=0
    elif __verify_filesizes "$local_file_size" "$remote_file_size"; then
      printf_green "Downloading of $GRAB_LOCAL_ISO_NAME was successful"
      exitCode=0
    else
      printf_red "Downloading of $GRAB_LOCAL_ISO_NAME has failed: file size mismatch (got $local_file_size, expected $remote_filesize)"
      exitCode=1
    fi
  else
    if [ -n "$LATEST_ISO_CURL_ERROR" ] && [ "$LATEST_ISO_CURL_ERROR" != "0" ]; then
      printf_red "Downloading of $GRAB_LOCAL_ISO_NAME has failed: curl error code $LATEST_ISO_CURL_ERROR"
    else
      printf_red "Downloading of $GRAB_LOCAL_ISO_NAME has failed: file not created (disk full or permission denied?)"
    fi
    exitCode=2
  fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Helper: Send notifications based on result
__notify_download_result() {
  local exitCode="$1"
  if [ "$exitCode" -eq 0 ]; then
    __notifications "Downloading of $GRAB_LOCAL_ISO_NAME was successful"
  elif [ "$exitCode" -eq 1 ]; then
    __notifications "Downloading of $GRAB_LOCAL_ISO_NAME has failed: file size mismatch"
  elif [ "$exitCode" -eq 2 ]; then
    if [ -n "$LATEST_ISO_CURL_ERROR" ] && [ "$LATEST_ISO_CURL_ERROR" != "0" ]; then
      __notifications "Downloading of $GRAB_LOCAL_ISO_NAME has failed: curl error code $LATEST_ISO_CURL_ERROR"
    else
      __notifications "Downloading of $GRAB_LOCAL_ISO_NAME has failed: file not created"
    fi
  elif [ "$exitCode" -eq 3 ]; then
    __notifications "Downloading of $GRAB_LOCAL_ISO_NAME has failed: $LATEST_ISO_SPACE_ERROR"
  else
    __notifications "Downloading of $GRAB_LOCAL_ISO_NAME has failed"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__grab_iso() {
  trap 'exitCode=$?;if [ $exitCode -ne 0 ]; then if [ -n "$GRAB_DOWNLOAD_FILE" ] && [ ! -s "$GRAB_DOWNLOAD_FILE" ]; then rm -Rf "$GRAB_DOWNLOAD_FILE";fi;fi' ERR SIGINT
  local exitCode=10

  # Setup paths and variables
  __setup_download_paths "$1" "$2" "$3"

  # Check disk space before downloading
  if ! __check_disk_space "$GRAB_LATEST_FILE_DIR" "$remote_file_size_raw"; then
    printf_red "Downloading of $GRAB_LOCAL_ISO_NAME has failed: $LATEST_ISO_SPACE_ERROR"
    printf_newline
    __notify_download_result 3
    return 3
  fi

  # Check if URL is valid (skip for DMG files - Apple CDN doesn't return Content-Length)
  if [ "$remote_filesize" = "0" ] || [ "$remote_filesize" = "0B" ]; then
    if [[ "$GRAB_LATEST" != *.dmg ]]; then
      printf_error "$GRAB_LATEST doesn't seem to be a valid ISO image"
      printf_newline
      __notify_download_result 4
      return 4
    fi
  fi

  # Check if file already exists (also check for extracted ISO from archives)
  local check_file="$GRAB_DOWNLOAD_FILE"
  case "$GRAB_LATEST" in
  *.tar | *.xz | *.gz | *.zip | *.bz2 | *.7z)
    # For archives, also check if the extracted .iso exists
    local extracted_iso="$GRAB_DOWNLOAD_FILE"
    case "$extracted_iso" in
    *.zip) extracted_iso="${extracted_iso%.zip}.iso" ;;
    *.xz) extracted_iso="${extracted_iso%.xz}.iso" ;;
    *.gz) extracted_iso="${extracted_iso%.gz}.iso" ;;
    esac
    [ -f "$extracted_iso" ] && check_file="$extracted_iso"
    ;;
  esac
  if [ -f "$check_file" ] && [ "$LATEST_ISO_OVERWRITE" != "yes" ]; then
    __filesize_local "$check_file" "silent" &>/dev/null
    printf_cyan "File already exists in: ${PURPLE}$check_file : $local_file_size"
    [ -n "$GRAB_LATEST" ] && printf_blue "$GRAB_LATEST : $remote_filesize"
    printf_newline
    return 0
  fi

  # Proceed with download
  if [ -n "$GRAB_LATEST" ]; then
    __determine_download_type
    printf_cyan "$GRAB_SAVE_MESSAGE"
    printf_purple "$GRAB_DOWNLOAD_MESSAGE"

    if __execute_download; then
      __verify_download
      exitCode=$?
    else
      printf_red "Failed to download $GRAB_LATEST"
      exitCode=2
    fi
  fi

  __notify_download_result "$exitCode"
  printf_newline
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__verify_filesizes() {
  local local_size="" remote_size="" min_size="" max_size="" tolerance=""
  local_size="$(__get_numbers "$1")"
  remote_size="$(__get_numbers "$2")"
  tolerance="${LATEST_ISO_FILESIZE_TOLERANCE:-5}"

  # Allow tolerance % (default 95-105% of expected size)
  min_size=$((remote_size * (100 - tolerance) / 100))
  max_size=$((remote_size * (100 + tolerance) / 100))

  if [ "$local_size" -ge "$min_size" ] && [ "$local_size" -le "$max_size" ]; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__filesize_local() {
  set -o pipefail
  local filename="${1:-$download_file}"
  [ -f "$filename" ] || return 1
  # find+du+awk was overkill for a single file path. du reads the file once,
  # stat gives us the raw byte count directly - saves 3 forks per call.
  local_file_size_raw="$(stat -c%s "$filename" 2>/dev/null || stat -f%z "$filename" 2>/dev/null || echo 0)"
  local_file_size="$(du -h "$filename" 2>/dev/null | { read -r sz _; printf '%s' "$sz"; })"
  [ -n "$local_file_size" ] || local_file_size="0"
  [ -n "$2" ] && printf_cyan "The size of the local file is: $local_file_size"
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__remote_filesize() {
  set -o pipefail
  local head="" content_length="" content_length_count=""
  local url="$1"

  # Handle rsync URLs differently
  if [[ "$url" == rsync://* ]]; then
    local rsync_dir="" rsync_file=""
    rsync_dir="${url%/*}/"
    rsync_file="${url##*/}"
    content_length="$(__rsync_get_filesize "$rsync_dir" "$rsync_file")"
    [ -z "$content_length" ] && content_length=0
  else
    head="$(__curl -I "$url" 2>/dev/null)"
    content_length_count="$(__grep -ic 'content-length' <<< "$head" || echo 1)"
    if [ $content_length_count = 1 ]; then
      content_length="$(__grep -ai 'content-length' <<< "$head" | head -n1 | awk -v IGNORECASE=1 'BEGIN{RS="\r\n"} /^content-length/ { print $2 }')"
    elif [ "$content_length_count" != 1 ]; then
      content_length="$(__grep -ai 'content-length' <<< "$head" | tail -n1 | awk -v IGNORECASE=1 'BEGIN{RS="\r\n"} /^content-length/ { print $2 }')"
    fi
  fi
  if [ "$content_length" = 0B ]; then
    content_length=""
    remote_file_size_raw="0"
  fi
  [ -n "$content_length" ] || content_length=0
  [ -n "$remote_file_size_raw" ] || remote_file_size_raw="$content_length"
  if cmd_exists numfmt; then
    remote_filesize="$(numfmt --to=iec-i --suffix=B "$content_length" | __sed 's|iB$||g')"
  elif cmd_exists gnumfmt; then
    remote_filesize="$(gnumfmt --to=iec-i --suffix=B "$content_length" | __sed 's|iB$||g')"
  else
    remote_filesize="$(printf '%s\n' "$content_length")"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__check_disk_space() {
  local dir="$1"
  local needed="$2"
  local needed_with_buffer=$((needed * 2))
  local available=""

  # Get available space in bytes
  if [ -d "$dir" ]; then
    available=$(df -B1 "$dir" 2>/dev/null | awk 'NR==2 {print $4}')
  else
    available=$(df -B1 "${dir%/*}" 2>/dev/null | awk 'NR==2 {print $4}')
  fi

  [ -z "$available" ] && return 0 # Can't check, assume OK

  if [ "$available" -lt "$needed_with_buffer" ]; then
    # Format sizes for display
    local avail_fmt="" need_fmt=""
    if command -v numfmt &>/dev/null; then
      avail_fmt="$(numfmt --to=iec-i --suffix=B "$available" | __sed 's|iB$||g')"
      need_fmt="$(numfmt --to=iec-i --suffix=B "$needed_with_buffer" | __sed 's|iB$||g')"
    elif command -v gnumfmt &>/dev/null; then
      avail_fmt="$(gnumfmt --to=iec-i --suffix=B "$available" | __sed 's|iB$||g')"
      need_fmt="$(gnumfmt --to=iec-i --suffix=B "$needed_with_buffer" | __sed 's|iB$||g')"
    else
      avail_fmt="$available"
      need_fmt="$needed_with_buffer"
    fi
    export LATEST_ISO_SPACE_ERROR="insufficient disk space (need $need_fmt, have $avail_fmt)"
    return 1
  fi
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__distro_arch_schema() {
  local system_arch="$1"
  local distro="${2:-default}"

  case "$distro" in
  # Uses: x86_64, aarch64
  tinycore | tiny | alpine | void)
    case "$system_arch" in
    x86_64 | amd64) echo "x86_64" ;;
    aarch64 | arm64) echo "aarch64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  # Uses: amd64, arm64
  debian | ubuntu | kali | parrot | peppermint | tails | clonezilla | gparted | popos | vanilla)
    case "$system_arch" in
    x86_64 | amd64) echo "amd64" ;;
    aarch64 | arm64) echo "arm64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  # Uses: x86_64, aarch64
  arch | archcraft | blackarch | cachyos | cachy | endeavour | garuda | manjaro | redcore)
    case "$system_arch" in
    x86_64 | amd64) echo "x86_64" ;;
    aarch64 | arm64) echo "aarch64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  # Uses: x86_64, aarch64
  alma | rocky | centos | fedora | rhel | photon | openvz | nobara | bazzite)
    case "$system_arch" in
    x86_64 | amd64) echo "x86_64" ;;
    aarch64 | arm64) echo "aarch64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  # Uses: x86_64, aarch64
  opensuse | suse)
    case "$system_arch" in
    x86_64 | amd64) echo "x86_64" ;;
    aarch64 | arm64) echo "aarch64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  # Uses: amd64, arm64
  freebsd | openbsd | netbsd)
    case "$system_arch" in
    x86_64 | amd64) echo "amd64" ;;
    aarch64 | arm64) echo "arm64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  # Uses: amd64, arm64
  gentoo)
    case "$system_arch" in
    x86_64 | amd64) echo "amd64" ;;
    aarch64 | arm64) echo "arm64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  # Uses: x86_64, aarch64
  nixos | chimera)
    case "$system_arch" in
    x86_64 | amd64) echo "x86_64" ;;
    aarch64 | arm64) echo "aarch64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  # Uses: x86_64 only
  solus | aeryn)
    case "$system_arch" in
    x86_64 | amd64) echo "x86_64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  # Uses: amd64 only
  proxmox | freenas | truenas | pfsense | opnsense | flatcar | heads | hirens | xcp-ng)
    case "$system_arch" in
    x86_64 | amd64) echo "amd64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  # macOS: x86_64 for Intel, arm64e for Apple Silicon
  macos | mac | osx)
    case "$system_arch" in
    x86_64 | amd64) echo "x86_64" ;;
    aarch64 | arm64) echo "arm64e" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  *)
    # Default: x86_64, aarch64
    case "$system_arch" in
    x86_64 | amd64) echo "x86_64" ;;
    aarch64 | arm64) echo "aarch64" ;;
    *) echo "$system_arch" ;;
    esac
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__rsync_list() {
  local url="$1"
  rsync --list-only "$url" 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__rsync_find_latest_version() {
  local url="$1"
  __rsync_list "$url" | awk '{print $NF}' | __grep -E '^[0-9]+\.x$' | sort -rV | head -n1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__rsync_get_filesize() {
  local url="$1"
  local filename="$2"
  __rsync_list "$url" | __grep " ${filename}$" | awk '{print $2}' | tr -d ','
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__rsync_download() {
  local url="$1"
  local output="$2"
  local total_size="${3:-$remote_file_size_raw}"
  local output_dir="${output%/*}"
  local current_size=0
  local rsync_pid=""
  local resume_flag=""

  [ -d "$output_dir" ] || mkdir -p "$output_dir"

  # Check if partial file exists for resume
  if [ -f "$output" ]; then
    current_size=$(stat -c%s "$output" 2>/dev/null || stat -f%z "$output" 2>/dev/null || echo 0)
    if [ "$current_size" -gt 0 ]; then
      local resume_size=""
      if command -v numfmt &>/dev/null; then
        resume_size="$(numfmt --to=iec-i --suffix=B "$current_size" 2>/dev/null | __sed 's|iB$||g')"
      elif command -v gnumfmt &>/dev/null; then
        resume_size="$(gnumfmt --to=iec-i --suffix=B "$current_size" 2>/dev/null | __sed 's|iB$||g')"
      else
        resume_size="${current_size}B"
      fi
      printf_cyan "Resuming download from $resume_size..."
    fi
  fi

  # Run rsync in background with partial/resume support
  rsync -a --partial --inplace "$url" "$output" >/dev/null 2>&1 &
  rsync_pid=$!

  # Trap CTRL+C to clean up
  trap 'kill $rsync_pid 2>/dev/null; return 130' INT TERM

  # Monitor progress
  while kill -0 $rsync_pid 2>/dev/null; do
    if [ -f "$output" ]; then
      current_size=$(stat -c%s "$output" 2>/dev/null || stat -f%z "$output" 2>/dev/null || echo 0)
      if [ -n "$total_size" ] && [ "$total_size" -gt 0 ]; then
        __progress_bar "$current_size" "$total_size"
      fi
    fi
    sleep 0.5
  done

  # Reset trap
  trap - INT TERM

  # Wait for rsync to finish and get exit code
  wait $rsync_pid
  local exit_code=$?

  # Final progress update
  if [ -f "$output" ]; then
    current_size=$(stat -c%s "$output" 2>/dev/null || stat -f%z "$output" 2>/dev/null || echo 0)
    if [ -n "$total_size" ] && [ "$total_size" -gt 0 ]; then
      __progress_bar "$current_size" "$total_size"
    fi
  fi
  printf '\n'

  return $exit_code
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__get_torrent() {
  local exitTCode=0
  local torrent_url="$1"
  local torrent_name=""
  LATEST_ISO_IS_TORRENT="no"

  if [[ "$torrent_url" == magnet:* ]] || [[ "$torrent_url" == *.torrent ]]; then
    LATEST_ISO_IS_TORRENT="yes"
    printf_yellow "This appears to be a torrent"

    # Get torrent name for display
    if [[ "$torrent_url" == magnet:* ]]; then
      # Extract display name from magnet link
      torrent_name="${torrent_url##*dn=}"
      torrent_name="${torrent_name%%&*}"
      torrent_name="${torrent_name//%20/ }"
    else
      torrent_name="${torrent_url##*/}"
    fi
    [ -z "$torrent_name" ] && torrent_name="torrent"

    # Try aria2c first (direct download with progress)
    if __cmd_exists aria2c; then
      printf_blue "Downloading torrent via aria2c"
      aria2c --enable-dht=true --seed-time=0 --summary-interval=1 \
        --console-log-level=warn --download-result=hide \
        -d "$LATEST_ISO_DOWNLOAD_DIR" "$torrent_url"
      exitTCode=$?
      if [ $exitTCode -eq 0 ]; then
        printf_green "Downloading of $torrent_name was successful"
      else
        printf_red "Downloading of $torrent_name has failed: aria2c error code $exitTCode"
      fi
    # Try transadd (transmission wrapper)
    elif __cmd_exists transadd; then
      printf_blue "Adding torrent via transadd"
      transadd "$torrent_url"
      exitTCode=$?
      if [ $exitTCode -eq 0 ]; then
        __monitor_transmission "$torrent_name"
        exitTCode=$?
      else
        printf_red "Downloading of $torrent_name has failed: transadd error"
      fi
    # Try transmission-remote directly
    elif __cmd_exists transmission-remote; then
      printf_blue "Adding torrent via transmission-remote"
      local server="${TORRENT_SERVER:-localhost}:${TORRENT_SERVER_PORT:-9091}"
      transmission-remote "$server" -a "$torrent_url" &>/dev/null
      exitTCode=$?
      if [ $exitTCode -eq 0 ]; then
        __monitor_transmission "$torrent_name"
        exitTCode=$?
      else
        printf_red "Downloading of $torrent_name has failed: transmission-remote error"
      fi
    else
      printf_red "No torrent client found (aria2c, transadd, or transmission-remote)"
      exitTCode=1
    fi
  fi
  return $exitTCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__monitor_transmission() {
  local torrent_name="${1:-torrent}"
  local server="${TORRENT_SERVER:-localhost}:${TORRENT_SERVER_PORT:-9091}"
  local torrent_id=""
  local status="" percent="" done_check=""

  # Get the most recent torrent ID
  sleep 2
  torrent_id="$(transmission-remote "$server" -l 2>/dev/null | tail -2 | head -1 | awk '{print $1}')"

  if [ -z "$torrent_id" ] || [ "$torrent_id" = "ID" ]; then
    printf_yellow "Could not get torrent ID for monitoring"
    return 0
  fi

  printf_cyan "Monitoring torrent download (ID: $torrent_id)"

  # Monitor until complete or stopped
  while true; do
    local info="$(transmission-remote "$server" -t "$torrent_id" -i 2>/dev/null)"

    if [ -z "$info" ]; then
      printf_red "\nDownloading of $torrent_name has failed: torrent removed or connection lost"
      return 1
    fi

    status="$(__grep 'State:' <<< "$info" | __sed 's|.*State: ||')"
    percent="$(__grep 'Percent Done:' <<< "$info" | __sed 's|.*Percent Done: ||')"

    # Check if done
    local status_lower="${status,,}"
    if [ "$percent" = "100%" ] || [[ "$status_lower" == *seeding* ]] || [[ "$status_lower" == *finished* ]]; then
      printf '\n'
      printf_green "Downloading of $torrent_name was successful"
      return 0
    fi

    # Check if stopped/error
    if [[ "$status_lower" == *stopped* ]] || [[ "$status_lower" == *error* ]]; then
      printf '\n'
      printf_red "Downloading of $torrent_name has failed: $status"
      return 1
    fi

    # Show progress (cached tput escapes)
    printf '\r%b[Torrent] %s - %s%b' \
      "${_TPUT_FG[6]}" \
      "$percent" "$status" \
      "$_TPUT_RESET"

    sleep 2
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__latest_list() {
  local statusCode=0 system_iso="$1"
  case "$1" in
  # Server variants (hyphenated)
  debian-server|debian-server=*)
    shift 1
    local debian_arch="" debian_url="" version="" debian_release=""
    __parse_version "$system_iso" "LATEST_ISO_DEBIAN_RELEASE"; version="$LATEST_ISO_VERSION"
    debian_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "debian")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/debian-server.iso"
    # Versioned resolve: try /release/ (currently-supported debian-X.Y.Z dirs) then /archive/.
    # Skip -live variants (no iso-cd/ subdir) and sort -rV to pick the newest point release.
    if [ -n "$version" ]; then
      debian_release="$(__curl "https://cdimage.debian.org/cdimage/release/" | __strip_href | __grep -v '\-live' | __grep -E "^debian-${version}(\.|/)" | sort -rV | head -n1 | __sed 's|/$||g')"
      if [ -n "$debian_release" ]; then
        debian_url="https://cdimage.debian.org/cdimage/release/$debian_release/$debian_arch/iso-cd"
      else
        debian_release="$(__curl "https://cdimage.debian.org/cdimage/archive/" | __strip_href | __grep -v '\-live' | __grep -E "^${version}(\.|/)" | sort -rV | head -n1 | __sed 's|/$||g')"
        [ -n "$debian_release" ] && debian_url="https://cdimage.debian.org/cdimage/archive/$debian_release/$debian_arch/iso-cd" || debian_url="https://cdimage.debian.org/cdimage/release/current/$debian_arch/iso-cd"
      fi
    else
      debian_url="https://cdimage.debian.org/cdimage/release/current/$debian_arch/iso-cd"
    fi
    real_url="$debian_url"
    iso_url="$(__curl "$debian_url" | __strip_tags | __grep "netinst" | __grep -i "$debian_arch" | __strip_iso)"
    iso_url_filename="$debian_url/$iso_url"
    __latest_iso "$iso_url_filename" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  ubuntu-server|ubuntu-server=*)
    shift 1
    local ubuntu_version="" ubuntu_iso="" ubuntu_arch="" ubuntu_base_url="" ubuntu_versions="" version=""
    __parse_version "$system_iso" "LATEST_ISO_UBUNTU_RELEASE"; version="$LATEST_ISO_VERSION"
    ubuntu_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "ubuntu")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/ubuntu-server.iso"
    if [ "$ubuntu_arch" = "arm64" ]; then
      ubuntu_base_url="https://cdimage.ubuntu.com/ubuntu-server/releases"
    else
      ubuntu_base_url="https://releases.ubuntu.com"
    fi
    if [ -n "$version" ]; then
      ubuntu_versions="$version"
    else
      ubuntu_versions="$(__curl "$ubuntu_base_url" | __strip_tags | __grep -oE '[0-9]+\.[0-9]+' | sort -ruV)"
    fi
    if [ "$ubuntu_arch" = "arm64" ]; then
      for ubuntu_version in $ubuntu_versions; do
        ubuntu_iso="$(__curl "$ubuntu_base_url/$ubuntu_version/release/" | __strip_tags | __grep "live-server" | __grep "$ubuntu_arch" | __grep "\.iso$" | head -n1)"
        [ -n "$ubuntu_iso" ] && { iso_url="$ubuntu_base_url/$ubuntu_version/release"; break; }
      done
    else
      for ubuntu_version in $ubuntu_versions; do
        ubuntu_iso="$(__curl "$ubuntu_base_url/$ubuntu_version" | __strip_tags | __grep "live-server" | __grep "$ubuntu_arch" | __grep "\.iso$" | head -n1)"
        [ -n "$ubuntu_iso" ] && { iso_url="$ubuntu_base_url/$ubuntu_version"; break; }
      done
    fi
    real_url="$ubuntu_base_url"
    iso_url_filename="$iso_url/$ubuntu_iso"
    __latest_iso "$iso_url_filename" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  cachy-server)
    shift 1
    printf_yellow "CachyOS Server Edition is coming soon (expected 2026)"
    printf_cyan "See: https://cachyos.org/blog/2025-christmas-new-year/"
    statusCode=$((1 + $statusCode))
    ;;
  # Regular distros
  alma|alma=*)
    shift 1
    local alma_arch="" version=""
    __parse_version "$system_iso" "LATEST_ISO_ALMA_RELEASE"; version="$LATEST_ISO_VERSION"
    alma_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "alma")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/alma.iso"
    real_url="$LATEST_ISO_ALMA_URL"
    iso_url="${version:-$(__curl "$LATEST_ISO_ALMA_URL" | __strip_tags | __sort_v | __strip_url)}/isos/$alma_arch"
    iso_url_filename="$(__curl "$LATEST_ISO_ALMA_URL/$iso_url" | __grep -i "$LATEST_ISO_ALMA_FLAVOR" | __strip_tags | __strip_iso || false)"
    [ -n "$iso_url_filename" ] || iso_url_filename="$(__curl "$LATEST_ISO_ALMA_URL/$iso_url" | __strip_tags | __strip_iso)"
    __latest_iso "$LATEST_ISO_ALMA_URL/$iso_url/$iso_url_filename" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  alpine|alpine=*)
    shift 1
    local alpine_arch="" version="" alpine_branch=""
    __parse_version "$system_iso" "LATEST_ISO_ALPINE_RELEASE"; version="$LATEST_ISO_VERSION"
    alpine_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "alpine")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/alpine.iso"
    # Alpine uses "v3.18" style branches; "latest-stable" when no version pinned
    if [ -n "$version" ]; then
      alpine_branch="v${version#v}"
    else
      alpine_branch="latest-stable"
    fi
    real_url="https://dl-cdn.alpinelinux.org/alpine/$alpine_branch/releases/$alpine_arch"
    iso_url="$(__curl "$real_url" | __strip_tags | sort -rV | __grep -Ei "$LATEST_ISO_ALPINE_FLAVOR" | __strip_iso)"
    [ -z "$iso_url" ] && iso_url="$(__curl "$real_url" | __strip_tags | sort -rV | __grep -E "standard" | __strip_iso)"
    __latest_iso "$real_url/$iso_url" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  aeryn|aeryn=*|serpent|serpent=*)
    shift 1
    local aeryn_arch="" version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "AerynOS" "$version"
    aeryn_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "aeryn")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/aeryn.iso"
    real_url="$LATEST_ISO_AERYN_URL"
    if [ "$aeryn_arch" = "aarch64" ] || [ "$aeryn_arch" = "arm64" ]; then
      __arch_not_supported "AerynOS does not support arm64"
    else
      iso_url="$(__curl "$LATEST_ISO_AERYN_URL/" | __strip_href | __grep -i 'AerynOS.*\.iso$' | sort -rV | head -n1)"
      __latest_iso "$LATEST_ISO_AERYN_URL/$iso_url" "$ISOFILE"
      statusCode=$(($? + $statusCode))
    fi
    ;;
  arch|arch=*)
    shift 1
    local arch_arch="" version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "Arch Linux" "$version"
    arch_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "arch")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/arch.iso"
    # Arch Linux mainline only provides x86_64 ISOs (Arch ARM is a separate project)
    if [ "$arch_arch" = "aarch64" ] || [ "$arch_arch" = "arm64" ]; then
      __arch_not_supported "Arch Linux does not support arm64 (see archlinuxarm.org for ARM builds)"
    else
      real_url="$LATEST_ISO_ARCHLINUX_URL"
      iso_url="$(__curl "$LATEST_ISO_ARCHLINUX_URL" | __strip_tags | __strip_iso)"
      __latest_iso "$LATEST_ISO_ARCHLINUX_URL/$iso_url" "$ISOFILE"
      statusCode=$(($? + $statusCode))
    fi
    ;;
  archcraft|archcraft=*)
    shift 1
    local version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "Archcraft" "$version"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/archcraft.iso"
    real_url="$LATEST_ISO_ARCHCRAFT_URL"
    iso_url_filename="$(__sourceforge "archcraft" "" "v[0-9]")"
    __latest_iso "$iso_url_filename" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  blackarch|blackarch=*)
    shift 1
    local version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "BlackArch" "$version"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/blackarch.iso"
    real_url="$LATEST_ISO_BLACKARCH_URL"
    iso_url="$(__curl "$LATEST_ISO_BLACKARCH_URL" | __strip_tags | __grep -i "$LATEST_ISO_BLACKARCH_FLAVOR" | __strip_iso)"
    __latest_iso "$LATEST_ISO_BLACKARCH_URL/$iso_url" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  bazzite|bazzite=*)
    shift 1
    local bazzite_arch="" version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "Bazzite" "$version"
    bazzite_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "bazzite")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/bazzite.iso"
    real_url="$LATEST_ISO_BAZZITE_URL"
    if [ "$bazzite_arch" = "aarch64" ] || [ "$bazzite_arch" = "arm64" ]; then
      __arch_not_supported "Bazzite does not support arm64"
    else
      iso_url="$LATEST_ISO_BAZZITE_URL/${LATEST_ISO_BAZZITE_FLAVOR:-bazzite-stable}-amd64.iso"
      __latest_iso "$iso_url" "$ISOFILE"
      statusCode=$(($? + $statusCode))
    fi
    ;;
  cachy|cachy=*)
    shift 1
    local cachy_type="" version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "CachyOS" "$version"
    cachy_type="$1"
    if [ "$cachy_type" = "server" ]; then
      shift 1
      printf_yellow "CachyOS Server Edition is coming soon (expected 2026)"
      printf_cyan "See: https://cachyos.org/blog/2025-christmas-new-year/"
      statusCode=$((1 + $statusCode))
    else
      ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/cachy.iso"
      real_url="${LATEST_ISO_CACHYOS_URL//\/best_release.json/}"
      iso_url="$(__curl "$LATEST_ISO_CACHYOS_URL" | jq -rc '.release|.url' | __sed 's|/download$||g' | __grep -i "$LATEST_ISO_CACHY_FLAVOR")"
      __latest_iso "$iso_url" "$ISOFILE"
      statusCode=$(($? + $statusCode))
    fi
    ;;
  centos|centos=*)
    shift 1
    local centos_arch="" version=""
    __parse_version "$system_iso" "LATEST_ISO_CENTOS_RELEASE"; version="$LATEST_ISO_VERSION"
    centos_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "centos")"
    printf_red "This should be avoided unless you have a good reason"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/centos.iso"
    real_url="$LATEST_ISO_CENTOS_URL"
    iso_url="${version:-$(__curl "$LATEST_ISO_CENTOS_URL" | __strip_tags | __sort_v | __strip_url)}/isos/$centos_arch"
    iso_url_filename="$(__curl "$LATEST_ISO_CENTOS_URL/$iso_url" | __grep -i "$LATEST_ISO_CENTOS_FLAVOR" | __strip_tags | __strip_iso || false)"
    [ -n "$iso_url_filename" ] || iso_url_filename="$(__curl "$LATEST_ISO_CENTOS_URL/$iso_url" | __strip_tags | __strip_iso)"
    __latest_iso "$LATEST_ISO_CENTOS_URL/$iso_url/$iso_url_filename" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  chimera|chimera=*)
    shift 1
    local chimera_arch="" version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "Chimera Linux" "$version"
    chimera_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "chimera")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/chimera.iso"
    real_url="$LATEST_ISO_CHIMERA_URL"
    iso_url="$(__curl "$LATEST_ISO_CHIMERA_URL/" | __strip_href | __grep -i "chimera-linux-${chimera_arch}.*-${LATEST_ISO_CHIMERA_FLAVOR:-gnome}\.iso$" | sort -rV | head -n1)"
    __latest_iso "$LATEST_ISO_CHIMERA_URL/$iso_url" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  debian|debian=*)
    shift 1
    local debian_arch="" debian_type="" debian_url="" debian_base="" debian_release="" version=""
    __parse_version "$system_iso" "LATEST_ISO_DEBIAN_RELEASE"; version="$LATEST_ISO_VERSION"
    debian_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "debian")"
    debian_type="$1"
    # Resolve a Debian version to a release directory. Try /release/ first (current supported
    # releases), then /archive/ for older ones. Skips -live/ variants (no iso-dvd/iso-cd inside)
    # and sorts point-releases descending so "debian=12" picks the newest 12.x.
    __debian_resolve_release() {
      local ver="$1" release=""
      release="$(__curl "https://cdimage.debian.org/cdimage/release/" | __strip_href | __grep -v '\-live' | __grep -E "^debian-${ver}(\.|/)" | sort -rV | head -n1 | __sed 's|/$||g')"
      if [ -n "$release" ]; then
        echo "release/$release"
        return 0
      fi
      release="$(__curl "https://cdimage.debian.org/cdimage/archive/" | __strip_href | __grep -v '\-live' | __grep -E "^${ver}(\.|/)" | sort -rV | head -n1 | __sed 's|/$||g')"
      if [ -n "$release" ]; then
        echo "archive/$release"
        return 0
      fi
      return 1
    }
    if [ "$debian_type" = "server" ]; then
      shift 1
      ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/debian-server.iso"
      if [ -n "$version" ]; then
        debian_release="$(__debian_resolve_release "$version")"
        [ -n "$debian_release" ] && debian_url="https://cdimage.debian.org/cdimage/$debian_release/$debian_arch/iso-cd" || debian_url="https://cdimage.debian.org/cdimage/release/current/$debian_arch/iso-cd"
      else
        debian_url="https://cdimage.debian.org/cdimage/release/current/$debian_arch/iso-cd"
      fi
      real_url="$debian_url"
      iso_url="$(__curl "$debian_url" | __strip_tags | __grep "netinst" | __grep -i "$debian_arch" | __strip_iso)"
      iso_url_filename="$debian_url/$iso_url"
    else
      ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/debian.iso"
      if [ -n "$version" ]; then
        debian_release="$(__debian_resolve_release "$version")"
        [ -n "$debian_release" ] && debian_base="https://cdimage.debian.org/cdimage/$debian_release/$debian_arch/${LATEST_ISO_DEBIAN_FLAVOR}" || debian_base="$LATEST_ISO_DEBIAN_URL/$debian_arch/${LATEST_ISO_DEBIAN_FLAVOR}"
      else
        debian_base="$LATEST_ISO_DEBIAN_URL/$debian_arch/${LATEST_ISO_DEBIAN_FLAVOR}"
      fi
      real_url="$debian_base"
      iso_url="$(__curl "$debian_base" | __strip_tags | __grep -i ".iso$" | __strip_iso)"
      iso_url_filename="$debian_base/$iso_url"
    fi
    __latest_iso "$iso_url_filename" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  endeavour|endeavour=*)
    shift 1
    local version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "EndeavourOS" "$version"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/endeavour.iso"
    real_url="$LATEST_ISO_ENDEAVOUR_URL"
    iso_url="$(__curl "$LATEST_ISO_ENDEAVOUR_URL" | __tr_split | __grep 'mirrors.gigenet.com' | __strip_iso)"
    __latest_iso "$iso_url" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  fedora|fedora=*)
    shift 1
    local fedora_arch="" version="" fedora_base=""
    __parse_version "$system_iso" "LATEST_ISO_FEDORA_RELEASE"; version="$LATEST_ISO_VERSION"
    fedora_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "fedora")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/fedora.iso"
