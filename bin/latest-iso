cmd_exists() { builtin command -v "$1" &>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Send all output to /dev/null
__devnull() {
  tee &>/dev/null && exitCode=0 || exitCode=1
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -'
# Send errors to /dev/null
__devnull2() {
  [ -n "$1" ] && local cmd="$1" && shift 1 || return 1
  eval $cmd "$*" 2>/dev/null && exitCode=0 || exitCode=1
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -'
# See if the executable exists
__cmd_exists() {
  local exitCode=0
  [ -n "$1" ] || return 0
  for cmd in "$@"; do
    if builtin command -v "$cmd" &>/dev/null; then
      exitCode=$((exitCode + 0))
    else
      exitCode=$((exitCode + 1))
    fi
  done
  [ $exitCode -eq 0 ] || exitCode=3
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for a valid internet connection
__am_i_online() {
  __curl -sI "${1:-1.1.1.1}" &>/dev/null && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# colorization
# Cache tput escapes at startup so every colored printf doesn't fork tput twice.
declare -a _TPUT_FG=()
_TPUT_RESET=""
if [ "$SHOW_RAW" = "true" ]; then
  NC=""
  RESET=""
  BLACK=""
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  PURPLE=""
  CYAN=""
  WHITE=""
  ORANGE=""
  LIGHTRED=""
  BG_GREEN=""
  BG_RED=""
  ICON_INFO="[ info ]"
  ICON_GOOD="[ ok ]"
  ICON_WARN="[ warn ]"
  ICON_ERROR="[ error ]"
  ICON_QUESTION="[ ? ]"
  for _i in 0 1 2 3 4 5 6 7 8; do _TPUT_FG[_i]=""; done
  unset _i
  printf_column() { tee | grep '^'; }
  printf_color() { printf '%b' "$1" | tr -d '\t' | __sed '/^%b$/d;s,\x1B\[ 0-9;]*[a-zA-Z],,g'; }
else
  _TPUT_RESET="$(tput sgr0 2>/dev/null)"
  for _i in 0 1 2 3 4 5 6 7 8; do _TPUT_FG[_i]="$(tput setaf "$_i" 2>/dev/null)"; done
  unset _i
  printf_color() { printf "%b" "${_TPUT_FG[${2:-7}]}" "$1" "$_TPUT_RESET"; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Printf wrapper functions (self-contained)
printf_newline() { printf '\n'; }
printf_blue() { printf_color "$1\n" "4"; }
printf_red() { printf_color "$1\n" "1"; }
printf_green() { printf_color "$1\n" "2"; }
printf_cyan() { printf_color "$1\n" "6"; }
printf_yellow() { printf_color "$1\n" "3"; }
printf_purple() { printf_color "$1\n" "5"; }
printf_error() { printf_red "ERROR: $1"; }
printf_exit() { printf_red "$1"; exit "${2:-1}"; }
