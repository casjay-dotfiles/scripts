    local ubuntu_version="" ubuntu_iso="" ubuntu_arch="" ubuntu_base_url="" ubuntu_type="" ubuntu_pattern="" ubuntu_spec="" ubuntu_versions="" version=""
    ubuntu_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "ubuntu")"
    # Parse "ubuntu=<spec>" - spec is either "server" (build type) or a version number.
    # Allow $LATEST_ISO_UBUNTU_RELEASE as the env-level fallback for the version case.
    LATEST_ISO_VERSION=""
    LATEST_ISO_VERSION_SOURCE="default"
    [[ "$system_iso" == *"="* ]] && ubuntu_spec="${system_iso#*=}"
    if [ "$ubuntu_spec" = "server" ]; then
      ubuntu_type="server"
      LATEST_ISO_VERSION_SOURCE="cli"
    else
      ubuntu_type="desktop"
      if [ -n "$ubuntu_spec" ]; then
        version="$ubuntu_spec"
        LATEST_ISO_VERSION="$ubuntu_spec"
        LATEST_ISO_VERSION_SOURCE="cli"
      elif [ -n "${LATEST_ISO_UBUNTU_RELEASE:-}" ]; then
        version="$LATEST_ISO_UBUNTU_RELEASE"
        LATEST_ISO_VERSION="$LATEST_ISO_UBUNTU_RELEASE"
        LATEST_ISO_VERSION_SOURCE="env"
      fi
    fi
    if [ "$ubuntu_type" = "server" ]; then
      ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/ubuntu-server.iso"
      ubuntu_pattern="live-server"
      if [ "$ubuntu_arch" = "arm64" ]; then
        ubuntu_base_url="https://cdimage.ubuntu.com/ubuntu-server"
      else
        ubuntu_base_url="https://releases.ubuntu.com"
      fi
    else
      ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/ubuntu.iso"
      ubuntu_pattern="desktop"
      if [ "$ubuntu_arch" = "arm64" ]; then
        ubuntu_base_url="https://cdimage.ubuntu.com/releases"
      else
        ubuntu_base_url="$LATEST_ISO_UBUNTU_URL"
      fi
    fi
    real_url="$ubuntu_base_url"
    if [ -n "$version" ]; then
      ubuntu_versions="$version"
    else
      ubuntu_versions="$(__curl "$ubuntu_base_url" | __sort_v)"
    fi
    for ubuntu_version in $ubuntu_versions; do
      ubuntu_iso="$(__curl "$ubuntu_base_url/$ubuntu_version/release/" | __strip_tags | __grep "$ubuntu_pattern" | __grep "$ubuntu_arch" | __strip_iso)"
      [ -n "$ubuntu_iso" ] && break
    done
    iso_url="$ubuntu_base_url/$ubuntu_version/release"
    iso_url_filename="$iso_url/$ubuntu_iso"
    __latest_iso "$iso_url_filename" "$ISOFILE"
    statusCode=$(($? + $statusCode))
