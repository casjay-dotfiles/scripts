      [ -n "$iso_url" ] || iso_url="$(__curl "$LATEST_ISO_PROXMOX_URL" | __sort_rv | __grep -i 'proxmox-ve_' | __strip_iso)"
    else
      iso_url="$(__curl "$LATEST_ISO_PROXMOX_URL" | __sort_rv | __grep -i 'proxmox-ve_' | __strip_iso)"
    fi
    __latest_iso "$LATEST_ISO_PROXMOX_URL/$iso_url" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  freenas|freenas=*)
    shift 1
    local version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "TrueNAS" "$version"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/freenas.iso"
    real_url="$LATEST_ISO_FREENAS_URL"
    iso_url_filename="$(__curl "$LATEST_ISO_FREENAS_URL" | __strip_href | __strip_iso)"
    __latest_iso "$iso_url_filename" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  pfsense|pfsense=*)
    shift 1
    local pfsense_arch="" version=""
    __parse_version "$system_iso" "LATEST_ISO_PFSENSE_RELEASE"; version="$LATEST_ISO_VERSION"
    pfsense_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "pfsense")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_DIR/pfsense.iso"
    if [ "$pfsense_arch" = "aarch64" ] || [ "$pfsense_arch" = "arm64" ]; then
      __arch_not_supported "pfSense does not support arm64"
    else
      real_url="$LATEST_ISO_PFSENSE_URL"
      if [ -n "$version" ]; then
        iso_url_filename="$(__curl "$LATEST_ISO_PFSENSE_URL" | __strip_tags | __grep "$version" | __grep '\.iso' | __iso_is_archive | __sort_rv)"
        [ -n "$iso_url_filename" ] || iso_url_filename="$(__curl "$LATEST_ISO_PFSENSE_URL" | __strip_tags | __grep '\.iso' | __iso_is_archive | __sort_rv)"
      else
        iso_url_filename="$(__curl "$LATEST_ISO_PFSENSE_URL" | __strip_tags | __grep '\.iso' | __iso_is_archive | __sort_rv)"
      fi
      __latest_iso "$LATEST_ISO_PFSENSE_URL/$iso_url_filename" "$ISOFILE" "$LATEST_ISO_TEMP_DIR/pfsense/$iso_url_filename"
      statusCode=$(($? + $statusCode))
    fi
    ;;
  heads|heads=*)
    shift 1
    local version=""
    __parse_version "$system_iso" "LATEST_ISO_HEADS_RELEASE"; version="$LATEST_ISO_VERSION"
    ISOFILE="$LATEST_ISO_DOWNLOAD_LIVE_DIR/heads.iso"
    real_url="$LATEST_ISO_HEADS_URL"
    if [ -n "$version" ]; then
      iso_file="$(__parse_html "$LATEST_ISO_HEADS_URL" "heads-${version}" "" "nojs")"
      [ -n "$iso_file" ] || iso_file="$(__parse_html "$LATEST_ISO_HEADS_URL" "heads-" "" "nojs")"
    else
      iso_file="$(__parse_html "$LATEST_ISO_HEADS_URL" "heads-" "" "nojs")"
    fi
    iso_url="${LATEST_ISO_HEADS_URL}/${iso_file}"
    __latest_iso "$iso_url" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  tails|tails=*)
    shift 1
    local tails_arch="" version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "Tails" "$version"
    tails_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "tails")"
    ISOFILE="$LATEST_ISO_DOWNLOAD_LIVE_DIR/tails.iso"
    # Tails only provides amd64 ISOs
    if [ "$tails_arch" = "aarch64" ] || [ "$tails_arch" = "arm64" ]; then
      __arch_not_supported "Tails does not support arm64"
    else
      real_url="$LATEST_ISO_TAILS_URL"
      __latest_iso "$LATEST_ISO_TAILS_URL" "$ISOFILE"
      statusCode=$(($? + $statusCode))
    fi
    ;;
  clonezilla|clonezilla=*)
    shift 1
    local version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "Clonezilla Live" "$version"
    ISOFILE="$LATEST_ISO_DOWNLOAD_UTILS_DIR/clonezilla.iso"
    real_url="https://sourceforge.net/projects/clonezilla/files/clonezilla_live_stable"
    iso_url="$(__sourceforge "clonezilla" "clonezilla_live_stable")"
    __latest_iso "$iso_url" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  gparted|gparted=*)
    shift 1
    local version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "GParted Live" "$version"
    ISOFILE="$LATEST_ISO_DOWNLOAD_UTILS_DIR/gparted.iso"
    real_url="https://sourceforge.net/projects/gparted/files/gparted-live-stable"
    iso_url="$(__sourceforge "gparted" "gparted-live-stable")"
    __latest_iso "$iso_url" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  hirens|hirens=*)
    shift 1
    local version=""
    __parse_version "$system_iso"; version="$LATEST_ISO_VERSION"
    __rolling_version_warn "Hiren's BootCD" "$version"
    ISOFILE="$LATEST_ISO_DOWNLOAD_UTILS_DIR/hirens.iso"
    real_url="https://www.hirensbootcd.org/download"
    iso_url="https://www.hirensbootcd.org/files/$(__curl "https://www.hirensbootcd.org/download" | __get_link | __grep '.iso')"
    __latest_iso "$iso_url" "$ISOFILE"
    statusCode=$(($? + $statusCode))
    ;;
  server)
    # Server edition dispatch - rewrite into the top-level *-server cases which already handle versions
    shift 1
    local server_distro="${1:-}" server_name="" server_ver=""
    [ -n "$server_distro" ] && shift 1
    if [[ "$server_distro" == *"="* ]]; then
      server_name="${server_distro%%=*}"
      server_ver="=${server_distro#*=}"
    else
      server_name="$server_distro"
      server_ver=""
    fi
    case "$server_name" in
    debian) __latest_list "debian-server${server_ver}" ;;
    ubuntu) __latest_list "ubuntu-server${server_ver}" ;;
    cachy)
      printf_yellow "CachyOS Server Edition is coming soon (expected 2026)"
      printf_cyan "See: https://cachyos.org/blog/2025-christmas-new-year/"
      statusCode=$((1 + $statusCode))
      ;;
    *)
      printf_red "Usage: $APPNAME server [debian|ubuntu|cachy][=version]"
      statusCode=$((1 + $statusCode))
      ;;
    esac
    statusCode=$(($? + $statusCode))
    ;;
  *) printf_red "$1 is not a valid option" ;;
  esac
  exitCode=$statusCode
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__get_numbers() {
  printf '%s' "$1" | __sed 's/[^0-9]*//g' | tr -d '\n' | __grep '^' 2>/dev/null || printf '0'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__progress_bar() {
  local current="$1"
  local total="$2"
  local width="${COLUMNS:-80}"
  local bar_width=$((width - 30))
  [ $bar_width -lt 10 ] && bar_width=10
  [ $bar_width -gt 50 ] && bar_width=50

  local percent=0
  [ "$total" -gt 0 ] && percent=$((current * 100 / total))
  [ $percent -gt 100 ] && percent=100

  local filled=$((bar_width * percent / 100))
  local empty=$((bar_width - filled))

  # Format sizes
  local current_fmt="" total_fmt=""
  if command -v numfmt &>/dev/null; then
    current_fmt="$(numfmt --to=iec-i --suffix=B "$current" 2>/dev/null | __sed 's|iB$||g')"
    total_fmt="$(numfmt --to=iec-i --suffix=B "$total" 2>/dev/null | __sed 's|iB$||g')"
  elif command -v gnumfmt &>/dev/null; then
    current_fmt="$(gnumfmt --to=iec-i --suffix=B "$current" 2>/dev/null | __sed 's|iB$||g')"
    total_fmt="$(gnumfmt --to=iec-i --suffix=B "$total" 2>/dev/null | __sed 's|iB$||g')"
  else
    current_fmt="$current"
    total_fmt="$total"
  fi

  # Build progress bar
  local bar_fill="" bar_empty=""
  for ((i = 0; i < filled; i++)); do bar_fill+="█"; done
  for ((i = 0; i < empty; i++)); do bar_empty+="░"; done

  # Print with colors (cyan for bar, green for filled) - cached escapes, no per-tick forks.
  printf '\r%b[%b%s%b%s%b] %3d%% %s/%s%b ' \
    "${_TPUT_FG[6]}" \
    "${_TPUT_FG[2]}" "$bar_fill" \
    "${_TPUT_FG[8]}" "$bar_empty" \
    "${_TPUT_FG[5]}" "$percent" "$current_fmt" "$total_fmt" \
    "$_TPUT_RESET"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__download_cleanup() {
  local tmp_file="$1"
  local pid="$2"
  printf '\n'
  printf_yellow "Download interrupted by user"
  # Kill curl process if still running
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null
    wait "$pid" 2>/dev/null
  fi
  # Remove incomplete temp file
  [ -f "$tmp_file" ] && rm -f "$tmp_file"
  export LATEST_ISO_CURL_ERROR="interrupted"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__download_with_progress() {
  local url="$1"
  local output="$2"
  local total_size="$3"
  local current_size=0
  local curl_pid=""
  local resume_flag=""

  # Check if partial file exists for resume
  if [ -f "$output" ]; then
    current_size=$(stat -c%s "$output" 2>/dev/null || stat -f%z "$output" 2>/dev/null || echo 0)
    if [ "$current_size" -gt 0 ]; then
      resume_flag="-C -"
      local resume_size=""
      if command -v numfmt &>/dev/null; then
        resume_size="$(numfmt --to=iec-i --suffix=B "$current_size" 2>/dev/null | __sed 's|iB$||g')"
      elif command -v gnumfmt &>/dev/null; then
        resume_size="$(gnumfmt --to=iec-i --suffix=B "$current_size" 2>/dev/null | __sed 's|iB$||g')"
      else
        resume_size="${current_size}B"
      fi
      printf_cyan "Resuming download from $resume_size..."
    fi
  fi

  # Start curl in background with resume support
  # shellcheck disable=SC2086
  \curl -q -LSsf --fail-early --connect-timeout "${LATEST_ISO_CONNECT_TIMEOUT:-2}" --retry "${LATEST_ISO_RETRY_COUNT:-5}" --retry-delay "${LATEST_ISO_RETRY_DELAY:-3}" $resume_flag -o "$output" "$url" 2>/dev/null &
  curl_pid=$!

  # Trap CTRL+C to clean up
  trap '__download_cleanup "$output" "$curl_pid"; return 130' INT TERM

  # Monitor progress
  while kill -0 $curl_pid 2>/dev/null; do
    if [ -f "$output" ]; then
      current_size=$(stat -c%s "$output" 2>/dev/null || stat -f%z "$output" 2>/dev/null || echo 0)
      __progress_bar "$current_size" "$total_size"
    fi
    sleep 0.5
  done

  # Reset trap
  trap - INT TERM

  # Wait for curl to finish and get exit code
  wait $curl_pid
  local exit_code=$?

  # Final progress update
  if [ -f "$output" ]; then
    current_size=$(stat -c%s "$output" 2>/dev/null || stat -f%z "$output" 2>/dev/null || echo 0)
    __progress_bar "$current_size" "$total_size"
  fi
  printf '\n'

  if [ $exit_code -eq 0 ] && [ -f "$output" ]; then
    return 0
  else
    # Keep partial file for resume on retry (caller handles cleanup on final failure)
    export LATEST_ISO_CURL_ERROR="$exit_code"
    return 1
  fi
}
