    __parse_version "$system_iso" "LATEST_ISO_MACOS_RELEASE"; version="$LATEST_ISO_VERSION"
    [ -n "$version" ] && export LATEST_ISO_MACOS_VERSION_PIN="$version"
    macos_arch="$(__distro_arch_schema "$LATEST_ISO_SYSTEM_ARCH" "macos")"
    if [ "$macos_arch" = "arm64e" ]; then
      macos_dmg="$LATEST_ISO_DOWNLOAD_DIR/mac.arm64.dmg"
      macos_iso="$LATEST_ISO_DOWNLOAD_DIR/mac.arm64.iso"
    else
      macos_dmg="$LATEST_ISO_DOWNLOAD_DIR/mac.amd64.dmg"
      macos_iso="$LATEST_ISO_DOWNLOAD_DIR/mac.amd64.iso"
    fi
    ISOFILE="$macos_dmg"
    real_url="$LATEST_ISO_MACOS_CATALOG_URL"
    printf_cyan "Fetching macOS catalog from Apple..."
    macos_url="$(__get_macos_iso "$macos_arch")"
    if [ -n "$macos_url" ]; then
      printf_cyan "Found macOS $MACOS_VERSION recovery image"
      __latest_iso "$macos_url" "$ISOFILE"
      statusCode=$(($? + $statusCode))
      # Convert DMG to ISO if dmg2img is available (Linux)
      if [ "$statusCode" -eq 0 ] && [ -f "$macos_dmg" ]; then
        if command -v dmg2img &>/dev/null; then
          printf_cyan "Converting DMG to ISO..."
          if dmg2img "$macos_dmg" "$macos_iso" &>/dev/null; then
            rm -f "$macos_dmg"
            printf_green "Converted to: $macos_iso"
            ISOFILE="$macos_iso"
          else
            printf_yellow "Conversion failed, keeping DMG format"
          fi
        elif command -v hdiutil &>/dev/null; then
          # macOS native conversion
          printf_cyan "Converting DMG to ISO..."
          local macos_cdr="${macos_iso%.iso}.cdr"
          if hdiutil convert "$macos_dmg" -format UDTO -o "$macos_cdr" &>/dev/null; then
            mv "$macos_cdr" "$macos_iso"
            rm -f "$macos_dmg"
            printf_green "Converted to: $macos_iso"
            ISOFILE="$macos_iso"
          else
            printf_yellow "Conversion failed, keeping DMG format"
          fi
        fi
      fi
    else
      printf_red "No macOS recovery image found for $macos_arch"
      statusCode=$((1 + $statusCode))
    fi
    ;;
