# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  { [ $(id -u) -ne 0 ] || [ $EUID -ne 0 ] || [ "$WHOAMI" != "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -s "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$LATEST_ISO_REQUIRE_SUDO" = "yes" ] && [ -z "$LATEST_ISO_REQUIRE_SUDO_RUN" ]; then
    export LATEST_ISO_REQUIRE_SUDO="no"
    export LATEST_ISO_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "$(basename "$SUDO" 2>/dev/null)" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-$?}
  [ -f "$LATEST_ISO_TEMP_FILE" ] && rm -Rf "$LATEST_ISO_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__gui() {
  [ -n "$DISPLAY" ] || return 1
  [ -z "$SSH_CONNECTION" ] || return 1
  url="$(INPUT_NAME="$APPNAME" ask_for_input "What is the url to iso?" || echo '')"
  iso="$(INPUT_NAME="$APPNAME" ask_for_input "Saved name relative to\n$LATEST_ISO_DOWNLOAD_DIR" || echo '')"
  file=$LATEST_ISO_DOWNLOAD_DIR/${iso%.*}.iso
  [ -n "$url" ] || printf_exit "URL is missing or invalid"
  [ -n "$iso" ] || printf_exit "Filename is missing"
  __notifications "Downloading from $url"
  if [ -n "$url" ] && [ -n "$iso" ]; then
    __latest_iso "$url" "$file" &>"$LATEST_ISO_LOG_DIR/gui.log" && __notifications "Download saved to $file"
    exitCode=$?
  else
    __notifications "Download has failed"
  fi
  exit $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_all() {
  local isos=()
  isos=("$(echo "$ARRAY" | tr ' ' '\n' | sort -u | grep -Ev 'iso')")
  for iso in "${isos[@]}"; do
    eval $APPNAME "$iso"
  done
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__test_iso() {
  local test=""
  local verify=""
  [ -n "$1" ] && test="$(echo "$1" | grep -aE 'https://|http://|ftp://' | grep -a '.iso$' | grep '^' || echo '')"
  [ -n "$test" ] && verify="$(curl -q -LSsfI "$test" 2>/dev/null | grep -q 'HTTP/.* 200' && echo 'valid' || echo '')"
  if [ "$verify" = "valid" ]; then
    return 0
  else
    verify=""
    test=""
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__sort_rv() {
  __strip_tags |
    sort -rV |
    head -n1 |
    sed 's|/$||g' |
    sed 's|//|/|g'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__sort_v() {
  __strip_tags |
    grep '^[0-9]' |
    sort -rV |
    head -n1 |
    sed 's|/$||g' |
    sed 's|//|/|g'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__strip_iso() {
  grep -aE '[_|-|.]*.*[_|-|.]' |
    grep -av 'torrent' |
    grep -av 'target' |
    grep -av 'ti-download' |
    grep -a '.iso$'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__strip_tags() {
  sed -r 's/.*href="([^"]+).*/\1/g' |
    sed 's|^<a href=||g;s|"||g' |
    sed 's/<..*=//g' |
    sed 's|>$||g' |
    sed 's|\\/|/|g' |
    sed 's|&#x2F;&#x2F;|//|g;s|&#x2F;|/|g' |
    sed 's|<.*||g' |
    sed 's|>.*||g' |
    sed "s|$iso/download$|$iso|g" |
    sed 's|.iso.torrent|.iso|g' |
    sed 's|\t||g' |
    sed 's|/index.html||g' |
    sed "s|'||g" |
    grep -v '^$'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__verify_arch() {
  local latest="" __verify_arch=""
  latest="${1:-$latest}"
  if echo "$latest" | grep -wq 'x86_64'; then
    verify_arch="x86_64"
  elif echo "$latest" | grep -wq 'amd64'; then
    verify_arch="x86_64"
  elif echo "$latest" | grep -wq 'aarch64'; then
    verify_arch="aarch64"
  elif echo "$latest" | grep -wq 'arm.*'; then
    verify_arch="arm"
  elif echo "$latest" | grep -wqE 'i[1-9]86|x86'; then
    verify_arch="i386"
  else
    verify_arch="x86_64"
  fi
  echo "$verify_arch"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_arch() {
  get_arch=$(uname -i | grep -v 'unknown' | grep '^' || uname -m | grep '^' || uname -p | grep '^')
  if [[ "$get_arch" =~ x86_64* ]]; then
    echo "x86_64"
  elif [[ "$get_arch" =~ i*86 ]]; then
    echo "i386"
  elif [[ "$get_arch" =~ aarch64 ]]; then
    echo "aarch64"
  elif [[ "$get_arch" =~ arm* ]]; then
    echo "$get_arch"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__find_iso() {
  set -o pipefail
  local url="" iso_url="" set_system_arch=""
  url="$1"
  iso_url=""
  set_system_arch="$(__get_arch)"
  if __test_iso "$url"; then
    iso_url="$url"
  else
    iso_url="$(curl -q -LSsf "$url" 2>/dev/null | grep -i "$set_system_arch" | grep 'href="*.*"' | grep -E '[http,ftp]*.*\.iso' | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
    [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    if [ -z "$iso_url" ]; then
      iso_url="$(curl -q -LSsf "$url" 2>/dev/null | grep -i "$set_system_arch" | grep 'href="*.*"' | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      iso_url="$(curl -q -LSsf "$url" 2>/dev/null | grep -E 'x86_64|amd64' | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      iso_url="$(curl -q -LSsf "$url" 2>/dev/null | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      isor="$(curl -q -LSsf "$url" 2>/dev/null | grep '\.iso' | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
      iso_url="$url/$isor"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
    if [ -z "$iso_url" ]; then
      iso_url="$(curl -q -LSsf "$url" 2>/dev/null | __strip_tags | __strip_iso | head -n1 | grep '^' || echo '')"
      [ -n "$iso_url" ] && __test_iso "$iso_url" || iso_url=""
    fi
  fi
  if [ -n "$iso_url" ]; then
    echo "$iso_url"
    return 0
  else
    echo ""
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__latest_iso() {
  local latest
  local exitCode="0"
  __get_torrent "$1"
  url="${1:-$url}"
  file="${2:-$file}"
  latest=$(__find_iso "${url}")
  localname=$(basename "$latest" 2>/dev/null)
  download_dir=$(dirname "${2:-$LATEST_ISO_DOWNLOAD_DIR/$localname}" 2>/dev/null)
  download_file="$download_dir/${file//$download_dir\//}"
  [ -d "$LATEST_ISO_DOWNLOAD_DIR" ] || mkdir -p "$LATEST_ISO_DOWNLOAD_DIR"
  [ -n "$latest" ] || printf_exit "No iso found on $url\n"
  [ -d "$LATEST_ISO_DOWNLOAD_DIR" ] || printf_exit "The download file should not be a directory: $LATEST_ISO_DOWNLOAD_DIR\n"
  echo "$latest" | grep -q '.iso$' || printf_exit "$latest seems to be invalid\n"
  __grab_iso "$latest" "$download_file" && exitCode="0" || exitCode="1"
  if [ "$exitCode" = 0 ]; then
    return 0
  else
    return 2
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__set_filename() {
  echo "$1" | sed "s|.iso$|.$2.iso|g" | grep '^' || echo "$1"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__grab_iso() {
  local exitCode="" url="" latest="" latest_file="" remote_filesize=""
  local system_arch="" iso_arch="" download_file=""
  exitCode="10"
  url="${url:-$1}"
  latest="${1:-$latest}"
  latest_file="${2:-$download_file}"
  remote_filesize="$(__remote_filesize "$latest")"
  system_arch="$(__get_arch)"
  iso_arch="$(__verify_arch "$latest")"
  download_file="$(__set_filename ${latest_file:-$download_file} "$iso_arch")"
  [ -z "$FORCE_INST" ] || __rm_rf "$download_file"
  [ -d "$LATEST_ISO_DOWNLOAD_DIR" ] || mkdir -p "$LATEST_ISO_DOWNLOAD_DIR"
  [ "$system_arch" = "$iso_arch" ] && set_system_arch="$system_arch" || set_system_arch="$iso_arch"
  if [ "$remote_filesize" = "0" ] || [ "$remote_filesize" = "0B" ]; then
    printf_red "URL: $latest"
    printf_error "doesn't seem to be a valid ISO image"
    exitCode="4"
  elif [ -f "$download_file" ] && [ "$LATEST_ISO_OVERWRITE" != "yes" ]; then
    printf_cyan "File already exists in:"
    printf_purple "$download_file"
    [ -n "$remote_filesize" ] && printf_cyan "Remote file size is: $remote_filesize"
    __filesize_local "$download_file"
    exitCode="0"
  elif [ -n "$latest" ]; then
    if { [ "$LATEST_ISO_OVERWRITE" = "yes" ] || [ ! -f "$file" ] || [ "$FORCE_INST" = "yes" ]; }; then
      printf_green "Attempting to locate the ISO from: "
      if echo "$url" | grep -q '.iso$' &>/dev/null; then
        printf_cyan "$(dirname "$url")"
      else
        printf_cyan "$url"
      fi
    fi
    printf_cyan "Grabbing iso for $set_system_arch from:"
    printf_green "$latest"
    printf_purple "and saving it to $download_file"
    printf_blue "The size of the remote ISO is: $remote_filesize"
    if [ -f "$download_file" ] && [ "$LATEST_ISO_OVERWRITE" = "yes" ]; then
      curl -q -LSsf -o "$download_file" -C - "$latest" 2>/dev/null && success="true" || success=""
    else
      curl -q -LSsf -o "$download_file" "$latest" 2>/dev/null && success="true" || success=""
    fi
    [ -f "$download_file" ] && __filesize_local "$download_file"
    if __verify_filesizes $local_file_size $remote_filesize; then
      printf_green "Downloading of the ISO was successful" ||
        { printf_red "Downloading of the ISO was unsuccessful" && exitFailed=1; }
      exitCode=${exitFailed:-0}
    elif ! __verify_filesizes $local_file_size $remote_filesize; then
      printf_red "Downloading of the ISO was unsuccessful"
      exitCode="1"
    else
      printf_red "Error downloading the ISO"
      exitCode="2"
    fi
  fi
  echo ""
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__verify_filesizes() {
  local local_version="" remote_version=""
  local_version="$(printf '%s' "$1" | sed 's/[^0-9]*//g' | tr -d '\n')"
  remote_version="$(printf '%s' "$2" | sed 's/[^0-9]*//g' | tr -d '\n')"
  if [ "$remote_version" -le $local_version ]; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__filesize_local() {
  set -o pipefail
  local local_file=""
  local_file="${1:-$download_file}"
  local_file_size=""
  if [ -f "$local_file" ]; then
    local_file_size="$(find "$download_file" -type f -exec du -h {} \; | awk '{print $1}' | grep -v '^$' || echo '')"
    if [ -n "$local_file_size" ]; then
      printf_cyan "The size of the local file is: $local_file_size"
    else
      return 1
    fi
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__remote_filesize() {
  set -o pipefail
  local head="" content_length="" content_length_count=""
  head="$(curl -q -LSsfI "$1" 2>/dev/null)"
  content_length_count="$(echo "$head" | grep -ic 'content-length' || echo 1)"
  if [ $content_length_count = 1 ]; then
    content_length="$(echo "$head" | grep -ai 'content-length' | head -n1 | awk -v IGNORECASE=1 'BEGIN{RS="\r\n"} /^content-length/ { print $2 }')"
  elif [ "$content_length_count" != 1 ]; then
    content_length="$(echo "$head" | grep -ai 'content-length' | tail -n1 | awk -v IGNORECASE=1 'BEGIN{RS="\r\n"} /^content-length/ { print $2 }')"
  fi
  if [ "$content_length" = 0B ]; then
    content_length=""
  fi
  [ -n "$content_length" ] || content_length=0
  if cmd_exists numfmt; then
    numfmt --to=iec-i --suffix=B "$content_length" | sed 's|iB$||g'
  elif cmd_exists gnumfmt; then
    gnumfmt --to=iec-i --suffix=B "$content_length" | sed 's|iB$||g'
  else
    printf '%s\n' "$content_length"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_iso() {
  local get_iso=""
  get_iso="$(curl -q -LSsf "$1" 2>/dev/null || echo '')"
  [ -n "$get_iso" ] &&
    echo "$get_iso" |
    grep -a "${2:-^}" |
      __strip_tags |
      __strip_iso |
      head -n1 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_torrent() {
  if echo "$1" | grep -qE 'magnet:|iso.torrent$'; then
    printf_yellow "This appears to be a torrent"
    printf_blue "Downloading torrent via transmission"
    transadd "$1"
    exit $?
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__github_api() {
  local repo=""
  repo="$(echo "$1" | sed 's|.*://||g;s|.*.github.com/||g' || echo "$1")"
  if echo "$repo" | grep -q 'api.github.com'; then
    api="$1"
  else
    api="https://api.github.com/repos/${repo:-$1}/releases/latest"
  fi
  results="$(curl -q -LSsf -H "Accept: application/vnd.github+json" "$api" |
    jq -r '.[]' | grep 'browser_download_url' | awk -F'": ' '{print $2}' |
    sed 's|"||g' | grep '.iso$' | sort | head -n1 | grep '^')"
  [ -n "$results" ] && echo "$results" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__latest_list() {
  local statusCode=0
  while :; do
    case $1 in
    alma)
      shift 1
      isourl="$(curl -q -LSsf "$LATEST_ISO_ALMA_URL" 2>/dev/null | __sort_v)/isos/x86_64"
      isoname="$(curl -q -LSsf "$LATEST_ISO_ALMA_URL/$isourl" 2>/dev/null | __strip_tags | grep "${1:-minimal}.iso$" | head -n1)"
      __latest_iso "$LATEST_ISO_ALMA_URL/$isourl/$isoname" "$LATEST_ISO_DOWNLOAD_DIR/alma.iso"
      statusCode=$(($? + $statusCode))
      ;;
    alpine)
      shift 1
      isourl="$(curl -q -LSsf https://dl-cdn.alpinelinux.org/alpine/latest-stable/releases/${set_system_arch:-x86_64} | __strip_tags | sort -rV | grep -E "extended" | grep '.iso$' | head -n1 | grep '^')"
      [ -z "$isourl" ] && isourl="$(curl -q -LSsf https://dl-cdn.alpinelinux.org/alpine/latest-stable/releases/${set_system_arch:-x86_64} | __strip_tags | sort -rV | grep -E "standard" | grep '.iso$' | head -n1 | grep '^')"
      __latest_iso "$LATEST_ISO_ALPINE_URL" "$LATEST_ISO_DOWNLOAD_DIR/alpine.iso"
      statusCode=$(($? + $statusCode))
      ;;
    arch)
      shift 1
      isourl="$(curl -q -LSsf "$LATEST_ISO_ARCHLINUX_URL" | __strip_tags | __strip_iso | head -n1)"
      __latest_iso "$LATEST_ISO_ARCHLINUX_URL/$isourl" "$LATEST_ISO_DOWNLOAD_DIR/arch.iso"
      statusCode=$(($? + $statusCode))
      ;;
    archcraft)
      shift 1
      isourl="$(__github_api "$LATEST_ISO_ARCHCRAFT_URL")"
      __latest_iso "$isourl" "$LATEST_ISO_DOWNLOAD_DIR/archcraft.iso"
      statusCode=$(($? + $statusCode))
      ;;
    arco)
      shift 1
      isourl="$(curl -q -LSsf "$LATEST_ISO_ARCOLINUX_URL" | __strip_tags | grep 'v[0-9]' | sort -ruV | head -n1)"
      isoname="$(curl -q -LSsf "$LATEST_ISO_ARCOLINUX_URL/$isourl" | __strip_tags | grep 'arcolinuxl' | __strip_iso | head -n1)"
      __latest_iso "$LATEST_ISO_ARCOLINUX_URL/$isourl/$isoname" "$LATEST_ISO_DOWNLOAD_DIR/arco.iso"
      statusCode=$(($? + $statusCode))
      ;;
    centos)
      shift 1
      __latest_iso "$LATEST_ISO_CENTOS_URL" "$LATEST_ISO_DOWNLOAD_DIR/centos.iso"
      statusCode=$(($? + $statusCode))
      ;;
    clear)
      shift 1
      isourl="$(curl -q -LSsf "$LATEST_ISO_CLEAR_URL/" | __strip_tags | __sort_v)"
      isoname="$(curl -q -LSsf "$LATEST_ISO_CLEAR_URL/$isourl/clear/" | __strip_tags | grep -i 'desktop' | __strip_iso)"
      __latest_iso "$LATEST_ISO_CLEAR_URL/$isourl/clear/$isoname" "$LATEST_ISO_DOWNLOAD_DIR/clear.iso"
      statusCode=$(($? + $statusCode))
      ;;
    debian)
      shift 1
      __latest_iso "$LATEST_ISO_DEBIAN_URL" "$LATEST_ISO_DOWNLOAD_DIR/debian.iso"
      statusCode=$(($? + $statusCode))
      ;;
    endeavour)
      shift 1
      isourl="$(curl -q -LSsf "$LATEST_ISO_ENDEAVOUR_URL" | __strip_tags | grep 'iso$' | grep "Artemis" | head -n1)"
      isoname="$LATEST_ISO_ENDEAVOUR_URL/$isourl"
      __latest_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/endeavour.iso"
      statusCode=$(($? + $statusCode))
      ;;
    fedora)
      shift 1
      __latest_iso "$LATEST_ISO_FEDORA_URL" "$LATEST_ISO_DOWNLOAD_DIR/fedora.iso"
      statusCode=$(($? + $statusCode))
      ;;
    garuda)
      shift 1
      __latest_iso "$LATEST_ISO_GARUDA_URL" "$LATEST_ISO_DOWNLOAD_DIR/garuda.iso"
      statusCode=$(($? + $statusCode))
      ;;
    heads)
      shift 1
      __latest_iso "$LATEST_ISO_HEADS_URL" "$LATEST_ISO_DOWNLOAD_DIR/heads.iso"
      statusCode=$(($? + $statusCode))
      ;;
    kali)
      shift 1
      __latest_iso "$LATEST_ISO_KALI_URL" "$LATEST_ISO_DOWNLOAD_DIR/kali.iso"
      statusCode=$(($? + $statusCode))
      ;;
    manjaro)
      shift 1
      isoname="$(curl -q -LSsf "$LATEST_ISO_MANJARO_URL" | __strip_tags | grep 'xfce' | grep 'iso$' | sort -V | head -n1)"
      __latest_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/manjaro.iso"
      statusCode=$(($? + $statusCode))
      ;;
    openvz)
      shift 1
      isourl="$(curl -q -LSsf "$LATEST_ISO_OPENVZ_URL" | __sort_v)"
      isoname="$(curl -q -LSsf "$LATEST_ISO_OPENVZ_URL/$isourl/x86_64/iso/" | __strip_tags | __strip_iso | head -n1)"
      __latest_iso "$LATEST_ISO_OPENVZ_URL/$isourl/x86_64/iso/$isoname" "$LATEST_ISO_DOWNLOAD_DIR/openvz.iso"
      statusCode=$(($? + $statusCode))
      ;;
    parrot)
      shift 1
      isourl="$(__get_iso "$LATEST_ISO_PARROT_URL" "security" | head -n1)"
      isoname="$LATEST_ISO_PARROT_URL/$isourl"
      __latest_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/parrot.iso"
      statusCode=$(($? + $statusCode))
      ;;
    peppermint)
      shift 1
      isoname="$(curl -q -LSsf "$LATEST_ISO_PEPPERMINT_URL/" | __strip_tags | __strip_iso | grep -E 'x86_64|amd64')"
      __latest_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/peppermint.iso"
      statusCode=$(($? + $statusCode))
      ;;
    photon)
      shift 1
      __latest_iso "$LATEST_ISO_PHOTON_URL" "$LATEST_ISO_DOWNLOAD_DIR/photon.iso"
      statusCode=$(($? + $statusCode))
      ;;
    proxmox)
      shift 1
      isourl="$(curl -q -LSsf "$LATEST_ISO_PROXMOX_URL" 2>/dev/null | __sort_rv | grep -i 'proxmox-ve_')"
      __latest_iso "$LATEST_ISO_PROXMOX_URL/$isourl" "$LATEST_ISO_DOWNLOAD_DIR/proxmox.iso"
      statusCode=$(($? + $statusCode))
      ;;
    rocky)
      shift 1
      isourl="$(curl -q -LSsf "$LATEST_ISO_ROCKY_URL" 2>/dev/null | __sort_v)/isos/x86_64"
      isoname="$LATEST_ISO_ROCKY_URL/$isourl/$(curl -q -LSsf "$LATEST_ISO_ROCKY_URL/$isourl" 2>/dev/null | __strip_tags | grep 'minimal.iso$')"
      __latest_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/rocky.iso"
      statusCode=$(($? + $statusCode))
      ;;
    ubuntu)
      shift 1
      isoname="$LATEST_ISO_UBUNTU_URL/$(curl -q -LSsf "$LATEST_ISO_UBUNTU_URL" 2>/dev/null | __sort_v)/release"
      __latest_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/ubuntu.iso"
      statusCode=$(($? + $statusCode))
      ;;
    tails)
      shift 1
      __latest_iso "$LATEST_ISO_TAILS_URL" "$LATEST_ISO_DOWNLOAD_DIR/tails.iso"
      statusCode=$(($? + $statusCode))
      ;;
    tiny)
      shift 1
      isoversion="$(curl -q -LSsf "http://tinycorelinux.net/downloads.html" | __strip_tags | grep '.iso$' | grep -i 'plus' | head -n1)"
      isoname="$LATEST_ISO_TINYCORE_URL/$isoversion"
      __latest_iso "$isoname" "$LATEST_ISO_DOWNLOAD_DIR/tiny.iso"
      statusCode=$(($? + $statusCode))
      ;;
    *)
      break
      ;;
    esac
  done
  exitCode=$statusCode
  return $exitCode
}
