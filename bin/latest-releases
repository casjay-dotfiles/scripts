#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108100527-git"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#set opts
trap 'exitCode=${exitCode:-$?};[ -f "$LATEST_RELEASE_TEMP_FILE" ] && rm -Rf "$LATEST_RELEASE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108100527-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : latest-release --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Tuesday, Aug 10, 2021 05:27 EDT
# @File          : latest-release
# @Description   :
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$LATEST_RELEASE_CONFIG_DIR/$LATEST_RELEASE_CONFIG_FILE"
  [ -d "$LATEST_RELEASE_CONFIG_DIR" ] || mkdir -p "$LATEST_RELEASE_CONFIG_DIR"
  [ -d "$LATEST_RELEASE_CONFIG_BACKUP_DIR" ] || mkdir -p "$LATEST_RELEASE_CONFIG_BACKUP_DIR"
  [ -f "$LATEST_RELEASE_CONFIG_DIR/$LATEST_RELEASE_CONFIG_FILE" ] &&
    cp -Rf "$LATEST_RELEASE_CONFIG_DIR/$LATEST_RELEASE_CONFIG_FILE" "$LATEST_RELEASE_CONFIG_BACKUP_DIR/$LATEST_RELEASE_CONFIG_FILE.$$"
  cat <<EOF >"$LATEST_RELEASE_CONFIG_DIR/$LATEST_RELEASE_CONFIG_FILE"
# Settings for latest-release
LATEST_RELEASE_GITHUB_TOKEN="$GITHUB_ACCESS_TOKEN"
LATEST_RELEASE_GITHUB_AUTH_FILE="$LATEST_RELEASE_CONFIG_DIR/auth.conf"
LATEST_RELEASE_REPO_LIST="$LATEST_RELEASE_CONFIG_DIR/repos.conf"
LATEST_RELEASE_TEMP_FILE="${TMPDIR:-/tmp}/latest-release"
LATEST_RELEASE_NOTIFY_ENABLED="yes"
LATEST_RELEASE_NOTIFY_CLIENT_NAME="\${NOTIFY_CLIENT_NAME:-\$APPNAME}"
LATEST_RELEASE_NOTIFY_CLIENT_ICON="\${NOTIFY_CLIENT_ICON:-\$LATEST_RELEASE_NOTIFY_CLIENT_ICON}"
LATEST_RELEASE_CURL_HEADER='-H "Authorization: token '${LATEST_RELEASE_GITHUB_TOKEN:-$LATEST_RELEASE_GITHUB_TOKEN}'"'

EOF

  if [ ! -f "${LATEST_RELEASE_REPO_LIST}" ]; then
    cat <<EOF >"${LATEST_RELEASE_REPO_LIST}"
gokcehan/lf
docker/docker-ce
nodejs/node
justjanne/powerline-go
EOF
  fi

  if [ ! -f "${LATEST_RELEASE_GITHUB_AUTH_FILE}" ]; then
    cat <<EOF >"${LATEST_RELEASE_GITHUB_AUTH_FILE}"
GITHUB_USERNAME="$GITHUB_USERNAME"
GITHUB_ACCESS_TOKEN="$GITHUB_ACCESS_TOKEN"
EOF
  fi

  if [ -f "$LATEST_RELEASE_CONFIG_DIR/$LATEST_RELEASE_CONFIG_FILE" ] && [ -f "$LATEST_RELEASE_GITHUB_AUTH_FILE" ] && [ -f "$LATEST_RELEASE_REPO_LIST" ]; then
    printf_green "Your config file for latest-release has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_available() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Defaults
exitCode=""
LATEST_RELEASE_CONFIG_FILE="settings.conf"
LATEST_RELEASE_CONFIG_DIR="$HOME/.config/myscripts/latest-release"
LATEST_RELEASE_CONFIG_BACKUP_DIR="$HOME/.local/share/myscripts/latest-release/backups"
LATEST_RELEASE_OPTIONS_DIR="$HOME/.local/share/myscripts/latest-release/options"
LATEST_RELEASE_TEMP_FILE="${TMPDIR:-/tmp}/latest-release"
LATEST_RELEASE_NOTIFY_ENABLED="yes"
LATEST_RELEASE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
LATEST_RELEASE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$LATEST_RELEASE_NOTIFY_CLIENT_ICON}"
LATEST_RELEASE_GITHUB_TOKEN="$GITHUB_ACCESS_TOKEN"
LATEST_RELEASE_CURL_HEADER='-H "Authorization: token '${LATEST_RELEASE_GITHUB_TOKEN:-$LATEST_RELEASE_GITHUB_TOKEN}'"'
LATEST_RELEASE_REPO_LIST="$LATEST_RELEASE_CONFIG_DIR/repos.conf"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="v,h"
LONGOPTS="options,config,version,help"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate Files
[ -f "$LATEST_RELEASE_CONFIG_DIR/$LATEST_RELEASE_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
if [ -f "$LATEST_RELEASE_CONFIG_DIR/$LATEST_RELEASE_CONFIG_FILE" ]; then
  . "$LATEST_RELEASE_CONFIG_DIR/$LATEST_RELEASE_CONFIG_FILE"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_available "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_available "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_available "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
export NOTIFY_CLIENT_NAME="${LATEST_RELEASE_NOTIFY_CLIENT_NAME}"
export NOTIFY_CLIENT_ICON="${LATEST_RELEASE_NOTIFY_CLIENT_ICON}"
if [ "$LATEST_RELEASE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash jq curl || exit 1 # exit 1 if not found
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
printf_green "Latest releases on GitHub:"
nl=$'\n'
out=""
while read -r repo; do
  tag_info=""
  tag_name=""
  tag_commit_url=""
  tag_commit_date=""
  set -e
  if ! tag_info="$(curl -q -LS ${LATEST_RELEASE_CURL_HEADER} "https://api.github.com/repos/${repo}/tags?per_page=1" 2>/dev/null | jq -r ".[0].name, .[0].commit.url" | paste -sd,-)"; then
    printf_green "You are API rate limited by GitHub, please authenticate by:"
    printf_green 'export LATEST_RELEASE_GITHUB_TOKEN="youraccesstoken"'
    exit "${?}"
  fi
  set -e
  tag_name="$(cut -d ',' -f 1 <<<"${tag_info}")"
  tag_commit_url="$(cut -d ',' -f 2 <<<"${tag_info}")"
  tag_commit_date="$(curl "${LATEST_RELEASE_CURL_HEADER}" -s "${tag_commit_url}" 2>/dev/null | jq -r ".commit.author.date" | cut -d 'T' -f 1)"
  out+=$"${repo} | ${tag_name} | ${tag_commit_date}${nl}"
done <"${LATEST_RELEASE_REPO_LIST}"
column -t <<<"${out}" | sort -t "|" -k 3 -r | printf_readline "6"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
