export LATEST_RELEASES_CWD
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set actions based on variables

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
#requiresudo "$0" "$@" || exit 2     # exit 2 if errors
#cmd_exists --error --ask bash || exit 3 # exit 3 if not found
#am_i_online --error || exit 4           # exit 4 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
token)
  [ -n "$LATEST_RELEASE_GITHUB_TOKEN" ] && printf_cyan "Your API Token is set" || printf_exit "Token is not set"
  exit
  ;;
add)
  shift 1
  for l in "$@"; do
    __add_to_latest "$l"
  done
  exit
  ;;

remove)
  shift 1
  for l in "$@"; do
    __remove_from_latest "$l"
  done
  exit
  ;;

install)
  shift 1
  __update_install "$@"
  exit $?
  ;;

update)
  shift 1
  __update_install "$@"
  exit $?
  ;;

gitea)
  shift 1
  __gitea "$@"
  ;;

info)
  shift 1
  __show_latest
  ;;

list)
  shift 1
  show="$(<"$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST")"
  if [ -n "$show" ]; then
    printf_purple "The following packages are available for installation:"
    printf '%s\n' "$show" | printf_column "$LATEST_RELEASES_OUTPUT_COLOR_1"
  else
    printf_return "There are no packages available"
  fi
  exit $?
  ;;

search)
  shift 1
  [ $# -ge 1 ] || printf_exit "Usage: $APPNAME search [repo,api]"
  case "$1" in
  repo)
    shift 1
    [ $# = 0 ] && __search_help || __api_repos "$@"
    exit $?
    ;;
  api)
    shift 1
    [ $# -ge 1 ] || printf_exit "Usage: $APPNAME search api [repo,search] searchTerm"
    case "$1" in
    release)
      shift 1
      [ $# = 0 ] && __search_help && exit 1 || printf_purple "Searching for $*"
      if echo "$1" | grep -vq './.' && [ $# = 0 ]; then
        __search_help
      elif [ $# -eq 1 ]; then
        __curl_json_all "$1" | printf_readline "$LATEST_RELEASES_OUTPUT_COLOR_1"
      elif [ $# -gt 1 ]; then
        __curl_json_all "$1" | grep -i $3 "$2" | printf_readline "$LATEST_RELEASES_OUTPUT_COLOR_1"
      fi
      ;;
    *)
      query="$1"
      # { printf_purple "Searching github for $*" && __api_search "$@" || printf_exit "No results found for ${1:-$repo}"; }
      printf_purple "Searching github for $*"
      results="$(search_gh_api "$query" | grep '^' || __api_search "$query")"
      if [ -n "$results" ]; then
        #printf_cyan "Found the following results for $query"
        printf '%s\n' "$results" | printf_readline "$LATEST_RELEASES_OUTPUT_COLOR_1"
      else
        printf_red "No results found for $query"
      fi
      exit $?
      ;;
    esac
    ;;
  *)
    printf_exit "Usage: $APPNAME search api [repo,search] searchTerm"
    ;;
  esac
  ;;

*)
  if [ $# -ne 0 ]; then
    for app in "$@"; do
      if echo "$app" | grep -q '/'; then
        __install_latest "$app" && true || false
      else
        printf_custom "${YELLOW}$app${NC} ${RED}is an invalid repo: format is user/repo${NC}"
      fi
    done
  else
    __show_latest
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set exit code
exitCode="${exitCode:-$?}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
