# - - - - - - - - - - - - - - - - - - - - - - - - -
__clean_old_bin() { { [ -n "$1" ] && [ -e "$LATEST_RELEASES_BIN_DIR_USER/$1" ]; } && rm -Rf "${LATEST_RELEASES_BIN_DIR_USER:?}/$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Extract a downloaded archive into an already-existing destination directory.
# Dispatches on filename extension the same way __github's case-statement did,
# so tarballs with .bz2/.tar.bz2/.tar.gz/.tgz/.gz/.xz/.zip/.7z all land correctly.
# A bare `.gz`/`.xz`/`.bz2` is still handled by tar (for `foo.tar` misnamed as
# `foo.gz`, etc.) - matches the pre-refactor behavior. Returns 0 on success,
# 1 on any failure so callers can abort the install flow.
# Usage: __extract_archive <archive_path> <dest_dir>
__extract_archive() {
  local archive="${1:-}" dest="${2:-}"
  [ -n "$archive" ] && [ -f "$archive" ] && [ -n "$dest" ] || return 1
  [ -d "$dest" ] || mkdir -p "$dest" || return 1
  case "$archive" in
    *.tar.bz2|*.tbz2|*.bz2)
      tar xjfv "$archive" -C "$dest" &>/dev/null
      ;;
    *.tar.gz|*.tgz|*.tar.xz|*.txz|*.tar|*.gz|*.xz)
      tar xfv "$archive" -C "$dest" &>/dev/null
      ;;
    *.zip)
      unzip -o "$archive" -d "$dest" &>/dev/null
      ;;
    *.7z)
      [ -d "$dest" ] && rm -Rf "${dest:?}"/* 2>/dev/null
      mkdir -p "$dest"
      7za x -y "$archive" -o"$dest" &>/dev/null
      ;;
    *)
      return 1
      ;;
  esac
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Given an extracted directory, sweep obvious metadata/documentation files so
# the single-vs-multi detector below isn't fooled by README/LICENSE/man-page
# clutter shipped alongside a single binary. Conservative - only matches names
# that are unambiguously non-functional. Does nothing if dest doesn't exist.
# Usage: __cleanup_meta_files <dir>
__cleanup_meta_files() {
  local dir="${1:-}" rm_file
  [ -n "$dir" ] && [ -d "$dir" ] || return 0
  shopt -s nullglob 2>/dev/null || true
  for rm_file in \
    "$dir"/*.md "$dir"/*.txt "$dir"/*.rst \
    "$dir"/*.html "$dir"/*.adoc "$dir"/*.pdf \
    "$dir"/README* "$dir"/readme* \
    "$dir"/LICENSE* "$dir"/license* "$dir"/COPYING* \
    "$dir"/CHANGELOG* "$dir"/CHANGES* "$dir"/NEWS* \
    "$dir"/NOTICE* "$dir"/AUTHORS* "$dir"/CONTRIBUTORS* \
    "$dir"/*.1 "$dir"/*.2 "$dir"/*.3 "$dir"/*.4 \
    "$dir"/*.5 "$dir"/*.6 "$dir"/*.7 "$dir"/*.8 \
    "$dir"/.editorconfig "$dir"/.gitattributes \
    "$dir"/.gitignore "$dir"/.git*; do
    [ -e "$rm_file" ] && rm -Rf "$rm_file"
  done
  shopt -u nullglob 2>/dev/null || true
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Locate the binary inside an extracted tree. Walks through several fallback
# find strategies in the same order __github used to, so the resolver keeps
# handling the wide variety of archive layouts seen in the wild (flat binary,
# versioned subdir `$name-$version/`, arch-suffixed binary, nested bin/ dir).
# Echoes the absolute path on success, returns 1 if nothing plausible found.
# Usage: __locate_binary <extract_dir> <hint_name>
__locate_binary() {
  local dir="${1:-}" hint="${2:-}" found=""
  [ -n "$dir" ] && [ -d "$dir" ] && [ -n "$hint" ] || return 1
  # Layer 1: executable file whose basename matches the hint exactly
  found="$(find "$dir" -maxdepth 3 -type f -executable -iname "$hint" 2>/dev/null | __grep -i "$hint$" | head -n1)"
  # Layer 2: same but without -executable (some archives don't set the bit)
  [ -n "$found" ] || found="$(find "$dir" -maxdepth 3 -type f -iname "$hint" 2>/dev/null | __grep -i "$hint$" | head -n1)"
  # Layer 3: split the hint on `-` and try each half as a search root
  if [ -z "$found" ]; then
    local search
    search="${hint//-*/}"
    found="$(find "$dir" -maxdepth 3 -type f -executable -iname "$search" 2>/dev/null | __grep -iE "^$search|$search$" | head -n1)"
    if [ -z "$found" ]; then
      search="${hint//*-/}"
      found="$(find "$dir" -maxdepth 3 -type f -executable -iname "$search" 2>/dev/null | __grep -iE "^$search|$search$" | head -n1)"
    fi
  fi
  # Layer 4: arch-suffixed variants (name-amd64, name-arm64, ...)
  if [ -z "$found" ]; then
    local try_arch
    for try_arch in aarch64 arm64 amd64 x86_64; do
      found="$(find "$dir" -maxdepth 2 -type f -executable -iname "${hint}*${try_arch}" 2>/dev/null | head -n1)"
      [ -n "$found" ] && break
    done
  fi
  # Layer 5: give up on matching the hint, take any executable file
  [ -n "$found" ] || found="$(find "$dir" -type f -executable 2>/dev/null | head -n1)"
  [ -n "$found" ] || return 1
  printf '%s\n' "$found"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# The unified download-extract-install pipeline shared by __github, __gitea, and
# __gitlab. Each service-specific function now just resolves an upstream URL, then
# hands off here for the download + archive handling + binary install + state
# recording. Anything that writes to disk lives here - the service functions are
# pure URL resolvers.
#
# Usage:
#   __fetch_and_install <service> <url> <bin_name> <version> <tracking_entry> [repo_description]
#
# - service:         "github" / "gitea" / "gitlab" - used in logs/tracking only
# - url:             the concrete .iso/.tar.gz/bare-binary URL to fetch
# - bin_name:        desired name on disk (e.g. "fastfetch", "zed")
# - version:         version string for installed.db (empty if unknown)
# - tracking_entry:  the full "service;repo:binname:desc" string for __update_latest_list
# - repo_description optional - passed through for tracking-list display
#
# Returns 0 on success, non-zero on any failure in the pipeline.
__fetch_and_install() {
  local service="${1:-unknown}" url="${2:-}" bin_name="${3:-}" version="${4:-}"
  local tracking_entry="${5:-}" _description="${6:-}"
  [ -n "$url" ] && [ -n "$bin_name" ] || { printf_red "__fetch_and_install: url and bin_name required"; return 1; }
  local tempfile="$LATEST_RELEASES_TEMP_FILE"
  local download_dir="$LATEST_RELEASE_DOWNLOADS"
  local basename="${url##*/}"
  local download_file="$download_dir/$basename"
  # Flat share layout: one dir per installed tool, named by bin_name (not by org).
  local extract_dir="$LATEST_RELEASE_INSTALL_DIR/$bin_name"
  local target="$LATEST_RELEASES_BIN_DIR_USER/$bin_name"
  # Decide whether the URL points at a real archive. A bare binary URL skips
  # extraction entirely and just copies the download into bin/.
  local is_archive="false"
  case "$basename" in
    *.tar|*.tar.gz|*.tgz|*.tar.bz2|*.tbz2|*.tar.xz|*.txz|*.gz|*.xz|*.bz2|*.zip|*.7z)
      is_archive="true" ;;
  esac
  mkdir -p "$download_dir" "$LATEST_RELEASES_BIN_DIR_USER"
  printf_green "Attempting to download $basename from $url"
  __wget "$url" "$tempfile" || { printf_red "Failed to download $url"; return 2; }
  [ -s "$tempfile" ] || { printf_red "Downloaded file is empty: $url"; return 2; }
  __cp_rf "$tempfile" "$download_file" || { printf_red "Failed to stage $download_file"; return 2; }
  local state_extdir="" state_binfiles="$target" binary_path="" exec_count=0
  if [ "$is_archive" = "true" ]; then
    [ -d "$extract_dir" ] && __rm_rf "$extract_dir"
    __extract_archive "$download_file" "$extract_dir" || { printf_red "Failed to extract $basename"; return 3; }
    # If the archive wrapped its contents in a single top-level dir like
    # `$name-$version/`, flatten that one level up into extract_dir so find logic
    # below doesn't have to know about it. Matches pre-refactor behavior.
    if [ "$(find "$extract_dir" -maxdepth 1 -mindepth 1 2>/dev/null | wc -l)" = "1" ]; then
      local only_entry
      only_entry="$(find "$extract_dir" -maxdepth 1 -mindepth 1 2>/dev/null | head -n1)"
      if [ -d "$only_entry" ]; then
        rsync -ah "$only_entry/." "$extract_dir/" --delete-after 2>/dev/null
        rm -Rf "$only_entry"
      fi
    fi
    __cleanup_meta_files "$extract_dir"
    binary_path="$(__locate_binary "$extract_dir" "$bin_name")"
    [ -n "$binary_path" ] || { printf_red "Could not locate a binary in $extract_dir"; return 4; }
    # Count only top-level executables, so a single binary shipped with leftover
    # non-exec files still counts as "single-file" and lands in bin/ directly.
    exec_count="$(find "$extract_dir" -maxdepth 1 -type f -executable 2>/dev/null | wc -l)"
    if [ "$exec_count" = "1" ]; then
      # Single-file install: copy the binary, nuke the whole share tree.
      __clean_old_bin "$bin_name"
      __cp_rf "$binary_path" "$target" || { printf_red "Failed to install $target"; return 5; }
      chmod 755 "$target" 2>/dev/null
      __rm_rf "$extract_dir"
    else
      # Multi-file install: keep the tree, write a cd+exec wrapper.
      __write_wrapper "$target" "$extract_dir" "$binary_path" || { printf_red "Failed to write wrapper at $target"; return 5; }
      state_extdir="$extract_dir"
    fi
  else
    # Bare binary: the downloaded file IS the executable. Just copy + chmod.
    __clean_old_bin "$bin_name"
    __cp_rf "$download_file" "$target" || { printf_red "Failed to install $target"; return 5; }
    chmod 755 "$target" 2>/dev/null
  fi
  # Optional secondary install to system bin (--system flag). Only fires when
  # LATEST_RELEASE_INSTALL_TO_SYSTEM_BIN=yes AND the user is root-or-sudo-capable.
  if [ "$LATEST_RELEASE_INSTALL_TO_SYSTEM_BIN" = "yes" ]; then
    if { [ "$(id -u)" = "0" ] || __can_i_sudo; } && [ -x "$target" ] && [ ! -L "$target" ]; then
      printf_green "Copying $bin_name to $LATEST_RELEASES_BIN_DIR_SYSTEM/$bin_name"
      __sudo cp -Rf "$target" "$LATEST_RELEASES_BIN_DIR_SYSTEM/$bin_name"
      __sudo chmod 755 "$LATEST_RELEASES_BIN_DIR_SYSTEM/$bin_name" 2>/dev/null
      [ -f "$LATEST_RELEASES_BIN_DIR_SYSTEM/$bin_name" ] && state_binfiles+=",$LATEST_RELEASES_BIN_DIR_SYSTEM/$bin_name"
    fi
  fi
  # Record in installed.db for safe uninstall, and keep the user-facing tracking
  # list (repos.conf) in sync.
  __save_details "$bin_name" "$version" "$state_binfiles" "$state_extdir"
  [ -n "$tracking_entry" ] && __update_latest_list "$tracking_entry"
  # Ephemeral staging: delete the archive, rmdir the download dir if empty.
  [ -f "$download_file" ] && rm -f "$download_file"
  rmdir "$download_dir" 2>/dev/null || true
  printf_cyan "Installed $bin_name to $target ($service, v${version:-unknown})"
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Write a POSIX shell wrapper at $1 that cd's into the share dir ($2) then execs
# the binary at $3 (absolute path). Using a relative path after cd means apps like
# zed / vim / neovim that probe cwd or argv[0] for their own resources find the
# rest of the tree naturally. Wrapper is chmod 755 and overwrites any stale
# symlink/file at the target path.
# Usage: __write_wrapper <wrapper_path> <share_dir> <abs_binary_path>
__write_wrapper() {
  local wrapper_path="${1:-}" share_dir="${2:-}" target_bin="${3:-}"
  [ -n "$wrapper_path" ] && [ -n "$share_dir" ] && [ -n "$target_bin" ] || return 1
  # Relative path from share_dir to the binary, so the exec line shows what's
  # actually inside the tree (more informative than a duplicated absolute path).
  local rel_bin="${target_bin#$share_dir/}"
  # Clear any existing symlink or stub so the new wrapper always lands cleanly.
  [ -L "$wrapper_path" ] && unlink "$wrapper_path" 2>/dev/null
  [ -e "$wrapper_path" ] && rm -Rf "${wrapper_path:?}" 2>/dev/null
  cat >"$wrapper_path" <<WRAPPER
#!/bin/sh
# Auto-generated by latest-releases. Wraps a multi-file install that lives in a
# share tree. cd first so the app can locate its runtime resources by argv[0]
# or getcwd() the same way it would if you ran it from the share dir directly.
cd "$share_dir" || exit 1
exec "./$rel_bin" "\$@"
WRAPPER
  chmod 755 "$wrapper_path" 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Take a filename, strip any "...-<arch>" suffix (amd64/arm64/aarch64/x86_64), lowercase.
# Used in 3 __github code paths that all need the same binary-name derivation.
# Replaces a `basename | sed | tr` pipeline (3 forks) with pure bash parameter expansion.
__derive_bin_name() {
  local _n="${1##*/}"
  _n="${_n//*-amd64/}"
  _n="${_n//*-arm64/}"
  _n="${_n//*-aarch64/}"
  _n="${_n//*-x86_64/}"
  printf '%s' "${_n,,}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__grep_include() { sed 's|"||g' | __grep -Ei 'linux|mac|win|i386|arm|amd|x86|aarch|tar|gz|xz|zip|bz2|exe'; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__grep_exclude() { sed 's|"||g' | __grep -viE '*.txt$|*.pem$|*.sbom$|*.sig$|*.gpg$|*.md5$|*.sha512$|*.sha256$'; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__update_latest_list() { __add_to_latest "$1" "${2:-$1}" "${3:-$1}" &>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Return the part before the first `;` if the input contains one. Returns 1 otherwise.
# Previously: echo "$1" | grep ';' | awk -F ';' '{print $1}' - 3 forks per call.
__get_service() { [[ "$1" == *";"* ]] || return 1; local _s="${1%%;*}"; [ -n "$_s" ] && printf '%s\n' "$_s" || return 1; }
# Validate "user/repo" format (two alphanumeric segments separated by a slash).
__check_if_repo() { [[ "$1" =~ [a-zA-Z0-9]/[a-zA-Z0-9] ]] || { printf_custom "${YELLOW}$1${NC} ${RED}is an invalid repo: format is user/repo${NC}" && return 1; }; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Persist install metadata for safe uninstall. One aggregate DB at
# $LATEST_RELEASES_CACHE_DIR/installed.db, colon-delimited:
#   name:version:binfiles:extracteddir
# `binfiles` is a comma-separated list of paths this script wrote - usually one
# (user bin dir) but two when --system install copied into the system bin dir.
# `extracteddir` is empty for single-file installs (where __github already cleans
# the extraction dir). Re-installing the same name replaces the prior entry.
# Usage: __save_details <name> <version> <binfiles-comma-sep> <extracteddir>
__save_details() {
  local name="${1:-}" version="${2:-}" binfiles="${3:-}" extdir="${4:-}"
  local db="$LATEST_RELEASES_CACHE_DIR/installed.db"
  [ -n "$name" ] || return 1
  [ -d "$LATEST_RELEASES_CACHE_DIR" ] || mkdir -p "$LATEST_RELEASES_CACHE_DIR" 2>/dev/null
  # Drop any pre-existing line for this name, then append the new entry.
  if [ -f "$db" ]; then
    __grep -v "^${name}:" "$db" >"${db}.tmp" 2>/dev/null
    mv -f "${db}.tmp" "$db" 2>/dev/null || true
  fi
  printf '%s:%s:%s:%s\n' "$name" "$version" "$binfiles" "$extdir" >>"$db"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Look up a name in installed.db. Prints the full entry line on success, returns 1 if
# no match. Callers split with `IFS=: read -r name version binfile extdir`.
__lookup_details() {
  local name="${1:-}" db="$LATEST_RELEASES_CACHE_DIR/installed.db"
  [ -n "$name" ] && [ -f "$db" ] || return 1
  __grep "^${name}:" "$db" | head -n1 | __grep '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Remove a name's entry from installed.db (used after successful uninstall).
__forget_details() {
  local name="${1:-}" db="$LATEST_RELEASES_CACHE_DIR/installed.db"
  [ -n "$name" ] && [ -f "$db" ] || return 0
  __grep -v "^${name}:" "$db" >"${db}.tmp" 2>/dev/null
  mv -f "${db}.tmp" "$db" 2>/dev/null || true
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__get_arch() {
  local silent arch
  arch="$(uname -m)"
  [ "$1" = " " ] && shift 1
  [ "$1" = "silent" ] && silent="true" && shift 1
  if [ -n "$1" ]; then
    get_arch="$1"
  elif [ "$arch" = "x86_64" ]; then
    get_arch="amd64"
    retry_arch="x64"
    retry2_arch="x86_64"
  elif [ "$arch" = "aarch64" ]; then
    get_arch="aarch64"
    retry_arch="arm64"
  elif [ "$arch" = "arm64" ]; then
    get_arch="arm64"
    retry_arch="aarch64"
  else
    get_arch="$arch"
  fi
  [ -n "$get_arch" ] || return
  printf '%s\n' "$get_arch"
  export get_arch set_arches="$get_arch $retry_arch $retry2_arch"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
search_gh_api() {
  local -a results=()
  local api_results=""
  api_results="$(curl -q -LSsf -H "Accept: application/vnd.github+json" "https://api.github.com/search/repositories?q=$1&sort=stars&order=desc&per_page=100" 2>/dev/null | jq '.items | .[]')"
  results=("$(echo "${api_results}" | jq -c '[.full_name,.description]' | sed 's|\]||g;s|\[||g;s|"||g' | awk -F',' '{print $1": "$2}' | __grep -iwF "$1")")
  if [ -n "${results[*]}" ]; then
    for line in "${results[@]}"; do
      echo "$line" | cut -c 1-120 | __grep -v ': null' | __grep '^'
      retExit=$?
      exitCode=$(($exitCode + $retExit))
    done
  else
    exitCode=1
  fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# - - - - - - - - - - - - - - - - - - - - - - - - -
__gitea() {
  # Gitea: resolve release asset URL via the instance API, then hand off to the
  # unified installer. URL resolution is the ONLY part that differs between the
  # three forges; everything downstream (extract, wrapper, state DB, tracking)
  # runs through __fetch_and_install - so gitea now gets archive handling,
  # wrapper scripts for multi-file tools, and installed.db entries that make
  # uninstall safe. Prior implementation dropped the archive straight into
  # bin/ and didn't record any state.
  local url="" repo="" bin_name="" get_repo="$1" gitea_domain=""
  local arch="${LATEST_RELEASE_OS_ARCH:-$(uname -m)}"
  # Parse the repo + domain from whichever input form the caller used.
  if [[ "$get_repo" == *"|"* ]]; then
    repo="${get_repo//*|/}"
    local _after_semi="${get_repo//*;/}"
    gitea_domain="${_after_semi%%|*}"
  elif [[ "$get_repo" =~ [a-zA-Z0-9]/[a-zA-Z0-9] ]]; then
    repo="$get_repo"
    shift 1
  elif [ $# -gt 1 ]; then
    repo="$1/$2"
    shift 2
  else
    printf_exit "Usage: $APPNAME gitea [user/repo]"
  fi
  if [[ "$get_repo" =~ ^(http|https):// ]]; then
    gitea_domain="${get_repo//;/}"
    gitea_domain="${gitea_domain#*://}"
    gitea_domain="${gitea_domain%%/*}"
    gitea_domain="${gitea_domain//|/}"
    local _parent="${get_repo%/*}" org="${get_repo##*/}"
    repo="${_parent##*/}"
    repo="$org/$repo"
  fi
  repo="${repo//*;/}"
  repo="${repo//*|/}"
  bin_name="${repo##*/}"
  gitea_domain="${gitea_domain:-$LATEST_RELEASE_GITEA_DOMAIN}"
  [ -n "$gitea_domain" ] || printf_exit "ERROR: The variable LATEST_RELEASE_GITEA_DOMAIN is not set"
  __check_if_repo "$repo" || return
  # Determine the current set of arches to try. __get_arch also exports set_arches.
  set_arch="$(__get_arch "${1:-$arch}")"
  set_os="$LATEST_RELEASE_OS_NAME"
  __get_arch &>/dev/null
  # Hit the Gitea API once per candidate arch until something matches.
  local releases_json=""
  releases_json="$(curl -q -LSs -X 'GET' "$gitea_domain/api/v1/repos/$repo/releases" -H 'accept: application/json' 2>/dev/null)"
  for arch in $set_arches; do
    url="$(printf '%s' "$releases_json" | jq -rc '.[].assets | .[] | {name: .name, link: .browser_download_url}' 2>/dev/null | jq -c '.' 2>/dev/null | jq -r '.' 2>/dev/null | __grep "\"$arch\"" | __grep -i "$set_os" | head -n1 | __grep 'link' | awk -F '":' '{print $2}' | sed 's|"||g;s| ||g' | __grep '^')"
    [ -n "$url" ] && break
  done
  [ -n "$url" ] || printf_exit "No Gitea release asset found matching $set_arch/$set_os for $repo"
  # Attempt to pull the release tag name for state DB, ignore failure (version is optional).
  local version=""
  version="$(printf '%s' "$releases_json" | jq -r '.[0].tag_name' 2>/dev/null | __grep '^' || true)"
  __fetch_and_install "gitea" "$url" "$bin_name" "$version" "gitea;$gitea_domain|$repo:$bin_name:"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__gitlab() {
  # GitLab: resolve release asset URL via /api/v4/projects/{url-encoded-path}/
  # releases, then delegate to __fetch_and_install - same deal as __gitea. Prior
  # implementation was a copy-paste of gitea with a different API path and also
  # skipped archive extraction / state DB / wrappers.
  local url="" repo="" bin_name="" get_repo="$1" gitlab_domain="" project_id=""
  local arch="${LATEST_RELEASE_OS_ARCH:-$(uname -m)}"
  if [[ "$get_repo" == *"|"* ]]; then
    repo="${get_repo//*|/}"
    local _after_semi="${get_repo//*;/}"
    gitlab_domain="${_after_semi%%|*}"
  elif [[ "$get_repo" =~ [a-zA-Z0-9]/[a-zA-Z0-9] ]]; then
    repo="$get_repo"
    shift 1
  elif [ $# -gt 1 ]; then
    repo="$1/$2"
    shift 2
  else
    printf_exit "Usage: $APPNAME gitlab [user/repo]"
  fi
  if [[ "$get_repo" =~ ^(http|https):// ]]; then
    gitlab_domain="${get_repo//;/}"
    gitlab_domain="${gitlab_domain#*://}"
    gitlab_domain="${gitlab_domain%%/*}"
    gitlab_domain="${gitlab_domain//|/}"
    local _parent="${get_repo%/*}" org="${get_repo##*/}"
    repo="${_parent##*/}"
    repo="$org/$repo"
  fi
  repo="${repo//*;/}"
  repo="${repo//*|/}"
  bin_name="${repo##*/}"
  gitlab_domain="${gitlab_domain:-$LATEST_RELEASE_GITLAB_DOMAIN}"
  [ -n "$gitlab_domain" ] || printf_exit "ERROR: The variable LATEST_RELEASE_GITLAB_DOMAIN is not set"
  __check_if_repo "$repo" || return
  set_arch="$(__get_arch "${1:-$arch}")"
  set_os="$LATEST_RELEASE_OS_NAME"
  __get_arch &>/dev/null
  # GitLab API uses URL-encoded "org%2Frepo" paths for project IDs.
  project_id="${repo//\//%2F}"
  local releases_json=""
  releases_json="$(curl -q -LSs "$gitlab_domain/api/v4/projects/$project_id/releases" 2>/dev/null)"
  if [ -z "$releases_json" ] || ! echo "$releases_json" | jq -e '.[0]' &>/dev/null; then
    printf_yellow "Can not find any releases from $gitlab_domain/api/v4/projects/$project_id/releases"
    return 1
  fi
  for arch in $set_arches; do
    url="$(printf '%s' "$releases_json" | jq -r '.[0].assets.links[] | select(.name | test("'"$arch"'"; "i")) | select(.name | test("'"$set_os"'"; "i")) | .direct_asset_url' 2>/dev/null | head -n1)"
    [ -n "$url" ] && break
  done
  [ -n "$url" ] || printf_exit "No GitLab release asset found matching $set_arch/$set_os for $repo"
  local version=""
  version="$(printf '%s' "$releases_json" | jq -r '.[0].tag_name' 2>/dev/null | __grep '^' || true)"
  __fetch_and_install "gitlab" "$url" "$bin_name" "$version" "gitlab;$repo:$bin_name:"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__add_to_latest() {
  local repo binname description getrepo _rest
  local repo_list="$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
  for repo in "$@"; do
    if [ -n "$repo" ] && [ "$repo" != " " ]; then
      # Parse "repo:binname:description" without echo|awk. Empty fields stay empty.
      if [[ "$repo" == *":"* ]]; then
        getrepo="${repo%%:*}"
        _rest="${repo#*:}"
        if [[ "$_rest" == *":"* ]]; then
          binname="${_rest%%:*}"
          description="${_rest#*:}"
        else
          binname="$_rest"
          description=""
        fi
      else
        getrepo="$repo"
        binname="${repo##*/}"
        description="$repo"
      fi
      binname="${binname:-${get_repo##*/}}"
      description="${description:-$binname}"
      binname="${binname,,}"
      binname="${binname//\/-/}"
      description="${description//|/ }"
      # Prefix with "github;" if the entry doesn't already carry a "service;" prefix.
      [[ "$getrepo" == *";"* ]] || getrepo="github;$getrepo"
      if __grep -qs "^$getrepo " "$repo_list"; then
        printf_yellow "$getrepo is already in $repo_list"
      else
        printf_purple "Added $getrepo to $repo_list"
        printf '%-47s%-30s#%s\n' "$getrepo" "$binname" " $description" | tee -p -a "$repo_list" &>/dev/null
      fi
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__remove_from_latest() {
  local repos="${*//,/ }"
  local repo_list="$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
  for repo in $repos; do
    if __grep -qs "$repo" "$repo_list"; then
      printf_yellow "Removing repo: $repo"
      if __grep -v "$repo" "$repo_list" | tee -p "$LATEST_RELEASES_TEMP_FILE" &>/dev/null; then
        __mv_f "$LATEST_RELEASES_TEMP_FILE" "$repo_list"
        printf_purple "Removed $repo from $repo_list"
      fi
    else
      printf_red "$repo doesn't exist in $repo_list"
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__uninstall() {
  local names="${*//, /}"
  local -a _binfiles=()
  for name in $names; do
    local entry="" state_version="" state_binfiles="" state_extdir="" bf
    # Prefer the installed.db entry - that records exactly what this script put in
    # place so we only ever remove our own files. Never probe conventional paths
    # blindly (the whole point of installed.db is to avoid deleting binaries we
    # didn't install, like apt/dnf-managed ones that happen to share a name).
    entry="$(__lookup_details "$name" 2>/dev/null)"
    if [ -n "$entry" ]; then
      IFS=: read -r _ state_version state_binfiles state_extdir <<<"$entry"
      printf_cyan "Removing $name (version ${state_version:-unknown}) from $APPNAME"
      # binfiles is a comma-separated list of paths - one entry for a USER-only
      # install, two for --system install. Iterate and remove each explicitly.
      _binfiles=()
      if [ -n "$state_binfiles" ]; then
        IFS=',' read -ra _binfiles <<<"$state_binfiles"
      fi
      for bf in "${_binfiles[@]}"; do
        [ -n "$bf" ] || continue
        if [ -L "$bf" ]; then
          unlink "$bf" 2>/dev/null && printf_green "Removed symlink $bf"
        elif [ -e "$bf" ]; then
          # Use sudo for system bin dir, plain rm for user paths.
          if [[ "$bf" == "$LATEST_RELEASES_BIN_DIR_SYSTEM"/* ]]; then
            __sudo rm -Rf "${bf:?}" && printf_green "Removed $bf"
          else
            rm -Rf "${bf:?}" && printf_green "Removed $bf"
          fi
        fi
      done
      # Multi-file installs (e.g. zed) keep a whole tree alongside the bin symlink.
      if [ -n "$state_extdir" ] && [ -d "$state_extdir" ]; then
        rm -Rf "${state_extdir:?}" && printf_green "Removed $state_extdir"
        # Tidy up the per-org wrapper dir if it's now empty (e.g.
        # ~/.local/share/latest-releases/fastfetch-cli/ after removing its only child).
        local _state_parent="${state_extdir%/*}"
        [ -d "$_state_parent" ] && rmdir "$_state_parent" 2>/dev/null || true
      fi
      __forget_details "$name"
    else
      # No state entry - this install predates installed.db or was done by hand.
      # Be conservative: only remove from LATEST_RELEASES_BIN_DIR_USER (we can be
      # confident we own that), never touch system bin without explicit tracking.
      printf_yellow "No state entry for $name - removing user-dir binary only"
      local legacy_name
      legacy_name="$(__grep -E "(^|[[:space:]])${name}([[:space:]]|$)" "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" 2>/dev/null | awk '{print $2}' | head -n1)"
      [ -n "$legacy_name" ] || legacy_name="$(__grep "/${name}\([[:space:]]\|$\)" "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" 2>/dev/null | awk '{print $2}' | head -n1)"
      [ -n "$legacy_name" ] || legacy_name="${name##*/}"
      printf_cyan "Removing $name from $APPNAME"
      if [ -L "$LATEST_RELEASES_BIN_DIR_USER/$legacy_name" ]; then
        unlink "$LATEST_RELEASES_BIN_DIR_USER/$legacy_name" 2>/dev/null && printf_green "Removed symlink $LATEST_RELEASES_BIN_DIR_USER/$legacy_name"
      elif [ -f "$LATEST_RELEASES_BIN_DIR_USER/$legacy_name" ]; then
        rm -Rf "$LATEST_RELEASES_BIN_DIR_USER/${legacy_name:?}" && printf_green "Removed $LATEST_RELEASES_BIN_DIR_USER/$legacy_name"
      fi
      printf_yellow "If this tool was installed with --system, remove $LATEST_RELEASES_BIN_DIR_SYSTEM/$legacy_name manually."
    fi
    __remove_from_latest "$name"
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_repolist() {
  if [ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" ]; then
    __cp_rf "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" "$LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_REPO_LIST.$$"
  else
    cat <<EOF | tee -p "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" &>/dev/null
# Format: service;org/repo                       symlinkName                     # description
github;gokcehan/lf                               lf                              # filemanager
github;JanDeDobbeleer/oh-my-posh                 oh-my-posh                      # highly customizable prompt theme engine
github;tobychui/zoraxy                           zoraxy                          # general purpose request (reverse) proxy
github;fastfetch-cli/fastfetch                   fastfetch                       # neofetch replacement
github;mrjackwills/oxker                         oxker                           # simple tui to view & control docker containers
EOF
  fi
  if [ -f "$LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_REPO_LIST.$$" ]; then
    printf_cyan "Backing up repo list to: $LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_REPO_LIST.$$"
  elif [ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" ]; then
    printf_blue "Created sample repo lists: $LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_github_auth() {
  local auth_file="$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE"
  if [ -f "$auth_file" ]; then
    __cp_rf "$auth_file" "$LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE.$$"
  else
    printf_green "Creating default authentication file"
    cat <<EOF | tee -p "$auth_file" &>/dev/null
# Go to https://github.com/settings/tokens to create auth token
LATEST_RELEASE_GITHUB_USERNAME="${LATEST_RELEASE_GITHUB_USERNAME:-$GITHUB_USERNAME}"
LATEST_RELEASE_GITHUB_TOKEN="${LATEST_RELEASE_GITHUB_TOKEN:-$GITHUB_ACCESS_TOKEN}"

EOF
  fi
  if [ -f "$LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE.$$" ]; then
    printf_blue "Backup $auth_file to: $LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE.$$"
  elif [ -f "$auth_file" ]; then
    printf_blue "Created $auth_file"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__github() {
  # GitHub: resolve the release asset URL via api.github.com, then delegate to
  # the unified __fetch_and_install pipeline. The function now focuses purely on
  # URL resolution (auth, JSON traversal, arch iteration, override vars, search
  # mode). Everything below "found a URL" lives in __fetch_and_install.
  [ -n "$1" ] || return
  [[ "$1" == "#"* ]] && return
  [ -z "$1" ] && [ -z "$LATEST_RELEASE_FULL_URL" ] && return
  local repo="$1" search="" api_url="" latest_json=""
  local latest_download="" latest_version_full="" latest_version=""
  local bin_name="" repo_description="" tracked_bin_name=""
  local arch="${LATEST_RELEASE_OS_ARCH:-$(uname -m)}"
  local repo_list="$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
  shift 1
  [ "$repo" = "search" ] && search="true"
  # Bare-name input (no "/") -> treat as "name/name". Strip any "service;" or "|domain|"
  # prefix the repo-list can attach.
  [[ "$repo" == *"/"* ]] || repo="$repo/$repo"
  repo="${repo//*;/}"
  repo="${repo//*|/}"
  set_os="$LATEST_RELEASE_OS_NAME"
  set_arch="$(__get_arch "${1:-$arch}")"
  api_url="https://api.github.com/repos/$repo/releases/latest"
  __check_if_repo "$repo" || return
  __get_arch &>/dev/null
  [ -n "$LATEST_RELEASE_GITHUB_TOKEN" ] && printf_blue "Github API Auth token is set"
  printf_green "Getting info from $api_url"
  # Resolve the download URL - three paths:
  #   1. Caller forced a URL via LATEST_RELEASE_FULL_URL (totally bypasses API)
  #   2. Caller forced a filename filter via LATEST_RELEASES_FILENAME
  #   3. Default: iterate through $set_arches, pick the first matching asset
  if [ -n "$LATEST_RELEASE_FULL_URL" ]; then
    latest_download="$LATEST_RELEASE_FULL_URL"
  elif [ -n "$LATEST_RELEASES_FILENAME" ]; then
    latest_json="$(__curl_json_all "$repo" | grep -v 'Error: ')"
    latest_download="$(echo "$latest_json" | __grep -i "$LATEST_RELEASES_FILENAME" | __grep_exclude | grep "$set_arch" | head -n1 | __grep '^')"
    [ -n "$latest_download" ] || latest_download="$(echo "$latest_json" | __grep -i "$LATEST_RELEASES_FILENAME" | __grep_exclude | __grep_include | grep "$LATEST_RELEASE_OS_NAME" | head -n1 | __grep '^')"
  else
    latest_json="$(__curl_json)"
    for arch in $set_arches; do
      latest_download="$(__browser_download_url "$latest_json" "$arch" || return 1)"
      [ -n "$latest_download" ] && get_arch="$arch" && break
    done
  fi
  [ -n "$latest_download" ] || latest_download="$(__browser_download_url "$latest_json" "$LATEST_RELEASE_OS_NAME" | __grep_exclude | __grep_include | grep "$set_arch" || return 1)"
  # --search mode short-circuits the install: just print the asset URLs the API
  # returned, one per line, and exit.
  if [ "$search" = "true" ]; then
    echo "$latest_json" | __grep -iE 'browser_download_url' | awk '{print $2}' | sed 's|"||g' | grep '^' | printf_readline '6'
    exit $?
  fi
  if [ -z "$latest_download" ]; then
    local manual_dl=""
    manual_dl="$(echo "$latest_json" | jq -r '.html_url' 2>/dev/null)"
    printf_custom "$LATEST_RELEASES_OUTPUT_COLOR_ERROR" "No releases found from $repo matching $get_arch"
    [ -n "$manual_dl" ] && echo "Go to $manual_dl for manual download" | printf_readline "$LATEST_RELEASES_OUTPUT_COLOR_1"
    return 1
  fi
  # Derive version from the URL's parent path segment ("/releases/download/vX.Y.Z/").
  local _parent_url="${latest_download%/*}"
  latest_version_full="${_parent_url##*/}"
  latest_version="${latest_version_full//[a-zA-Z]/}"
  # bin_name precedence: explicit LATEST_RELEASES_BIN_NAME env > tracked entry in
  # repos.conf (preserves user's chosen rename) > lowercase of repo basename.
  if [ -n "$LATEST_RELEASES_BIN_NAME" ]; then
    bin_name="$LATEST_RELEASES_BIN_NAME"
  elif [ -f "$repo_list" ] && __grep -qs "^.*;$repo " "$repo_list"; then
    tracked_bin_name="$(__grep "^.*;$repo " "$repo_list" | __grep -v '^#' | sed 's|.*;||g' | awk '{print $2}' | head -n1)"
    bin_name="${tracked_bin_name:-${repo##*/}}"
  else
    bin_name="${repo##*/}"
  fi
  bin_name="${bin_name,,}"
  # Description is optional metadata for the repos.conf tracking list.
  repo_description="$(curl -q -LSsf "https://api.github.com/repos/$repo" 2>/dev/null | jq -rc '.description' 2>/dev/null | sed 's|\. .*||g;s|\? .*||g;s|\! .*||g' | grep '^' || echo "${repo##*/}")"
  repo_description="${repo_description:0:40}"
  # Hand off to the unified installer.
  __fetch_and_install "github" "$latest_download" "$bin_name" "$latest_version_full" "github;$repo:$bin_name:$repo_description" "$repo_description"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__browser_download_url() {
  echo "${1:-$latest_json}" |
    __grep -iE 'browser_download_url' |
    __grep -vE '.*.deb|.*.rpm' |
    __grep -E 'tar.*|*.bz|*.zip|.*' | cut -d '"' -f 4 |
    __grep -i "$(uname -s)" | __grep -i "${2:-$set_arch}" |
    __grep_exclude | head -n1 | __grep '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__wget_latest() {
  local filename="${1:-$filename}"
  local tempfile="${2:-$tempfile}"
  [ -d "$download_dir" ] || __mkd "$download_dir"
  [ "$LATEST_RELEASE_FORCE_INSTALL" != "true" ] || rm -rf "$filename"
  if [ -s "$filename" ]; then
    printf_yellow "Reinstalling from $filename"
    __mv_f "$filename" "$tempfile"
  else
    [ -f "$filename" ] && rm -f "$filename"
    __wget "${1:-$latest_download}" "${2:-$tempfile}"
    [ -s "${2:-$tempfile}" ] && return 0 || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_date() {
  if [ -z "$LATEST_RELEASE_GITHUB_TOKEN" ]; then
    curl -q -LS -s "${tag_commit_url}" 2>/dev/null | jq -r ".commit.author.date" 2>/dev/null | cut -d 'T' -f 1
  else
    curl -q -LS -H "Authorization: token $LATEST_RELEASE_GITHUB_TOKEN" -s "${tag_commit_url}" 2>/dev/null | jq -r ".commit.author.date" 2>/dev/null | cut -d 'T' -f 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_tag() {
  # No-token branch previously had the URL stuffed into a -H header value, so curl bailed
  # with "no URL specified!" and __show_latest always reported "rate limited". Pass the URL
  # as the positional argument.
  if [ -z "$LATEST_RELEASE_GITHUB_TOKEN" ]; then
    curl -q -LSs "https://api.github.com/repos/${1:-$repo}/tags?per_page=1" 2>/dev/null | jq -r ".[0].name, .[0].commit.url" 2>/dev/null | paste -sd,-
  else
    curl -q -LSs -H "Authorization: token $LATEST_RELEASE_GITHUB_TOKEN" "https://api.github.com/repos/${1:-$repo}/tags?per_page=1" 2>/dev/null | jq -r ".[0].name, .[0].commit.url" 2>/dev/null | paste -sd,-
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_json() {
  if [ -z "$LATEST_RELEASE_GITHUB_TOKEN" ]; then
    curl -q -LSs --fail "${1:-$api_url}" 2>/dev/null
  else
    curl -q -LSs --fail -H "Authorization: token $LATEST_RELEASE_GITHUB_TOKEN" "${1:-$api_url}" 2>/dev/null
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_json_all() {
  local results=""
  local exitcode=0
  # Input must be "user/repo" shape (two non-empty segments around a slash).
  [[ "$1" == ?*/?* ]] || printf_exit "Usage: $APPNAME username/reponame"
  results="$(__curl_json "https://api.github.com/repos/${1:-$repo}/releases" 2>"$LATEST_RELEASES_LOG_DIR/error.log")"
  if [ -n "$results" ]; then
    links="$(printf '%s\n' "$results" | jq -r '.[]' | jq -r '.assets | .[].browser_download_url' | sort -rV | __grep '^' || echo '')"
    if [ -n "$links" ]; then
      printf '%s\n' "$links"
    else
      printf '%s\n' "Error: $(<"$LATEST_RELEASES_LOG_DIR/error.log")"
      exitCode=1
    fi
  fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__show_latest() {
  printf_purple "Finding the Latest releases on GitHub. This may take a minute:"
  local tag_info="" tag_name="" tag_commit_url="" tag_commit_date=""
  printf '%s\n' "Repo | Release | Date" >"$LATEST_RELEASES_TEMP_FILE"
  while read -r get_repo; do
    out=""
    repo=""
    # Skip blank and commented lines. Then drop any "service;" prefix and any trailing
    # " #comment", and take the first whitespace-delimited token.
    if [ -n "$get_repo" ] && [[ "$get_repo" != "#"* ]]; then
      local _r="${get_repo//*;/}"
      _r="${_r%%#*}"
      repo="${_r%% *}"
    fi
    if [ -n "$repo" ]; then
      tag_info="$(__curl_tag "$repo")"
      if [ -z "$tag_info" ]; then
        if [ -z "$LATEST_RELEASE_GITHUB_TOKEN" ]; then
          printf_green "You are likely being rate limited by GitHub, please authenticate by setting your api token:" >&2
          printf_green 'export LATEST_RELEASE_GITHUB_TOKEN="youraccesstoken"' >&2
        else
          printf_cyan "Something went very, very wrong" >&2
        fi
        exit 1
      fi
      tag_name="$(cut -d ',' -f 1 <<<"${tag_info}")"
      tag_commit_url="$(cut -d ',' -f 2 <<<"${tag_info}")"
      tag_commit_date="$(__curl_date)"
      out="${repo} | ${tag_name} | ${tag_commit_date}"
    fi
    [ -z "$out" ] || printf '%s\n' "$out"
  done < "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" >>"$LATEST_RELEASES_TEMP_FILE"
  column -t < "$LATEST_RELEASES_TEMP_FILE" | sort -t "|" -k 3 -r | printf_readline "6"
  printf '\n'
}

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Parse "service;user/repo" (or bare "user/repo") and dispatch to the right
# resolver. Collapses the split-and-switch blocks that __update_install used
# to duplicate and keeps the default case path consistent.
__dispatch_service() {
  local _raw="${1:-}" _service="" _target=""
  [ -z "$_raw" ] && return 0
  _raw="${_raw%%[[:space:]]*}"
  if [[ "$_raw" == *";"* ]]; then
    _service="${_raw%%;*}"
    _target="${_raw#*;}"
  else
    _target="$_raw"
  fi
  [ -z "$_target" ] && return 0
  case "$_service" in
  gitea) __gitea "$_target" ;;
  gitlab) __gitlab "$_target" ;;
  *) __github "$_target" ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__update_install() {
  local get_repo_list="" _first _second _trimmed
  if [ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" ] && [ -z "$1" ]; then
    # Iterate the repo-list in-place (no cat|grep|sed|while). Drop "#comment" and skip
    # blank lines. Each line is "service;user/repo   binname   # desc".
    while read -r get_repo_list; do
      _trimmed="${get_repo_list%%#*}"
      [ -z "$_trimmed" ] && continue
      [[ "$get_repo_list" == "#"* ]] && continue
      read -r _first _second _ <<<"$_trimmed"
      [ -z "$_first" ] && continue
      LATEST_RELEASES_BIN_NAME="$_second"
      __dispatch_service "$_first"
    done < <(grep -shv '^#' "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST")
  else
    [[ "$*" == *"/"* ]] || { printf_red "You provided an invalid repo" && printf_exit "Usage: $APPNAME install user/repo"; }
    for get_repo_list in "$@"; do
      read -r _first _ <<<"$get_repo_list"
      __dispatch_service "$_first"
    done
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__api_repos() {
  # First query-string separator is `?`, subsequent are `&`. Using `&per_page=...` made
  # GitHub treat the whole string as a path and return 404.
  res="$(curl -q -LSs -H "Authorization: token $LATEST_RELEASE_GITHUB_TOKEN" \
    "https://api.github.com/users/$1/repos?per_page=500&sort=updated" 2>/dev/null |
    jq -r '.[] | .name' 2>/dev/null | __grep '^' || return 1)"
  [ -n "$res" ] && printf '%s\n' "$res" | sort -n || __api_search "$1"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__api_search() {
  res="$(curl -q -LSsf "https://api.github.com/search/repositories?q=${1:-$repo}&per_page=100&sort=updated" 2>/dev/null |
    jq -r '.items[].full_name' 2>/dev/null || return 1)" &&
    [ -n "$res" ] && printf '%s\n' "$res" | sort -u || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__search_help() {
  printf_red "Usage: $APPNAME username/reponame [filter] [grepOpts] - $APPNAME search api <query>"
  printf_exit "$APPNAME search PowerShell/PowerShell 'arm' '-E linux|amd' '-v alpine'"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
if __cmd_exists curl; then
  if [ -z "$LATEST_RELEASE_GITHUB_TOKEN" ]; then
    __wget() { curl -q -LSsf "$1" -o "$2" 2>/dev/null || return 1; }
  else
    __wget() { curl -q -LSsf -H "Authorization: token ${LATEST_RELEASE_GITHUB_TOKEN}" "$1" -o "$2" 2>/dev/null || return 1; }
  fi
elif __cmd_exists wget; then
  if [ -z "$LATEST_RELEASE_GITHUB_TOKEN" ]; then
    __wget() { wget -q "$1" -O "$2" 2>/dev/null || return 1; }
  else
    __wget() { wget -q --header="Authorization: token ${LATEST_RELEASE_GITHUB_TOKEN}" "$1" -O "$2" 2>/dev/null; }
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined variables/import external variables

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
# Auto-detect root / UID 0: install to /usr/local/{bin,share}. DOWNLOADS is a
# staging area for the tarball - not kept after install - so it goes to /var/tmp
# for root and the existing per-user ephemeral TEMP_DIR for users. Env vars still
# win (user can override to any path).
# INSTALL_DIR is just `{share}` (no `latest-releases/` subdir) so a multi-file
# install for zed lands at /usr/local/share/zed or ~/.local/share/zed. Single-file
# installs (like lf) put the binary directly in bin and don't create a share tree
# at all.
if __user_is_root; then
  LATEST_RELEASES_BIN_DIR_USER="${LATEST_RELEASES_BIN_DIR_USER:-/usr/local/bin}"
  LATEST_RELEASE_INSTALL_DIR="${LATEST_RELEASE_INSTALL_DIR:-/usr/local/share}"
  LATEST_RELEASE_DOWNLOADS="${LATEST_RELEASE_DOWNLOADS:-/var/tmp/latest-releases}"
else
  LATEST_RELEASES_BIN_DIR_USER="${LATEST_RELEASES_BIN_DIR_USER:-$HOME/.local/bin}"
  LATEST_RELEASE_INSTALL_DIR="${LATEST_RELEASE_INSTALL_DIR:-$HOME/.local/share}"
  LATEST_RELEASE_DOWNLOADS="${LATEST_RELEASE_DOWNLOADS:-$LATEST_RELEASES_TEMP_DIR/downloads}"
fi
LATEST_RELEASES_BIN_DIR_SYSTEM="${LATEST_RELEASES_BIN_DIR_SYSTEM:-/usr/local/bin}"
LATEST_RELEASES_CONFIG_FILE="${LATEST_RELEASES_CONFIG_FILE:-settings.conf}"
LATEST_RELEASES_CONFIG_DIR="${LATEST_RELEASES_CONFIG_DIR:-$HOME/.config/myscripts/latest-releases}"
LATEST_RELEASES_CONFIG_BACKUP_DIR="${LATEST_RELEASES_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/latest-releases/backups}"
LATEST_RELEASES_LOG_DIR="${LATEST_RELEASES_LOG_DIR:-$HOME/.local/log/latest-releases}"
LATEST_RELEASES_TEMP_DIR="${LATEST_RELEASES_TEMP_DIR:-$HOME/.local/tmp/system_scripts/latest-releases}"
LATEST_RELEASES_CACHE_DIR="${LATEST_RELEASES_CACHE_DIR:-$HOME/.cache/latest-releases}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
LATEST_RELEASES_OUTPUT_COLOR_1="${LATEST_RELEASES_OUTPUT_COLOR_1:-33}"
LATEST_RELEASES_OUTPUT_COLOR_2="${LATEST_RELEASES_OUTPUT_COLOR_2:-5}"
LATEST_RELEASES_OUTPUT_COLOR_GOOD="${LATEST_RELEASES_OUTPUT_COLOR_GOOD:-2}"
LATEST_RELEASES_OUTPUT_COLOR_ERROR="${LATEST_RELEASES_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
LATEST_RELEASES_NOTIFY_ENABLED="${LATEST_RELEASES_NOTIFY_ENABLED:-yes}"
LATEST_RELEASES_GOOD_NAME="${LATEST_RELEASES_GOOD_NAME:-Great:}"
LATEST_RELEASES_ERROR_NAME="${LATEST_RELEASES_ERROR_NAME:-Error:}"
LATEST_RELEASES_GOOD_MESSAGE="${LATEST_RELEASES_GOOD_MESSAGE:-No errors reported}"
LATEST_RELEASES_ERROR_MESSAGE="${LATEST_RELEASES_ERROR_MESSAGE:-Errors were reported}"
LATEST_RELEASES_NOTIFY_CLIENT_NAME="${LATEST_RELEASES_NOTIFY_CLIENT_NAME:-$APPNAME}"
LATEST_RELEASES_NOTIFY_CLIENT_ICON="${LATEST_RELEASES_NOTIFY_CLIENT_ICON:-notification-new}"
LATEST_RELEASES_NOTIFY_CLIENT_URGENCY="${LATEST_RELEASES_NOTIFY_CLIENT_URGENCY:-normal}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional Variables
LATEST_RELEASE_GITEA_DOMAIN="${LATEST_RELEASE_GITEA_DOMAIN:-}"
LATEST_RELEASE_INSTALL_TO_SYSTEM_BIN="${LATEST_RELEASE_INSTALL_TO_SYSTEM_BIN:-no}"
LATEST_RELEASE_GITLAB_DOMAIN="${LATEST_RELEASE_GITLAB_DOMAIN:-https://gitlab.com}"
LATEST_RELEASE_GITHUB_USERNAME="${LATEST_RELEASE_GITHUB_USERNAME:-$GITHUB_USERNAME}"
LATEST_RELEASE_GITHUB_TOKEN="${LATEST_RELEASE_GITHUB_TOKEN:-$GITHUB_ACCESS_TOKEN}"
LATEST_RELEASE_REPO_LIST="${LATEST_RELEASE_REPO_LIST:-repos.conf}"
LATEST_RELEASE_GITHUB_AUTH_FILE="${LATEST_RELEASE_GITHUB_AUTH_FILE:-auth.conf}"
# LATEST_RELEASE_DOWNLOADS and LATEST_RELEASE_INSTALL_DIR defaults are set by the
# root/user auto-detect block above - don't re-default them here.
LATEST_RELEASE_DEFAULT_ARCH="${LATEST_RELEASE_DEFAULT_ARCH:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE" ] || [ "$*" = "--config" ] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE" ] && . "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$LATEST_RELEASES_LOG_DIR" ] || mkdir -p "$LATEST_RELEASES_LOG_DIR" |& __devnull
[ -d "$LATEST_RELEASES_TEMP_DIR" ] || mkdir -p "$LATEST_RELEASES_TEMP_DIR" |& __devnull
[ -d "$LATEST_RELEASES_CACHE_DIR" ] || mkdir -p "$LATEST_RELEASES_CACHE_DIR" |& __devnull
# - - - - - - - - - - - - - - - - - - - - - - - - -
LATEST_RELEASES_TEMP_FILE="${LATEST_RELEASES_TEMP_FILE:-$(mktemp $LATEST_RELEASES_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap '__trap_exit' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
__notifications() {
  __cmd_exists notifications || return
  [ "$LATEST_RELEASES_NOTIFY_ENABLED" = "yes" ] || return
  [ "$SEND_NOTIFICATION" = "no" ] && return
  (
    export SCRIPT_OPTS="" _DEBUG=""
    export NOTIFY_GOOD_MESSAGE="${NOTIFY_GOOD_MESSAGE:-$LATEST_RELEASES_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${NOTIFY_ERROR_MESSAGE:-$LATEST_RELEASES_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$LATEST_RELEASES_NOTIFY_CLIENT_ICON}"
    export NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$LATEST_RELEASES_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_URGENCY="${NOTIFY_CLIENT_URGENCY:-$LATEST_RELEASES_NOTIFY_CLIENT_URGENCY}"
    notifications "$@"
  ) |& __devnull &
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Set custom actions

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Argument/Option settings
SETARGS=("$@")
# - - - - - - - - - - - - - - - - - - - - - - - - -
SHORTOPTS="f:,t:,b:"
SHORTOPTS+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
LONGOPTS="completions:,config,debug,dir:,help,options,raw,version,silent,force"
LONGOPTS+=",filename:,binname:,type:,gitlab:,gitea:,system"
# - - - - - - - - - - - - - - - - - - - - - - - - -
ARRAY="add remove install update uninstall gitea gitlab info list search token"
ARRAY+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
LIST=""
LIST+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --raw)
    shift 1
    export SHOW_RAW="true"
    NC=""
    RESET=""
    BLACK=""
    RED=""
    GREEN=""
    YELLOW=""
    BLUE=""
    PURPLE=""
    CYAN=""
    WHITE=""
    ORANGE=""
    LIGHTRED=""
    BG_GREEN=""
    BG_RED=""
    ICON_INFO="[ info ]"
    ICON_GOOD="[ ok ]"
    ICON_WARN="[ warn ]"
    ICON_ERROR="[ error ]"
    ICON_QUESTION="[ ? ]"
    printf_column() { tee | grep '^'; }
    printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[ 0-9;]*[a-zA-Z],,g'; }
    ;;
  --debug)
    shift 1
    set -xo pipefail
    export SCRIPT_OPTS="--debug"
    export _DEBUG="on"
    __devnull() { tee || return 1; }
    __devnull2() { eval "$@" |& tee -p || return 1; }
    ;;
  --completions)
    if [ "$2" = "short" ]; then
      printf '%s\n' "-$SHORTOPTS" | sed 's|"||g;s|:||g;s|,|,-|g' | tr ',' '\n'
    elif [ "$2" = "long" ]; then
      printf '%s\n' "--$LONGOPTS" | sed 's|"||g;s|:||g;s|,|,--|g' | tr ',' '\n'
    elif [ "$2" = "array" ]; then
      printf '%s\n' "$ARRAY" | sed 's|"||g;s|:||g' | tr ',' '\n'
    elif [ "$2" = "list" ]; then
      printf '%s\n' "$LIST" | sed 's|"||g;s|:||g' | tr ',' '\n'
    else
      exit 1
    fi
    shift 2
    exit $?
    ;;
  --options)
    shift 1
    printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "Short Options" "-${SHORTOPTS}" ',' '-' 4
    [ -z "$LONGOPTS" ] || __list_options "Long Options" "--${LONGOPTS}" ',' '--' 4
    [ -z "$ARRAY" ] || __list_options "Base Options" "${ARRAY}" ',' '' 4
    [ -z "$LIST" ] || __list_options "LIST Options" "${LIST}" ',' '' 4
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --silent)
    shift 1
    LATEST_RELEASES_SILENT="true"
    ;;
  --dir)
    CWD_IS_SET="TRUE"
    LATEST_RELEASES_CWD="$2"
    [ -d "$LATEST_RELEASES_CWD" ] || mkdir -p "$LATEST_RELEASES_CWD" |& __devnull
    shift 2
    ;;
  --force)
    shift 1
    LATEST_RELEASE_FORCE_INSTALL="true"
    ;;
  --system)
    shift 1
    LATEST_RELEASE_INSTALL_TO_SYSTEM_BIN="yes"
    ;;
  -f | --filename)
    LATEST_RELEASES_FILENAME="$2"
    shift 2
    ;;
  -t | --type)
    LATEST_RELEASES_ARCH="$2"
    shift 2
    ;;
  -b | --binname)
    LATEST_RELEASES_BIN_NAME="$2"
    shift 2
    ;;
  --gitea)
    LATEST_RELEASE_GITEA_DOMAIN="$2"
    shift 2
    ;;
  --gitlab)
    LATEST_RELEASE_GITLAB_DOMAIN="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Get directory from args
