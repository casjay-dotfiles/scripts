# @File          : latest-releases
# @Description   : Download the latest release of a package
# @TODO          : Refactor this mess
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE"
  [ -d "$LATEST_RELEASES_CONFIG_DIR" ] || mkdir -p "$LATEST_RELEASES_CONFIG_DIR"
  [ -d "$LATEST_RELEASES_CONFIG_BACKUP_DIR" ] || mkdir -p "$LATEST_RELEASES_CONFIG_BACKUP_DIR"
  [ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE" ] &&
    cp -Rf "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE" "$LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASES_CONFIG_FILE.$$"
  cat <<EOF >"$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE"
# Settings for latest-releases
LATEST_RELEASE_DOWNLOADS="${LATEST_RELEASE_DOWNLOADS:-$HOME/Downloads/Latest}"
LATEST_RELEASE_REPO_LIST="${LATEST_RELEASE_REPO_LIST:-repos.conf}"
LATEST_RELEASE_GITHUB_AUTH_FILE="${LATEST_RELEASE_GITHUB_AUTH_FILE:-auth.conf}"
LATEST_RELEASE_DEFAULT_ARCH="${LATEST_RELEASE_DEFAULT_ARCH:-$(uname -m)}"
LATEST_RELEASE_INSTALL_DIR="${LATEST_RELEASE_INSTALL_DIR:-$HOME/.local/share/latest-releases}"

# Notification settings
LATEST_RELEASES_GOOD_MESSAGE="${LATEST_RELEASES_GOOD_MESSAGE:-Everything Went OK}"
LATEST_RELEASES_ERROR_MESSAGE="${LATEST_RELEASES_ERROR_MESSAGE:-Well something seems to have gone wrong}"
LATEST_RELEASES_NOTIFY_ENABLED="${LATEST_RELEASES_NOTIFY_ENABLED:-yes}"
LATEST_RELEASES_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
LATEST_RELEASES_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$LATEST_RELEASES_NOTIFY_CLIENT_ICON}"

# Colorization settings
LATEST_RELEASES_OUTPUT_COLOR="${LATEST_RELEASES_OUTPUT_COLOR:-5}"
LATEST_RELEASES_OUTPUT_COLOR_GOOD="${LATEST_RELEASES_OUTPUT_COLOR_GOOD:-2}"
LATEST_RELEASES_OUTPUT_COLOR_ERROR="${LATEST_RELEASES_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__gitea() {
  local url=""
  local dom="$1"
  local repo="$2"
  local download_dir="$LATEST_RELEASE_DOWNLOADS"
  local tempfile="$LATEST_RELEASES_TEMP_FILE"
  local api_url="$dom/api/v1/repos/$repo/releases"
  local filename="$(basename "$repo")"
  local get_arch=""
  mkdir -p "$download_dir"
  if [ "$LATEST_RELEASE_DEFAULT_ARCH" = "x86_64" ]; then
    get_arch="amd64"
  elif [[ -n "$1" ]]; then
    get_arch="$1"
  else
    get_arch="arm64"
  fi
  arch="${LATEST_RELEASES_ARCH_TYPE:-$get_arch}"
  url="$(curl -q -LSs -X 'GET' "$api_url" -H 'accept: application/json' | jq -rc '.[].assets | .[] | {name: .name, link: .browser_download_url}' | grep ''$arch'"' | grep -i "$(uname -s)" | jq -c | head -n1 | jq -r | grep link | awk -F '":' '{print $2}' | sed 's|"||g;s| ||g')"
  printf_green "Attempting to download $filename from $url"
  printf_green "and save to $download_dir/$filename"
  curl -q -LSs "$url" -o "$tempfile" 2>/dev/null || printf_exit "Failed to download the file"
  if [[ -f "$tempfile" ]] && [[ -s "$tempfile" ]]; then
    mv -f "$tempfile" "$download_dir/$filename"
    if [[ -d "$HOME/.local/bin" ]]; then
      cp -Rf "$download_dir/$filename" "$HOME/.local/bin/$filename"
      chmod -Rf 755 "$HOME/.local/bin/$filename"
    fi
  else
    printf_exit "Failed to download the file"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gitlab() {
  local url=""
  local arch=""
  local dom="$1"
  local repo="$2"
  local download_dir="$LATEST_RELEASE_DOWNLOADS"
  local tempfile="$LATEST_RELEASES_TEMP_FILE"
  local api_url="$dom/api/v1/repos/$repo/releases"
  local filename="$(basename "$repo")"
  mkdir -p "$download_dir"
  if [ "$LATEST_RELEASE_DEFAULT_ARCH" = "x86_64" ]; then
    get_arch="amd64"
  elif [[ -n "$1" ]]; then
    get_arch="$1"
  else
    get_arch="arm64"
  fi
  arch="${LATEST_RELEASES_ARCH_TYPE:-$get_arch}"
  url="$(curl -q -LSs -X 'GET' "$api_url" -H 'accept: application/json' | jq -rc '.[].assets | .[] | {name: .name, link: .browser_download_url}' | grep ''$arch'"' | grep -i "$(uname -s)" | jq -c | head -n1 | jq -r | grep link | awk -F '":' '{print $2}' | sed 's|"||g;s| ||g')"
  printf_green "Attempting to download $filename from $url"
  printf_green "and save to $download_dir/$filename"
  curl -q -LSs "$url" -o "$tempfile" 2>/dev/null || printf_exit "Failed to download the file"
  if [[ -f "$tempfile" ]] && [[ -s "$tempfile" ]]; then
    mv -f "$tempfile" "$download_dir/$filename"
    if [[ -d "$HOME/.local/bin" ]]; then
      cp -Rf "$download_dir/$filename" "$HOME/.local/bin/$filename"
      chmod -Rf 755 "$HOME/.local/bin/$filename"
    fi
  else
    printf_exit "Failed to download the file"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__add_to_latest() {
  if ! grep -qs "$1" "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"; then
    printf_purple "Added ${2:-$1} to $LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
    printf '%s\n' "${2:-$1}" | tee -a "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" &>/dev/null
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__remove_from_latest() {
  if grep -qs "$1" "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"; then
    if grep -v "$1" "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" | tee "$LATEST_RELEASES_TEMP_FILE" &>/dev/null; then
      __mv_f "$LATEST_RELEASES_TEMP_FILE" "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
      printf_purple "Removed ${2:-$1} from $LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_repolist() {
  if [ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" ]; then
    __cp_rf "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" "$LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_REPO_LIST.$$"
  else
    printf_green "Creating default repo lists"
    cat <<EOF | tee "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" &>/dev/null
gokcehan/lf
go-gitea/gitea
justjanne/powerline-go
codeskyblue/gohttpserver
EOF
  fi
  if [[ -f "$LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_REPO_LIST.$$" ]]; then
    printf_blue "Backup $LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
    printf_cyan "to: $LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_REPO_LIST.$$"
  elif [ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" ]; then
    printf_blue "Created $LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_github_auth() {
  if [ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE" ]; then
    __cp_rf "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE" "$LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE.$$"
  else
    printf_green "Creating default authentication file"
    cat <<EOF | tee "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE" &>/dev/null
# Go to https://github.com/settings/tokens to create auth token
LATEST_RELEASE_GITHUB_USERNAME="${LATEST_RELEASE_GITHUB_USERNAME:-$GITHUB_USERNAME}"
LATEST_RELEASE_GITHUB_TOKEN="${LATEST_RELEASE_GITHUB_TOKEN:-$GITHUB_ACCESS_TOKEN}"

EOF
  fi
  if [[ -f "$LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE.$$" ]]; then
    printf_blue "Backup $LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE"
    printf_cyan "to: $LATEST_RELEASES_CONFIG_BACKUP_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE.$$"
  elif [ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE" ]; then
    printf_blue "Created $LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__install_latest() {
  echo "$1" | grep -qv '^#' || return
  echo "$1" | grep -qv '^$' || [[ -n "$LATEST_RELEASE_FULL_URL" ]] || return
  set_arch="$(uname -m)"
  [ "$1" = search ] && search="true" && shift 1
  if echo "$1" | grep -q './.' || [[ $# == 1 ]]; then
    repo="$1"
    shift 1
  elif [[ $# -gt 1 ]]; then
    repo="$1/$2"
    shift 2
  fi
  if [[ -n "$1" ]]; then
    get_arch="$1"
  elif [ "$LATEST_RELEASE_DEFAULT_ARCH" = "x86_64" ]; then
    get_arch="amd64"
    retry_arch="x86_64"
  elif [ "$set_arch" = "aarch64" ]; then
    get_arch="arm64"
    retry_arch="aarch64"
  fi
  arch="${LATEST_RELEASES_ARCH_TYPE:-$get_arch}"
  tempfile="$LATEST_RELEASES_TEMP_FILE"
  download_dir="$LATEST_RELEASE_DOWNLOADS"
  api_url="https://api.github.com/repos/$repo/releases/latest"
  if [[ -n "$LATEST_RELEASE_GITHUB_TOKEN" ]]; then
    printf_blue "Github API Auth token is set"
    printf_green "Getting info from $api_url"
  else
    printf_green "Getting info from $api_url"
  fi
  if [[ -n "$LATEST_RELEASE_FULL_URL" ]]; then
    latest_download="$LATEST_RELEASE_FULL_URL"
  elif [ -n "$LATEST_RELEASES_FILENAME" ]; then
    latest_json="$(__curl_json_all "$repo")"
    latest_download="$(echo "$latest_json" | grep -i "$LATEST_RELEASES_FILENAME" | head -n1 | grep '^')"
  else
    latest_json="$(__curl_json)"
    latest_download="$(__browser_download_url "$latest_json" "$arch" || __browser_download_url "$latest_json" "$retry_arch" || return 1)"
  fi
  latest_download_url="https://github.com/$repo"
  basename="$(basename "$latest_download")"
  basenamerepo="$(basename "$repo")"
  filename="$download_dir/$basename"
  extract_name="$(basename "$repo")"
  extract_dir="$LATEST_RELEASE_INSTALL_DIR/$extract_name"
  if [ "$search" = "true" ]; then
    echo "$latest_json" | grep -iE 'browser_download_url' | awk '{print $2}' | sed 's|"||g' | printf_readline '6'
  elif [ -n "$latest_download" ]; then
    printf_green "Attempting to download $latest_download "
    if __wget_latest "$latest_download" "$tempfile"; then
      [[ -f "$tempfile" ]] && __cp_rf "$tempfile" "$filename"
      exitCode=0
    else
      [ -f "$tempfile" ] && __rm_rf "$tempfile"
      printf_exit "failed to find any files from $latest_download_url"
      exit 1
    fi
    [[ -f "$filename" ]] && [[ -d "$extract_dir" ]] && __rm_rf "$extract_dir"
    case "$filename" in
    *.tar.bz2)
      printf_blue "Extracting to $extract_dir"
      mkdir -p "$extract_dir"
      tar xjf "$filename" -C "$extract_dir" &>/dev/null || printf_exit "Failed to extract $filename"
      ;;
    *.bz2)
      printf_blue "Extracting to $extract_dir"
      mkdir -p "$extract_dir"
      tar xjf "$filename" -C "$extract_dir" &>/dev/null || printf_exit "Failed to extract $filename"
      ;;
    *.tar.gz)
      printf_blue "Extracting to $extract_dir"
      mkdir -p "$extract_dir"
      tar xf "$filename" -C "$extract_dir" &>/dev/null || printf_exit "Failed to extract $filename"
      ;;
    *.tgz)
      printf_blue "Extracting to $extract_dir"
      mkdir -p "$extract_dir"
      tar xf "$filename" -C "$extract_dir" &>/dev/null || printf_exit "Failed to extract $filename"
      ;;
    *.gz)
      printf_blue "Extracting to $extract_dir"
      mkdir -p "$extract_dir"
      tar xf "$filename" -C "$extract_dir" &>/dev/null || printf_exit "Failed to extract $filename"
      ;;
    *.zip)
      printf_blue "Extracting to $extract_dir"
      mkdir -p "$extract_dir"
      unzip "$filename" -d "$extract_dir" &>/dev/null || printf_exit "Failed to extract $filename"
      ;;
    *.7z)
      printf_blue "Extracting to $extract_dir"
      mkdir -p "$extract_dir"
      7za x -y "$filename" -o"$extract_dir" my_dir && mv -f my_dir/* "$extract_dir" && rmdir my_dir &>/dev/null || printf_exit "Failed to extract $filename"
      ;;
    *) ;;
    esac
    [[ -z "$LATEST_RELEASES_BIN_NAME" ]] || extract_name="$LATEST_RELEASES_BIN_NAME"
    if [[ "$(find "$extract_dir" -maxdepth 1 -type f,d 2>/dev/null | wc -l)" -gt 4 ]]; then
      ln -sf "$extract_dir/$extract_name" "$HOME/.local/bin/$extract_name" &&
        chmod 755 "$HOME/.local/bin/$extract_name" &&
        printf_cyan "Installed $extract_dir/$extract_name to $HOME/.local/bin/$extract_name" ||
        printf_red "Failed to install $extract_name to $HOME/.local/bin/$extract_name"
    elif [[ -f "$extract_dir/$extract_name" ]] && [[ $(file --mime-type -b "$extract_dir/$extract_name") == "application/x-executable" ]]; then
      __cp_rf "$extract_dir/$extract_name" "$HOME/.local/bin/$extract_name" &&
        chmod 755 "$HOME/.local/bin/$extract_name" &&
        printf_cyan "Installed $extract_dir/$extract_name to $HOME/.local/bin/$extract_name" ||
        printf_red "Failed to install $extract_name to $HOME/.local/bin/$extract_name"
      __rm_rf "$extract_dir"
    elif [[ -f "$filename" ]] && [[ $(file --mime-type -b "$filename") == "application/x-executable" ]]; then
      __cp_rf "$filename" "$HOME/.local/bin/${basenamerepo}" &&
        printf_cyan "Installed $filename to $HOME/.local/bin/${basenamerepo}" ||
        printf_red "Failed to install $filename to $HOME/.local/bin/${basenamerepo}"
    fi
  else
    manual_dl="$(echo $latest_json | jq -r '.html_url')"
    printf_custom $LATEST_RELEASES_OUTPUT_COLOR_ERROR "No releases found from $repo matching $arch"
    echo "Go to $manual_dl for manual download" | printf_readline $LATEST_RELEASES_OUTPUT_COLOR
    exitCode=1
  fi
  if sudo -n true; then
    if [[ -f "$HOME/.local/bin/${basenamerepo}" ]]; then
      printf_green "Copying $basenamerepo to /usr/local/bin"
      sudo cp -Rf "$HOME/.local/bin/${basenamerepo}" "/usr/local/bin/${basenamerepo}"
      sudo chmod -Rf 755 "/usr/local/bin/${basenamerepo}"
    fi
  fi
  [[ -n "$latest_download" ]] && __add_to_latest "$repo" "$repo"
  [[ -s "$tempfile" ]] && __mv_f "$tempfile" "$filename"
  echo
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__browser_download_url() {
  echo "${1:-$latest_json}" | grep -iE 'browser_download_url' |
    grep -vE '*.deb|*.rpm' |
    grep -E 'tar.*|*.bz|*.zip|.*' |
    cut -d '"' -f 4 |
    grep -i "$(uname -s)" | grep -i "${2:-$arch}" |
    head -n1 | grep '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__wget_latest() {
  [[ -d "$download_dir" ]] || __mkd "$download_dir"
  if [[ -s "$filename" ]]; then
    printf_yellow "Already downloaded $filename"
    printf_yellow "Reinstalling from $filename"
    __cp_rf "$filename" "$tempfile"
    return 0
  elif [[ -z "$LATEST_RELEASE_GITHUB_TOKEN" ]]; then
    wget -q "${1:-$latest_download}" -O "${2:-$tempfile}" 2>/dev/null
  else
    wget -q --header="Authorization: token ${LATEST_RELEASE_GITHUB_TOKEN}" "${1:-$latest_download}" -O "${2:-$tempfile}" 2>/dev/null
  fi
  [[ -s "${2:-$tempfile}" ]] && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_date() {
  if [[ -z "$LATEST_RELEASE_GITHUB_TOKEN" ]]; then
    curl -q -LS -s "${tag_commit_url}" 2>/dev/null | jq -r ".commit.author.date" 2>/dev/null | cut -d 'T' -f 1
  else
    curl -q -LS -H "Authorization: token $LATEST_RELEASE_GITHUB_TOKEN" -s "${tag_commit_url}" 2>/dev/null | jq -r ".commit.author.date" 2>/dev/null | cut -d 'T' -f 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_tag() {
  if [[ -z "$LATEST_RELEASE_GITHUB_TOKEN" ]]; then
    curl -q -LSs -H "https://api.github.com/repos/${repo}/tags?per_page=1" 2>/dev/null | jq -r ".[0].name, .[0].commit.url" 2>/dev/null | paste -sd,-
  else
    curl -q -LSs -H "Authorization: token $LATEST_RELEASE_GITHUB_TOKEN" "https://api.github.com/repos/${repo}/tags?per_page=1" 2>/dev/null | jq -r ".[0].name, .[0].commit.url" 2>/dev/null | paste -sd,-
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_json() {
  if [[ -z "$LATEST_RELEASE_GITHUB_TOKEN" ]]; then
    curl -q -LSs --fail "${1:-$api_url}" 2>/dev/null
  else
    curl -q -LSs --fail -H "Authorization: token $LATEST_RELEASE_GITHUB_TOKEN" "${1:-$api_url}" 2>/dev/null
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_json_all() {
  echo "$1" | grep -qs './.' || printf_exit "Usage: $APPNAME username/reponame"
  local results="$(__curl_json "https://api.github.com/repos/${1:-$repo}/releases" 2>/dev/null)"
  if [[ -n "$results" ]]; then
    printf '%s\n' "$results" | jq -r '.[]' | jq -r '.assets | .[].browser_download_url' | sort | grep '^' ||
      {
        manual_dl="$(echo $results | jq -r '.[] | .html_url' | sort -n | tail -n1 | grep '^')"
        printf_custom $LATEST_RELEASES_OUTPUT_COLOR_ERROR "No releases found from ${1:-$repo}"
        if [[ -n "$manual_dl" ]]; then
          printf_purple "However I did find the following link:"
          printf '%s\n' "$manual_dl" | printf_readline $LATEST_RELEASES_OUTPUT_COLOR
        fi
        exit 1
      }
  else
    printf_exit "No releases found for ${1:-$repo}"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__show_latest() {
  printf_green "Latest releases on GitHub:"
  nl=$'\n'
  out=""
  while read -r repo; do
    tag_info=""
    tag_name=""
    tag_commit_url=""
    tag_commit_date=""
    set -e
    if ! tag_info="$(__curl_tag)"; then
      printf_green "You are API rate limited by GitHub, please authenticate by:"
      printf_green 'export LATEST_RELEASE_GITHUB_TOKEN="youraccesstoken"'
      exit "${?}"
    fi
    set -e
    tag_name="$(cut -d ',' -f 1 <<<"${tag_info}")"
    tag_commit_url="$(cut -d ',' -f 2 <<<"${tag_info}")"
    tag_commit_date="$(__curl_date)"
    out+=$"${repo} | ${tag_name} | ${tag_commit_date}${nl}"
  done <"$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
  column -t <<<"${out}" | sort -t "|" -k 3 -r | printf_readline "6"
}

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__update_install() {
  if [[ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" ]] && [[ -z "$1" ]]; then
    while read -r repo_list; do
      [[ -n "$repo_list" ]] && __install_latest "$repo_list"
      repo_list=
    done <"$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST"
  else
    for l in "$@"; do
      __install_latest "$l"
    done
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_repos() {
  res="$(curl -q -LSs -H "Authorization: token $LATEST_RELEASE_GITHUB_TOKEN" \
    "https://api.github.com/users/$1/repos&per_page=500&sort=updated" 2>/dev/null |
    jq -r '.[] | .name' 2>/dev/null | grep '^' || return 1)"
  [ -n "$res" ] && printf '%s\n' "$res" | sort -n || __api_search "$1"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__api_search() {
  res="$(curl -q -LSsf "https://api.github.com/search/repositories?q=${1:-$repo}&per_page=100&sort=updated" 2>/dev/null |
    jq -r '.items[].full_name' 2>/dev/null || return 1)" &&
    [ -n "$res" ] && printf '%s\n' "$res" | sort -u || printf_exit "No results found for ${1:-$repo}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__search_help() {
  printf_red "Usage: $APPNAME username/reponame [filter] [grepOpts]" &&
    printf_red "or: $APPNAME search api <query>" &&
    printf_exit "$APPNAME search PowerShell/PowerShell 'arm' '-E linux|amd -v alpine'"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
LATEST_RELEASES_LOG_DIR="${LATEST_RELEASES_LOG_DIR:-$HOME/.local/log/latest-releases}"
LATEST_RELEASES_CACHE_DIR="${LATEST_RELEASES_CACHE_DIR:-$HOME/.cache/latest-releases}"
LATEST_RELEASES_CONFIG_DIR="${LATEST_RELEASES_CONFIG_DIR:-$HOME/.config/myscripts/latest-releases}"
LATEST_RELEASES_CONFIG_BACKUP_DIR="${LATEST_RELEASES_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/latest-releases/backups}"
LATEST_RELEASES_TEMP_DIR="${LATEST_RELEASES_TEMP_DIR:-$HOME/.local/tmp/system_scripts/latest-releases}"
LATEST_RELEASES_OPTIONS_DIR="${LATEST_RELEASES_OPTIONS_DIR:-$HOME/.local/share/myscripts/latest-releases/options}"
LATEST_RELEASES_CONFIG_FILE="${LATEST_RELEASES_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
LATEST_RELEASES_OUTPUT_COLOR="${LATEST_RELEASES_OUTPUT_COLOR:-4}"
LATEST_RELEASES_OUTPUT_COLOR_2="${LATEST_RELEASES_OUTPUT_COLOR:-6}"
LATEST_RELEASES_OUTPUT_COLOR_GOOD="${LATEST_RELEASES_OUTPUT_COLOR_GOOD:-2}"
LATEST_RELEASES_OUTPUT_COLOR_ERROR="${LATEST_RELEASES_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
LATEST_RELEASES_GOOD_MESSAGE="${LATEST_RELEASES_GOOD_MESSAGE:-Everything Went OK}"
LATEST_RELEASES_ERROR_MESSAGE="${LATEST_RELEASES_ERROR_MESSAGE:-Well something seems to have gone wrong}"
LATEST_RELEASES_NOTIFY_ENABLED="${LATEST_RELEASES_NOTIFY_ENABLED:-yes}"
LATEST_RELEASES_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
LATEST_RELEASES_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$LATEST_RELEASES_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
LATEST_RELEASE_GITHUB_USERNAME="${LATEST_RELEASE_GITHUB_USERNAME:-$GITHUB_USERNAME}"
LATEST_RELEASE_GITHUB_TOKEN="${LATEST_RELEASE_GITHUB_TOKEN:-$GITHUB_ACCESS_TOKEN}"
LATEST_RELEASE_REPO_LIST="${LATEST_RELEASE_REPO_LIST:-repos.conf}"
LATEST_RELEASE_GITHUB_AUTH_FILE="${LATEST_RELEASE_GITHUB_AUTH_FILE:-auth.conf}"
LATEST_RELEASE_DEFAULT_ARCH="${LATEST_RELEASE_DEFAULT_ARCH:-$(uname -m)}"
LATEST_RELEASE_DOWNLOADS="${LATEST_RELEASE_DOWNLOADS:-$HOME/Downloads/Latest}"
LATEST_RELEASE_INSTALL_DIR="${LATEST_RELEASE_INSTALL_DIR:-$HOME/.local/share/latest-releases}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
[ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE" ] || __gen_github_auth &>/dev/null
[ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST" ] || __gen_repolist &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE" ] && . "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASES_CONFIG_FILE"
[ -f "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE" ] && . "$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_GITHUB_AUTH_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$LATEST_RELEASES_LOG_DIR" ] || mkdir -p "$LATEST_RELEASES_LOG_DIR" &>/dev/null
[ -d "$LATEST_RELEASES_TEMP_DIR" ] || mkdir -p "$LATEST_RELEASES_TEMP_DIR" &>/dev/null
[ -d "$LATEST_RELEASES_CACHE_DIR" ] || mkdir -p "$LATEST_RELEASES_CACHE_DIR" &>/dev/null
[ -d "$LATEST_RELEASE_INSTALL_DIR" ] || mkdir -p "$LATEST_RELEASE_INSTALL_DIR" &>/dev/null
LATEST_RELEASES_TEMP_FILE="${LATEST_RELEASES_TEMP_FILE:-$(mktemp $LATEST_RELEASES_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$LATEST_RELEASES_TEMP_FILE" ] && [ -f "$LATEST_RELEASES_TEMP_FILE" ] && rm -Rf "$LATEST_RELEASES_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$LATEST_RELEASES_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${LATEST_RELEASES_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${LATEST_RELEASES_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${LATEST_RELEASES_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${LATEST_RELEASES_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="f:,t:,b:"
LONGOPTS="options,config,version,help,dir:,filename:,type:,bin:"
ARRAY="add remove install gitea info update list search"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    __gen_repolist
    __gen_update_list
    __gen_github_auth
    exit $?
    ;;
  --dir)
    LATEST_RELEASES_CWD="$2"
    shift 2
    ;;
  -f | --filename)
    LATEST_RELEASES_FILENAME="$2"
    shift 2
    ;;
  -t | --type)
    LATEST_RELEASES_ARCH="$2"
    shift 2
    ;;
  -b | --bin)
    LATEST_RELEASES_BIN_NAME="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash jq curl wget || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
add)
  shift 1
  for l in "$@"; do
    __add_to_latest "$l"
  done
  exit
  ;;

remove)
  shift 1
  for l in "$@"; do
    __remove_from_latest "$l"
  done
  exit
  ;;

install)
  shift 1
  __update_install "$@"
  exit $?
  ;;

update)
  shift 1
  __update_install "$@"
  exit $?
  ;;

gitea)
  shift 1
  __gitea "$@"
  ;;

info)
  shift 1
  __show_latest
  ;;

list)
  shift 1
  show="$(<"$LATEST_RELEASES_CONFIG_DIR/$LATEST_RELEASE_REPO_LIST")"
  if [[ -n "$show" ]]; then
    printf '\n'
    printf_purple "The following packages are available for installation:"
    printf '%s\n' "$show" | printf_column '6'
  else
    printf_return "There are no packages available"
  fi
  exit $?
  ;;

search)
  shift 1
  if [ "$1" = "repo" ]; then
    shift 1
    [ $# = 0 ] && __search_help || __api_repos "$@"
  elif [ "$1" = "api" ]; then
    shift 1
    [ $# = 0 ] && __search_help || __api_search "$@"
  elif echo "$1" | grep -vq './.' && [ $# = 0 ]; then
    __search_help
  elif [ $# -eq 1 ]; then
    __curl_json_all "$1"
  elif [ $# -gt 1 ]; then
    __curl_json_all "$1" | grep -i $3 "$2"
  fi
  exit $?
  ;;

*)
  if [[ $# -ne 0 ]]; then
    for l in "$@"; do
      __install_latest "$@" && __add_to_latest "$l"
    done
  else
    __show_latest
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
