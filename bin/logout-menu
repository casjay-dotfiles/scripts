#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : logout-menu --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : logout-menu
# @Description   : Logout, shutdown, reboot or lock screen
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$LOGOUT_MENU_TEMP_FILE" ] && [ -f "$LOGOUT_MENU_TEMP_FILE" ] && rm -Rf "$LOGOUT_MENU_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$LOGOUT_MENU_CONFIG_DIR/$LOGOUT_MENU_CONFIG_FILE"
  [ -d "$LOGOUT_MENU_CONFIG_DIR" ] || mkdir -p "$LOGOUT_MENU_CONFIG_DIR"
  [ -d "$LOGOUT_MENU_CONFIG_BACKUP_DIR" ] || mkdir -p "$LOGOUT_MENU_CONFIG_BACKUP_DIR"
  [ -f "$LOGOUT_MENU_CONFIG_DIR/$LOGOUT_MENU_CONFIG_FILE" ] &&
    cp -Rf "$LOGOUT_MENU_CONFIG_DIR/$LOGOUT_MENU_CONFIG_FILE" "$LOGOUT_MENU_CONFIG_BACKUP_DIR/$LOGOUT_MENU_CONFIG_FILE.$$"
  cat <<EOF >"$LOGOUT_MENU_CONFIG_DIR/$LOGOUT_MENU_CONFIG_FILE"
# Settings for logout-menu
LOGOUT_MENU_LOCKER_APP="${LOGOUT_MENU_LOCKER_APP:=slock}"

# Notification settings
LOGOUT_MENU_GOOD_MESSAGE="${LOGOUT_MENU_GOOD_MESSAGE:-Everything Went OK}"
LOGOUT_MENU_ERROR_MESSAGE="${LOGOUT_MENU_ERROR_MESSAGE:-Well something seems to have gone wrong}"
LOGOUT_MENU_NOTIFY_ENABLED="${LOGOUT_MENU_NOTIFY_ENABLED:-yes}"
LOGOUT_MENU_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
LOGOUT_MENU_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$LOGOUT_MENU_NOTIFY_CLIENT_ICON}"

# Colorization settings
LOGOUT_MENU_OUTPUT_COLOR="${LOGOUT_MENU_OUTPUT_COLOR:-5}"
LOGOUT_MENU_OUTPUT_COLOR_GOOD="${LOGOUT_MENU_OUTPUT_COLOR_GOOD:-2}"
LOGOUT_MENU_OUTPUT_COLOR_ERROR="${LOGOUT_MENU_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$LOGOUT_MENU_CONFIG_DIR/$LOGOUT_MENU_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    # if [[ "$INIT_CONFIG" = "TRUE" ]]; then
    #   unset INIT_CONFIG
    #   eval bash -c "$APPNAME $*"
    #   exit
    # fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__output() { ${OUTPUT} "$APPNAME" "$@"; }
cmd_exists rofi && __dmenu() { rofi -theme ${ROFI_THEME:-purple} -dmenu -i -p "$*" || return 1; }
cmd_exists dmenu && __dmenu() { dmenu -i -p "$*" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
LOGOUT_MENU_LOG_DIR="${LOGOUT_MENU_LOG_DIR:-$HOME/.local/log/logout-menu}"
LOGOUT_MENU_CACHE_DIR="${LOGOUT_MENU_CACHE_DIR:-$HOME/.cache/logout-menu}"
LOGOUT_MENU_CONFIG_DIR="${LOGOUT_MENU_CONFIG_DIR:-$HOME/.config/myscripts/logout-menu}"
LOGOUT_MENU_CONFIG_BACKUP_DIR="${LOGOUT_MENU_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/logout-menu/backups}"
LOGOUT_MENU_TEMP_DIR="${LOGOUT_MENU_TEMP_DIR:-$HOME/.local/tmp/system_scripts/logout-menu}"
LOGOUT_MENU_OPTIONS_DIR="${LOGOUT_MENU_OPTIONS_DIR:-$HOME/.local/share/myscripts/logout-menu/options}"
LOGOUT_MENU_TEMP_FILE="${LOGOUT_MENU_TEMP_FILE:-$(mktemp $LOGOUT_MENU_TEMP_DIR/XXXXXX 2>/dev/null)}"
LOGOUT_MENU_CONFIG_FILE="${LOGOUT_MENU_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
LOGOUT_MENU_OUTPUT_COLOR="${LOGOUT_MENU_OUTPUT_COLOR:-4}"
LOGOUT_MENU_OUTPUT_COLOR_2="${LOGOUT_MENU_OUTPUT_COLOR:-6}"
LOGOUT_MENU_OUTPUT_COLOR_GOOD="${LOGOUT_MENU_OUTPUT_COLOR_GOOD:-2}"
LOGOUT_MENU_OUTPUT_COLOR_ERROR="${LOGOUT_MENU_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
LOGOUT_MENU_GOOD_MESSAGE="${LOGOUT_MENU_GOOD_MESSAGE:-Everything Went OK}"
LOGOUT_MENU_ERROR_MESSAGE="${LOGOUT_MENU_ERROR_MESSAGE:-Well something seems to have gone wrong}"
LOGOUT_MENU_NOTIFY_ENABLED="${LOGOUT_MENU_NOTIFY_ENABLED:-yes}"
LOGOUT_MENU_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
LOGOUT_MENU_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$LOGOUT_MENU_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$LOGOUT_MENU_CONFIG_DIR/$LOGOUT_MENU_CONFIG_FILE" ] && . "$LOGOUT_MENU_CONFIG_DIR/$LOGOUT_MENU_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$LOGOUT_MENU_LOG_DIR" ] || mkdir -p "$LOGOUT_MENU_LOG_DIR" &>/dev/null
[ -d "$LOGOUT_MENU_TEMP_DIR" ] || mkdir -p "$LOGOUT_MENU_TEMP_DIR" &>/dev/null
[ -d "$LOGOUT_MENU_CACHE_DIR" ] || mkdir -p "$LOGOUT_MENU_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$LOGOUT_MENU_CONFIG_DIR/$LOGOUT_MENU_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    LOGOUT_MENU_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$LOGOUT_MENU_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${LOGOUT_MENU_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${LOGOUT_MENU_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${LOGOUT_MENU_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${LOGOUT_MENU_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash slock || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
type -p __dmenu &>/dev/null || printf_exit "This requires either rofi or dmenu to be installed"
ask_for_password true
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
declare -a MANAGERS
while IFS= read -r manager; do
  MANAGERS+=("${manager,,}")
done < <(grep 'Name' /usr/share/xsessions/*.desktop | awk -F"=" '{print $2}')

declare -a options=(
  "Cancel"
  "Lock screen"
  "Logout"
  "Reboot"
  "Shutdown"
  "Quit"
)
OUTPUT="echo"
if [[ ${TERM} == 'dumb' ]]; then
  OUTPUT="__notifications"
fi
export OUTPUT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
choice=$(printf '%s\n' "${options[@]}" | __dmenu 'Shutdown menu: ' "${@}")
case $choice in
'Logout')
  if [[ "$(echo -e "No\nYes" | __dmenu "${choice}?" "${@}")" == "Yes" ]]; then
    for manager in "${MANAGERS[@]}"; do
      killall "${manager}" || __output "Process ${manager} was not running."
    done
  else
    __output "User chose not to logout." && exit 1
  fi
  ;;
'Lock screen')
  ${LOGOUT_MENU_LOCKER_APP}
  ;;
'Reboot')
  if [[ "$(echo -e "No\nYes" | __dmenu "${choice}?" "${@}")" == "Yes" ]]; then
    sudo reboot
  else
    __output "User chose not to reboot." && exit 1
  fi
  ;;
'Shutdown')
  if [[ "$(echo -e "No\nYes" | __dmenu "${choice}?" "${@}")" == "Yes" ]]; then
    sudo poweroff
  else
    __output "User chose not to shutdown." && exit 1
  fi
  ;;
'Suspend')
  if [[ "$(echo -e "No\nYes" | __dmenu "${choice}?" "${@}")" == "Yes" ]]; then
    sudo systemctl suspend
  else
    __output "User chose not to suspend." && exit 1
  fi
  ;;
'Quit')
  __output "Program terminated." && exit 1
  ;;
'Cancel')
  __output "User chose to cancel." && exit 1
  ;;
*)
  false
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
