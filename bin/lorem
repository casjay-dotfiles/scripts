#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : lorem --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : lorem
# @Description   : lorem ipsum generator
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$LOREM_TEMP_FILE" ] && [ -f "$LOREM_TEMP_FILE" ] && rm -Rf "$LOREM_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$LOREM_CONFIG_DIR/$LOREM_CONFIG_FILE"
  [ -d "$LOREM_CONFIG_DIR" ] || mkdir -p "$LOREM_CONFIG_DIR"
  [ -d "$LOREM_CONFIG_BACKUP_DIR" ] || mkdir -p "$LOREM_CONFIG_BACKUP_DIR"
  [ -f "$LOREM_CONFIG_DIR/$LOREM_CONFIG_FILE" ] &&
    cp -Rf "$LOREM_CONFIG_DIR/$LOREM_CONFIG_FILE" "$LOREM_CONFIG_BACKUP_DIR/$LOREM_CONFIG_FILE.$$"
  cat <<EOF >"$LOREM_CONFIG_DIR/$LOREM_CONFIG_FILE"
# Settings for lorem
LOREM_API_SERVER="${LOREM_API_SERVER:-https://lorum.casjay.now.sh}"
LOREM_DEFAULT_TYPE="${LOREM_DEFAULT_TYPE:-paragraphs}"
LOREM_DEFAULT_AMOUNT="${LOREM_DEFAULT_AMOUNT:-10}"
LOREM_DEFAULT_AMOUNT_SENTENCE="${LOREM_DEFAULT_AMOUNT_SENTENCE:-15}"
LOREM_DEFAULT_AMOUNT_PARAGRAPH="${LOREM_DEFAULT_AMOUNT_PARAGRAPH:-5}"

# Notification settings
LOREM_GOOD_MESSAGE="${LOREM_GOOD_MESSAGE:-Everything Went OK}"
LOREM_ERROR_MESSAGE="${LOREM_ERROR_MESSAGE:-Well that didn\'t work}"
LOREM_NOTIFY_ENABLED="${LOREM_NOTIFY_ENABLED:-yes}"
LOREM_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
LOREM_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$LOREM_NOTIFY_CLIENT_ICON}"

# Colorization settings
LOREM_OUTPUT_COLOR="${LOREM_OUTPUT_COLOR:-5}"
LOREM_OUTPUT_COLOR_GOOD="${LOREM_OUTPUT_COLOR_GOOD:-2}"
LOREM_OUTPUT_COLOR_ERROR="${LOREM_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$LOREM_CONFIG_DIR/$LOREM_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for lorem has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
LOREM_LOG_DIR="${LOREM_LOG_DIR:-$HOME/.local/log/lorem}"
LOREM_CACHE_DIR="${LOREM_CACHE_DIR:-$HOME/.cache/lorem}"
LOREM_CONFIG_DIR="${LOREM_CONFIG_DIR:-$HOME/.config/myscripts/lorem}"
LOREM_CONFIG_BACKUP_DIR="${LOREM_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/lorem/backups}"
LOREM_TEMP_DIR="${LOREM_TEMP_DIR:-$HOME/.local/tmp/system_scripts/lorem}"
LOREM_OPTIONS_DIR="${LOREM_OPTIONS_DIR:-$HOME/.local/share/myscripts/lorem/options}"
LOREM_TEMP_FILE="${LOREM_TEMP_FILE:-$(mktemp $LOREM_TEMP_DIR/XXXXXX 2>/dev/null)}"
LOREM_CONFIG_FILE="${LOREM_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
LOREM_OUTPUT_COLOR="${LOREM_OUTPUT_COLOR:-4}"
LOREM_OUTPUT_COLOR_2="${LOREM_OUTPUT_COLOR:-6}"
LOREM_OUTPUT_COLOR_GOOD="${LOREM_OUTPUT_COLOR_GOOD:-2}"
LOREM_OUTPUT_COLOR_ERROR="${LOREM_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
LOREM_GOOD_MESSAGE="${LOREM_GOOD_MESSAGE:-Everything Went OK}"
LOREM_ERROR_MESSAGE="${LOREM_ERROR_MESSAGE:-Well that didn\'t work}"
LOREM_NOTIFY_ENABLED="${LOREM_NOTIFY_ENABLED:-yes}"
LOREM_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
LOREM_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$LOREM_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
LOREM_API_SERVER="${LOREM_API_SERVER:-https://lorum.casjay.now.sh}"
LOREM_DEFAULT_TYPE="${LOREM_DEFAULT_TYPE:-paragraphs}"
LOREM_DEFAULT_AMOUNT="${LOREM_DEFAULT_AMOUNT:-10}"
LOREM_DEFAULT_AMOUNT_SENTENCE="${LOREM_DEFAULT_AMOUNT_SENTENCE:-15}"
LOREM_DEFAULT_AMOUNT_PARAGRAPH="${LOREM_DEFAULT_AMOUNT_PARAGRAPH:-5}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$LOREM_CONFIG_DIR/$LOREM_CONFIG_FILE" ] && . "$LOREM_CONFIG_DIR/$LOREM_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$LOREM_LOG_DIR" ] || mkdir -p "$LOREM_LOG_DIR" &>/dev/null
[ -d "$LOREM_TEMP_DIR" ] || mkdir -p "$LOREM_TEMP_DIR" &>/dev/null
[ -d "$LOREM_CACHE_DIR" ] || mkdir -p "$LOREM_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$LOREM_CONFIG_DIR/$LOREM_CONFIG_FILE" ] && [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config "${SETARGS:-$*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    LOREM_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$LOREM_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${LOREM_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${LOREM_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${LOREM_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${LOREM_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
p | paragraphs)
  type="paragraphs"
  amount="${2:-$LOREM_DEFAULT_AMOUNT_PARAGRAPH}"
  ;;

s | sentences)
  type="sentences"
  amount="${2:-$LOREM_DEFAULT_AMOUNT_SENTENCE}"
  ;;

a | amount)
  type="${LOREM_DEFAULT_TYPE:-sentences}"
  amount="${2:-$LOREM_DEFAULT_AMOUNT_SENTENCE}"
  ;;

*)
  type="${type:-$LOREM_DEFAULT_TYPE}"
  amount="${2:-$LOREM_DEFAULT_AMOUNT}"
  ;;
esac
#printf_exit "$LOREM_API_SERVER $type $amount"
printf_blue "Below is your request from $LOREM_API_SERVER/$type/$amount\n"
__curl "${LOREM_API_SERVER}/${type}/${amount}" | sed 's|\. |\.\n|g'
printf_newline '\n\n'

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
