#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : mailsync --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : mailsync
# @Description   : Sync mail and give notification if there is new mail.
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$MAILSYNC_TEMP_FILE" ] && [ -f "$MAILSYNC_TEMP_FILE" ] && rm -Rf "$MAILSYNC_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$MAILSYNC_CONFIG_DIR/$MAILSYNC_CONFIG_FILE"
  [ -d "$MAILSYNC_CONFIG_DIR" ] || mkdir -p "$MAILSYNC_CONFIG_DIR"
  [ -d "$MAILSYNC_CONFIG_BACKUP_DIR" ] || mkdir -p "$MAILSYNC_CONFIG_BACKUP_DIR"
  [ -f "$MAILSYNC_CONFIG_DIR/$MAILSYNC_CONFIG_FILE" ] &&
    cp -Rf "$MAILSYNC_CONFIG_DIR/$MAILSYNC_CONFIG_FILE" "$MAILSYNC_CONFIG_BACKUP_DIR/$MAILSYNC_CONFIG_FILE.$$"
  cat <<EOF >"$MAILSYNC_CONFIG_DIR/$MAILSYNC_CONFIG_FILE"
# Settings for mailsync
MAILSYNC_PASSWORD_STORE_DIR="${MAILSYNC_PASSWORD_STORE_DIR:-$PASSWORD_STORE_DIR}"

# Notification settings
MAILSYNC_GOOD_MESSAGE="${MAILSYNC_GOOD_MESSAGE:-Everything Went OK}"
MAILSYNC_ERROR_MESSAGE="${MAILSYNC_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MAILSYNC_NOTIFY_ENABLED="${MAILSYNC_NOTIFY_ENABLED:-yes}"
MAILSYNC_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MAILSYNC_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MAILSYNC_NOTIFY_CLIENT_ICON}"

# Colorization settings
MAILSYNC_OUTPUT_COLOR="${MAILSYNC_OUTPUT_COLOR:-5}"
MAILSYNC_OUTPUT_COLOR_GOOD="${MAILSYNC_OUTPUT_COLOR_GOOD:-2}"
MAILSYNC_OUTPUT_COLOR_ERROR="${MAILSYNC_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MAILSYNC_CONFIG_DIR/$MAILSYNC_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for mailsync has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__notify() { notifications "mutt-wizard" "📬 $2 new mail(s) in \`$1\` account."; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
syncandnotify() {
  acc="$(echo "$account" | sed "s/.*\///")"
  mbsync "$acc"
  new=$(find "$HOME/.local/share/mail/$acc/INBOX/new/" "$HOME/.local/share/mail/$acc/Inbox/new/" "$HOME/.local/share/mail/$acc/inbox/new/" -type f -newer "$MAILSYNC_CACHE_DIR/mailsynclastrun" 2>/dev/null)
  newcount=$(echo "$new" | sed '/^\s*$/d' | wc -l)
  if [ "$newcount" -gt "0" ]; then
    __notify "$acc" "$newcount" &
    for file in $new; do
      # Extract subject and sender from mail.
      from=$(awk '/^From: / && ++n ==1,/^\<.*\>:/' "$file" | perl -CS -MEncode -ne 'print decode("MIME-Header", $_)' | awk '{ $1=""; if (NF>=3)$NF=""; print $0 }' | sed 's/^[[:blank:]]*[\"'\''\<]*//;s/[\"'\''\>]*[[:blank:]]*$//')
      subject=$(awk '/^Subject: / && ++n == 1,/^\<.*\>: / && ++i == 2' "$file" | head -n-1 | perl -CS -MEncode -ne 'print decode("MIME-Header", $_)' | sed 's/^Subject: //' | sed 's/^{[[:blank:]]*[\"'\''\<]*//;s/[\"'\''\>]*[[:blank:]]*$//' | tr -d '\n')
      __notify "📧$from:" "$subject" &
    done
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MAILSYNC_LOG_DIR="${MAILSYNC_LOG_DIR:-$HOME/.local/log/mailsync}"
MAILSYNC_CACHE_DIR="${MAILSYNC_CACHE_DIR:-$HOME/.cache/mailsync}"
MAILSYNC_CONFIG_DIR="${MAILSYNC_CONFIG_DIR:-$HOME/.config/myscripts/mailsync}"
MAILSYNC_CONFIG_BACKUP_DIR="${MAILSYNC_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/mailsync/backups}"
MAILSYNC_TEMP_DIR="${MAILSYNC_TEMP_DIR:-$HOME/.local/tmp/system_scripts/mailsync}"
MAILSYNC_OPTIONS_DIR="${MAILSYNC_OPTIONS_DIR:-$HOME/.local/share/myscripts/mailsync/options}"
MAILSYNC_TEMP_FILE="${MAILSYNC_TEMP_FILE:-$(mktemp $MAILSYNC_TEMP_DIR/XXXXXX 2>/dev/null)}"
MAILSYNC_CONFIG_FILE="${MAILSYNC_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MAILSYNC_OUTPUT_COLOR="${MAILSYNC_OUTPUT_COLOR:-4}"
MAILSYNC_OUTPUT_COLOR_2="${MAILSYNC_OUTPUT_COLOR:-6}"
MAILSYNC_OUTPUT_COLOR_GOOD="${MAILSYNC_OUTPUT_COLOR_GOOD:-2}"
MAILSYNC_OUTPUT_COLOR_ERROR="${MAILSYNC_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MAILSYNC_GOOD_MESSAGE="${MAILSYNC_GOOD_MESSAGE:-Everything Went OK}"
MAILSYNC_ERROR_MESSAGE="${MAILSYNC_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MAILSYNC_NOTIFY_ENABLED="${MAILSYNC_NOTIFY_ENABLED:-yes}"
MAILSYNC_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MAILSYNC_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MAILSYNC_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
MAILSYNC_PASSWORD_STORE_DIR="${MAILSYNC_PASSWORD_STORE_DIR:-$PASSWORD_STORE_DIR}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MAILSYNC_CONFIG_DIR/$MAILSYNC_CONFIG_FILE" ] && . "$MAILSYNC_CONFIG_DIR/$MAILSYNC_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MAILSYNC_LOG_DIR" ] || mkdir -p "$MAILSYNC_LOG_DIR" &>/dev/null
[ -d "$MAILSYNC_TEMP_DIR" ] || mkdir -p "$MAILSYNC_TEMP_DIR" &>/dev/null
[ -d "$MAILSYNC_CACHE_DIR" ] || mkdir -p "$MAILSYNC_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MAILSYNC_CONFIG_DIR/$MAILSYNC_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MAILSYNC_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MAILSYNC_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MAILSYNC_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MAILSYNC_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MAILSYNC_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MAILSYNC_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash mbsync notmuch || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
pgrep -x mbsync >/dev/null && printf_exit "mbsync is already running."
pgrep -u "${USER:=$LOGNAME}" >/dev/null || printf_exit "$USER not logged in; sync will not run."
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u)/bus}"
if [ -d "$MAILSYNC_PASSWORD_STORE_DIR" ] || [ -d "$HOME/.local/share/password-store" ]; then
  MAILSYNC_PASSWORD_STORE_DIR="${MAILSYNC_PASSWORD_STORE_DIR:-$HOME/.local/share/password-store}"
fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ "$#" -eq "0" ]; then
  accounts="$(awk '/^Channel/ {print $2}' "$HOME/.mbsyncrc" 2>/dev/null)"
else
  accounts=$*
fi
echo " 🔃" >"$MAILSYNC_TEMP_FILE"
[ -n "${STATUSBAR:-}" ] && devnull pkill -RTMIN+12 "${STATUSBAR:-}"
for account in $accounts; do
  syncandnotify &
done
wait
[ -n "${STATUSBAR:-}" ] && devnull pkill -RTMIN+12 "${STATUSBAR:-}"
notmuch new 2>/dev/null
touch "$MAILSYNC_CACHE_DIR/mailsynclastrun"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
