#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -xo pipefail && export DEBUGGING="true"
trap 'exitCode=${exitCode:-$?};[ -f "$MKPASSWD_TEMP_FILE" ] && rm -Rf "$MKPASSWD_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : mkpasswd --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : mkpasswd
# @Description   : generate random password
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$MKPASSWD_CONFIG_DIR/$MKPASSWD_CONFIG_FILE"
  [ -d "$MKPASSWD_CONFIG_DIR" ] || mkdir -p "$MKPASSWD_CONFIG_DIR"
  [ -d "$MKPASSWD_CONFIG_BACKUP_DIR" ] || mkdir -p "$MKPASSWD_CONFIG_BACKUP_DIR"
  [ -f "$MKPASSWD_CONFIG_DIR/$MKPASSWD_CONFIG_FILE" ] &&
    cp -Rf "$MKPASSWD_CONFIG_DIR/$MKPASSWD_CONFIG_FILE" "$MKPASSWD_CONFIG_BACKUP_DIR/$MKPASSWD_CONFIG_FILE.$$"
  cat <<EOF >"$MKPASSWD_CONFIG_DIR/$MKPASSWD_CONFIG_FILE"
# Settings for mkpasswd
MKPASSWD_DEFAULT_LENGTH="${MKPASSWD_DEFAULT_LENGTH:-20}"
MKPASSWD_DEFAULT_OPTIONS="${MKPASSWD_DEFAULT_OPTIONS:-A-Za-z0-9_@+-}"

# Notification settings
MKPASSWD_GOOD_MESSAGE="${MKPASSWD_GOOD_MESSAGE:-Everything Went OK}"
MKPASSWD_ERROR_MESSAGE="${MKPASSWD_ERROR_MESSAGE:-Well that didn\'t work}"
MKPASSWD_NOTIFY_ENABLED="${MKPASSWD_NOTIFY_ENABLED:-yes}"
MKPASSWD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MKPASSWD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MKPASSWD_NOTIFY_CLIENT_ICON}"

# Colorization settings
MKPASSWD_OUTPUT_COLOR="${MKPASSWD_OUTPUT_COLOR:-5}"
MKPASSWD_OUTPUT_COLOR_GOOD="${MKPASSWD_OUTPUT_COLOR_GOOD:-2}"
MKPASSWD_OUTPUT_COLOR_ERROR="${MKPASSWD_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MKPASSWD_CONFIG_DIR/$MKPASSWD_CONFIG_FILE" ]; then
    printf_green "Your config file for mkpasswd has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
if [[ -f "$(builtin type -P xclip)" ]]; then
  __clipboard() { xclip -selection __clipboard; }
elif [[ -f "$(builtin type -P xsel 2>/dev/null)" ]]; then
  __clipboard() { xsel -ib; }
elif [[ -f "$(builtin type -P aa clip.exe 2>/dev/null)" ]]; then
  __clipboard() { clip.exe; }
elif [[ -f "$(builtin type -P pbcopy 2>/dev/null)" ]]; then
  __clipboard() { pbcopy; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MKPASSWD_LOG_DIR="${MKPASSWD_LOG_DIR:-$HOME/.local/log/mkpasswd}"
MKPASSWD_CACHE_DIR="${MKPASSWD_CACHE_DIR:-$HOME/.cache/mkpasswd}"
MKPASSWD_CONFIG_DIR="${MKPASSWD_CONFIG_DIR:-$HOME/.config/myscripts/mkpasswd}"
MKPASSWD_CONFIG_BACKUP_DIR="${MKPASSWD_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/mkpasswd/backups}"
MKPASSWD_TEMP_DIR="${MKPASSWD_TEMP_DIR:-$HOME/.local/tmp/system_scripts/mkpasswd}"
MKPASSWD_OPTIONS_DIR="${MKPASSWD_OPTIONS_DIR:-$HOME/.local/share/myscripts/mkpasswd/options}"
MKPASSWD_TEMP_FILE="${MKPASSWD_TEMP_FILE:-$(mktemp $MKPASSWD_TEMP_DIR/XXXXXX 2>/dev/null)}"
MKPASSWD_CONFIG_FILE="${MKPASSWD_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MKPASSWD_OUTPUT_COLOR="${MKPASSWD_OUTPUT_COLOR:-4}"
MKPASSWD_OUTPUT_COLOR_2="${MKPASSWD_OUTPUT_COLOR:-6}"
MKPASSWD_OUTPUT_COLOR_GOOD="${MKPASSWD_OUTPUT_COLOR_GOOD:-2}"
MKPASSWD_OUTPUT_COLOR_ERROR="${MKPASSWD_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MKPASSWD_GOOD_MESSAGE="${MKPASSWD_GOOD_MESSAGE:-Everything Went OK}"
MKPASSWD_ERROR_MESSAGE="${MKPASSWD_ERROR_MESSAGE:-Well that didn\'t work}"
MKPASSWD_NOTIFY_ENABLED="${MKPASSWD_NOTIFY_ENABLED:-yes}"
MKPASSWD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MKPASSWD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MKPASSWD_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
MKPASSWD_DEFAULT_LENGTH="${MKPASSWD_DEFAULT_LENGTH:-20}"
MKPASSWD_DEFAULT_OPTIONS="${MKPASSWD_DEFAULT_OPTIONS:-A-Za-z0-9_@+-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MKPASSWD_CONFIG_DIR/$MKPASSWD_CONFIG_FILE" ] && . "$MKPASSWD_CONFIG_DIR/$MKPASSWD_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MKPASSWD_LOG_DIR" ] || mkdir -p "$MKPASSWD_LOG_DIR" &>/dev/null
[ -d "$MKPASSWD_TEMP_DIR" ] || mkdir -p "$MKPASSWD_TEMP_DIR" &>/dev/null
[ -d "$MKPASSWD_CACHE_DIR" ] || mkdir -p "$MKPASSWD_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MKPASSWD_CONFIG_DIR/$MKPASSWD_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,no-numbers,no-chars,no-upper,length:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MKPASSWD_CWD="$2"
    shift 2
    ;;
  --no-numbers)
    shift 1
    TROPT="$(echo "$MKPASSWD_DEFAULT_OPTIONS" | sed 's|0-9||g')"
    ;;
  --no-chars)
    shift 1
    TROPT="$(TROPT="$(echo "$MKPASSWD_DEFAULT_OPTIONS" | sed 's|_@+-||g')")"
    ;;
  --no-upper)
    shift 1
    TROPT="$(TROPT="$(echo "$MKPASSWD_DEFAULT_OPTIONS" | sed 's|A-Z||g')")"
    ;;
  --length)
    MKPASSWD_DEFAULT_LENGTH="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MKPASSWD_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MKPASSWD_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MKPASSWD_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MKPASSWD_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MKPASSWD_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
TROPT="${TROPT:-$MKPASSWD_DEFAULT_OPTIONS}"
pass="$(cat /dev/urandom | tr -dc $TROPT | tr -d '[:space:]\042\047\134' | fold -w ${1:-$MKPASSWD_DEFAULT_LENGTH} | head -n 1)"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
printf_blue "Your password has been created and copied to your clipboard"
printf_green "$pass"
echo $pass | __clipboard
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
