#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$MULTI_CLIPBOARD_TEMP_FILE" ] && rm -Rf "$MULTI_CLIPBOARD_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : multi_clipboard --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : multi_clipboard
# @Description   : Utility to keep multiple clipboards
# @TODO          :
# @Other         :
# @Resource      : https://github.com/rcmdnk/multi_clipboard
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$MULTI_CLIPBOARD_CONFIG_DIR/$MULTI_CLIPBOARD_CONFIG_FILE"
  [ -d "$MULTI_CLIPBOARD_CONFIG_DIR" ] || mkdir -p "$MULTI_CLIPBOARD_CONFIG_DIR"
  [ -d "$MULTI_CLIPBOARD_CONFIG_BACKUP_DIR" ] || mkdir -p "$MULTI_CLIPBOARD_CONFIG_BACKUP_DIR"
  [ -f "$MULTI_CLIPBOARD_CONFIG_DIR/$MULTI_CLIPBOARD_CONFIG_FILE" ] &&
    cp -Rf "$MULTI_CLIPBOARD_CONFIG_DIR/$MULTI_CLIPBOARD_CONFIG_FILE" "$MULTI_CLIPBOARD_CONFIG_BACKUP_DIR/$MULTI_CLIPBOARD_CONFIG_FILE.$$"
  cat <<EOF >"$MULTI_CLIPBOARD_CONFIG_DIR/$MULTI_CLIPBOARD_CONFIG_FILE"
# Settings for multi_clipboard

# Notification settings
MULTI_CLIPBOARD_GOOD_MESSAGE="${MULTI_CLIPBOARD_GOOD_MESSAGE:-Everything Went OK}"
MULTI_CLIPBOARD_ERROR_MESSAGE="${MULTI_CLIPBOARD_ERROR_MESSAGE:-Well that didn\'t work}"
MULTI_CLIPBOARD_NOTIFY_ENABLED="${MULTI_CLIPBOARD_NOTIFY_ENABLED:-yes}"
MULTI_CLIPBOARD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MULTI_CLIPBOARD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MULTI_CLIPBOARD_NOTIFY_CLIENT_ICON}"

# Colorization settings
MULTI_CLIPBOARD_OUTPUT_COLOR="${MULTI_CLIPBOARD_OUTPUT_COLOR:-5}"
MULTI_CLIPBOARD_OUTPUT_COLOR_GOOD="${MULTI_CLIPBOARD_OUTPUT_COLOR_GOOD:-2}"
MULTI_CLIPBOARD_OUTPUT_COLOR_ERROR="${MULTI_CLIPBOARD_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MULTI_CLIPBOARD_CONFIG_DIR/$MULTI_CLIPBOARD_CONFIG_FILE" ]; then
    printf_green "Your config file for multi_clipboard has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
MULTI_CLIPBOARD_CACHE_DIR="${MULTI_CLIPBOARD_CACHE_DIR:-$HOME/.cache/multi_clipboard}"
MULTI_CLIPBOARD_CONFIG_DIR="${MULTI_CLIPBOARD_CONFIG_DIR:-$HOME/.config/myscripts/multi_clipboard}"
MULTI_CLIPBOARD_OPTIONS_DIR="${MULTI_CLIPBOARD_OPTIONS_DIR:-$HOME/.local/share/myscripts/multi_clipboard/options}"
MULTI_CLIPBOARD_CONFIG_BACKUP_DIR="${MULTI_CLIPBOARD_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/multi_clipboard/backups}"
MULTI_CLIPBOARD_TEMP_DIR="${MULTI_CLIPBOARD_TEMP_DIR:-$HOME/.local/tmp/system_scripts/multi_clipboard}"
MULTI_CLIPBOARD_TEMP_FILE="${MULTI_CLIPBOARD_TEMP_FILE:-$(mktemp $MULTI_CLIPBOARD_TEMP_DIR/XXXXXX 2>/dev/null)}"
MULTI_CLIPBOARD_CONFIG_FILE="${MULTI_CLIPBOARD_CONFIG_FILE:-settings.conf}"
MULTI_CLIPBOARD_GOOD_MESSAGE="${MULTI_CLIPBOARD_GOOD_MESSAGE:-Everything Went OK}"
MULTI_CLIPBOARD_ERROR_MESSAGE="${MULTI_CLIPBOARD_ERROR_MESSAGE:-Well that didn\'t work}"
MULTI_CLIPBOARD_NOTIFY_ENABLED="${MULTI_CLIPBOARD_NOTIFY_ENABLED:-yes}"
MULTI_CLIPBOARD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MULTI_CLIPBOARD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MULTI_CLIPBOARD_NOTIFY_CLIENT_ICON}"
MULTI_CLIPBOARD_OUTPUT_COLOR="${MULTI_CLIPBOARD_OUTPUT_COLOR:-5}"
MULTI_CLIPBOARD_OUTPUT_COLOR_GOOD="${MULTI_CLIPBOARD_OUTPUT_COLOR_GOOD:-2}"
MULTI_CLIPBOARD_OUTPUT_COLOR_ERROR="${MULTI_CLIPBOARD_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MULTI_CLIPBOARD_TEMP_DIR" ] || mkdir -p "$MULTI_CLIPBOARD_TEMP_DIR" &>/dev/null
[ -d "$MULTI_CLIPBOARD_CACHE_DIR" ] || mkdir -p "$MULTI_CLIPBOARD_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$MULTI_CLIPBOARD_CONFIG_DIR/$MULTI_CLIPBOARD_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MULTI_CLIPBOARD_CONFIG_DIR/$MULTI_CLIPBOARD_CONFIG_FILE" ] &&
  . "$MULTI_CLIPBOARD_CONFIG_DIR/$MULTI_CLIPBOARD_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    MULTI_CLIPBOARD_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MULTI_CLIPBOARD_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MULTI_CLIPBOARD_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MULTI_CLIPBOARD_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MULTI_CLIPBOARD_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MULTI_CLIPBOARD_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
bash "${BASH_SOURCE%/*}/sources/multi_clipboard" "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
