#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : multimedia --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : multimedia
# @Description   : multimedia menu
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# = 0 ]; } && TERMINAL_APP="TRUE" myterminal -e "$APPNAME" "$*" && { exit || exit 1; }
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$MULTIMEDIA_TEMP_FILE" ] && [ -f "$MULTIMEDIA_TEMP_FILE" ] && rm -Rf "$MULTIMEDIA_TEMP_FILE" &>/dev/null' EXIT
shopt -s extglob
trap '' SIGINT
trap '' SIGQUIT
trap '' SIGTSTP

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$MULTIMEDIA_CONFIG_DIR/$MULTIMEDIA_CONFIG_FILE"
  [ -d "$MULTIMEDIA_CONFIG_DIR" ] || mkdir -p "$MULTIMEDIA_CONFIG_DIR"
  [ -d "$MULTIMEDIA_CONFIG_BACKUP_DIR" ] || mkdir -p "$MULTIMEDIA_CONFIG_BACKUP_DIR"
  [ -f "$MULTIMEDIA_CONFIG_DIR/$MULTIMEDIA_CONFIG_FILE" ] &&
    cp -Rf "$MULTIMEDIA_CONFIG_DIR/$MULTIMEDIA_CONFIG_FILE" "$MULTIMEDIA_CONFIG_BACKUP_DIR/$MULTIMEDIA_CONFIG_FILE.$$"
  cat <<EOF >"$MULTIMEDIA_CONFIG_DIR/$MULTIMEDIA_CONFIG_FILE"
# Settings for multimedia
MULTIMEDIA_COUNTDOWN_TIME="${MULTIMEDIA_COUNTDOWN_TIME:-3}"

# Notification settings
MULTIMEDIA_GOOD_MESSAGE="${MULTIMEDIA_GOOD_MESSAGE:-Everything Went OK}"
MULTIMEDIA_ERROR_MESSAGE="${MULTIMEDIA_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MULTIMEDIA_NOTIFY_ENABLED="${MULTIMEDIA_NOTIFY_ENABLED:-yes}"
MULTIMEDIA_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MULTIMEDIA_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MULTIMEDIA_NOTIFY_CLIENT_ICON}"

# Colorization settings
MULTIMEDIA_OUTPUT_COLOR="${MULTIMEDIA_OUTPUT_COLOR:-5}"
MULTIMEDIA_OUTPUT_COLOR_GOOD="${MULTIMEDIA_OUTPUT_COLOR_GOOD:-2}"
MULTIMEDIA_OUTPUT_COLOR_ERROR="${MULTIMEDIA_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MULTIMEDIA_CONFIG_DIR/$MULTIMEDIA_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for multimedia has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MULTIMEDIA_LOG_DIR="${MULTIMEDIA_LOG_DIR:-$HOME/.local/log/multimedia}"
MULTIMEDIA_CACHE_DIR="${MULTIMEDIA_CACHE_DIR:-$HOME/.cache/multimedia}"
MULTIMEDIA_CONFIG_DIR="${MULTIMEDIA_CONFIG_DIR:-$HOME/.config/myscripts/multimedia}"
MULTIMEDIA_CONFIG_BACKUP_DIR="${MULTIMEDIA_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/multimedia/backups}"
MULTIMEDIA_TEMP_DIR="${MULTIMEDIA_TEMP_DIR:-$HOME/.local/tmp/system_scripts/multimedia}"
MULTIMEDIA_OPTIONS_DIR="${MULTIMEDIA_OPTIONS_DIR:-$HOME/.local/share/myscripts/multimedia/options}"
MULTIMEDIA_TEMP_FILE="${MULTIMEDIA_TEMP_FILE:-$(mktemp $MULTIMEDIA_TEMP_DIR/XXXXXX 2>/dev/null)}"
MULTIMEDIA_CONFIG_FILE="${MULTIMEDIA_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MULTIMEDIA_OUTPUT_COLOR="${MULTIMEDIA_OUTPUT_COLOR:-4}"
MULTIMEDIA_OUTPUT_COLOR_2="${MULTIMEDIA_OUTPUT_COLOR:-6}"
MULTIMEDIA_OUTPUT_COLOR_GOOD="${MULTIMEDIA_OUTPUT_COLOR_GOOD:-2}"
MULTIMEDIA_OUTPUT_COLOR_ERROR="${MULTIMEDIA_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MULTIMEDIA_GOOD_MESSAGE="${MULTIMEDIA_GOOD_MESSAGE:-Everything Went OK}"
MULTIMEDIA_ERROR_MESSAGE="${MULTIMEDIA_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MULTIMEDIA_NOTIFY_ENABLED="${MULTIMEDIA_NOTIFY_ENABLED:-yes}"
MULTIMEDIA_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MULTIMEDIA_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MULTIMEDIA_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MULTIMEDIA_CONFIG_DIR/$MULTIMEDIA_CONFIG_FILE" ] && . "$MULTIMEDIA_CONFIG_DIR/$MULTIMEDIA_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MULTIMEDIA_LOG_DIR" ] || mkdir -p "$MULTIMEDIA_LOG_DIR" &>/dev/null
[ -d "$MULTIMEDIA_TEMP_DIR" ] || mkdir -p "$MULTIMEDIA_TEMP_DIR" &>/dev/null
[ -d "$MULTIMEDIA_CACHE_DIR" ] || mkdir -p "$MULTIMEDIA_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MULTIMEDIA_CONFIG_DIR/$MULTIMEDIA_CONFIG_FILE" ] || [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MULTIMEDIA_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MULTIMEDIA_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MULTIMEDIA_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MULTIMEDIA_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MULTIMEDIA_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MULTIMEDIA_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
while :; do
  # show menu
  clear
  shift 1
  printf_newline "\n\n\n\n"
  printf_head "MultiMedia Menu"
  printf_green "1. launch music"
  printf_green "2. launch videos"
  printf_green "3. launch images"
  printf_green "4. launch recording"
  printf_green "y. launch custom application"
  printf_green "z. or escape to Exit"
  printf_green "---------------------------------"
  printf_read_question_nt "6" "Enter your choice [1,2,3,4,y,z] : " "1" "main"
  printf_newline

  # take action
  case "$main" in
  1)
    shift 1
    music
    ;;
  2)
    shift 1
    videos
    ;;
  3)
    shift 1
    images
    ;;
  4)
    shift 1
    recording
    ;;
  y)
    shift 1
    __custom_menus
    ;;
  $'\E' | $'\e' | z)
    clear
    break
    ;;
  *) shift ;;
  esac
  clear
  printf_newline "\n\n"
  printf_counter "$MULTIMEDIA_OUTPUT_COLOR" "$MULTIMEDIA_COUNTDOWN_TIME" "Re-loading menu in"
done
clear

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
