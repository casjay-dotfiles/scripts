# @File          : mybluetooth
# @Description   : Setup bluetooth devices
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$MYBLUETOOTH_CONFIG_DIR/$MYBLUETOOTH_CONFIG_FILE"
  [ -d "$MYBLUETOOTH_CONFIG_DIR" ] || mkdir -p "$MYBLUETOOTH_CONFIG_DIR"
  [ -d "$MYBLUETOOTH_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYBLUETOOTH_CONFIG_BACKUP_DIR"
  [ -f "$MYBLUETOOTH_CONFIG_DIR/$MYBLUETOOTH_CONFIG_FILE" ] &&
    cp -Rf "$MYBLUETOOTH_CONFIG_DIR/$MYBLUETOOTH_CONFIG_FILE" "$MYBLUETOOTH_CONFIG_BACKUP_DIR/$MYBLUETOOTH_CONFIG_FILE.$$"
  cat <<EOF >"$MYBLUETOOTH_CONFIG_DIR/$MYBLUETOOTH_CONFIG_FILE"
# Settings for mybluetooth
MYBLUETOOTH_DEFAULT_DEVICE="${MYBLUETOOTH_DEFAULT_DEVICE:-}"
MYBLUETOOTH_DEFAULT_TIMEOUT="${MYBLUETOOTH_DEFAULT_TIMEOUT:-20}"

# Notification settings
MYBLUETOOTH_GOOD_MESSAGE="${MYBLUETOOTH_GOOD_MESSAGE:-Everything Went OK}"
MYBLUETOOTH_ERROR_MESSAGE="${MYBLUETOOTH_ERROR_MESSAGE:-Well that didn\'t work}"
MYBLUETOOTH_NOTIFY_ENABLED="${MYBLUETOOTH_NOTIFY_ENABLED:-yes}"
MYBLUETOOTH_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYBLUETOOTH_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYBLUETOOTH_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYBLUETOOTH_OUTPUT_COLOR="${MYBLUETOOTH_OUTPUT_COLOR:-5}"
MYBLUETOOTH_OUTPUT_COLOR_GOOD="${MYBLUETOOTH_OUTPUT_COLOR_GOOD:-2}"
MYBLUETOOTH_OUTPUT_COLOR_ERROR="${MYBLUETOOTH_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYBLUETOOTH_CONFIG_DIR/$MYBLUETOOTH_CONFIG_FILE" ]; then
    printf_green "Your config file for mybluetooth has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__ok_msg() { printf_green "$1" && return 0; }
__fail_msg() { printf_exit "1" "1" "$ICON_ERROR $1"; }
__grep_macaddr() { grep -o -E '([[:xdigit:]]{1,2}:){5}[[:xdigit:]]{1,2}' &>/dev/null || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__device_config() {
  local MY_BT_NAME="${1:-default}"
  local MY_BT_DEVICE="${2:-$MY_BT_DEVICE}"
  printf_green "Generating the config file for ${MY_BT_NAME}"
  __mkd "$MYBLUETOOTH_CONFIG_DIR"
  cat <<EOF | tee "$MYBLUETOOTH_CONFIG_DIR/$MY_BT_NAME.conf" &>/dev/null
  # Settings for mybluetooth - ${MY_BT_NAME}
CONFIGNAME="${MY_BT_NAME}"
MY_BT_DEVICE="${MY_BT_DEVICE}"

EOF

  if [ -f "$MYBLUETOOTH_CONFIG_DIR/$MY_BT_NAME.conf" ]; then
    printf_green "File has been saved to"
    printf_green "$MYBLUETOOTH_CONFIG_DIR/$MY_BT_NAME.conf"
    return 0
  else
    printf_error "Failed to generate the file"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__device() {
  local MY_BT_NAME="${1:-default}"
  local MY_BT_DEVICE="${2:-$MY_BT_DEVICE}"
  echo "$MY_BT_NAME" | __grep_macaddr && MY_BT_NAME="default"
  if echo "$MY_BT_DEVICE" | __grep_macaddr 2>/dev/null; then
    if [[ $# -lt 2 ]]; then
      local MY_BT_NAME="default"
      local MY_BT_DEVICE="${MY_BT_DEVICE}"
    elif [[ $# = 2 ]]; then
      local MY_BT_NAME="$1"
      local MY_BT_DEVICE="${2:-$MY_BT_DEVICE}"
    else
      printf_cyan "Usage: mybluetooth config Name MAC"
      return 1
    fi
    __device_config "$MY_BT_NAME" "$MY_BT_DEVICE"
  fi
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
MYBLUETOOTH_CACHE_DIR="${MYBLUETOOTH_CACHE_DIR:-$HOME/.cache/mybluetooth}"
MYBLUETOOTH_CONFIG_DIR="${MYBLUETOOTH_CONFIG_DIR:-$HOME/.config/myscripts/mybluetooth}"
MYBLUETOOTH_OPTIONS_DIR="${MYBLUETOOTH_OPTIONS_DIR:-$HOME/.local/share/myscripts/mybluetooth/options}"
MYBLUETOOTH_CONFIG_BACKUP_DIR="${MYBLUETOOTH_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/mybluetooth/backups}"
MYBLUETOOTH_TEMP_DIR="${MYBLUETOOTH_TEMP_DIR:-$HOME/.local/tmp/system_scripts/mybluetooth}"
MYBLUETOOTH_TEMP_FILE="${MYBLUETOOTH_TEMP_FILE:-$(mktemp $MYBLUETOOTH_TEMP_DIR/XXXXXX 2>/dev/null)}"
MYBLUETOOTH_CONFIG_FILE="${MYBLUETOOTH_CONFIG_FILE:-settings.conf}"
MYBLUETOOTH_GOOD_MESSAGE="${MYBLUETOOTH_GOOD_MESSAGE:-Everything Went OK}"
MYBLUETOOTH_ERROR_MESSAGE="${MYBLUETOOTH_ERROR_MESSAGE:-Well that didn\'t work}"
MYBLUETOOTH_NOTIFY_ENABLED="${MYBLUETOOTH_NOTIFY_ENABLED:-yes}"
MYBLUETOOTH_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYBLUETOOTH_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYBLUETOOTH_NOTIFY_CLIENT_ICON}"
MYBLUETOOTH_OUTPUT_COLOR="${MYBLUETOOTH_OUTPUT_COLOR:-5}"
MYBLUETOOTH_OUTPUT_COLOR_GOOD="${MYBLUETOOTH_OUTPUT_COLOR_GOOD:-2}"
MYBLUETOOTH_OUTPUT_COLOR_ERROR="${MYBLUETOOTH_OUTPUT_COLOR_ERROR:-1}"
MYBLUETOOTH_DEFAULT_TIMEOUT="${MYBLUETOOTH_DEFAULT_TIMEOUT:-20}"
MYBLUETOOTH_DEFAULT_DEVICE="${MYBLUETOOTH_DEFAULT_DEVICE:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MYBLUETOOTH_TEMP_DIR" ] || mkdir -p "$MYBLUETOOTH_TEMP_DIR" &>/dev/null
[ -d "$MYBLUETOOTH_CACHE_DIR" ] || mkdir -p "$MYBLUETOOTH_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$MYBLUETOOTH_CONFIG_DIR/$MYBLUETOOTH_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYBLUETOOTH_CONFIG_DIR/$MYBLUETOOTH_CONFIG_FILE" ] &&
  . "$MYBLUETOOTH_CONFIG_DIR/$MYBLUETOOTH_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY="search status remove add discover off on config"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    MYBLUETOOTH_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MYBLUETOOTH_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYBLUETOOTH_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYBLUETOOTH_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYBLUETOOTH_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYBLUETOOTH_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash bluetoothctl || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
lsusb | grep -qi 'Bluetooth Adapter' &>/dev/null || lspci | grep -qi 'Bluetooth Adapter' &>/dev/null || printf_exit "No bluetooth devices detected"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
MYTERMINAL_NOTIFICATIONS="no"
if [ -f "$MYBLUETOOTH_CONFIG_DIR/${2:-$1}.conf" ]; then
  . "$MYBLUETOOTH_CONFIG_DIR/${2:-$1}.conf"
fi
if [ -f "$MYBLUETOOTH_CONFIG_DIR/default.conf" ]; then
  . "$MYBLUETOOTH_CONFIG_DIR/default.conf"
fi
DEFAULT_DEVICE="${MY_BT_DEVICE:-$MYBLUETOOTH_DEFAULT_DEVICE}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
config)
  shift 1
  [[ "$1" = "help" ]] && printf_exit 3 0 "Usage: mybluetooth config name device | IE: mybluetooth config speaker ADDRESS"
  MY_BT_DEVICE="${2:-$DEFAULT_DEVICE}"
  __device "$1" "$MY_BT_DEVICE"
  exit $?
  ;;

on | connect)
  shift 1
  MY_BT_DEVICE="${1:-$DEFAULT_DEVICE}"
  printf_cyan "Attempting to connect to $MY_BT_DEVICE"
  bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT connect "$MY_BT_DEVICE" | grep -iq "Connection successful" >/dev/null 2>&1 &&
    __ok_msg "Connected" || __fail_msg "Connection failed"
  exit $?
  ;;

off | disconnect)
  shift 1
  MY_BT_DEVICE="${1:-$DEFAULT_DEVICE}"
  printf_cyan "Attempting to disconnect from $MY_BT_DEVICE"
  bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT disconnect "$MY_BT_DEVICE" | grep -iq "Successful disconnected" >/dev/null 2>&1 &&
    __ok_msg "Disconnected" || __fail_msg "Disconnection failed"
  exit $?
  ;;

discover)
  shift 1
  case $1 in
  on)
    shift 1
    MY_BT_DEVICE="${1:-$DEFAULT_DEVICE}"
    printf_cyan "Turning on discover mode"
    bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT discoverable on | grep -iq "on succeeded" >/dev/null 2>&1 &&
      __ok_msg "Device is now in discoverable mode" || __fail_msg "Failed to initiate discovery mode"
    exit $?
    ;;

  off)
    shift 1
    MY_BT_DEVICE="${1:-$DEFAULT_DEVICE}"
    printf_cyan "Turning off discover mode"
    bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT discoverable off | grep -iq "off succeeded" >/dev/null 2>&1 &&
      __ok_msg "Device has ended discoverable mode" || __fail_msg "Failed to exit discovery mode"
    exit $?
    ;;
  esac
  ;;

add | pair)
  shift 1
  MY_BT_DEVICE="${1:-$DEFAULT_DEVICE}"
  printf_yellow "Scanning for and adding device $MY_BT_DEVICE"
  bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT scan on &>/dev/null
  bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT pair "$MY_BT_DEVICE" &>/dev/null &&
    bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT trust "$MY_BT_DEVICE" &>/dev/null &&
    printf_green "$MY_BT_DEVICE has been added" ||
    printf_exit 1 1 "Failed to pair to $MY_BT_DEVICE"
  exit $?
  ;;

remove | unpair)
  shift 1
  MY_BT_DEVICE="${1:-$DEFAULT_DEVICE}"
  printf_cyan "Removing $MY_BT_DEVICE"
  bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT remove "$MY_BT_DEVICE" | grep -q 'been removed' &&
    printf_green "$MY_BT_DEVICE has been removed"
  exit $?
  ;;

status)
  shift 1
  MY_BT_DEVICE="${1:-$DEFAULT_DEVICE}"
  printf_green "Bluetooth status"
  bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT info "$MY_BT_DEVICE" | printf_readline "4"
  exit $?
  ;;

search)
  shift 1
  MY_BT_DEVICE="${1:-$DEFAULT_DEVICE}"
  printf_green "Press control-C to cancel search"
  if [ ${#} -eq 0 ]; then
    printf_green "Searching please wait....."
    bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT scan on | grep -v 'Discovery started' | printf_readline $MYBLUETOOTH_OUTPUT_COLOR
  elif [ ${#} -ne 0 ]; then
    printf_green "Searching for $*"
    bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT scan on | grep -v 'Discovery started' | grep -i "$*" | printf_readline $MYBLUETOOTH_OUTPUT_COLOR
  fi
  bluetoothctl --timeout $MYBLUETOOTH_DEFAULT_TIMEOUT scan off &>/dev/null
  exit $?
  ;;

*)
  shift
  MY_BT_DEVICE="${MY_BT_DEVICE:-$DEFAULT_DEVICE}"
  printf_cyan "Getting bluetooth info. This may take some time"
  LIST="$(bluetoothctl --timeout 2 list 2>/dev/null)"
  INFO="$(bluetoothctl --timeout 2 info "$MY_BT_DEVICE" 2>/dev/null)"
  PAIRED="$(bluetoothctl --timeout 10 paired-devices 2>/dev/null)"
  printf_green "Available controller[s]"
  echo "$LIST" | printf_readline "4"
  printf_green "Bluetooth status"
  echo "$INFO" | printf_readline "4"
  printf_green "Paired devices"
  echo "$PAIRED" | printf_readline "4"
  exit $?
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
