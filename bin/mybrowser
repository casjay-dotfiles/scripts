#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$MYBROWSER_TEMP_FILE" ] && rm -Rf "$MYBROWSER_TEMP_FILE" &>/dev/null' EXIT
[ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# = 0 ]; } && { TERMINAL_APP="TRUE" myterminal -e "$APPNAME" "$*" && true || exit 1; }

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : mybrowser --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : mybrowser
# @Description   : Open up the web browser
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  local BROWSER="${BROWSER// /}"
  local MYBROWSER="${MYBROWSER// /}"
  printf_green "Generating the config file in"
  printf_green "$MYBROWSER_CONFIG_DIR/$MYBROWSER_CONFIG_FILE"
  [ -d "$MYBROWSER_CONFIG_DIR" ] || mkdir -p "$MYBROWSER_CONFIG_DIR"
  [ -d "$MYBROWSER_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYBROWSER_CONFIG_BACKUP_DIR"
  [ -f "$MYBROWSER_CONFIG_DIR/$MYBROWSER_CONFIG_FILE" ] &&
    cp -Rf "$MYBROWSER_CONFIG_DIR/$MYBROWSER_CONFIG_FILE" "$MYBROWSER_CONFIG_BACKUP_DIR/$MYBROWSER_CONFIG_FILE.$$"
  cat <<EOF >"$MYBROWSER_CONFIG_DIR/$MYBROWSER_CONFIG_FILE"
# Settings for mybrowser
MYBROWSER_NAME="${MYBROWSER_NAME:-config}"
MYBROWSER="${MYBROWSER:-$BROWSER}"
MYBROWSER_OPTIONS="${MYBROWSER_OPTIONS:-}"
MYBROWSER_STARTPAGE="${MYBROWSER_STARTPAGE:-}"
MYBROWSER_CONSOLE="${MYBROWSER_CONSOLE:-}"

# Notification settings
MYBROWSER_GOOD_MESSAGE="${MYBROWSER_GOOD_MESSAGE:-Everything Went OK}"
MYBROWSER_ERROR_MESSAGE="${MYBROWSER_ERROR_MESSAGE:-Well that didn\'t work}"
MYBROWSER_NOTIFY_ENABLED="${MYBROWSER_NOTIFY_ENABLED:-yes}"
MYBROWSER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYBROWSER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYBROWSER_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYBROWSER_OUTPUT_COLOR="${MYBROWSER_OUTPUT_COLOR:-5}"
MYBROWSER_OUTPUT_COLOR_GOOD="${MYBROWSER_OUTPUT_COLOR_GOOD:-2}"
MYBROWSER_OUTPUT_COLOR_ERROR="${MYBROWSER_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYBROWSER_CONFIG_DIR/$MYBROWSER_CONFIG_FILE" ]; then
    printf_green "Your config file for mybrowser has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__create_term() {
  cat <<EOF | tee
  #!/usr/bin/env sh
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202104040050-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : mybrowser --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Sunday, Apr 04, 2021 00:50 EDT
# @File          : mybrowser
# @Description   : Setup $MYBROWSER
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ ! -t 0 ]; then
  myterminal -e "$MYBROWSER \$MYBROWSER_OPTIONS \$*"
else
  $MYBROWSER \$MYBROWSER_OPTIONS \$*
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}

EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__create_link() {
  if [ -n "$2" ]; then
    shift 1
    if cmd_exists "$1"; then
      if [ "$MYBROWSER_CONSOLE" = "yes" ]; then
        printf_green "Generating the script for $MYBROWSER"
        __create_term >"$HOME/.local/bin/mybrowser"
      fi
      printf_green "Linking $HOME/.local/bin/mybrowser to $1"
      __ln_sf "$(builtin type -P $1)" "$HOME/.local/bin/mybrowser"
    else
      printf_green "Linking $HOME/.local/bin/mybrowser to $MYBROWSER"
      __ln_sf "$MYBROWSER" "$HOME/.local/bin/mybrowser"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__term() {
  if [ $# = 0 ]; then
    $MYBROWSER --help | less
  else
    $MYBROWSER "$*"
  fi
  while :; do
    printf_newline
    printf_read_input "2" "What command would you like to execute [q to exit]" "20" "CMD"
    if { [[ "$CMD" = '-q' ]] || [[ "$CMD" = 'q' ]] || [[ "$CMD" = 'quit' ]] || [[ "$CMD" = 'exit' ]]; }; then exit; fi
    $MYBROWSER $CMD
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
MYBROWSER_CACHE_DIR="${MYBROWSER_CACHE_DIR:-$HOME/.cache/mybrowser}"
MYBROWSER_CONFIG_DIR="${MYBROWSER_CONFIG_DIR:-$HOME/.config/myscripts/mybrowser}"
MYBROWSER_OPTIONS_DIR="${MYBROWSER_OPTIONS_DIR:-$HOME/.local/share/myscripts/mybrowser/options}"
MYBROWSER_CONFIG_BACKUP_DIR="${MYBROWSER_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/mybrowser/backups}"
MYBROWSER_TEMP_DIR="${MYBROWSER_TEMP_DIR:-$HOME/.local/tmp/system_scripts/mybrowser}"
MYBROWSER_TEMP_FILE="${MYBROWSER_TEMP_FILE:-$(mktemp $MYBROWSER_TEMP_DIR/XXXXXX 2>/dev/null)}"
MYBROWSER_CONFIG_FILE="${MYBROWSER_CONFIG_FILE:-settings.conf}"
MYBROWSER_GOOD_MESSAGE="${MYBROWSER_GOOD_MESSAGE:-Everything Went OK}"
MYBROWSER_ERROR_MESSAGE="${MYBROWSER_ERROR_MESSAGE:-Well that didn\'t work}"
MYBROWSER_NOTIFY_ENABLED="${MYBROWSER_NOTIFY_ENABLED:-yes}"
MYBROWSER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYBROWSER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYBROWSER_NOTIFY_CLIENT_ICON}"
MYBROWSER_OUTPUT_COLOR="${MYBROWSER_OUTPUT_COLOR:-5}"
MYBROWSER_OUTPUT_COLOR_GOOD="${MYBROWSER_OUTPUT_COLOR_GOOD:-2}"
MYBROWSER_OUTPUT_COLOR_ERROR="${MYBROWSER_OUTPUT_COLOR_ERROR:-1}"
MYBROWSER="${MYBROWSER:-$BROWSER}"
MYBROWSER_OPTIONS="${MYBROWSER_OPTIONS:-}"
MYBROWSER_STARTPAGE="${MYBROWSER_STARTPAGE:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MYBROWSER_TEMP_DIR" ] || mkdir -p "$MYBROWSER_TEMP_DIR" &>/dev/null
[ -d "$MYBROWSER_CACHE_DIR" ] || mkdir -p "$MYBROWSER_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$MYBROWSER_CONFIG_DIR/$MYBROWSER_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYBROWSER_CONFIG_DIR/$MYBROWSER_CONFIG_FILE" ] &&
  . "$MYBROWSER_CONFIG_DIR/$MYBROWSER_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
if [ -z "$(builtin type -P "$MYBROWSER")" ] || [ "$MYBROWSER" = "mybrowser" ]; then unset MYBROWSER; fi
if [ "$MYBROWSER_NAME" = "config" ] || [ "$MYBROWSER_NAME" = "" ]; then
  if [ -n "$(builtin type -P garcon-url-handler 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P garcon-url-handler 2>/dev/null) --url"
  elif [ -n "$(builtin type -P firefox 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P firefox 2>/dev/null)"
  elif [ -n "$(builtin type -P chromium 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P chromium 2>/dev/null)"
  elif [ -n "$(builtin type -P google-chrome 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P google-chrome 2>/dev/null)"
  elif [ -n "$(builtin type -P opera 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P opera 2>/dev/null)"
  elif [ -n "$(builtin type -P epiphany-browser 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P epiphany-browser 2>/dev/null)"
  elif [ -n "$(builtin type -P falkon 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P falkon 2>/dev/null)"
  elif [ -n "$(builtin type -P midori 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P midori 2>/dev/null)"
  elif [ -n "$(builtin type -P netsurf 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P netsurf 2>/dev/null)"
  elif [ -n "$(builtin type -P surf 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P surf 2>/dev/null)"
  elif [ -n "$(builtin type -P arora 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P arora 2>/dev/null)"
  elif [ -f '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' ]; then
    MYBROWSER='/Applications/Google Chrome.app/Contents/MacOS/Google Chrome'
  elif [ -f '/Applications/Firefox.app/Contents/MacOS/firefox-bin' ]; then
    MYBROWSER='/Applications/Firefox.app/Contents/MacOS/firefox-bin'
  elif [ -f '/Applications/Opera.app/Contents/MacOS/Opera' ]; then
    MYBROWSER='/Applications/Opera.app/Contents/MacOS/Opera'
  elif [ -f '/Applications/Brave Browser.app/Contents/MacOS/Brave Browser' ]; then
    MYBROWSER='/Applications/Brave Browser.app/Contents/MacOS/Brave Browser'
  elif [ -f '/Applications/Tor Browser.app/Contents/MacOS/firefox' ]; then
    MYBROWSER='/Applications/Tor Browser.app/Contents/MacOS/firefox'
  elif [ -n "$(builtin type -P lynx 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P lynx 2>/dev/null)"
  elif [ -n "$(builtin type -P links 2>/dev/null)" ]; then
    MYBROWSER="$(builtin type -P links 2>/dev/null)"
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
MYBROWSER_NAME="$(basename "$MYBROWSER" 2>/dev/null)"
export BROWSER="$MYBROWSER"
export MYBROWSER="$BROWSER"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
case $MYBROWSER_NAME in
links | lynx)
  export TERMINAL_APP="TRUE"
  export MYBROWSER_CONSOLE="yes"
  ;;
firefox | chromium | google-chrome* | opera | brave)
  OPEN="${OPEN:-About:Blank}"
  ;;
esac
{ [ "$MYBROWSER_NAME" = "config" ] || [ "$MYBROWSER_NAME" = "" ]; } && __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:,term,link:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    MYBROWSER_CWD="$2"
    shift 2
    ;;
  --link)
    shift 1
    __create_link "${1:-$MYBROWSER}"
    shift 1
    exit $?
    ;;
  --term)
    shift 1
    __term "$*"
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MYBROWSER_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYBROWSER_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYBROWSER_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYBROWSER_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYBROWSER_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -z "$MYBROWSER" ]; then
  printf_newline "\n"
  __notifications "No browsers are installed"
  printf_red "No browsers are installed"
  printf_pause 1 "Press any key to exit this window"
  exit
fi
if [ -f "$MYBROWSER_STARTPAGE" ]; then STARTPAGE="${MYBROWSER_STARTPAGE}"; fi
STARTPAGE="${OPEN:-$MYBROWSER_STARTPAGE}"
OPEN="$MYBROWSER_OPTIONS ${*:-$STARTPAGE}"
[ -n "$OPEN" ] || OPEN=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__notifications "Attempting to launch $MYBROWSER_NAME"
if [ -f "$HOME/.local/bin/mybrowser" ]; then
  "$HOME/.local/bin/mybrowser" "$ARGS"
elif [ "$MYBROWSER_CONSOLE" = "yes" ]; then
  eval $MYBROWSER $OPEN
else
  __exec $MYBROWSER $OPEN
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
