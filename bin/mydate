#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : mydate --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : mydate
# @Description   : Show date
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$MYDATE_CONFIG_DIR/$MYDATE_CONFIG_FILE"
  [ -d "$MYDATE_CONFIG_DIR" ] || mkdir -p "$MYDATE_CONFIG_DIR"
  [ -d "$MYDATE_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYDATE_CONFIG_BACKUP_DIR"
  [ -f "$MYDATE_CONFIG_DIR/$MYDATE_CONFIG_FILE" ] &&
    cp -Rf "$MYDATE_CONFIG_DIR/$MYDATE_CONFIG_FILE" "$MYDATE_CONFIG_BACKUP_DIR/$MYDATE_CONFIG_FILE.$$"
  cat <<EOF >"$MYDATE_CONFIG_DIR/$MYDATE_CONFIG_FILE"
# Settings for mydate
MYDATE_NOW_FORMAT="${MYDATE_NOW_FORMAT:-%T}"
MYDATE_TIME_FORMAT="${MYDATE_TIME_FORMAT:-%m-%d-%Y}"
MYDATE_VERSION_FORMAT="${MYDATE_VERSION_FORMAT:-%Y%m%d%H%M-git}"

# Notification settings
MYDATE_GOOD_MESSAGE="${MYDATE_GOOD_MESSAGE:-Everything Went OK}"
MYDATE_ERROR_MESSAGE="${MYDATE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYDATE_NOTIFY_ENABLED="${MYDATE_NOTIFY_ENABLED:-yes}"
MYDATE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYDATE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYDATE_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYDATE_OUTPUT_COLOR="${MYDATE_OUTPUT_COLOR:-5}"
MYDATE_OUTPUT_COLOR_GOOD="${MYDATE_OUTPUT_COLOR_GOOD:-2}"
MYDATE_OUTPUT_COLOR_ERROR="${MYDATE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYDATE_CONFIG_DIR/$MYDATE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    # if [[ "$INIT_CONFIG" = "TRUE" ]]; then
    #   unset INIT_CONFIG
    #   eval bash -c "$APPNAME $*"
    #   exit
    # fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MYDATE_LOG_DIR="${MYDATE_LOG_DIR:-$HOME/.local/log/mydate}"
MYDATE_CACHE_DIR="${MYDATE_CACHE_DIR:-$HOME/.cache/mydate}"
MYDATE_CONFIG_DIR="${MYDATE_CONFIG_DIR:-$HOME/.config/myscripts/mydate}"
MYDATE_CONFIG_BACKUP_DIR="${MYDATE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/mydate/backups}"
MYDATE_TEMP_DIR="${MYDATE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/mydate}"
MYDATE_OPTIONS_DIR="${MYDATE_OPTIONS_DIR:-$HOME/.local/share/myscripts/mydate/options}"
MYDATE_CONFIG_FILE="${MYDATE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYDATE_OUTPUT_COLOR="${MYDATE_OUTPUT_COLOR:-4}"
MYDATE_OUTPUT_COLOR_2="${MYDATE_OUTPUT_COLOR:-6}"
MYDATE_OUTPUT_COLOR_GOOD="${MYDATE_OUTPUT_COLOR_GOOD:-2}"
MYDATE_OUTPUT_COLOR_ERROR="${MYDATE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYDATE_GOOD_MESSAGE="${MYDATE_GOOD_MESSAGE:-Everything Went OK}"
MYDATE_ERROR_MESSAGE="${MYDATE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYDATE_NOTIFY_ENABLED="${MYDATE_NOTIFY_ENABLED:-yes}"
MYDATE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYDATE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYDATE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
MYDATE_NOW_FORMAT="${MYDATE_NOW_FORMAT:-%T}"
MYDATE_TIME_FORMAT="${MYDATE_TIME_FORMAT:-%m-%d-%Y}"
MYDATE_VERSION_FORMAT="${MYDATE_VERSION_FORMAT:-$VERSION_DATE_FORMAT}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MYDATE_CONFIG_DIR/$MYDATE_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYDATE_CONFIG_DIR/$MYDATE_CONFIG_FILE" ] && . "$MYDATE_CONFIG_DIR/$MYDATE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$MYDATE_LOG_DIR" ] || mkdir -p "$MYDATE_LOG_DIR" &>/dev/null
[ -d "$MYDATE_TEMP_DIR" ] || mkdir -p "$MYDATE_TEMP_DIR" &>/dev/null
[ -d "$MYDATE_CACHE_DIR" ] || mkdir -p "$MYDATE_CACHE_DIR" &>/dev/null
MYDATE_TEMP_FILE="${MYDATE_TEMP_FILE:-$(mktemp $MYDATE_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$MYDATE_TEMP_FILE" ] && [ -f "$MYDATE_TEMP_FILE" ] && rm -Rf "$MYDATE_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$MYDATE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYDATE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYDATE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYDATE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYDATE_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MYDATE_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
nowtime)
  shift 1
  printf_green "$(date +"$MYDATE_NOW_FORMAT")"
  ;;

nowdate)
  shift 1
  printf_green "$(date +"$MYDATE_TIME_FORMAT")"
  ;;

setver)
  shift 1
  printf_green "$(date +"$MYDATE_VERSION_FORMAT")"
  ;;

setverfile)
  shift 1
  printf_green "$(date +"$MYDATE_VERSION_FORMAT")"
  date +"$MYDATE_VERSION_FORMAT" >version.txt
  ;;

custom)
  shift 1
  printf_green "$(date +"$*")"
  ;;
*)
  set --
  printf_green "Time is:  $(date +"$MYDATE_NOW_FORMAT")"
  printf_green "Date is:  $(date +"$MYDATE_TIME_FORMAT")"
  printf_green "Version:  $(date +"$MYDATE_VERSION_FORMAT")"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
