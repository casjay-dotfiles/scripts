# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : myeditor
# @Description   : Open up text editor
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
#if [ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; }; then  TERMINAL_APP="TRUE" myterminal -e "$APPNAME $*" && exit || exit 1; fi
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  local EDITOR="${EDITOR// /}"
  local MYEDITOR="${MYEDITOR// /}"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$MYEDITOR_CONFIG_DIR/$MYEDITOR_CONFIG_FILE"
  [ -d "$MYEDITOR_CONFIG_DIR" ] || mkdir -p "$MYEDITOR_CONFIG_DIR"
  [ -d "$MYEDITOR_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYEDITOR_CONFIG_BACKUP_DIR"
  [ -f "$MYEDITOR_CONFIG_DIR/$MYEDITOR_CONFIG_FILE" ] &&
    cp -Rf "$MYEDITOR_CONFIG_DIR/$MYEDITOR_CONFIG_FILE" "$MYEDITOR_CONFIG_BACKUP_DIR/$MYEDITOR_CONFIG_FILE.$$"
  cat <<EOF >"$MYEDITOR_CONFIG_DIR/$MYEDITOR_CONFIG_FILE"
# Settings for myeditor
MYEDITOR_NAME="${MYEDITOR_NAME:-config}"
MYEDITOR="${MYEDITOR:-$EDITOR}"
MYEDITOR_OPTIONS="${MYEDITOR_OPTIONS:-}"
MYEDITOR_CONSOLE="$MYEDITOR_CONSOLE"

# Notification settings
MYEDITOR_GOOD_MESSAGE="${MYEDITOR_GOOD_MESSAGE:-Everything Went OK}"
MYEDITOR_ERROR_MESSAGE="${MYEDITOR_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYEDITOR_NOTIFY_ENABLED="${MYEDITOR_NOTIFY_ENABLED:-yes}"
MYEDITOR_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYEDITOR_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYEDITOR_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYEDITOR_OUTPUT_COLOR="${MYEDITOR_OUTPUT_COLOR:-5}"
MYEDITOR_OUTPUT_COLOR_GOOD="${MYEDITOR_OUTPUT_COLOR_GOOD:-2}"
MYEDITOR_OUTPUT_COLOR_ERROR="${MYEDITOR_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYEDITOR_CONFIG_DIR/$MYEDITOR_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__console_apps() {
  if [ -n "$(builtin type -P vim 2>/dev/null)" ]; then
    MYEDITOR="vim"
  elif [ -n "$(builtin type -P nvim 2>/dev/null)" ]; then
    MYEDITOR="nvim"
  elif [ -n "$(builtin type -P nano 2>/dev/null)" ]; then
    MYEDITOR="nano"
  elif [ -n "$(builtin type -P emacs 2>/dev/null)" ]; then
    MYEDITOR="emacs"
  fi
  [[ -n "$MYEDITOR" ]] || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__term() {
  if [ $# = 0 ]; then
    $MYEDITOR --help | less
  else
    $MYEDITOR "$*"
  fi
  while :; do
    printf_newline
    printf_read_input "2" "What command would you like to execute [q to exit]" "20" "CMD"
    if { [[ "$CMD" = '-q' ]] || [[ "$CMD" = 'q' ]] || [[ "$CMD" = 'quit' ]] || [[ "$CMD" = 'exit' ]]; }; then exit; fi
    $MYEDITOR $CMD
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MYEDITOR_LOG_DIR="${MYEDITOR_LOG_DIR:-$HOME/.local/log/myeditor}"
MYEDITOR_CACHE_DIR="${MYEDITOR_CACHE_DIR:-$HOME/.cache/myeditor}"
MYEDITOR_CONFIG_DIR="${MYEDITOR_CONFIG_DIR:-$HOME/.config/myscripts/myeditor}"
MYEDITOR_CONFIG_BACKUP_DIR="${MYEDITOR_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/myeditor/backups}"
MYEDITOR_TEMP_DIR="${MYEDITOR_TEMP_DIR:-$HOME/.local/tmp/system_scripts/myeditor}"
MYEDITOR_OPTIONS_DIR="${MYEDITOR_OPTIONS_DIR:-$HOME/.local/share/myscripts/myeditor/options}"
MYEDITOR_CONFIG_FILE="${MYEDITOR_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYEDITOR_OUTPUT_COLOR="${MYEDITOR_OUTPUT_COLOR:-4}"
MYEDITOR_OUTPUT_COLOR_2="${MYEDITOR_OUTPUT_COLOR:-6}"
MYEDITOR_OUTPUT_COLOR_GOOD="${MYEDITOR_OUTPUT_COLOR_GOOD:-2}"
MYEDITOR_OUTPUT_COLOR_ERROR="${MYEDITOR_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYEDITOR_GOOD_MESSAGE="${MYEDITOR_GOOD_MESSAGE:-Everything Went OK}"
MYEDITOR_ERROR_MESSAGE="${MYEDITOR_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYEDITOR_NOTIFY_ENABLED="${MYEDITOR_NOTIFY_ENABLED:-yes}"
MYEDITOR_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYEDITOR_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYEDITOR_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
MYEDITOR_CONSOLE="${MYEDITOR_CONSOLE:-}"
MYEDITOR="${MYEDITOR:-$EDITOR}"
MYEDITOR_OPTIONS="${MYEDITOR_OPTIONS:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MYEDITOR_CONFIG_DIR/$MYEDITOR_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYEDITOR_CONFIG_DIR/$MYEDITOR_CONFIG_FILE" ] && . "$MYEDITOR_CONFIG_DIR/$MYEDITOR_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$MYEDITOR_LOG_DIR" ] || mkdir -p "$MYEDITOR_LOG_DIR" &>/dev/null
[ -d "$MYEDITOR_TEMP_DIR" ] || mkdir -p "$MYEDITOR_TEMP_DIR" &>/dev/null
[ -d "$MYEDITOR_CACHE_DIR" ] || mkdir -p "$MYEDITOR_CACHE_DIR" &>/dev/null
MYEDITOR_TEMP_FILE="${MYEDITOR_TEMP_FILE:-$(mktemp $MYEDITOR_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$MYEDITOR_TEMP_FILE" ] && [ -f "$MYEDITOR_TEMP_FILE" ] && rm -Rf "$MYEDITOR_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$MYEDITOR_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYEDITOR_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYEDITOR_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYEDITOR_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYEDITOR_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
if [ "$MYEDITOR_NAME" = "config" ] || [ "$MYEDITOR_NAME" = "" ]; then
  if [ -n "$(builtin type -P code-insiders 2>/dev/null)" ]; then
    MYEDITOR="code-insiders"
  elif [ -n "$(builtin type -P code 2>/dev/null)" ]; then
    MYEDITOR="code"
  elif [ -n "$(builtin type -P code-oss 2>/dev/null)" ]; then
    MYEDITOR="code-oss"
  elif [ -n "$(builtin type -P vscode 2>/dev/null)" ]; then
    MYEDITOR="vscode"
  elif [ -n "$(builtin type -P geany 2>/dev/null)" ]; then
    MYEDITOR="geany"
  elif [ -n "$(builtin type -P gedit 2>/dev/null)" ]; then
    MYEDITOR="gedit"
  elif [ -n "$(builtin type -P atom 2>/dev/null)" ]; then
    MYEDITOR="atom"
  elif [ -n "$(builtin type -P brackets 2>/dev/null)" ]; then
    MYEDITOR="brackets"
  elif [ -n "$(builtin type -P mousepad 2>/dev/null)" ]; then
    MYEDITOR="mousepad"
  fi
  [[ -n "$MYEDITOR" ]] || __console_apps
fi
[[ "$1" = "--console" ]] && shift 1 && __console_apps
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
export MYEDITOR_NAME="$(basename $MYEDITOR 2>/dev/null)"
export EDITOR="$MYEDITOR"
export MYEDITOR="$MYEDITOR"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
case $MYEDITOR_NAME in
nano | vim | emacs | nvim)
  export MYEDITOR_CONSOLE="yes"
  export TERMINAL_APP="TRUE"
  ;;
esac
if grep -s "MYEDITOR_NAME" "$MYEDITOR_CONFIG_DIR/$MYEDITOR_CONFIG_FILE" | grep -q config; then __gen_config &>/dev/null; fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,term:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MYEDITOR_CWD="$2"
    shift 2
    ;;
  --term)
    shift 1
    __term "$1"
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -z "$MYEDITOR" ]; then
  printf_newline "\n"
  __notifications "No editors are installed"
  printf_red "No editors are installed"
  printf_pause 1 "ERROR: Press any key to exit this window"
  exit
fi
ARGS="$*"
OPEN="$MYEDITOR_OPTIONS $ARGS"
[ -n "$OPEN" ] || OPEN=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__notifications "Attempting to launch $MYEDITOR_NAME"
if [ "$MYEDITOR_CONSOLE" = "yes" ]; then
  if [ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; }; then
    TERMINAL_APP="TRUE" myterminal -e "$APPNAME" "$OPEN"
  else
    $MYEDITOR $OPEN
  fi
else
  __exec $MYEDITOR $OPEN
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
