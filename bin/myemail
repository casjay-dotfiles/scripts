#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -euo pipefail
trap 'exitCode=${exitCode:-$?};[ -f "$MYEMAIL_TEMP_FILE" ] && rm -Rf "$MYEMAIL_TEMP_FILE" &>/dev/null' EXIT
#[ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# = 0 ]; } && { TERMINAL_APP="TRUE" myterminal -e "$APPNAME" "$*" && true || exit 1; }

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : myemail --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : myemail
# @Description   : Open e-mail client
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  local EMAIL="${EMAIL// /}"
  local MYEMAIL="${MYEMAIL// /}"
  printf_green "Generating the config file in"
  printf_green "$MYEMAIL_CONFIG_DIR/$MYEMAIL_CONFIG_FILE"
  [ -d "$MYEMAIL_CONFIG_DIR" ] || mkdir -p "$MYEMAIL_CONFIG_DIR"
  [ -d "$MYEMAIL_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYEMAIL_CONFIG_BACKUP_DIR"
  [ -f "$MYEMAIL_CONFIG_DIR/$MYEMAIL_CONFIG_FILE" ] &&
    cp -Rf "$MYEMAIL_CONFIG_DIR/$MYEMAIL_CONFIG_FILE" "$MYEMAIL_CONFIG_BACKUP_DIR/$MYEMAIL_CONFIG_FILE.$$"
  cat <<EOF >"$MYEMAIL_CONFIG_DIR/$MYEMAIL_CONFIG_FILE"
# Settings for myemail
MYEMAIL_NAME="${MYEMAIL_NAME:-config}"
MYEMAIL="${MYEMAIL:-$EMAIL}"
MYEMAIL_OPTIONS="${MYEMAIL_OPTIONS:-}"
MYEMAIL_CONSOLE="${MYEMAIL_CONSOLE:-}"

# Notification settings
MYEMAIL_GOOD_MESSAGE="${MYEMAIL_GOOD_MESSAGE:-Everything Went OK}"
MYEMAIL_ERROR_MESSAGE="${MYEMAIL_ERROR_MESSAGE:-Well that didn\'t work}"
MYEMAIL_NOTIFY_ENABLED="${MYEMAIL_NOTIFY_ENABLED:-yes}"
MYEMAIL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYEMAIL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYEMAIL_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYEMAIL_OUTPUT_COLOR="${MYEMAIL_OUTPUT_COLOR:-5}"
MYEMAIL_OUTPUT_COLOR_GOOD="${MYEMAIL_OUTPUT_COLOR_GOOD:-2}"
MYEMAIL_OUTPUT_COLOR_ERROR="${MYEMAIL_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYEMAIL_CONFIG_DIR/$MYEMAIL_CONFIG_FILE" ]; then
    printf_green "Your config file for myemail has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__create_term() {
  cat <<EOF | tee
  #!/usr/bin/env sh
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202104040050-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : myemail --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Sunday, Apr 04, 2021 00:50 EDT
# @File          : myemail
# @Description   : Setup $MYEMAIL
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ ! -t 0 ]; then
  myterminal -e "$MYEMAIL \$MYEMAIL_OPTIONS \$*"
else
  $MYEMAIL \$MYEMAIL_OPTIONS \$*
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}

EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__create_link() {
  if [ -n "$2" ]; then
    shift 1
    if cmd_exists "$1"; then
      if [ "$MYEMAIL_CONSOLE" = "yes" ]; then
        printf_green "Generating the script for $MYEMAIL"
        __create_term >"$HOME/.local/bin/myemail"
      fi
      printf_green "Linking $HOME/.local/bin/myemail to $1"
      __ln_sf "$(builtin type -P $1)" "$HOME/.local/bin/myemail"
    else
      printf_green "Linking $HOME/.local/bin/myemail to $MYEMAIL"
      __ln_sf "$MYEMAIL" "$HOME/.local/bin/myemail"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__term() {
  if [ $# = 0 ]; then
    $MYEMAIL --help | less
  else
    $MYEMAIL "$*"
  fi
  while :; do
    printf_newline
    printf_read_input "2" "What command would you like to execute [q to exit]" "20" "CMD"
    if { [[ "$CMD" = '-q' ]] || [[ "$CMD" = 'q' ]] || [[ "$CMD" = 'quit' ]] || [[ "$CMD" = 'exit' ]]; }; then exit; fi
    $MYEMAIL $CMD
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
MYEMAIL_CACHE_DIR="${MYEMAIL_CACHE_DIR:-$HOME/.cache/myemail}"
MYEMAIL_CONFIG_DIR="${MYEMAIL_CONFIG_DIR:-$HOME/.config/myscripts/myemail}"
MYEMAIL_OPTIONS_DIR="${MYEMAIL_OPTIONS_DIR:-$HOME/.local/share/myscripts/myemail/options}"
MYEMAIL_CONFIG_BACKUP_DIR="${MYEMAIL_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/myemail/backups}"
MYEMAIL_TEMP_DIR="${MYEMAIL_TEMP_DIR:-$HOME/.local/tmp/system_scripts/myemail}"
MYEMAIL_TEMP_FILE="${MYEMAIL_TEMP_FILE:-$(mktemp $MYEMAIL_TEMP_DIR/XXXXXX 2>/dev/null)}"
MYEMAIL_CONFIG_FILE="${MYEMAIL_CONFIG_FILE:-settings.conf}"
MYEMAIL_GOOD_MESSAGE="${MYEMAIL_GOOD_MESSAGE:-Everything Went OK}"
MYEMAIL_ERROR_MESSAGE="${MYEMAIL_ERROR_MESSAGE:-Well that didn\'t work}"
MYEMAIL_NOTIFY_ENABLED="${MYEMAIL_NOTIFY_ENABLED:-yes}"
MYEMAIL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYEMAIL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYEMAIL_NOTIFY_CLIENT_ICON}"
MYEMAIL_OUTPUT_COLOR="${MYEMAIL_OUTPUT_COLOR:-5}"
MYEMAIL_OUTPUT_COLOR_GOOD="${MYEMAIL_OUTPUT_COLOR_GOOD:-2}"
MYEMAIL_OUTPUT_COLOR_ERROR="${MYEMAIL_OUTPUT_COLOR_ERROR:-1}"
MYEMAIL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYEMAIL_NOTIFY_CLIENT_ICON}"
MYEMAIL="${MYEMAIL:-$EMAIL}"
MYEMAIL_CONSOLE="${MYEMAIL_CONSOLE:-}"
MYEMAIL_OPTIONS="${MYEMAIL_OPTIONS:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MYEMAIL_TEMP_DIR" ] || mkdir -p "$MYEMAIL_TEMP_DIR" &>/dev/null
[ -d "$MYEMAIL_CACHE_DIR" ] || mkdir -p "$MYEMAIL_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$MYEMAIL_CONFIG_DIR/$MYEMAIL_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYEMAIL_CONFIG_DIR/$MYEMAIL_CONFIG_FILE" ] &&
  . "$MYEMAIL_CONFIG_DIR/$MYEMAIL_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
if [ -z "$(builtin type -P "$MYEMAIL")" ] || [ "$MYEMAIL" = "myemail" ]; then unset MYEMAIL; fi
if [ "$MYEMAIL_NAME" = "config" ] || [ "$MYEMAIL_NAME" = "" ]; then
  if [ -n "$(builtin type -P thunderbird 2>/dev/null)" ]; then
    MYEMAIL="thunderbird"
  elif [ -n "$(builtin type -P evolution 2>/dev/null)" ]; then
    MYEMAIL="evolution"
  elif [ -n "$(builtin type -P clawsmail 2>/dev/null)" ]; then
    MYEMAIL="clawsmail"
  elif [ -n "$(builtin type -P geary 2>/dev/null)" ]; then
    MYEMAIL="geary"
  elif [ -n "$(builtin type -P kmail 2>/dev/null)" ]; then
    MYEMAIL="kmail"
  elif [ -n "$(builtin type -P gmail 2>/dev/null)" ]; then
    MYEMAIL="mybrowser https://gmail.com"
  elif [ -n "$(builtin type -P ymail 2>/dev/null)" ]; then
    MYEMAIL="mybrowser https://ymail.com"
  elif [ -n "$(builtin type -P sylpheed 2>/dev/null)" ]; then
    MYEMAIL="sylpheed"
  elif [ -n "$(builtin type -P neomutt 2>/dev/null)" ]; then
    MYEMAIL="neomutt"
  elif [ -n "$(builtin type -P mutt 2>/dev/null)" ]; then
    MYEMAIL="mutt"
  elif [ -n "$(builtin type -P emacs 2>/dev/null)" ]; then
    MYEMAIL="emacs"
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
MYEMAIL_NAME="$(basename $MYEMAIL 2>/dev/null)"
export EMAIL="$MYEMAIL"
export MYEMAIL="$MYEMAIL"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
case $MYEMAIL_NAME in
emacs | mutt | neomutt)
  MYEMAIL_CONSOLE="yes"
  export TERMINAL_APP="TRUE"
  ;;
esac
if grep -s "MYEMAIL_NAME" "$MYEMAIL_CONFIG_DIR/$MYEMAIL_CONFIG_FILE" | grep -q config; then __gen_config &>/dev/null; fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:,term,link:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    MYEMAIL_CWD="$2"
    shift 2
    ;;
  --link)
    shift 1
    __create_link "${1:-$MYEMAIL}"
    shift 1
    exit $?
    ;;
  --term)
    shift 1
    __term "$*"
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MYEMAIL_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYEMAIL_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYEMAIL_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYEMAIL_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYEMAIL_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -z "$MYEMAIL" ]; then
  printf_newline "\n"
  __notifications "No email clients are installed"
  printf_red "No email clients are installed"
  printf_pause 1 "Press any key to exit this window"
  exit
fi
ARGS="$*"
OPEN="$MYEMAIL_OPTIONS $ARGS"
[ -n "$OPEN" ] || OPEN=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__notifications "Attempting to launch $MYEMAIL_NAME"
if [ -f "$HOME/.local/bin/myemail" ]; then
  "$HOME/.local/bin/myemail" "$ARGS"
elif [ "$MYEMAIL_CONSOLE" = "yes" ]; then
  if [ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# = 0 ]; }; then
    TERMINAL_APP="TRUE" myterminal -e "$APPNAME" "$OPEN"
  else
    $MYEMAIL ${OPEN:-}
  fi
else
  __exec $MYEMAIL $OPEN &>/dev/null
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
