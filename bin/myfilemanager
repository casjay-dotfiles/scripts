#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : myfilemanager --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : myfilemanager
# @Description   : Open file manager
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
#if [ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; }; then  TERMINAL_APP="TRUE" myterminal -e "$APPNAME $*" && exit || exit 1; fi

if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$MYFILEMANAGER_TEMP_FILE" ] && [ -f "$MYFILEMANAGER_TEMP_FILE" ] && rm -Rf "$MYFILEMANAGER_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  local FILEMANAGER="${FILEMANAGER// /}"
  local MYFILEMANAGER="${MYFILEMANAGER// /}"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$MYFILEMANAGER_CONFIG_DIR/$MYFILEMANAGER_CONFIG_FILE"
  [ -d "$MYFILEMANAGER_CONFIG_DIR" ] || mkdir -p "$MYFILEMANAGER_CONFIG_DIR"
  [ -d "$MYFILEMANAGER_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYFILEMANAGER_CONFIG_BACKUP_DIR"
  [ -f "$MYFILEMANAGER_CONFIG_DIR/$MYFILEMANAGER_CONFIG_FILE" ] &&
    cp -Rf "$MYFILEMANAGER_CONFIG_DIR/$MYFILEMANAGER_CONFIG_FILE" "$MYFILEMANAGER_CONFIG_BACKUP_DIR/$MYFILEMANAGER_CONFIG_FILE.$$"
  cat <<EOF >"$MYFILEMANAGER_CONFIG_DIR/$MYFILEMANAGER_CONFIG_FILE"
# Settings for myfilemanager
MYFILEMANAGER_NAME="${MYFILEMANAGER_NAME:-config}"
MYFILEMANAGER="${MYFILEMANAGER:-$FILEMANAGER}"
MYFILEMANAGER_OPTIONS="${MYFILEMANAGER_OPTIONS:-}"
MYFILEMANAGER_CONSOLE="${MYFILEMANAGER_CONSOLE:-}"

# Notification settings
MYFILEMANAGER_GOOD_MESSAGE="${MYFILEMANAGER_GOOD_MESSAGE:-Everything Went OK}"
MYFILEMANAGER_ERROR_MESSAGE="${MYFILEMANAGER_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYFILEMANAGER_NOTIFY_ENABLED="${MYFILEMANAGER_NOTIFY_ENABLED:-yes}"
MYFILEMANAGER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYFILEMANAGER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYFILEMANAGER_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYFILEMANAGER_OUTPUT_COLOR="${MYFILEMANAGER_OUTPUT_COLOR:-5}"
MYFILEMANAGER_OUTPUT_COLOR_GOOD="${MYFILEMANAGER_OUTPUT_COLOR_GOOD:-2}"
MYFILEMANAGER_OUTPUT_COLOR_ERROR="${MYFILEMANAGER_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYFILEMANAGER_CONFIG_DIR/$MYFILEMANAGER_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__create_term() {
  cat <<EOF | tee
  #!/usr/bin/env sh
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202104040050-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : myfilemanager --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Sunday, Apr 04, 2021 00:50 EDT
# @File          : myfilemanager
# @Description   : Using $MYFILEMANAGER as myfilemanager
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ ! -t 0 ]; then
  myterminal -e "$MYFILEMANAGER \$MYFILEMANAGER_OPTIONS \$*"
else
  $MYFILEMANAGER \$MYFILEMANAGER_OPTIONS \$*
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}

EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__create_link() {
  local MYFILEMANAGER="$1"
  local MYFILEMANAGER_NAME="$(basename "$MYFILEMANAGER" 2>/dev/null)"
  shift $#
  if cmd_exists "$MYFILEMANAGER"; then
    if [ "$MYFILEMANAGER_CONSOLE" = "yes" ]; then
      printf_green "Generating the script for $MYFILEMANAGER"
      __create_term >"$HOME/.local/bin/myfilemanager"
      chmod 755 "$HOME/.local/bin/myfilemanager" &>/dev/null
    else
      printf_green "Linking $HOME/.local/bin/myfilemanager to $MYFILEMANAGER"
      __ln_sf "$(builtin type -P "$MYFILEMANAGER")" "$HOME/.local/bin/myfilemanager"
    fi
  else
    printf_green "Linking $HOME/.local/bin/myfilemanager to $MYFILEMANAGER"
    __ln_sf "$MYFILEMANAGER" "$HOME/.local/bin/myfilemanager"
  fi
  printf_blue "Updating the config file"
  __gen_config &>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__term() {
  if [ $# = 0 ]; then
    $MYFILEMANAGER --help | less
  else
    $MYFILEMANAGER "$*"
  fi
  while :; do
    printf_newline
    printf_read_input "2" "What command would you like to execute [q to exit]" "20" "CMD"
    if { [[ "$CMD" = '-q' ]] || [[ "$CMD" = 'q' ]] || [[ "$CMD" = 'quit' ]] || [[ "$CMD" = 'exit' ]]; }; then exit; fi
    $MYFILEMANAGER $CMD
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MYFILEMANAGER_LOG_DIR="${MYFILEMANAGER_LOG_DIR:-$HOME/.local/log/myfilemanager}"
MYFILEMANAGER_CACHE_DIR="${MYFILEMANAGER_CACHE_DIR:-$HOME/.cache/myfilemanager}"
MYFILEMANAGER_CONFIG_DIR="${MYFILEMANAGER_CONFIG_DIR:-$HOME/.config/myscripts/myfilemanager}"
MYFILEMANAGER_CONFIG_BACKUP_DIR="${MYFILEMANAGER_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/myfilemanager/backups}"
MYFILEMANAGER_TEMP_DIR="${MYFILEMANAGER_TEMP_DIR:-$HOME/.local/tmp/system_scripts/myfilemanager}"
MYFILEMANAGER_OPTIONS_DIR="${MYFILEMANAGER_OPTIONS_DIR:-$HOME/.local/share/myscripts/myfilemanager/options}"
MYFILEMANAGER_TEMP_FILE="${MYFILEMANAGER_TEMP_FILE:-$(mktemp $MYFILEMANAGER_TEMP_DIR/XXXXXX 2>/dev/null)}"
MYFILEMANAGER_CONFIG_FILE="${MYFILEMANAGER_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYFILEMANAGER_OUTPUT_COLOR="${MYFILEMANAGER_OUTPUT_COLOR:-4}"
MYFILEMANAGER_OUTPUT_COLOR_2="${MYFILEMANAGER_OUTPUT_COLOR:-6}"
MYFILEMANAGER_OUTPUT_COLOR_GOOD="${MYFILEMANAGER_OUTPUT_COLOR_GOOD:-2}"
MYFILEMANAGER_OUTPUT_COLOR_ERROR="${MYFILEMANAGER_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYFILEMANAGER_GOOD_MESSAGE="${MYFILEMANAGER_GOOD_MESSAGE:-Everything Went OK}"
MYFILEMANAGER_ERROR_MESSAGE="${MYFILEMANAGER_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYFILEMANAGER_NOTIFY_ENABLED="${MYFILEMANAGER_NOTIFY_ENABLED:-yes}"
MYFILEMANAGER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYFILEMANAGER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYFILEMANAGER_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
MYFILEMANAGER_CONSOLE="${MYFILEMANAGER_CONSOLE:-}"
MYFILEMANAGER="${MYFILEMANAGER:-$FILEMANAGER}"
MYFILEMANAGER_OPTIONS=${MYFILEMANAGER_OPTIONS:-}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYFILEMANAGER_CONFIG_DIR/$MYFILEMANAGER_CONFIG_FILE" ] && . "$MYFILEMANAGER_CONFIG_DIR/$MYFILEMANAGER_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MYFILEMANAGER_LOG_DIR" ] || mkdir -p "$MYFILEMANAGER_LOG_DIR" &>/dev/null
[ -d "$MYFILEMANAGER_TEMP_DIR" ] || mkdir -p "$MYFILEMANAGER_TEMP_DIR" &>/dev/null
[ -d "$MYFILEMANAGER_CACHE_DIR" ] || mkdir -p "$MYFILEMANAGER_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MYFILEMANAGER_CONFIG_DIR/$MYFILEMANAGER_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
if [ -z "$(builtin type -P "$MYFILEMANAGER")" ] || [ "$MYFILEMANAGER" = "myfilemanager" ]; then unset MYFILEMANAGER; fi
if [ "$MYFILEMANAGER_NAME" = "config" ] || [ "$MYFILEMANAGER_NAME" = "" ]; then
  if [ -n "$(builtin type -P caja 2>/dev/null)" ]; then
    MYFILEMANAGER="caja"
  elif [ -n "$(builtin type -P thunar 2>/dev/null)" ]; then
    MYFILEMANAGER="thunar"
  elif [ -n "$(builtin type -P Thunar 2>/dev/null)" ]; then
    MYFILEMANAGER="Thunar"
  elif [ -n "$(builtin type -P spacefm 2>/dev/null)" ]; then
    MYFILEMANAGER="spacefm"
  elif [ -n "$(builtin type -P nemo 2>/dev/null)" ]; then
    MYFILEMANAGER="nemo"
  elif [ -n "$(builtin type -P pcmanfm 2>/dev/null)" ]; then
    MYFILEMANAGER="pcmanfm"
  elif [ -n "$(builtin type -P polo 2>/dev/null)" ]; then
    MYFILEMANAGER="polo"
  elif [ -n "$(builtin type -P nautilus 2>/dev/null)" ]; then
    MYFILEMANAGER="nautilus"
  elif [ -n "$(builtin type -P polo 2>/dev/null)" ]; then
    MYFILEMANAGER="polo"
  elif [ -n "$(builtin type -P dolphin 2>/dev/null)" ]; then
    MYFILEMANAGER="dolphin"
  elif [ -n "$(builtin type -P konqueror 2>/dev/null)" ]; then
    MYFILEMANAGER="konqueror"
  elif [ -n "$(builtin type -P lf 2>/dev/null)" ]; then
    MYFILEMANAGER="lf"
  elif [ -n "$(builtin type -P vifm 2>/dev/null)" ]; then
    MYFILEMANAGER="vifm"
  elif [ -n "$(builtin type -P ranger 2>/dev/null)" ]; then
    MYFILEMANAGER="ranger"
  elif [ -n "$(builtin type -P cfiles 2>/dev/null)" ]; then
    MYFILEMANAGER="cfiles"
  elif [ -n "$(builtin type -P se 2>/dev/null)" ]; then
    MYFILEMANAGER="se"
  fi
  if [[ "$(uname -s)" = Darwin ]]; then
    MYFILEMANAGER="open"
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
MYFILEMANAGER_NAME="$(basename $MYFILEMANAGER 2>/dev/null)"
export MYFILEMANAGER="$MYFILEMANAGER"
export FILEMANAGER="$MYFILEMANAGER"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
case $MYFILEMANAGER_NAME in
lf | vifm | ranger | se | cfiles)
  MYFILEMANAGER_CONSOLE="yes"
  export TERMINAL_APP="TRUE"
  ;;
esac
if grep -s "MYFILEMANAGER_NAME" "$MYFILEMANAGER_CONFIG_DIR/$MYFILEMANAGER_CONFIG_FILE" | grep -q config; then __gen_config &>/dev/null; fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,term:,link:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MYFILEMANAGER_CWD="$2"
    shift 2
    ;;
  --link)
    shift 1
    __create_link "${1:-$MYFILEMANAGER}"
    shift 1
    exit $?
    ;;
  --term)
    shift 1
    __term "$1"
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MYFILEMANAGER_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYFILEMANAGER_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYFILEMANAGER_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYFILEMANAGER_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYFILEMANAGER_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -z "$MYFILEMANAGER" ]; then
  printf_newline "\n"
  __notifications "No file managers are installed"
  printf_red "No file managers are installed"
  printf_pause 1 "Press any key to exit this window"
  exit
fi
ARGS=${*:-}
OPEN="$MYFILEMANAGER_OPTIONS $ARGS"
[ -n "$OPEN" ] || OPEN=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__notifications "Attempting to launch $MYFILEMANAGER_NAME"
if [ -f "$HOME/.local/bin/myfilemanager" ]; then
  "$HOME/.local/bin/myfilemanager" "$ARGS"
elif [ "$MYFILEMANAGER_CONSOLE" = "yes" ]; then
  if [ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; }; then
    TERMINAL_APP="TRUE" myterminal -e "$APPNAME" "$OPEN"
  else
    $MYFILEMANAGER ${OPEN:---help}
  fi
else
  __exec $MYFILEMANAGER $OPEN &>/dev/null
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
