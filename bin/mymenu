# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : mymenu
# @Description   : Application menu
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; } && myterminal -e "$APPNAME" "$*" && { exit || exit 1; }
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$MYMENU_TEMP_FILE" ] && [ -f "$MYMENU_TEMP_FILE" ] && rm -Rf "$MYMENU_TEMP_FILE" &>/dev/null' EXIT
trap '' SIGINT
trap '' SIGQUIT
trap '' SIGTSTP
shopt -s extglob

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$MYMENU_CONFIG_DIR/$MYMENU_CONFIG_FILE"
  [ -d "$MYMENU_CONFIG_DIR" ] || mkdir -p "$MYMENU_CONFIG_DIR"
  [ -d "$MYMENU_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYMENU_CONFIG_BACKUP_DIR"
  [ -f "$MYMENU_CONFIG_DIR/$MYMENU_CONFIG_FILE" ] &&
    cp -Rf "$MYMENU_CONFIG_DIR/$MYMENU_CONFIG_FILE" "$MYMENU_CONFIG_BACKUP_DIR/$MYMENU_CONFIG_FILE.$$"
  cat <<EOF >"$MYMENU_CONFIG_DIR/$MYMENU_CONFIG_FILE"
# Settings for mymenu

# Notification settings
MYMENU_GOOD_MESSAGE="${MYMENU_GOOD_MESSAGE:-Everything Went OK}"
MYMENU_ERROR_MESSAGE="${MYMENU_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYMENU_NOTIFY_ENABLED="${MYMENU_NOTIFY_ENABLED:-yes}"
MYMENU_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYMENU_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYMENU_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYMENU_OUTPUT_COLOR="${MYMENU_OUTPUT_COLOR:-5}"
MYMENU_OUTPUT_COLOR_GOOD="${MYMENU_OUTPUT_COLOR_GOOD:-2}"
MYMENU_OUTPUT_COLOR_ERROR="${MYMENU_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYMENU_CONFIG_DIR/$MYMENU_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__run() {
  printf_newline "\n\n"
  printf_read_input "3" "${MESSAGE:-Arguments to send}" "180" "SEND" '-e'
  [ "$1" = "q" ] && return
  run_in_term "$1" "$SEND"
  printf_newline "\n"
  printf_pause
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MYMENU_LOG_DIR="${MYMENU_LOG_DIR:-$HOME/.local/log/mymenu}"
MYMENU_CACHE_DIR="${MYMENU_CACHE_DIR:-$HOME/.cache/mymenu}"
MYMENU_CONFIG_DIR="${MYMENU_CONFIG_DIR:-$HOME/.config/myscripts/mymenu}"
MYMENU_CONFIG_BACKUP_DIR="${MYMENU_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/mymenu/backups}"
MYMENU_TEMP_DIR="${MYMENU_TEMP_DIR:-$HOME/.local/tmp/system_scripts/mymenu}"
MYMENU_OPTIONS_DIR="${MYMENU_OPTIONS_DIR:-$HOME/.local/share/myscripts/mymenu/options}"
MYMENU_TEMP_FILE="${MYMENU_TEMP_FILE:-$(mktemp $MYMENU_TEMP_DIR/XXXXXX 2>/dev/null)}"
MYMENU_CONFIG_FILE="${MYMENU_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYMENU_OUTPUT_COLOR="${MYMENU_OUTPUT_COLOR:-4}"
MYMENU_OUTPUT_COLOR_2="${MYMENU_OUTPUT_COLOR:-6}"
MYMENU_OUTPUT_COLOR_GOOD="${MYMENU_OUTPUT_COLOR_GOOD:-2}"
MYMENU_OUTPUT_COLOR_ERROR="${MYMENU_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYMENU_GOOD_MESSAGE="${MYMENU_GOOD_MESSAGE:-Everything Went OK}"
MYMENU_ERROR_MESSAGE="${MYMENU_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYMENU_NOTIFY_ENABLED="${MYMENU_NOTIFY_ENABLED:-yes}"
MYMENU_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYMENU_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYMENU_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYMENU_CONFIG_DIR/$MYMENU_CONFIG_FILE" ] && . "$MYMENU_CONFIG_DIR/$MYMENU_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MYMENU_LOG_DIR" ] || mkdir -p "$MYMENU_LOG_DIR" &>/dev/null
[ -d "$MYMENU_TEMP_DIR" ] || mkdir -p "$MYMENU_TEMP_DIR" &>/dev/null
[ -d "$MYMENU_CACHE_DIR" ] || mkdir -p "$MYMENU_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MYMENU_CONFIG_DIR/$MYMENU_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MYMENU_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MYMENU_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYMENU_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYMENU_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYMENU_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYMENU_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
while :; do
  # show menu
  clear
  shift 1
  printf_newline "\n\n\n\n"
  printf_head "Application Menu"
  printf_green "1. Reload menu"
  printf_green "a. launch mybluetooth"
  printf_green "b. launch mybrowser"
  printf_green "c. launch mydate"
  printf_green "d. launch myeditor"
  printf_green "e. launch myemail"
  printf_green "f. launch myfilemanager"
  printf_green "g. launch myip"
  printf_green "h. launch mylocation"
  printf_green "i. launch myterminal"
  printf_green "j. launch mytorrent"
  printf_green "k. launch myvmmanager"
  printf_green "l. launch social"
  printf_green "m. launch multimedia"
  printf_green "n. launch calc"
  printf_green "o. launch define"
  printf_green "p. launch spellcheck"
  printf_green "q. launch thesaurus"
  printf_green "r. launch notes"
  printf_green "s. launch rofi"
  printf_green "t. launch dmenu"
  printf_green "u. launch catfish"
  printf_green "y. launch custom application"
  printf_green "z. or escape to Exit"
  printf_green "---------------------------------"
  printf_read_question_nt "6" "Enter your choice [a-z] : " "1" "main"
  clear
  printf_newline "\n\n\n"

  # take action
  case "$main" in
  1) exec "$APPNAME" ;;
  a)
    shift 1
    printf_green "Loading mybluetooth"
    __run mybluetooth
    ;;
  b)
    shift 1
    printf_green "Loading mybrowser"
    __run mybrowser
    ;;
  c)
    shift 1
    printf_green "Loading mydate"
    __run mydate
    ;;
  d)
    shift 1
    printf_green "Loading myeditor"
    __run myeditor
    ;;
  e)
    shift 1
    printf_green "Loading myemail"
    __run myemail
    ;;
  f)
    shift 1
    printf_green "Loading myfilemanager"
    __run myfilemanager
    ;;
  g)
    shift 1
    printf_green "Loading myip"
    __run myip
    ;;
  h)
    shift 1
    printf_green "Loading mylocation"
    __run mylocation
    ;;
  i)
    shift 1
    printf_green "Loading myterminal"
    __run myterminal
    ;;
  j)
    shift 1
    printf_green "Loading mytorrent"
    __run mytorrent
    ;;
  k)
    shift 1
    printf_green "Loading myvmmanager"
    __run myvmmanager
    ;;
  l)
    shift 1
    printf_green "Loading social"
    __run social
    ;;
  m)
    shift 1
    printf_green "Loading multimedia"
    __run multimedia
    ;;
  n)
    shift 1
    printf_green "Loading calc"
    __run calc
    ;;
  o)
    shift 1
    printf_green "Loading define"
    __run define
    ;;
  p)
    shift 1
    printf_green "Loading spellcheck"
    __run spellcheck
    ;;
  q)
    shift 1
    printf_green "Loading thesaurus"
    __run thesaurus
    ;;
  r)
    shift 1
    printf_green "Loading notes"
    __run notes
    ;;
  s)
    printf_green "Loading rofi"
    rofi -theme ${ROFI_THEME:-purple} -show run
    ;;
  t)
    printf_green "Loading dmenu"
    dmenu_run
    ;;
  u)
    printf_green "Loading catfish"
    catfish
    ;;
  y)
    shift 1
    if cmd_exists rofi; then
      APP="$(ls /usr/local/share/CasjaysDev/scripts/bin/ | rofi -theme ${ROFI_THEME:-purple} -dmenu)"
    elif cmd_exists dmenu; then
      APP="$(ls /usr/local/share/CasjaysDev/scripts/bin/ | dmenu)"
    else
      printf_read_input "2" "What app would you like to run" "160" "APP"
    fi
    eval "$APP"
    ;;
  $'\E' | $'\e' | z)
    shift 1
    clear
    break
    ;;
  *) shift ;;

  esac
  clear
  printf_newline "\n\n"
  #printf_counter "5" "3" "Re-loading menu in"
done
clear
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
