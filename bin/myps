# - - - - - - - - - - - - - - - - - - - - - - - - -
# Send all output to /dev/null
__devnull() {
  tee &>/dev/null && exitCode=0 || exitCode=1
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -'
# Send errors to /dev/null
__devnull2() {
  [ -n "$1" ] && local cmd="$1" && shift 1 || return 1
  eval $cmd "$*" 2>/dev/null && exitCode=0 || exitCode=1
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -'
# See if the executable exists
__cmd_exists() {
  local exitCode=0
  [ -n "$1" ] || return 0
  for cmd in "$@"; do
    if builtin command -v "$cmd" &>/dev/null; then
      exitCode=$((exitCode + 0))
    else
      exitCode=$((exitCode + 1))
    fi
  done
  [ $exitCode -eq 0 ] || exitCode=3
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for a valid internet connection
__am_i_online() {
  local exitCode=0
  curl -q -LSsfI --max-time 2 --retry 1 "${1:-https://1.1.1.1}" 2>&1 | grep -qi -- 'server:.*cloudflare' || exitCode=4
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# colorization
if [ -n "${NO_COLOR+x}" ] || [ "$SHOW_RAW" = "true" ]; then
  NC=""
  RESET=""
  BLACK=""
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  PURPLE=""
  CYAN=""
  WHITE=""
  ORANGE=""
  LIGHTRED=""
  BG_GREEN=""
  BG_RED=""
  ICON_INFO="[ info ]"
  ICON_GOOD="[ ok ]"
  ICON_WARN="[ warn ]"
  ICON_ERROR="[ error ]"
  ICON_QUESTION="[ ? ]"
  printf_column() { tee | grep -- '^'; }
  printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
else
  printf_color() { printf "%b" "$(tput setaf "${2:-7}" 2>/dev/null)" "$1" "$(tput sgr0 2>/dev/null)"; }
  printf_column() {
    local color="${1:-7}"
    column | while IFS= read -r line; do
      printf_color "$line\n" "$color"
    done
    printf '\n'
  }
  NC="$(tput sgr0 2>/dev/null)"
  PURPLE="$(tput setaf 5 2>/dev/null)"
  YELLOW="$(tput setaf 3 2>/dev/null)"
  CYAN="$(tput setaf 6 2>/dev/null)"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional printf_ functions
printf_newline() { [ -n "$1" ] && printf '%b\n' "${*:-}" || printf '\n'; }
printf_green() { printf_color "$1\n" 2; }
printf_red() { printf_color "$1\n" 208; }
printf_purple() { printf_color "$1\n" 5; }
printf_yellow() { printf_color "$1\n" 3; }
printf_blue() { printf_color "$1\n" 33; }
printf_cyan() { printf_color "$1\n" 6; }
printf_exit() {
  test -n "$1" && test -z "${1//[0-9]/}" && local color="$1" && shift 1 || local color="208"
  test -n "$1" && test -z "${1//[0-9]/}" && local exitCode="$1" && shift 1 || local exitCode="1"
  local msg="$*"
  printf_color "$msg" "$color" 1>&2
  printf '\n'
  exit "$exitCode"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional printf_ colors
__printf_head() { printf_blue "$1"; }
__printf_opts() { printf_purple "$1"; }
__printf_line() { printf_cyan "$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# output version
__version() { printf_cyan "$VERSION"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  printf_color "$1: " "$5"
  echo -ne "$2" | sed 's|:||g;s/'$3'/ '$4'/g' | tr '\n' ' '
  printf_newline
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# create the config file
__gen_config() {
  local NOTIFY_CLIENT_NAME="$APPNAME"
  if [ "$INIT_CONFIG" != "TRUE" ]; then
    printf_blue "Generating the config file in"
    printf_cyan "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE"
  fi
  [ -d "$MYPS_CONFIG_DIR" ] || mkdir -p "$MYPS_CONFIG_DIR"
  [ -d "$MYPS_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYPS_CONFIG_BACKUP_DIR"
  [ -f "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE" ] &&
    cp -Rf "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE" "$MYPS_CONFIG_BACKUP_DIR/$MYPS_CONFIG_FILE.$$"
  cat <<EOF >"$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE"
# Settings for myps

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYPS_OUTPUT_COLOR_1="${MYPS_OUTPUT_COLOR_1:-}"
MYPS_OUTPUT_COLOR_2="${MYPS_OUTPUT_COLOR_2:-}"
MYPS_OUTPUT_COLOR_GOOD="${MYPS_OUTPUT_COLOR_GOOD:-}"
MYPS_OUTPUT_COLOR_ERROR="${MYPS_OUTPUT_COLOR_ERROR:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYPS_NOTIFY_ENABLED="${MYPS_NOTIFY_ENABLED:-}"
MYPS_GOOD_NAME="${MYPS_GOOD_NAME:-}"
MYPS_ERROR_NAME="${MYPS_ERROR_NAME:-}"
MYPS_GOOD_MESSAGE="${MYPS_GOOD_MESSAGE:-}"
MYPS_ERROR_MESSAGE="${MYPS_ERROR_MESSAGE:-}"
MYPS_NOTIFY_CLIENT_NAME="${MYPS_NOTIFY_CLIENT_NAME:-}"
MYPS_NOTIFY_CLIENT_ICON="${MYPS_NOTIFY_CLIENT_ICON:-}"
MYPS_NOTIFY_CLIENT_URGENCY="${MYPS_NOTIFY_CLIENT_URGENCY:-}"

EOF
  if builtin type -t __gen_config_local | grep -q -- 'function'; then __gen_config_local; fi
  if [ -f "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE" ]; then
    [ "$INIT_CONFIG" = "TRUE" ] || printf_green "Your config file for $APPNAME has been created"
    . "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Help function - Align to 50
__help() {
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "myps:  My processes - $VERSION"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Usage: myps [options] [commands]"
  __printf_line "                                       - "

  __printf_line "                                       - "

  __printf_line "--dir                                  - Sets the working directory"

  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "--help                                 - Shows this message"

  __printf_line "--config                               - Generate user config file"

  __printf_line "--version                              - Show script version"

  __printf_line "--options                              - Shows all available options"

  __printf_line "--debug                                - Enables script debugging"

  __printf_line "--no-color                             - Disable ANSI color output"

  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# check if arg is a builtin option
__is_an_option() { if [[ "$ARRAY" == *"${1:-^}"* ]]; then return 1; else return 0; fi; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-0}
  [ -f "$MYPS_TEMP_FILE" ] && rm -Rf "$MYPS_TEMP_FILE" &>/dev/null
  #unset CASJAYSDEV_TITLE_SET && printf '\033]2│;%s\033\\' "${USER}@${HOSTNAME}:${PWD/#$HOME/~} - ${CASJAYSDEV_TITLE_PREV:-$SHELL}"
  if builtin type -t __trap_exit_local | grep -q -- 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__execute_myps() {
  local -a proclist=()
  local column="$((${COLUMNS:-100} - 30))"
  test -n "$1" && test -z "${1//[0-9]/}" && NPROCESSES="$1" || NPROCESSES=50
  printf '\033[2J\033[H'
  printf '\n\n\n'
  proclist=("$(
    ps --sort pid --columns $column -o %cpu -o %mem -o command | grep -vEw 'head -*|tail -*|myps' | head -n$((NPROCESSES + 1)) | tail -n$NPROCESSES |
      while read -r line; do
        cpu=$(echo "${line[*]}" | awk '{print $1}')
        mem=$(echo "${line[*]}" | awk '{print $2}')
        cmd=$(echo "${line[*]}" | awk '{for(i=3;i<NF;i++){printf("%10s ",$i,OFS=" ")}print $NF}')
        if echo "${cmd[*]}" | grep -q "/"; then
          cmd=$(echo "${cmd[*]}" | awk -F, '{n=split($1,tmp,"/")}{print tmp[n]}')
        fi
        printf "${PURPLE}%s ${YELLOW}%15s  ${CYAN}%15s\n" "$cpu" "$mem" "${cmd:0:$column}${NC}"
      done
  )")
  [ -n "${proclist[*]}" ] && printf '%b\n' "${proclist[@]}" && exitCode=0 || exitCode=1
  printf '\n\n'
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined variables/import external variables

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MYPS_CONFIG_FILE="${MYPS_CONFIG_FILE:-settings.conf}"
MYPS_CONFIG_DIR="${MYPS_CONFIG_DIR:-$HOME/.config/myscripts/myps}"
MYPS_CONFIG_BACKUP_DIR="${MYPS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/myps/backups}"
MYPS_LOG_DIR="${MYPS_LOG_DIR:-$HOME/.local/log/myps}"
MYPS_TEMP_DIR="${MYPS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/myps}"
MYPS_CACHE_DIR="${MYPS_CACHE_DIR:-$HOME/.cache/myps}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYPS_OUTPUT_COLOR_1="${MYPS_OUTPUT_COLOR_1:-33}"
MYPS_OUTPUT_COLOR_2="${MYPS_OUTPUT_COLOR_2:-5}"
MYPS_OUTPUT_COLOR_GOOD="${MYPS_OUTPUT_COLOR_GOOD:-2}"
MYPS_OUTPUT_COLOR_ERROR="${MYPS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYPS_NOTIFY_ENABLED="${MYPS_NOTIFY_ENABLED:-yes}"
MYPS_GOOD_NAME="${MYPS_GOOD_NAME:-Great:}"
MYPS_ERROR_NAME="${MYPS_ERROR_NAME:-Error:}"
MYPS_GOOD_MESSAGE="${MYPS_GOOD_MESSAGE:-No errors reported}"
MYPS_ERROR_MESSAGE="${MYPS_ERROR_MESSAGE:-Errors were reported}"
MYPS_NOTIFY_CLIENT_NAME="${MYPS_NOTIFY_CLIENT_NAME:-$APPNAME}"
MYPS_NOTIFY_CLIENT_ICON="${MYPS_NOTIFY_CLIENT_ICON:-notification-new}"
MYPS_NOTIFY_CLIENT_URGENCY="${MYPS_NOTIFY_CLIENT_URGENCY:-normal}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional Variables

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE" ] || [ "$*" = "--config" ] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE" ] && . "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MYPS_LOG_DIR" ] || mkdir -p "$MYPS_LOG_DIR" |& __devnull
[ -d "$MYPS_TEMP_DIR" ] || mkdir -p "$MYPS_TEMP_DIR" |& __devnull
[ -d "$MYPS_CACHE_DIR" ] || mkdir -p "$MYPS_CACHE_DIR" |& __devnull
# - - - - - - - - - - - - - - - - - - - - - - - - -
MYPS_TEMP_FILE="${MYPS_TEMP_FILE:-$(mktemp $MYPS_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap '__trap_exit' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
__notifications() {
  __cmd_exists notifications || return
  [ "$MYPS_NOTIFY_ENABLED" = "yes" ] || return
  [ "$SEND_NOTIFICATION" = "no" ] && return
  (
    export SCRIPT_OPTS="" _DEBUG=""
    export NOTIFY_GOOD_MESSAGE="${NOTIFY_GOOD_MESSAGE:-$MYPS_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${NOTIFY_ERROR_MESSAGE:-$MYPS_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYPS_NOTIFY_CLIENT_ICON}"
    export NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$MYPS_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_URGENCY="${NOTIFY_CLIENT_URGENCY:-$MYPS_NOTIFY_CLIENT_URGENCY}"
    notifications "$@"
  ) |& __devnull &
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Set custom actions

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Argument/Option settings
SETARGS=("$@")
# - - - - - - - - - - - - - - - - - - - - - - - - -
SHORTOPTS=""
SHORTOPTS+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
LONGOPTS="completions:,config,debug,dir:,help,options,no-color,version,silent"
LONGOPTS+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
ARRAY=""
ARRAY+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
LIST=""
LIST+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --no-color)
    shift 1
    export SHOW_RAW="true"
    NC=""
    RESET=""
    BLACK=""
    RED=""
    GREEN=""
    YELLOW=""
    BLUE=""
    PURPLE=""
    CYAN=""
    WHITE=""
    ORANGE=""
    LIGHTRED=""
    BG_GREEN=""
    BG_RED=""
    ICON_INFO="[ info ]"
    ICON_GOOD="[ ok ]"
    ICON_WARN="[ warn ]"
    ICON_ERROR="[ error ]"
    ICON_QUESTION="[ ? ]"
    printf_column() { tee | grep -- '^'; }
    printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
    ;;
  --debug)
    shift 1
    set -xo pipefail
    export SCRIPT_OPTS="--debug"
    export _DEBUG="on"
    __devnull() { tee || return 1; }
    __devnull2() { eval "$@" |& tee -p || return 1; }
    ;;
  --completions)
    if [ "$2" = "short" ]; then
      printf '%s\n' "-$SHORTOPTS" | sed 's|"||g;s|:||g;s|,|,-|g' | tr ',' '\n'
    elif [ "$2" = "long" ]; then
      printf '%s\n' "--$LONGOPTS" | sed 's|"||g;s|:||g;s|,|,--|g' | tr ',' '\n'
    elif [ "$2" = "array" ]; then
      printf '%s\n' "$ARRAY" | sed 's|"||g;s|:||g' | tr ',' '\n'
    elif [ "$2" = "list" ]; then
      printf '%s\n' "$LIST" | sed 's|"||g;s|:||g' | tr ',' '\n'
    else
      exit 1
    fi
    shift 2
    exit $?
    ;;
  --options)
    shift 1
    printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "Short Options" "-${SHORTOPTS}" ',' '-' 4
    [ -z "$LONGOPTS" ] || __list_options "Long Options" "--${LONGOPTS}" ',' '--' 4
    [ -z "$ARRAY" ] || __list_options "Base Options" "${ARRAY}" ',' '' 4
    [ -z "$LIST" ] || __list_options "LIST Options" "${LIST}" ',' '' 4
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --silent)
    shift 1
    MYPS_SILENT="true"
    ;;
  --dir)
    CWD_IS_SET="TRUE"
    MYPS_CWD="$2"
    [ -d "$MYPS_CWD" ] || mkdir -p "$MYPS_CWD" |& __devnull
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Set directory to first argument
# [ -d "$1" ] && __is_an_option "$1" && MYPS_CWD="$1" && shift 1 || MYPS_CWD="${MYPS_CWD:-$PWD}"
MYPS_CWD="$(realpath "${MYPS_CWD:-$PWD}" 2>/dev/null)"
export MYPS_CWD
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Set actions based on variables

