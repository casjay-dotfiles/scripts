#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : myps --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : myps
# @Description   : My processes
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE"
  [ -d "$MYPS_CONFIG_DIR" ] || mkdir -p "$MYPS_CONFIG_DIR"
  [ -d "$MYPS_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYPS_CONFIG_BACKUP_DIR"
  [ -f "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE" ] &&
    cp -Rf "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE" "$MYPS_CONFIG_BACKUP_DIR/$MYPS_CONFIG_FILE.$$"
  cat <<EOF >"$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE"
# Settings for myps

# Notification settings
MYPS_GOOD_MESSAGE="${MYPS_GOOD_MESSAGE:-Everything Went OK}"
MYPS_ERROR_MESSAGE="${MYPS_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYPS_NOTIFY_ENABLED="${MYPS_NOTIFY_ENABLED:-yes}"
MYPS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYPS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYPS_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYPS_OUTPUT_COLOR="${MYPS_OUTPUT_COLOR:-5}"
MYPS_OUTPUT_COLOR_GOOD="${MYPS_OUTPUT_COLOR_GOOD:-2}"
MYPS_OUTPUT_COLOR_ERROR="${MYPS_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    # if [[ "$INIT_CONFIG" = "TRUE" ]]; then
    #   unset INIT_CONFIG
    #   eval bash -c "$APPNAME $*"
    #   exit
    # fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MYPS_LOG_DIR="${MYPS_LOG_DIR:-$HOME/.local/log/myps}"
MYPS_CACHE_DIR="${MYPS_CACHE_DIR:-$HOME/.cache/myps}"
MYPS_CONFIG_DIR="${MYPS_CONFIG_DIR:-$HOME/.config/myscripts/myps}"
MYPS_CONFIG_BACKUP_DIR="${MYPS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/myps/backups}"
MYPS_TEMP_DIR="${MYPS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/myps}"
MYPS_OPTIONS_DIR="${MYPS_OPTIONS_DIR:-$HOME/.local/share/myscripts/myps/options}"
MYPS_CONFIG_FILE="${MYPS_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYPS_OUTPUT_COLOR="${MYPS_OUTPUT_COLOR:-4}"
MYPS_OUTPUT_COLOR_2="${MYPS_OUTPUT_COLOR:-6}"
MYPS_OUTPUT_COLOR_GOOD="${MYPS_OUTPUT_COLOR_GOOD:-2}"
MYPS_OUTPUT_COLOR_ERROR="${MYPS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYPS_GOOD_MESSAGE="${MYPS_GOOD_MESSAGE:-Everything Went OK}"
MYPS_ERROR_MESSAGE="${MYPS_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYPS_NOTIFY_ENABLED="${MYPS_NOTIFY_ENABLED:-yes}"
MYPS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYPS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYPS_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE" ] && . "$MYPS_CONFIG_DIR/$MYPS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$MYPS_LOG_DIR" ] || mkdir -p "$MYPS_LOG_DIR" &>/dev/null
[ -d "$MYPS_TEMP_DIR" ] || mkdir -p "$MYPS_TEMP_DIR" &>/dev/null
[ -d "$MYPS_CACHE_DIR" ] || mkdir -p "$MYPS_CACHE_DIR" &>/dev/null
MYPS_TEMP_FILE="${MYPS_TEMP_FILE:-$(mktemp $MYPS_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$MYPS_TEMP_FILE" ] && [ -f "$MYPS_TEMP_FILE" ] && rm -Rf "$MYPS_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$MYPS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYPS_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYPS_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYPS_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYPS_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MYPS_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[ ! -z "$1" ] && NPROCESSES="$1" || NPROCESSES=10
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
ps axr -o %cpu -o %mem -o comm | head -n$((NPROCESSES + 1)) | tail -n$NPROCESSES | while read -r line; do
  cpu=$(echo "${line[*]}" | awk '{print $1}')
  mem=$(echo "${line[*]}" | awk '{print $2}')
  cmd=$(echo "${line[*]}" | awk '{for(i=3;i<NF;i++){printf("%10s ",$i,OFS=" ")}print $NF}')
  if echo "${cmd[*]}" | grep -q "/"; then
    cmd=$(echo "${cmd[*]}" | awk -F, '{n=split($1,tmp,"/")}{print tmp[n]}')
  fi
  printf "${GREEN}%10s%10s %10s\n" "$cpu" "$mem" "$cmd${NC}"
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
