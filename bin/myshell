#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -xo pipefail && export DEBUGGING="true"
trap 'exitCode=${exitCode:-$?};[ -f "$MYSHELL_TEMP_FILE" ] && rm -Rf "$MYSHELL_TEMP_FILE" &>/dev/null' EXIT
[ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# = 0 ]; } && myterminal -e "$APPNAME" "$*" && { exit || exit 1; }

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : myshell --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : myshell
# @Description   : Change the default user shell
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$MYSHELL_CONFIG_DIR/$MYSHELL_CONFIG_FILE"
  [ -d "$MYSHELL_CONFIG_DIR" ] || mkdir -p "$MYSHELL_CONFIG_DIR"
  [ -d "$MYSHELL_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYSHELL_CONFIG_BACKUP_DIR"
  [ -f "$MYSHELL_CONFIG_DIR/$MYSHELL_CONFIG_FILE" ] &&
    cp -Rf "$MYSHELL_CONFIG_DIR/$MYSHELL_CONFIG_FILE" "$MYSHELL_CONFIG_BACKUP_DIR/$MYSHELL_CONFIG_FILE.$$"
  cat <<EOF >"$MYSHELL_CONFIG_DIR/$MYSHELL_CONFIG_FILE"
# Settings for myshell
MYSHELL_SEARCH_PATH="${MYSHELL_SEARCH_PATH:-/usr/local/bin:/bin:/sbin:/usr/bin:/usr/sbin:/usr/games}"

# Notification settings
MYSHELL_GOOD_MESSAGE="${MYSHELL_GOOD_MESSAGE:-Everything Went OK}"
MYSHELL_ERROR_MESSAGE="${MYSHELL_ERROR_MESSAGE:-Well that didn\'t work}"
MYSHELL_NOTIFY_ENABLED="${MYSHELL_NOTIFY_ENABLED:-yes}"
MYSHELL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYSHELL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYSHELL_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYSHELL_OUTPUT_COLOR="${MYSHELL_OUTPUT_COLOR:-5}"
MYSHELL_OUTPUT_COLOR_GOOD="${MYSHELL_OUTPUT_COLOR_GOOD:-2}"
MYSHELL_OUTPUT_COLOR_ERROR="${MYSHELL_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYSHELL_CONFIG_DIR/$MYSHELL_CONFIG_FILE" ]; then
    printf_green "Your config file for myshell has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__passwd() {
  password=
  printf_read_passwd "6" "Please enter your password: " "password"
  if [ -z "$password" ]; then
    printf_exit 1 1 "Password is required"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__vars() {
  local PATH="$MYSHELL_SEARCH_PATH"
  newshell="$(grep $shell /etc/shells | head -n 1 2>/dev/null)"
  newshellname="$(basename $newshell 2>/dev/null)"
  if [ -z "$newshell" ] && [ -z "$newshellname" ]; then
    printf_exit "$shell doesn't exist in /etc/shells"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__list_shells() {
  [ -f "/etc/shells" ] && sort -u "/etc/shells" | sed '/^\#/d;/^$/d' | printf_readline "3"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__success() {
  printf_green "shell has been changed to $newshell"
  printf_custom "3" "You will need to logout for the changes to take effect"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__failure() {
  printf_exit "Failed to change the shell to $newshell"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__del() {
  local del_shell="$*"
  local tmpshell="/tmp/shells"
  if [ $# = 0 ]; then
    printf_help "Usage: myshell --del shellname | myshell --del zsh"
  else
    __requiresudo true
    for f in $del_shell; do
      if grep -q "$f" /etc/shells; then
        grep -Fv "$f" /etc/shells >"$tmpshell"
        sudo mv -f "$tmpshell" /etc/shells
        printf_green "$f has been removed from /etc/shells"
      else
        printf_red "$f isn't in /etc/shells"
      fi
    done
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__add() {
  local add_shell="$*"
  local PATH="$MYSHELL_SEARCH_PATH"
  local tmpshell="/tmp/shells"
  __requiresudo true
  if [ $# = 0 ]; then
    for f in bash fish zsh; do
      cmd="$(command -v $f)"
      if [ -f "$cmd" ]; then
        if ! grep -q "$f" /etc/shells; then
          echo "$(command -v $f)" | sudo tee -a /etc/shells &>/dev/null &&
            printf_green "Successfuly added $cmd to /etc/shells"
        else
          printf_yellow "$cmd is already in /etc/shells"
        fi
      else
        printf_red "The command $f does not exist"
      fi
    done
    exit $?
  else
    for f in $add_shell; do
      cmd="$(command -v $f)"
      if [ -f "$cmd" ]; then
        if ! grep -q "$f" /etc/shells; then
          echo "$(command -v $f)" | sudo tee -a /etc/shells &>/dev/null &&
            printf_green "Successfuly added $cmd to /etc/shells"
        else
          printf_yellow "$cmd is already in /etc/shells"
        fi
      else
        printf_red "The command $f does not exist"
      fi
    done
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MYSHELL_LOG_DIR="${MYSHELL_LOG_DIR:-$HOME/.local/log/myshell}"
MYSHELL_CACHE_DIR="${MYSHELL_CACHE_DIR:-$HOME/.cache/myshell}"
MYSHELL_CONFIG_DIR="${MYSHELL_CONFIG_DIR:-$HOME/.config/myscripts/myshell}"
MYSHELL_CONFIG_BACKUP_DIR="${MYSHELL_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/myshell/backups}"
MYSHELL_TEMP_DIR="${MYSHELL_TEMP_DIR:-$HOME/.local/tmp/system_scripts/myshell}"
MYSHELL_OPTIONS_DIR="${MYSHELL_OPTIONS_DIR:-$HOME/.local/share/myscripts/myshell/options}"
MYSHELL_TEMP_FILE="${MYSHELL_TEMP_FILE:-$(mktemp $MYSHELL_TEMP_DIR/XXXXXX 2>/dev/null)}"
MYSHELL_CONFIG_FILE="${MYSHELL_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYSHELL_OUTPUT_COLOR="${MYSHELL_OUTPUT_COLOR:-4}"
MYSHELL_OUTPUT_COLOR_2="${MYSHELL_OUTPUT_COLOR:-6}"
MYSHELL_OUTPUT_COLOR_GOOD="${MYSHELL_OUTPUT_COLOR_GOOD:-2}"
MYSHELL_OUTPUT_COLOR_ERROR="${MYSHELL_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYSHELL_GOOD_MESSAGE="${MYSHELL_GOOD_MESSAGE:-Everything Went OK}"
MYSHELL_ERROR_MESSAGE="${MYSHELL_ERROR_MESSAGE:-Well that didn\'t work}"
MYSHELL_NOTIFY_ENABLED="${MYSHELL_NOTIFY_ENABLED:-yes}"
MYSHELL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYSHELL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYSHELL_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
MYSHELL_SEARCH_PATH="${MYSHELL_SEARCH_PATH:-/usr/local/bin:/bin:/sbin:/usr/bin:/usr/sbin:/usr/games}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYSHELL_CONFIG_DIR/$MYSHELL_CONFIG_FILE" ] && . "$MYSHELL_CONFIG_DIR/$MYSHELL_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MYSHELL_LOG_DIR" ] || mkdir -p "$MYSHELL_LOG_DIR" &>/dev/null
[ -d "$MYSHELL_TEMP_DIR" ] || mkdir -p "$MYSHELL_TEMP_DIR" &>/dev/null
[ -d "$MYSHELL_CACHE_DIR" ] || mkdir -p "$MYSHELL_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MYSHELL_CONFIG_DIR/$MYSHELL_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,list,add:,del:,set:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MYSHELL_CWD="$2"
    shift 2
    ;;
  --list)
    shift 1
    printf_custom "2" "Available shells:"
    __list_shells
    exit
    ;;
  --add)
    shift 1
    SETOPTS="add"
    SHELL_LIST="$1"
    shift 1
    ;;
  --del)
    shift 1
    SETOPTS="del"
    SHELL_LIST="$1"
    shift 1
    ;;
  --set)
    shift 1
    SETOPTS="set"
    SHELL_LIST="$1"
    shift 1
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MYSHELL_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYSHELL_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYSHELL_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYSHELL_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYSHELL_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash chsh || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
PATH="$MYSHELL_SEARCH_PATH"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case ${SETOPTS:-$1} in
add)
  shift 1
  __add "${*:-$SHELL_LIST}"
  ;;

del)
  shift 1
  __del "${*:-$SHELL_LIST}"
  ;;

set)
  shift 1
  myshell "${*:-$SHELL_LIST}"
  exit $?
  ;;

*)
  [ -n "$1" ] && shell="$(builtin type -P "$1" 2>/dev/null)"
  [ -n "$shell" ] && __vars "$shell"
  case "$(uname -s)" in
  Linux)
    if [ -z "$1" ]; then
      printf_green "Your default shell is $(__getuser_cur_shell)"
      printf_blue "to change your default shell run:"
      printf_exit 4 0 "myshell shellname | myshell fish"
    elif __getuser_shell "$newshell"; then
      printf_custom "The old and new shell are both $newshellname"
    else
      if [ -f "$newshell" ]; then
        __passwd
        echo -n "$(echo $password | chsh -s "$newshell" "$USER" &>/dev/null)" &&
          __getuser_shell "$newshell" && __success || __failure
      else
        printf_red "$newshell is an invalid shell"
      fi
    fi
    ;;

  Darwin)
    if [ -z "$1" ]; then
      printf_green "Your default shell is $SHELL"
      printf_blue "to change your default shell"
      printf_exit 4 0 "run myshell shellname | myshell fish"
    elif [ -f "$newshell" ]; then
      __passwd
      echo -n "$(echo $password | chsh -u "$USER" -s "$newshell" | printf_readline "3" | grep -vq "chsh")" && __success || __failure
    else
      printf_red "$newshell is an invalid shell"
    fi
    ;;

  *) printf_exit "Unsupported OS" ;;
  esac
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
