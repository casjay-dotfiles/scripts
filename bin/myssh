# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -euo pipefail
trap 'exitCode=${exitCode:-$?};[ -f "$MYSSH_TEMP_FILE" ] && rm -Rf "$MYSSH_TEMP_FILE" &>/dev/null' EXIT
[ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# = 0 ]; } && myterminal -e "$APPNAME" "$*" && { exit || exit 1; }

