#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename $0)"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#set opts

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202103201731-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : myterminal --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Saturday, Mar 20, 2021 17:31 EDT
# @File          : myterminal
# @Description   : Open up terminal emulator
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# I'm sure there is a better way to do this
if [ -d "$1" ]; then
  PROJECT_DIR="$1" && shift 1
  COMMAND="$1" && shift 1
  COMMAND_ARGS="$*" && shift
elif [ -d "$2" ]; then
  COMMAND="$1" && shift 1
  PROJECT_DIR="$1" && shift 1
  COMMAND_ARGS="$PROJECT_DIR $*" && shift
else
  PROJECT_DIR="$PWD"
  COMMAND="$1" && shift 1
  COMMAND_ARGS="$*" && shift
fi
if [ "$PROJECT_DIR" != "$PWD" ]; then
  [ -d "$PROJECT_DIR" ] || __mkd "$PROJECT_DIR"
  cd "$PROJECT_DIR" || true
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import settings
MYTERMINAL_NOTIFICATIONS="${MYTERMINAL_NOTIFICATIONS:-no}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[ -f "$HOME/.config/myterminal/settings.conf" ] && . "$HOME/.config/myterminal/settings.conf"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate the config function
__config() {
  printf_green "Generating config file"
  __mkd "$HOME/.config/myterminal"
  cat <<EOF >"$HOME/.config/myterminal/settings.conf"
  # Settings for myterminal
MYTERMINAL="config"
MYTERMINAL="$MYTERMINAL"
MYTERMINAL_MULTIPLEX="screen"
MYTERMINAL_MULTIPLEX_OPTS=""
MYTERMINAL_NOTIFICATIONS="$MYTERMINAL_NOTIFICATIONS"

EOF
  if [ -f "$HOME/.config/myterminal/settings.conf" ]; then
    printf_green "File saved to: $HOME/.config/myterminal/settings.conf"
    [ -n "$MYTERMINAL_NOTIFICATIONS" ] && notifications "MyTerminal" "Config file saved to:\n$HOME/.config/myterminal/settings.conf"
  fi
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Create link function
__create_link() {
  case "$1" in
  *)
    if [ ! -z "$2" ]; then
      shift 1
      if cmd_exists "$1"; then
        printf_green "Linking $HOME/.local/bin/myterminal to $1"
        __ln_sf "$(builtin type -P $1)" "$HOME/.local/bin/myterminal"
        exit 0
      else
        printf_green "Linking $HOME/.local/bin/myterminal to $MYTERMINAL"
        __ln_sf "$MYTERMINAL" "$HOME/.local/bin/myterminal"
        exit 0
      fi
    fi
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Unset
if [ -z "$(builtin type -P "$MYTERMINAL")" ] || [ "$MYTERMINAL" = "myterminal" ]; then unset MYTERMINAL; fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Find the terminal app
if [ "$MYTERMINAL" != "config" ]; then
  if [ -z "$DISPLAY" ]; then
    if [ "$(builtin type -P "$MYTERMINAL_MULTIPLEX")" ]; then
      MYTERMINAL="$MYTERMINAL_MULTIPLEX $MYTERMINAL_MULTIPLEX_OPTS"
    elif cmd_exists tmux; then
      MYTERMINAL="tmux new"
    elif cmd_exists screen; then
      MYTERMINAL="screen"
    else
      MYTERMINAL="$SHELL -c"
    fi
  else
    if [ -n "$(builtin type -P termite 2>/dev/null)" ]; then
      MYTERMINAL="termite"
    elif [ -n "$(builtin type -P xfce4-terminal 2>/dev/null)" ]; then
      MYTERMINAL="xfce4-terminal"
    elif [ -n "$(builtin type -P qterminal 2>/dev/null)" ]; then
      MYTERMINAL="qterminal"
    elif [ -n "$(builtin type -P mate-terminal 2>/dev/null)" ]; then
      MYTERMINAL="mate-terminal"
    elif [ -n "$(builtin type -P i3-sensible-terminal 2>/dev/null)" ]; then
      MYTERMINAL="i3-sensible-terminal"
    elif [ -n "$(builtin type -P rofi-sensible-terminal 2>/dev/null)" ]; then
      MYTERMINAL="rofi-sensible-terminal"
    elif [ -n "$(builtin type -P terminology 2>/dev/null)" ]; then
      MYTERMINAL="terminology"
    elif [ -n "$(builtin type -P gnome-terminal 2>/dev/null)" ]; then
      MYTERMINAL="gnome-terminal"
    elif [ -f "/Applications/iTerm.app/Contents/MacOS/iTerm2" ]; then
      MYTERMINAL="/Applications/iTerm.app/Contents/MacOS/iTerm2"
    elif [ -f "/System/Applications/Utilities/terminal.app/Contents/MacOS/terminal" ]; then
      MYTERMINAL="/System/Applications/Utilities/terminal.app/Contents/MacOS/terminal"
    elif [ -n "$(builtin type -P xterm 2>/dev/null)" ]; then
      MYTERMINAL="xterm"
    elif [ -n "$(builtin type -P uxterm 2>/dev/null)" ]; then
      MYTERMINAL="uxterm"
    elif [ -n "$(builtin type -P garcon-terminal-handler 2>/dev/null)" ]; then
      MYTERMINAL="garcon-terminal-handler"
    fi
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
MYTERMINAL_NAME="$(basename "$MYTERMINAL" 2>/dev/null)"
export TERMINAL="$MYTERMINAL"
export MYTERMINAL="$MYTERMINAL"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -z "$MYTERMINAL" ]; then
  [ "$MYTERMINAL_NOTIFICATIONS" = "yes" ] && notifications "MyTerminal" "No terminal emulators are installed"
  printf_newline "\n"
  printf_exit 1 1 "No terminal emulators are installed"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
while getopts ":*" removeopt; do
  case $removeopt in *) shift ;; esac
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
case $1 in
config)
  shift 1
  __config
  ;;

create | link)
  shift 1
  __create_link "$@"
  ;;

*)
  COMMAND="${COMMAND:-$SHELL}"
  COMMAND_ARGS="${COMMAND_ARGS:-}"
  opt="-e"
  [ -e "$COMMAND" ] || cmd_exists "$COMMAND" || printf_exit 2 1 "$COMMAND does not seem to exist"
  [ "$MYTERMINAL_NOTIFICATIONS" = "yes" ] && notifications "MyTerminal" "Attempting to launch $MYTERMINAL_NAME"
  if [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_TTY" ] || [ -z "$DISPLAY" ]; then
    printf_blue "Executing $COMMAND $COMMAND_ARGS"
    printf_blue "in shell due to no display"
    if [ "$MYTERMINAL" = "$MYTERMINAL_MULTIPLEX" ]; then
      $MYTERMINAL_MULTIPLEX $MYTERMINAL_MULTIPLEX_OPTS $COMMAND $COMMAND_ARGS
    elif cmd_exists screen; then
      screen $COMMAND $COMMAND_ARGS &>/dev/null
    elif cmd_exists tmux; then
      tmux new $COMMAND $COMMAND_ARGS &>/dev/null
    else
      $COMMAND $COMMAND_ARGS
      $SHELL
    fi
  else
    if [ -f "$HOME/.local/bin/myterminal" ]; then
      ~/.local/bin/myterminal ${OPTIONS:-$opt} "$COMMAND $COMMAND_ARGS" &>/dev/null &
      disown
    else
      $MYTERMINAL ${OPTIONS:-$opt} "$COMMAND $COMMAND_ARGS" &>/dev/null &
      disown
    fi
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
exit 0
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
