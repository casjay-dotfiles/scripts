#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$MYTERMINAL_TEMP_FILE" ] && rm -Rf "$MYTERMINAL_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : myterminal --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : myterminal
# @Description   : Open up terminal emulator
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  local TERMINAL="${TERMINAL// /}"
  local MYTERMINAL="${MYTERMINAL// /}"
  printf_green "Generating the config file in"
  printf_green "$MYTERMINAL_CONFIG_DIR/$MYTERMINAL_CONFIG_FILE"
  [ -d "$MYTERMINAL_CONFIG_DIR" ] || mkdir -p "$MYTERMINAL_CONFIG_DIR"
  [ -d "$MYTERMINAL_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYTERMINAL_CONFIG_BACKUP_DIR"
  [ -f "$MYTERMINAL_CONFIG_DIR/$MYTERMINAL_CONFIG_FILE" ] &&
    cp -Rf "$MYTERMINAL_CONFIG_DIR/$MYTERMINAL_CONFIG_FILE" "$MYTERMINAL_CONFIG_BACKUP_DIR/$MYTERMINAL_CONFIG_FILE.$$"
  cat <<EOF >"$MYTERMINAL_CONFIG_DIR/$MYTERMINAL_CONFIG_FILE"
# Settings for myterminal
MYTERMINAL_NAME="${MYTERMINAL_NAME:-config}"
MYTERMINAL="${MYTERMINAL:-$TERMINAL}"
MYTERMINAL_MULTIPLEX="${MYTERMINAL_MULTIPLEX:-tmux}"
MYTERMINAL_MULTIPLEX_OPTS="${MYTERMINAL_MULTIPLEX_OPTS:--f $CASJAYSDEVDIR/templates/tmux.conf}"
MYTERMINAL_NOTIFICATIONS="${MYTERMINAL_NOTIFICATIONS:-}"
OLD_MYTERMINAL="${OLD_MYTERMINAL:-$MYTERMINAL}"
# Notification settings
MYTERMINAL_GOOD_MESSAGE="${MYTERMINAL_GOOD_MESSAGE:-Everything Went OK}"
MYTERMINAL_ERROR_MESSAGE="${MYTERMINAL_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYTERMINAL_NOTIFY_ENABLED="${MYTERMINAL_NOTIFY_ENABLED:-no}"
MYTERMINAL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYTERMINAL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYTERMINAL_NOTIFY_CLIENT_ICON}"
# Colorization settings
MYTERMINAL_OUTPUT_COLOR="${MYTERMINAL_OUTPUT_COLOR:-5}"
MYTERMINAL_OUTPUT_COLOR_GOOD="${MYTERMINAL_OUTPUT_COLOR_GOOD:-2}"
MYTERMINAL_OUTPUT_COLOR_ERROR="${MYTERMINAL_OUTPUT_COLOR_ERROR:-1}"
EOF
  if [ -f "$MYTERMINAL_CONFIG_DIR/$MYTERMINAL_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      unset INIT_CONFIG
      eval bash -c "$APPNAME $@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__create_link() {
  local MYTERMINAL="$1"
  local MYTERMINAL_NAME="$(basename "$MYTERMINAL" 2>/dev/null)"
  shift $#
  [[ -f "$HOME/.local/bin/myterminal" ]] && unlink "$HOME/.local/bin/myterminal" &>/dev/null
  if cmd_exists "$MYTERMINAL"; then
    printf_green "Linking $HOME/.local/bin/myterminal to $MYTERMINAL"
    __ln_sf "$MYTERMINAL" "$HOME/.local/bin/myterminal"
  fi
  printf_blue "Updating the config file"
  __rm_rf "$MYTERMINAL_CONFIG_DIR/$MYTERMINAL_CONFIG_FILE"
  __gen_config &>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MYTERMINAL_LOG_DIR="${MYTERMINAL_LOG_DIR:-$HOME/.local/log/myterminal}"
MYTERMINAL_CACHE_DIR="${MYTERMINAL_CACHE_DIR:-$HOME/.cache/myterminal}"
MYTERMINAL_CONFIG_DIR="${MYTERMINAL_CONFIG_DIR:-$HOME/.config/myscripts/myterminal}"
MYTERMINAL_CONFIG_BACKUP_DIR="${MYTERMINAL_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/myterminal/backups}"
MYTERMINAL_TEMP_DIR="${MYTERMINAL_TEMP_DIR:-$HOME/.local/tmp/system_scripts/myterminal}"
MYTERMINAL_OPTIONS_DIR="${MYTERMINAL_OPTIONS_DIR:-$HOME/.local/share/myscripts/myterminal/options}"
MYTERMINAL_TEMP_FILE="${MYTERMINAL_TEMP_FILE:-$(mktemp $MYTERMINAL_TEMP_DIR/XXXXXX 2>/dev/null)}"
MYTERMINAL_CONFIG_FILE="${MYTERMINAL_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYTERMINAL_OUTPUT_COLOR="${MYTERMINAL_OUTPUT_COLOR:-4}"
MYTERMINAL_OUTPUT_COLOR_2="${MYTERMINAL_OUTPUT_COLOR:-6}"
MYTERMINAL_OUTPUT_COLOR_GOOD="${MYTERMINAL_OUTPUT_COLOR_GOOD:-2}"
MYTERMINAL_OUTPUT_COLOR_ERROR="${MYTERMINAL_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYTERMINAL_GOOD_MESSAGE="${MYTERMINAL_GOOD_MESSAGE:-Everything Went OK}"
MYTERMINAL_ERROR_MESSAGE="${MYTERMINAL_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYTERMINAL_NOTIFY_ENABLED="${MYTERMINAL_NOTIFY_ENABLED:-no}"
MYTERMINAL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYTERMINAL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYTERMINAL_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYTERMINAL_CONFIG_DIR/$MYTERMINAL_CONFIG_FILE" ] && . "$MYTERMINAL_CONFIG_DIR/$MYTERMINAL_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$MYTERMINAL_LOG_DIR" ] || mkdir -p "$MYTERMINAL_LOG_DIR" &>/dev/null
[ -d "$MYTERMINAL_TEMP_DIR" ] || mkdir -p "$MYTERMINAL_TEMP_DIR" &>/dev/null
[ -d "$MYTERMINAL_CACHE_DIR" ] || mkdir -p "$MYTERMINAL_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MYTERMINAL_CONFIG_DIR/$MYTERMINAL_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
if [ -z "$(builtin type -P "$MYTERMINAL" 2>/dev/null)" ] || [ "$MYTERMINAL" = "myterminal" ]; then unset MYTERMINAL; fi
if [ "$MYTERMINAL_NAME" = "config" ] || [[ "$MYTERMINAL_NAME" = "" ]]; then
  if [ -z "$DISPLAY" ]; then
    if [ "$(builtin type -P "$MYTERMINAL_MULTIPLEX")" ]; then
      MYTERMINAL="$MYTERMINAL_MULTIPLEX $MYTERMINAL_MULTIPLEX_OPTS"
    elif cmd_exists tmux; then
      MYTERMINAL="tmux new"
    elif cmd_exists screen; then
      MYTERMINAL="screen"
    else
      MYTERMINAL="$(builtin type -P "${SHELL:-bash}")"
    fi
  else
    if [ -n "$(builtin type -P termite 2>/dev/null)" ]; then
      MYTERMINAL="termite"
    elif [ -n "$(builtin type -P xfce4-terminal 2>/dev/null)" ]; then
      MYTERMINAL="xfce4-terminal"
    elif [ -n "$(builtin type -P qterminal 2>/dev/null)" ]; then
      MYTERMINAL="qterminal"
    elif [ -n "$(builtin type -P mate-terminal 2>/dev/null)" ]; then
      MYTERMINAL="mate-terminal"
    elif [ -n "$(builtin type -P i3-sensible-terminal 2>/dev/null)" ]; then
      MYTERMINAL="i3-sensible-terminal"
    elif [ -n "$(builtin type -P rofi-sensible-terminal 2>/dev/null)" ]; then
      MYTERMINAL="rofi-sensible-terminal"
    elif [ -n "$(builtin type -P terminology 2>/dev/null)" ]; then
      MYTERMINAL="terminology"
    elif [ -n "$(builtin type -P gnome-terminal 2>/dev/null)" ]; then
      MYTERMINAL="gnome-terminal"
    elif [ -f "/Applications/iTerm.app/Contents/MacOS/iTerm2" ]; then
      MYTERMINAL="/Applications/iTerm.app/Contents/MacOS/iTerm2"
    elif [ -f "/System/Applications/Utilities/terminal.app/Contents/MacOS/terminal" ]; then
      MYTERMINAL="/System/Applications/Utilities/terminal.app/Contents/MacOS/terminal"
    elif [ -n "$(builtin type -P xterm 2>/dev/null)" ]; then
      MYTERMINAL="xterm"
    elif [ -n "$(builtin type -P uxterm 2>/dev/null)" ]; then
      MYTERMINAL="uxterm"
    elif [ -n "$(builtin type -P garcon-terminal-handler 2>/dev/null)" ]; then
      MYTERMINAL="garcon-terminal-handler"
    fi
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
MYTERMINAL_NAME="$(basename "$MYTERMINAL" 2>/dev/null)"
export TERMINAL="$MYTERMINAL"
export MYTERMINAL="$MYTERMINAL"
{ [ "$MYTERMINAL_NAME" = "config" ] || [[ "$MYTERMINAL_NAME" = "" ]]; } && __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -z "$MYTERMINAL" ]; then
  [ "$MYTERMINAL_NOTIFICATIONS" = "yes" ] && notifications "MyTerminal" "No terminal emulators are installed"
  printf_newline "\n"
  printf_exit 1 1 "No terminal emulators are installed"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,link:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
case "$@" in
--options)
  shift 1
  [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
  [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
  [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
  [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
  exit $?
  ;;
--version)
  shift 1
  __version
  exit $?
  ;;
--help)
  shift 1
  __help
  exit $?
  ;;
--config)
  shift 1
  __gen_config
  exit $?
  ;;
--dir)
  MYTERMINAL_CWD="$2"
  shift 2
  ;;
--link)
  shift 1
  OLD_MYTERMINAL="${OLD_MYTERMINAL:-$MYTERMINAL}"
  __create_link "${1:-$MYTERMINAL}"
  exit $?
  ;;
-e)
  shift 1
  ;;
--)
  shift 1
  ;;
esac
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$MYTERMINAL_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYTERMINAL_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYTERMINAL_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYTERMINAL_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYTERMINAL_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[[ "$1" = "-e" ]] && shift 1
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
SHELL="$(builtin type -P "${SHELL:-bash}")"
COMMAND="${*:-$SHELL}"
opt="-e"
[ -e "$COMMAND" ] || cmd_exists "$1" || printf_exit 2 1 "$COMMAND does not seem to exist"
[ "$MYTERMINAL_NOTIFY_ENABLED" = "yes" ] && notifications "MyTerminal" "Attempting to launch $MYTERMINAL_NAME"
if [[ -n "$SSH_CONNECTION" ]] || [[ -n "$SSH_TTY" ]] || [[ -z "$DISPLAY" ]]; then
  printf_blue "Executing $COMMAND"
  printf_blue "in shell due to no display"
  if [ "$MYTERMINAL" = "$MYTERMINAL_MULTIPLEX" ]; then
    $MYTERMINAL_MULTIPLEX $MYTERMINAL_MULTIPLEX_OPTS $COMMAND
  elif cmd_exists screen; then
    screen $COMMAND &>/dev/null
  elif cmd_exists tmux; then
    tmux new $COMMAND &>/dev/null
  else
    $COMMAND
    $SHELL
  fi
else
  if [ -f "$HOME/.local/bin/myterminal" ]; then
    exec "$HOME/.local/bin/myterminal" $COMMAND &>/dev/null &
  #disown
  elif [[ "$TERMINAL_APP" = "TRUE" ]]; then
    eval $MYTERMINAL ${OPTIONS:-$opt} $COMMAND &>/dev/null &
  else
    __exec $MYTERMINAL ${OPTIONS:-$opt} $COMMAND &>/dev/null &
    #disown
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
