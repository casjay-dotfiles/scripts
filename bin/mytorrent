APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
#if [ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; }; then TERMINAL_APP="TRUE" myterminal -e "$APPNAME $*" && exit || exit 1; fi
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  local TORRENT="${TORRENT// /}"
  local MYTORRENT="${MYTORRENT// /}"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$MYTORRENT_CONFIG_DIR/$MYTORRENT_CONFIG_FILE"
  [ -d "$MYTORRENT_CONFIG_DIR" ] || mkdir -p "$MYTORRENT_CONFIG_DIR"
  [ -d "$MYTORRENT_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYTORRENT_CONFIG_BACKUP_DIR"
  [ -f "$MYTORRENT_CONFIG_DIR/$MYTORRENT_CONFIG_FILE" ] &&
    cp -Rf "$MYTORRENT_CONFIG_DIR/$MYTORRENT_CONFIG_FILE" "$MYTORRENT_CONFIG_BACKUP_DIR/$MYTORRENT_CONFIG_FILE.$$"
  cat <<EOF >"$MYTORRENT_CONFIG_DIR/$MYTORRENT_CONFIG_FILE"
# Settings for mytorrent
MYTORRENT_NAME="${MYTORRENT_NAME:-config}"
MYTORRENT="${MYTORRENT:-$TORRENT}"
MYTORRENT_OPTIONS="${MYTORRENT_OPTIONS:-}"
MYTORRENT_CONSOLE="${MYTORRENT_CONSOLE:-}"
MYTORRENT_SERVER="${MYTORRENT_SERVER:-localhost:9091}"

# Notification settings
MYTORRENT_GOOD_MESSAGE="${MYTORRENT_GOOD_MESSAGE:-Everything Went OK}"
MYTORRENT_ERROR_MESSAGE="${MYTORRENT_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYTORRENT_NOTIFY_ENABLED="${MYTORRENT_NOTIFY_ENABLED:-yes}"
MYTORRENT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYTORRENT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYTORRENT_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYTORRENT_OUTPUT_COLOR="${MYTORRENT_OUTPUT_COLOR:-5}"
MYTORRENT_OUTPUT_COLOR_GOOD="${MYTORRENT_OUTPUT_COLOR_GOOD:-2}"
MYTORRENT_OUTPUT_COLOR_ERROR="${MYTORRENT_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYTORRENT_CONFIG_DIR/$MYTORRENT_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    # if [[ "$INIT_CONFIG" = "TRUE" ]]; then
    #   unset INIT_CONFIG
    #   eval bash -c "$APPNAME $*"
    #   exit
    # fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__create_term() {
  cat <<EOF | tee
  #!/usr/bin/env sh
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202104040050-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : mytorrent --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Sunday, Apr 04, 2021 00:50 EDT
# @File          : mytorrent
# @Description   : Using $MYTORRENT as mytorrent
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ ! -t 0 ]; then
  myterminal -e "$MYTORRENT \$MYTORRENT_OPTIONS \$*"
else
  $MYTORRENT \$MYTORRENT_OPTIONS \$*
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}

EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__create_link() {
  local MYTORRENT="$1"
  local MYTORRENT_NAME="$(basename "$MYTORRENT" 2>/dev/null)"
  shift $#
  if cmd_exists "$MYTORRENT"; then
    if [ "$MYTORRENT_CONSOLE" = "yes" ]; then
      printf_green "Generating the script for $MYTORRENT"
      __create_term >"$HOME/.local/bin/mytorrent"
      chmod 755 "$HOME/.local/bin/mytorrent" &>/dev/null
    else
      printf_green "Linking $HOME/.local/bin/mytorrent to $MYTORRENT"
      __ln_sf "$(builtin type -P "$MYTORRENT")" "$HOME/.local/bin/mytorrent"
    fi
  else
    printf_green "Linking $HOME/.local/bin/mytorrent to $MYTORRENT"
    __ln_sf "$MYTORRENT" "$HOME/.local/bin/mytorrent"
  fi
  printf_blue "Updating the config file"
  __gen_config &>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__term() {
  $MYTORRENT --help | less
  while :; do
    printf_newline
    printf_read_input "2" "What command would you like to execute [q to exit]" "20" "CMD"
    if [ $CMD = '-q' ] || [ $CMD = 'q' ] || [ $CMD = 'quit' ] || [ $CMD = 'exit' ]; then exit; fi
    $MYTORRENT $CMD
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MYTORRENT_LOG_DIR="${MYTORRENT_LOG_DIR:-$HOME/.local/log/mytorrent}"
MYTORRENT_CACHE_DIR="${MYTORRENT_CACHE_DIR:-$HOME/.cache/mytorrent}"
MYTORRENT_CONFIG_DIR="${MYTORRENT_CONFIG_DIR:-$HOME/.config/myscripts/mytorrent}"
MYTORRENT_CONFIG_BACKUP_DIR="${MYTORRENT_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/mytorrent/backups}"
MYTORRENT_TEMP_DIR="${MYTORRENT_TEMP_DIR:-$HOME/.local/tmp/system_scripts/mytorrent}"
MYTORRENT_OPTIONS_DIR="${MYTORRENT_OPTIONS_DIR:-$HOME/.local/share/myscripts/mytorrent/options}"
MYTORRENT_CONFIG_FILE="${MYTORRENT_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYTORRENT_OUTPUT_COLOR="${MYTORRENT_OUTPUT_COLOR:-4}"
MYTORRENT_OUTPUT_COLOR_2="${MYTORRENT_OUTPUT_COLOR:-6}"
MYTORRENT_OUTPUT_COLOR_GOOD="${MYTORRENT_OUTPUT_COLOR_GOOD:-2}"
MYTORRENT_OUTPUT_COLOR_ERROR="${MYTORRENT_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYTORRENT_GOOD_MESSAGE="${MYTORRENT_GOOD_MESSAGE:-Everything Went OK}"
MYTORRENT_ERROR_MESSAGE="${MYTORRENT_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYTORRENT_NOTIFY_ENABLED="${MYTORRENT_NOTIFY_ENABLED:-yes}"
MYTORRENT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYTORRENT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYTORRENT_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
MYTORRENT="${MYTORRENT:-$TORRENT}"
MYTORRENT_CONSOLE="${MYTORRENT_CONSOLE:-}"
MYTORRENT_SERVER="${MYTORRENT_SERVER:-localhost:9091}"
MYTORRENT_OPTIONS="${MYTORRENT_OPTIONS:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MYTORRENT_CONFIG_DIR/$MYTORRENT_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYTORRENT_CONFIG_DIR/$MYTORRENT_CONFIG_FILE" ] && . "$MYTORRENT_CONFIG_DIR/$MYTORRENT_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$MYTORRENT_LOG_DIR" ] || mkdir -p "$MYTORRENT_LOG_DIR" &>/dev/null
[ -d "$MYTORRENT_TEMP_DIR" ] || mkdir -p "$MYTORRENT_TEMP_DIR" &>/dev/null
[ -d "$MYTORRENT_CACHE_DIR" ] || mkdir -p "$MYTORRENT_CACHE_DIR" &>/dev/null
MYTORRENT_TEMP_FILE="${MYTORRENT_TEMP_FILE:-$(mktemp $MYTORRENT_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$MYTORRENT_TEMP_FILE" ] && [ -f "$MYTORRENT_TEMP_FILE" ] && rm -Rf "$MYTORRENT_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$MYTORRENT_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYTORRENT_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYTORRENT_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYTORRENT_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYTORRENT_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
if [ -z "$(builtin type -P "$MYTORRENT")" ] || [ "$MYTORRENT" = "mytorrent" ]; then unset MYTORRENT; fi
if [ "$MYTORRENT_NAME" = "config" ] || [[ "$MYTORRENT_NAME" = "" ]]; then
  if [ -n "$(builtin type -P transmission-remote-gtk 2>/dev/null)" ]; then
    MYTORRENT="transmission-remote-gtk"
  elif [ -n "$(builtin type -P transmission-gtk 2>/dev/null)" ]; then
    MYTORRENT="transmission-gtk"
  elif [ -n "$(builtin type -P transmission-qt 2>/dev/null)" ]; then
    MYTORRENT="transmission-qt"
  elif [ -n "$(builtin type -P transmission-cli 2>/dev/null)" ]; then
    MYTORRENT="transmission-cli"
  elif [ -n "$(builtin type -P deluge 2>/dev/null)" ]; then
    MYTORRENT="deluge"
  elif [ -n "$(builtin type -P vuze 2>/dev/null)" ]; then
    MYTORRENT="vuze"
  elif [ -n "$(builtin type -P qbittorrent 2>/dev/null)" ]; then
    MYTORRENT="qbittorrent"
  elif [ -n "$(builtin type -P ktorrent 2>/dev/null)" ]; then
    MYTORRENT="ktorrent"
  elif [ -n "$(builtin type -P ctorrent 2>/dev/null)" ]; then
    MYTORRENT="ctorrent"
  elif [ -n "$(builtin type -P unworkable 2>/dev/null)" ]; then
    MYTORRENT="unworkable"
  elif [ -n "$(builtin type -P rtorrent 2>/dev/null)" ]; then
    MYTORRENT="rtorrent"
  elif [ -n "$(builtin type -P bitstormlite 2>/dev/null)" ]; then
    MYTORRENT="bitstormlite"
  elif [ -f "/Applications/Transmission.app/Contents/MacOS/Transmission" ]; then
    MYTORRENT="/Applications/Transmission.app/Contents/MacOS/Transmission"
  elif [ -n "$(builtin type -P transmission-remote 2>/dev/null)" ]; then
    MYTORRENT="transmission-remote"
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
MYTORRENT_NAME="$(basename $MYTORRENT 2>/dev/null)"
export TORRENT="$MYTORRENT"
export MYTORRENT="$MYTORRENT"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
case "$MYTORRENT_NAME" in
*-gtk* | *-qt*)
  export TERMINAL_APP=""
  ;;
transmission-remote | transmission-remote-* | transmission-cli)
  transmission_daemon="$(ps -aux | grep transmission-da | grep -v 'grep ' 2>/dev/null)"
  TRANSMISSION_REMOTE="true"
  export TERMINAL_APP="TRUE"
  if [[ -z "$MYTORRENT_SERVER" ]] || [[ "$MYTORRENT_SERVER" = "localhost" ]]; then
    [[ -z "$transmission_daemon" ]] && transmission-daemon &>/dev/null &
  fi
  ;;
esac
if grep -s "MYTORRENT_NAME" "$MYTORRENT_CONFIG_DIR/$MYTORRENT_CONFIG_FILE" | grep -q config; then __gen_config &>/dev/null; fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,term:,link:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MYTORRENT_CWD="$2"
    shift 2
    ;;
  --link)
    shift 1
    __create_link "${1:-$MYTORRENT}"
    exit $?
    ;;
  --term)
    shift 1
    __term "$1"
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -z "$MYTORRENT" ]; then
  printf_newline "\n"
  __notifications "MyTorrent" "No bittorrent clients are installed"
  printf_red "No bittorrent clients are installed"
  printf_pause 1 "Press any key to exit this window"
  exit
fi
ARGS="$*"
MYTORRENT_SERVER="${MYTORRENT_SERVER:-}"
OPEN="$MYTORRENT_OPTIONS $ARGS"
[ -n "$OPEN" ] || OPEN=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ "$TRANSMISSION_REMOTE" = "true" ]; then
  if [ "$MYTORRENT_SERVER" = "localhost" ] || [ "$MYTORRENT_SERVER" = "$(hostname -s)" ] || [ "$MYTORRENT_SERVER" = "$(hostname -f)" ]; then
    if [ -z "$transmission_daemon" ]; then
      transmission-daemon &>/dev/null && sleep 5 &&
        __notifications "Transmission server has been started" || __notifications "Transmission server failed to start"
    fi
  fi
  MYTORRENT_CONSOLE="yes"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__notifications "Attempting to launch $MYTORRENT_NAME"
if [ -f "$HOME/.local/bin/mytorrent" ]; then
  $HOME/.local/bin/mytorrent $OPEN
elif [[ $ARGS = *.torrent ]]; then
  if [[ "$MYTORRENT" =~ transmission ]]; then
    if cmd_exists transadd; then
      transadd "$ARGS" | grep -q "success" && true || false
    else
      transmission -a "$ARGS"
    fi
  elif [ -n "$DESKTOP_SESSION" ]; then
    xdg-open "$ARGS"
  else
    $MYTORRENT "$ARGS"
  fi
elif [ "$MYTORRENT_CONSOLE" = "yes" ]; then
  if [ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; }; then
    TERMINAL_APP="TRUE" myterminal -e "$APPNAME" "$OPEN"
  else
    $MYTORRENT ${OPEN:---help}
    bash -l
  fi
elif [ ${#ARGS} -eq 0 ] && [[ "$MYTORRENT_CONSOLE" != "yes" ]] && [[ "$MYTORRENT" =~ transmission ]]; then
  $MYTORRENT -m &>/dev/null &
else
  if [[ "$ARGS" = "" ]]; then
    $MYTORRENT &>/dev/null &
  else
    __exec $MYTORRENT $OPEN &>/dev/null
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
