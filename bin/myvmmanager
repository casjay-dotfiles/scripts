#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : myvmmanager --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : myvmmanager
# @Description   : Setup virtual machine manager
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
#if [ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; }; then  TERMINAL_APP="TRUE" myterminal -e "$APPNAME $*" && exit || exit 1; fi
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  local VMMANAGER="${VMMANAGER// /}"
  local MYVMMANAGER="${MYVMMANAGER// /}"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$MYVMMANAGER_CONFIG_DIR/$MYVMMANAGER_CONFIG_FILE"
  [ -d "$MYVMMANAGER_CONFIG_DIR" ] || mkdir -p "$MYVMMANAGER_CONFIG_DIR"
  [ -d "$MYVMMANAGER_CONFIG_BACKUP_DIR" ] || mkdir -p "$MYVMMANAGER_CONFIG_BACKUP_DIR"
  [ -f "$MYVMMANAGER_CONFIG_DIR/$MYVMMANAGER_CONFIG_FILE" ] &&
    cp -Rf "$MYVMMANAGER_CONFIG_DIR/$MYVMMANAGER_CONFIG_FILE" "$MYVMMANAGER_CONFIG_BACKUP_DIR/$MYVMMANAGER_CONFIG_FILE.$$"
  cat <<EOF >"$MYVMMANAGER_CONFIG_DIR/$MYVMMANAGER_CONFIG_FILE"
# Settings for myvmmanager
MYVMMANAGER_NAME="${MYVMMANAGER_NAME:-config}"
MYVMMANAGER="${MYVMMANAGER:-$VMMANAGER}"
MYVMMANAGER_CONSOLE="${MYVMMANAGER_CONSOLE:-}"
MYVMMANAGER_OPTIONS="${MYVMMANAGER_OPTIONS:-}"

# Notification settings
MYVMMANAGER_GOOD_MESSAGE="${MYVMMANAGER_GOOD_MESSAGE:-Everything Went OK}"
MYVMMANAGER_ERROR_MESSAGE="${MYVMMANAGER_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYVMMANAGER_NOTIFY_ENABLED="${MYVMMANAGER_NOTIFY_ENABLED:-yes}"
MYVMMANAGER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYVMMANAGER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYVMMANAGER_NOTIFY_CLIENT_ICON}"

# Colorization settings
MYVMMANAGER_OUTPUT_COLOR="${MYVMMANAGER_OUTPUT_COLOR:-5}"
MYVMMANAGER_OUTPUT_COLOR_GOOD="${MYVMMANAGER_OUTPUT_COLOR_GOOD:-2}"
MYVMMANAGER_OUTPUT_COLOR_ERROR="${MYVMMANAGER_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$MYVMMANAGER_CONFIG_DIR/$MYVMMANAGER_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__create_term() {
  cat <<EOF | tee
  #!/usr/bin/env sh
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202104040050-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : myvmmanager --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Sunday, Apr 04, 2021 00:50 EDT
# @File          : myvmmanager
# @Description   : Using $MYVMMANAGER as myvmmanager
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ ! -t 0 ]; then
  myterminal -e "$MYVMMANAGER \$MYVMMANAGER_OPTIONS \$*"
else
  $MYVMMANAGER \$MYVMMANAGER_OPTIONS \$*
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}

EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__create_link() {
  local MYVMMANAGER="$1"
  local MYVMMANAGER_NAME="$(basename "$MYVMMANAGER" 2>/dev/null)"
  shift $#
  if cmd_exists "$MYVMMANAGER"; then
    if [ "$MYVMMANAGER_CONSOLE" = "yes" ]; then
      printf_green "Generating the script for $MYVMMANAGER"
      __create_term >"$HOME/.local/bin/myvmmanager"
      chmod 755 "$HOME/.local/bin/myvmmanager" &>/dev/null
    else
      printf_green "Linking $HOME/.local/bin/myvmmanager to $MYVMMANAGER"
      __ln_sf "$(builtin type -P "$MYVMMANAGER")" "$HOME/.local/bin/myvmmanager"
    fi
  else
    printf_green "Linking $HOME/.local/bin/myvmmanager to $MYVMMANAGER"
    __ln_sf "$MYVMMANAGER" "$HOME/.local/bin/myvmmanager"
  fi
  printf_blue "Updating the config file"
  __gen_config &>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__term() {
  if [ $# = 0 ]; then
    $MYVMMANAGER --help | less
  else
    $MYVMMANAGER "$*"
  fi
  while :; do
    printf_newline
    printf_read_input "2" "What command would you like to execute [q to exit]" "20" "CMD"
    if { [[ "$CMD" = '-q' ]] || [[ "$CMD" = 'q' ]] || [[ "$CMD" = 'quit' ]] || [[ "$CMD" = 'exit' ]]; }; then exit; fi
    $MYVMMANAGER $CMD
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
MYVMMANAGER_LOG_DIR="${MYVMMANAGER_LOG_DIR:-$HOME/.local/log/myvmmanager}"
MYVMMANAGER_CACHE_DIR="${MYVMMANAGER_CACHE_DIR:-$HOME/.cache/myvmmanager}"
MYVMMANAGER_CONFIG_DIR="${MYVMMANAGER_CONFIG_DIR:-$HOME/.config/myscripts/myvmmanager}"
MYVMMANAGER_CONFIG_BACKUP_DIR="${MYVMMANAGER_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/myvmmanager/backups}"
MYVMMANAGER_TEMP_DIR="${MYVMMANAGER_TEMP_DIR:-$HOME/.local/tmp/system_scripts/myvmmanager}"
MYVMMANAGER_OPTIONS_DIR="${MYVMMANAGER_OPTIONS_DIR:-$HOME/.local/share/myscripts/myvmmanager/options}"
MYVMMANAGER_CONFIG_FILE="${MYVMMANAGER_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
MYVMMANAGER_OUTPUT_COLOR="${MYVMMANAGER_OUTPUT_COLOR:-4}"
MYVMMANAGER_OUTPUT_COLOR_2="${MYVMMANAGER_OUTPUT_COLOR:-6}"
MYVMMANAGER_OUTPUT_COLOR_GOOD="${MYVMMANAGER_OUTPUT_COLOR_GOOD:-2}"
MYVMMANAGER_OUTPUT_COLOR_ERROR="${MYVMMANAGER_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
MYVMMANAGER_GOOD_MESSAGE="${MYVMMANAGER_GOOD_MESSAGE:-Everything Went OK}"
MYVMMANAGER_ERROR_MESSAGE="${MYVMMANAGER_ERROR_MESSAGE:-Well something seems to have gone wrong}"
MYVMMANAGER_NOTIFY_ENABLED="${MYVMMANAGER_NOTIFY_ENABLED:-yes}"
MYVMMANAGER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
MYVMMANAGER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$MYVMMANAGER_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
MYVMMANAGER="${MYVMMANAGER:-$VMMANAGER}"
MYVMMANAGER_OPTIONS="${MYVMMANAGER_OPTIONS:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$MYVMMANAGER_CONFIG_DIR/$MYVMMANAGER_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$MYVMMANAGER_CONFIG_DIR/$MYVMMANAGER_CONFIG_FILE" ] && . "$MYVMMANAGER_CONFIG_DIR/$MYVMMANAGER_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$MYVMMANAGER_LOG_DIR" ] || mkdir -p "$MYVMMANAGER_LOG_DIR" &>/dev/null
[ -d "$MYVMMANAGER_TEMP_DIR" ] || mkdir -p "$MYVMMANAGER_TEMP_DIR" &>/dev/null
[ -d "$MYVMMANAGER_CACHE_DIR" ] || mkdir -p "$MYVMMANAGER_CACHE_DIR" &>/dev/null
MYVMMANAGER_TEMP_FILE="${MYVMMANAGER_TEMP_FILE:-$(mktemp $MYVMMANAGER_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$MYVMMANAGER_TEMP_FILE" ] && [ -f "$MYVMMANAGER_TEMP_FILE" ] && rm -Rf "$MYVMMANAGER_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$MYVMMANAGER_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${MYVMMANAGER_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${MYVMMANAGER_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${MYVMMANAGER_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${MYVMMANAGER_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
if [ -z "$(builtin type -P "$MYVMMANAGER")" ] || [ "$MYVMMANAGER" = "myvmmanager" ]; then unset MYVMMANAGER; fi
if [ "$MYVMMANAGER_NAME" = "config" ] || [[ "$MYVMMANAGER_NAME" = "" ]]; then
  if [ -n "$(builtin type -P VirtualBox 2>/dev/null)" ]; then
    MYVMMANAGER="VirtualBox"
  elif [ -n "$(builtin type -P VMWare 2>/dev/null)" ]; then
    MYVMMANAGER="VMWare"
  elif [ -n "$(builtin type -P virt-manager 2>/dev/null)" ]; then
    MYVMMANAGER="virt-manager"
  elif [ -n "$(builtin type -P kubectl 2>/dev/null)" ]; then
    MYVMMANAGER="kubectl"
  elif [ -n "$(builtin type -P docker 2>/dev/null)" ]; then
    MYVMMANAGER="docker"
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
MYVMMANAGER_NAME="$(basename $MYVMMANAGER 2>/dev/null)"
export VMMANAGER="$MYVMMANAGER"
export MYVMMANAGER="$MYVMMANAGER"
case $MYVMMANAGER_NAME in
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
docker | kubectl | virt-manager)
  MYVMMANAGER_CONSOLE="yes"
  export TERMINAL_APP="TRUE"
  ;;
esac
if grep -s "MYVMMANAGER_NAME" "$MYVMMANAGER_CONFIG_DIR/$MYVMMANAGER_CONFIG_FILE" | grep -q config; then __gen_config &>/dev/null; fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="l:,t"
LONGOPTS="options,config,version,help,dir:,term:,link:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    MYVMMANAGER_CWD="$2"
    shift 2
    ;;
  --link)
    shift 1
    __create_link "${2:-$MYVMMANAGER}"
    exit $?
    ;;
  --term)
    shift 1
    __term "$1"
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -z "$MYVMMANAGER" ]; then
  printf_newline "\n"
  __notifications "No Virtual Machine Managers are installed"
  printf_red "No Virtual Machine Managers are installed"
  printf_pause 1 "Press any key to exit this window"
  exit
fi
ARGS="${*:-}"
OPEN="$MYVMMANAGER_OPTIONS $ARGS"
[ -n "$OPEN" ] || OPEN=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__notifications "Attempting to launch $MYVMMANAGER_NAME"
if [ -f "$HOME/.local/bin/myvmmanager" ]; then
  "$HOME/.local/bin/myvmmanager" "$ARGS"
elif [ "$MYVMMANAGER_CONSOLE" = "yes" ]; then
  if [ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; }; then
    TERMINAL_APP="TRUE" myterminal -e "$APPNAME" "$OPEN"
  else
    $MYVMMANAGER ${OPEN:---help}
    bash -l
  fi
else
  __exec $MYVMMANAGER $OPEN &>/dev/null
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
