#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -euo pipefail
trap 'exitCode=${exitCode:-$?};[ -f "$NETSTATG_TEMP_FILE" ] && rm -Rf "$NETSTATG_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : netstatg --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : netstatg
# @Description   : grep netstat
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$NETSTATG_CONFIG_DIR/$NETSTATG_CONFIG_FILE"
  [ -d "$NETSTATG_CONFIG_DIR" ] || mkdir -p "$NETSTATG_CONFIG_DIR"
  [ -d "$NETSTATG_CONFIG_BACKUP_DIR" ] || mkdir -p "$NETSTATG_CONFIG_BACKUP_DIR"
  [ -f "$NETSTATG_CONFIG_DIR/$NETSTATG_CONFIG_FILE" ] &&
    cp -Rf "$NETSTATG_CONFIG_DIR/$NETSTATG_CONFIG_FILE" "$NETSTATG_CONFIG_BACKUP_DIR/$NETSTATG_CONFIG_FILE.$$"
  cat <<EOF >"$NETSTATG_CONFIG_DIR/$NETSTATG_CONFIG_FILE"
# Settings for netstatg
NETSTATG_DEFAULT_OPTS="${NETSTATG_DEFAULT_NETSTAT_OPTS:-taupln}"
NETSTATG_DEFAULT_GREP_OPTS="${NETSTATG_DEFAULT_GREP_OPTS:-^}"

# Notification settings
NETSTATG_GOOD_MESSAGE="${NETSTATG_GOOD_MESSAGE:-Everything Went OK}"
NETSTATG_ERROR_MESSAGE="${NETSTATG_ERROR_MESSAGE:-Well that didn\'t work}"
NETSTATG_NOTIFY_ENABLED="${NETSTATG_NOTIFY_ENABLED:-yes}"
NETSTATG_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
NETSTATG_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$NETSTATG_NOTIFY_CLIENT_ICON}"

# Colorization settings
NETSTATG_OUTPUT_COLOR="${NETSTATG_OUTPUT_COLOR:-5}"
NETSTATG_OUTPUT_COLOR_GOOD="${NETSTATG_OUTPUT_COLOR_GOOD:-2}"
NETSTATG_OUTPUT_COLOR_ERROR="${NETSTATG_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$NETSTATG_CONFIG_DIR/$NETSTATG_CONFIG_FILE" ]; then
    printf_green "Your config file for netstatg has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
NETSTATG_CACHE_DIR="${NETSTATG_CACHE_DIR:-$HOME/.cache/netstatg}"
NETSTATG_CONFIG_DIR="${NETSTATG_CONFIG_DIR:-$HOME/.config/myscripts/netstatg}"
NETSTATG_OPTIONS_DIR="${NETSTATG_OPTIONS_DIR:-$HOME/.local/share/myscripts/netstatg/options}"
NETSTATG_CONFIG_BACKUP_DIR="${NETSTATG_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/netstatg/backups}"
NETSTATG_TEMP_DIR="${NETSTATG_TEMP_DIR:-$HOME/.local/tmp/system_scripts/netstatg}"
NETSTATG_TEMP_FILE="${NETSTATG_TEMP_FILE:-$(mktemp $NETSTATG_TEMP_DIR/XXXXXX 2>/dev/null)}"
NETSTATG_CONFIG_FILE="${NETSTATG_CONFIG_FILE:-settings.conf}"
NETSTATG_GOOD_MESSAGE="${NETSTATG_GOOD_MESSAGE:-Everything Went OK}"
NETSTATG_ERROR_MESSAGE="${NETSTATG_ERROR_MESSAGE:-Well that didn\'t work}"
NETSTATG_NOTIFY_ENABLED="${NETSTATG_NOTIFY_ENABLED:-yes}"
NETSTATG_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
NETSTATG_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$NETSTATG_NOTIFY_CLIENT_ICON}"
NETSTATG_OUTPUT_COLOR="${NETSTATG_OUTPUT_COLOR:-5}"
NETSTATG_OUTPUT_COLOR_GOOD="${NETSTATG_OUTPUT_COLOR_GOOD:-2}"
NETSTATG_OUTPUT_COLOR_ERROR="${NETSTATG_OUTPUT_COLOR_ERROR:-1}"
NETSTATG_DEFAULT_GREP_OPTS="${NETSTATG_DEFAULT_GREP_OPTS:-^}"
NETSTATG_DEFAULT_NETSTAT_OPTS="${NETSTATG_DEFAULT_OPTS:-taupln}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$NETSTATG_TEMP_DIR" ] || mkdir -p "$NETSTATG_TEMP_DIR" &>/dev/null
[ -d "$NETSTATG_CACHE_DIR" ] || mkdir -p "$NETSTATG_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$NETSTATG_CONFIG_DIR/$NETSTATG_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$NETSTATG_CONFIG_DIR/$NETSTATG_CONFIG_FILE" ] &&
  . "$NETSTATG_CONFIG_DIR/$NETSTATG_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    NETSTATG_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$NETSTATG_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${NETSTATG_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${NETSTATG_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${NETSTATG_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${NETSTATG_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
gropts="${1:-$NETSTATG_DEFAULT_GREP_OPTS}"
nsopts="${2:-$NETSTATG_DEFAULT_OPTS}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
sudo netstat -"$nsopts" | grep -i --color=auto "$gropts"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
