# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$NOTIFICATIONS_CONFIG_DIR/$NOTIFICATIONS_CONFIG_FILE"
  [ -d "$NOTIFICATIONS_CONFIG_DIR" ] || mkdir -p "$NOTIFICATIONS_CONFIG_DIR"
  [ -d "$NOTIFICATIONS_CONFIG_BACKUP_DIR" ] || mkdir -p "$NOTIFICATIONS_CONFIG_BACKUP_DIR"
  [ -f "$NOTIFICATIONS_CONFIG_DIR/$NOTIFICATIONS_CONFIG_FILE" ] &&
    cp -Rf "$NOTIFICATIONS_CONFIG_DIR/$NOTIFICATIONS_CONFIG_FILE" "$NOTIFICATIONS_CONFIG_BACKUP_DIR/$NOTIFICATIONS_CONFIG_FILE.$$"
  cat <<EOF >"$NOTIFICATIONS_CONFIG_DIR/$NOTIFICATIONS_CONFIG_FILE"
# Settings for notifications
NOTIFICATIONS_HOST="${NOTIFICATIONS_HOST:-$NOTIFYD_HOST}"
NOTIFICATIONS_PORT="${NOTIFICATIONS_PORT:-${NOTIFYD_PORT:-65001}}"
NOTIFICATIONS_CLIENT="${NOTIFICATIONS_CLIENT:-no}"

# Option Settings

# Notification settings
NOTIFICATIONS_GOOD_MESSAGE="${NOTIFICATIONS_GOOD_MESSAGE:-}"
NOTIFICATIONS_ERROR_MESSAGE="${NOTIFICATIONS_ERROR_MESSAGE:-}"
NOTIFICATIONS_NOTIFY_ENABLED="${NOTIFICATIONS_NOTIFY_ENABLED:-yes}"
NOTIFICATIONS_NOTIFY_CLIENT_NAME="${NOTIFICATIONS_NOTIFY_CLIENT_NAME:-$APPNAME}"
NOTIFICATIONS_NOTIFY_CLIENT_ICON="${NOTIFICATIONS_NOTIFY_CLIENT_ICON:-com.github.timecraft.notifier}"
NOTIFICATIONS_NOTIFY_CLIENT_URGENCY="${NOTIFICATIONS_NOTIFY_CLIENT_URGENCY:-normal}"

# Colorization settings
NOTIFICATIONS_OUTPUT_COLOR="${NOTIFICATIONS_OUTPUT_COLOR:-5}"
NOTIFICATIONS_OUTPUT_COLOR_GOOD="${NOTIFICATIONS_OUTPUT_COLOR_GOOD:-2}"
NOTIFICATIONS_OUTPUT_COLOR_ERROR="${NOTIFICATIONS_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$NOTIFICATIONS_CONFIG_DIR/$NOTIFICATIONS_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__nc_send() { $netcat -c "$1" "$2" 2>>"$_LOG" && true || $netcat -w 1 "$1" "$2" 2>>"$_LOG" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_bg() {
  local notifyDir="${TMP:-/tmp}/notifications/process"
  [ -f "$notifyDir/kill" ] && __rm_rf $notifyDir/kill
  notifications "notifications" "Starting server: to stop make the file $notifyDir/kill"
  __mkd "$notifyDir"
  while :; do
    for f in $notifyDir/*; do
      if [ -f "$f" ]; then
        title="$(cat "$f" | awk '{print $1}' 2>/dev/null)"
        message="$(cat "$f" | sed 's#'"$(cat "$f" | awk '{print $1}')"' ##g' 2>/dev/null)"
        notifications "$title" "$message"
      fi
      rm -Rf "$f"
      sleep 30
      [ -f "$notifyDir/kill" ] && break || continue
    done
    if [ -f "$notifyDir/kill" ]; then
      __rm_rf "$notifyDir"/*
      notifications "notifications" "Stopping background proccess"
      break
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__notify_send() {
  local CLIENT_NAME="$NOTIFY_CLIENT_NAME"
  local CLIENT_ICON="$NOTIFY_CLIENT_ICON"
  local CLIENT_URGENCY="$NOTIFY_CLIENT_URGENCY"
  if [ "$(uname -s)" = "Darwin" ]; then
    [[ "$1" = *ask ]] && exit 0
    osascript -e "display notification \"${2}\" with title \"$1\"" || return
  elif [ "$(uname -s)" = "Linux" ]; then
    DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u ${USER})/bus"
    XUSERS=($(who | grep -E "\(:[0-9](\.[0-9])*\)" | awk '{print $1$5}' | sort -u | grep "$USER"))
    if cmd_exists notify-send; then
      [[ "$1" = *ask ]] && exit 0
      notify-send --app-name="$CLIENT_NAME" -u "$CLIENT_URGENCY" -i "$CLIENT_ICON" "$@"
    elif cmd_exists notify-send.sh; then
      [[ "$1" = *ask ]] && exit 0
      notify-send.sh --app-name="$CLIENT_NAME" -u "$CLIENT_URGENCY" -i "$CLIENT_ICON" "$@"
    else
      [[ "$1" = *ask ]] && exit 1
      if [ -n "$1" ]; then
        echo "$*" >/dev/null
      else
        printf_exit 1 1 "There is no notify app installed: Install notify-send, dunst, deadd"
      fi
    fi
    NAME=("${XUSER/(/ }")
    DISPLAY="${NAME[1]/)/}"
  else
    exit 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__notifications_cli() {
  __netcat_test
  __mkd "$TMP/notify-client"
  local title="$1"
  local msg="$2"
  local _PATH="$(mktemp ${TMPDIR:-/tmp}/notify-client/XXX.tmp)"
  local _LOG="${TMPDIR:-/tmp}/notify-client.log"
  printf_green "Attempting to send $msg to $NOTIFICATIONS_HOST on $NOTIFICATIONS_PORT" 2>>"$_LOG"
  notifications "Daemon" "Attempting to send $msg to $NOTIFICATIONS_HOST on $NOTIFICATIONS_PORT" 2>>"$_LOG"
  printf "%s\n" "$title" "$msg" >"$_PATH" 2>>"$_LOG" &&
    cat "$_PATH" 2>>"$_LOG" | __nc_send "$NOTIFICATIONS_HOST" "$NOTIFICATIONS_PORT" 2>>"$_LOG" &&
    __rm_rf "$_PATH" && sleep 3 && return 0 || {
    notifications "Daemon" "Failed to send message: ensure the server is running"
    return 1
  }
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__notifications_all() {
  local title="$1"
  local msg="$2"
  if [ "$(uname -s)" = "Linux" ]; then
    shift
    XUSERS=($(who | grep -E "\(:[0-9](\.[0-9])*\)" | awk '{print $1$5}' | sort -u))
    for XUSER in ${XUSERS[*]}; do
      NAME=("${XUSER//(:[0-9])/}")
      DISPLAY="${NAME[1]/)/}"
      DBUS_ADDRESS=unix:path=/run/user/"$(id -u ${NAME[0]})"/bus
      sudo -u "${NAME[0]}" DISPLAY="${DISPLAY}" \
        DBUS_SESSION_BUS_ADDRESS="${DBUS_ADDRESS}" \
        PATH="${PATH}" \
        notify-send --app-name="${NOTIFY_CLIENT_NAME:-$APPNAME}" -u "${NOTIFY_CLIENT_URGENCY:-normal}" -i "${NOTIFY_CLIENT_ICON:-com.github.timecraft.notifier}" "$title" "$msg" || return 0
      cmd_exists wall && echo "$title: $msg" | wall
      printf_console "3" "$title: $msg" >/dev/fd/0
    done
  else
    __notifications "$title" "$msg" || return 0
    cmd_exists wall && echo "$title: $msg" | wall
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
NOTIFICATIONS_LOG_DIR="${NOTIFICATIONS_LOG_DIR:-$HOME/.local/log/notifications}"
NOTIFICATIONS_CACHE_DIR="${NOTIFICATIONS_CACHE_DIR:-$HOME/.cache/notifications}"
NOTIFICATIONS_CONFIG_DIR="${NOTIFICATIONS_CONFIG_DIR:-$HOME/.config/myscripts/notifications}"
NOTIFICATIONS_CONFIG_BACKUP_DIR="${NOTIFICATIONS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/notifications/backups}"
NOTIFICATIONS_TEMP_DIR="${NOTIFICATIONS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/notifications}"
NOTIFICATIONS_OPTIONS_DIR="${NOTIFICATIONS_OPTIONS_DIR:-$HOME/.local/share/myscripts/notifications/options}"
NOTIFICATIONS_CONFIG_FILE="${NOTIFICATIONS_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
NOTIFICATIONS_OUTPUT_COLOR="${NOTIFICATIONS_OUTPUT_COLOR:-4}"
NOTIFICATIONS_OUTPUT_COLOR_2="${NOTIFICATIONS_OUTPUT_COLOR:-6}"
NOTIFICATIONS_OUTPUT_COLOR_GOOD="${NOTIFICATIONS_OUTPUT_COLOR_GOOD:-2}"
NOTIFICATIONS_OUTPUT_COLOR_ERROR="${NOTIFICATIONS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
NOTIFICATIONS_GOOD_MESSAGE="${NOTIFICATIONS_GOOD_MESSAGE:-}"
NOTIFICATIONS_ERROR_MESSAGE="${NOTIFICATIONS_ERROR_MESSAGE:-}"
NOTIFICATIONS_NOTIFY_ENABLED="${NOTIFICATIONS_NOTIFY_ENABLED:-yes}"
NOTIFICATIONS_NOTIFY_CLIENT_NAME="${NOTIFICATIONS_NOTIFY_CLIENT_NAME:-$APPNAME}"
NOTIFICATIONS_NOTIFY_CLIENT_ICON="${NOTIFICATIONS_NOTIFY_CLIENT_ICON:-com.github.timecraft.notifier}"
NOTIFICATIONS_NOTIFY_CLIENT_URGENCY="${NOTIFICATIONS_NOTIFY_CLIENT_URGENCY:-normal}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
NOTIFICATIONS_HOST="${NOTIFICATIONS_HOST:-$NOTIFYD_HOST}"
NOTIFICATIONS_PORT="${NOTIFICATIONS_PORT:-${NOTIFYD_PORT:-65001}}"
NOTIFICATIONS_CLIENT="${NOTIFICATIONS_CLIENT:-no}"
NOTIFICATIONS_CLIENT_NAME="${NOTIFICATIONS_CLIENT_NAME:-$APPNAME}"
NOTIFICATIONS_CLIENT_URGENY="${NOTIFICATIONS_CLIENT_URGENY:-normal}"
NOTIFICATIONS_CLIENT_ICON="${NOTIFICATIONS_CLIENT_ICON:-com.github.timecraft.notifier}"
NOTIFICATIONS_APPNAME="${NOTIFICATIONS_NOTIFY_CLIENT_NAME:-$APPNAME}"
NOTIFICATIONS_URGENY="${NOTIFICATIONS_URGENY:-NOTIFICATIONS_NOTIFY_CLIENT_URGENCY}"
NOTIFICATIONS_ICON="${NOTIFICATIONS_CLIENT_ICON:-com.github.timecraft.notifier}"
netcat="${netcat:-$(type -P netcat 2>/dev/null || type -P nc 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$NOTIFICATIONS_CONFIG_DIR/$NOTIFICATIONS_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$NOTIFICATIONS_CONFIG_DIR/$NOTIFICATIONS_CONFIG_FILE" ] && . "$NOTIFICATIONS_CONFIG_DIR/$NOTIFICATIONS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$NOTIFICATIONS_LOG_DIR" ] || mkdir -p "$NOTIFICATIONS_LOG_DIR" &>/dev/null
[ -d "$NOTIFICATIONS_TEMP_DIR" ] || mkdir -p "$NOTIFICATIONS_TEMP_DIR" &>/dev/null
[ -d "$NOTIFICATIONS_CACHE_DIR" ] || mkdir -p "$NOTIFICATIONS_CACHE_DIR" &>/dev/null
NOTIFICATIONS_TEMP_FILE="${NOTIFICATIONS_TEMP_FILE:-$(mktemp $NOTIFICATIONS_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$NOTIFICATIONS_TEMP_FILE" ] && [ -f "$NOTIFICATIONS_TEMP_FILE" ] && rm -Rf "$NOTIFICATIONS_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$NOTIFICATIONS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    local title msg
    local exitCode=0
    NOTIFY_GOOD_MESSAGE="${NOTIFY_GOOD_MESSAGE:-$NOTIFICATIONS_GOOD_MESSAGE}"
    NOTIFY_ERROR_MESSAGE="${NOTIFY_ERROR_MESSAGE:-$NOTIFICATIONS_ERROR_MESSAGE}"
    NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$NOTIFICATIONS_NOTIFY_CLIENT_NAME}"
    NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$NOTIFICATIONS_NOTIFY_CLIENT_ICON}"
    NOTIFY_CLIENT_URGENCY="${NOTIFY_CLIENT_URGENCY:-$NOTIFICATIONS_NOTIFY_CLIENT_URGENCY}"
    export NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_CLIENT_URGENCY
    if [ $# = 0 ]; then
      NOTIFY_CLIENT_ICON="dialog-error-symbolic"
      NOTIFY_CLIENT_URGENCY="critical"
      export NOTIFY_CLIENT_ICON NOTIFY_CLIENT_URGENCY
      title="$NOTIFY_CLIENT_NAME"
      msg="Nothing was sent to notify you of"
      __notify_send "$title" "$msg" && exitCode=0 || exitCode=1
    elif [ $# -lt 2 ]; then
      title="$NOTIFY_CLIENT_NAME"
      msg="$1"
      __notify_send "$title" "$msg" && exitCode=0 || exitCode=1
    elif [ $# -gt 1 ]; then
      title="$1"
      msg="$2"
      __notify_send "$title" "$msg" && exitCode=0 || exitCode=1
    fi
    if [ "$NOTIFICATIONS_CLIENT" = "yes" ] && [ -n "$NOTIFICATIONS_HOST" ]; then
      __notifications_cli "$title" "$msg" && exitCode=0 || exitCode=1
    else
      exitCode=1
    fi
    unset NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE NOTIFY_CLIENT_NAME
    unset NOTIFY_CLIENT_ICON NOTIFY_CLIENT_URGENCY
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,bg,client,all"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    NOTIFICATIONS_CWD="$2"
    shift 2
    ;;
  --bg)
    OPTS="bg"
    shift 1
    ;;
  --client)
    OPTS=client
    shift 1
    ;;
  --all)
    OPTS=all
    shift 1
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "${1:-$OPTS}" in
bg)
  shift 1
  __run_bg &
  exit
  ;;

client)
  shift 1
  if [ ${#} -eq 0 ] && [ -p "/dev/stdin" ]; then
    title="${NOTIFY_CLIENT_NAME:-$APPNAME}"
    msg="$(</dev/stdin)"
    shift
  else
    if [ ${#} -eq 1 ]; then
      title="${NOTIFY_CLIENT_NAME:-$APPNAME}"
      msg="$*"
    else
      title="$1"
      shift 1
      msg="$*"
    fi
  fi
  if [ -n "$NOTIFICATIONS_HOST" ]; then
    __notifications_cli "$title" "$msg"
  else
    notifications "Daemon" "Please set NOTIFICATIONS_HOST variable to your server"
    printf_exit 1 1 "Please set NOTIFICATIONS_HOST: variable to your server $NOTIFICATIONS_HOST"
  fi
  ;;

all)
  shift 1
  if [ ${#} -eq 0 ] && [ -p "/dev/stdin" ]; then
    title="${NOTIFY_CLIENT_NAME:-$APPNAME}"
    msg="$(</dev/stdin)"
    shift
  else
    if [ ${#} -eq 1 ]; then
      title="${NOTIFY_CLIENT_NAME:-$APPNAME}"
      msg="$(</dev/stdin)"
      shift
    else
      if [ ${#} -eq 1 ]; then
        title="${NOTIFY_CLIENT_NAME:-$APPNAME}"
        msg="$*"
      else
        title="$1"
        shift 1
        msg="$*"
      fi
    fi
  fi
  __notifications_all "$title" "$msg"
  ;;

-)
  shift 1
  title="${NOTIFY_CLIENT_NAME:-$APPNAME}"
  msg="$(</dev/stdin)"
  __notifications "$title" "$msg"
  ;;

*)
  if [ ${#} -eq 0 ] && [ -p "/dev/stdin" ]; then
    title="${NOTIFY_CLIENT_NAME:-$APPNAME}"
    msg="$(</dev/stdin)"
    shift
  else
    if [ ${#} -eq 1 ]; then
      title="${NOTIFY_CLIENT_NAME:-$APPNAME}"
      msg="$*"
    else
      title="$1"
      shift 1
      msg="$*"
    fi
  fi
  if [ -z "$msg" ]; then
    __notifications "$@"
  else
    __notifications "$title" "$msg"
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
