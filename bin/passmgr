#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : passmgr --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : passmgr
# @Description   : wrapper for the pass command
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$PASSMGR_CONFIG_DIR/$PASSMGR_CONFIG_FILE"
  [ -d "$PASSMGR_CONFIG_DIR" ] || mkdir -p "$PASSMGR_CONFIG_DIR"
  [ -d "$PASSMGR_CONFIG_BACKUP_DIR" ] || mkdir -p "$PASSMGR_CONFIG_BACKUP_DIR"
  [ -f "$PASSMGR_CONFIG_DIR/$PASSMGR_CONFIG_FILE" ] &&
    cp -Rf "$PASSMGR_CONFIG_DIR/$PASSMGR_CONFIG_FILE" "$PASSMGR_CONFIG_BACKUP_DIR/$PASSMGR_CONFIG_FILE.$$"
  cat <<EOF >"$PASSMGR_CONFIG_DIR/$PASSMGR_CONFIG_FILE"
# Settings for passmgr
PASSMGR_GIT_URL=""
PASSWORD_STORE_KEY="${PASSWORD_STORE_KEY}"
PASSWORD_STORE_UMASK="${PASSWORD_STORE_UMASK:-077}"
PASSWORD_STORE_CLIP_TIME="${PASSWORD_STORE_CLIP_TIME:-60}"
PASSWORD_STORE_DIR="${PASSWORD_STORE_DIR:-$HOME/.local/share/pass-store}"
PASSWORD_STORE_ENABLE_EXTENSIONS="${PASSWORD_STORE_ENABLE_EXTENSIONS:-true}"
PASSWORD_STORE_EXTENSIONS_DIR="${PASSWORD_STORE_EXTENSIONS_DIR:-$PASSWORD_STORE_DIR/.extensions}"
PASSMGR_BACKUP_DATE_FMT="\$(date +%F)"
PASSWORD_STORE_BACKUP="${PASSWORD_STORE_BACKUP:-$HOME/.local/backups/passmgr/$(hostname).$PASSMGR_BACKUP_DATE_FMT.tar}"
PASSMGR_FORCE_INSTALL="false"
PASSMGR_UPDATE_URL="${PASSMGR_UPDATE_URL:-https://git.zx2c4.com/password-store/plain/src/password-store.sh}"

# Notification settings
PASSMGR_GOOD_MESSAGE="${PASSMGR_GOOD_MESSAGE:-Everything Went OK}"
PASSMGR_ERROR_MESSAGE="${PASSMGR_ERROR_MESSAGE:-Well something seems to have gone wrong}"
PASSMGR_NOTIFY_ENABLED="${PASSMGR_NOTIFY_ENABLED:-yes}"
PASSMGR_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PASSMGR_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PASSMGR_NOTIFY_CLIENT_ICON}"

# Colorization settings
PASSMGR_OUTPUT_COLOR="${PASSMGR_OUTPUT_COLOR:-5}"
PASSMGR_OUTPUT_COLOR_GOOD="${PASSMGR_OUTPUT_COLOR_GOOD:-2}"
PASSMGR_OUTPUT_COLOR_ERROR="${PASSMGR_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$PASSMGR_CONFIG_DIR/$PASSMGR_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__update_pass() {
  local PASS_BIN="$(builtin type -P pass 2>/dev/null)"
  wget -O /tmp/pass-store.sh "$PASSMGR_UPDATE_URL" && [ -f "/tmp/pass-store.sh" ] &&
    chmod -f 755 /tmp/pass-store.sh && __mv_f /tmp/pass-store.sh "$HOME/.local/bin/pass" &&
    return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
PASSMGR_LOG_DIR="${PASSMGR_LOG_DIR:-$HOME/.local/log/passmgr}"
PASSMGR_CACHE_DIR="${PASSMGR_CACHE_DIR:-$HOME/.cache/passmgr}"
PASSMGR_CONFIG_DIR="${PASSMGR_CONFIG_DIR:-$HOME/.config/myscripts/passmgr}"
PASSMGR_CONFIG_BACKUP_DIR="${PASSMGR_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/passmgr/backups}"
PASSMGR_TEMP_DIR="${PASSMGR_TEMP_DIR:-$HOME/.local/tmp/system_scripts/passmgr}"
PASSMGR_OPTIONS_DIR="${PASSMGR_OPTIONS_DIR:-$HOME/.local/share/myscripts/passmgr/options}"
PASSMGR_CONFIG_FILE="${PASSMGR_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
PASSMGR_OUTPUT_COLOR="${PASSMGR_OUTPUT_COLOR:-4}"
PASSMGR_OUTPUT_COLOR_2="${PASSMGR_OUTPUT_COLOR:-6}"
PASSMGR_OUTPUT_COLOR_GOOD="${PASSMGR_OUTPUT_COLOR_GOOD:-2}"
PASSMGR_OUTPUT_COLOR_ERROR="${PASSMGR_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
PASSMGR_GOOD_MESSAGE="${PASSMGR_GOOD_MESSAGE:-Everything Went OK}"
PASSMGR_ERROR_MESSAGE="${PASSMGR_ERROR_MESSAGE:-Well something seems to have gone wrong}"
PASSMGR_NOTIFY_ENABLED="${PASSMGR_NOTIFY_ENABLED:-yes}"
PASSMGR_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PASSMGR_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PASSMGR_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
PASSWORD_STORE_KEY="${PASSWORD_STORE_KEY:-}"
PASSWORD_STORE_UMASK="${PASSWORD_STORE_UMASK:-077}"
PASSWORD_STORE_CLIP_TIME="${PASSWORD_STORE_CLIP_TIME:-60}"
PASSWORD_STORE_DIR="${PASSWORD_STORE_DIR:-$HOME/.local/share/pass-store}"
PASSWORD_STORE_ENABLE_EXTENSIONS="${PASSWORD_STORE_ENABLE_EXTENSIONS:-true}"
PASSWORD_STORE_EXTENSIONS_DIR="${PASSWORD_STORE_EXTENSIONS_DIR:-$PASSWORD_STORE_DIR/.extensions}"
PASSWORD_STORE_BACKUP="${PASSWORD_STORE_BACKUP:-$HOME/.local/backups/passmgr/$(hostname).$(date +%F).tar}"
PASSMGR_FORCE_INSTALL="${PASSMGR_FORCE_INSTALL:-false}"
PASSMGR_UPDATE_URL="${PASSMGR_UPDATE_URL:-https://git.zx2c4.com/password-store/plain/src/password-store.sh}"
PASSMGR_GIT_URL="${PASSMGR_GIT_URL:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$PASSMGR_CONFIG_DIR/$PASSMGR_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$PASSMGR_CONFIG_DIR/$PASSMGR_CONFIG_FILE" ] && . "$PASSMGR_CONFIG_DIR/$PASSMGR_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$PASSMGR_LOG_DIR" ] || mkdir -p "$PASSMGR_LOG_DIR" &>/dev/null
[ -d "$PASSMGR_TEMP_DIR" ] || mkdir -p "$PASSMGR_TEMP_DIR" &>/dev/null
[ -d "$PASSMGR_CACHE_DIR" ] || mkdir -p "$PASSMGR_CACHE_DIR" &>/dev/null
PASSMGR_TEMP_FILE="${PASSMGR_TEMP_FILE:-$(mktemp $PASSMGR_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$PASSMGR_TEMP_FILE" ] && [ -f "$PASSMGR_TEMP_FILE" ] && rm -Rf "$PASSMGR_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$PASSMGR_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${PASSMGR_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${PASSMGR_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${PASSMGR_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${PASSMGR_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*f,i:,a"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:force,import:,all"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    PASSMGR_CWD="$2"
    shift 2
    ;;
  -f | --force)
    shift 1
    export FORCE_INSTALL="true"
    ;;
  -i | --import)
    URL=${2:-$PASSMGR_GIT_URL}
    shift 2
    ;;
  -a | --all)
    INSTALL_ALL="true"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if cmd_exists pass; then
  pass "$@"
else
  ask_yes_no_question "Would you like to install the pass program?" "pkmgr install pass || pkmgr install password-store || __update_pass" ||
    { printf_red "Install failed please try a manual install" && printf_custom "11" "See site at https://git.zx2c4.com/password-store/about/"; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
