#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$PASTEBIN_TEMP_FILE" ] && rm -Rf "$PASTEBIN_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : pastebin --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : pastebin
# @Description   : bash pastebin.com client
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE"
  [ -d "$PASTEBIN_CONFIG_DIR" ] || mkdir -p "$PASTEBIN_CONFIG_DIR"
  [ -d "$PASTEBIN_CONFIG_BACKUP_DIR" ] || mkdir -p "$PASTEBIN_CONFIG_BACKUP_DIR"
  [ -f "$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE" ] &&
    cp -Rf "$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE" "$PASTEBIN_CONFIG_BACKUP_DIR/$PASTEBIN_CONFIG_FILE.$$"
  cat <<EOF >"$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE"
# Settings for pastebin
# Change to your API Developer Key
#PASTEBIN_API_KEY=""
# Change to your pastebin.com username, if you want to log into your account
#PASTEBIN_USER_NAME=""
# Change to your pastebin.com password
#PASTEBIN_PASSWORD=""
# Set to 1 if you want to log into your account automatically
# (you may login with -l, -u, -p arguments also)
#PASTEBIN_LOGIN="0"
# Default paste title, if -n argument is not defined
#PASTEBIN_PASTE_NAME=""
# Default paste highlighting, if -f argument is not defined
# (see http://pastebin.com/api#5 for more)
#PASTEBIN_PASTE_FORMAT="text"
# Default private settings, if -p argument is not defined
# (0=public, 1=unlisted, 2=private)
#PASTEBIN_PASTE_PRIVATE="0"
# Default expire date, if -e argument is not defined
#PASTEBIN_PASTE_EXPIRES="N"

# Notification settings
PASTEBIN_GOOD_MESSAGE="${PASTEBIN_GOOD_MESSAGE:-Everything Went OK}"
PASTEBIN_ERROR_MESSAGE="${PASTEBIN_ERROR_MESSAGE:-Well that didn\'t work}"
PASTEBIN_NOTIFY_ENABLED="${PASTEBIN_NOTIFY_ENABLED:-yes}"
PASTEBIN_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PASTEBIN_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PASTEBIN_NOTIFY_CLIENT_ICON}"

# Colorization settings
PASTEBIN_OUTPUT_COLOR="${PASTEBIN_OUTPUT_COLOR:-5}"
PASTEBIN_OUTPUT_COLOR_GOOD="${PASTEBIN_OUTPUT_COLOR_GOOD:-2}"
PASTEBIN_OUTPUT_COLOR_ERROR="${PASTEBIN_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE" ]; then
    printf_green "Your config file for pastebin has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
auth_user() {
  if [ -z "$PASTEBIN_USER_NAME" ] || [ -z "$PASTEBIN_PASSWORD" ]; then
    echo "Username and/or password is undefined."
    echo "Please adjust 'PASTEBIN_USER_NAME' and 'PASTEBIN_PASSWORD' in the configuration file '$config_file'"
    exit 1
  fi
  server_reply="$(curl --silent --data "PASTEBIN_API_KEY=$PASTEBIN_API_KEY" --data-urlencode "PASTEBIN_USER_NAME=$PASTEBIN_USER_NAME" --data-urlencode "PASTEBIN_PASSWORD=$PASTEBIN_PASSWORD" "$api_url/api_login.php")"
  if [[ $server_reply == Bad* ]]; then
    echo "Username: $PASTEBIN_USER_NAME"
    echo "$server_reply"
    exit 1
  else
    api_user_key="$server_reply"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
_cat() {
  file=${1--}
  while IFS= read -r line; do
    printf '%s\n' "$line" # Or: env POSIXLY_CORRECT=1 echo "$line"
  done < <(cat -- "$file")
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
PASTEBIN_CACHE_DIR="${PASTEBIN_CACHE_DIR:-$HOME/.cache/pastebin}"
PASTEBIN_CONFIG_DIR="${PASTEBIN_CONFIG_DIR:-$HOME/.config/myscripts/pastebin}"
PASTEBIN_OPTIONS_DIR="${PASTEBIN_OPTIONS_DIR:-$HOME/.local/share/myscripts/pastebin/options}"
PASTEBIN_CONFIG_BACKUP_DIR="${PASTEBIN_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/pastebin/backups}"
PASTEBIN_TEMP_DIR="${PASTEBIN_TEMP_DIR:-$HOME/.local/tmp/system_scripts/pastebin}"
PASTEBIN_TEMP_FILE="${PASTEBIN_TEMP_FILE:-$(mktemp $PASTEBIN_TEMP_DIR/XXXXXX 2>/dev/null)}"
PASTEBIN_CONFIG_FILE="${PASTEBIN_CONFIG_FILE:-settings.conf}"
PASTEBIN_GOOD_MESSAGE="${PASTEBIN_GOOD_MESSAGE:-Everything Went OK}"
PASTEBIN_ERROR_MESSAGE="${PASTEBIN_ERROR_MESSAGE:-Well that didn\'t work}"
PASTEBIN_NOTIFY_ENABLED="${PASTEBIN_NOTIFY_ENABLED:-yes}"
PASTEBIN_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PASTEBIN_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PASTEBIN_NOTIFY_CLIENT_ICON}"
PASTEBIN_OUTPUT_COLOR="${PASTEBIN_OUTPUT_COLOR:-5}"
PASTEBIN_OUTPUT_COLOR_GOOD="${PASTEBIN_OUTPUT_COLOR_GOOD:-2}"
PASTEBIN_OUTPUT_COLOR_ERROR="${PASTEBIN_OUTPUT_COLOR_ERROR:-1}"
PASTEBIN_API_KEY="${PASTEBIN_API_KEY:-}"
PASTEBIN_USER_NAME="${PASTEBIN_USER_NAME:-}"
PASTEBIN_PASSWORD="${PASTEBIN_PASSWORD:-}"
PASTEBIN_LOGIN="${PASTEBIN_LOGIN:-0}"
PASTEBIN_PASTE_NAME="${PASTEBIN_PASTE_NAME:-}"
PASTEBIN_PASTE_FORMAT="${PASTEBIN_PASTE_FORMAT:-text}"
PASTEBIN_PASTE_PRIVATE="${PASTEBIN_PASTE_PRIVATE:-0}"
PASTEBIN_PASTE_EXPIRES="${PASTEBIN_PASTE_EXPIRES:-N}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$PASTEBIN_TEMP_DIR" ] || mkdir -p "$PASTEBIN_TEMP_DIR" &>/dev/null
[ -d "$PASTEBIN_CACHE_DIR" ] || mkdir -p "$PASTEBIN_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE" ] &&
  . "$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:,h,u:,p:,l,n:,f:,e:,r:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    PASTEBIN_CWD="$2"
    shift 2
    ;;
  l)
    PASTEBIN_LOGIN=1
    shift 1
    ;;
  u)
    PASTEBIN_USER_NAME="$OPTARG"
    PASTEBIN_LOGIN=1
    shift 2
    ;;
  p)
    PASTEBIN_PASSWORD="$OPTARG"
    shift 2
    ;;
  n)
    PASTEBIN_PASTE_NAME="$OPTARG"
    shift 2
    ;;
  f)
    PASTEBIN_PASTE_FORMAT="$OPTARG"
    shift 2
    ;;
  e)
    case $OPTARG in
    n | never)
      PASTEBIN_PASTE_EXPIRES=N
      shift 1
      ;;
    10M)
      PASTEBIN_PASTE_EXPIRES=10M
      shift 1
      ;;
    1H)
      PASTEBIN_PASTE_EXPIRES=1H
      shift 1
      ;;
    1D)
      PASTEBIN_PASTE_EXPIRES=1D
      shift 1
      ;;
    1M)
      PASTEBIN_PASTE_EXPIRES=1M
      shift 1
      ;;
    1W)
      PASTEBIN_PASTE_EXPIRES=1W
      shift 1
      ;;
    2W)
      PASTEBIN_PASTE_EXPIRES=2W
      shift 1
      ;;
    *)
      PASTEBIN_PASTE_EXPIRES=N
      ;;
    esac
    shift 1
    ;;
  r)
    case $OPTARG in
    public | 0)
      PASTEBIN_PASTE_PRIVATE=0
      shift 1
      ;;
    unlisted | 1)
      PASTEBIN_PASTE_PRIVATE=1
      shift 1
      ;;
    private | 2)
      if [ $PASTEBIN_LOGIN -ne 1 ]; then
        echo "You need to log in (option -l or -u) if you want to post private pastes."
        exit 1
      else
        PASTEBIN_PASTE_PRIVATE=2
      fi
      shift 1
      ;;
    esac
    shift 1
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$PASTEBIN_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${PASTEBIN_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${PASTEBIN_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${PASTEBIN_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${PASTEBIN_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash curl || exit 1 # exit 1 if not found
am_i_online --error || exit 1                # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
[ $PASTEBIN_LOGIN -ne 0 ] && auth_user
api_paste_code=$(_cat "$@")
curl -X POST -0 --show-error \
  --data "api_dev_key=$PASTEBIN_API_KEY" \
  --data "api_option=paste" \
  --data "api_paste_code=$api_paste_code" \
  --data "api_paste_format=$PASTEBIN_PASTE_FORMAT" \
  --data "api_paste_private=$PASTEBIN_PASTE_PRIVATE" \
  --data "api_paste_expire_date=$PASTEBIN_PASTE_EXPIRES" \
  --data "api_user_key=$api_user_key" \
  --data-urlencode "api_paste_name=$PASTEBIN_PASTE_NAME" \
  --data-urlencode "api_paste_code=$api_paste_code" \
  "$api_url/api_post.php"
printf_newline
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
