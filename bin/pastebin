# Generate config files
[ -f "$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE" ] ||
  [ "$*" = "--config" ] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE" ] &&
  . "$PASTEBIN_CONFIG_DIR/$PASTEBIN_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$PASTEBIN_LOG_DIR" ] ||
  mkdir -p "$PASTEBIN_LOG_DIR" |& __devnull
[ -d "$PASTEBIN_TEMP_DIR" ] ||
  mkdir -p "$PASTEBIN_TEMP_DIR" |& __devnull
[ -d "$PASTEBIN_CACHE_DIR" ] ||
  mkdir -p "$PASTEBIN_CACHE_DIR" |& __devnull
[ -d "$(dirname "$PASTEBIN_SAVED_FILE")" ] ||
  mkdir -p "$(dirname "$PASTEBIN_SAVED_FILE=")" |& __devnull
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
PASTEBIN_TEMP_FILE="${PASTEBIN_TEMP_FILE:-$(mktemp $PASTEBIN_TEMP_DIR/XXXXXX 2>/dev/null)}"
