# else
# SET_NEW_ARGS+=("$arg")
# fi
# done
# set -- "${SET_NEW_ARGS[@]}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set directory to first argument
# [ -d "$1" ] && PASTEBIN_CWD="$1" && shift 1 || PASTEBIN_CWD="${PASTEBIN_CWD:-$PWD}"
PASTEBIN_CWD="$(realpath "${PASTEBIN_CWD:-$PWD}" 2>/dev/null)"
# if [ -d "$PASTEBIN_CWD" ] && cd "$PASTEBIN_CWD"; then
# if [ "$PASTEBIN_SILENT" != "true" ] && [ "$CWD_SILENCE" != "true" ]; then
# printf_cyan "Setting working dir to $PASTEBIN_CWD"
# fi
# else
# printf_exit "💔 $PASTEBIN_CWD does not exist 💔"
# fi
export PASTEBIN_CWD
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set actions based on variables

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
#requiresudo "$0" "$@" || exit 2     # exit 2 if errors
#cmd_exists --error --ask bash || exit 3 # exit 3 if not found
#am_i_online --error || exit 4           # exit 4 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
[ "$PASTEBIN_LOGIN" -ne 0 ] && auth_user
if [ -p "/dev/stdin" ]; then
  PASTEBIN_POST_DATA="$(<"/dev/stdin")"
elif [ -f "$1" ]; then
  PASTEBIN_POST_DATA="$(<"$1")"
  PASTEBIN_PASTE_NAME="${PASTEBIN_PASTE_NAME:-$(basename "$1")}"
elif [ $# -ne 1 ]; then
  PASTEBIN_POST_DATA="$(echo "$@")"
  PASTEBIN_PASTE_NAME="${PASTEBIN_PASTE_NAME:-$1}"
else
  printf_exit "No data was received"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__execute_pastebin "$PASTEBIN_POST_DATA"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set exit code
exitCode="${exitCode:-$?}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
