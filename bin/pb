#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : pb --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : pb
# @Description   : Send output to a pastebin
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$PB_TEMP_FILE" ] && [ -f "$PB_TEMP_FILE" ] && rm -Rf "$PB_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$PB_CONFIG_DIR/$PB_CONFIG_FILE"
  [ -d "$PB_CONFIG_DIR" ] || mkdir -p "$PB_CONFIG_DIR"
  [ -d "$PB_CONFIG_BACKUP_DIR" ] || mkdir -p "$PB_CONFIG_BACKUP_DIR"
  [ -f "$PB_CONFIG_DIR/$PB_CONFIG_FILE" ] &&
    cp -Rf "$PB_CONFIG_DIR/$PB_CONFIG_FILE" "$PB_CONFIG_BACKUP_DIR/$PB_CONFIG_FILE.$$"
  cat <<EOF >"$PB_CONFIG_DIR/$PB_CONFIG_FILE"
# Settings for pb
PB_URL="${PRIVATE_PASTEBIN_URL:-$PB_URL}"
PB_API_URL="${PRIVATE_PASTEBIN_URL:-$PB_API_URL}"
PB_API_KEY="${PRIVATE_PASTEBIN_API_KEY:-$PB_API_KEY}"

# Notification settings
PB_GOOD_MESSAGE="${PB_GOOD_MESSAGE:-Everything Went OK}"
PB_ERROR_MESSAGE="${PB_ERROR_MESSAGE:-Well something seems to have gone wrong}"
PB_NOTIFY_ENABLED="${PB_NOTIFY_ENABLED:-yes}"
PB_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PB_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PB_NOTIFY_CLIENT_ICON}"

# Colorization settings
PB_OUTPUT_COLOR="${PB_OUTPUT_COLOR:-5}"
PB_OUTPUT_COLOR_GOOD="${PB_OUTPUT_COLOR_GOOD:-2}"
PB_OUTPUT_COLOR_ERROR="${PB_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$PB_CONFIG_DIR/$PB_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for pb has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__private() {
  local PB_API_URL="${PB_API_URL:-https://casjay.cc/api/create}"
  if [ $# -gt 0 ]; then
    paste=$(cat "$@")
  else
    paste=$(cat)
  fi
  printf "%s" "$paste" | curl -q -LSs -d lang="$language" -d name="$name" --data-urlencode text@- "$PB_API_URL"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
PB_LOG_DIR="${PB_LOG_DIR:-$HOME/.local/log/pb}"
PB_CACHE_DIR="${PB_CACHE_DIR:-$HOME/.cache/pb}"
PB_CONFIG_DIR="${PB_CONFIG_DIR:-$HOME/.config/myscripts/pb}"
PB_CONFIG_BACKUP_DIR="${PB_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/pb/backups}"
PB_TEMP_DIR="${PB_TEMP_DIR:-$HOME/.local/tmp/system_scripts/pb}"
PB_OPTIONS_DIR="${PB_OPTIONS_DIR:-$HOME/.local/share/myscripts/pb/options}"
PB_TEMP_FILE="${PB_TEMP_FILE:-$(mktemp $PB_TEMP_DIR/XXXXXX 2>/dev/null)}"
PB_CONFIG_FILE="${PB_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
PB_OUTPUT_COLOR="${PB_OUTPUT_COLOR:-4}"
PB_OUTPUT_COLOR_2="${PB_OUTPUT_COLOR:-6}"
PB_OUTPUT_COLOR_GOOD="${PB_OUTPUT_COLOR_GOOD:-2}"
PB_OUTPUT_COLOR_ERROR="${PB_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
PB_GOOD_MESSAGE="${PB_GOOD_MESSAGE:-Everything Went OK}"
PB_ERROR_MESSAGE="${PB_ERROR_MESSAGE:-Well something seems to have gone wrong}"
PB_NOTIFY_ENABLED="${PB_NOTIFY_ENABLED:-yes}"
PB_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PB_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PB_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
PB_URL="${PRIVATE_PASTEBIN_URL:-$PB_URL}"
PB_API_URL="${PRIVATE_PASTEBIN_API_URL:-$PB_API_URL}"
PB_API_KEY="${PRIVATE_PASTEBIN_API_KEY:-$PB_API_KEY}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$PB_CONFIG_DIR/$PB_CONFIG_FILE" ] && . "$PB_CONFIG_DIR/$PB_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$PB_LOG_DIR" ] || mkdir -p "$PB_LOG_DIR" &>/dev/null
[ -d "$PB_TEMP_DIR" ] || mkdir -p "$PB_TEMP_DIR" &>/dev/null
[ -d "$PB_CACHE_DIR" ] || mkdir -p "$PB_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$PB_CONFIG_DIR/$PB_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
unset title
unset private
unset language
unset expire
unset reply
name=${SUDO_USER:-$USER}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="t:,n:,p,l:,e:,r:,b:,a:"
LONGOPTS="options,config,version,help,dir:,title:,name:,private,language:,expire:,reply:,apikey:"
ARRAY="ix,0x0,nullbyte,sprunge,iopaste,clbin,uguu,lewd,fiery,catbox,dmca,dumpz,w1r3,pastebin,private"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    PB_CWD="$2"
    shift 2
    ;;
  -t | --title)
    title="$2"
    shift 2
    ;;
  -n | --name)
    name="$2"
    shift 2
    ;;
  -p | --private)
    shift 1
    private=1
    ;;
  -l | --language)
    language="$2"
    shift 2
    ;;
  -e | --expire)
    expire="$2"
    shift 2
    ;;
  -r | --reply)
    reply="$2"
    shift 2
    ;;
  -b)
    PASTE_URL="$2"
    shift 2
    ;;
  -a | --apikey)
    PASTE_APIKEY="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$PB_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${PB_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${PB_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${PB_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${PB_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
ARG="${2:-/dev/stdin}"
UA=${UA:="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/44.0.2403.157 Safari/537.36"}
PROGRAM=${0##*/}
PB_URL="${PB_URL:-}"
PB_API_KEY="${PASTE_APIKEY:-$PB_API_KEY}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
ix | ix.io)
  curl -A "$UA" -sF 'f:1=<-' http://ix.io <$ARG | printf_readline $PB_OUTPUT_COLOR
  ;;
0x0 | null | nullbyte | 0*)
  curl -A "$UA" -sF 'file=@-' https://0x0.st <$ARG | printf_readline $PB_OUTPUT_COLOR
  ;;
sprunge | sprunge.us | s*)
  curl -A "$UA" -sF 'sprunge=<-' http://sprunge.us <$ARG | printf_readline $PB_OUTPUT_COLOR
  ;;
iotek | iopaste | p.iotek.org | iop*)
  curl -A "$UA" -sT- https://p.iotek.org <$ARG | printf_readline $PB_OUTPUT_COLOR
  ;;
clbin | clbin.com | cl*)
  curl -A "$UA" -sF 'clbin=<-' https://clbin.com <$ARG | printf_readline $PB_OUTPUT_COLOR
  ;;
uguu | uguu.se | u*)
  curl -A "$UA" -sF 'file=@-' https://uguu.se/api.php?d=upload-tool <$ARG | printf_readline $PB_OUTPUT_COLOR
  ;;
lewd | lewd.se | l*)
  curl -A "$UA" -sF 'file=@-' https://lewd.se/api.php?d=upload-tool <$ARG | printf_readline $PB_OUTPUT_COLOR
  ;;
fiery | fiery.me | f*)
  curl -A "$UA" -sF 'files[]=@-' https://safe.fiery.me/api/upload <$ARG | grep -Po '"url":"[A-Za-z0-9]+.*?"' | sed 's/"url":"//;s/"//' | printf_readline $PB_OUTPUT_COLOR
  ;;
catbox | catbox.moe | cat*)
  curl -A "$UA" -sF 'reqtype=fileupload' -F 'fileToUpload=@-' https://catbox.moe/user/api.php <$ARG | printf_readline $PB_OUTPUT_COLOR
  ;;
dmca | dmca.gripe | gripe | dm*)
  curl -A "$UA" -sF 'files[]=@-' http://dmca.gripe/api/upload <$ARG | grep -Po '"url":"[A-Za-z0-9]+.*?"' | sed 's/"url":"//;s/"//;s/[\]//g' | printf_readline $PB_OUTPUT_COLOR
  ;;
dumpz | dumpz.org | du*)
  curl -A "$UA" -s --data-binary @- https://dumpz.org <$ARG | sed 's/http/&s/;s!$!/text/!' | printf_readline $PB_OUTPUT_COLOR
  ;;
w1r3 | wire | w1r3.net | w*)
  curl -sF 'upload=@-' https://w1r3.net <$ARG | printf_readline $PB_OUTPUT_COLOR
  ;;
pb | pastebin | pastebin.com)
  [ -z ${PB_API_DEV} ] && usage
  PRIVACY="${PRIVACY:-1}"
  if [ -n "${PRIVACY}" ]; then
    case ${PRIVACY} in
    public | 0)
      PRIVACY=0
      ;;
    unlisted | 1)
      PRIVACY=1
      ;;
    private | 2)
      PRIVACY=2
      ;;
    *)
      usage
      ;;
    esac
  fi
  qs="api_option=paste&api_dev_key=${PB_API_DEV}&api_paste_expire_date=N&api_paste_private=${PRIVACY}&api_paste_name=$(basename ${ARG})"
  [ -n "${PB_API_USR}" ] && [ -z ${ANON} ] && qs="${qs}&api_user_key=${PB_API_USR}"
  curl -A "$UA" -d "${qs}" --data-urlencode "api_paste_code=$(<$ARG)" http://pastebin.com/api/api_post.php | printf_readline $PB_OUTPUT_COLOR
  ;;
private)
  shift 1
  __private "$*" | printf_readline $PB_OUTPUT_COLOR
  ;;
*)
  __private "$*" | printf_readline $PB_OUTPUT_COLOR
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
