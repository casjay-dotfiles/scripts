#cmd_exists --error --ask bash || exit 3 # exit 3 if not found
#am_i_online --error || exit 4           # exit 4 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
PROGRAM=${0##*/}
SERVICE="$1" && shift 1
PB_PRIVATE_URL="${PB_PRIVATE_URL:-}"
PB_PRIVATE_API_KEY="${PB_PRIVATE_API_KEY:-$PASTE_APIKEY}"
{ [ -p "/dev/stdin" ] && ARG="$(<"/dev/stdin")" || false; } || { [ -f "$2" ] && ARG="$(<"$2")" || false; } || ARG="$(echo -e "${@:-}" | cat -)"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ -z "$ARG" ]; then
  printf '\n\n'
  printf_yellow "Below are all available services"
  echo "$ARRAY" | tr ' ' '\n' | grep -v '^$' | printf_column $PB_OUTPUT_COLOR_2
  printf '\n'
  exit 1
fi
