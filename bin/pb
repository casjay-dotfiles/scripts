PB_NOTIFY_CLIENT_NAME="${PB_NOTIFY_CLIENT_NAME:-$APPNAME}"
PB_NOTIFY_CLIENT_ICON="${PB_NOTIFY_CLIENT_ICON:-notification-new}"
