# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set directory to first argument
# [ -d "$1" ] && PB_CWD="$1" && shift 1 || PB_CWD="${PB_CWD:-$PWD}"
PB_CWD="$(realpath "${PB_CWD:-$PWD}" 2>/dev/null)"
# if [ -d "$PB_CWD" ] && cd "$PB_CWD"; then
# if [ "$PB_SILENT" != "true" ]; then
# printf_cyan "Setting working dir to $PB_CWD"
