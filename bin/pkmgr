      __pkgmgrbinupdcron(){ sudo --preserve-env=PATH -u $RUN_USER brew upgrade -f; }                    #
      __pkgmgrbindel()    { sudo --preserve-env=PATH -u $RUN_USER brew remove "$@"; }                   #
      __pkgmgrbinsea()    { sudo --preserve-env=PATH -u $RUN_USER brew search "$@"; }                   #
      __pkgmgrbinupd()    { sudo --preserve-env=PATH -u $RUN_USER brew upgrade "$@"; }                  #
      __pkgmgrbincle()    { sudo --preserve-env=PATH -u $RUN_USER brew cleanup; }                       #
      __pkgmgrbincac()    { sudo --preserve-env=PATH -u $RUN_USER brew update; }                        #
      pkmgrcheckbin="$(builtin type -P brew 2>/dev/null)"                                               #
      __pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin outdated 2>/dev/null | wc -l; } #
      __pkgmgrexport()    { brew list --cask && brew list --formula | sort -u; }                        #
      __pkgmr_reinstall() { echo "Not yet implemented" && return 1; }                                   #
      __pkmgrgpgskip()      { return 0; }                                                               #
      __pkmgrbrokenkeyfix() { printf_cyan "Updating brew"; brew update --force 2>/dev/null || return 1; } #
      __pkgfix()            { brew doctor 2>/dev/null || true; brew update 2>/dev/null || return 1; }   #
      __keys_remove()       { return 0; }                                                               #
      __keys_init()         { return 0; }                                                               #
      __keys_update()       { brew update 2>/dev/null || return 0; }                                    #
      __keys_reinstall()    { brew update --force 2>/dev/null || return 0; }                            #
