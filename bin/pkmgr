      __pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin -q check-update 2>/dev/null | grep -v 'Security' | wc -l; } #
      __pkgmgrexport()    { rpm -qa --qf '%{name}\n' | grep -v gpg-pubkey | sort -u; }                                              #
      __pkgmr_reinstall() { echo "Not yet implemented" && return 1; }                                                               #
      execute_pkg_check() { __cmd_exists "$1" || rpm -qi "$1" &>/dev/null || return 1; }                                            #
      __pkmgrgpgskip()      { printf_cyan "Updating TDNF with GPG check disabled"; sudo --preserve-env=PATH /usr/bin/tdnf update --nogpgcheck -y || return 1; } #
      __pkmgrbrokenkeyfix() { printf_cyan "Fixing broken TDNF keys"; sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null; sudo --preserve-env=PATH /usr/bin/tdnf clean all 2>/dev/null || return 1; } #
      __pkgfix()            { printf_cyan "Running TDNF distro-sync"; sudo --preserve-env=PATH /usr/bin/tdnf distro-sync -y || return 1; }                      #
      __keys_remove()       { printf_cyan "Removing RPM GPG keys"; sudo rpm -e gpg-pubkey --allmatches 2>/dev/null; return 0; }                                 #
      __keys_init()         { printf_cyan "Importing RPM GPG keys"; sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null || return 0; }                #
      __keys_update()       { printf_cyan "Updating TDNF/RPM keys"; sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null || true; return 0; }          #
      __keys_reinstall()    { printf_cyan "Reinstalling TDNF keyring"; sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null || return 1; }              #
      # apk alpine based setup
    elif [ -f "$(builtin type -P apk 2>/dev/null)" ]; then                   #
      PKMGR_TYPE="apk"                                                        #
      dotfilesrepo_url="$PKMGR_GIT_REPO/$PKMGR_GIT_DOTFILES"                 #
      dotfilesrepo_raw="$dotfilesrepo_url/raw/$PKMGR_GIT_BRANCH/apk"         #
      pkmgrcheckbin="$(builtin type -P apk 2>/dev/null)"                     #
      __pkgmgrbin()       { apk "$@"; }                                      #
      __pkgmgrbinins()    { apk -U add "$@"; }                               #
      __pkgmgrbininssil() { apk -U add "$@" >/dev/null; }                    #
      __pkgmgrbinremsil() { apk del -f "$@"; }                               #
      __pkgmgrbinupdsil() { apk -U upgrade >/dev/null; }                     #
      __pkgmgrbinupdcron(){ apk -U upgrade >/dev/null; }                     #
      __pkgmgrbindel()    { apk del --purge "$@"; }                                  #
      __pkgmgrbinsea()    { apk search "$@" | sed 's|-[0-9].*\.[0-9]\.[0-9].*||g'; } #
      __pkgmgrbinupd()    { apk -U upgrade "$@"; }                           #
      __pkgmgrbincle()    { apk cache clean && rm -rf /var/lib/apk/; }       #
      __pkgmgrbincac()    { apk update; }                                    #
      __pkmgrcheckupdates() { $pkmgrcheckbin -u list | wc -l; }              #
      __pkgmgrexport()    { apk info | grep -ve '-doc$' | sort -u; }         #
      __pkgmr_reinstall() { apk info | xargs apk fix || return 1; }          #
      __pkmgrgpgskip()      { printf_cyan "Updating APK with untrusted packages"; apk update --allow-untrusted && apk upgrade --allow-untrusted || return 1; } #
      __pkmgrbrokenkeyfix() {                                                #
        local rc=0                                                           #
        printf_cyan "Fixing Alpine APK keys"                                 #
        sudo rm -f /etc/apk/keys/*.pub 2>/dev/null                           #
        sudo rm -rf /var/cache/apk/* 2>/dev/null                             #
        apk fix --allow-untrusted alpine-keys 2>/dev/null || rc=$((rc + 1)) #
        apk update || rc=$((rc + 1))                                        #
        return $rc                                                           #
      }                                                                      #
      __pkgfix()            { printf_cyan "Fixing APK packages"; apk info | xargs apk fix || return 1; }                        #
      __keys_remove()       { printf_cyan "Removing APK keys"; sudo rm -f /etc/apk/keys/*.pub; return 0; }                      #
      __keys_init() {                                                                                                          #
        printf_cyan "Initializing APK keys"                                                                                  #
        apk fix --allow-untrusted alpine-keys 2>/dev/null || return 1                                                       #
        apk update || return 1                                                                                               #
      }                                                                                                                      #
      __keys_update()       { printf_cyan "Updating APK"; apk update 2>/dev/null || return 1; }                             #
      __keys_reinstall() {                                                                                                   #
        printf_cyan "Reinstalling APK keys"                                                                                  #
        apk fix --allow-untrusted alpine-keys 2>/dev/null || return 1                                                       #
        apk update || return 1                                                                                               #
      }                                                                                                                      #
    # xbps-* voidlinux based setup
    elif [ -f "$(builtin type -P xbps-install 2>/dev/null)" ]; then                            #
      PKMGR_TYPE="xbps"                                                                        #
      dotfilesrepo_url="$PKMGR_GIT_REPO/$PKMGR_GIT_DOTFILES"                                   #
      dotfilesrepo_raw="$dotfilesrepo_url/raw/$PKMGR_GIT_BRANCH/xbps"                          #
      pkmgrcheckbin="$(builtin type -P xbps-install 2>/dev/null)"                              #
      __pkgmgrbin()       { sudo --preserve-env=PATH /usr/bin/xbps-install "$@"; }             #
      __pkgmgrbinins()    { sudo --preserve-env=PATH /usr/bin/xbps-install -S "$@"; }          #
      __pkgmgrbininssil() { sudo --preserve-env=PATH /usr/bin/xbps-install -Sy "$@"; }         #
      __pkgmgrbinremsil() { sudo --preserve-env=PATH /usr/bin/xbps-remove -y "$@"; }           #
      __pkgmgrbinupdsil() { sudo --preserve-env=PATH /usr/bin/xbps-install -Syu; }             #
      __pkgmgrbinupdcron(){ sudo --preserve-env=PATH /usr/bin/xbps-install -Syu; }             #
      __pkgmgrbindel()    { sudo --preserve-env=PATH /usr/bin/xbps-remove "$@"; }              #
      __pkgmgrbinsea()    { sudo --preserve-env=PATH /usr/bin/xbps-query -Rs "$@"; }           #
      __pkgmgrbinupd()    { sudo --preserve-env=PATH /usr/bin/xbps-install -Syu "$@"; }        #
      __pkgmgrbincle()    { sudo --preserve-env=PATH /usr/bin/xbps-remove -O; }                #
      __pkgmgrbincac()    { sudo --preserve-env=PATH /usr/bin/xbps-install -S; }               #
      __pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin 2>/dev/null | wc -l; } #
      __pkgmgrexport()    { xbps-query -l; }                                                   #
      __pkgmr_reinstall() { echo "Not yet implemented" && return 1; }                          #
      __pkmgrgpgskip()      { return 0; }                                                      #
      __pkmgrbrokenkeyfix() { printf_cyan "Resyncing xbps"; sudo --preserve-env=PATH /usr/bin/xbps-install --sync 2>/dev/null || return 1; } #
      __pkgfix()            { printf_cyan "Resyncing xbps"; sudo --preserve-env=PATH /usr/bin/xbps-install --sync -y || return 1; }          #
      __keys_remove()       { return 0; }                                                      #
      __keys_init()         { return 0; }                                                      #
      __keys_update()       { sudo --preserve-env=PATH /usr/bin/xbps-install -S xbps 2>/dev/null || return 0; }                             #
      __keys_reinstall()    { sudo --preserve-env=PATH /usr/bin/xbps-install -S xbps void-repo-nonfree 2>/dev/null || return 0; }           #
