      __pkgmgrbininssil() { sudo --preserve-env=PATH /usr/bin/tdnf install -y "$@"; }                                               #
      __pkgmgrbinremsil() { sudo --preserve-env=PATH /usr/bin/tdnf remove -y "$@"; }                                                #
      __pkgmgrbinupdsil() { sudo --preserve-env=PATH /usr/bin/tdnf update -y; }                                                     #
      __pkgmgrbinupdcron(){ sudo --preserve-env=PATH /usr/bin/tdnf update -y; }                                                     #
      __pkgmgrbindel()    { sudo --preserve-env=PATH /usr/bin/tdnf remove "$@"; }                                                   #
      __pkgmgrbinsea()    { sudo --preserve-env=PATH /usr/bin/tdnf search "$@"; }                                                   #
      __pkgmgrbinupd()    { sudo --preserve-env=PATH /usr/bin/tdnf update "$@"; }                                                   #
      __pkgmgrbincle()    { sudo --preserve-env=PATH /usr/bin/tdnf clean all; }                                                     #
