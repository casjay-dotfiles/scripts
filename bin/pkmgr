__rm_rf() { sudo -HE rm -Rf "$@"; }
__cp_rf() { sudo -HE cp -Rf "$@"; }
__curl() { am_i_online --error && curl --disable -LSsfk --connect-timeout 3 --retry 0 --fail "$*" 2>/dev/null || return 1; }
__not_installed() { echo -ne "${RED}Not Installed${NC}"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
searchcmd() {
  local package_name=""
  for pkg in ${LISTARRAY[*]}; do
    package_name+=$($pkgmgrbinsea "$pkg" 2>&1 | grep -v 'Warning: No matches' | awk '{printf (NR%2==0) ? $0 "\n" : $0}' | sed 's#    #: #g' | grep "$pkg" | grep '^')
  done
  if [ -n "$package_name" ]; then
    echo "$package_name" | printf_readline
  else
    printf_red "$pkg was not found"
  fi
}
