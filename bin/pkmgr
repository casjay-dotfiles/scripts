# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl() {
  __am_i_online && curl --disable -LSsfk --connect-timeout 3 --retry 0 --fail "$*" 2>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__not_installed() { echo -ne "${RED}Not Installed${NC}"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
searchcmd() {
  local pkgs="$*"
  local exitCode=0
  local search_name=""
  local -a package_name=""
  for pkg in "${pkgs[@]}"; do
    if __cmd_exists pacman; then
      search_name="$($pkgmgrbinsea "$pkg" 2>&1 | grep -v 'Warning: No matches' | awk '{printf (NR%2==0) ? $0 "\n" : $0}' | grep "$pkg" | sed 's|^.*/||g' | sed 's#    #: #g' | grep ':' | grep '^')"
    else
      search_name="$($pkgmgrbinsea "$pkg" 2>&1 | grep -v 'Warning: No matches' | grep "$pkg" | grep '^' || echo '')"
    fi
    package_name+="${search_name}"
  done
  if [ -n "$package_name" ]; then
    printf '%s\n' "${package_name}" |& grep -v '^$' | grep '^' | cut -c 1-$PKMGR_OUTPUT_TRUNCATE
    exitCode=0
  else
    printf_red "$pkg was not found" 1>&2
    exitCode=1
  fi
  return ${exitCode:-$?}
}
