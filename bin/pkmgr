      __pkgmgrbinremsil() { sudo --preserve-env=PATH /usr/bin/dnf remove -y "$@"; }                                              #
      __pkgmgrbinupdsil() { sudo --preserve-env=PATH /usr/bin/dnf update -y; }                                                   #
      __pkgmgrbinupdcron(){ sudo --preserve-env=PATH /usr/bin/dnf update -y; }                                                   #
      __pkgmgrbindel()    { sudo --preserve-env=PATH /usr/bin/dnf remove -y "$@"; }                                              #
      __pkgmgrbinsea()    { sudo --preserve-env=PATH /usr/bin/dnf search "$@"; }                                                 #
