# User defined functions
__init_log_status() {
  printf '### Starting %s on: %s\n' "$1" "$(date)" | tee -a "${2:-/var/log/pkmgr.log}" &>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__write_log_status() {
  printf '%s\n' "$1" | tee -a "${2:-/var/log/pkmgr.log}" &>/dev/null
  printf '### Completed: %s\n\n' "$(date)" | tee -a "${2:-/var/log/pkmgr.log}" &>/dev/null
}
