# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if output contains PGP/signature errors (pacman specific)
__has_pgp_error() {
  local output="$1"
  echo "$output" | grep -qiE 'unknown trust|invalid.*signature|corrupted.*PGP|signature.*invalid|key.*could not be looked up|required key missing'
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Detect Arch-based distribution for pacman-key --populate
__detect_arch_distro() {
  if grep -qi "cachyos" /etc/os-release 2>/dev/null; then
    echo "cachyos"
  elif grep -qi "manjaro" /etc/os-release 2>/dev/null; then
    echo "manjaro"
  elif grep -qi "arcolinux" /etc/os-release 2>/dev/null; then
    echo "arcolinux"
  elif grep -qi "endeavouros" /etc/os-release 2>/dev/null; then
    echo "endeavouros"
  else
    echo "archlinux"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Core pacman keyring fix logic (used by keys command and auto-recovery)
__pacman_reinit_keyring() {
  local distro_keys="${1:-$(__detect_arch_distro)}"
  local fix_broken="${2:-false}"
  local exit_code=0
  # Update mirrorlist
  __default_mirror_list_archlinux | sudo tee -p /etc/pacman.d/mirrorlist &>/dev/null
  # Remove only the pacman keyring directory, not root's personal GPG keyring
  sudo rm -Rf "/etc/pacman.d/gnupg/" &>/dev/null
  # Handle broken mode - temporarily disable signature checking and clear package cache
  if [ "$fix_broken" = "true" ] && [ -f "/etc/pacman.conf" ]; then
    sudo cp -Rf "/etc/pacman.conf" "$PKMGR_TEMP_DIR/pacman.conf"
    sudo sed -i "s|SigLevel.*=.*|SigLevel = Optional TrustAll|g" "/etc/pacman.conf"
    # Clear package cache to remove any corrupted or partially-downloaded packages
    sudo rm -Rf "/var/cache/pacman/pkg/" &>/dev/null
    __execute "sudo reflector -f 30 -l 30 --number 10 --verbose --save /etc/pacman.d/mirrorlist 2>/dev/null >&1" "${CYAN}Updating the mirrors"
    printf_cyan "Attempting to fix pacman signatures"
  fi
  # Always include the base archlinux keyring; append distro-specific keyring if different
  local populate_keys="archlinux"
  if [ "$distro_keys" != "archlinux" ]; then
    populate_keys="archlinux $distro_keys"
  fi
  # Reinitialize and populate pacman keys
  __execute "sudo pacman-key --init >/dev/null 2>&1" "Initializing pacman key" || exit_code=$((exit_code + 1))
  __execute "sudo pacman-key --populate $populate_keys >/dev/null 2>&1" "Populating the keys" || exit_code=$((exit_code + 1))
  __execute "sudo pacman -Syyu --noconfirm >/dev/null 2>&1" "${YELLOW}Updating packages" || exit_code=$((exit_code + 1))
  # Restore pacman.conf if we backed it up
  # When fix_broken=true, save a reference copy then always restore the original
  if [ -f "$PKMGR_TEMP_DIR/pacman.conf" ]; then
    if [ "$fix_broken" = "true" ]; then
      sudo cp -Rf "$PKMGR_TEMP_DIR/pacman.conf" "/etc/pacman.broken.conf"
    fi
    sudo cp -Rf "$PKMGR_TEMP_DIR/pacman.conf" "/etc/pacman.conf"
  fi
  return $exit_code
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute pacman command with automatic keyring recovery
__exec_pacman_with_recovery() {
  local cmd="$*"
  local temp_output
  local exit_code=0
  temp_output=$(mktemp 2>/dev/null || echo "/tmp/pkmgr_output.$$")
  # First attempt - capture output to check for errors
  if command -v script >/dev/null 2>&1; then
    script -qefc "$cmd" /dev/null 2>&1 | tee "$temp_output"
    exit_code=${PIPESTATUS[0]}
  elif command -v stdbuf >/dev/null 2>&1; then
    stdbuf -o0 -e0 bash -c "$cmd" 2>&1 | tee "$temp_output"
    exit_code=${PIPESTATUS[0]}
  else
    bash -c "$cmd" 2>&1 | tee "$temp_output"
    exit_code=${PIPESTATUS[0]}
  fi
  # Check for PGP errors and attempt recovery
  if [ $exit_code -ne 0 ] && __has_pgp_error "$(cat "$temp_output" 2>/dev/null)"; then
    printf_yellow "Detected PGP/signature error, attempting automatic recovery..."
    if __pacman_reinit_keyring "$(__detect_arch_distro)" "false"; then
      printf_cyan "Retrying package operation..."
      # Retry the command
      if command -v script >/dev/null 2>&1; then
        script -qefc "$cmd" /dev/null 2>&1
        exit_code=$?
      elif command -v stdbuf >/dev/null 2>&1; then
        stdbuf -o0 -e0 bash -c "$cmd" 2>&1
        exit_code=$?
      else
        bash -c "$cmd" 2>&1
        exit_code=$?
      fi
    fi
  fi
  rm -f "$temp_output" 2>/dev/null
  return $exit_code
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute package manager commands with real-time output
__exec_unbuffered() {
  local cmd="$*"
  local log_file="${PKMGR_LOG_INFO:-}"
  local exit_code=0
  local is_internal_function=false

  # Set environment variables for unbuffered output
  export PYTHONUNBUFFERED=1
  export PAGER=""
  export SYSTEMD_PAGER=""
  export APT_LISTCHANGES_FRONTEND=none

  if [[ "$cmd" =~ ^__[[:alnum:]_]+([[:space:]]|$) ]]; then
    is_internal_function=true
  fi

  # Execute command based on available tools
  # Priority: script > stdbuf > direct execution
  # script provides best TTY emulation for package managers

  if [ -n "$log_file" ] && [ -d "$(dirname "$log_file")" ]; then
    # With logging
    if [ "$is_internal_function" = "true" ]; then
      eval "$cmd" 2>&1 | tee -a "$log_file"
      exit_code=${PIPESTATUS[0]}
    elif command -v script >/dev/null 2>&1; then
      script -qefc "bash -c '$cmd'" /dev/null 2>&1 | tee -a "$log_file"
      exit_code=${PIPESTATUS[0]}
    elif command -v stdbuf >/dev/null 2>&1; then
      stdbuf -o0 -e0 bash -c "$cmd" 2>&1 | tee -a "$log_file"
      exit_code=${PIPESTATUS[0]}
    else
      bash -c "$cmd" 2>&1 | tee -a "$log_file"
      exit_code=${PIPESTATUS[0]}
    fi
  else
    # Without logging - direct execution
    if [ "$is_internal_function" = "true" ]; then
      eval "$cmd" 2>&1
      exit_code=$?
    elif command -v script >/dev/null 2>&1; then
      script -qefc "bash -c '$cmd'" /dev/null 2>&1
      exit_code=$?
    elif command -v stdbuf >/dev/null 2>&1; then
      stdbuf -o0 -e0 bash -c "$cmd" 2>&1
      exit_code=$?
    else
      bash -c "$cmd" 2>&1
      exit_code=$?
    fi
  fi

  return $exit_code
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__log_info() { tee -p -a "$PKMGR_LOG_INFO" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__log_error() { tee -p -a "$PKMGR_LOG_ERROR" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__silent_log_file() { tee -a "${2:-$PKMGR_LOG_INFO}" &>/dev/null || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__init_log_status() { printf '### Starting %s on: %s\n%s\n' "$1" "$(date)" "Command: $2" | tee -p -a "${3:-$PKMGR_LOG_INFO}" &>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
__write_log_status() {
  printf '%s\n' "$1" | tee -p -a "${2:-$PKMGR_LOG_INFO}" &>/dev/null
  printf '### Completed on: %s\n\n' "$(date)" | tee -p -a "${2:-$PKMGR_LOG_INFO}" &>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__run_updatecheck() { __am_i_online && __pkmgrcheckupdates || echo "0"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if scripts update is needed (every 6 hours)
__scripts_update_needed() {
  local timestamp_file="${PKMGR_CACHE_DIR:-$HOME/.cache/pkmgr}/scripts_update_timestamp"
  local update_interval="${PKMGR_SCRIPTS_UPDATE_INTERVAL:-21600}"
  local current_time last_update time_diff
  current_time=$(date +%s)
  if [ -f "$timestamp_file" ]; then
    last_update=$(cat "$timestamp_file" 2>/dev/null)
    if [ -n "$last_update" ] && [[ "$last_update" =~ ^[0-9]+$ ]]; then
      time_diff=$((current_time - last_update))
      if [ "$time_diff" -lt "$update_interval" ]; then
        return 1
      fi
    fi
  fi
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Update the scripts update timestamp
__scripts_update_timestamp() {
  local timestamp_file="${PKMGR_CACHE_DIR:-$HOME/.cache/pkmgr}/scripts_update_timestamp"
  [ -d "${timestamp_file%/*}" ] || mkdir -p "${timestamp_file%/*}"
  date +%s >"$timestamp_file" 2>/dev/null
}
