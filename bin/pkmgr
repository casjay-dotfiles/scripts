eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    __list_array "$PKMGR_OPTIONS_DIR" "$ARRAY"
    __list_options "$PKMGR_OPTIONS_DIR"
    __list_available >"$PKMGR_OPTIONS_DIR/available"
    exit ${exitCode:-$?}
    ;;
  --version)
    shift 1
    __version
    exit ${exitCode:-$?}
    ;;
