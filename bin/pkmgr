# - - - - - - - - - - - - - - - - - - - - - - - - -
# Perl/CPAN functions
__cpan_run() {
  local cpandir="" cpanconf="" cpanfile=""
  cpan="$(type -P cpan 2>/dev/null | grep -v "$HOME" | grep '^')"
  if [[ -n "$cpan" ]]; then
    cpandir="$(__devnull2 sudo find /usr/share/perl* /usr/local/share/perl* -path '*/CPAN/Version.pm' | sed 's#/Version.pm##g' | head -n1)"
    cpanconf="https://raw.githubusercontent.com/casjay-base/centos/master/usr/share/perl5/CPAN/Config.pm"
    cpanfile="$cpandir/Config.pm"
    if [ ! -f "$cpanfile" ] || [ ! -f "$cpandir/.init" ]; then
      printf_green "Grabbing the CPAN.pm file"
      __urlcheck "$cpanconf" &&
        __curl "$cpanconf" | sudo tee -p "$cpanfile" &>/dev/null &&
        sudo touch "$cpandir/.init" || exit 1
    fi
    sudo bash -c "$cpan notest install $*" 2>/dev/null || return 1
  fi
}
__cpan_remove() {
  cpan="$(type -P cpan 2>/dev/null | grep -v "$HOME" | grep '^')"
  if [[ -n "$cpan" ]]; then
    sudo bash -c "$cpan --uninstall $*" 2>/dev/null || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Python/PIP functions
__pip_run() {
  local packages="$*"
  local pip_opts=""
  py_bin="$(builtin type -P python3 2>/dev/null || builtin type -P python2 2>/dev/null || builtin type -P python 2>/dev/null || return)"
  py_version="$($py_bin --version | sed 's|[pP]ython ||g' | awk -F '.' '{print $1$2}' | grep '[0-9]' || echo "0")"
  PKMGR_TEMP_FILE="${PKMGR_TEMP_FILE:-$(mktemp $PKMGR_TEMP_DIR/XXXXXX 2>/dev/null)}"
  [ -n "$py_bin" ] || printf_exit "python is not installed" >&2
  [ -n "$packages" ] || printf_exit "Usage: $APPNAME pip install [package]" >&2
  pip="$(builtin type -P pip3 2>/dev/null || builtin type -P pip 2>/dev/null || echo "$py_bin -m pip")"
  cat <<EOF >"$PKMGR_TEMP_FILE"
pip="$pip"
pip_opts=""
if [ "$py_version" -gt "310" ]; then
  pip_opts="--break-system-packages"
fi
[ -n "\$pip" ] && exitStatus=0 || { echo "pip is not installed" >&2 && exit 1; }
[ -f "/etc/profile.d/pyenv.sh" ] && . /etc/profile.d/pyenv.sh
echo "Running as: ${SUDO_USER:-$USER}"
for pkg_name in $packages; do
  name="\${pkg_name// /}"
  sudo -HE -u ${SUDO_USER:-$USER} \$pip install --upgrade --user \$pip_opts "\$name" 2>&1 | grep -v "DeprecationWarning" || true
  [ "\${PIPESTATUS[0]}" -ne 0 ] && exitStatus=\$((exitStatus + 1))
done
exit \$exitStatus
EOF
  if [ -f "$PKMGR_TEMP_FILE" ]; then
    chmod 755 "$PKMGR_TEMP_FILE" && sudo -H bash -c "$PKMGR_TEMP_FILE"
  else
    printf_red "Failed to create $PKMGR_TEMP_FILE" && return 1
  fi
  return $?
}
#
__pip_remove() {
  local packages="$*"
  py_bin="$(builtin type -P python3 2>/dev/null || builtin type -P python2 2>/dev/null || builtin type -P python 2>/dev/null || return)"
  py_version="$($py_bin --version | sed 's|[pP]ython ||g' | awk -F '.' '{print $1$2}' | grep '[0-9]' || echo "0")"
  PKMGR_TEMP_FILE="${PKMGR_TEMP_FILE:-$(mktemp $PKMGR_TEMP_DIR/XXXXXX 2>/dev/null)}"
  [ -n "$py_bin" ] || printf_exit "python is not installed" >&2
  [ -n "$packages" ] || printf_exit "Usage: $APPNAME pip remove [package]" >&2
  pip="$(builtin type -P pip3 2>/dev/null || builtin type -P pip 2>/dev/null || echo "$py_bin -m pip")"
  cat <<EOF >"$PKMGR_TEMP_FILE"
pip="$pip"
[ -f "/etc/profile.d/pyenv.sh" ] && . /etc/profile.d/pyenv.sh
[ -n "\$pip" ] && exitStatus=0 || { echo "pip is not installed" >&2 && exit 1; }
echo "Running as: ${SUDO_USER:-$USER}"
for file in $packages; do
  name="\${file// /}"
  sudo -HE -u ${SUDO_USER:-$USER} \$pip uninstall --yes "\$name" || exitStatus=\$((exitStatus + 1))
  if [ -f "/usr/local/bin/\$name" ]; then
    rm -Rf "/usr/local/bin/\$name"
  fi
done
exit \$exitStatus
EOF
  if [ -f "$PKMGR_TEMP_FILE" ]; then
    chmod 755 "$PKMGR_TEMP_FILE" && sudo -H bash -c "$PKMGR_TEMP_FILE"
  else
    printf_red "Failed to create $PKMGR_TEMP_FILE" && return 1
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Ruby/GEM functions
__gem_run() {
  local packages="$*"
  gem="$(type -P gem 2>/dev/null | grep -v "$HOME" | grep '^' || return)"
  [ -n "$packages" ] || printf_exit "Usage: $APPNAME gem install [package]" >&2
  if [ -n "$packages" ] && [ -n "$gem" ]; then
    sudo $gem install --no-user-install $packages 2>/dev/null || return 1
  fi
}
__gem_remove() {
  local packages="$*"
  gem="$(type -P gem 2>/dev/null | grep -v "$HOME" | grep '^' || return)"
  [ -n "$packages" ] || printf_exit "Usage: $APPNAME gem remove [package]" >&2
  if [ -n "$gem" ]; then
    sudo $gem uninstall --no-user-install --force -aIx $packages 2>/dev/null || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# NODE/Yarn/NPM functions
__npm_run() {
  local packages="$*"
  local NODE_PATH="" PATH="${PATH}"
  NODE_PATH="$(echo "$PATH" | tr ':' '\n' | grep 'node' | grep '/bin')"
  [ -n "$NODE_PATH" ] && PATH="$NODE_PATH:$PATH"
  [ -n "$packages" ] || printf_exit "Usage: $APPNAME node install [package]" >&2
  if __cmd_exists fnm; then
    eval "$(fnm env)"
    fnm use default &>/dev/null
    npm i -g $packages 2>/dev/null | grep -v '^$'
    return ${PIPESTATUS[0]}
  elif __cmd_exists npm; then
    npm install -g $packages 2>/dev/null | grep -v '^$'
    return ${PIPESTATUS[0]}
  elif __cmd_exists yarn; then
    if [ "$USER" = "root" ]; then
      yarn global add $packages --prefix "/usr/local/bin"
    else
      yarn global add $packages --prefix "$HOME/.local/bin"
    fi
  else
    printf_exit "Neither npm or yarn seem to be installed"
  fi
}
__npm_remove() {
  local packages="$*"
  local NODE_PATH="" PATH="${PATH}"
  NODE_PATH="$(echo "$PATH" | tr ':' '\n' | grep 'node' | grep '/bin')"
  [ -n "$NODE_PATH" ] && PATH="$NODE_PATH:$PATH"
  [ -n "$packages" ] || printf_exit "Usage: $APPNAME node remove [package]" >&2
  if __cmd_exists fnm; then
    eval "$(fnm env)"
    fnm use default &>/dev/null
    npm remove -g $packages 2>/dev/null | grep -v '^$'
    return ${PIPESTATUS[0]}
  elif __cmd_exists npm; then
    npm remove -g $packages 2>/dev/null | grep -v '^$'
    return ${PIPESTATUS[0]}
  elif __cmd_exists yarn; then
    if [ "$USER" = "root" ]; then
      yarn global remove "$*" --prefix "/usr/local/bin"
    else
      yarn global remove "$*" --prefix "$HOME/.local/bin"
    fi
  else
    printf_exit "Neither npm or yarn seem to be installed"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Lua/Rocks functions
__lua_run() {
  local packages="$*"
  __cmd_exists lua && __cmd_exists luarocks || return 1
  [ -n "$packages" ] || printf_exit "Usage: $APPNAME lua install [package]" >&2
  luarocks install --local $packages
}
__lua_remove() {
  local packages="$*"
  __cmd_exists lua && __cmd_exists luarocks || return 1
  [ -n "$packages" ] || printf_exit "Usage: $APPNAME lua remove [package]" >&2
  luarocks remove --local $packages
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Go functions
__go_run() {
  local packages="$*"
  __cmd_exists go || return 1
  [ -n "$packages" ] || printf_exit "Usage: $APPNAME go install [package]" >&2
  export GOPATH="${GOPATH:-$HOME/.local/share/go}"
  for pack in $packages; do
    go install -v "$pack@latest"
  done
}
__go_remove() {
  local packages="$*"
  __cmd_exists go || return 1
  local pkg="" ost="" cnt="" scr=""
  [ -n "$packages" ] || printf_exit "Usage: $APPNAME go remove [package]" >&2
  export GOPATH="${GOPATH:-$HOME/.local/share/go}"
  # Clean removes object files from package source directories (ignore error)
  local goos arch
  goos="$(uname -s | tr '[:upper:]' '[:lower:]')"
  arch="$(uname -m)"
  case "$arch" in
    x86_64)          ost="${goos}_amd64" ;;
    aarch64 | arm64) ost="${goos}_arm64" ;;
    armv7l | armv6l) ost="${goos}_arm" ;;
    *)               ost="${goos}_${arch}" ;;
  esac
  for pkg in $packages; do
    go clean -i $pkg &>/dev/null
    cnt="${pkg//[^\/]/}"
    # Delete the source directory and compiled package directory(ies)
    if (("${#cnt}" == "2")); then
      rm -rf "${GOPATH%%:*}/src/${pkg%/*}"
      rm -rf "${GOPATH%%:*}/pkg/${ost}/${pkg%/*}"
    elif (("${#cnt}" > "2")); then
      rm -rf "${GOPATH%%:*}/src/${pkg%/*/*}"
      rm -rf "${GOPATH%%:*}/pkg/${ost}/${pkg%/*/*}"
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Curl functions
__curl_run() {
  local os="" distro="" distroid="" url=""
  [ -z $1 ] && printf_exit 1 0 "Usage: pkmgr curl OS filename or pkmgr curl fullurltolist "
  url="$1"
  os="$(echo $OS | tr '[:upper:]' '[:lower:]')"
  distro="$(echo $DISTRO | tr '[:upper:]' '[:lower:]')"
  distroid="$(echo $DISTROID | tr '[:upper:]' '[:lower:]')"
  if __is_url "$url"; then
    __urlverify "$url" && __curl "$url" -o "$PKMGR_TEMP_FILE" &>/dev/null || return 1
  else
    url="$PKMGR_GIT_REPO/$1/raw/$PKMGR_GIT_BRANCH/lists/$2.list"
    shift "$#"
    __urlverify "$url" && __curl "$url" -o "$PKMGR_TEMP_FILE" &>/dev/null || return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Remote script execution functions
__script_run_if_is_url() {
  [ -z "$1" ] && printf_exit 1 0 "Usage: pkmgr script filename or url "
  if [[ "$1" =~ https?://.* ]] || [[ "$1" =~ ftp?://.* ]]; then
    __urlverify "$1" && __curl "$1" | tee -p "$PKMGR_TEMP_FILE" &>/dev/null || return 1
  else
    __cp_rf "$1" "$PKMGR_TEMP_FILE"
  fi
  if [ -f "$PKMGR_TEMP_FILE" ]; then
    chmod 755 "$PKMGR_TEMP_FILE"
  else
    printf_red "Error file does not exit"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Script execution
__script_run() {
  if [ "$1" = "--script" ]; then
    shift 1
    __script_run_if_is_url "$1" || return 1
    __execute "$PKMGR_TEMP_FILE" "executing the script"
  elif [ "$1" = "--line" ]; then
    shift 1
    __script_run_if_is_url "$1" || return 1
    while read -r line; do __execute "$line" "$line"; done <"$PKMGR_TEMP_FILE"
  else
    __script_run_if_is_url "$1" || return 1
    "$PKMGR_TEMP_FILE"
  fi
  __rm_rf "$PKMGR_TEMP_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__schedule() {
  local logfile="" loggerfile="" file="" tmpfile="" mailadmin="" sleepcmd="" date="" cronjob=""
  logfile="/var/log/pkmgr/cron.log"
  loggerfile="/var/log/pkmgr/cron.err"
  file="/etc/cron.d/pkmgr_update"
  tmpfile="$PKMGR_TEMP_DIR/pkmgr_cron"
  mailadmin="${PKMGR_NOTIFICATION_EMAIL:-root}"
  sleepcmd=$((RANDOM / 300))
  date="$(date +"%m-%d-%Y %H:%M")"
  cronjob="0 4 * * * root sleep ${sleepcmd} ; pkmgr cron run"
  sudo mkdir -p "/var/log/pkmgr"
  case "$1" in
  remove)
    shift 1
    printf_green "Removing pkmgr schedule"
    __rm_rf "$file" ||
      printf_error "Failed to remove $file"
    ;;
  add)
    shift 1
    printf_green "Adding pkmgr to run daily at 4am with random sleep of $sleepcmd seconds"
    echo "MAILTO=$mailadmin" >"$tmpfile"
    echo "$cronjob" >"$tmpfile"
    sudo chown -f root:root "$tmpfile"
    sudo chmod -f 600 "$tmpfile"
    sudo mv -f $tmpfile $file ||
      printf_error "Failed to install $tmpfile to $file"
    ;;
  run)
    shift 1
    echo -e "###########\n$date\n###########\n" | sudo tee -p -a "$logfile" &>/dev/null
    echo -e "###########\n$date\n###########\n" | sudo tee -p -a "$loggerfile" &>/dev/null
    __pkgmgrbinupdcron 2>>"$loggerfile.tmp" | sudo tee -p -a "$logfile" &>/dev/null
    if [ -s "$loggerfile.tmp" ] && [ -f "$loggerfile.tmp" ] && grep -q '[^[:space:]]' "$loggerfile.tmp" &>/dev/null; then
      if __cmd_exists mail; then
        MAILMESS="$(echo -e "Errors were reported and they are as follows:\n""$(cat $loggerfile.tmp)\n")"
        echo $MAILMESS | mail -r "$mailadmin" -s "pkmgr failed" "$mailadmin"
      fi
    fi
    [ ! -f "$loggerfile.tmp" ] || sudo cat "$loggerfile.tmp" sudo | tee -p -a "$loggerfile" && __rm_rf "$loggerfile.tmp"
    ;;
  *)
    [ -f "$file" ] && pkmgr cron remove || pkmgr cron add
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__dotfiles_run() {
  local file="" f="" url=""
  [ -n "$1" ] || printf_exit "Usage: pkmgr dotfiles name"
  f=""
  file=("$@")
  echo >"$PKMGR_TEMP_FILE"
  for f in "${file[@]}"; do
    if [ -n "$f" ]; then
      url="$dotfilesrepo_raw/$f.list"
      __urlverify "$url" || return 1
      __curl "$url" | tee -p -a "$PKMGR_TEMP_FILE" &>/dev/null
      [ "${PIPESTATUS[0]}" -eq 0 ] || return 1
    fi
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__aliases() {
  cat <<EOF
  alias apt='$APPNAME '
  alias apt-get='$APPNAME '
  alias dnf='$APPNAME '
  alias yum='$APPNAME '
  alias pacman='$APPNAME '
  alias brew='$APPNAME '
  alias yay='$APPNAME '
EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__show_info() {
  local col="" truncate="$1" display_version="" pkmgr_bin=""
  [ -n "$COLUMNS" ] && col=$(($COLUMNS - 30)) || col=80
  # Determine if this is a rolling-release distro
  local _n
  _n="$(printf '%s' "${DISTRO_NAME:-}" | tr '[:upper:]' '[:lower:]')"
  case "$_n" in
    *arch* | *manjaro* | *cachyos* | *arcolinux* | *endeavouros* | *artix* | \
    *garuda* | *parabola* | *blackarch* | *tumbleweed* | *gentoo* | *void*)
      display_version="rolling" ;;
    *)
      case "$PKMGR_TYPE" in
        pacman | pamac | yay | xbps) display_version="rolling" ;;
        *) display_version="${DISTRO_VERSION:-N/A}" ;;
      esac ;;
  esac
  [ "$display_version" = "Version: Unknown" ] && display_version="N/A"
  # Derive a short binary path for the active package manager
  case "$PKMGR_TYPE" in
    apt-get) pkmgr_bin="$(builtin type -P apt-get 2>/dev/null)" ;;
    apt)     pkmgr_bin="$(builtin type -P apt 2>/dev/null)" ;;
    pacman)  pkmgr_bin="$(builtin type -P pacman 2>/dev/null)" ;;
    pamac)   pkmgr_bin="$(builtin type -P pamac 2>/dev/null)" ;;
    yay)     pkmgr_bin="$(builtin type -P yay 2>/dev/null)" ;;
    dnf)     pkmgr_bin="$(builtin type -P dnf 2>/dev/null)" ;;
    yum)     pkmgr_bin="$(builtin type -P yum 2>/dev/null)" ;;
    tdnf)    pkmgr_bin="$(builtin type -P tdnf 2>/dev/null)" ;;
    apk)     pkmgr_bin="$(builtin type -P apk 2>/dev/null)" ;;
    xbps)    pkmgr_bin="$(builtin type -P xbps-install 2>/dev/null)" ;;
    brew)    pkmgr_bin="$(builtin type -P brew 2>/dev/null)" ;;
    choco)   pkmgr_bin="$(builtin type -P choco 2>/dev/null)" ;;
    *)       pkmgr_bin="unknown" ;;
  esac
  printf_red "System info for $(hostname -f)         "
  printf_blue "Distribution:               $DISTRO_NAME"
  if [ -n "$CODE_NAME" ] && [ "$CODE_NAME" != "N/A" ]; then
    printf_yellow "Codename:                   $CODE_NAME"
  fi
  printf_blue "Distro Version:             $display_version"
  printf_yellow "Kernel version              $KERNEL_VERSION"
  if [ "$truncate" != "notruncate" ] && { [ "$truncate" = "truncate" ] || [ $col -le 80 ]; }; then
    truncate="true"
    printf_cyan "Repo:                       ${dotfilesrepo_url:0:$col}"
    printf_cyan "Repo Raw:                   ${dotfilesrepo_raw:0:$col}"
    printf_cyan "Package manager type:       $PKMGR_TYPE"
    printf_cyan "Package manager bin:        ${pkmgr_bin:0:$col}"
  else
    truncate="false"
    printf_cyan "Repo:                       ${dotfilesrepo_url}"
    printf_cyan "Repo Raw:                   ${dotfilesrepo_raw}"
    printf_cyan "Package manager type:       $PKMGR_TYPE"
    printf_cyan "Package manager bin:        $pkmgr_bin"
  fi
  printf_blue "Node:                       $(builtin type -P node || __not_installed)"
  printf_blue "NPM:                        $(builtin type -P npm || builtin type -P yarn || __not_installed)"
  printf_purple "Python:                     $(builtin type -P python3 || builtin type -P python2 || __not_installed)"
  printf_purple "PIP:                        $(builtin type -P pip3 || builtin type -P pip || __not_installed)"
  printf_blue "Perl:                       $(builtin type -P perl || __not_installed)"
  printf_blue "CPAN:                       $(builtin type -P cpan || __not_installed)"
  printf_purple "Ruby:                       $(builtin type -P ruby || __not_installed)"
  printf_purple "Gem:                        $(builtin type -P gem || __not_installed)"
  printf_blue "Lua                         $(builtin type -P lua || __not_installed)"
  printf_blue "Luarocks                    $(builtin type -P luarocks || __not_installed)"
  if [ "$truncate" = "true" ]; then
    printf_newline && printf_yellow "Results may have been truncated to $col characters add notruncate for no truncation"
  fi
  printf_newline
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__exportpkg() {
  local pkgdir="" pkglist=""
  local distro="$(printf '%s\n' "$DISTRO" | sed 's|[0-9]||g')"
  case "$(uname -s)" in
  Darwin*) distro="MacOS" ;;
  ^MING* | WIN* | MSYS*) distro="Windows" ;;
  esac
  pkgdir="$PKMGR_TEMP_DIR/${distro:-}"
  pkglist="$pkgdir/$(hostname -s).list"
  mkdir -p "$pkgdir"
  printf_green "Exporting package list to:"
  printf_green "$pkglist"
  __pkgmgrexport >"$pkglist"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__update_mirrors() {
  __cmd_exists pacman || return 0
  sudo pacman -S --noconfirm --needed reflector &>/dev/null
  __cmd_exists reflector || return
  (
    sudo reflector --protocol 'https' --ipv4 --latest 100 \
      --country us --fastest 20 --sort rate --threads 5 \
      --download-timeout 1 --connection-timeout 1 --save "$PKMGR_TEMP_DIR/mirrorlist.new"
    rankmirrors -n 0 "$PKMGR_TEMP_DIR/mirrorlist.new" >"$PKMGR_TEMP_DIR/mirrorlist"
  ) |& tee -p &>/dev/null
  if [ -f "$PKMGR_TEMP_DIR/mirrorlist" ] && [ -s "$PKMGR_TEMP_DIR/mirrorlist" ]; then
    sudo mv -f "$PKMGR_TEMP_DIR/mirrorlist" "/etc/pacman.d/mirrorlist" &>/dev/null
    sudo rm -Rf "$PKMGR_TEMP_DIR/mirrorlist" "$PKMGR_TEMP_DIR/mirrorlist.new" &>/dev/null
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__initialize_variables() {
  PKMGR_OS_NAME="$(uname -s | tr '[:upper:]' '[:lower:]')"
  export SUDO_USER RUN_USER
  if [[ "$(__devnull2 python3 -V)" =~ "Python 3" ]]; then
    PYTHONVER="python3"
    PIP="pip3"
    PATH="${PATH}:$(python3 -c 'import site; print(site.USER_BASE)')/bin"
  elif [[ "$(__devnull2 python2 -V)" =~ "Python 2" ]]; then
    PYTHONVER="python"
    PIP="pip"
    PATH="${PATH}:$(python -c 'import site; print(site.USER_BASE)')/bin"
  fi
  if __cmd_exists pacman; then
    PYTHONVER="python"
    PIP="pip3"
  fi
  [ -f "$PKMGR_TEMP_FILE" ] && __rm_rf "$PKMGR_TEMP_FILE"
  case "$PKMGR_OS_NAME" in
  linux)
    # apt-get debian based setup
    if [ -f "$(builtin type -P apt-get 2>/dev/null)" ]; then                                                                      #
      PKMGR_TYPE="apt-get"                                                                                                        #
      pkmgrcheckbin_opts="-q -y --ignore-hold --allow-change-held-packages --allow-unauthenticated -s dist-upgrade"               #
      export DEBIAN_FRONTEND=noninteractive                                                                                       #
      export APT_OPTS="-o Dpkg::Options::=--force-confdef -o Dpkg::Options::=--force-confold"                     #
      dotfilesrepo_url="$PKMGR_GIT_REPO/$PKMGR_GIT_DOTFILES"                                                                      #
      dotfilesrepo_raw="$dotfilesrepo_url/raw/$PKMGR_GIT_BRANCH/apt"                                                              #
      pkmgrcheckbin="$(builtin type -P apt 2>/dev/null)"                                                                          #
      __pkgmgrbin()       { sudo --preserve-env=PATH /usr/bin/apt-get "$@"; }                                                     #
      __pkgmgrbinins()    { sudo --preserve-env=PATH /usr/bin/apt-get install $APT_OPTS --assume-yes "$@"; }                      #
      __pkgmgrbininssil() { sudo --preserve-env=PATH /usr/bin/apt-get install $APT_OPTS --ignore-missing -yy -q --allow-unauthenticated --assume-yes "$@"; } #
      __pkgmgrbinremsil() { sudo --preserve-env=PATH /usr/bin/apt-get remove -yy -q --assume-yes --purge "$@"; }                  #
      __pkgmgrbinupdsil() { sudo --preserve-env=PATH /usr/bin/apt-get dist-upgrade $APT_OPTS --ignore-missing -yy -q --allow-unauthenticated --assume-yes; } #
      __pkgmgrbinupdcron(){ sudo --preserve-env=PATH /usr/bin/apt-get dist-upgrade $APT_OPTS --ignore-missing -yy --allow-unauthenticated --assume-yes; }    #
      __pkgmgrbindel()    { sudo --preserve-env=PATH /usr/bin/apt-get remove --purge "$@"; }                                      #
      __pkgmgrbinsea()    { sudo --preserve-env=PATH /usr/bin/apt-cache search "$@"; }                                            #
      __pkgmgrbinupd()    { sudo --preserve-env=PATH /usr/bin/apt-get dist-upgrade "$@"; }                                       #
      __pkgmgrbincle()    { sudo --preserve-env=PATH /usr/bin/apt-get clean; }                                                   #
      __pkgmgrbincac()    { sudo --preserve-env=PATH /usr/bin/apt-get update; }                                                  #
      __pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin $pkmgrcheckbin_opts 2>/dev/null | grep '^Inst' | wc -l; } #
      __pkgmgrexport()    { dpkg -l | grep ^ii | awk '{print $2}' | sed "s#:.*##g" | sort -u; }                                  #
      __pkgmr_reinstall() { echo "Not yet implemented" && return 1; }                                                             #
      __pkmgrgpgskip() {                                                                                                          #
        local rc=0                                                                                                                #
        printf_cyan "Disabling APT GPG verification temporarily"                                                                 #
        echo 'Acquire::AllowInsecureRepositories "true";' | sudo tee /etc/apt/apt.conf.d/99insecure &>/dev/null                  #
        echo 'APT::Get::AllowUnauthenticated "true";' | sudo tee -a /etc/apt/apt.conf.d/99insecure &>/dev/null                   #
        sudo --preserve-env=PATH /usr/bin/apt-get update --allow-insecure-repositories &>/dev/null || rc=$((rc + 1))             #
        sudo --preserve-env=PATH /usr/bin/apt-get dist-upgrade $APT_OPTS --allow-unauthenticated --allow-insecure-repositories -yy || rc=$((rc + 1)) #
        sudo rm -f /etc/apt/apt.conf.d/99insecure                                                                                #
        return $rc                                                                                                               #
      }                                                                                                                          #
      __pkmgrbrokenkeyfix() {                                                                                                    #
        local rc=0                                                                                                               #
        printf_cyan "Fixing broken APT keys"                                                                                    #
        sudo --preserve-env=PATH /usr/bin/apt-get update 2>&1 | grep -oP 'NO_PUBKEY \K[A-F0-9]+' | while read -r key; do        #
          sudo gpg --keyserver hkps://keyserver.ubuntu.com --recv-keys "$key" 2>/dev/null &&                                    #
            sudo gpg --export "$key" | sudo apt-key add - 2>/dev/null ||                                                        #
            sudo apt-key adv --keyserver keyserver.ubuntu.com --recv-keys "$key" 2>/dev/null || true                            #
        done                                                                                                                     #
        sudo --preserve-env=PATH /usr/bin/apt-get update 2>/dev/null || rc=$((rc + 1))                                          #
        return $rc                                                                                                               #
      }                                                                                                                          #
      __pkgfix() {                                                                                                               #
        local rc=0                                                                                                               #
        printf_cyan "Fixing broken APT packages"                                                                                #
        sudo dpkg --configure -a || rc=$((rc + 1))                                                                              #
        sudo --preserve-env=PATH /usr/bin/apt-get -f install -yy || rc=$((rc + 1))                                              #
        sudo --preserve-env=PATH /usr/bin/apt-get --fix-broken install -yy || rc=$((rc + 1))                                    #
        return $rc                                                                                                               #
      }                                                                                                                          #
      __keys_remove()    { printf_cyan "Removing APT keyring"; sudo rm -rf /etc/apt/trusted.gpg /etc/apt/trusted.gpg.d/* && return 0 || return 1; } #
      __keys_init()      { printf_cyan "Initializing APT keyring"; sudo apt-key update 2>/dev/null || return 0; }               #
      __keys_update()    { printf_cyan "Updating APT keys"; sudo apt-key update 2>/dev/null || true; sudo --preserve-env=PATH /usr/bin/apt-get update --allow-insecure-repositories 2>/dev/null || return 1; } #
      __keys_reinstall() {                                                                                                       #
        local rc=0                                                                                                               #
        printf_cyan "Reinstalling APT keyring packages"                                                                         #
        sudo --preserve-env=PATH /usr/bin/apt-get install --reinstall -y debian-archive-keyring 2>/dev/null || true             #
        sudo --preserve-env=PATH /usr/bin/apt-get install --reinstall -y ubuntu-keyring 2>/dev/null || true                     #
        sudo --preserve-env=PATH /usr/bin/apt-get update 2>/dev/null || rc=$((rc + 1))                                          #
        return $rc                                                                                                               #
      }                                                                                                                          #
    # apt debian based setup
    elif [ -f "$(builtin type -P apt 2>/dev/null)" ]; then                                                                        #
      PKMGR_TYPE="apt"                                                                                                            #
      pkmgrcheckbin_opts="-q -y --ignore-hold --allow-change-held-packages --allow-unauthenticated -s dist-upgrade"               #
      export DEBIAN_FRONTEND=noninteractive                                                                                       #
      export APT_OPTS="-o Dpkg::Options::=--force-confdef -o Dpkg::Options::=--force-confold"                                     #
      dotfilesrepo_url="$PKMGR_GIT_REPO/$PKMGR_GIT_DOTFILES"                                                                      #
      dotfilesrepo_raw="$dotfilesrepo_url/raw/$PKMGR_GIT_BRANCH/apt"                                                              #
      pkmgrcheckbin="$(builtin type -P apt 2>/dev/null)"                                                                          #
      __pkgmgrbin()       { sudo --preserve-env=PATH /usr/bin/apt "$@"; }                                                        #
      __pkgmgrbinins()    { sudo --preserve-env=PATH /usr/bin/apt install $APT_OPTS --assume-yes "$@"; }                         #
      __pkgmgrbininssil() { sudo --preserve-env=PATH /usr/bin/apt install $APT_OPTS --ignore-missing -yy -q --allow-unauthenticated --assume-yes "$@"; } #
      __pkgmgrbinremsil() { sudo --preserve-env=PATH /usr/bin/apt remove -yy -q --assume-yes --purge "$@"; }                      #
      __pkgmgrbinupdsil() { sudo --preserve-env=PATH /usr/bin/apt dist-upgrade $APT_OPTS --ignore-missing -yy -q --allow-unauthenticated --assume-yes; } #
      __pkgmgrbinupdcron(){ sudo --preserve-env=PATH /usr/bin/apt dist-upgrade $APT_OPTS --ignore-missing -yy --allow-unauthenticated --assume-yes; }    #
      __pkgmgrbindel()    { sudo --preserve-env=PATH /usr/bin/apt remove --purge "$@"; }                                         #
      __pkgmgrbinsea()    { sudo --preserve-env=PATH /usr/bin/apt-cache search "$@"; }                                           #
      __pkgmgrbinupd()    { sudo --preserve-env=PATH /usr/bin/apt dist-upgrade "$@"; }                                          #
      __pkgmgrbincle()    { sudo --preserve-env=PATH /usr/bin/apt clean; }                                                      #
      __pkgmgrbincac()    { sudo --preserve-env=PATH /usr/bin/apt update; }                                                     #
      __pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin $pkmgrcheckbin_opts 2>/dev/null | grep '^Inst' | wc -l; } #
      __pkgmgrexport()    { dpkg -l | grep ^ii | awk '{print $2}' | sed "s#:.*##g" | sort -u; }                                  #
      __pkgmr_reinstall() { echo "Not yet implemented" && return 1; }                                                             #
      __pkmgrgpgskip() {                                                                                                          #
        local rc=0                                                                                                                #
        printf_cyan "Disabling APT GPG verification temporarily"                                                                 #
        echo 'Acquire::AllowInsecureRepositories "true";' | sudo tee /etc/apt/apt.conf.d/99insecure &>/dev/null                  #
        echo 'APT::Get::AllowUnauthenticated "true";' | sudo tee -a /etc/apt/apt.conf.d/99insecure &>/dev/null                   #
        sudo --preserve-env=PATH /usr/bin/apt update --allow-insecure-repositories &>/dev/null || rc=$((rc + 1))                 #
        sudo --preserve-env=PATH /usr/bin/apt dist-upgrade $APT_OPTS --allow-unauthenticated --allow-insecure-repositories -yy || rc=$((rc + 1)) #
        sudo rm -f /etc/apt/apt.conf.d/99insecure                                                                                #
        return $rc                                                                                                               #
      }                                                                                                                          #
      __pkmgrbrokenkeyfix() {                                                                                                    #
        local rc=0                                                                                                               #
        printf_cyan "Fixing broken APT keys"                                                                                    #
        sudo --preserve-env=PATH /usr/bin/apt update 2>&1 | grep -oP 'NO_PUBKEY \K[A-F0-9]+' | while read -r key; do            #
          sudo gpg --keyserver hkps://keyserver.ubuntu.com --recv-keys "$key" 2>/dev/null &&                                    #
            sudo gpg --export "$key" | sudo apt-key add - 2>/dev/null ||                                                        #
            sudo apt-key adv --keyserver keyserver.ubuntu.com --recv-keys "$key" 2>/dev/null || true                            #
        done                                                                                                                     #
        sudo --preserve-env=PATH /usr/bin/apt update 2>/dev/null || rc=$((rc + 1))                                              #
        return $rc                                                                                                               #
      }                                                                                                                          #
      __pkgfix() {                                                                                                               #
        local rc=0                                                                                                               #
        printf_cyan "Fixing broken APT packages"                                                                                #
        sudo dpkg --configure -a || rc=$((rc + 1))                                                                              #
        sudo --preserve-env=PATH /usr/bin/apt -f install -yy || rc=$((rc + 1))                                                  #
        sudo --preserve-env=PATH /usr/bin/apt --fix-broken install -yy || rc=$((rc + 1))                                        #
        return $rc                                                                                                               #
      }                                                                                                                          #
      __keys_remove()    { printf_cyan "Removing APT keyring"; sudo rm -rf /etc/apt/trusted.gpg /etc/apt/trusted.gpg.d/* && return 0 || return 1; } #
      __keys_init()      { printf_cyan "Initializing APT keyring"; sudo apt-key update 2>/dev/null || return 0; }               #
      __keys_update()    { printf_cyan "Updating APT keys"; sudo apt-key update 2>/dev/null || true; sudo --preserve-env=PATH /usr/bin/apt update --allow-insecure-repositories 2>/dev/null || return 1; } #
      __keys_reinstall() {                                                                                                       #
        local rc=0                                                                                                               #
        printf_cyan "Reinstalling APT keyring packages"                                                                         #
        sudo --preserve-env=PATH /usr/bin/apt install --reinstall -y debian-archive-keyring 2>/dev/null || true                 #
        sudo --preserve-env=PATH /usr/bin/apt install --reinstall -y ubuntu-keyring 2>/dev/null || true                         #
        sudo --preserve-env=PATH /usr/bin/apt update 2>/dev/null || rc=$((rc + 1))                                              #
        return $rc                                                                                                               #
      }                                                                                                                          #
    # pacman archlinux based setup
    elif [ -f "$(builtin type -P pacman 2>/dev/null)" ]; then                                                                                                               #
      PKMGR_TYPE="pacman"                                                                                                                                                    #
      dotfilesrepo_url="$PKMGR_GIT_REPO/$PKMGR_GIT_DOTFILES"                                                                                                                #
      dotfilesrepo_raw="$dotfilesrepo_url/raw/$PKMGR_GIT_BRANCH/pacman"                                                                                                     #
      pkmgrcheckbin="$(builtin type -P pacman 2>/dev/null)"                                                                                                                 #
      __pkgmgrbin()       { sudo --preserve-env=PATH /usr/bin/pacman "$@"; }                                                                                                #
      __pkgmgrbinins()    { sudo --preserve-env=PATH /usr/bin/pacman -S --noconfirm --needed --overwrite "*" "$@"; }                                                        #
      __pkgmgrbininssil() { sudo --preserve-env=PATH /usr/bin/pacman -Sy --noconfirm --needed --overwrite "*" "$@"; }                                                       #
      __pkgmgrbinremsil() { sudo --preserve-env=PATH /usr/bin/pacman -Ry --noconfirm "$@"; }                                                                                #
      __pkgmgrbinupdsil() { sudo --preserve-env=PATH /usr/bin/pacman -Syyu --noconfirm; }                                                                                   #
      __pkgmgrbinupdcron(){ sudo --preserve-env=PATH /usr/bin/pacman -Syyu --noconfirm; }                                                                                   #
      __pkgmgrbindel()    { sudo --preserve-env=PATH /usr/bin/pacman -Rns "$@"; }                                                                                           #
      __pkgmgrbinsea()    { sudo --preserve-env=PATH /usr/bin/pacman -Ss "$@"; }                                                                                            #
      __pkgmgrbinupd()    { sudo --preserve-env=PATH /usr/bin/pacman -Syyu --noconfirm --needed --overwrite "*" "$@"; }                                                     #
      __pkgmgrbincle()    { yes | sudo --preserve-env=PATH /usr/bin/pacman -Scc --noconfirm; }                                                                              #
      __pkgmgrbincac()    { sudo --preserve-env=PATH /usr/bin/pacman -Syy; }                                                                                               #
      __pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin -Qu 2>/dev/null | wc -l; }                                                                          #
      __pkgmgrexport()    { (pacman -Qqe | grep -v "$(pacman -Qqm)" && pacman -Qqet | grep -v "$(pacman -Qqm)") | sort -u; }                                                #
      __pkgmr_reinstall() { for pkg in $(pacman -Q | cut -d' ' -f1); do __execute "pacman -S --noconfirm $pkg" "Reinstalling package: $pkg"; done && return 0 || return $?; } #
      __pkmgrgpgskip() {                                                                                                                                                     #
        local rc=0                                                                                                                                                           #
        printf_cyan "Disabling pacman GPG verification temporarily"                                                                                                         #
        sudo cp -f /etc/pacman.conf "$PKMGR_TEMP_DIR/pacman.conf.gpgskip.bak"                                                                                               #
        sudo sed -i 's/^SigLevel.*/SigLevel = Never/' /etc/pacman.conf                                                                                                      #
        sudo --preserve-env=PATH /usr/bin/pacman -Syyu --noconfirm || rc=$((rc + 1))                                                                                        #
        sudo cp -f "$PKMGR_TEMP_DIR/pacman.conf.gpgskip.bak" /etc/pacman.conf                                                                                               #
        return $rc                                                                                                                                                          #
      }                                                                                                                                                                      #
      __pkmgrbrokenkeyfix() { printf_cyan "Fixing broken pacman keys"; __pacman_reinit_keyring "$(__detect_arch_distro)" "true"; }                                           #
      __pkgfix()            { printf_cyan "Refreshing pacman database"; sudo --preserve-env=PATH /usr/bin/pacman -Syy --noconfirm || return 1; }                             #
      __keys_remove()       { printf_cyan "Removing pacman keyring"; sudo rm -rf /etc/pacman.d/gnupg && return 0 || return 1; }                                             #
      __keys_init()         { printf_cyan "Initializing pacman keyring"; sudo pacman-key --init || return 1; }                                                              #
      __keys_update()       { printf_cyan "Updating pacman keys"; sudo pacman-key --refresh-keys || return 1; }                                                             #
      __keys_reinstall() {                                                                                                                                                   #
        local distro="$(__detect_arch_distro)"                                                                                                                              #
        printf_cyan "Reinstalling pacman keyring packages"                                                                                                                  #
        sudo --preserve-env=PATH /usr/bin/pacman -S --noconfirm "${distro}-keyring" archlinux-keyring 2>/dev/null || true                                                   #
        __pacman_reinit_keyring "$distro" "false" || return 1                                                                                                               #
      }                                                                                                                                                                      #
    # pamac archlinux based setup
    elif [ -f "$(builtin type -P pamac 2>/dev/null)" ]; then                                                                                                      #
      PKMGR_TYPE="pamac"                                                                                                                                          #
      dotfilesrepo_url="$PKMGR_GIT_REPO/$PKMGR_GIT_DOTFILES"                                                                                                      #
      dotfilesrepo_raw="$dotfilesrepo_url/raw/$PKMGR_GIT_BRANCH/pacman"                                                                                           #
      pkmgrcheckbin="$(builtin type -P pamac 2>/dev/null)"                                                                                                        #
      __pkgmgrbin()       { sudo /usr/bin/pamac "$@"; }                                                                                                          #
      __pkgmgrbinins()    { sudo /usr/bin/pamac install --noconfirm "$@"; }                                                                                      #
      __pkgmgrbininssil() { sudo /usr/bin/pamac install --noconfirm "$@"; }                                                                                      #
      __pkgmgrbinremsil() { sudo /usr/bin/pamac remove --noconfirm "$@"; }                                                                                       #
      __pkgmgrbinupdsil() { sudo /usr/bin/pamac upgrade -a; }                                                                                                    #
      __pkgmgrbinupdcron(){ sudo /usr/bin/pamac upgrade -a; }                                                                                                    #
      __pkgmgrbindel()    { sudo /usr/bin/pamac remove "$@"; }                                                                                                   #
      __pkgmgrbinsea()    { sudo /usr/bin/pamac search -a "$@"; }                                                                                                #
      __pkgmgrbinupd()    { sudo /usr/bin/pamac upgrade -a; }                                                                                                    #
      __pkgmgrbincle()    { sudo /usr/bin/pamac clean; }                                                                                                         #
      __pkgmgrbincac()    { sudo /usr/bin/pamac checkupdates; }                                                                                                  #
      __pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin checkupdates -a 2>/dev/null | wc -l; }                                                    #
      __pkgmgrexport()    { pamac list ${1:--e} | grep -E 'extra|community|core' | awk '{print $1}' | sort -u; }                                                  #
      __pkgmr_reinstall() { for pkg in $(__pkgmgrexport -i); do __execute "pacman -S --noconfirm $pkg" "Reinstalling package: $pkg"; done && return 0 || return $?; } #
      __pkmgrgpgskip() {                                                                                                                                          #
        local rc=0                                                                                                                                               #
        printf_cyan "Disabling pacman GPG verification temporarily"                                                                                             #
        sudo cp -f /etc/pacman.conf "$PKMGR_TEMP_DIR/pacman.conf.gpgskip.bak"                                                                                   #
        sudo sed -i 's/^SigLevel.*/SigLevel = Never/' /etc/pacman.conf                                                                                          #
        sudo --preserve-env=PATH /usr/bin/pacman -Syyu --noconfirm || rc=$((rc + 1))                                                                            #
        sudo cp -f "$PKMGR_TEMP_DIR/pacman.conf.gpgskip.bak" /etc/pacman.conf                                                                                   #
        return $rc                                                                                                                                               #
      }                                                                                                                                                          #
      __pkmgrbrokenkeyfix() { printf_cyan "Fixing broken pacman keys"; __pacman_reinit_keyring "$(__detect_arch_distro)" "true"; }                               #
      __pkgfix()            { printf_cyan "Refreshing pacman database"; sudo --preserve-env=PATH /usr/bin/pacman -Syy --noconfirm || return 1; }                 #
      __keys_remove()       { printf_cyan "Removing pacman keyring"; sudo rm -rf /etc/pacman.d/gnupg && return 0 || return 1; }                                 #
      __keys_init()         { printf_cyan "Initializing pacman keyring"; sudo pacman-key --init || return 1; }                                                  #
      __keys_update()       { printf_cyan "Updating pacman keys"; sudo pacman-key --refresh-keys || return 1; }                                                 #
      __keys_reinstall() {                                                                                                                                       #
        local distro="$(__detect_arch_distro)"                                                                                                                  #
        printf_cyan "Reinstalling pacman keyring packages"                                                                                                      #
        sudo --preserve-env=PATH /usr/bin/pacman -S --noconfirm "${distro}-keyring" archlinux-keyring 2>/dev/null || true                                       #
        __pacman_reinit_keyring "$distro" "false" || return 1                                                                                                   #
      }                                                                                                                                                          #
    # dnf fedora based setup
    elif [ -f "$(builtin type -P dnf 2>/dev/null)" ]; then                                                                        #
      PKMGR_TYPE="dnf"                                                                                                            #
