silent) # Silent
  case "$2" in
  install) # Silently install packages
    shift 2
    [ "$1" = "help" ] && printf_help "Silently install packages"
    am_i_online --error || exit 1
    declare -a LISTARRAY="$*"
    for pkg in ${LISTARRAY[*]}; do
      __devnull $pkgmgrbininssil "$pkg" && exitCode+=0 || exitCode+=1
    done
    exit ${exitCode:-$?}
    ;;

  remove) # Silently remove packages
    shift 2
    [ "$1" = "help" ] && printf_help "Silently remove packages"
    declare -a LISTARRAY="$*"
    for pkg in ${LISTARRAY[*]}; do
      __devnull $pkgmgrbinremsil "*$pkg*" && exitCode+=0 || exitCode+=1
    done
    exit ${exitCode:-$?}
    ;;

  upgrade) # Silently update packages
    shift 2
    [ "$1" = "help" ] && printf_help "Silently upgrade your system"
    am_i_online --error || exit 1
    if [ -f "$(builtin type -P systemmgr)" ]; then
      __devnull sudo -HE systemmgr install installer
    fi
    __devnull $pkgmgrbinupdsil && exitCode+=0 || exitCode+=1
    exit ${exitCode:-$?}
    ;;

  *) # Silently update packages
    shift 1
    [ "$1" = "help" ] && printf_help "Silently install packages | defaults to a silent update"
    am_i_online --error || exit 1
    if [ -z "$1" ]; then
      __devnull $pkgmgrbinupdsil && exitCode+=0 || exitCode+=1
    else
      declare -a LISTARRAY="$*"
      for pkg in ${LISTARRAY[*]}; do
        __devnull $pkgmgrbininssil "$pkg" && exitCode+=0 || exitCode+=1
      done
    fi
    exit ${exitCode:-$?}
    ;;
  esac
  ;;

info) # Show system info
  shift 1
  [ "$1" = "help" ] && printf_help "Show info about your system"
  show_info
  ;;

version) # Show version
  shift 1
  run_install_version "$@"
  exit
  ;;

bin)
  shift 1
  $pkgmgrbin "$@"
  ;;

*) # Help
  __help
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
