      __pkgmgrbincle()    { sudo --preserve-env=PATH /usr/bin/dnf clean all; }                                                   #
      __pkgmgrbincac()    { sudo --preserve-env=PATH /usr/bin/dnf makecache; }                                                   #
      __pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin -q check-update 2>/dev/null | grep -v Security | wc -l; } #
      __pkgmgrexport()    { rpm -qa --qf '%{name}\n' | grep -v gpg-pubkey | sort -u; }                                           #
      __pkgmr_reinstall() { echo "Not yet implemented" && return 1; }                                                             #
      execute_pkg_check() { __cmd_exists "$1" || rpm -qi "$1" &>/dev/null || return 1; }                                         #
      __pkmgrgpgskip()      { printf_cyan "Updating DNF with GPG check disabled"; sudo --preserve-env=PATH /usr/bin/dnf update --nogpgcheck -y || return 1; }  #
      __pkmgrbrokenkeyfix() {                                                                                                     #
        local rc=0                                                                                                               #
        printf_cyan "Fixing broken DNF/RPM keys"                                                                                #
        sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null || rc=$((rc + 1))                                         #
        sudo --preserve-env=PATH /usr/bin/dnf clean all && sudo --preserve-env=PATH /usr/bin/dnf check-update 2>/dev/null || true #
        return $rc                                                                                                               #
      }                                                                                                                          #
      __pkgfix()            { printf_cyan "Running DNF distro-sync"; sudo --preserve-env=PATH /usr/bin/dnf distro-sync -y || return 1; }                        #
      __keys_remove()       { printf_cyan "Removing RPM GPG keys"; sudo rpm -e gpg-pubkey --allmatches 2>/dev/null; return 0; }                                 #
      __keys_init()         { printf_cyan "Importing RPM GPG keys"; sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null || return 0; }                #
      __keys_update()       { printf_cyan "Updating DNF/RPM keys"; sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null || true; return 0; }           #
      __keys_reinstall() {                                                                                                       #
        local rc=0                                                                                                               #
        printf_cyan "Reinstalling DNF keyring"                                                                                  #
        sudo --preserve-env=PATH /usr/bin/dnf reinstall -y redhat-release 2>/dev/null || true                                   #
        sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null || rc=$((rc + 1))                                         #
        return $rc                                                                                                               #
      }                                                                                                                          #
    # yum fedora based setup
    elif [ -f "$(builtin type -P yum 2>/dev/null)" ]; then                                                                        #
      PKMGR_TYPE="yum"                                                                                                            #
      execute_pkg_check="true"                                                                                                    #
      dotfilesrepo_url="$PKMGR_GIT_REPO/$PKMGR_GIT_DOTFILES"                                                                      #
