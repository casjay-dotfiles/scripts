      execute_pkg_check() { __cmd_exists "$1" || rpm -qi "$1" &>/dev/null || return 1; }                                         #
      __pkmgrgpgskip()      { printf_cyan "Updating YUM with GPG check disabled"; sudo --preserve-env=PATH /usr/bin/yum update --nogpgcheck -y || return 1; }  #
      __pkmgrbrokenkeyfix() {                                                                                                     #
