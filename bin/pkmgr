# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Variables - Distro specific
case "$(uname -s)" in                                                                                                                   #
Linux)                                                                                                                                  #
  if [ -f "$(builtin type -P apt-get 2>/dev/null)" ]; then                                                                              #
    pkmgrcheckbin_opts="-q -y --ignore-hold --allow-change-held-packages --allow-unauthenticated -s dist-upgrade"                       #
    export DEBIAN_FRONTEND=noninteractive                                                                                               #
    export APT_OPTS="-o Dpkg::Options::='--force-confdef' -o Dpkg::Options::='--force-confold'"                                         #
    dotfilesrepo="$REPODF/apt"                                                                                                          #
    pkgmgrbin="sudo -HE --preserve-env=PATH /usr/bin/apt-get"                                                                           #
    pkgmgrbinins="$pkgmgrbin install"                                                                                                   #
    pkgmgrbininssil="$pkgmgrbin install $APT_OPTS --ignore-missing -yy -qq --allow-unauthenticated --assume-yes"                        #
    pkgmgrbinremsil="$pkgmgrbin remove -yy -qq --assume-yes --purge"                                                                    #
    pkgmgrbinupdsil="$pkgmgrbin dist-upgrade $APT_OPTS --ignore-missing -yy -qq --allow-unauthenticated --assume-yes"                   #
    pkgmgrbinupdcron="$pkgmgrbin dist-upgrade $APT_OPTS --ignore-missing -yy --allow-unauthenticated --assume-yes"                      #
    pkgmgrbindel="$pkgmgrbin remove --purge"                                                                                            #
    pkgmgrbinsea="sudo -HE --preserve-env=PATH /usr/bin/apt-cache search"                                                               #
    pkgmgrbinupd="$pkgmgrbin dist-upgrade"                                                                                              #
    pkgmgrbincle="$pkgmgrbin clean"                                                                                                     #
    pkgmgrbincac="$pkgmgrbin update"                                                                                                    #
    pkmgrcheckbin="$(builtin type -P apt 2>/dev/null)"                                                                                  #
    pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin $pkmgrcheckbin_opts 2>/dev/null | grep '^Inst' | wc -l || echo 0; } #
    pkgmgrexport() { dpkg -l | grep ^ii | awk '{print $2}' | sed "s#:.*##g" | sort -u; }                                                #
    #
  elif [ -f "$(builtin type -P apt 2>/dev/null)" ]; then #
    pkmgrcheckbin_opts="-q -y --ignore-hold --allow-change-held-packages --allow-unauthenticated -s dist-upgrade"
    export DEBIAN_FRONTEND=noninteractive                                                                                               #
    export APT_OPTS="-o Dpkg::Options::='--force-confdef' -o Dpkg::Options::='--force-confold'"                                         #
    dotfilesrepo="$REPODF/apt"                                                                                                          #
    pkgmgrbin="sudo -HE --preserve-env=PATH /usr/bin/apt"                                                                               #
    pkgmgrbinins="$pkgmgrbin install"                                                                                                   #
    pkgmgrbininssil="$pkgmgrbin install $APT_OPTS --ignore-missing -yy -qq --allow-unauthenticated --assume-yes"                        #
    pkgmgrbinremsil="$pkgmgrbin remove -yy -qq --assume-yes --purge"                                                                    #
    pkgmgrbinupdsil="$pkgmgrbin dist-upgrade $APT_OPTS --ignore-missing -yy -qq --allow-unauthenticated --assume-yes"                   #
    pkgmgrbinupdcron="$pkgmgrbin dist-upgrade $APT_OPTS --ignore-missing -yy --allow-unauthenticated --assume-yes"                      #
    pkgmgrbindel="$pkgmgrbin remove --purge"                                                                                            #
    pkgmgrbinsea="sudo -HE --preserve-env=PATH /usr/bin/apt-cache search"                                                               #
    pkgmgrbinupd="$pkgmgrbin dist-upgrade"                                                                                              #
    pkgmgrbincle="$pkgmgrbin clean"                                                                                                     #
    pkgmgrbincac="$pkgmgrbin update"                                                                                                    #
    pkmgrcheckbin="$(builtin type -P apt 2>/dev/null)"                                                                                  #
    pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin $pkmgrcheckbin_opts 2>/dev/null | grep '^Inst' | wc -l || echo 0; } #
    pkgmgrexport() { dpkg -l | grep ^ii | awk '{print $2}' | sed "s#:.*##g" | sort -u; }                                                #
    #
  elif [ -f "$(builtin type -P pacman 2>/dev/null)" ]; then                                                                       #
    dotfilesrepo="$REPODF/pacman"                                                                                                 #
    pkgmgrbin="sudo -HE --preserve-env=PATH /usr/bin/pacman"                                                                      #
    pkgmgrbinins="$pkgmgrbin -S --noconfirm --overwrite='*'"                                                                      #
    pkgmgrbininssil="$pkgmgrbin -S --noconfirm --needed --overwrite='*' "                                                         #
    pkgmgrbinremsil="$pkgmgrbin -R --noconfirm"                                                                                   #
    pkgmgrbinupdsil="$pkgmgrbin -Syyu --noconfirm"                                                                                #
    pkgmgrbinupdcron="$pkgmgrbin -Syyu --noconfirm"                                                                               #
    pkgmgrbindel="$pkgmgrbin -R"                                                                                                  #
    pkgmgrbinsea="$pkgmgrbin -Ss"                                                                                                 #
    pkgmgrbinupd="$pkgmgrbin -Syyu --needed --overwrite='*'"                                                                      #
    pkgmgrbincle="$pkgmgrbin -Scc --noconfirm"                                                                                    #
    pkgmgrbincac="$pkgmgrbin -Syy"                                                                                                #
    pkmgrcheckbin="$(builtin type -P pacman 2>/dev/null)"                                                                         #
    pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin -Qu 2>/dev/null | wc -l || echo 0; }                          #
    pkgmgrexport() { pacman -Qqe | grep -v "$(pacman -Qqm)" && echo '###' && pacman -Qqet | grep -v "$(pacman -Qqm)" | sort -u; } #
    #
  elif [ -f "$(builtin type -P pamac 2>/dev/null)" ]; then                                                           #
    dotfilesrepo="$REPODF/pacman"                                                                                    #
    pkgmgrbin="sudo -HE  /usr/bin/pamac"                                                                             #
    pkgmgrbinins="$pkgmgrbin install --noconfirm"                                                                    #
    pkgmgrbininssil="$pkgmgrbin install --noconfirm"                                                                 #
    pkgmgrbinremsil="$pkgmgrbin remove --noconfirm"                                                                  #
    pkgmgrbinupdsil="$pkgmgrbin upgrade -a"                                                                          #
    pkgmgrbinupdcron="$pkgmgrbin upgrade -a"                                                                         #
    pkgmgrbindel="$pkgmgrbin remove"                                                                                 #
    pkgmgrbinsea="$pkgmgrbin search -a"                                                                              #
    pkgmgrbinupd="$pkgmgrbin upgrade -a"                                                                             #
    pkgmgrbincle="$pkgmgrbin clean"                                                                                  #
    pkgmgrbincac="$pkgmgrbin checkupdates"                                                                           #
    pkmgrcheckbin="$(builtin type -P pamac 2>/dev/null)"                                                             #
    pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin checkupdates -a 2>/dev/null | wc -l || echo 0; } #
    pkgmgrexport() { pacman -Qqet | grep -v "$(pacman -Qqm)" | sort -u; }                                            #
    #
  elif [ -f "$(builtin type -P dnf 2>/dev/null)" ]; then                                                                                #
    dotfilesrepo="$REPODF/yum"                                                                                                          #
    pkgmgrbin="sudo -HE --preserve-env=PATH /usr/bin/dnf"                                                                               #
    pkgmgrbinins="$pkgmgrbin install"                                                                                                   #
    pkgmgrbininssil="$pkgmgrbin install -y -q"                                                                                          #
    pkgmgrbinremsil="$pkgmgrbin remove -y -q"                                                                                           #
    pkgmgrbinupdsil="$pkgmgrbin update -y -q"                                                                                           #
    pkgmgrbinupdcron="$pkgmgrbin update -y"                                                                                             #
    pkgmgrbindel="$pkgmgrbin remove"                                                                                                    #
    pkgmgrbinsea="$pkgmgrbin search"                                                                                                    #
    pkgmgrbinupd="$pkgmgrbin update"                                                                                                    #
    pkgmgrbincle="$pkgmgrbin clean"                                                                                                     #
    pkgmgrbincac="$pkgmgrbin makecache"                                                                                                 #
    pkmgrcheckbin="$(builtin type -P dnf 2>/dev/null)"                                                                                  #
    pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin -q check-update 2>/dev/null | grep -v Security | wc -l || echo 0; } #
    pkgmgrexport() { rpm -qa --qf '%{name}\n' | grep -v gpg-pubkey | sort -u; }                                                         #
    #
  elif [ -f "$(builtin type -P yum 2>/dev/null)" ]; then                                                                                #
    dotfilesrepo="$REPODF/yum"                                                                                                          #
    pkgmgrbin="sudo -HE --preserve-env=PATH /usr/bin/yum"                                                                               #
    pkgmgrbinins="$pkgmgrbin install"                                                                                                   #
    pkgmgrbininssil="$pkgmgrbin install -y -q"                                                                                          #
    pkgmgrbinremsil="$pkgmgrbin remove -y -q"                                                                                           #
    pkgmgrbinupdsil="$pkgmgrbin install -y -q"                                                                                          #
    pkgmgrbinupdcron="$pkgmgrbin install -y"                                                                                            #
    pkgmgrbindel="$pkgmgrbin remove"                                                                                                    #
    pkgmgrbinsea="$pkgmgrbin search"                                                                                                    #
    pkgmgrbinupd="$pkgmgrbin update"                                                                                                    #
    pkgmgrbincle="$pkgmgrbin clean"                                                                                                     #
    pkgmgrbincac="$pkgmgrbin makecache"                                                                                                 #
    pkmgrcheckbin="$(builtin type -P yum 2>/dev/null)"                                                                                  #
    pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin -q check-update 2>/dev/null | grep -v Security | wc -l || echo 0; } #
    pkgmgrexport() { rpm -qa --qf '%{name}\n' | grep -v gpg-pubkey | sort -u; }                                                         #
    #
  elif [ -f "$(builtin type -P xbps-install 2>/dev/null)" ]; then                                    #
    dotfilesrepo="$REPODF/xbps"                                                                      #
    pkgmgrbin="sudo -HE --preserve-env=PATH /usr/bin/xbps-install"                                   #
    pkgmgrbinins="$pkgmgrbin -S"                                                                     #
    pkgmgrbininssil="$pkgmgrbin -Sy"                                                                 #
    pkgmgrbinremsil="sudo -HE --preserve-env=PATH /usr/bin/xbps-remove -y"                           #
    pkgmgrbinupdsil="$pkgmgrbin -Syu"                                                                #
    pkgmgrbinupdcron="$pkgmgrbin -Syu"                                                               #
    pkgmgrbindel="sudo -HE --preserve-env=PATH /usr/bin/xbps-remove"                                 #
    pkgmgrbinsea="sudo -HE --preserve-env=PATH /usr/bin/xbps-query -Rs"                              #
    pkgmgrbinupd="$pkgmgrbin -Syu "                                                                  #
    pkgmgrbincle="sudo -HE --preserve-env=PATH /usr/bin/xbps-remove -O"                              #
    pkgmgrbincac="$pkgmgrbin -S"                                                                     #
    pkmgrcheckbin="$(builtin type -P xbps-install 2>/dev/null)"                                      #
    pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin 2>/dev/null | wc -l || echo 0; } #
    pkgmgrexport() { xbps-query -l; }                                                                #
  fi                                                                                                 #
  ;;                                                                                                 #
  #
Darwin)                                                                                                       #
  if [ -n "$(builtin type -P brew 2>/dev/null)" ]; then                                                       #
    dotfilesrepo="$REPODF/brew"                                                                               #
    if [ "$1" = "--cask" ]; then                                                                              #
      pkgmgrbin="sudo -HE --preserve-env=PATH -u $RUN_USER brew --cask"                                       #
    else                                                                                                      #
      pkgmgrbin="sudo -HE --preserve-env=PATH -u $RUN_USER brew"                                              #
    fi                                                                                                        #
    pkgmgrbinins="$pkgmgrbin install"                                                                         #
    pkgmgrbininssil="$pkgmgrbin install -f"                                                                   #
    pkgmgrbinremsil="$pkgmgrbin remove -f"                                                                    #
    pkgmgrbinupdsil="$pkgmgrbin upgrade -f"                                                                   #
    pkgmgrbinupdcron="$pkgmgrbin upgrade -f"                                                                  #
    pkgmgrbindel="$pkgmgrbin remove"                                                                          #
    pkgmgrbinsea="$pkgmgrbin search"                                                                          #
    pkgmgrbinupd="$pkgmgrbin upgrade"                                                                         #
    pkgmgrbincle="$pkgmgrbin cleanup"                                                                         #
    pkgmgrbincac="$pkgmgrbin update"                                                                          #
    pkmgrcheckbin="$(builtin type -P brew 2>/dev/null)"                                                       #
    pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin outdated 2>/dev/null | wc -l || echo 0; } #
    pkgmgrexport() { $pkgmgrbin list --cask && $pkgmgrbin list --formula | sort -u; }                         #
  fi                                                                                                          #
  ;;                                                                                                          #
CYGWIN* | MINGW32* | MSYS* | MINGW*)                                                                          #
  dotfilesrepo="$REPODF/win"                                                                                  #
  pkgmgrbin="choco"                                                                                           #
  pkgmgrbinins="choco install"                                                                                #
  pkgmgrbininssil="choco install -yf"                                                                         #
  pkgmgrbinremsil="choco remove -f"                                                                           #
  pkgmgrbinupdsil="choco update -yf"                                                                          #
  pkgmgrbinupdcron="choco update -yf"                                                                         #
  pkgmgrbindel="choco remove"                                                                                 #
  pkgmgrbinsea="choco search"                                                                                 #
  pkgmgrbinupd="choco update"                                                                                 #
  pkgmgrbincle="choco cleanup"                                                                                #
  pkmgrcheckbin="$(builtin type -P false 2>/dev/null)"                                                        #
  pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && $pkmgrcheckbin 2>/dev/null | wc -l || echo 0; }            #
  pkgmgrexport() { echo not enabled; }                                                                        #
  ;;                                                                                                          #
*)                                                                                                            #
  printf_exit "Unknown OS or OS not supported"                                                                #
  ;;                                                                                                          #
esac                                                                                                          #
#
if [ -f "$(builtin type -P yay 2>/dev/null)" ] && [ "$ENABLE_AUR" = "true" ]; then                                               #
  dotfilesrepo="$REPODF/pacman"                                                                                                  #
  pkgmgrbin="sudo -HE --preserve-env=PATH -HE -u $RUN_USER /usr/bin/yay"                                                         #
  pkgmgrbinins="$pkgmgrbin -S --cleanafter --overwrite='*'"                                                                      #
  pkgmgrbininssil="$pkgmgrbin -Sy --needed --noconfirm --cleanafter --overwrite='*'"                                             #
  pkgmgrbinremsil="$pkgmgrbin -Ry --noconfirm --needed --noconfirm"                                                              #
  pkgmgrbinupdsil="$pkgmgrbin -Syyu --noconfirm"                                                                                 #
  pkgmgrbinupdcron="$pkgmgrbin -Syyu --noconfirm"                                                                                #
  pkgmgrbindel="$pkgmgrbin -R"                                                                                                   #
  pkgmgrbinsea="$pkgmgrbin -Ss"                                                                                                  #
  pkgmgrbinupd="$pkgmgrbin -Syyu --needed --overwrite='*'"                                                                       #
  pkgmgrbincle="$pkgmgrbin -Scc --noconfirm"                                                                                     #
  pkgmgrbincac="$pkgmgrbin -Syy"                                                                                                 #
  pkmgrcheckbin="$(builtin type -P yay 2>/dev/null)"                                                                             #
  pkmgrcheckupdates() { [ -n "$pkmgrcheckbin" ] && echo "$(pacman -Qu 2>/dev/null && yay -Qum 2>/dev/null)" | wc -l || echo 0; } #
  pkgmgrexport() { pacman -Qqet | grep -v "$(pacman -Qqm)" | sort -u; }                                                          #
fi                                                                                                                               #
if cmd_exists yay pacman; then
  pkmgrcheckupdates() {
    pacman="$(pacman -Qu 2>/dev/null | wc -l | grep '^' || echo 0)"
    yay="$(yay -Qum 2>/dev/null | wc -l | grep '^' || echo 0)"
    updates=$(("$pacman" + "$yay")) || updates=0
    echo $updates
  }
fi
pkginit="$pkgmgrbincle ; $pkgmgrbincac ; $pkgmgrbinupdsil"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
check) # Check for updates
  shift 1
  builtin command sudo -n true &>/dev/null && $pkgmgrbincac &>/dev/null
  UPDATECHECKFILE="$CHECK_FOR_UPDATES_CACHEDIR/update_check"
  [[ "$1" = "force" || "$FORCE_INSTALL" = "yes" ]] && __rm_rf "$UPDATECHECKFILE"
  __find_mtime "$UPDATECHECKFILE" "1800" || __rm_rf "$UPDATECHECKFILE"
  if [ ! -f "$UPDATECHECKFILE" ]; then
    builtin command sudo -n true &>/dev/null && $pkgmgrbincac &>/dev/null
    run_updatecheck >"$UPDATECHECKFILE"
  fi
  [ -f "$UPDATECHECKFILE" ] && cat "$UPDATECHECKFILE" || echo 0
  exit ${exitCode:-$?}
  ;;

available) # List
  shift 1
  run_install_available "$APPNAME"
  exit ${exitCode:-$?}
  ;;

aliases) # Generate aliases
  shift 1
  if [ -d "$HOME/.config/bash/local" ] && grep -q userbashprofilelocal "$HOME/.bashrc" &>/dev/null; then
    ALIASFILE="$HOME/.config/bash/local/pkmgr.bash"
  else
    ALIASFILE="$HOME/.bash_profile"
  fi
  [ "$1" = "help" ] && printf_help "Print to terminal or --save to export to bash_profile"
  if [ "$1" = "--save" ]; then
    printf_green "Saving the aliases to your bash profile"
    if grep -vq "# pkmgr aliases" "$ALIASFILE"; then
      echo "# pkmgr aliases - Do not remove this line" >>"$ALIASFILE"
      __aliases >>"$ALIASFILE"
      printf_custom "5" "$ALIASFILE"
    fi
  else
    __aliases | printf_readline "2"
    printf_custom "3" "add --save to save this to the alias file"
    printf_custom "5" "$ALIASFILE"
    exit ${exitCode:-$?}
  fi
  ;;

cron) # run via cron
  shift 1
  [ "$1" = "help" ] && printf_help "Options are add, remove, or run"
  __schedule "$@"
  ;;

ask) # Ask user to install missing
  shift 1
  if [ -n "$DISPLAY" ]; then
    __attemp_install_menus "$@"
  else
    __check_app "$@" && printf_green "Installed: $*" || printf_exit 1 1 "Install of $* failed"
  fi
  echo
  ;;

keys | -k)
  shift 1
  if cmd_exists pacman-key; then
    [ "$1" = "help" ] && printf_help "Usage: $APPNAME keys [arch,manjaro,arcolinux] - Manage arch keys"
    sudo -HE rm -R /etc/pacman.d/gnupg/
    sudo -HE rm -R /root/.gnupg/
    sudo -HE gpg --refresh-keys
    sudo -HE pacman-key --init && sudo -HE pacman-key --populate "${1:-archlinux}"
    sudo -HE pacman-key --refresh-keys
  else
    printf_error "This is only supported on Arch based distros"
  fi
  ;;

install | -i) # Install packages
  shift 1
  [ "$1" = "help" ] && printf_help "Install a package"
  am_i_online --error || exit 1
  declare -a LISTARRAY="$*"
  #for pkg in ${LISTARRAY[*]}; do
  $pkgmgrbinins "$@" && exitCode+=0 || exitCode+=1
  #done
  exit ${exitCode:-$?}
  ;;

remove | -r) # Remove packages
  shift 1
  [ "$1" = "help" ] && printf_help "Remove a package"
  declare -a LISTARRAY="$*"
  #for pkg in ${LISTARRAY[*]}; do
  $pkgmgrbindel "$@" && exitCode+=0 || exitCode+=1
  #done
  exit ${exitCode:-$?}
  ;;

list) # Install package in a list file
  shift 1
  [ "$1" = "help" ] && printf_help "Install package via a list: pkmgr list ./listToInstall"
  am_i_online --error || exit 1
  PCKLIST="$(grep -Ev '^$|^#' "$1" | sort -u | tr '\n' ' ' && echo)"
  declare -a LISTARRAY=$PCKLIST
  for pkg in ${LISTARRAY[*]}; do
    __execute "$pkgmgrbinins $pkg" "Installing $pkg" && exitCode+=0 || exitCode+=1
  done
  exit ${exitCode:-$?}
  ;;

curl) # Download a list file and install
  shift 1
  [ "$1" = "help" ] && printf_help "pkmgr curl arch min or pkmgr curl fullURLtoList"
  am_i_online --error || exit 1
  curl_run "$@"
  set --
  PCKLIST="$(grep -Ev '^$|^#' "$PKMGR_TEMP_FILE" | sort -u | tr '\n' ' ' && echo)"
  declare -a LISTARRAY=$PCKLIST
  for pkg in ${LISTARRAY[*]}; do
    __execute "$pkgmgrbinins $pkg" "Installing $pkg" && exitCode+=0 || exitCode+=1
  done
  [ -n "$VDEBUG" ] || __rm_rf "$PKMGR_TEMP_FILE"
  exit ${exitCode:-$?}
  ;;

dotfiles) # Install dfmgr packages
  shift 1
  [ "$1" = "help" ] && printf_help "pkmgr dotfiles git"
  am_i_online --error || exit 1
  dotfiles_run "$@"
  PCKLIST="$(grep -Ev '^$|^#' "$PKMGR_TEMP_FILE" | sort -u | tr '\n' ' ' && echo)"
  declare -a LISTARRAY=$PCKLIST
  for pkg in ${LISTARRAY[*]}; do
    __execute "$pkgmgrbininssil $pkg" "Installing $pkg" && exitCode+=0 || exitCode+=1
  done
  [ -n "$VDEBUG" ] || __rm_rf "$PKMGR_TEMP_FILE"
  exit ${exitCode:-$?}
  ;;

script) # Execute a script
  shift 1
  [ "$1" = "help" ] && printf_help "pkmgr script ./myScript or fullURLtoScript"
  am_i_online --error || exit 1
  script_run "$@" && exitCode+=0 || exitCode+=1
  exit ${exitCode:-$?}
  ;;

upgrade | update) # Update packages
  shift 1
  [ "$1" = "help" ] && printf_help "Update your system"
  declare -a LISTARRAY=$PCKLIST
  am_i_online --error || exit 1
  if [ -f "$(builtin type -P systemmgr)" ]; then
    sudo -HE systemmgr install installer && exitCode+=0 || exitCode+=1
  fi
  $pkgmgrbinupd "$@" && exitCode+=0 || exitCode+=1
  exit ${exitCode:-$?}
  ;;

export) # Export installed packages
  shift 1
  [ "$1" = "help" ] && printf_help "Export installed packages to a list"
  exportpkg
  ;;

clean) # Clean package manager files
  shift 1
  [ "$1" = "help" ] && printf_help "Clean up package manager files"
  $pkgmgrbincle
  ;;

init) # Update package manager and upgrade system
  shift 1
  [ "$1" = "help" ] && printf_help "Initialize the system by making the cache and updating"
  am_i_online --error || exit 1
  __execute "$pkginit" "Initializing System" && exitCode+=0 || exitCode+=1
  exit ${exitCode:-$?}
  ;;

makecache) # Create the package manage cache file
  shift 1
  [ "$1" = "help" ] && printf_help "Create the cache for the package manager"
  __devnull $pkgmgrbincac && exitCode+=0 || exitCode+=1
  exit ${exitCode:-$?}
  ;;

search) # Search for packages
  shift 1
  [ "$1" = "help" ] && printf_help "Search for a package"
  if [ "$1" == "show-raw" ]; then
    shift 1
    declare -a LISTARRAY="$*"
  else
    declare -a LISTARRAY="$*"
  fi
  searchcmd $LISTARRAY
  ;;

required) # Install required files
  shift 1
  [ "$1" = "help" ] && printf_help "Install required packages"
  am_i_online --error || exit 1
  declare -a LISTARRAY="$*"
  for pkg in ${LISTARRAY[*]}; do
    __execute "$pkgmgrbininssil $pkg" "Installing $pkg" exitCode+=0 || exitCode+=1
  done
  exit ${exitCode:-$?}
  ;;

silent-install) # Silently install packages
  shift 1
  [ "$1" = "help" ] && printf_help "Silently install packages"
  am_i_online --error || exit 1
  declare -a LISTARRAY="$*"
  for pkg in ${LISTARRAY[*]}; do
    __devnull "$pkgmgrbininssil" "$pkg" && exitCode+=0 || exitCode+=1
  done
  exit ${exitCode:-$?}
  ;;

silent-remove) # Silently remove packages
  shift 1
  [ "$1" = "help" ] && printf_help "Silently remove packages"
  declare -a LISTARRAY="$*"
  for pkg in ${LISTARRAY[*]}; do
    __devnull $pkgmgrbinremsil "*$pkg*" && exitCode+=0 || exitCode+=1
  done
  exit ${exitCode:-$?}
  ;;

silent-upgrade | silent-update) # Silently update packages
  shift 1
  [ "$1" = "help" ] && printf_help "Silently upgrade your system"
  am_i_online --error || exit 1
  if [ -f "$(builtin type -P systemmgr)" ]; then
    __devnull sudo -HE systemmgr install scripts && exitCode+=0 || exitCode+=1
  fi
  __devnull $pkgmgrbinupdsil && exitCode+=0 || exitCode+=1
  exit ${exitCode:-$?}
  ;;

cpan | perl) # perl CPAN modules
  shift 1
  case $1 in
  install) # Install perl modules
    shift 1
    [ "$1" = "help" ] && printf_help "install perl modules via cpan"
    am_i_online --error || exit 1
    declare -a LISTARRAY="$*"
    for pkg in ${LISTARRAY[*]}; do
      cpan_run "$pkg" && exitCode+=0 || exitCode+=1
    done
    exit ${exitCode:-$?}
    ;;

  remove) # Remove perl modules
    shift 1
    [ "$1" = "help" ] && printf_help "Remove perl modules via cpan"
    declare -a LISTARRAY="$*"
    for pkg in ${LISTARRAY[*]}; do
      cpan_remove "$pkg"
    done
    ;;

  check) # Check to see if perl modules are installed
    shift 1
    [ "$1" = "help" ] && printf_help "Check for cpan module"
    declare -a LISTARRAY="$*"
    for pkg in ${LISTARRAY[*]}; do
      __perl_exists --sudo "$pkg" || printf_red "CPAN module $pkg is missing"
    done
    ;;

  *) # Install perl modules
    [ "$1" = "help" ] && printf_help "install perl modules via cpan"
    am_i_online --error || exit 1
    declare -a LISTARRAY="$*"
    for pkg in ${LISTARRAY[*]}; do
      cpan_run "$pkg" && exitCode+=0 || exitCode+=1
    done
    exit ${exitCode:-$?}
    ;;
  esac
  ;;

