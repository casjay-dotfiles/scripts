      }                                                                                                                          #
      __pkgfix()            { printf_cyan "Running YUM distro-sync"; sudo --preserve-env=PATH /usr/bin/yum distro-sync -y 2>/dev/null || sudo --preserve-env=PATH /usr/bin/yum update -y || return 1; } #
      __keys_remove()       { printf_cyan "Removing RPM GPG keys"; sudo rpm -e gpg-pubkey --allmatches 2>/dev/null; return 0; }                                 #
      __keys_init()         { printf_cyan "Importing RPM GPG keys"; sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null || return 0; }                #
      __keys_update()       { printf_cyan "Updating YUM/RPM keys"; sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null || true; return 0; }           #
      __keys_reinstall() {                                                                                                       #
        local rc=0                                                                                                               #
        printf_cyan "Reinstalling YUM keyring"                                                                                  #
        sudo --preserve-env=PATH /usr/bin/yum reinstall -y redhat-release 2>/dev/null || true                                   #
        sudo rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-* 2>/dev/null || rc=$((rc + 1))                                         #
        return $rc                                                                                                               #
      }                                                                                                                          #
      # tdnf photon based setup
    elif [ -f "$(builtin type -P tdnf 2>/dev/null)" ]; then                                                                         #
