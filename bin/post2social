#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : post2social --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : post2social
# @Description   : Post to mastodon and twitter
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$POST2SOCIAL_TEMP_FILE" ] && [ -f "$POST2SOCIAL_TEMP_FILE" ] && rm -Rf "$POST2SOCIAL_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$POST2SOCIAL_CONFIG_DIR/$POST2SOCIAL_CONFIG_FILE"
  [ -d "$POST2SOCIAL_CONFIG_DIR" ] || mkdir -p "$POST2SOCIAL_CONFIG_DIR"
  [ -d "$POST2SOCIAL_CONFIG_BACKUP_DIR" ] || mkdir -p "$POST2SOCIAL_CONFIG_BACKUP_DIR"
  [ -f "$POST2SOCIAL_CONFIG_DIR/$POST2SOCIAL_CONFIG_FILE" ] &&
    cp -Rf "$POST2SOCIAL_CONFIG_DIR/$POST2SOCIAL_CONFIG_FILE" "$POST2SOCIAL_CONFIG_BACKUP_DIR/$POST2SOCIAL_CONFIG_FILE.$$"
  cat <<EOF >"$POST2SOCIAL_CONFIG_DIR/$POST2SOCIAL_CONFIG_FILE"
# Settings for post2social

# Notification settings
POST2SOCIAL_GOOD_MESSAGE="${POST2SOCIAL_GOOD_MESSAGE:-Everything Went OK}"
POST2SOCIAL_ERROR_MESSAGE="${POST2SOCIAL_ERROR_MESSAGE:-Well something seems to have gone wrong}"
POST2SOCIAL_NOTIFY_ENABLED="${POST2SOCIAL_NOTIFY_ENABLED:-yes}"
POST2SOCIAL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
POST2SOCIAL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$POST2SOCIAL_NOTIFY_CLIENT_ICON}"

# Colorization settings
POST2SOCIAL_OUTPUT_COLOR="${POST2SOCIAL_OUTPUT_COLOR:-5}"
POST2SOCIAL_OUTPUT_COLOR_GOOD="${POST2SOCIAL_OUTPUT_COLOR_GOOD:-2}"
POST2SOCIAL_OUTPUT_COLOR_ERROR="${POST2SOCIAL_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$POST2SOCIAL_CONFIG_DIR/$POST2SOCIAL_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for post2social has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      exit 1
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__twitter() { twitter set "$1"; }
__mastodon() { toot post "$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__post_it() {
  __twitter "$1"
  __mastodon "$1"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
POST2SOCIAL_LOG_DIR="${POST2SOCIAL_LOG_DIR:-$HOME/.local/log/post2social}"
POST2SOCIAL_CACHE_DIR="${POST2SOCIAL_CACHE_DIR:-$HOME/.cache/post2social}"
POST2SOCIAL_CONFIG_DIR="${POST2SOCIAL_CONFIG_DIR:-$HOME/.config/myscripts/post2social}"
POST2SOCIAL_CONFIG_BACKUP_DIR="${POST2SOCIAL_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/post2social/backups}"
POST2SOCIAL_TEMP_DIR="${POST2SOCIAL_TEMP_DIR:-$HOME/.local/tmp/system_scripts/post2social}"
POST2SOCIAL_OPTIONS_DIR="${POST2SOCIAL_OPTIONS_DIR:-$HOME/.local/share/myscripts/post2social/options}"
POST2SOCIAL_TEMP_FILE="${POST2SOCIAL_TEMP_FILE:-$(mktemp $POST2SOCIAL_TEMP_DIR/XXXXXX 2>/dev/null)}"
POST2SOCIAL_CONFIG_FILE="${POST2SOCIAL_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
POST2SOCIAL_OUTPUT_COLOR="${POST2SOCIAL_OUTPUT_COLOR:-4}"
POST2SOCIAL_OUTPUT_COLOR_2="${POST2SOCIAL_OUTPUT_COLOR:-6}"
POST2SOCIAL_OUTPUT_COLOR_GOOD="${POST2SOCIAL_OUTPUT_COLOR_GOOD:-2}"
POST2SOCIAL_OUTPUT_COLOR_ERROR="${POST2SOCIAL_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
POST2SOCIAL_GOOD_MESSAGE="${POST2SOCIAL_GOOD_MESSAGE:-Everything Went OK}"
POST2SOCIAL_ERROR_MESSAGE="${POST2SOCIAL_ERROR_MESSAGE:-Well something seems to have gone wrong}"
POST2SOCIAL_NOTIFY_ENABLED="${POST2SOCIAL_NOTIFY_ENABLED:-yes}"
POST2SOCIAL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
POST2SOCIAL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$POST2SOCIAL_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$POST2SOCIAL_CONFIG_DIR/$POST2SOCIAL_CONFIG_FILE" ] && . "$POST2SOCIAL_CONFIG_DIR/$POST2SOCIAL_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$POST2SOCIAL_LOG_DIR" ] || mkdir -p "$POST2SOCIAL_LOG_DIR" &>/dev/null
[ -d "$POST2SOCIAL_TEMP_DIR" ] || mkdir -p "$POST2SOCIAL_TEMP_DIR" &>/dev/null
[ -d "$POST2SOCIAL_CACHE_DIR" ] || mkdir -p "$POST2SOCIAL_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$POST2SOCIAL_CONFIG_DIR/$POST2SOCIAL_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,mastodon:,twitter:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    POST2SOCIAL_CWD="$2"
    shift 2
    ;;
  --twitter)
    __twitter "$@"
    shift 2
    ;;
  --mastodon)
    __mastodon "$@"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$POST2SOCIAL_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${POST2SOCIAL_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${POST2SOCIAL_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${POST2SOCIAL_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${POST2SOCIAL_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
mastadon)
  shift 1
  __mastodon "$@"
  ;;

twitter)
  shift 1
  __twitter "$@"
  ;;

*)
  __post_it "$@"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
