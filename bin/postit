#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202111222241-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : postit --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Monday, Nov 22, 2021 22:41 EST
# @File          : postit
# @Description   : create blog post from terminal using github
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202111222241-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$POSTIT_CONFIG_DIR/$POSTIT_CONFIG_FILE"
  [ -d "$POSTIT_CONFIG_DIR" ] || mkdir -p "$POSTIT_CONFIG_DIR"
  [ -d "$POSTIT_CONFIG_BACKUP_DIR" ] || mkdir -p "$POSTIT_CONFIG_BACKUP_DIR"
  [ -f "$POSTIT_CONFIG_DIR/$POSTIT_CONFIG_FILE" ] &&
    cp -Rf "$POSTIT_CONFIG_DIR/$POSTIT_CONFIG_FILE" "$POSTIT_CONFIG_BACKUP_DIR/$POSTIT_CONFIG_FILE.$$"
  cat <<EOF >"$POSTIT_CONFIG_DIR/$POSTIT_CONFIG_FILE"
# Settings for postit
POSTIT_TEMPLATE_FILE="${POSTIT_TEMPLATE_FILE:-template.md}"
POSTIT_GITHUB_AUTH_TOKEN="${POSTIT_GITHUB_AUTH_TOKEN:-$GITHUB_ACCESS_TOKEN}"
POSTIT_DEFAULT_EDITOR="${POSTIT_DEFAULT_EDITOR:-vim}"
POSTIT_AUTHOR="${POSTIT_AUTHOR:-$USER}"
POSTIT_AUTHOR_SITE="${POSTIT_AUTHOR_SITE:-}"

# Notification settings
POSTIT_GOOD_MESSAGE="${POSTIT_GOOD_MESSAGE:-Everything Went OK}"
POSTIT_ERROR_MESSAGE="${POSTIT_ERROR_MESSAGE:-Well something seems to have gone wrong}"
POSTIT_NOTIFY_ENABLED="${POSTIT_NOTIFY_ENABLED:-yes}"
POSTIT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
POSTIT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$POSTIT_NOTIFY_CLIENT_ICON}"

# Colorization settings
POSTIT_OUTPUT_COLOR="${POSTIT_OUTPUT_COLOR:-5}"
POSTIT_OUTPUT_COLOR_GOOD="${POSTIT_OUTPUT_COLOR_GOOD:-2}"
POSTIT_OUTPUT_COLOR_ERROR="${POSTIT_OUTPUT_COLOR_ERROR:-1}"

EOF

  if [ -f "$POSTIT_CONFIG_DIR/$POSTIT_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__template() {
  title="${1:-$POSTIT_BLOG_TITLE}"
  [[ -f "$POSTIT_CONFIG_DIR/$POSTIT_TEMPLATE_FILE" ]] || return 1
  cat <<EOF | tee
---
layout: post
title: $title
categories: blog
tags: dev
date: $(date +'%Y-%m-%d %H:%M')
author: ${POSTIT_AUTHOR:-$USER}
site: $POSTIT_AUTHOR_SITE
comments: true
---

# Head

EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
POSTIT_LOG_DIR="${POSTIT_LOG_DIR:-$HOME/.local/log/postit}"
POSTIT_CACHE_DIR="${POSTIT_CACHE_DIR:-$HOME/.cache/postit}"
POSTIT_CONFIG_DIR="${POSTIT_CONFIG_DIR:-$HOME/.config/myscripts/postit}"
POSTIT_OPTIONS_DIR="${POSTIT_OPTIONS_DIR:-$HOME/.local/share/myscripts/postit/options}"
POSTIT_CONFIG_BACKUP_DIR="${POSTIT_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/postit/backups}"
POSTIT_TEMP_DIR="${POSTIT_TEMP_DIR:-$HOME/.local/tmp/system_scripts/postit}"
POSTIT_CONFIG_FILE="${POSTIT_CONFIG_FILE:-settings.conf}"
POSTIT_GOOD_MESSAGE="${POSTIT_GOOD_MESSAGE:-Everything Went OK}"
POSTIT_ERROR_MESSAGE="${POSTIT_ERROR_MESSAGE:-Well something seems to have gone wrong}"
POSTIT_NOTIFY_ENABLED="${POSTIT_NOTIFY_ENABLED:-yes}"
POSTIT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
POSTIT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$POSTIT_NOTIFY_CLIENT_ICON}"
POSTIT_OUTPUT_COLOR="${POSTIT_OUTPUT_COLOR:-5}"
POSTIT_OUTPUT_COLOR_GOOD="${POSTIT_OUTPUT_COLOR_GOOD:-2}"
POSTIT_OUTPUT_COLOR_ERROR="${POSTIT_OUTPUT_COLOR_ERROR:-1}"

POSTIT_TEMPLATE_FILE="${POSTIT_TEMPLATE_FILE:-template.md}"
POSTIT_GITHUB_AUTH_TOKEN="${POSTIT_GITHUB_AUTH_TOKEN:-$GITHUB_ACCESS_TOKEN}"
POSTIT_DEFAULT_EDITOR="${POSTIT_DEFAULT_EDITOR:-vim}"
POSTIT_AUTHOR="${POSTIT_AUTHOR:-$USER}"
POSTIT_AUTHOR_SITE="${POSTIT_AUTHOR_SITE:-}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$POSTIT_CONFIG_DIR/$POSTIT_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$POSTIT_CONFIG_DIR/$POSTIT_CONFIG_FILE" ] && . "$POSTIT_CONFIG_DIR/$POSTIT_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$POSTIT_LOG_DIR" ] || mkdir -p "$POSTIT_LOG_DIR" &>/dev/null
[ -d "$POSTIT_TEMP_DIR" ] || mkdir -p "$POSTIT_TEMP_DIR" &>/dev/null
[ -d "$POSTIT_CACHE_DIR" ] || mkdir -p "$POSTIT_CACHE_DIR" &>/dev/null
POSTIT_TEMP_FILE="${POSTIT_TEMP_FILE:-$(mktemp $POSTIT_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$POSTIT_TEMP_FILE" ] && [ -f "$POSTIT_TEMP_FILE" ] && rm -Rf "$POSTIT_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$POSTIT_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${POSTIT_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${POSTIT_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${POSTIT_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${POSTIT_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    __help
    shift 1
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    POSTIT_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
POSTIT_BLOG_TITLE="${1:-$POSTIT_BLOG_TITLE}"
POSTIT_BLOG_REPO="${2:-$POSTIT_BLOG_REPO}"
POSTIT_BLOG_DIR="${3:-$POSTIT_BLOG_DIR}"
POSTIT_BLOG_FILE="$(date +'%Y-%m-%d')-${POSTIT_BLOG_TITLE}.md"
POSTIT_BLOG_FILENAME="${POSTIT_BLOG_FILE// /-}"
POSTIT_BLOG_API_URL="https://api.github.com/repos/$POSTIT_BLOG_REPO/contents/${POSTIT_BLOG_DIR:-_posts}/$POSTIT_BLOG_FILENAME"
POSTIT_BLOG_API_INFO="$(curl -q -LSs -H "Authorization: token $POSTIT_GITHUB_AUTH_TOKEN" "$POSTIT_BLOG_API_URL" 2>/dev/null | jq -r 2>/dev/null | grep '^')"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if echo $POSTIT_BLOG_API_INFO | grep -qE 'Not Found|get-repository-content'; then
  __template "$POSTIT_BLOG_TITLE" >"$POSTIT_TEMP_FILE"
else
  api_file="$(echo $POSTIT_BLOG_API_INFO | jq -r '.download_url')"
  sha="$(curl -q -LSs -H "Authorization: token $POSTIT_GITHUB_AUTH_TOKEN" "$POSTIT_BLOG_API_URL" 2>/dev/null | jq -r '.sha' 2>/dev/null | grep -v 'null')"
  curl -q -LSs "$api_file" >"$POSTIT_TEMP_FILE" 2>/dev/null
fi
[[ -f "$POSTIT_TEMP_FILE.err" ]] && __mv_f "$POSTIT_TEMP_FILE.err" "$POSTIT_TEMP_FILE"
$POSTIT_DEFAULT_EDITOR "$POSTIT_TEMP_FILE"
contents="$(base64 "$POSTIT_TEMP_FILE" | tr -d '\n\r')"
if [[ -n "$contents" ]]; then
  curl -LSs -X PUT \
    -H "Accept: application/vnd.github.v3+json" \
    -H "Authorization: token $POSTIT_GITHUB_AUTH_TOKEN" \
    -H "Content-Type: application/octet-stream" \
    "$POSTIT_BLOG_API_URL" -d '{"message":"🐜📓❇📓 New blog post 📓❇📓🐜","content":"'$contents'","sha":"'$sha'"}' &>"$POSTIT_LOG_DIR/$APPNAME.log"
  url="$(cat "$POSTIT_LOG_DIR/$APPNAME.log" | jq -r '.content.html_url' 2>/dev/null)"
  if [[ -n "$url" && "$url" != "null" ]]; then
    if grep -sqiv "documentation_url" "$POSTIT_LOG_DIR/$APPNAME.log"; then
      printf_blue "Success: $url"
      exitCode=0
      __rm_rf "${POSTIT_TEMP_FILE}.base64"
    else
      printf_red "Something went wrong"
      __mv_f "$POSTIT_TEMP_FILE"
      exitCode=1
    fi
  else
    printf "failed: " && cat "$POSTIT_LOG_DIR/$APPNAME.log" | jq -cr '.message' | tr '\n' ' ' | sed 's|  | |g' | printf_readline '6'
    echo
    exitCode=1
  fi
else
  printf_red "An error has occurred"
  exitCode=1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
