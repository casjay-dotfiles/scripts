#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$PSLIST_TEMP_FILE" ] && rm -Rf "$PSLIST_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : pslist --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : pslist
# @Description   : list processes
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$PSLIST_CONFIG_DIR/$PSLIST_CONFIG_FILE"
  [ -d "$PSLIST_CONFIG_DIR" ] || mkdir -p "$PSLIST_CONFIG_DIR"
  [ -d "$PSLIST_CONFIG_BACKUP_DIR" ] || mkdir -p "$PSLIST_CONFIG_BACKUP_DIR"
  [ -f "$PSLIST_CONFIG_DIR/$PSLIST_CONFIG_FILE" ] &&
    cp -Rf "$PSLIST_CONFIG_DIR/$PSLIST_CONFIG_FILE" "$PSLIST_CONFIG_BACKUP_DIR/$PSLIST_CONFIG_FILE.$$"
  cat <<EOF >"$PSLIST_CONFIG_DIR/$PSLIST_CONFIG_FILE"
# Settings for pslist

# Notification settings
PSLIST_GOOD_MESSAGE="${PSLIST_GOOD_MESSAGE:-Everything Went OK}"
PSLIST_ERROR_MESSAGE="${PSLIST_ERROR_MESSAGE:-Well that didn\'t work}"
PSLIST_NOTIFY_ENABLED="${PSLIST_NOTIFY_ENABLED:-yes}"
PSLIST_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PSLIST_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PSLIST_NOTIFY_CLIENT_ICON}"

# Colorization settings
PSLIST_OUTPUT_COLOR="${PSLIST_OUTPUT_COLOR:-5}"
PSLIST_OUTPUT_COLOR_GOOD="${PSLIST_OUTPUT_COLOR_GOOD:-2}"
PSLIST_OUTPUT_COLOR_ERROR="${PSLIST_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$PSLIST_CONFIG_DIR/$PSLIST_CONFIG_FILE" ]; then
    printf_green "Your config file for pslist has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
PSLIST_CACHE_DIR="${PSLIST_CACHE_DIR:-$HOME/.cache/pslist}"
PSLIST_CONFIG_DIR="${PSLIST_CONFIG_DIR:-$HOME/.config/myscripts/pslist}"
PSLIST_OPTIONS_DIR="${PSLIST_OPTIONS_DIR:-$HOME/.local/share/myscripts/pslist/options}"
PSLIST_CONFIG_BACKUP_DIR="${PSLIST_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/pslist/backups}"
PSLIST_TEMP_DIR="${PSLIST_TEMP_DIR:-$HOME/.local/tmp/system_scripts/pslist}"
PSLIST_TEMP_FILE="${PSLIST_TEMP_FILE:-$(mktemp $PSLIST_TEMP_DIR/XXXXXX 2>/dev/null)}"
PSLIST_CONFIG_FILE="${PSLIST_CONFIG_FILE:-settings.conf}"
PSLIST_GOOD_MESSAGE="${PSLIST_GOOD_MESSAGE:-Everything Went OK}"
PSLIST_ERROR_MESSAGE="${PSLIST_ERROR_MESSAGE:-Well that didn\'t work}"
PSLIST_NOTIFY_ENABLED="${PSLIST_NOTIFY_ENABLED:-yes}"
PSLIST_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PSLIST_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PSLIST_NOTIFY_CLIENT_ICON}"
PSLIST_OUTPUT_COLOR="${PSLIST_OUTPUT_COLOR:-5}"
PSLIST_OUTPUT_COLOR_GOOD="${PSLIST_OUTPUT_COLOR_GOOD:-2}"
PSLIST_OUTPUT_COLOR_ERROR="${PSLIST_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$PSLIST_TEMP_DIR" ] || mkdir -p "$PSLIST_TEMP_DIR" &>/dev/null
[ -d "$PSLIST_CACHE_DIR" ] || mkdir -p "$PSLIST_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$PSLIST_CONFIG_DIR/$PSLIST_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$PSLIST_CONFIG_DIR/$PSLIST_CONFIG_FILE" ] &&
  . "$PSLIST_CONFIG_DIR/$PSLIST_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    PSLIST_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$PSLIST_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${PSLIST_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${PSLIST_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${PSLIST_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${PSLIST_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[ -n "$1" ] || __help
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
for p in "$@"; do
  if cmd_exists pidof; then
    pid="$(pidof $p)"
    if [ -n "$pid" ]; then
      printf_green "The pid of $p is: $pid"
    else
      printf_red "There is no pid for $p"
    fi
  else
    pid="$(__ps | grep $p | awk '{print $11,$2}' | grep -Fv "$APPNAME" | grep -v "$$" | grep '^' || exit)"
    if [ -n "$pid" ]; then
      printf_green "Found the following pids for $p:"
      echo "$pid" | printf_readline
    else
      printf_red "There is no pid for $p"
    fi
  fi
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
