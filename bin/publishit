#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202111162147-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : LICENSE.md
# @ReadME        : publishit --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Dec 09, 2021 20:50 EST
# @File          : publishit
# @Description   : Publish things
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202111162147-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$PUBLISHIT_CONFIG_DIR/$PUBLISHIT_CONFIG_FILE"
  [ -d "$PUBLISHIT_CONFIG_DIR" ] || mkdir -p "$PUBLISHIT_CONFIG_DIR"
  [ -d "$PUBLISHIT_CONFIG_BACKUP_DIR" ] || mkdir -p "$PUBLISHIT_CONFIG_BACKUP_DIR"
  [ -f "$PUBLISHIT_CONFIG_DIR/$PUBLISHIT_CONFIG_FILE" ] &&
    cp -Rf "$PUBLISHIT_CONFIG_DIR/$PUBLISHIT_CONFIG_FILE" "$PUBLISHIT_CONFIG_BACKUP_DIR/$PUBLISHIT_CONFIG_FILE.$$"
  cat <<EOF >"$PUBLISHIT_CONFIG_DIR/$PUBLISHIT_CONFIG_FILE"
# Settings for publishit

# Notification settings
PUBLISHIT_GOOD_MESSAGE="${PUBLISHIT_GOOD_MESSAGE:-Everything Went OK}"
PUBLISHIT_ERROR_MESSAGE="${PUBLISHIT_ERROR_MESSAGE:-Well something seems to have gone wrong}"
PUBLISHIT_NOTIFY_ENABLED="${PUBLISHIT_NOTIFY_ENABLED:-yes}"
PUBLISHIT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PUBLISHIT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PUBLISHIT_NOTIFY_CLIENT_ICON}"

# Colorization settings
PUBLISHIT_OUTPUT_COLOR="${PUBLISHIT_OUTPUT_COLOR:-5}"
PUBLISHIT_OUTPUT_COLOR_GOOD="${PUBLISHIT_OUTPUT_COLOR_GOOD:-2}"
PUBLISHIT_OUTPUT_COLOR_ERROR="${PUBLISHIT_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$PUBLISHIT_CONFIG_DIR/$PUBLISHIT_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
PUBLISHIT_LOG_DIR="${PUBLISHIT_LOG_DIR:-$HOME/.local/log/publishit}"
PUBLISHIT_CACHE_DIR="${PUBLISHIT_CACHE_DIR:-$HOME/.cache/publishit}"
PUBLISHIT_CONFIG_DIR="${PUBLISHIT_CONFIG_DIR:-$HOME/.config/myscripts/publishit}"
PUBLISHIT_OPTIONS_DIR="${PUBLISHIT_OPTIONS_DIR:-$HOME/.local/share/myscripts/publishit/options}"
PUBLISHIT_CONFIG_BACKUP_DIR="${PUBLISHIT_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/publishit/backups}"
PUBLISHIT_TEMP_DIR="${PUBLISHIT_TEMP_DIR:-$HOME/.local/tmp/system_scripts/publishit}"
PUBLISHIT_CONFIG_FILE="${PUBLISHIT_CONFIG_FILE:-settings.conf}"
PUBLISHIT_GOOD_MESSAGE="${PUBLISHIT_GOOD_MESSAGE:-Everything Went OK}"
PUBLISHIT_ERROR_MESSAGE="${PUBLISHIT_ERROR_MESSAGE:-Well something seems to have gone wrong}"
PUBLISHIT_NOTIFY_ENABLED="${PUBLISHIT_NOTIFY_ENABLED:-yes}"
PUBLISHIT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PUBLISHIT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PUBLISHIT_NOTIFY_CLIENT_ICON}"
PUBLISHIT_OUTPUT_COLOR="${PUBLISHIT_OUTPUT_COLOR:-5}"
PUBLISHIT_OUTPUT_COLOR_GOOD="${PUBLISHIT_OUTPUT_COLOR_GOOD:-2}"
PUBLISHIT_OUTPUT_COLOR_ERROR="${PUBLISHIT_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Enviroment overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$PUBLISHIT_CONFIG_DIR/$PUBLISHIT_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$PUBLISHIT_CONFIG_DIR/$PUBLISHIT_CONFIG_FILE" ] && . "$PUBLISHIT_CONFIG_DIR/$PUBLISHIT_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$PUBLISHIT_LOG_DIR" ] || mkdir -p "$PUBLISHIT_LOG_DIR" &>/dev/null
[ -d "$PUBLISHIT_TEMP_DIR" ] || mkdir -p "$PUBLISHIT_TEMP_DIR" &>/dev/null
[ -d "$PUBLISHIT_CACHE_DIR" ] || mkdir -p "$PUBLISHIT_CACHE_DIR" &>/dev/null
PUBLISHIT_TEMP_FILE="${PUBLISHIT_TEMP_FILE:-$(mktemp $PUBLISHIT_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$PUBLISHIT_TEMP_FILE" ] && [ -f "$PUBLISHIT_TEMP_FILE" ] && rm -Rf "$PUBLISHIT_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$PUBLISHIT_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${PUBLISHIT_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${PUBLISHIT_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${PUBLISHIT_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${PUBLISHIT_NOTIFY_CLIENT_ICON}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    __help
    shift 1
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    PUBLISHIT_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[ -f "./Dockerfile" ] && action="docker"
[ -f "./package.json" ] && action="npm"
[ -f "./Makefile" ] && action="make"
[ -f "./setup.py" ] && action="python"
[ -f "./gem.spec" ] && action="gem"
[ -f "./composer.json" ] && action="composer"
[ -f "./pom.xml" ] && action="maven"
[ -f "./build.gradle" ] && action="gradle"
[ -n "$action" ] || action="$1"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "${actions:-$1}" in
docker)
  shift 1
  docker push "$@"
  exit $?
  ;;

npm)
  shift 1
  npm publish "$@"
  exit $?
  ;;

gem)
  shift 1
  gem push "$@"
  exit $?
  ;;

*)
  printf_return "$action has not been implemented yet"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
