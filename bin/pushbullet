#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : pushbullet --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : pushbullet
# @Description   : send pushbullet notification
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$PUSHBULLET_TEMP_FILE" ] && [ -f "$PUSHBULLET_TEMP_FILE" ] && rm -Rf "$PUSHBULLET_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$PUSHBULLET_CONFIG_DIR/$PUSHBULLET_CONFIG_FILE"
  [ -d "$PUSHBULLET_CONFIG_DIR" ] || mkdir -p "$PUSHBULLET_CONFIG_DIR"
  [ -d "$PUSHBULLET_CONFIG_BACKUP_DIR" ] || mkdir -p "$PUSHBULLET_CONFIG_BACKUP_DIR"
  [ -f "$PUSHBULLET_CONFIG_DIR/$PUSHBULLET_CONFIG_FILE" ] &&
    cp -Rf "$PUSHBULLET_CONFIG_DIR/$PUSHBULLET_CONFIG_FILE" "$PUSHBULLET_CONFIG_BACKUP_DIR/$PUSHBULLET_CONFIG_FILE.$$"
  cat <<EOF >"$PUSHBULLET_CONFIG_DIR/$PUSHBULLET_CONFIG_FILE"
# Settings for pushbullet
PUSHBULLET_ACCESS_TOKEN="${PUSHBULLET_ACCESS_TOKEN:-}"
PUSHBULLET_API_HOST="${PUSHBULLET_API_HOST:-https://api.pushbullet.com/v2/pushes}"

# Notification settings
PUSHBULLET_GOOD_MESSAGE="${PUSHBULLET_GOOD_MESSAGE:-Everything Went OK}"
PUSHBULLET_ERROR_MESSAGE="${PUSHBULLET_ERROR_MESSAGE:-Well something seems to have gone wrong}"
PUSHBULLET_NOTIFY_ENABLED="${PUSHBULLET_NOTIFY_ENABLED:-yes}"
PUSHBULLET_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PUSHBULLET_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PUSHBULLET_NOTIFY_CLIENT_ICON}"

# Colorization settings
PUSHBULLET_OUTPUT_COLOR="${PUSHBULLET_OUTPUT_COLOR:-5}"
PUSHBULLET_OUTPUT_COLOR_GOOD="${PUSHBULLET_OUTPUT_COLOR_GOOD:-2}"
PUSHBULLET_OUTPUT_COLOR_ERROR="${PUSHBULLET_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$PUSHBULLET_CONFIG_DIR/$PUSHBULLET_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    # if [[ "$INIT_CONFIG" = "TRUE" ]]; then
    #   unset INIT_CONFIG
    #   eval bash -c "$APPNAME $*"
    #   exit
    # fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
PUSHBULLET_LOG_DIR="${PUSHBULLET_LOG_DIR:-$HOME/.local/log/pushbullet}"
PUSHBULLET_CACHE_DIR="${PUSHBULLET_CACHE_DIR:-$HOME/.cache/pushbullet}"
PUSHBULLET_CONFIG_DIR="${PUSHBULLET_CONFIG_DIR:-$HOME/.config/myscripts/pushbullet}"
PUSHBULLET_CONFIG_BACKUP_DIR="${PUSHBULLET_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/pushbullet/backups}"
PUSHBULLET_TEMP_DIR="${PUSHBULLET_TEMP_DIR:-$HOME/.local/tmp/system_scripts/pushbullet}"
PUSHBULLET_OPTIONS_DIR="${PUSHBULLET_OPTIONS_DIR:-$HOME/.local/share/myscripts/pushbullet/options}"
PUSHBULLET_TEMP_FILE="${PUSHBULLET_TEMP_FILE:-$(mktemp $PUSHBULLET_TEMP_DIR/XXXXXX 2>/dev/null)}"
PUSHBULLET_CONFIG_FILE="${PUSHBULLET_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
PUSHBULLET_OUTPUT_COLOR="${PUSHBULLET_OUTPUT_COLOR:-4}"
PUSHBULLET_OUTPUT_COLOR_2="${PUSHBULLET_OUTPUT_COLOR:-6}"
PUSHBULLET_OUTPUT_COLOR_GOOD="${PUSHBULLET_OUTPUT_COLOR_GOOD:-2}"
PUSHBULLET_OUTPUT_COLOR_ERROR="${PUSHBULLET_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
PUSHBULLET_GOOD_MESSAGE="${PUSHBULLET_GOOD_MESSAGE:-Everything Went OK}"
PUSHBULLET_ERROR_MESSAGE="${PUSHBULLET_ERROR_MESSAGE:-Well something seems to have gone wrong}"
PUSHBULLET_NOTIFY_ENABLED="${PUSHBULLET_NOTIFY_ENABLED:-yes}"
PUSHBULLET_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PUSHBULLET_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PUSHBULLET_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
PUSHBULLET_ACCESS_TOKEN="${PUSHBULLET_ACCESS_TOKEN:-}"
PUSHBULLET_API_HOST="${PUSHBULLET_API_HOST:-https://api.pushbullet.com/v2/pushes}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$PUSHBULLET_CONFIG_DIR/$PUSHBULLET_CONFIG_FILE" ] && . "$PUSHBULLET_CONFIG_DIR/$PUSHBULLET_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$PUSHBULLET_LOG_DIR" ] || mkdir -p "$PUSHBULLET_LOG_DIR" &>/dev/null
[ -d "$PUSHBULLET_TEMP_DIR" ] || mkdir -p "$PUSHBULLET_TEMP_DIR" &>/dev/null
[ -d "$PUSHBULLET_CACHE_DIR" ] || mkdir -p "$PUSHBULLET_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$PUSHBULLET_CONFIG_DIR/$PUSHBULLET_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    PUSHBULLET_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$PUSHBULLET_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${PUSHBULLET_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${PUSHBULLET_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${PUSHBULLET_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${PUSHBULLET_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[ -z "$PUSHBULLET_ACCESS_TOKEN" ] && printf_help "Please set PUSHBULLET_ACCESS_TOKEN"
[ -z "$1" ] && [ -z "$2" ] && printf_help 'Usage: pushbullet "title" "body"'
title="$1"
body="$2"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ -n "$PUSHBULLET_ACCESS_TOKEN" ]; then
  curl -q -LSsq -u ${PUSHBULLET_ACCESS_TOKEN}: \
    --header 'Content-Type: application/json' \
    -X POST "$PUSHBULLET_API_HOST" \
    -d "{\"type\": \"note\", \"title\": \"$title\", \"body\": \"$body.\"}" 2>/dev/null | grep -q active &&
    printf_green "Message was sent" || printf_red "Failed to send"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
