user_install && __options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Send all output to /dev/null
__devnull() {
  tee &>/dev/null && exitCode=0 || exitCode=1
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -'
# Send errors to /dev/null
__devnull2() {
  [ -n "$1" ] && local cmd="$1" && shift 1 || return 1
  eval $cmd "$*" 2>/dev/null && exitCode=0 || exitCode=1
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -'
# See if the executable exists
__cmd_exists() {
  exitCode=0
  [ -n "$1" ] && local exitCode="" || return 0
  for cmd in "$@"; do
    builtin command -v "$cmd" &>/dev/null && exitCode+=$(($exitCode + 0)) || exitCode+=$(($exitCode + 1))
  done
  [ $exitCode -eq 0 ] || exitCode=3
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for a valid internet connection
__am_i_online() {
  local exitCode=0
  curl -q -LSsfI --max-time 1 --retry 0 "${1:-http://1.1.1.1}" 2>&1 | grep -qi 'server:.*cloudflare' || exitCode=4
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# colorization
if [ "$SHOW_RAW" = "true" ]; then
  printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[ 0-9;]*[a-zA-Z],,g'; }
else
  printf_color() { printf "%b" "$(tput setaf "${2:-7}" 2>/dev/null)" "$1" "$(tput sgr0 2>/dev/null)"; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional printf_ colors
__printf_head() { printf_blue "$1"; }
__printf_opts() { printf_purple "$1"; }
__printf_line() { printf_cyan "$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# output version
__version() { printf_cyan "$VERSION"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  printf_color "$1: " "$5"
  echo -ne "$2" | sed 's|:||g;s/'$3'/ '$4'/g'
  printf_newline
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# create the config file
__gen_config() {
  local NOTIFY_CLIENT_NAME="$APPNAME"
  if [ "$INIT_CONFIG" != "TRUE" ]; then
    printf_blue "Generating the config file in"
    printf_cyan "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE"
  fi
  [ -d "$PVE_SPICE_CONFIG_DIR" ] || mkdir -p "$PVE_SPICE_CONFIG_DIR"
  [ -d "$PVE_SPICE_CONFIG_BACKUP_DIR" ] || mkdir -p "$PVE_SPICE_CONFIG_BACKUP_DIR"
  [ -f "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE" ] &&
    cp -Rf "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE" "$PVE_SPICE_CONFIG_BACKUP_DIR/$PVE_SPICE_CONFIG_FILE.$$"
  cat <<EOF >"$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE"
# Settings for pve-spice
PVE_SPICE_DEFAULT_USERNAME="${PVE_SPICE_DEFAULT_USERNAME:-}"
PVE_SPICE_DEFAULT_PASSWORD="${PVE_SPICE_DEFAULT_PASSWORD:-}"
PVE_SPICE_DEFAULT_NODE_ID="${PVE_SPICE_DEFAULT_NODE_ID:-}"
PVE_SPICE_DEFAULT_SERVER="${PVE_SPICE_DEFAULT_SERVER:-}"
PVE_SPICE_DEFAULT_PORT="${PVE_SPICE_DEFAULT_PORT:-}"
PVE_SPICE_SAVE_DIR="${PVE_SPICE_SAVE_DIR:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
PVE_SPICE_OUTPUT_COLOR_1="${PVE_SPICE_OUTPUT_COLOR_1:-}"
PVE_SPICE_OUTPUT_COLOR_2="${PVE_SPICE_OUTPUT_COLOR_2:-}"
PVE_SPICE_OUTPUT_COLOR_GOOD="${PVE_SPICE_OUTPUT_COLOR_GOOD:-}"
PVE_SPICE_OUTPUT_COLOR_ERROR="${PVE_SPICE_OUTPUT_COLOR_ERROR:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
PVE_SPICE_NOTIFY_ENABLED="${PVE_SPICE_NOTIFY_ENABLED:-}"
PVE_SPICE_GOOD_NAME="${PVE_SPICE_GOOD_NAME:-}"
PVE_SPICE_ERROR_NAME="${PVE_SPICE_ERROR_NAME:-}"
PVE_SPICE_GOOD_MESSAGE="${PVE_SPICE_GOOD_MESSAGE:-}"
PVE_SPICE_ERROR_MESSAGE="${PVE_SPICE_ERROR_MESSAGE:-}"
PVE_SPICE_NOTIFY_CLIENT_NAME="${PVE_SPICE_NOTIFY_CLIENT_NAME:-}"
PVE_SPICE_NOTIFY_CLIENT_ICON="${PVE_SPICE_NOTIFY_CLIENT_ICON:-}"
PVE_SPICE_NOTIFY_CLIENT_URGENCY="${PVE_SPICE_NOTIFY_CLIENT_URGENCY:-}"

EOF
  if builtin type -t __gen_config_local | grep -q 'function'; then __gen_config_local; fi
  if [ -f "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE" ]; then
    [ "$INIT_CONFIG" = "TRUE" ] || printf_green "Your config file for $APPNAME has been created"
    . "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Help function - Align to 50
__help() {
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "pve-spice:  - $VERSION"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Usage: pve-spice [options] [commands]"
  __printf_line " - "
  __printf_line " - "
  __printf_line "--dir                           - Sets the working directory"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "--help                          - Shows this message"
  __printf_line "--config                        - Generate user config file"
  __printf_line "--version                       - Show script version"
  __printf_line "--options                       - Shows all available options"
  __printf_line "--debug                         - Enables script debugging"
  __printf_line "--raw                           - Removes all formatting on output"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  { [ $(id -u) -ne 0 ] || [ $EUID -ne 0 ] || [ "$WHOAMI" != "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -s "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$PVE_SPICE_REQUIRE_SUDO" = "yes" ] && [ -z "$PVE_SPICE_REQUIRE_SUDO_RUN" ]; then
    export PVE_SPICE_REQUIRE_SUDO="no"
    export PVE_SPICE_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "$(basename "$SUDO" 2>/dev/null)" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-$?}
  [ -f "$PVE_SPICE_TEMP_FILE" ] && rm -Rf "$PVE_SPICE_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
printf_answer_no() {
  [ -n "$1" ] || return 1
  printf_answer_yes "$1" && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__query_server() {
  curl -q -LfsSk \
    --data-urlencode "username=$USERNAME" \
    --data-urlencode "password=$PASSWORD" \
    "https://$PVE_SPICE_DEFAULT_SERVER:$PVE_SPICE_DEFAULT_PORT/api2/json/access/ticket" 2>/dev/null
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_spice_file() {
  curl -q -f -s -S -k -b "PVEAuthCookie=$TICKET" -H "CSRFPreventionToken: $CSRF" \
    "https://$PVE_SPICE_DEFAULT_SERVER:$PVE_SPICE_DEFAULT_PORT/api2/spiceconfig/nodes/$PVE_SPICE_DEFAULT_NODE_ID/qemu/$PVE_SPICE_DEFAULT_MACHINE/spiceproxy" \
    -d "proxy=$PVE_SPICE_DEFAULT_SERVER" >"$FILENAME" 2>/dev/null && return 0
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_spice_viewer() {
  local FILE="${1:-$FILENAME}"
  local RUN="${1:-$FILENAME}.spice"
  sed 's|delete-this-file=1|delete-this-file=0|g' "$FILE"
  cp -Rf "$FILE" "$RUN"
  remote-viewer "$RUN" &>/dev/null &
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_curl() {
  local DATA="${1:-$DATA}"
  local FILENAME="${2:-$FILENAME}"
  local TICKET="${DATA//\"/}"
  local TICKET="${TICKET##*ticket:}"
  local TICKET="${TICKET%%,*}"
  local TICKET="${TICKET%%\}*}"
  local CSRF="${DATA//\"/}"
  local CSRF="${CSRF##*CSRFPreventionToken:}"
  local CSRF="${CSRF%%,*}"
  local CSRF="${CSRF%%\}*}"
  if [ -n "$CSRF" ]; then
    __get_spice_file && printf_purple "Saving to $FILENAME" && return 0 || printf_exit "Failed to get the spice file"
  else
    printf_red "Failed to retrieve auth token"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_vm_id() {
  printf_read_input "What is your vm id number? " "120" "set_vmid"
  PVE_SPICE_DEFAULT_MACHINE="${set_vmid:-}"
  [ -n "$PVE_SPICE_DEFAULT_MACHINE" ] || printf_exit "VM ID is required"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_username() {
  local change_user="" option_user=""
  printf_read_question "5" "Is the username correct? [y/N]: [$PVE_SPICE_DEFAULT_USERNAME]" "1" "change_user"
  if printf_answer_no "$change_user"; then
    printf_read_input "What is your username? " "120" "option_user" "-s"
    PVE_SPICE_DEFAULT_USERNAME="$option_user"
  fi
  [ -n "$PVE_SPICE_DEFAULT_USERNAME" ] || printf_exit "Username is required"
  grep -sq "PVE_SPICE_DEFAULT_USERNAME=" "$PVE_SPICE_NODE_CONFIG_FILE" ||
    printf '%s\n' 'PVE_SPICE_DEFAULT_USERNAME="'$PVE_SPICE_DEFAULT_USERNAME'"' >>"$PVE_SPICE_NODE_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_password() {
  local change_pass="" option_pass_new="" option_pass_confirm=""
  printf_read_question "5" "Would you like to change the password? [y/N]: [$PVE_SPICE_DEFAULT_PASSWORD]" "1" "change_pass"
  if printf_answer_no "$change_pass"; then
    printf_read_passwd "What is your password? " "120" "option_pass_new" "-s"
    printf_read_passwd "confirm your password? " "120" "option_pass_confirm" "-s"
    if [ "$option_pass_new" != "$option_pass_confirm" ]; then
      while :; do
        printf_red "Error: the passwords do not match"
        __get_password && break
      done
    fi
    PVE_SPICE_DEFAULT_PASSWORD="${option_pass_new:-}"
  fi
  [ -n "$PVE_SPICE_DEFAULT_PASSWORD" ] || printf_exit "Password is required"
  grep -sq "PVE_SPICE_DEFAULT_PASSWORD=" "$PVE_SPICE_NODE_CONFIG_FILE" ||
    printf '%s\n' 'PVE_SPICE_DEFAULT_PASSWORD="'$PVE_SPICE_DEFAULT_PASSWORD'"' >>"$PVE_SPICE_NODE_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_node_name() {
  local change_node=""
  printf_read_question "5" "Is the node name correct? [y/N]: [$PVE_SPICE_DEFAULT_NODE_ID]" "1" "change_node"
  if printf_answer_no "$change_node"; then
    printf_read_input "What is node name? " "120" "PVE_SPICE_DEFAULT_NODE_ID"
  fi
  [ -n "$PVE_SPICE_DEFAULT_NODE_ID" ] || printf_exit "The node name is required"
  grep -sq "PVE_SPICE_DEFAULT_NODE_ID=" "$PVE_SPICE_NODE_CONFIG_FILE" ||
    printf '%s\n' 'PVE_SPICE_DEFAULT_NODE_ID="'$PVE_SPICE_DEFAULT_NODE_ID'"' >>"$PVE_SPICE_NODE_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_servername() {
  local change_server=""
  printf_read_question "5" "is the server address correct? [y/N]: [$PVE_SPICE_DEFAULT_SERVER]" "1" "change_server"
  if printf_answer_no "$change_server"; then
    printf_read_input "What is the server address? " "120" "PVE_SPICE_DEFAULT_SERVER"
  fi
  [ -n "$PVE_SPICE_DEFAULT_SERVER" ] || printf_exit "The host is required"
  grep -sq "PVE_SPICE_DEFAULT_SERVER=" "$PVE_SPICE_NODE_CONFIG_FILE" ||
    printf '%s\n' 'PVE_SPICE_DEFAULT_SERVER="'$PVE_SPICE_DEFAULT_SERVER'"' >>"$PVE_SPICE_NODE_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_serverport() {
  local change_port=""
  printf_read_question "5" "is the port correct? [y/N]: [$PVE_SPICE_DEFAULT_PORT]" "1" "change_port"
  if printf_answer_no "$change_port"; then
    printf_read_input "What is the port? " "120" "PVE_SPICE_DEFAULT_PORT"
  fi
  [ -n "$PVE_SPICE_DEFAULT_PORT" ] || printf_exit "The port is required"
  grep -sq "PVE_SPICE_DEFAULT_PORT=" "$PVE_SPICE_NODE_CONFIG_FILE" ||
    printf '%s\n' 'PVE_SPICE_DEFAULT_PORT="'$PVE_SPICE_DEFAULT_PORT'"' >>"$PVE_SPICE_NODE_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__initialize_app() {
  PVE_SPICE_DEFAULT_MACHINE="${1:-$PVE_SPICE_DEFAULT_MACHINE}"
  PVE_SPICE_DEFAULT_NODE_ID="${2:-$PVE_SPICE_DEFAULT_NODE_ID}"
  PVE_SPICE_DEFAULT_SERVER="${3:-$PVE_SPICE_DEFAULT_SERVER}"
  PVE_SPICE_DEFAULT_PORT="${4:-$PVE_SPICE_DEFAULT_PORT}"
  [ "$1" = "reset" ] && PVE_SPICE_FORCE="true" && shift 1 && PVE_SPICE_FORCED="complete"
  if [ -n "$PVE_SPICE_CONFIG_DIR" ] && [ -n "$PVE_SPICE_DEFAULT_NODE_ID" ]; then
    [ "$PVE_SPICE_FORCE" = "true" ] && rm -Rf "$PVE_SPICE_NODE_CONFIG_FILE"
    PVE_SPICE_NEW_INSTALL="true"
  fi
  if [ ! -f "$PVE_SPICE_NODE_CONFIG_FILE" ]; then
    __get_username
    __get_password
    __get_node_name
    __get_servername
    __get_serverport
  fi
  # Get/confirm username
  [ -z "$PVE_SPICE_DEFAULT_USERNAME" ] && __get_username
  # Get/confirm password
  [ -z "$PVE_SPICE_DEFAULT_PASSWORD" ] && __get_password
  # Get/confirm servername
  [ -z "$PVE_SPICE_DEFAULT_NODE_ID" ] && __get_node_name
  # Get/confirm node name
  [ -z "$PVE_SPICE_DEFAULT_SERVER" ] && __get_servername
  # Get/confirm port
  [ -z "$PVE_SPICE_DEFAULT_PORT" ] && __get_serverport
  # Write settings to file
  if [ -f "$PVE_SPICE_NODE_CONFIG_FILE" ] && [ "$PVE_SPICE_NEW_INSTALL" = "true" ]; then
    [ -d "$PVE_SPICE_SAVE_DIR" ] || mkdir -p "$PVE_SPICE_SAVE_DIR" &>/dev/null
    printf_blue "Updating the configuration and setting permissions"
    chmod 600 "$PVE_SPICE_NODE_CONFIG_FILE" "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE"
    touch "$PVE_SPICE_NODE_CONFIG_FILE"
    . "$PVE_SPICE_NODE_CONFIG_FILE"
    __gen_config &>/dev/null
    PVE_SPICE_NEW_INSTALL=""
    PVE_SPICE_FORCE=""
    return 0
  else
    printf_exit "Something went wrong"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__execute_pve-spice() {
  USERNAME="$PVE_SPICE_DEFAULT_USERNAME"
  PASSWORD="$PVE_SPICE_DEFAULT_PASSWORD"
  SPICEDIR="$PVE_SPICE_SAVE_DIR"
  FILENAME="$PVE_SPICE_SAVE_DIR/${PVE_SPICE_DEFAULT_NODE_ID}_${PVE_SPICE_DEFAULT_MACHINE}"
  [ -n "$PVE_SPICE_DEFAULT_MACHINE" ] || __get_vm_id

  DATA="$(__query_server || echo '')"
  if [ -n "$DATA" ]; then
    printf_blue "Authentication with server was a success"
    if __run_curl "$DATA"; then
      if __cmd_exists remote-viewer; then
        __run_spice_viewer "${FILENAME}" &>/dev/null
        return $?
      else
        printf_yellow "remote-viewer is required: 'virt-viewer' or 'remote-viewer'"
      fi
      return
    else
      printf_red "Failed to get spice file from server"
      exitCode=1
    fi
  else
    printf_error "Something went wrong"
    exitCode=1
  fi
}
