# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202112022054-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE"
  [ -d "$PVE_SPICE_CONFIG_DIR" ] || mkdir -p "$PVE_SPICE_CONFIG_DIR"
  [ -d "$PVE_SPICE_CONFIG_BACKUP_DIR" ] || mkdir -p "$PVE_SPICE_CONFIG_BACKUP_DIR"
  [ -f "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE" ] &&
    cp -Rf "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE" "$PVE_SPICE_CONFIG_BACKUP_DIR/$PVE_SPICE_CONFIG_FILE.$$"
  cat <<EOF >"$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE"
# Settings for pve-spice
PVE_SPICE_DEFAULT_USERNAME="${PVE_SPICE_DEFAULT_USERNAME:-root@pam}"
PVE_SPICE_DEFAULT_PASSWORD="${PVE_SPICE_DEFAULT_PASSWORD:-Password}"
PVE_SPICE_DEFAULT_NODE="${PVE_SPICE_DEFAULT_NODE:-pve}"
PVE_SPICE_DEFAULT_HOST="${PVE_SPICE_DEFAULT_HOST:-pve.local}"
PVE_SPICE_DEFAULT_PORT="${PVE_SPICE_DEFAULT_PORT:-8006}"
PVE_SPICE_SAVE_DIR="${PVE_SPICE_SAVE_DIR:-$HOME/Documents/Spice}"

# Notification settings
PVE_SPICE_GOOD_MESSAGE="${PVE_SPICE_GOOD_MESSAGE:-Everything Went OK}"
PVE_SPICE_ERROR_MESSAGE="${PVE_SPICE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
PVE_SPICE_NOTIFY_ENABLED="${PVE_SPICE_NOTIFY_ENABLED:-yes}"
PVE_SPICE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PVE_SPICE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PVE_SPICE_NOTIFY_CLIENT_ICON}"

# Colorization settings
PVE_SPICE_OUTPUT_COLOR="${PVE_SPICE_OUTPUT_COLOR:-5}"
PVE_SPICE_OUTPUT_COLOR_GOOD="${PVE_SPICE_OUTPUT_COLOR_GOOD:-2}"
PVE_SPICE_OUTPUT_COLOR_ERROR="${PVE_SPICE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__run_spice_viewer() {
  local FILE="${1:-$FILENAME}"
  local RUN="${1:-$FILENAME}.spice"
  sed 's|delete-this-file=1|delete-this-file=0|g' "$FILE"
  cp -Rf "$FILE" "${RUN}"
  remote-viewer "$RUN" &>/dev/null &
  return $?
}
__run_curl() {
  local DATA="${1:-$DATA}"
  local FILENAME="${2:-$FILENAME}"
  local TICKET="${DATA//\"/}"
  local TICKET="${TICKET##*ticket:}"
  local TICKET="${TICKET%%,*}"
  local TICKET="${TICKET%%\}*}"

  local CSRF="${DATA//\"/}"
  local CSRF="${CSRF##*CSRFPreventionToken:}"
  local CSRF="${CSRF%%,*}"
  local CSRF="${CSRF%%\}*}"
  if [ -n "$CSRF" ]; then
    curl -q -L -f -s -S -k -b \
      "PVEAuthCookie=$TICKET" -H "CSRFPreventionToken: $CSRF" \
      "https://$PROXY:$PORT/api2/spiceconfig/nodes/$NODE/qemu/$VMID/spiceproxy" \
      -d "proxy=$PROXY" >"$FILENAME" 2>/dev/null &&
      printf_purple "Saving to $FILENAME" &&
      return 0 || return 1
  else
    printf_red "Failed to retrieve auth token"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
PVE_SPICE_LOG_DIR="${PVE_SPICE_LOG_DIR:-$HOME/.local/log/pve-spice}"
PVE_SPICE_CACHE_DIR="${PVE_SPICE_CACHE_DIR:-$HOME/.cache/pve-spice}"
PVE_SPICE_CONFIG_DIR="${PVE_SPICE_CONFIG_DIR:-$HOME/.config/myscripts/pve-spice}"
PVE_SPICE_OPTIONS_DIR="${PVE_SPICE_OPTIONS_DIR:-$HOME/.local/share/myscripts/pve-spice/options}"
PVE_SPICE_CONFIG_BACKUP_DIR="${PVE_SPICE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/pve-spice/backups}"
PVE_SPICE_TEMP_DIR="${PVE_SPICE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/pve-spice}"
PVE_SPICE_CONFIG_FILE="${PVE_SPICE_CONFIG_FILE:-settings.conf}"
PVE_SPICE_GOOD_MESSAGE="${PVE_SPICE_GOOD_MESSAGE:-Everything Went OK}"
PVE_SPICE_ERROR_MESSAGE="${PVE_SPICE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
PVE_SPICE_NOTIFY_ENABLED="${PVE_SPICE_NOTIFY_ENABLED:-yes}"
PVE_SPICE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
PVE_SPICE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$PVE_SPICE_NOTIFY_CLIENT_ICON}"
PVE_SPICE_OUTPUT_COLOR="${PVE_SPICE_OUTPUT_COLOR:-5}"
PVE_SPICE_OUTPUT_COLOR_GOOD="${PVE_SPICE_OUTPUT_COLOR_GOOD:-2}"
PVE_SPICE_OUTPUT_COLOR_ERROR="${PVE_SPICE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
PVE_SPICE_DEFAULT_USERNAME="${PVE_SPICE_DEFAULT_USERNAME:-root@pam}"
PVE_SPICE_DEFAULT_PASSWORD="${PVE_SPICE_DEFAULT_PASSWORD:-Password}"
PVE_SPICE_DEFAULT_NODE="${PVE_SPICE_DEFAULT_NODE:-pve}"
PVE_SPICE_DEFAULT_HOST="${PVE_SPICE_DEFAULT_HOST:-pve.local}"
PVE_SPICE_DEFAULT_PORT="${PVE_SPICE_DEFAULT_PORT:-8006}"
PVE_SPICE_SAVE_DIR="${PVE_SPICE_SAVE_DIR:-$HOME/Documents/Spice}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE" ] && . "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$PVE_SPICE_LOG_DIR" ] || mkdir -p "$PVE_SPICE_LOG_DIR" &>/dev/null
[ -d "$PVE_SPICE_TEMP_DIR" ] || mkdir -p "$PVE_SPICE_TEMP_DIR" &>/dev/null
[ -d "$PVE_SPICE_CACHE_DIR" ] || mkdir -p "$PVE_SPICE_CACHE_DIR" &>/dev/null
[ -d "$PVE_SPICE_SAVE_DIR" ] || mkdir -p "$PVE_SPICE_SAVE_DIR" &>/dev/null
PVE_SPICE_TEMP_FILE="${PVE_SPICE_TEMP_FILE:-$(mktemp $PVE_SPICE_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$PVE_SPICE_TEMP_FILE" ] && [ -f "$PVE_SPICE_TEMP_FILE" ] && rm -Rf "$PVE_SPICE_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$PVE_SPICE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${PVE_SPICE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${PVE_SPICE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${PVE_SPICE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${PVE_SPICE_NOTIFY_CLIENT_ICON}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="u:,p:,m:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    __help
    shift 1
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    PVE_SPICE_CWD="$2"
    shift 2
    ;;
  -u)
    PVE_SPICE_DEFAULT_USERNAME="$2"
    shift 2
    ;;
  -p)
    PVE_SPICE_DEFAULT_PASSWORD="$2"
    shift 2
    ;;
  -m)
    PVE_SPICE_DEFAULT_MACHINE="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash remote-viewer curl || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
VMID="${1:-$PVE_SPICE_DEFAULT_MACHINE}"
NODE="${2:-$PVE_SPICE_DEFAULT_NODE}"
PROXY="${3:-$PVE_SPICE_DEFAULT_HOST}"
PORT="${4:-$PVE_SPICE_DEFAULT_PORT}"
USERNAME="$PVE_SPICE_DEFAULT_USERNAME"
PASSWORD="$PVE_SPICE_DEFAULT_PASSWORD"
SPICEDIR="$PVE_SPICE_SAVE_DIR"
FILENAME="$SPICEDIR/${NODE}_${VMID}"
[[ -d "$SPICEDIR" ]] || mkdir -p "$SPICEDIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
DATA="$(curl -q -L -f -s -S -k --data-urlencode "username=$USERNAME" --data-urlencode "password=$PASSWORD" "https://$PROXY:$PORT/api2/json/access/ticket" 2>/dev/null || echo "")"
if [[ -n "$DATA" ]]; then
  printf_blue "Authentication with server was a success"
  if __run_curl "$DATA"; then
    __run_spice_viewer "${FILENAME}" &>/dev/null || exitCode=1
  else
    printf_red "Failed to get spice file from server"
    exitCode=1
  fi
else
  printf_error "Something went wrong"
  exitCode=1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
