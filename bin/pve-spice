  __printf_line "reset                           - Reset script variables"
  __printf_line "ssh                             - Connect to proxmox server "
  __printf_line "web                             - Open the proxmox web interface"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
