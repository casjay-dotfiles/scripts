}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -s "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$PVE_SPICE_REQUIRE_SUDO" = "yes" ] && [ -z "$PVE_SPICE_REQUIRE_SUDO_RUN" ]; then
    export PVE_SPICE_REQUIRE_SUDO="no"
    export PVE_SPICE_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "$(basename "$SUDO" 2>/dev/null)" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-$?}
  [ -f "$PVE_SPICE_TEMP_FILE" ] && rm -Rf "$PVE_SPICE_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
printf_answer_no() {
  if [ -n "$1" ] && [ "$1" != "" ]; then
    printf_answer_yes "$1" && return 1 || return 0
  else
    printf '\n'
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_auth() {
  curl -q -f -s -S -k -b "PVEAuthCookie=$TICKET" -H "CSRFPreventionToken: $CSRF" "$@"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__curl_post() {
  curl -q -s -S -k --fail -b "PVEAuthCookie=$TICKET" -H "CSRFPreventionToken: $CSRF" -X POST "$@"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__query_server() {
  curl -q -LfsSk \
    --data-urlencode "username=$USERNAME" \
    --data-urlencode "password=$PASSWORD" \
    "https://$PVE_SPICE_DEFAULT_SERVER_HOST:$PVE_SPICE_DEFAULT_SERVER_PORT/api2/json/access/ticket" 2>/dev/null
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_config() {
  local url_lxc="https://$PVE_SPICE_DEFAULT_SERVER_HOST:$PVE_SPICE_DEFAULT_SERVER_PORT/api2/spiceconfig/nodes/$PVE_SPICE_DEFAULT_NODE_ID/lxc"
  local url_qemu="https://$PVE_SPICE_DEFAULT_SERVER_HOST:$PVE_SPICE_DEFAULT_SERVER_PORT/api2/spiceconfig/nodes/$PVE_SPICE_DEFAULT_NODE_ID/qemu"
  __curl_auth "$url_qemu/$PVE_SPICE_DEFAULT_MACHINE/config" 2>/dev/null && return 0 ||
    __curl_auth "$url_lxc/$PVE_SPICE_DEFAULT_MACHINE/config" && return 0
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_status() {
  local url_lxc="https://$PVE_SPICE_DEFAULT_SERVER_HOST:$PVE_SPICE_DEFAULT_SERVER_PORT/api2/spiceconfig/nodes/$PVE_SPICE_DEFAULT_NODE_ID/lxc"
  local url_qemu="https://$PVE_SPICE_DEFAULT_SERVER_HOST:$PVE_SPICE_DEFAULT_SERVER_PORT/api2/spiceconfig/nodes/$PVE_SPICE_DEFAULT_NODE_ID/qemu"
  local url_status="$PVE_SPICE_DEFAULT_MACHINE/status/current"
  if __curl_auth "$url_qemu/$url_status" 2>/dev/null | grep '^'; then
    return 0
  elif __curl_auth "$url_lxc/$url_status" 2>/dev/null | grep '^'; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_spice_file() {
  local vm_exists="$(__get_status | grep '^' || false)"
  local vm_status="$(echo "$vm_exists" | grep -q '^status=running' && echo 'on' || echo "off")"
  local vm_name="$(echo "$vm_exists" | grep '^name=' | awk -F '=' '{print $2}' | grep '^' || echo "$PVE_SPICE_DEFAULT_MACHINE")"
  local url_lxc="https://$PVE_SPICE_DEFAULT_SERVER_HOST:$PVE_SPICE_DEFAULT_SERVER_PORT/api2/spiceconfig/nodes/$PVE_SPICE_DEFAULT_NODE_ID/lxc"
  local url_qemu="https://$PVE_SPICE_DEFAULT_SERVER_HOST:$PVE_SPICE_DEFAULT_SERVER_PORT/api2/spiceconfig/nodes/$PVE_SPICE_DEFAULT_NODE_ID/qemu"
  if [ -z "$vm_exists" ]; then
    printf_exit "$vm_name does not exist"
  elif [ "$vm_status" = "off" ]; then
    printf_read_question "4" "Would you to turn on $vm_name" "1" "power_on"
    if printf_answer_yes "$power_on"; then
      if __start_stop_vm "qemu" "start"; then
        vm_status="on"
      else
        printf_exit "Failed to start $vm_name on $PVE_SPICE_DEFAULT_NODE_ID"
      fi
      sleep 2
    else
      printf_exit "User cancelled"
    fi
  fi
  if [ "$vm_status" = "on" ]; then
    printf_cyan "Initializing the connection to $vm_name ($PVE_SPICE_DEFAULT_MACHINE)"
    __save_spice_file "$url_qemu" || __save_spice_file "$url_lxc"
    return $?
  else
    printf_red ""
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__save_spice_file() {
  __curl_auth "$1/$PVE_SPICE_DEFAULT_MACHINE/spiceproxy" -d "proxy=$PVE_SPICE_DEFAULT_SERVER_HOST" >"$FILENAME" 2>/dev/null && return 0
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__start_stop_vm() {
  __curl_post "https://$PVE_SPICE_DEFAULT_SERVER_HOST:$PVE_SPICE_DEFAULT_SERVER_PORT/api2/json/nodes/$PVE_SPICE_DEFAULT_NODE_ID/${1:-qemu}/$PVE_SPICE_DEFAULT_MACHINE/status/${2:-start}" |& __devnull
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_spice_viewer() {
  local FILE="${1:-$FILENAME}"
  local RUN="${2:-$FILENAME}.spice"
  sed 's|delete-this-file=1|delete-this-file=0|g' "$FILE"
  cp -Rf "$FILE" "$RUN"
  remote-viewer "$RUN" &>/dev/null &
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_curl() {
  DATA="${1:-$DATA}"
  FILENAME="${2:-$FILENAME}"
  TICKET="${DATA//\"/}"
  TICKET="${TICKET##*ticket:}"
  TICKET="${TICKET%%,*}"
  TICKET="${TICKET%%\}*}"
  CSRF="${DATA//\"/}"
  CSRF="${CSRF##*CSRFPreventionToken:}"
  CSRF="${CSRF%%,*}"
  CSRF="${CSRF%%\}*}"
  if [ -n "$CSRF" ]; then
    if [ -n "$PVE_SPICE_GET_CONFIG" ]; then
      __get_config || printf_exit "Failed to get the configuration for $PVE_SPICE_DEFAULT_MACHINE"
      exit $?
    elif [ -n "$PVE_SPICE_GET_STATUS" ]; then
      __get_status || printf_exit "Failed to get the status for $PVE_SPICE_DEFAULT_MACHINE"
    else
      __get_spice_file && printf_purple "Saving to $FILENAME" || printf_exit "Failed to get the spice file"
      if __cmd_exists remote-viewer; then
        printf_yellow "Attempting to launch the client " && sleep 2
        __run_spice_viewer "$FILENAME" &>/dev/null
        return $?
      else
        printf_yellow "remote-viewer is required: 'virt-viewer' or 'remote-viewer'"
        return 1
      fi
    fi
  else
    printf_red "Failed to retrieve auth token from $PVE_SPICE_DEFAULT_SERVER_HOST"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_vm_id() {
  printf_read_input "What is your vm id number? " "120" "set_vmid"
  PVE_SPICE_DEFAULT_MACHINE="${set_vmid:-}"
  [ -n "$PVE_SPICE_DEFAULT_MACHINE" ] || printf_exit "VM ID is required"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_username() {
  local change_user="" option_user=""
  PVE_SPICE_DEFAULT_USERNAME="${PVE_SPICE_DEFAULT_USERNAME:-root@pam}"
  printf_read_question "5" "Is the username correct? [y/N]: [$PVE_SPICE_DEFAULT_USERNAME]" "1" "change_user"
  if printf_answer_no "$change_user"; then
    printf_read_input "What is your username? " "120" "option_user"
    PVE_SPICE_DEFAULT_USERNAME="$option_user"
  fi
  [ -n "$PVE_SPICE_DEFAULT_USERNAME" ] || printf_exit "Username is required"
  grep -sq "PVE_SPICE_DEFAULT_USERNAME=" "$PVE_SPICE_NODE_CONFIG_FILE" ||
    printf '%s\n' 'PVE_SPICE_DEFAULT_USERNAME="'$PVE_SPICE_DEFAULT_USERNAME'"' >>"$PVE_SPICE_NODE_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_password() {
  local change_pass="" option_pass_new="" option_pass_confirm=""
  printf_read_question "5" "Is this the correct password? [y/N]: [$PVE_SPICE_DEFAULT_PASSWORD]" "1" "change_pass"
  if printf_answer_no "$change_pass"; then
    printf_read_passwd "1" "What is your password? " "option_pass_new"
    printf_read_passwd "1" "confirm your password? " "option_pass_confirm"
    if [ "$option_pass_new" != "$option_pass_confirm" ]; then
      while :; do
        printf_red "Error: the passwords do not match"
        __get_password && break
      done
    fi
    PVE_SPICE_DEFAULT_PASSWORD="${option_pass_new:-}"
  fi
  [ -n "$PVE_SPICE_DEFAULT_PASSWORD" ] || printf_exit "Password is required"
  grep -sq "PVE_SPICE_DEFAULT_PASSWORD=" "$PVE_SPICE_NODE_CONFIG_FILE" ||
    printf '%s\n' 'PVE_SPICE_DEFAULT_PASSWORD="'$PVE_SPICE_DEFAULT_PASSWORD'"' >>"$PVE_SPICE_NODE_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_node_name() {
  local change_node=""
  PVE_SPICE_DEFAULT_NODE_ID="${PVE_SPICE_DEFAULT_NODE_ID:-pve}"
  printf_read_question "5" "Is the node name correct? [y/N]: [$PVE_SPICE_DEFAULT_NODE_ID]" "1" "change_node"
  if printf_answer_no "$change_node"; then
    printf_read_input "What is node name? " "120" "PVE_SPICE_DEFAULT_NODE_ID"
  fi
  [ -n "$PVE_SPICE_DEFAULT_NODE_ID" ] || printf_exit "The node name is required"
  grep -sq "PVE_SPICE_DEFAULT_NODE_ID=" "$PVE_SPICE_NODE_CONFIG_FILE" ||
    printf '%s\n' 'PVE_SPICE_DEFAULT_NODE_ID="'$PVE_SPICE_DEFAULT_NODE_ID'"' >>"$PVE_SPICE_NODE_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_servername() {
  local change_server=""
  PVE_SPICE_DEFAULT_SERVER_HOST="${PVE_SPICE_DEFAULT_SERVER_HOST:-proxmox.local}"
  printf_read_question "5" "is the server address correct? [y/N]: [$PVE_SPICE_DEFAULT_SERVER_HOST]" "1" "change_server"
  if printf_answer_no "$change_server"; then
    printf_read_input "What is the server address? " "120" "PVE_SPICE_DEFAULT_SERVER_HOST"
  fi
  [ -n "$PVE_SPICE_DEFAULT_SERVER_HOST" ] || printf_exit "The host is required"
  grep -sq "PVE_SPICE_DEFAULT_SERVER_HOST=" "$PVE_SPICE_NODE_CONFIG_FILE" ||
    printf '%s\n' 'PVE_SPICE_DEFAULT_SERVER_HOST="'$PVE_SPICE_DEFAULT_SERVER_HOST'"' >>"$PVE_SPICE_NODE_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_serverport() {
  local change_port=""
  PVE_SPICE_DEFAULT_SERVER_PORT="${PVE_SPICE_DEFAULT_SERVER_PORT:-8006}"
  printf_read_question "5" "is the port correct? [y/N]: [$PVE_SPICE_DEFAULT_SERVER_PORT]" "1" "change_port"
  if printf_answer_no "$change_port"; then
    printf_read_input "What is the port? " "120" "PVE_SPICE_DEFAULT_SERVER_PORT"
  fi
  [ -n "$PVE_SPICE_DEFAULT_SERVER_PORT" ] || printf_exit "The port is required"
  grep -sq "PVE_SPICE_DEFAULT_SERVER_PORT=" "$PVE_SPICE_NODE_CONFIG_FILE" ||
    printf '%s\n' 'PVE_SPICE_DEFAULT_SERVER_PORT="'$PVE_SPICE_DEFAULT_SERVER_PORT'"' >>"$PVE_SPICE_NODE_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__initialize_app() {
  while :; do
    case "$1" in
    reset) PVE_SPICE_FORCE="true" && shift 1 ;;
    config) PVE_SPICE_GET_CONFIG="true" && shift 1 ;;
    status) PVE_SPICE_GET_STATUS="true" && shift 1 ;;
    web) shift 1 && __open_web && exit 0 || exit 1 ;;
    ssh) shift 1 && __open__ssh && exit 0 || exit 1 ;;
    *) break ;;
    esac
  done
  PVE_SPICE_DEFAULT_MACHINE="${1:-$PVE_SPICE_DEFAULT_MACHINE}"
  PVE_SPICE_DEFAULT_NODE_ID="${2:-$PVE_SPICE_DEFAULT_NODE_ID}"
  PVE_SPICE_DEFAULT_SERVER_HOST="${3:-$PVE_SPICE_DEFAULT_SERVER_HOST}"
  PVE_SPICE_DEFAULT_SERVER_PORT="${4:-$PVE_SPICE_DEFAULT_SERVER_PORT}"
  PVE_SPICE_DEFAULT_USERNAME="${5:-$PVE_SPICE_DEFAULT_USERNAME}"
  PVE_SPICE_DEFAULT_PASSWORD="${6:-$PVE_SPICE_DEFAULT_PASSWORD}"
  if [ "$PVE_SPICE_FORCE" = "true" ]; then
    PVE_SPICE_NEW_INSTALL="true"
    PVE_SPICE_FORCED="complete"
    rm -Rf "$PVE_SPICE_NODE_CONFIG_FILE"
  fi
  if [ ! -f "$PVE_SPICE_NODE_CONFIG_FILE" ]; then
    __get_username
    __get_password
    __get_node_name
    __get_servername
    __get_serverport
  fi
  # Set vm id
  [ -n "$PVE_SPICE_DEFAULT_MACHINE" ] || __get_vm_id
  # Get/confirm username
  [ -z "$PVE_SPICE_DEFAULT_USERNAME" ] && __get_username
  # Get/confirm password
  [ -z "$PVE_SPICE_DEFAULT_PASSWORD" ] && __get_password
  # Get/confirm servername
  [ -z "$PVE_SPICE_DEFAULT_NODE_ID" ] && __get_node_name
  # Get/confirm node name
  [ -z "$PVE_SPICE_DEFAULT_SERVER_HOST" ] && __get_servername
  # Get/confirm port
  [ -z "$PVE_SPICE_DEFAULT_SERVER_PORT" ] && __get_serverport
  # Write settings to file
  if [ -f "$PVE_SPICE_NODE_CONFIG_FILE" ] && [ "$PVE_SPICE_NEW_INSTALL" = "true" ]; then
    [ -d "$PVE_SPICE_SAVE_DIR" ] || mkdir -p "$PVE_SPICE_SAVE_DIR" &>/dev/null
    printf_blue "Updating the configuration and setting permissions"
    __gen_config &>/dev/null
    touch "$PVE_SPICE_NODE_CONFIG_FILE"
    source "$PVE_SPICE_NODE_CONFIG_FILE"
    PVE_SPICE_FORCE="" PVE_SPICE_NEW_INSTALL=""
    chmod 600 "$PVE_SPICE_NODE_CONFIG_FILE" "$PVE_SPICE_CONFIG_DIR/$PVE_SPICE_CONFIG_FILE"
    return 0
  elif [ ! -f "$PVE_SPICE_NODE_CONFIG_FILE" ]; then
    printf_exit "Something went wrong"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__execute_pve_spice() {
  local statusCode=0
  SPICEDIR="$PVE_SPICE_SAVE_DIR"
  USERNAME="$PVE_SPICE_DEFAULT_USERNAME"
  PASSWORD="$PVE_SPICE_DEFAULT_PASSWORD"
  FILENAME="$PVE_SPICE_SAVE_DIR/${PVE_SPICE_DEFAULT_NODE_ID}_${PVE_SPICE_DEFAULT_MACHINE}"
  [ -d "$SPICEDIR" ] || mkdir -p "$SPICEDIR"
  DATA="$(__query_server || echo '')"
  if [ -n "$DATA" ]; then
    printf_blue "Authentication with server was a success"
    if __run_curl "$DATA" "$FILENAME"; then
      statusCode=0
    else
      printf_red "Failed to get spice file from server"
      statusCode=1
    fi
  else
    printf_error "Something went wrong"
    statusCode=1
  fi
  return $statusCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__open_web() {
  local url="https://$PVE_SPICE_DEFAULT_SERVER_HOST:$PVE_SPICE_DEFAULT_SERVER_PORT"
  if __cmd_exists mybrowser; then
    mybrowser "$url"
  elif [ -f "$BROWSER" ]; then
    $BROWSER "$url"
  else
    printf_exit "Can not find browser"
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__open__ssh() {
  local url="$PVE_SPICE_DEFAULT_SERVER_HOST"
  ssh -l root $url
  return $?
}
