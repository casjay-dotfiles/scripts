#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : radioreference --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : radioreference
# @Description   : Play radioreference/broadcastify stream
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$RADIOREFERENCE_TEMP_FILE" ] && [ -f "$RADIOREFERENCE_TEMP_FILE" ] && rm -Rf "$RADIOREFERENCE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$RADIOREFERENCE_CONFIG_DIR/$RADIOREFERENCE_CONFIG_FILE"
  [ -d "$RADIOREFERENCE_CONFIG_DIR" ] || mkdir -p "$RADIOREFERENCE_CONFIG_DIR"
  [ -d "$RADIOREFERENCE_CONFIG_BACKUP_DIR" ] || mkdir -p "$RADIOREFERENCE_CONFIG_BACKUP_DIR"
  [ -f "$RADIOREFERENCE_CONFIG_DIR/$RADIOREFERENCE_CONFIG_FILE" ] &&
    cp -Rf "$RADIOREFERENCE_CONFIG_DIR/$RADIOREFERENCE_CONFIG_FILE" "$RADIOREFERENCE_CONFIG_BACKUP_DIR/$RADIOREFERENCE_CONFIG_FILE.$$"
  cat <<EOF >"$RADIOREFERENCE_CONFIG_DIR/$RADIOREFERENCE_CONFIG_FILE"
# Settings for radioreference
RADIOREFERENCE_DEFAULT_FEED="${RADIOREFERENCE_DEFAULT_FEED:-https://www.broadcastify.com/scripts/playlists/1/30321/184850-6324415808.m3u}"

# Notification settings
RADIOREFERENCE_GOOD_MESSAGE="${RADIOREFERENCE_GOOD_MESSAGE:-Everything Went OK}"
RADIOREFERENCE_ERROR_MESSAGE="${RADIOREFERENCE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
RADIOREFERENCE_NOTIFY_ENABLED="${RADIOREFERENCE_NOTIFY_ENABLED:-yes}"
RADIOREFERENCE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
RADIOREFERENCE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$RADIOREFERENCE_NOTIFY_CLIENT_ICON}"

# Colorization settings
RADIOREFERENCE_OUTPUT_COLOR="${RADIOREFERENCE_OUTPUT_COLOR:-5}"
RADIOREFERENCE_OUTPUT_COLOR_GOOD="${RADIOREFERENCE_OUTPUT_COLOR_GOOD:-2}"
RADIOREFERENCE_OUTPUT_COLOR_ERROR="${RADIOREFERENCE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$RADIOREFERENCE_CONFIG_DIR/$RADIOREFERENCE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for radioreference has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      exit 1
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
RADIOREFERENCE_LOG_DIR="${RADIOREFERENCE_LOG_DIR:-$HOME/.local/log/radioreference}"
RADIOREFERENCE_CACHE_DIR="${RADIOREFERENCE_CACHE_DIR:-$HOME/.cache/radioreference}"
RADIOREFERENCE_CONFIG_DIR="${RADIOREFERENCE_CONFIG_DIR:-$HOME/.config/myscripts/radioreference}"
RADIOREFERENCE_CONFIG_BACKUP_DIR="${RADIOREFERENCE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/radioreference/backups}"
RADIOREFERENCE_TEMP_DIR="${RADIOREFERENCE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/radioreference}"
RADIOREFERENCE_OPTIONS_DIR="${RADIOREFERENCE_OPTIONS_DIR:-$HOME/.local/share/myscripts/radioreference/options}"
RADIOREFERENCE_TEMP_FILE="${RADIOREFERENCE_TEMP_FILE:-$(mktemp $RADIOREFERENCE_TEMP_DIR/XXXXXX 2>/dev/null)}"
RADIOREFERENCE_CONFIG_FILE="${RADIOREFERENCE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
RADIOREFERENCE_OUTPUT_COLOR="${RADIOREFERENCE_OUTPUT_COLOR:-4}"
RADIOREFERENCE_OUTPUT_COLOR_2="${RADIOREFERENCE_OUTPUT_COLOR:-6}"
RADIOREFERENCE_OUTPUT_COLOR_GOOD="${RADIOREFERENCE_OUTPUT_COLOR_GOOD:-2}"
RADIOREFERENCE_OUTPUT_COLOR_ERROR="${RADIOREFERENCE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
RADIOREFERENCE_GOOD_MESSAGE="${RADIOREFERENCE_GOOD_MESSAGE:-Everything Went OK}"
RADIOREFERENCE_ERROR_MESSAGE="${RADIOREFERENCE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
RADIOREFERENCE_NOTIFY_ENABLED="${RADIOREFERENCE_NOTIFY_ENABLED:-yes}"
RADIOREFERENCE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
RADIOREFERENCE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$RADIOREFERENCE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
RADIOREFERENCE_DEFAULT_FEED="${RADIOREFERENCE_DEFAULT_FEED:-https://www.broadcastify.com/scripts/playlists/1/30321/184850-6324415808.m3u}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$RADIOREFERENCE_CONFIG_DIR/$RADIOREFERENCE_CONFIG_FILE" ] && . "$RADIOREFERENCE_CONFIG_DIR/$RADIOREFERENCE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$RADIOREFERENCE_LOG_DIR" ] || mkdir -p "$RADIOREFERENCE_LOG_DIR" &>/dev/null
[ -d "$RADIOREFERENCE_TEMP_DIR" ] || mkdir -p "$RADIOREFERENCE_TEMP_DIR" &>/dev/null
[ -d "$RADIOREFERENCE_CACHE_DIR" ] || mkdir -p "$RADIOREFERENCE_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$RADIOREFERENCE_CONFIG_DIR/$RADIOREFERENCE_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    RADIOREFERENCE_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$RADIOREFERENCE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${RADIOREFERENCE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${RADIOREFERENCE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${RADIOREFERENCE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${RADIOREFERENCE_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash vlc || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
RADIOREFERENCE_DEFAULT_FEED="${1:-$RADIOREFERENCE_DEFAULT_FEED}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if __urlverify "$RADIOREFERENCE_DEFAULT_FEED"; then
  printf_green "Playing $RADIOREFERENCE_DEFAULT_FEED"
  vlc "$RADIOREFERENCE_DEFAULT_FEED" -I curses 2>/dev/null
else
  printf_exit 1 1 "$RADIOREFERENCE_DEFAULT_FEED seems to be an invalid url"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
