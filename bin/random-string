#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -euo pipefail
trap 'exitCode=${exitCode:-$?};[ -f "$RANDOM_STRING_TEMP_FILE" ] && rm -Rf "$RANDOM_STRING_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : random-string --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : random-string
# @Description   : generate random string
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$RANDOM_STRING_CONFIG_DIR/$RANDOM_STRING_CONFIG_FILE"
  [ -d "$RANDOM_STRING_CONFIG_DIR" ] || mkdir -p "$RANDOM_STRING_CONFIG_DIR"
  [ -d "$RANDOM_STRING_CONFIG_BACKUP_DIR" ] || mkdir -p "$RANDOM_STRING_CONFIG_BACKUP_DIR"
  [ -f "$RANDOM_STRING_CONFIG_DIR/$RANDOM_STRING_CONFIG_FILE" ] &&
    cp -Rf "$RANDOM_STRING_CONFIG_DIR/$RANDOM_STRING_CONFIG_FILE" "$RANDOM_STRING_CONFIG_BACKUP_DIR/$RANDOM_STRING_CONFIG_FILE.$$"
  cat <<EOF >"$RANDOM_STRING_CONFIG_DIR/$RANDOM_STRING_CONFIG_FILE"
# Settings for random-string

# Notification settings
RANDOM_STRING_GOOD_MESSAGE="${RANDOM_STRING_GOOD_MESSAGE:-Everything Went OK}"
RANDOM_STRING_ERROR_MESSAGE="${RANDOM_STRING_ERROR_MESSAGE:-Well that didn\'t work}"
RANDOM_STRING_NOTIFY_ENABLED="${RANDOM_STRING_NOTIFY_ENABLED:-yes}"
RANDOM_STRING_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
RANDOM_STRING_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$RANDOM_STRING_NOTIFY_CLIENT_ICON}"

# Colorization settings
RANDOM_STRING_OUTPUT_COLOR="${RANDOM_STRING_OUTPUT_COLOR:-5}"
RANDOM_STRING_OUTPUT_COLOR_GOOD="${RANDOM_STRING_OUTPUT_COLOR_GOOD:-2}"
RANDOM_STRING_OUTPUT_COLOR_ERROR="${RANDOM_STRING_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$RANDOM_STRING_CONFIG_DIR/$RANDOM_STRING_CONFIG_FILE" ]; then
    printf_green "Your config file for random-string has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
RANDOM_STRING_LOG_DIR="${RANDOM_STRING_LOG_DIR:-$HOME/.local/log/random-string}"
RANDOM_STRING_CACHE_DIR="${RANDOM_STRING_CACHE_DIR:-$HOME/.cache/random-string}"
RANDOM_STRING_CONFIG_DIR="${RANDOM_STRING_CONFIG_DIR:-$HOME/.config/myscripts/random-string}"
RANDOM_STRING_CONFIG_BACKUP_DIR="${RANDOM_STRING_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/random-string/backups}"
RANDOM_STRING_TEMP_DIR="${RANDOM_STRING_TEMP_DIR:-$HOME/.local/tmp/system_scripts/random-string}"
RANDOM_STRING_OPTIONS_DIR="${RANDOM_STRING_OPTIONS_DIR:-$HOME/.local/share/myscripts/random-string/options}"
RANDOM_STRING_TEMP_FILE="${RANDOM_STRING_TEMP_FILE:-$(mktemp $RANDOM_STRING_TEMP_DIR/XXXXXX 2>/dev/null)}"
RANDOM_STRING_CONFIG_FILE="${RANDOM_STRING_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
RANDOM_STRING_OUTPUT_COLOR="${RANDOM_STRING_OUTPUT_COLOR:-4}"
RANDOM_STRING_OUTPUT_COLOR_2="${RANDOM_STRING_OUTPUT_COLOR:-6}"
RANDOM_STRING_OUTPUT_COLOR_GOOD="${RANDOM_STRING_OUTPUT_COLOR_GOOD:-2}"
RANDOM_STRING_OUTPUT_COLOR_ERROR="${RANDOM_STRING_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
RANDOM_STRING_GOOD_MESSAGE="${RANDOM_STRING_GOOD_MESSAGE:-Everything Went OK}"
RANDOM_STRING_ERROR_MESSAGE="${RANDOM_STRING_ERROR_MESSAGE:-Well that didn\'t work}"
RANDOM_STRING_NOTIFY_ENABLED="${RANDOM_STRING_NOTIFY_ENABLED:-yes}"
RANDOM_STRING_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
RANDOM_STRING_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$RANDOM_STRING_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$RANDOM_STRING_CONFIG_DIR/$RANDOM_STRING_CONFIG_FILE" ] && . "$RANDOM_STRING_CONFIG_DIR/$RANDOM_STRING_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$RANDOM_STRING_LOG_DIR" ] || mkdir -p "$RANDOM_STRING_LOG_DIR" &>/dev/null
[ -d "$RANDOM_STRING_TEMP_DIR" ] || mkdir -p "$RANDOM_STRING_TEMP_DIR" &>/dev/null
[ -d "$RANDOM_STRING_CACHE_DIR" ] || mkdir -p "$RANDOM_STRING_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$RANDOM_STRING_CONFIG_DIR/$RANDOM_STRING_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    RANDOM_STRING_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$RANDOM_STRING_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${RANDOM_STRING_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${RANDOM_STRING_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${RANDOM_STRING_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${RANDOM_STRING_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
RANDOM_LENGTH="${1:-$RANDOM_LENGTH}"
RANDOM_STRING="$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w ${RANDOM_LENGTH:-64} | head -n 1)"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
printf_green "$RANDOM_STRING"
cmd_exists putclip && echo "$RANDOM_STRING" | putclip
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
