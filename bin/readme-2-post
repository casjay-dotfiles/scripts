#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -euo pipefail
trap 'exitCode=${exitCode:-$?};[ -f "$README_2_POST_TEMP_FILE" ] && rm -Rf "$README_2_POST_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : readme-2-post --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : readme-2-post
# @Description   : Create a markdown file from a README file
# @TODO          : Add import of script help
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$README_2_POST_CONFIG_DIR/$README_2_POST_CONFIG_FILE"
  [ -d "$README_2_POST_CONFIG_DIR" ] || mkdir -p "$README_2_POST_CONFIG_DIR"
  [ -d "$README_2_POST_CONFIG_BACKUP_DIR" ] || mkdir -p "$README_2_POST_CONFIG_BACKUP_DIR"
  [ -f "$README_2_POST_CONFIG_DIR/$README_2_POST_CONFIG_FILE" ] &&
    cp -Rf "$README_2_POST_CONFIG_DIR/$README_2_POST_CONFIG_FILE" "$README_2_POST_CONFIG_BACKUP_DIR/$README_2_POST_CONFIG_FILE.$$"
  cat <<EOF >"$README_2_POST_CONFIG_DIR/$README_2_POST_CONFIG_FILE"
# Settings for readme-2-post
README_2_POST_AUTHOR="$USER"
README_2_POST_DEST_FOLDER="man"
README_2_POST_TEMPLATE="${README_2_POST_TEMPLATE:-$README_2_POST_CONFIG_DIR/readme.template}"

# Notification settings
README_2_POST_GOOD_MESSAGE="${README_2_POST_GOOD_MESSAGE:-Everything Went OK}"
README_2_POST_ERROR_MESSAGE="${README_2_POST_ERROR_MESSAGE:-Well that didn\'t work}"
README_2_POST_NOTIFY_ENABLED="${README_2_POST_NOTIFY_ENABLED:-yes}"
README_2_POST_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
README_2_POST_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$README_2_POST_NOTIFY_CLIENT_ICON}"

# Colorization settings
README_2_POST_OUTPUT_COLOR="${README_2_POST_OUTPUT_COLOR:-5}"
README_2_POST_OUTPUT_COLOR_GOOD="${README_2_POST_OUTPUT_COLOR_GOOD:-2}"
README_2_POST_OUTPUT_COLOR_ERROR="${README_2_POST_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$README_2_POST_CONFIG_DIR/$README_2_POST_CONFIG_FILE" ]; then
    printf_green "Your config file for readme-2-post has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__sedcmd() { sed 's|^.*printf_he.. "[0-9]" ||g;s|"||g;s|$|  |g'; }
__grepcmd() { grep -E ^'?printf_he.. "." ' "$1"; }
__mimetype() { file "$1" --mime-type | awk '{print $2}'; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__generate_readme() {
  cat <<EOF | tee "$1" &>/dev/null
---
layout: post
title: $README_2_POST_TITLE
categories: [man]
tags: [readmes,manuals]
date: $(date '+%Y-%m-%d %H:%M')
comments: true
author: $README_2_POST_AUTHOR
---

$INPUT

## Author
👤 **$README_2_POST_AUTHOR**
##

EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
README_2_POST_CACHE_DIR="${README_2_POST_CACHE_DIR:-$HOME/.cache/readme-2-post}"
README_2_POST_CONFIG_DIR="${README_2_POST_CONFIG_DIR:-$HOME/.config/myscripts/readme-2-post}"
README_2_POST_OPTIONS_DIR="${README_2_POST_OPTIONS_DIR:-$HOME/.local/share/myscripts/readme-2-post/options}"
README_2_POST_CONFIG_BACKUP_DIR="${README_2_POST_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/readme-2-post/backups}"
README_2_POST_TEMP_DIR="${README_2_POST_TEMP_DIR:-$HOME/.local/tmp/system_scripts/readme-2-post}"
README_2_POST_TEMP_FILE="${README_2_POST_TEMP_FILE:-$(mktemp $README_2_POST_TEMP_DIR/XXXXXX 2>/dev/null)}"
README_2_POST_CONFIG_FILE="${README_2_POST_CONFIG_FILE:-settings.conf}"
README_2_POST_GOOD_MESSAGE="${README_2_POST_GOOD_MESSAGE:-Everything Went OK}"
README_2_POST_ERROR_MESSAGE="${README_2_POST_ERROR_MESSAGE:-Well that didn\'t work}"
README_2_POST_NOTIFY_ENABLED="${README_2_POST_NOTIFY_ENABLED:-yes}"
README_2_POST_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
README_2_POST_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$README_2_POST_NOTIFY_CLIENT_ICON}"
README_2_POST_OUTPUT_COLOR="${README_2_POST_OUTPUT_COLOR:-5}"
README_2_POST_OUTPUT_COLOR_GOOD="${README_2_POST_OUTPUT_COLOR_GOOD:-2}"
README_2_POST_OUTPUT_COLOR_ERROR="${README_2_POST_OUTPUT_COLOR_ERROR:-1}"
README_2_POST_TEMPLATE="${README_2_POST_TEMPLATE:-$README_2_POST_CONFIG_DIR/readme.template}"
README_2_POST_DEST_FOLDER="man"
README_2_POST_AUTHOR="$USER"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$README_2_POST_TEMP_DIR" ] || mkdir -p "$README_2_POST_TEMP_DIR" &>/dev/null
[ -d "$README_2_POST_CACHE_DIR" ] || mkdir -p "$README_2_POST_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$README_2_POST_CONFIG_DIR/$README_2_POST_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$README_2_POST_CONFIG_DIR/$README_2_POST_CONFIG_FILE" ] &&
  . "$README_2_POST_CONFIG_DIR/$README_2_POST_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:,f:,script,file:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    README_2_POST_CWD="$2"
    shift 2
    ;;
  -f | --file)
    shift 1
    README_2_POST_DEST_FILE="$(basename "$1")"
    README_2_POST_DEST_FOLDER="$(dirname "$1")"
    shift 1
    ;;
  --script)
    shift 1
    SCRIPT="yes"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$README_2_POST_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${README_2_POST_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${README_2_POST_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${README_2_POST_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${README_2_POST_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[[ $# = 0 ]] && __help
README_2_POST_INPUT_FILE="$1"
README_2_POST_DEST_FILE="${2:-$(basename "${1%.*}")}.md"
README_2_POST_TITLE="${2:-$(basename "${1%.*}")}"
README_2_POST_AUTHOR="${3:-$README_2_POST_AUTHOR}"
[ "$(__mimetype "$1")" = "text/x-shellscript" ] && SCRIPT="yes"
[ -d "$README_2_POST_DEST_FOLDER" ] || mkdir -p "$README_2_POST_DEST_FOLDER"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ "$SCRIPT" = "yes" ]; then
  printf_yellow "The file seems to be a script: running script import"
  __grepcmd "$README_2_POST_INPUT_FILE" | __sedcmd >"$README_2_POST_TEMP_FILE"
  if [ -f "$README_2_POST_TEMP_FILE" ]; then
    INPUT="$(<"$README_2_POST_TEMP_FILE")"
    rm -Rf "$README_2_POST_TEMP_FILE"
  else
    printf_exit "Failed to create the needed temp file"
  fi
else
  printf_yellow "Treating the file as a text file"
  INPUT="$(<"$README_2_POST_INPUT_FILE")"
fi
if [ -f "$README_2_POST_CONFIG_DIR/template.conf" ]; then
  . "$("$README_2_POST_CONFIG_DIR/template.conf")"
elif [ -n "$README_2_POST_TEMPLATE" ] && [ -f "$README_2_POST_TEMPLATE" ]; then
  . "$("$README_2_POST_TEMPLATE")"
else
  __generate_readme "$README_2_POST_DEST_FOLDER/$README_2_POST_DEST_FILE"
fi
if [ -f "$README_2_POST_DEST_FOLDER/$README_2_POST_DEST_FILE" ]; then
  printf_green "Your file has been created and saved"
  printf_green "to $README_2_POST_DEST_FOLDER/$README_2_POST_DEST_FILE"
else
  printf_error "Something went wrong"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
