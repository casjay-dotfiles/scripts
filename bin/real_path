#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version           :  202207171553-git
# @@Author           :  Jason Hempstead
# @@Contact          :  jason@casjaysdev.com
# @@License          :  WTFPL
# @@ReadME           :  real_path --help
# @@Copyright        :  Copyright: (c) 2022 Jason Hempstead, Casjays Developments
# @@Created          :  Sunday, Jul 17, 2022 15:53 EDT
# @@File             :  real_path
# @@Description      :
# @@Changelog        :
# @@TODO             :  Better documentation
# @@Other            :
# @@Resource         :
# @@sudo/root        :  no
# @@Template         :  bash/simple
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202207171553-git"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
[[ "$1" == "--raw" ]] && export SHOW_RAW="true" && printf_color() { printf '%s\n' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
set -o pipefail
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -'
# Set functions
__devnull() { tee &>/dev/null; }
__devnull2() { eval "$*" 2>/dev/null; }
__logr() { eval "$*" |& tee -a "${LOGFILE:-$REAL_PATH_LOG_DIR/$APPNAME.log}" |& __devnull; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__cmd_exist() {
  local exitCode=0
  for cmd in "$@"; do builtin command -v "$cmd" |& __devnull && true || exitCode+=1; done
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# colorization
[ -n "$SHOW_RAW" ] && printf_color() { echo -e "${1:-}"; } ||
  printf_color() { printf "%b" "$(tput setaf "$2" 2>/dev/null)" "\t\t$1\n" "$(tput sgr0 2>/dev/null)"; }

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# output version
__version() { printf_color "$VERSION" "2"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  echo -e "\t\t${5:-$BLUE}$1$NC"
  echo -e "\t\t${5:-$BLUE}$2${NC}" | sed 's|:||g;s/'$3'/ '$4'/g' 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# send notifications
__notifications() {
  [[ -n "$DISPLAY" ]] && [[ -z "$SSH_CONNECTION" ]] &&
    __cmd_exist notifications &>/dev/null && notifications "$@" || echo "$*"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Help function - Align to 50
__printf_head() { printf_color "$1" "5"; }
__printf_opts() { printf_color "$1" "4"; }
__printf_line() { printf_color "$1" "4"; }
__help() {
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "real_path: "
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Usage: real_path [options] [commands]"
  __printf_line "real_path available                             - list all available packages"
  __printf_line "real_path list                                  - list installed packages"
  __printf_line "real_path search    [package]                   - search for a package"
  __printf_line "real_path version   [package]                   - show the version info"
  __printf_line "real_path install   [package]                   - install a package"
  __printf_line "real_path remove    [package]                   - remove a package"
  __printf_line "real_path update    [package]                   - update a package"
  __printf_line "real_path download  [package]                   - downloads the source"
  __printf_line ""
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "real_path --debug                               - enable debugging"
  __printf_line "real_path --config                              - Generate user config file"
  __printf_line "real_path --version                             - Show script version"
  __printf_line "real_path --help                                - Shows this message"
  __printf_line "real_path --options                             - Shows all available options"
  __printf_line ""
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__real_path() {
  if [[ $OSTYPE == darwin* ]]; then
    greadlink "${@:-$PWD}" | grep '^'
  else
    readlink -f "${@:-$PWD}" | grep '^'
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__real_dirname() {
  { [[ -d "${1:-$PWD}" ]] && dirname "$(real_path "$1/dir" 2>/dev/null | grep '^')"; } ||
    { [[ -e "${1:-$PWD}" ]] && dirname "$(real_path "$1" 2>/dev/null | grep '^')"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__real_basename() {
  { [[ -d "${1:-$PWD}" ]] && basename "$(real_path "$1" 2>/dev/null | grep '^')"; } ||
    { [[ -e "${1:-$PWD}" ]] && basename "$(real_path "$1" 2>/dev/null | grep '^')"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for needed applications
__cmd_exist bash || { printf_color "Missing: bash" "1" && exit 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set options
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="debug,help,options,raw,version"
ARRAY="readlink basename dirname"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --help)
    shift 1
    __help
    exit
    ;;
  --version)
    shift 1
    printf_color "$APPNAME Version: $VERSION" "3"
    exit
    ;;
  --options)
    shift 1
    [ -n "$1" ] || printf_color "Current options for ${APPNAME:-$PRO}" "4"
    [ -z "$SHORTOPTS" ] || __list_options "Short Options" "-${SHORTOPTS}" ',' '-' "5"
    [ -z "$LONGOPTS" ] || __list_options "Long Options" "--${LONGOPTS}" ',' '--' "5"
    [ -z "$ARRAY" ] || __list_options "Base Options" "${ARRAY}" ',' '' "5"
    exit $?
    ;;
  --raw)
    shift 1
    export SHOW_RAW="true"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Redefine functions based on options

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional variables

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Main application
case "$1" in
basename)
  shift 1
  __real_basename "$1"
  exit $?
  ;;

dirname)
  shift 1
  __real_dirname "$1"
  exit $?
  ;;

readlink)
  shift 1
  __real_dirname "$1"
  exit $?
  ;;

*)
  __real_path "$1"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
exit ${exitCode:-$?}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
