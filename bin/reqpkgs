#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$REQPKGS_TEMP_FILE" ] && rm -Rf "$REQPKGS_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : reqpkgs --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : reqpkgs
# @Description   : Install required packages
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$REQPKGS_CONFIG_DIR/$REQPKGS_CONFIG_FILE"
  [ -d "$REQPKGS_CONFIG_DIR" ] || mkdir -p "$REQPKGS_CONFIG_DIR"
  [ -d "$REQPKGS_CONFIG_BACKUP_DIR" ] || mkdir -p "$REQPKGS_CONFIG_BACKUP_DIR"
  [ -f "$REQPKGS_CONFIG_DIR/$REQPKGS_CONFIG_FILE" ] &&
    cp -Rf "$REQPKGS_CONFIG_DIR/$REQPKGS_CONFIG_FILE" "$REQPKGS_CONFIG_BACKUP_DIR/$REQPKGS_CONFIG_FILE.$$"
  cat <<EOF >"$REQPKGS_CONFIG_DIR/$REQPKGS_CONFIG_FILE"
# Settings for reqpkgs
# Packages that are the same across distros
GLOBAL_PACKAGES="sudo git curl gnupg lynx wget net-tools "

# Debian/Ubuntu
DEB_PACKAGE_NAME="python3 python3-pil python3-pip vim-nox "
DEB_PACKAGE_NAME+=""

# Fedora/CentOS/REHEL/Rocky
YUM_PACKAGE_NAME="python3 python3-pip net-tools vim "
YUM_PACKAGE_NAME+=""

# Archlinux
PAC_PACKAGE_NAME="python3 python-pip net-tools vim "
PAC_PACKAGE_NAME+=""

# Python packages
REQ_PIP_PACKAGE_NAME=""

# Ruby packages
REQ_GEM_PACKAGE_NAME=""

# Lua packages
REQ_LUA_PACKAGE_NAME=""

# Go packages
REQ_GO_PACKAGE_NAME=""

# Notification settings
REQPKGS_GOOD_MESSAGE="${REQPKGS_GOOD_MESSAGE:-Everything Went OK}"
REQPKGS_ERROR_MESSAGE="${REQPKGS_ERROR_MESSAGE:-Well that didn\'t work}"
REQPKGS_NOTIFY_ENABLED="${REQPKGS_NOTIFY_ENABLED:-yes}"
REQPKGS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
REQPKGS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$REQPKGS_NOTIFY_CLIENT_ICON}"

# Colorization settings
REQPKGS_OUTPUT_COLOR="${REQPKGS_OUTPUT_COLOR:-5}"
REQPKGS_OUTPUT_COLOR_GOOD="${REQPKGS_OUTPUT_COLOR_GOOD:-2}"
REQPKGS_OUTPUT_COLOR_ERROR="${REQPKGS_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$REQPKGS_CONFIG_DIR/$REQPKGS_CONFIG_FILE" ]; then
    printf_green "Your config file for reqpkgs has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
REQPKGS_CACHE_DIR="${REQPKGS_CACHE_DIR:-$HOME/.cache/reqpkgs}"
REQPKGS_CONFIG_DIR="${REQPKGS_CONFIG_DIR:-$HOME/.config/myscripts/reqpkgs}"
REQPKGS_OPTIONS_DIR="${REQPKGS_OPTIONS_DIR:-$HOME/.local/share/myscripts/reqpkgs/options}"
REQPKGS_CONFIG_BACKUP_DIR="${REQPKGS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/reqpkgs/backups}"
REQPKGS_TEMP_DIR="${REQPKGS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/reqpkgs}"
REQPKGS_TEMP_FILE="${REQPKGS_TEMP_FILE:-$(mktemp $REQPKGS_TEMP_DIR/XXXXXX 2>/dev/null)}"
REQPKGS_CONFIG_FILE="${REQPKGS_CONFIG_FILE:-settings.conf}"
REQPKGS_GOOD_MESSAGE="${REQPKGS_GOOD_MESSAGE:-Everything Went OK}"
REQPKGS_ERROR_MESSAGE="${REQPKGS_ERROR_MESSAGE:-Well that didn\'t work}"
REQPKGS_NOTIFY_ENABLED="${REQPKGS_NOTIFY_ENABLED:-yes}"
REQPKGS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
REQPKGS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$REQPKGS_NOTIFY_CLIENT_ICON}"
REQPKGS_OUTPUT_COLOR="${REQPKGS_OUTPUT_COLOR:-5}"
REQPKGS_OUTPUT_COLOR_GOOD="${REQPKGS_OUTPUT_COLOR_GOOD:-2}"
REQPKGS_OUTPUT_COLOR_ERROR="${REQPKGS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$REQPKGS_TEMP_DIR" ] || mkdir -p "$REQPKGS_TEMP_DIR" &>/dev/null
[ -d "$REQPKGS_CACHE_DIR" ] || mkdir -p "$REQPKGS_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$REQPKGS_CONFIG_DIR/$REQPKGS_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$REQPKGS_CONFIG_DIR/$REQPKGS_CONFIG_FILE" ] &&
  . "$REQPKGS_CONFIG_DIR/$REQPKGS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    REQPKGS_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$REQPKGS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${REQPKGS_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${REQPKGS_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${REQPKGS_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${REQPKGS_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
YUM_PACKAGE_NAME="${*:-$YUM_PACKAGE_NAME}"
DEB_PACKAGE_NAME="${*:-$DEB_PACKAGE_NAME}"
PAC_PACKAGE_NAME="${*:-$PAC_PACKAGE_NAME}"
REQ_PIP_PACKAGE_NAME="${REQ_PIP_PACKAGE_NAME:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if cat /etc/*release | grep ^NAME | grep CentOS; then
  printf_green "============================================="
  printf_green "Installing packages for CentOS               "
  printf_green "============================================="
  for pkg in ${YUM_PACKAGE_NAME} ${GLOBAL_PACKAGES}; do
    sudo yum install -y $pkg &>/dev/null && exitCode+=0 || exitCode+=1
  done
elif cat /etc/*release | grep ^NAME | grep Red; then
  printf_green "============================================="
  printf_green "Installing packages for RedHat               "
  printf_green "============================================="
  for pkg in ${YUM_PACKAGE_NAME} ${GLOBAL_PACKAGES}; do
    sudo yum install -y $pkg &>/dev/null && exitCode+=0 || exitCode+=1
  done
elif cat /etc/*release | grep ^NAME | grep Fedora; then
  printf_green "============================================="
  printf_green "Installing packages for Fedora               "
  printf_green "============================================="
  for pkg in ${YUM_PACKAGE_NAME} ${GLOBAL_PACKAGES}; do
    sudo yum install -y $pkg &>/dev/null && exitCode+=0 || exitCode+=1
  done
elif cat /etc/*release | grep ^NAME | grep Ubuntu; then
  printf_green "============================================="
  printf_green "Installing packages for Ubuntu               "
  printf_green "============================================="
  for pkg in ${DEB_PACKAGE_NAME} ${GLOBAL_PACKAGES}; do
    sudo apt-get install -yy $pkg &>/dev/null && exitCode+=0 || exitCode+=1
  done
elif cat /etc/*release | grep ^NAME | grep Debian; then
  printf_green "============================================="
  printf_green "Installing packages for Debian               "
  printf_green "============================================="
  for pkg in ${DEB_PACKAGE_NAME} ${GLOBAL_PACKAGES}; do
    sudo apt-get install -yy $pkg &>/dev/null && exitCode+=0 || exitCode+=1
  done
elif cat /etc/*release | grep ^NAME | grep Mint; then
  printf_green "============================================="
  printf_green "Installing packages for Mint                 "
  printf_green "============================================="
  for pkg in ${DEB_PACKAGE_NAME} ${GLOBAL_PACKAGES}; do
    sudo apt-get install -yy $pkg &>/dev/null && exitCode+=0 || exitCode+=1
  done
elif cat /etc/*release | grep ^NAME | grep Kali; then
  printf_green "============================================="
  printf_green "Installing packages for KaliLinux            "
  printf_green "============================================="
  for pkg in ${DEB_PACKAGE_NAME} ${GLOBAL_PACKAGES}; do
    sudo apt-get install -yy $pkg &>/dev/null && exitCode+=0 || exitCode+=1
  done
elif cat /etc/*release | grep ^NAME | grep Parrot; then
  printf_green "============================================="
  printf_green "Installing packages for Parrot OS            "
  printf_green "============================================="
  for pkg in ${DEB_PACKAGE_NAME} ${GLOBAL_PACKAGES}; do
    sudo apt-get install -yy $pkg &>/dev/null && exitCode+=0 || exitCode+=1
  done
elif cat /etc/*release | grep ^NAME | grep Knoppix; then
  printf_green "============================================="
  printf_green "Installing packages for Knoppix              "
  printf_green "============================================="
  for pkg in ${YUM_PACKAGE_NAME} ${GLOBAL_PACKAGES}; do
    sudo yum install -y $pkg &>/dev/null && exitCode+=0 || exitCode+=1
  done
elif cat /etc/*release | grep ^NAME | grep -E 'Arch|Arco|Manjaro'; then
  printf_green "============================================="
  printf_green "Installing packages for Arch                 "
  printf_green "============================================="
  for pkg in ${PAC_PACKAGE_NAME} ${GLOBAL_PACKAGES}; do
    sudo pacman -Syyu --noconfirm --needed $pkg &>/dev/null && exitCode+=0 || exitCode+=1
  done
else
  printf_red "OS NOT DETECTED, couldn't install packages "
  exit 1
fi
printf_green "============================================="
printf_green "Installing python packages                   "
printf_green "============================================="
for pip in $REQ_PIP_PACKAGE_NAME; do
  { sudo python3 -m pip install $pip &>/dev/null ||
    sudo python2 -m pip install $pip &>/dev/null ||
    sudo python -m pip install $pip &>/dev/null; } && exitCode+=0 || exitCode+=1
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
printf_green "============================================="
printf_green "Installing gem packages                      "
printf_green "============================================="
for gem in $REQ_GEM_PACKAGE_NAME; do
  sudo gem install $gem &>/dev/null && exitCode+=0 || exitCode+=1
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
printf_green "============================================="
printf_green "Installing lua packages                      "
printf_green "============================================="
for lua in $REQ_LUA_PACKAGE_NAME; do
  sudo luarocks install $lua &>/dev/null && exitCode+=0 || exitCode+=1
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
printf_green "============================================="
printf_green "Installing go packages                       "
printf_green "============================================="
for go in $REQ_GO_PACKAGE_NAME; do
  go get -u $go &>/dev/null && exitCode+=0 || exitCode+=1
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
printf_green "============================================="
printf_green "Installation has completed                   "
printf_green "============================================="
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
