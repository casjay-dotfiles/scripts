# list options
__list_options() {
  printf_color "$1: " "$5"
  echo -ne "$2" | sed 's|:||g;s/'$3'/ '$4'/g' | tr '\n' ' '
  printf_newline
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# create the config file
__gen_config() {
  local NOTIFY_CLIENT_NAME="$APPNAME"
  if [ "$INIT_CONFIG" != "TRUE" ]; then
    printf_blue "Generating the config file in"
    printf_cyan "$RMD_CONFIG_DIR/$RMD_CONFIG_FILE"
  fi
  [ -d "$RMD_CONFIG_DIR" ] || mkdir -p "$RMD_CONFIG_DIR"
  [ -d "$RMD_CONFIG_BACKUP_DIR" ] || mkdir -p "$RMD_CONFIG_BACKUP_DIR"
  [ -f "$RMD_CONFIG_DIR/$RMD_CONFIG_FILE" ] &&
    cp -Rf "$RMD_CONFIG_DIR/$RMD_CONFIG_FILE" "$RMD_CONFIG_BACKUP_DIR/$RMD_CONFIG_FILE.$$"
  cat <<EOF >"$RMD_CONFIG_DIR/$RMD_CONFIG_FILE"
# Settings for rmd

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
RMD_OUTPUT_COLOR_1="${RMD_OUTPUT_COLOR_1:-}"
RMD_OUTPUT_COLOR_2="${RMD_OUTPUT_COLOR_2:-}"
RMD_OUTPUT_COLOR_GOOD="${RMD_OUTPUT_COLOR_GOOD:-}"
RMD_OUTPUT_COLOR_ERROR="${RMD_OUTPUT_COLOR_ERROR:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
RMD_NOTIFY_ENABLED="${RMD_NOTIFY_ENABLED:-}"
RMD_GOOD_NAME="${RMD_GOOD_NAME:-}"
RMD_ERROR_NAME="${RMD_ERROR_NAME:-}"
RMD_GOOD_MESSAGE="${RMD_GOOD_MESSAGE:-}"
RMD_ERROR_MESSAGE="${RMD_ERROR_MESSAGE:-}"
RMD_NOTIFY_CLIENT_NAME="${RMD_NOTIFY_CLIENT_NAME:-}"
RMD_NOTIFY_CLIENT_ICON="${RMD_NOTIFY_CLIENT_ICON:-}"
RMD_NOTIFY_CLIENT_URGENCY="${RMD_NOTIFY_CLIENT_URGENCY:-}"

EOF
  if builtin type -t __gen_config_local | grep -q 'function'; then __gen_config_local; fi
  if [ -f "$RMD_CONFIG_DIR/$RMD_CONFIG_FILE" ]; then
    [ "$INIT_CONFIG" = "TRUE" ] || printf_green "Your config file for $APPNAME has been created"
    . "$RMD_CONFIG_DIR/$RMD_CONFIG_FILE"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Help function - Align to 50
__help() {
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "rmd: remove files and directories recursively - $VERSION"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Usage: rmd [options] [paths...]"
  __printf_line ""
  __printf_line "Removes files and directories recursively with safety guards."
  __printf_line ""
  __printf_line "Paths may be passed as positional args, piped on stdin, or"
  __printf_line "single-quoted with glob meta chars for the script to expand:"
  __printf_line "  rmd file1 file2"
  __printf_line "  rmd '~/Test/*.log'           # script expands tilde + glob"
  __printf_line "  find . -name '*.bak' | rmd --yes"
  __printf_line "  ls /tmp/junk | rmd --yes"
  __printf_line ""
  __printf_line "Quoted-glob and stdin both avoid the kernel ARG_MAX limit you"
  __printf_line "would hit with an unquoted wildcard expanding to many paths."
  __printf_line ""
  __printf_line "--force                         - Override soft system-wildcard blocks"
  __printf_line "--yes                           - Skip the 2 second cancel delay"
  __printf_line "--dir <path>                    - Sets the working directory"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Safety Guards"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Always blocked, even with --force:"
  __printf_line "  /                             - root filesystem"
  __printf_line "  /etc, /bin, /usr/bin, \$HOME   - protected parent directories"
  __printf_line "  /etc/passwd*, /etc/group*,    - system identity files"
  __printf_line "  /etc/shadow*, /etc/gshadow*"
  __printf_line ""
  __printf_line "When asked to delete '/' from a tty, you'll be prompted whether"
  __printf_line "you meant the current directory (\$PWD). Non-interactive callers"
  __printf_line "are refused outright."
  __printf_line ""
  __printf_line "Specific named paths under protected parents are allowed, e.g."
  __printf_line "/etc/myfile.bak, /etc/nginx/*, ~/MyDir, ~/Test/*"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "--help                          - Shows this message"
  __printf_line "--config                        - Generate user config file"
  __printf_line "--version                       - Show script version"
  __printf_line "--options                       - Shows all available options"
  __printf_line "--debug                         - Enables script debugging"
  __printf_line "--raw                           - Removes all formatting on output"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# check if arg is a builtin option
__is_an_option() { if [[ "$ARRAY" == *"${1:-^}"* ]]; then return 1; else return 0; fi; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  if { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; }; then return 1; else return 0; fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -sh "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$RMD_REQUIRE_SUDO" = "yes" ] && [ -z "$RMD_REQUIRE_SUDO_RUN" ]; then
    export RMD_REQUIRE_SUDO="no"
    export RMD_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "${SUDO##*/}" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-0}
  [ -f "$RMD_TEMP_FILE" ] && rm -Rf "$RMD_TEMP_FILE" &>/dev/null
  #unset CASJAYSDEV_TITLE_SET && printf '\033]2│;%s\033\\' "${USER}@${HOSTNAME}:${PWD/#$HOME/~} - ${CASJAYSDEV_TITLE_PREV:-$SHELL}"
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Resolve to a canonical absolute path even if the target doesn't exist.
# realpath -m + readlink -f + raw arg fallback covers the busybox/coreutils
# variation we run into in production.
__rmd_resolve() {
  local in="$1" out
  out="$(realpath -m -- "$in" 2>/dev/null)"
  [ -n "$out" ] && { printf '%s' "$out"; return 0; }
  out="$(readlink -f -- "$in" 2>/dev/null)"
  [ -n "$out" ] && { printf '%s' "$out"; return 0; }
  printf '%s' "$in"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Hard-block: protected parent directories that may never be deleted as a
# whole, ever, even with --force. Children (e.g. /etc/nginx/foo) are NOT
# matched here.
__rmd_is_hard_blocked_dir() {
  local p="$1"
  case "$p" in
    /etc | /bin | /usr/bin) return 0 ;;
  esac
  if [ -n "$HOME" ] && [ "$p" = "$HOME" ]; then
    return 0
  fi
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Hard-block: system identity files. Matches /etc/passwd*, /etc/group*,
# /etc/shadow*, /etc/gshadow* exactly (parent must be /etc, not a
# sub-directory like /etc/old/passwd).
__rmd_is_identity_file() {
  local p="$1" parent base
  parent="${p%/*}"
  base="${p##*/}"
  [ "$parent" = "/etc" ] || return 1
  case "$base" in
    passwd* | group* | shadow* | gshadow*) return 0 ;;
  esac
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Other system dirs to refuse by default. These are still soft-ish — we
# refuse the directory itself, but specific files inside are allowed.
__rmd_is_protected_system_dir() {
  case "$1" in
    / | /home | /tmp | /usr | /etc | /var | /bin | /sbin | /lib | /lib64 | /boot | /sys | /proc | /dev) return 0 ;;
  esac
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Handle a request to delete '/' itself. Always refuses the literal '/'
# delete (even with --force). Interactive callers (tty on stdin and
# stdout) get prompted "did you mean $PWD?" — answering yes prints the
# replacement path on stdout for the caller to substitute in. Anything
# non-interactive prints a hint and returns 1.
__rmd_handle_root_request() {
  local pwd_now="${PWD:-$(pwd 2>/dev/null)}"
  printf_red "SECURITY: refusing to delete '/' (always blocked, even with --force)" >&2
  if [ -t 0 ] && [ -t 1 ] && [ -n "$pwd_now" ] && [ "$pwd_now" != "/" ]; then
    printf_yellow "Did you mean the current directory: $pwd_now ?" >&2
    printf "[y/N]: " >&2
    local answer=""
    read -r answer
    case "$answer" in
      [Yy] | [Yy][Ee][Ss])
        printf_cyan "Targeting $pwd_now instead..." >&2
        printf '%s' "$pwd_now"
        return 0
        ;;
    esac
    printf_yellow "Aborted" >&2
    return 1
  fi
  printf_yellow "If you meant the current directory, run: rmd \"\$PWD\"" >&2
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Expand a single argument: leading ~ -> $HOME, then glob ('*?[' meta
# chars). Lets users single-quote patterns the shell would otherwise
# eat: rmd '~/Test/*' or rmd '/var/log/*.gz'. This also avoids the
# kernel ARG_MAX limit because the script never receives the expanded
# list as argv -- the expansion happens after exec.
# Output: one expanded path per line on stdout, nothing if the pattern
# matched no files.
__rmd_expand_arg() {
  local pat="$1"
  case "$pat" in
    "~") pat="$HOME" ;;
    "~/"*) pat="${HOME}${pat#\~}" ;;
  esac
  case "$pat" in
    *"*"* | *"?"* | *"["*) ;;
    *)
      printf '%s\n' "$pat"
      return 0
      ;;
  esac
  local oldnull oldfail
  oldnull="$(shopt -p nullglob 2>/dev/null)"
  oldfail="$(shopt -p failglob 2>/dev/null)"
  shopt -s nullglob
  shopt -u failglob
  local -a matches
  # shellcheck disable=SC2206
  matches=( $pat )
  eval "$oldnull"
  eval "$oldfail"
  if [ "${#matches[@]}" -eq 0 ]; then
    return 0
  fi
  printf '%s\n' "${matches[@]}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__test_dir() {
  local tmp="${TMP:-$HOME/.local/tmp}"
  local original_arg="$1"
  local dir
  dir="$(__rmd_resolve "$1")"

  # --- HARD BLOCKS (always refuse, even with --force) ---
  # Caller is expected to have already routed literal '/' through
  # __rmd_handle_root_request before calling us; if it slips through,
  # refuse here too as a backstop.
  if [ "$dir" = "/" ] || [ "$original_arg" = "/" ] || [ "$original_arg" = "/*" ]; then
    printf_red "SECURITY: refusing to delete root '/' (always blocked, even with --force)"
    return 1
  fi
  if __rmd_is_identity_file "$dir"; then
    printf_red "SECURITY: refusing to delete system identity file: $dir (always blocked, even with --force)"
    return 1
  fi
  if __rmd_is_hard_blocked_dir "$dir"; then
    printf_red "SECURITY: refusing to delete protected directory: $dir (always blocked, even with --force)"
    return 1
  fi

  # --- SOFT BLOCKS (refuse by default, --force overrides where noted) ---
  # Other system dirs themselves (children are still allowed).
  if __rmd_is_protected_system_dir "$dir"; then
    printf_red "SECURITY: Refusing to delete protected directory: $dir"
    return 1
  fi

  # Literal wildcards in the un-expanded arg under system paths. Useful
  # when the arg arrives quoted (e.g. via a script wrapper).
  if [[ "$original_arg" == *"*"* ]]; then
    if [[ "$original_arg" == /bin/* ]] || [[ "$original_arg" == /sbin/* ]] ||
      [[ "$original_arg" == /usr/* ]] || [[ "$original_arg" == /etc/* ]] ||
      [[ "$original_arg" == /var/* ]] || [[ "$original_arg" == /lib/* ]] ||
      [[ "$original_arg" == /lib64/* ]] || [[ "$original_arg" == /boot/* ]] ||
      [[ "$original_arg" == /sys/* ]] || [[ "$original_arg" == /proc/* ]] ||
      [[ "$original_arg" == /dev/* ]] || [[ "$original_arg" == /home/* ]]; then
      if [ "$RMD_FORCE" != "true" ]; then
        printf_red "SECURITY: Refusing to delete with wildcard in system directory: $original_arg (use --force to override)"
        return 1
      fi
    fi
  fi

  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__rm_file() {
  local rmexitCode=0
  if [ -w "${1:-$file}" ]; then
    rm -Rf "${1:-$file}" &>/dev/null || rmexitCode=$(($rmexitCode + 1))
  else
    printf_red "You don't have permission to remove ${1:-$file}"
    rmexitCode=$(($rmexitCode + 1))
  fi
  return $rmexitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__rmd_delete_one() {
  local file="$1"
  if [ -d "$file" ]; then
    printf_green "Deleting folder and all files within: $file - this is unsafe "
    [ -z "$RMD_SLEEP_TIMEOUT" ] && sleep 2
    __rm_file "$file"
    return $?
  elif [ -L "$file" ]; then
    printf_green "Unlinking the file: $file"
    unlink "$file" &>/dev/null
    return $?
  elif [ -e "$file" ]; then
    printf_green "Deleting the file: $file"
    __rm_file "$file" &>/dev/null
    return $?
  else
    printf_red "Failed to delete non-existent file/folder: $file"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Validate a single literal arg (pre-expansion) and process it. Handles
# the '/' prompt, runs __test_dir against the literal (so soft-wildcard
# blocks like /etc/* still fire), then expands tilde+glob and validates
# each expanded path before delegating to __rmd_delete_one. Returns the
# count of failures.
__rmd_process_one() {
  local raw="$1"
  local fail=0

  # Strip dangling -* options that didn't get consumed by getopt
  if [[ "$raw" = -* ]] && [ ! -e "$raw" ]; then
    return 0
  fi

  [ -n "$raw" ] || return 0

  case "$raw" in
    "*" | "**")
      printf_red "SECURITY: Refusing dangerous pattern: $raw"
      return 1
      ;;
  esac

  # Literal '/' or '/*' goes through prompt handler. Yes substitutes
  # $PWD; no / non-tty refuses outright.
  if [ "$raw" = "/" ] || [ "$raw" = "/*" ]; then
    local replacement
    if replacement="$(__rmd_handle_root_request)" && [ -n "$replacement" ]; then
      raw="$replacement"
    else
      return 1
    fi
  fi

  # Pre-expansion check: catches /etc/* style soft blocks while the
  # glob meta chars are still in the literal.
  if ! __test_dir "$raw"; then
    return 1
  fi

  # Now expand tilde + glob. Output is one path per line; empty if the
  # pattern matched nothing.
  local -a expanded
  mapfile -t expanded < <(__rmd_expand_arg "$raw")

  if [ "${#expanded[@]}" -eq 0 ]; then
    printf_red "No files matched pattern: $raw"
    return 1
  fi

  local item
  for item in "${expanded[@]}"; do
    [ -n "$item" ] || continue
    if ! __test_dir "$item"; then
      fail=$((fail + 1))
      continue
    fi
    if ! __rmd_delete_one "$item"; then
      fail=$((fail + 1))
    fi
    # Confirm deletion actually occurred (parity with the original logic
    # which checked -e after the rm).
    [ -e "$item" ] && fail=$((fail + 1)) || true
  done
  return $fail
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__execute_rmd() {
  local exitCode=0
  local -a inputs=()

  if [ $# -gt 0 ]; then
    inputs=("$@")
  fi

  # Read paths from stdin when stdin is not a tty (find . | rmd, or
  # rmd < paths.txt). Merges with positional args; user picked the
  # "always merge args + stdin if non-tty" policy.
  if [ ! -t 0 ]; then
    local line
    while IFS= read -r line; do
      [ -n "$line" ] && inputs+=("$line")
    done
  fi

  if [ "${#inputs[@]}" -eq 0 ]; then
    printf_red "Must provide path to file or folder for deletion (positional or via stdin)"
    return 1
  fi

  local raw rc
  for raw in "${inputs[@]}"; do
    __rmd_process_one "$raw"
    rc=$?
    exitCode=$((exitCode + rc))
  done
  return ${exitCode:-0}
}
