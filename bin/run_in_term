#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : run_in_term --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : run_in_term
# @Description   : Keep a terminal app running
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# -eq 0 ]; } && { myterminal -e "$APPNAME" && exit || exit 1; }
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$RUN_IN_TERM_TEMP_FILE" ] && [ -f "$RUN_IN_TERM_TEMP_FILE" ] && rm -Rf "$RUN_IN_TERM_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$RUN_IN_TERM_CONFIG_DIR/$RUN_IN_TERM_CONFIG_FILE"
  [ -d "$RUN_IN_TERM_CONFIG_DIR" ] || mkdir -p "$RUN_IN_TERM_CONFIG_DIR"
  [ -d "$RUN_IN_TERM_CONFIG_BACKUP_DIR" ] || mkdir -p "$RUN_IN_TERM_CONFIG_BACKUP_DIR"
  [ -f "$RUN_IN_TERM_CONFIG_DIR/$RUN_IN_TERM_CONFIG_FILE" ] &&
    cp -Rf "$RUN_IN_TERM_CONFIG_DIR/$RUN_IN_TERM_CONFIG_FILE" "$RUN_IN_TERM_CONFIG_BACKUP_DIR/$RUN_IN_TERM_CONFIG_FILE.$$"
  cat <<EOF >"$RUN_IN_TERM_CONFIG_DIR/$RUN_IN_TERM_CONFIG_FILE"
# Settings for run_in_term

# Notification settings
RUN_IN_TERM_GOOD_MESSAGE="${RUN_IN_TERM_GOOD_MESSAGE:-Everything Went OK}"
RUN_IN_TERM_ERROR_MESSAGE="${RUN_IN_TERM_ERROR_MESSAGE:-Well something seems to have gone wrong}"
RUN_IN_TERM_NOTIFY_ENABLED="${RUN_IN_TERM_NOTIFY_ENABLED:-yes}"
RUN_IN_TERM_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
RUN_IN_TERM_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$RUN_IN_TERM_NOTIFY_CLIENT_ICON}"

# Colorization settings
RUN_IN_TERM_OUTPUT_COLOR="${RUN_IN_TERM_OUTPUT_COLOR:-5}"
RUN_IN_TERM_OUTPUT_COLOR_GOOD="${RUN_IN_TERM_OUTPUT_COLOR_GOOD:-2}"
RUN_IN_TERM_OUTPUT_COLOR_ERROR="${RUN_IN_TERM_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$RUN_IN_TERM_CONFIG_DIR/$RUN_IN_TERM_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for run_in_term has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      exit 1
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__check_cmd() {
  local CMD="$1" && shift 1
  local ARG="$*" && shift $#
  if cmd_exists $CMD; then
    $CMD ${ARG:-} 2>/dev/null
  else
    printf_exit "1" "1" "$CMD does not exist"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
RUN_IN_TERM_LOG_DIR="${RUN_IN_TERM_LOG_DIR:-$HOME/.local/log/run_in_term}"
RUN_IN_TERM_CACHE_DIR="${RUN_IN_TERM_CACHE_DIR:-$HOME/.cache/run_in_term}"
RUN_IN_TERM_CONFIG_DIR="${RUN_IN_TERM_CONFIG_DIR:-$HOME/.config/myscripts/run_in_term}"
RUN_IN_TERM_CONFIG_BACKUP_DIR="${RUN_IN_TERM_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/run_in_term/backups}"
RUN_IN_TERM_TEMP_DIR="${RUN_IN_TERM_TEMP_DIR:-$HOME/.local/tmp/system_scripts/run_in_term}"
RUN_IN_TERM_OPTIONS_DIR="${RUN_IN_TERM_OPTIONS_DIR:-$HOME/.local/share/myscripts/run_in_term/options}"
RUN_IN_TERM_TEMP_FILE="${RUN_IN_TERM_TEMP_FILE:-$(mktemp $RUN_IN_TERM_TEMP_DIR/XXXXXX 2>/dev/null)}"
RUN_IN_TERM_CONFIG_FILE="${RUN_IN_TERM_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
RUN_IN_TERM_OUTPUT_COLOR="${RUN_IN_TERM_OUTPUT_COLOR:-4}"
RUN_IN_TERM_OUTPUT_COLOR_2="${RUN_IN_TERM_OUTPUT_COLOR:-6}"
RUN_IN_TERM_OUTPUT_COLOR_GOOD="${RUN_IN_TERM_OUTPUT_COLOR_GOOD:-2}"
RUN_IN_TERM_OUTPUT_COLOR_ERROR="${RUN_IN_TERM_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
RUN_IN_TERM_GOOD_MESSAGE="${RUN_IN_TERM_GOOD_MESSAGE:-Everything Went OK}"
RUN_IN_TERM_ERROR_MESSAGE="${RUN_IN_TERM_ERROR_MESSAGE:-Well something seems to have gone wrong}"
RUN_IN_TERM_NOTIFY_ENABLED="${RUN_IN_TERM_NOTIFY_ENABLED:-yes}"
RUN_IN_TERM_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
RUN_IN_TERM_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$RUN_IN_TERM_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$RUN_IN_TERM_CONFIG_DIR/$RUN_IN_TERM_CONFIG_FILE" ] && . "$RUN_IN_TERM_CONFIG_DIR/$RUN_IN_TERM_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$RUN_IN_TERM_LOG_DIR" ] || mkdir -p "$RUN_IN_TERM_LOG_DIR" &>/dev/null
[ -d "$RUN_IN_TERM_TEMP_DIR" ] || mkdir -p "$RUN_IN_TERM_TEMP_DIR" &>/dev/null
[ -d "$RUN_IN_TERM_CACHE_DIR" ] || mkdir -p "$RUN_IN_TERM_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$RUN_IN_TERM_CONFIG_DIR/$RUN_IN_TERM_CONFIG_FILE" ] || [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    RUN_IN_TERM_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$RUN_IN_TERM_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${RUN_IN_TERM_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${RUN_IN_TERM_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${RUN_IN_TERM_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${RUN_IN_TERM_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ -n "$1" ]; then
  CMD="$1" && shift 1
  ARG="$*" && shift $#
  eval $CMD "$ARG"
else
  printf_newline "\n\n\n"
  printf_read_input "2" "What command would you like to run [!q to exit]?" "120" "CMD" '-e'
  printf_red "Type exit or ctrl + c to exit"
  printf_cyan "Usage: Enter the commands for $CMD"
  printf_cyan "To show this message again type: _help_"
  while :; do
    printf_read_input "5" "What would you like to pass to $CMD?" "120" "__ANSWER" '-e'
    if [ "$__ANSWER" = exit ] || [ "$__ANSWER" = quit ] || [ "$__ANSWER" = !q ]; then
      clear && break
    fi
    if [ "$__ANSWER" = _help_ ]; then
      clear
      printf_cyan "Usage: Enter the commands for $CMD or type exit to quit"
      continue
    fi
    clear
    printf_newline "\n\n\n"
    __check_cmd $CMD "$__ANSWER"
    printf_newline "\n"
  done
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
