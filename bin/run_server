#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : run_server --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : run_server
# @Description   : Start an HTTP server from a directory
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__exit() {
  local pid="$1"
  trap 'trap - INT
  kill -s INT "$pid"
  [[ -f "$RUN_SERVER_LOG_DIR/$pid" ]] && rm -Rf "$RUN_SERVER_LOG_DIR/$pid"
  true
' INT
  printf_red "Killing the server with pid: $pid"
  exit 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$RUN_SERVER_CONFIG_DIR/$RUN_SERVER_CONFIG_FILE"
  [ -d "$RUN_SERVER_CONFIG_DIR" ] || mkdir -p "$RUN_SERVER_CONFIG_DIR"
  [ -d "$RUN_SERVER_CONFIG_BACKUP_DIR" ] || mkdir -p "$RUN_SERVER_CONFIG_BACKUP_DIR"
  [ -f "$RUN_SERVER_CONFIG_DIR/$RUN_SERVER_CONFIG_FILE" ] &&
    cp -Rf "$RUN_SERVER_CONFIG_DIR/$RUN_SERVER_CONFIG_FILE" "$RUN_SERVER_CONFIG_BACKUP_DIR/$RUN_SERVER_CONFIG_FILE.$$"
  cat <<EOF >"$RUN_SERVER_CONFIG_DIR/$RUN_SERVER_CONFIG_FILE"
# Settings for run_server
RUN_SERVER_DEFAULT_DIR="${RUN_SERVER_DEFAULT_DIR:-$HOME/Public/www}"
RUN_SERVER_DEFAULT_PORT="${RUN_SERVER_DEFAULT_PORT:-19922}"
RUN_SERVER_BROWSER="${RUN_SERVER_BROWSER:-mybrowser}"
RUN_SERVER_BROWSER_ARGS="${RUN_SERVER_BROWSER_ARGS:-}"

# Notification settings
RUN_SERVER_GOOD_MESSAGE="${RUN_SERVER_GOOD_MESSAGE:-Everything Went OK}"
RUN_SERVER_ERROR_MESSAGE="${RUN_SERVER_ERROR_MESSAGE:-Well something seems to have gone wrong}"
RUN_SERVER_NOTIFY_ENABLED="${RUN_SERVER_NOTIFY_ENABLED:-yes}"
RUN_SERVER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
RUN_SERVER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$RUN_SERVER_NOTIFY_CLIENT_ICON}"

# Colorization settings
RUN_SERVER_OUTPUT_COLOR="${RUN_SERVER_OUTPUT_COLOR:-5}"
RUN_SERVER_OUTPUT_COLOR_GOOD="${RUN_SERVER_OUTPUT_COLOR_GOOD:-2}"
RUN_SERVER_OUTPUT_COLOR_ERROR="${RUN_SERVER_OUTPUT_COLOR_ERROR:-1}"

EOF
  [[ -f "$HOME/.config/screen/dev/runserverc" ]] || screen_config >"$HOME/.config/screen/dev/runserverc"
  if [ -f "$RUN_SERVER_CONFIG_DIR/$RUN_SERVER_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__main__() {
  mainPid="$$"
  trap '__exit $mainPid' INT
  RUN_SERVER_PORT="${RUN_SERVER_PORT:-$RUN_SERVER_DEFAULT_PORT}"
  MAX_NUMBER_OF_TRIES=${MAX_NUMBER_OF_TRIES:-20}
  RUN_SERVER_TEMP_DIR="${RUN_SERVER_TEMP_DIR:-/tmp}"
  i=0
  # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  printf_yellow "Attempting to start on: $port"
  echo "$RUN_SERVER_PORT" >"$RUN_SERVER_LOG_DIR/$mainPid"
  printf '%s\n' "Starting the server on port $RUN_SERVER_PORT" &>"$RUN_SERVER_LOG"
  export RUN_SERVER_DIR RUN_SERVER_URL RUN_SERVER_PORT
  while [ $i -lt $MAX_NUMBER_OF_TRIES ]; do
    if __port_used "$RUN_SERVER_PORT" || __lsof; then
      sleep 1
      open_url "$RUN_SERVER_URL"
      BROWSER_PID="$!"
      trap 'kill -9 $BROWSER_PID &>/dev/null || exit 0' EXIT
      i=$MAX_NUMBER_OF_TRIES
      break
    fi
    i=$((i + 1))
    sleep 5
  done &
  printf_purple "serving files from $RUN_SERVER_CWD with pid: $$"
  printf_blue "Log file: $RUN_SERVER_LOG"
  printf_yellow "Access from the network: http://$RUN_SERVER_ADDR:$RUN_SERVER_PORT"
  open_filemanager "$RUN_SERVER_CWD"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__return_error() { printf '%s\n' "Failed to start server" &>>"$RUN_SERVER_LOG" && printf_exit 1 1 "Failed to start the server"; }
__lsof() { lsof -i -nP | grep "${1:-$RUN_SERVER_PORT}" | grep -v 'grep' | grep -i "${prog:-python2}" | grep -q '^' && return 0 || return 1; }
__netcat_serv() { while true; do nc -l "$RUN_SERVER_PORT" <.; done &>>"$RUN_SERVER_LOG" && echo netcat started &>>"$RUN_SERVER_LOG" || return 1; }
__port_used() { sleep 5 && sudo netstat -tauln 2>/dev/null | grep 'LISTEN' | grep ":${1:-$RUN_SERVER_PORT}" | grep -q '^' && return 0 || return 1; }
__port_free() { sleep 5 && sudo netstat -tauln 2>/dev/null | grep 'LISTEN' | grep ":${1:-$RUN_SERVER_PORT}" | grep -q '^' && return 1 || return 0; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__go() {
  cmd_exists gohttpserver && cd "$RUN_SERVER_CWD" &&
    gohttpserver --theme dark --port $RUN_SERVER_PORT --title="Dev Server" -r "." --xheaders --cors &>>"$RUN_SERVER_LOG" &&
    echo gohttpserver started &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__caddy() {
  cmd_exists caddy && cd "$RUN_SERVER_CWD" &&
    caddy file-server -browse -listen :$RUN_SERVER_PORT -root "." -templates &>>"$RUN_SERVER_LOG" &&
    echo caddy started &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__proxy() {
  cmd_exists caddy && cd "$RUN_SERVER_CWD" &&
    caddy reverse-proxy -to 127.0.0.1:${port:-3000} -from :${other_port:-20000} &>>"$RUN_SERVER_LOG" &&
    echo caddy started &>>"$RUN_SERVER_LOG" && other_port="${other_port:-20000}" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__jekyll() {
  cmd_exists jekyll && cd "$RUN_SERVER_CWD" &&
    jekyll serve -P $RUN_SERVER_PORT -l -H 0.0.0.0 &>>"$RUN_SERVER_LOG" &&
    echo jekyll started &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__js_serv() {
  cmd_exists http-server && cd "$RUN_SERVER_CWD" &&
    http-server -a 0.0.0.0 -p $RUN_SERVER_PORT &>>"$RUN_SERVER_LOG" &&
    echo http-server started &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__php_serv() {
  cmd_exists php && cd "$RUN_SERVER_CWD" &&
    php -S 0.0.0.0:$RUN_SERVER_PORT &>>"$RUN_SERVER_LOG" &&
    echo php started &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__ruby_serv() {
  cmd_exists ruby && cd "$RUN_SERVER_CWD" &&
    ruby -run -ehttpd -p $RUN_SERVER_PORT &>>"$RUN_SERVER_LOG" &&
    echo ruby started &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__rails_serv() {
  cmd_exists rails && cd "$RUN_SERVER_CWD" &&
    server -p "$RUN_SERVER_PORT" &>>"$RUN_SERVER_LOG" &&
    echo ruby started &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__python3_serv() {
  cmd_exists python3 && cd "$RUN_SERVER_CWD" &&
    python3 -m http.server --cgi --bind "$RUN_SERVER_ADDR" "$RUN_SERVER_PORT" &>>"$RUN_SERVER_LOG" &&
    echo Py3 started &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__python2_serv() {
  cmd_exists python2 && cd "$RUN_SERVER_CWD" &&
    python2 -m http.server --cgi --bind "$RUN_SERVER_ADDR" "$RUN_SERVER_PORT" &>>"$RUN_SERVER_LOG" &&
    echo Py2 started &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__py_simple() {
  cmd_exists python && cd "$RUN_SERVER_CWD" &&
    python -m SimpleHTTPServer "$RUN_SERVER_PORT" &>>"$RUN_SERVER_LOG" &&
    echo "Py simple start" &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__default_srv() {
  cmd_exists python2 && cd "$RUN_SERVER_CWD" &&
    python2 -c $'import SimpleHTTPServer;\nmap = SimpleHTTPServer.SimpleHTTPRequestHandler.extensions_map;\nmap[""] = "text/plain";\nfor key, value in map.items():\n\tmap[key] = value + ";charset=UTF-8";\nSimpleHTTPServer.test();' "$RUN_SERVER_PORT" &>>"$RUN_SERVER_LOG" &&
    echo "Default has started" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__netcat_serv() {
  cd "$RUN_SERVER_CWD" && while true; do nc -l "$RUN_SERVER_PORT" <.; done &>>"$RUN_SERVER_LOG" && echo netcat started &>>"$RUN_SERVER_LOG" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__static() { __go || __caddy || __php_serv || __default_srv || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
open_url() {
  local PATH="$SRC_DIR:$PATH"
  [ -n "$SSH_CONNECTION" ] && return
  [[ -n "$RUN_SERVER_BROWSER_ARGS" ]] || RUN_SERVER_BROWSER_ARGS="--private"
  if cmd_exists mybrowser; then
    OPEN_WEB="mybrowser $RUN_SERVER_BROWSER_ARGS $1"
  elif cmd_exists "xdg-open"; then
    OPEN_WEB="xdg-open $1"
  elif cmd_exists "open"; then
    OPEN_WEB="open $1"
  fi
  printf_purple "Launching: $OPEN_WEB"
  $OPEN_WEB
  printf_red "control-c to exit"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
open_filemanager() {
  local PATH="$SRC_DIR:$PATH"
  if [ -n "$SSH_CONNECTION" ]; then
    { cmd_exists vim && OPEN_FM="vim"; } ||
      { cmd_exists vifm && OPEN_FM="vifm"; } ||
      { cmd_exists ranger && OPEN_FM="ranger"; } ||
      { cmd_exists se && cd "$1" && OPEN_FM="se"; }
  elif cmd_exists myfilemanager; then
    OPEN_FM="myfilemanager $1"
  elif cmd_exists "xdg-open"; then
    OPEN_FM="xdg-open $1"
  elif cmd_exists "open"; then
    OPEN_FM="open $1"
  fi
  printf_purple "Launching: $OPEN_FM"
  $OPEN_FM
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__prog_check() {
  cmd_exists --error "${1:-$prog}" || {
    clear
    printf_newline '\n\n\n'
    printf_red "Error: ${1:-$prog} is not installed\n"
    return 1
  }
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__set_vars() {
  local ORIG_PORT="${1:-$RUN_SERVER_DEFAULT_PORT}"
  local port="${1:-$RUN_SERVER_DEFAULT_PORT}"
  local set_port="${1:-$RUN_SERVER_DEFAULT_PORT}"
  local i=0
  if __port_used $port; then
    printf_red "Something appears to be running on port ${other_port:-$port}"
    printf_yellow "Attempting the next port: $((port + 1))"
    while :; do
      __port_free $port && break || set_port="$((port + 1)) "
      sleep .5
    done
  fi
  RUN_SERVER_PORT="$port"
  RUN_SERVER_HOST="$(__gethostname)"
  RUN_SERVER_ADDR="$(__getlipaddr && echo "$CURRIP4" || echo '127.0.0.1')"
  RUN_SERVER_CWD="$(realpath "${RUN_SERVER_CWD:-$PWD}" || dirname "${RUN_SERVER_CWD:-$PWD}/.")"
  RUN_SERVER_LOG="${RUN_SERVER_LOG:-$RUN_SERVER_TEMP_DIR/run_server_$RUN_SERVER_PORT.log}"
  RUN_SERVER_URL="${RUN_SERVER_URL:-http://$RUN_SERVER_ADDR:$RUN_SERVER_PORT}"
  export RUN_SERVER_HOST RUN_SERVER_PORT RUN_SERVER_ADDR RUN_SERVER_CWD RUN_SERVER_URL
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__try_default() {
  __main__ "__default_srv" ||
    __main__ "__python3_serv" ||
    __main__ "__python2_serv" ||
    __main__ "__py_simple" ||
    __main__ "__netcat_serv" ||
    __main__ "__return_error"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
screen_config() {
  printf_blue "Creating screenrc file"
  cat <<EOF | tee "$RUN_SERVER_CONFIG_DIR/runserverc" &>/dev/null
# Sources
# - https://bbs.archlinux.org/viewtopic.php?id=55618&p=3
# - https://bbs.archlinux.org/viewtopic.php?pid=930174#p930174
# search | name for dynamic window titles
shelltitle '$|bash'
# Detect activity in new windows
defmonitor on
# Turn your hardstatus line into a dynamic urxvt|xterm|aterm window title
backtick 1 5 5 true
termcapinfo rxvt* 'hs:ts=\E]2;:fs=\007:ds=\E]2;\007'
# Set the window titles
caption always
caption string "%n %t"
# Set the status bar
hardstatus alwayslastline
hardstatus alwayslastline " %{kb}$LOGNAME %{bk} %H %?%{kb}%{kY} %-Lw%{Yk}%:%{Yb}%{Yk}%?%{Yk} %n%f* %t %{kY}%+Lw %-="
#hardstatus alwayslastline "%{bk} %S %{kb} $LOGNAME %{bk} %H %?%{kb}%{kY} %-Lw%{Yk}%:%{Yb}%{Yk}%?%{Yk} %n%f* %t %{kY}%+Lw %-="
# huge scrollback buffer
defscrollback 5000
# no welcome message
startup_message off
# 256 colors
attrcolor b ".I"
termcapinfo xterm 'Co#256:AB=\E[48;5;%dm:AF=\E[38;5;%dm'
term "screen-256color"
defbce on
# Display notification when bell is detected for a window
bell_msg "Bell detected in %t (%n)!"
activity "Activity detected in %t (%n)!"
# Fix for residual editor text
altscreen on
# print wackier status messages
nethack on
# mouse tracking allows to switch region focus by clicking
mousetrack off
# window numbering starts at 1 not 0
screen -t main     1 bash -c "bash; $SHELL"
screen -t dev      2 bash -c "myeditor --console .; $SHELL"
screen -t web      3 bash -c "mybrowser --console .; $SHELL"
screen -t fm       4 bash -c "myfilemanager --console .; $SHELL"
screen -t serv     9 bash -c "$APPNAME .; $SHELL"
select 1
bind c screen 1
# get rid of silly xoff stuff
bind s split
# layouts
layout autosave on
layout new one
select 1
layout attach one
layout select one
# use hjkl keys to resize regions
bind -c rsz h eval "resize -h -5" "command -c rsz"
bind -c rsz j eval "resize -v -5" "command -c rsz"
bind -c rsz k eval "resize -v +5" "command -c rsz"
bind -c rsz l eval "resize -h +5" "command -c rsz"
# quickly switch between regions using tab and arrows
bind -c rsz \t    eval "focus"       "command -c rsz" # Tab
bind -c rsz -k kl eval "focus left"  "command -c rsz" # Left
bind -c rsz -k kr eval "focus right" "command -c rsz" # Right
bind -c rsz -k ku eval "focus up"    "command -c rsz" # Up
bind -c rsz -k kd eval "focus down"  "command -c rsz" # Down
# re-source screenrc file
#bind r eval "source $HOME/.screenrc" "echo '.screenrc reloaded!'"
# You can use "showkey -a" to capture the key definitions for your terminal.
bindkey "^[OR" prev         # F3 = previous window
bindkey "^[OS" next         # F4 = next window
bindkey "^[[1;2C" next      # shift+right_arrow
bindkey "^[[1;2D" prev      # shift+left_arrow
bindkey "^[[A" focus top    # ctrl+up_arrow = large top area
bindkey "^[[B" focus down   # ctrl+down_arrow = bottom-left area
bindkey "^[[C" focus bottom # ctrl+right_arrow = bottom-right area
bindkey "^[[D" focus left   # ctrl+left_arrow = back to bottom-left area from bottom-right area
# Finally! Shift-pg up or down to view scrollback buffer
bindkey "^[[5;2~" eval "copy" "stuff ^u"
bindkey -m "^[[5;2~" stuff ^u
bindkey -m "^[[6;2~" stuff ^d

EOF
  [[ -f "$RUN_SERVER_CONFIG_DIR/runserverc" ]] &&
    printf_blue "Created: $RUN_SERVER_CONFIG_DIR/runserverc"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
RUN_SERVER_LOG_DIR="${RUN_SERVER_LOG_DIR:-$HOME/.local/log/run_server}"
RUN_SERVER_CACHE_DIR="${RUN_SERVER_CACHE_DIR:-$HOME/.cache/run_server}"
RUN_SERVER_CONFIG_DIR="${RUN_SERVER_CONFIG_DIR:-$HOME/.config/myscripts/run_server}"
RUN_SERVER_CONFIG_BACKUP_DIR="${RUN_SERVER_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/run_server/backups}"
RUN_SERVER_TEMP_DIR="${RUN_SERVER_TEMP_DIR:-$HOME/.local/tmp/system_scripts/run_server}"
RUN_SERVER_OPTIONS_DIR="${RUN_SERVER_OPTIONS_DIR:-$HOME/.local/share/myscripts/run_server/options}"
RUN_SERVER_CONFIG_FILE="${RUN_SERVER_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
RUN_SERVER_OUTPUT_COLOR="${RUN_SERVER_OUTPUT_COLOR:-4}"
RUN_SERVER_OUTPUT_COLOR_2="${RUN_SERVER_OUTPUT_COLOR:-6}"
RUN_SERVER_OUTPUT_COLOR_GOOD="${RUN_SERVER_OUTPUT_COLOR_GOOD:-2}"
RUN_SERVER_OUTPUT_COLOR_ERROR="${RUN_SERVER_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
RUN_SERVER_GOOD_MESSAGE="${RUN_SERVER_GOOD_MESSAGE:-Everything Went OK}"
RUN_SERVER_ERROR_MESSAGE="${RUN_SERVER_ERROR_MESSAGE:-Well something seems to have gone wrong}"
RUN_SERVER_NOTIFY_ENABLED="${RUN_SERVER_NOTIFY_ENABLED:-yes}"
RUN_SERVER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
RUN_SERVER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$RUN_SERVER_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
RUN_SERVER_BROWSER_ARGS="${RUN_SERVER_BROWSER_ARGS:-}"
RUN_SERVER_DEFAULT_DIR="${RUN_SERVER_DEFAULT_DIR:-$HOME/Public/www}"
RUN_SERVER_DEFAULT_PORT="${RUN_SERVER_DEFAULT_PORT:-19922}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$RUN_SERVER_CONFIG_DIR/$RUN_SERVER_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$RUN_SERVER_CONFIG_DIR/$RUN_SERVER_CONFIG_FILE" ] && . "$RUN_SERVER_CONFIG_DIR/$RUN_SERVER_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$RUN_SERVER_LOG_DIR" ] || mkdir -p "$RUN_SERVER_LOG_DIR" &>/dev/null
[ -d "$RUN_SERVER_TEMP_DIR" ] || mkdir -p "$RUN_SERVER_TEMP_DIR" &>/dev/null
[ -d "$RUN_SERVER_CACHE_DIR" ] || mkdir -p "$RUN_SERVER_CACHE_DIR" &>/dev/null
RUN_SERVER_TEMP_FILE="${RUN_SERVER_TEMP_FILE:-$(mktemp $RUN_SERVER_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$RUN_SERVER_TEMP_FILE" ] && [ -f "$RUN_SERVER_TEMP_FILE" ] && rm -Rf "$RUN_SERVER_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$RUN_SERVER_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${RUN_SERVER_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${RUN_SERVER_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${RUN_SERVER_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${RUN_SERVER_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,bg,screen,filemanager,browser"
ARRAY="default,proxy,static,caddy,go,jekyll,js,php,rails,ruby,python2,python3,netcat "

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    screen_config
    exit $?
    ;;
  --dir)
    RUN_SERVER_CWD="$2"
    shift 2
    ;;
  --bg)
    shift 1
    echo "launching background process"
    export RUN_SERVER_LOG="${RUN_SERVER_TEMP_DIR:-/tmp}/run_server_bg.log"
    $APPNAME "$*" &>"$RUN_SERVER_LOG" &
    exit $?
    ;;
  --filemanager)
    shift 1
    open_filemanager
    exit
    ;;
  --browser)
    shift 1
    open_url "${RUN_SERVER_URL:-http://localhost:${SERVER_PORT:-$RUN_SERVER_DEFAULT_PORT}}"
    exit
    ;;
  --screen)
    shift 1
    if [ -z "$SCREEN_SESSION" ]; then
      export SCREEN_SESSION="$APPNAME"
      SCREEN_SHELL="$(builtin type -P screen 2>/dev/null || echo '')"
      screen_config &>/dev/null
    fi
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
clear
printf_newline '\n\n\n'

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash lsof || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -f "$1" ]; then
  RUN_SERVER_CWD="$(dirname "$1")"
  shift 1
elif [ -d "$1" ]; then
  RUN_SERVER_CWD="$1"
  shift 1
else
  RUN_SERVER_CWD="${RUN_SERVER_CWD:-$RUN_SERVER_DEFAULT_DIR}"
fi
RUN_SERVER_CWD="$(realpath "$RUN_SERVER_CWD" 2>/dev/null || echo "$RUN_SERVER_DEFAULT_DIR")"
if [[ "$RUN_SERVER_CWD" == "$HOME" ]]; then
  printf_red "Running this in your HOME directory is not supported"
  printf_yellow "Changing RUN_SERVER_CWD to $RUN_SERVER_DEFAULT_DIR"
  RUN_SERVER_CWD="$RUN_SERVER_DEFAULT_DIR"
  printf_newline '\n\n\n'
fi
[[ -d "$RUN_SERVER_CWD" ]] || mkdir -p "$RUN_SERVER_CWD"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
cd "$RUN_SERVER_CWD" || exit 1
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
static)
  shift 1
  prog="static"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__static $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

proxy)
  shift 1
  prog="caddy"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__proxy $RUN_SERVER_PORT $2" || __return_error
  exit $?
  ;;

caddy)
  shift 1
  prog="caddy"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__caddy $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

go)
  shift 1
  prog="gohttpserver"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__go $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

jekyll)
  shift 1
  prog="jekyll"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__jekyll $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

js)
  shift 1
  prog="http-server"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__js_serv $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

php)
  shift 1
  prog="php"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__php_serv $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

rails)
  shift 1
  prog="ruby"
  __prog_check "$prog"
  __main__ "__rails_serv $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

ruby)
  shift 1
  prog="ruby"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__ruby_serv $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

python2)
  shift 1
  prog="python2"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__python2_serv $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

python3)
  shift 1
  prog="python3"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__python3_serv $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

default)
  shift 1
  prog="python2"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__default_srv $RUN_SERVER_PORT" || __return_error
  exit $?
  ;;

netcat | nc)
  shift 1
  prog="$(basename $(type -P netcat 2>/dev/null || type -P nc 2>/dev/null))"
  __prog_check "$prog"
  __set_vars $1
  __main__ "__netcat_serv" || __return_error
  exit $?
  ;;

*)
  if [[ -n "$SCREEN_SHELL" ]]; then
    exec screen -c "$RUN_SERVER_CONFIG_DIR/runserverc"
  else
    __prog_check "$prog"
    __set_vars $1
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
