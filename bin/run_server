#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#set opts
trap '[ -f "$SERVER_LOG" ] && rm -Rf "$SERVER_LOG" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202103201833-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : run_server --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Saturday, Mar 20, 2021 18:33 EDT
# @File          : run_server
# @Description   : Start an HTTP server from a directory
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# main function
main() {
  i=0
  port="${1:-8000}" && shift 1
  other_port="${1:-}"
  myip=$(__getlipaddr && echo "$CURRIP4")
  myhost="$(hostname -s)"
  MAX_NUMBER_OF_TRIES=${MAX_NUMBER_OF_TRIES:-10}
  TMP_DIR="${TMPDIR:-/tmp}"
  SERVER_LOG="${SERVER_LOG:-$TMPDIR/run_server_${other_port:-$port}.log}"
  # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  if ! __test_server "${other_port:-$port}"; then
    printf_error "Something appears to be running on ${other_port:-$port}"
    printf_yellow "Attempting another port"
    while true; do
      [ -n "$other_port" ] && other_port=$((port + 1)) || port=$((port + 1))
      __test_server "${other_port:-$port}" && break
    done
    export other_port port
  fi
  # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  printf '%s\n' "Starting the server on port ${other_port:-$port}" &>"$SERVER_LOG"
  while [ $i -lt $MAX_NUMBER_OF_TRIES ]; do
    if [ "$(lsof -i -nP | grep "${other_port:-$port}" | grep -i "$prog")" != "" ]; then
      open_url "http://$myip:${other_port:-$port}}/" &>/dev/null
      break
    fi
    i=$((i + 1))
    sleep 5
  done &
  # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  if [ -n "$dir" ] && [ -d "$dir" ]; then
    printf_green "serving files from $dir"
    cd "$dir" || printf_exit "Could not cd into $dir"
  fi
  printf_blue "Log file: $SERVER_LOG"
  printf_yellow "Access from the network: http://$myip:${other_port:-$port}"
  printf_red "control-c to exit"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__test_server() { netstatg "$1" | grep -qi "${prog:-python2}" && return 1 || return 0; }
__return_error() { printf '%s\n' "Failed to start server" &>>"$SERVER_LOG" && printf_exit 1 1 "Failed to start the server"; }
__netcat_serv() { while true; do nc -l "${port}" <.; done &>>"$SERVER_LOG" && echo netcat started &>>"$SERVER_LOG" || return 1; }
__test_server() { netstatg "$1" | grep -qi "${prog:-python2}" && return 1 || return 0; }
__return_error() { printf '%s\n' "Failed to start server" &>>"$SERVER_LOG" && printf_exit 1 1 "Failed to start the server"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__static() { __go || __caddy || return 1; }
__go() { cmd_exists gohttpserver && cd "$dir" && gohttpserver --theme dark --port ${port} --title Dev Server -r "." --xheaders --cors &>>"$SERVER_LOG" && echo gohttpserver started &>>"$SERVER_LOG" || return 1; }
__caddy() { cmd_exists caddy && cd "$dir" && caddy file-server -browse -listen :${port} -root "." -templates &>>"$SERVER_LOG" && echo caddy started &>>"$SERVER_LOG" || return 1; }
__proxy() { cmd_exists caddy && cd "$dir" && caddy reverse-proxy -to 127.0.0.1:${port:-3000} -from :${other_port:-20000} &>>"$SERVER_LOG" && echo caddy started &>>"$SERVER_LOG" && other_port="${other_port:-20000}" || return 1; }
__jekyll() { cmd_exists jekyll && cd "$dir" && jekyll serve -P ${port} -l -H 0.0.0.0 &>>"$SERVER_LOG" && echo jekyll started &>>"$SERVER_LOG" || return 1; }
__js_serv() { cmd_exists http-server && cd "$dir" && http-server -a 0.0.0.0 -p ${port} &>>"$SERVER_LOG" && echo http-server started &>>"$SERVER_LOG" || return 1; }
__php_serv() { cmd_exists php && cd "$dir" && php -S 0.0.0.0:${port} &>>"$SERVER_LOG" && echo php started &>>"$SERVER_LOG" || return 1; }
__ruby_serv() { cmd_exists ruby && cd "$dir" && ruby -run -ehttpd -p ${port} &>>"$SERVER_LOG" && echo ruby started &>>"$SERVER_LOG" || return 1; }
__rails_serv() { cmd_exists rails && cd "$dir" && server -p "$port" &>>"$SERVER_LOG" && echo ruby started &>>"$SERVER_LOG" || return 1; }
__python3_serv() { cmd_exists python3 && cd "$dir" && python3 -m http.server --cgi --bind "$myip" "${port}" &>>"$SERVER_LOG" && echo Py3 started &>>"$SERVER_LOG" || return 1; }
__python2_serv() { cmd_exists python2 && cd "$dir" && python2 -m http.server --cgi --bind "$myip" "${port}" &>>"$SERVER_LOG" && echo Py2 started &>>"$SERVER_LOG" || return 1; }
__py_simple() { cmd_exists python && cd "$dir" && python -m SimpleHTTPServer "${port}" &>>"$SERVER_LOG" && echo "Py simple start" &>>"$SERVER_LOG" || return 1; }
__default_srv() { cmd_exists python2 && cd "$dir" && python2 -c $'import SimpleHTTPServer;\nmap = SimpleHTTPServer.SimpleHTTPRequestHandler.extensions_map;\nmap[""] = "text/plain";\nfor key, value in map.items():\n\tmap[key] = value + ";charset=UTF-8";\nSimpleHTTPServer.test();' "${port}" &>>"$SERVER_LOG" && echo "Default has started" || return 1; }
__netcat_serv() { while true; do nc -l "${port}" <.; done &>>"$SERVER_LOG" && echo netcat started &>>"$SERVER_LOG" || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
open_url() {
  [ -z "$SSH_CONNECTION" ] || [ -z "$DISPLAY" ] || return
  if cmd_exists mybrowser; then
    mybrowser "$1"
  elif cmd_exists "xdg-open"; then
    xdg-open "$1"
  elif cmd_exists "open"; then
    open "$1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
cmd_exists lsof
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ "$1" = "--bg" ]; then
  shift 1
  echo "launching background process"
  SERVER_LOG="${TMPDIR:-/tmp}/run_server_bg.log"
  $APPNAME "$*" &>"$SERVER_LOG" &
  disown
  exit $?
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
dir="$1"
[ -d "$dir" ] && [ -n "$dir" ] && shift 1 || dir="$PWD"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
case "$1" in
proxy)
  prog="caddy"
  shift 1
  ARGS="$*"
  main $ARGS
  __proxy || __return_error
  exit $?
  ;;

static)
  prog="static"
  shift 1
  ARGS="$*"
  main $ARGS
  __static || __return_error
  exit $?
  ;;

caddy)
  prog="caddy"
  shift 1
  ARGS="$*"
  main $ARGS
  __caddy || __return_error
  exit $?
  ;;

go)
  prog="go"
  shift 1
  ARGS="$*"
  main $ARGS
  __go || __return_error
  exit $?
  ;;

jekyll)
  prog="jekyll"
  shift 1
  ARGS="$*"
  main $ARGS
  __jekyll || __return_error
  exit $?
  ;;

js)
  prog="http-server"
  shift 1
  ARGS="$*"
  main $ARGS
  __js_serv || __return_error
  exit $?
  ;;

php)
  prog="php"
  shift 1
  ARGS="$*"
  main $ARGS
  __php_serv || __return_error
  exit $?
  ;;

rails)
  prog="ruby"
  shift 1
  ARGS="$*"
  main $ARGS
  __rails_serv || __return_error
  exit $?
  ;;

ruby)
  prog="ruby"
  shift 1
  ARGS="$*"
  main $ARGS
  __ruby_serv || __return_error
  exit $?
  ;;

python2)
  prog="python2"
  shift 1
  ARGS="$*"
  main $ARGS
  __python2_serv || __return_error
  exit $?
  ;;

python3)
  prog="python3"
  shift 1
  ARGS="$*"
  main $ARGS
  __python3_serv || __return_error
  exit $?
  ;;

default)
  prog="python2"
  shift 1
  ARGS="$*"
  main $ARGS
  __default_srv || __return_error
  exit $?
  ;;

netcat | nc)
  prog="betcat"
  shift 1
  ARGS="$*"
  main $ARGS
  __netcat_serv || __return_error
  exit $?
  ;;

*)
  ARGS="$*"
  [ -n "$ARGS" ] || __help
  main $ARGS
  __default_srv || __python3_serv || __python2_serv || __py_simple || __netcat_serv || __return_error
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
exit $?
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
