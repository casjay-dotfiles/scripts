#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -euo pipefail
trap 'exitCode=${exitCode:-$?};[ -f "$SCRATCHPAD_TEMP_FILE" ] && rm -Rf "$SCRATCHPAD_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : scratchpad --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : scratchpad
# @Description   : Setup a console base scratchpad
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$SCRATCHPAD_CONFIG_DIR/$SCRATCHPAD_CONFIG_FILE"
  [ -d "$SCRATCHPAD_CONFIG_DIR" ] || mkdir -p "$SCRATCHPAD_CONFIG_DIR"
  [ -d "$SCRATCHPAD_CONFIG_BACKUP_DIR" ] || mkdir -p "$SCRATCHPAD_CONFIG_BACKUP_DIR"
  [ -f "$SCRATCHPAD_CONFIG_DIR/$SCRATCHPAD_CONFIG_FILE" ] &&
    cp -Rf "$SCRATCHPAD_CONFIG_DIR/$SCRATCHPAD_CONFIG_FILE" "$SCRATCHPAD_CONFIG_BACKUP_DIR/$SCRATCHPAD_CONFIG_FILE.$$"
  cat <<EOF >"$SCRATCHPAD_CONFIG_DIR/$SCRATCHPAD_CONFIG_FILE"
# Settings for scratchpad
SCRATCHPAD_EDITOR="\${SCRATCHPAD_EDITOR:-vim}"
SCRATCHPAD_MULTIPLEXER="\${SCRATCHPAD_MULTIPLEXER:-tmux}"
SCRATCHPAD_FILENAME_EXT="${SCRATCHPAD_FILENAME_EXT:-txt}"
SCRATCHPAD_HOME="\${SCRATCHAD_DIR:-$HOME/.local/share/editors/scratchpads}"
SCRATCHPAD_HOUR_FMT="\${SCRATCHPAD_HOUR_FMT:-\$(date +"%H:%M")}"
SCRATCHPAD_MONTH_FMT="\${SCRATCHPAD_MONTH_FMT:-\$(date +"%m")}"
SCRATCHPAD_YEAR_FMT="\${SCRATCHPAD_YEAR_FMT:-\$(date +"%Y")}"
SCRATCHPAD_DAY_FMT="\${SCRATCHPAD_DAY_FMT:-\$(date +"%d")}"
SCRATCHPAD_FILE_BASEDIR="\${SCRATCHPAD_FILE_BASEDIR:-\$SCRATCHPAD_YEAR_FMT}"
SCRATCHPAD_TITLE="\${SCRATCHPAD_TITLE:-\$(date +"%B") \$(date +"%d"), \$SCRATCHPAD_YEAR_FMT created at \$SCRATCHPAD_HOUR_FMT}"
SCRATCHPAD_FILENAME="\${SCRATCHPAD_FILENAME:-\$SCRATCHPAD_FILE_BASEDIR/\$SCRATCHPAD_MONTH_FMT.$SCRATCHPAD_FILENAME_EXT}"

# Notification settings
SCRATCHPAD_GOOD_MESSAGE="${SCRATCHPAD_GOOD_MESSAGE:-Everything Went OK}"
SCRATCHPAD_ERROR_MESSAGE="${SCRATCHPAD_ERROR_MESSAGE:-Well that didn\'t work}"
SCRATCHPAD_NOTIFY_ENABLED="${SCRATCHPAD_NOTIFY_ENABLED:-yes}"
SCRATCHPAD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SCRATCHPAD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SCRATCHPAD_NOTIFY_CLIENT_ICON}"

# Colorization settings
SCRATCHPAD_OUTPUT_COLOR="${SCRATCHPAD_OUTPUT_COLOR:-5}"
SCRATCHPAD_OUTPUT_COLOR_GOOD="${SCRATCHPAD_OUTPUT_COLOR_GOOD:-2}"
SCRATCHPAD_OUTPUT_COLOR_ERROR="${SCRATCHPAD_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$SCRATCHPAD_CONFIG_DIR/$SCRATCHPAD_CONFIG_FILE" ]; then
    printf_green "Your config file for scratchpad has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__editor_config() {
  if [[ "$SCRATCHPAD_MULTIPLEXER" = "tmux" ]]; then
    if [ ! -f "$scratchdir/tmux.conf" ]; then
      if [ -f "$HOME/.config/tmux/others/editors.conf" ]; then
        __cp_rf "$HOME/.config/tmux/others/editors.conf" "$SCRATCHPAD_HOME/tmux.conf"
      else
        __cp_rf "$CASJAYSDEVDIR/templates/tmux.conf" "$SCRATCHPAD_HOME/tmux.conf"
      fi
    fi
    unset TMUX
    tmux -f "$scratchdir/tmux.conf" new-session -D -A -s scratchpad "$SCRATCHPAD_EDITOR $1" &>/dev/null
  elif [[ "$SCRATCHPAD_MULTIPLEXER" = "screen" ]]; then
    if [ ! -f "$scratchdir/screen.conf" ]; then
      if [ -f "$HOME/.config/tmux/others/editors.conf" ]; then
        __cp_rf "$HOME/.config/tmux/others/editors.conf" "$SCRATCHPAD_HOME/screen.conf"
      else
        __cp_rf "$CASJAYSDEVDIR/templates/screen.conf" "$SCRATCHPAD_HOME/screen.conf"
      fi
    fi
    screen -c "$SCRATCHPAD_HOME/screen.conf" "$SCRATCHPAD_EDITOR $1" &>/dev/null
  else
    $SCRATCHPAD_EDITOR "$1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__open() {
  filepath="$(__get_full_file "$1")"
  filename="$scratchdir/${1//$scratchdir/}"
  __run_editor "$filename"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__remove() {
  filepath="$(__get_full_file "$1")"
  filename="$scratchdir/${1//$scratchdir/}"
  printf_green "Deleting $filename"
  rm -Rf "$filename"
  if [ -d "$scratchdir/.git" ]; then
    gitcommit "$scratchdir" scratchpad
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_editor() {
  local filename="${1:-$filename}"
  local filename="$scratchdir/${filename//$scratchdir/}"
  if [ ! -f "$filename" ]; then
    local title="${2:-Scratchpad for $title}"
    printf "%s\n\n" "## $title  " >"$filename"
  fi
  __editor_config "$filename"
  if [ -d "$scratchdir/.git" ] && [[ $(git -C "$scratchdir" status --porcelain &>/dev/null) ]]; then
    printf_green "Committing changes"
    gitcommit "$scratchdir" scratchpad
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
run_git() {
  if [ -d "$scratchdir/.git" ]; then
    if [[ $(git -C "$scratchdir" status --porcelain &>/dev/null) ]]; then
      printf_green "Committing changes"
      gitcommit "$scratchdir" scratchpad
    fi
  else
    git -C "$scratchdir" init &>/dev/null &&
      gitcommit "$scratchdir" scratchpad
  fi
  exit $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
SCRATCHPAD_CACHE_DIR="${SCRATCHPAD_CACHE_DIR:-$HOME/.cache/scratchpad}"
SCRATCHPAD_CONFIG_DIR="${SCRATCHPAD_CONFIG_DIR:-$HOME/.config/myscripts/scratchpad}"
SCRATCHPAD_OPTIONS_DIR="${SCRATCHPAD_OPTIONS_DIR:-$HOME/.local/share/myscripts/scratchpad/options}"
SCRATCHPAD_CONFIG_BACKUP_DIR="${SCRATCHPAD_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/scratchpad/backups}"
SCRATCHPAD_TEMP_DIR="${SCRATCHPAD_TEMP_DIR:-$HOME/.local/tmp/system_scripts/scratchpad}"
SCRATCHPAD_TEMP_FILE="${SCRATCHPAD_TEMP_FILE:-$(mktemp $SCRATCHPAD_TEMP_DIR/XXXXXX 2>/dev/null)}"
SCRATCHPAD_CONFIG_FILE="${SCRATCHPAD_CONFIG_FILE:-settings.conf}"
SCRATCHPAD_GOOD_MESSAGE="${SCRATCHPAD_GOOD_MESSAGE:-Everything Went OK}"
SCRATCHPAD_ERROR_MESSAGE="${SCRATCHPAD_ERROR_MESSAGE:-Well that didn\'t work}"
SCRATCHPAD_NOTIFY_ENABLED="${SCRATCHPAD_NOTIFY_ENABLED:-yes}"
SCRATCHPAD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SCRATCHPAD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SCRATCHPAD_NOTIFY_CLIENT_ICON}"
SCRATCHPAD_OUTPUT_COLOR="${SCRATCHPAD_OUTPUT_COLOR:-5}"
SCRATCHPAD_OUTPUT_COLOR_GOOD="${SCRATCHPAD_OUTPUT_COLOR_GOOD:-2}"
SCRATCHPAD_OUTPUT_COLOR_ERROR="${SCRATCHPAD_OUTPUT_COLOR_ERROR:-1}"
SCRATCHPAD_EDITOR="${SCRATCHPAD_EDITOR:-vim}"
SCRATCHPAD_MULTIPLEXER="${SCRATCHPAD_MULTIPLEXER:-tmux}"
SCRATCHPAD_FILENAME_EXT="${SCRATCHPAD_FILENAME_EXT:-txt}"
SCRATCHPAD_HOME="${SCRATCHAD_DIR:-$HOME/.local/share/editors/scratchpads}"
SCRATCHPAD_HOUR_FMT="${SCRATCHPAD_HOUR_FMT:-$(date +"%H:%M")}"
SCRATCHPAD_MONTH_FMT="${SCRATCHPAD_MONTH_FMT:-$(date +"%m")}"
SCRATCHPAD_YEAR_FMT="${SCRATCHPAD_YEAR_FMT:-$(date +"%Y")}"
SCRATCHPAD_DAY_FMT="${SCRATCHPAD_DAY_FMT:-$(date +"%d")}"
SCRATCHPAD_FILE_BASEDIR="${SCRATCHPAD_FILE_BASEDIR:-$SCRATCHPAD_YEAR_FMT}"
SCRATCHPAD_TITLE="${SCRATCHPAD_TITLE:-$(date +"%B") $(date +"%d"), $SCRATCHPAD_YEAR_FMT created at $SCRATCHPAD_HOUR_FMT}"
SCRATCHPAD_FILENAME="${SCRATCHPAD_FILENAME:-$SCRATCHPAD_FILE_BASEDIR/$SCRATCHPAD_MONTH_FMT.$SCRATCHPAD_FILENAME_EXT}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$SCRATCHPAD_TEMP_DIR" ] || mkdir -p "$SCRATCHPAD_TEMP_DIR" &>/dev/null
[ -d "$SCRATCHPAD_CACHE_DIR" ] || mkdir -p "$SCRATCHPAD_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$SCRATCHPAD_CONFIG_DIR/$SCRATCHPAD_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SCRATCHPAD_CONFIG_DIR/$SCRATCHPAD_CONFIG_FILE" ] &&
  . "$SCRATCHPAD_CONFIG_DIR/$SCRATCHPAD_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    SCRATCHPAD_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$SCRATCHPAD_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${SCRATCHPAD_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${SCRATCHPAD_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${SCRATCHPAD_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${SCRATCHPAD_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
scratchdir="$SCRATCHPAD_HOME"
hour="$SCRATCHPAD_HOUR_FMT"
month="$SCRATCHPAD_MONTH_FMT"
year="$SCRATCHPAD_YEAR_FMT"
day="$SCRATCHPAD_DAY_FMT"
folder="$SCRATCHPAD_FILE_BASEDIR"
title="$SCRATCHPAD_TITLE"
filename="$SCRATCHPAD_FILENAME"
[ -d "$scratchdir/$folder" ] || __mkd "$scratchdir/$folder"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
git)
  shift 1
  run_git "$scratchdir"
  ;;

list)
  shift 1
  if [ -d "$scratchdir" ]; then
    printf_green "Listing the files in $scratchdir"
    find -L $scratchdir/*/* -type f,l -iname "*" 2>/dev/null | sed 's#'$scratchdir/'##g' | __column | printf_read "3"
  else
    printf_exit "No scratchpads exist"
  fi
  ;;

new)
  shift 1
  [ $# -eq 0 ] && printf_help 'Usage: '$APPNAME' new "ProjectName" "FileName" "ext"  |  '$APPNAME' new "server" "parts" "txt"'
  new_title="ScratchPad for $1: Created on $(date +"%B") $(date +"%d"), $year at $hour"
  __mkd "$scratchdir/$1"
  __run_editor "$scratchdir/$1/${2:-default}.${3:-md}" "$new_title"
  ;;

remove)
  shift 1
  __remove "$1"
  ;;

open)
  shift 1
  __open "$1"
  ;;

*)
  if [ -n "$1" ]; then
    __open "$1"
  else
    __run_editor "$scratchdir/$filename"
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
