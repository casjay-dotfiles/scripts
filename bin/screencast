#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : screencast --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : screencast
# @Description   : Record your desktop
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$SCREENCAST_TEMP_FILE" ] && [ -f "$SCREENCAST_TEMP_FILE" ] && rm -Rf "$SCREENCAST_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$SCREENCAST_CONFIG_DIR/$SCREENCAST_CONFIG_FILE"
  [ -d "$SCREENCAST_CONFIG_DIR" ] || mkdir -p "$SCREENCAST_CONFIG_DIR"
  [ -d "$SCREENCAST_CONFIG_BACKUP_DIR" ] || mkdir -p "$SCREENCAST_CONFIG_BACKUP_DIR"
  [ -f "$SCREENCAST_CONFIG_DIR/$SCREENCAST_CONFIG_FILE" ] &&
    cp -Rf "$SCREENCAST_CONFIG_DIR/$SCREENCAST_CONFIG_FILE" "$SCREENCAST_CONFIG_BACKUP_DIR/$SCREENCAST_CONFIG_FILE.$$"
  cat <<EOF >"$SCREENCAST_CONFIG_DIR/$SCREENCAST_CONFIG_FILE"
# Settings for screencast
SCREENCAST_SAVE_DIR="${SCREENCAST_SAVE_DIR:-$HOME/Pictures/Screencasts/\$(date +%m-%d-%Y-%H-%M)}"
SCREENCAST_FILENAME_FMT="${SCREENCAST_FILENAME_FMT:-%Y-%m-%d-%H-%M}"

# Notification settings
SCREENCAST_GOOD_MESSAGE="${SCREENCAST_GOOD_MESSAGE:-Everything Went OK}"
SCREENCAST_ERROR_MESSAGE="${SCREENCAST_ERROR_MESSAGE:-Well something seems to have gone wrong}"
SCREENCAST_NOTIFY_ENABLED="${SCREENCAST_NOTIFY_ENABLED:-yes}"
SCREENCAST_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SCREENCAST_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SCREENCAST_NOTIFY_CLIENT_ICON}"

# Colorization settings
SCREENCAST_OUTPUT_COLOR="${SCREENCAST_OUTPUT_COLOR:-5}"
SCREENCAST_OUTPUT_COLOR_GOOD="${SCREENCAST_OUTPUT_COLOR_GOOD:-2}"
SCREENCAST_OUTPUT_COLOR_ERROR="${SCREENCAST_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$SCREENCAST_CONFIG_DIR/$SCREENCAST_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      unset INIT_CONFIG
      eval bash -c "$APPNAME $*"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
SCREENCAST_LOG_DIR="${SCREENCAST_LOG_DIR:-$HOME/.local/log/screencast}"
SCREENCAST_CACHE_DIR="${SCREENCAST_CACHE_DIR:-$HOME/.cache/screencast}"
SCREENCAST_CONFIG_DIR="${SCREENCAST_CONFIG_DIR:-$HOME/.config/myscripts/screencast}"
SCREENCAST_CONFIG_BACKUP_DIR="${SCREENCAST_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/screencast/backups}"
SCREENCAST_TEMP_DIR="${SCREENCAST_TEMP_DIR:-$HOME/.local/tmp/system_scripts/screencast}"
SCREENCAST_OPTIONS_DIR="${SCREENCAST_OPTIONS_DIR:-$HOME/.local/share/myscripts/screencast/options}"
SCREENCAST_TEMP_FILE="${SCREENCAST_TEMP_FILE:-$(mktemp $SCREENCAST_TEMP_DIR/XXXXXX 2>/dev/null)}"
SCREENCAST_CONFIG_FILE="${SCREENCAST_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
SCREENCAST_OUTPUT_COLOR="${SCREENCAST_OUTPUT_COLOR:-4}"
SCREENCAST_OUTPUT_COLOR_2="${SCREENCAST_OUTPUT_COLOR:-6}"
SCREENCAST_OUTPUT_COLOR_GOOD="${SCREENCAST_OUTPUT_COLOR_GOOD:-2}"
SCREENCAST_OUTPUT_COLOR_ERROR="${SCREENCAST_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
SCREENCAST_GOOD_MESSAGE="${SCREENCAST_GOOD_MESSAGE:-Everything Went OK}"
SCREENCAST_ERROR_MESSAGE="${SCREENCAST_ERROR_MESSAGE:-Well something seems to have gone wrong}"
SCREENCAST_NOTIFY_ENABLED="${SCREENCAST_NOTIFY_ENABLED:-yes}"
SCREENCAST_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SCREENCAST_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SCREENCAST_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
SCREENCAST_SAVE_DIR="${SCREENCAST_SAVE_DIR:-$HOME/Pictures/Screencasts}"
SCREENCAST_FILENAME_FMT="${SCREENCAST_FILENAME_FMT:-%Y-%m-%d-%H-%M}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SCREENCAST_CONFIG_DIR/$SCREENCAST_CONFIG_FILE" ] && . "$SCREENCAST_CONFIG_DIR/$SCREENCAST_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$SCREENCAST_LOG_DIR" ] || mkdir -p "$SCREENCAST_LOG_DIR" &>/dev/null
[ -d "$SCREENCAST_TEMP_DIR" ] || mkdir -p "$SCREENCAST_TEMP_DIR" &>/dev/null
[ -d "$SCREENCAST_CACHE_DIR" ] || mkdir -p "$SCREENCAST_CACHE_DIR" &>/dev/null
[ -d "$SCREENCAST_SAVE_DIR" ] || mkdir -p "$SCREENCAST_SAVE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$SCREENCAST_CONFIG_DIR/$SCREENCAST_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    SCREENCAST_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$SCREENCAST_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${SCREENCAST_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${SCREENCAST_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${SCREENCAST_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${SCREENCAST_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash ffmpeg eog || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
filename="$SCREENCAST_SAVE_DIR/$(date +"$SCREENCAST_FILENAME_FMT")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
echo $SCREENCAST_SAVE_DIR/$(date +"$SCREENCAST_FILENAME_FMT")
echo $filename
echo $SCREENCAST_TEMP_FILE
read -r X Y W H G ID < <(slop -f "%x %y %w %h %g %i")
ffmpeg -f x11grab -s "$W"x"$H" -i :0.0+$X,$Y "$SCREENCAST_TEMP_FILE"
notifications "Screencast:" 'generating palette'
ffmpeg -y -i "$SCREENCAST_TEMP_FILE" -vf fps=10,palettegen /tmp/palette.png
notifications "Screencast:" 'generating gif'
ffmpeg -i "$SCREENCAST_TEMP_FILE" -i /tmp/palette.png -filter_complex "paletteuse" "$filename.gif"
mv "$SCREENCAST_TEMP_FILE" "$filename.mkv"
notifications "Screencast:" "size $(du -h "$filename.gif" | awk '{print $1}')"
eog "$SCREENCAST_SAVE_DIR" "$SCREENCAST_TEMP_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
