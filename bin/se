#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190117-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$SE_TEMP_FILE" ] && rm -Rf "$SE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : se --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : se
# @Description   : a bash file explorer
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$SE_CONFIG_DIR/$SE_CONFIG_FILE"
  [ -d "$SE_CONFIG_DIR" ] || mkdir -p "$SE_CONFIG_DIR"
  [ -d "$SE_CONFIG_BACKUP_DIR" ] || mkdir -p "$SE_CONFIG_BACKUP_DIR"
  [ -f "$SE_CONFIG_DIR/$SE_CONFIG_FILE" ] &&
    cp -Rf "$SE_CONFIG_DIR/$SE_CONFIG_FILE" "$SE_CONFIG_BACKUP_DIR/$SE_CONFIG_FILE.$$"
  cat <<EOF >"$SE_CONFIG_DIR/$SE_CONFIG_FILE"
# Settings for se
SE_BIN_DIR="${SE_BIN_DIR:-$CASJAYSDEVDIR/sources}"

# Notification settings
SE_GOOD_MESSAGE="${SE_GOOD_MESSAGE:-Everything Went OK}"
SE_ERROR_MESSAGE="${SE_ERROR_MESSAGE:-Well that didn\'t work}"
SE_NOTIFY_ENABLED="${SE_NOTIFY_ENABLED:-yes}"
SE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SE_NOTIFY_CLIENT_ICON}"

# Colorization settings
SE_OUTPUT_COLOR="${SE_OUTPUT_COLOR:-5}"
SE_OUTPUT_COLOR_GOOD="${SE_OUTPUT_COLOR_GOOD:-2}"
SE_OUTPUT_COLOR_ERROR="${SE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$SE_CONFIG_DIR/$SE_CONFIG_FILE" ]; then
    printf_green "Your config file for se has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
SE_CACHE_DIR="${SE_CACHE_DIR:-$HOME/.cache/se}"
SE_CONFIG_DIR="${SE_CONFIG_DIR:-$HOME/.config/myscripts/se}"
SE_OPTIONS_DIR="${SE_OPTIONS_DIR:-$HOME/.local/share/myscripts/se/options}"
SE_CONFIG_BACKUP_DIR="${SE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/se/backups}"
SE_TEMP_DIR="${SE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/se}"
SE_TEMP_FILE="${SE_TEMP_FILE:-$(mktemp $SE_TEMP_DIR/XXXXXX 2>/dev/null)}"
SE_CONFIG_FILE="${SE_CONFIG_FILE:-settings.conf}"
SE_GOOD_MESSAGE="${SE_GOOD_MESSAGE:-Everything Went OK}"
SE_ERROR_MESSAGE="${SE_ERROR_MESSAGE:-Well that didn\'t work}"
SE_NOTIFY_ENABLED="${SE_NOTIFY_ENABLED:-yes}"
SE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SE_NOTIFY_CLIENT_ICON}"
SE_OUTPUT_COLOR="${SE_OUTPUT_COLOR:-5}"
SE_OUTPUT_COLOR_GOOD="${SE_OUTPUT_COLOR_GOOD:-2}"
SE_OUTPUT_COLOR_ERROR="${SE_OUTPUT_COLOR_ERROR:-1}"
SE_BIN_DIR="${SE_BIN_DIR:-$CASJAYSDEVDIR/sources}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$SE_TEMP_DIR" ] || mkdir -p "$SE_TEMP_DIR" &>/dev/null
[ -d "$SE_CACHE_DIR" ] || mkdir -p "$SE_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$SE_CONFIG_DIR/$SE_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SE_CONFIG_DIR/$SE_CONFIG_FILE" ] &&
  . "$SE_CONFIG_DIR/$SE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS=""
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$SE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${SE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${SE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${SE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${SE_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
[ -f "$SE_BIN_DIR/se" ] && $SE_BIN_DIR/se
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
