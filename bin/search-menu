#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : search-menu --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : search-menu
# @Description   : Search various search engines
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$SEARCH_MENU_CONFIG_DIR/$SEARCH_MENU_CONFIG_FILE"
  [ -d "$SEARCH_MENU_CONFIG_DIR" ] || mkdir -p "$SEARCH_MENU_CONFIG_DIR"
  [ -d "$SEARCH_MENU_CONFIG_BACKUP_DIR" ] || mkdir -p "$SEARCH_MENU_CONFIG_BACKUP_DIR"
  [ -f "$SEARCH_MENU_CONFIG_DIR/$SEARCH_MENU_CONFIG_FILE" ] &&
    cp -Rf "$SEARCH_MENU_CONFIG_DIR/$SEARCH_MENU_CONFIG_FILE" "$SEARCH_MENU_CONFIG_BACKUP_DIR/$SEARCH_MENU_CONFIG_FILE.$$"
  cat <<EOF >"$SEARCH_MENU_CONFIG_DIR/$SEARCH_MENU_CONFIG_FILE"
# Settings for search-menu
SEARCH_MENU_BROWSER="${SEARCH_MENU_BROWSER:-mybrowser}"

# Notification settings
SEARCH_MENU_GOOD_MESSAGE="${SEARCH_MENU_GOOD_MESSAGE:-Everything Went OK}"
SEARCH_MENU_ERROR_MESSAGE="${SEARCH_MENU_ERROR_MESSAGE:-Well something seems to have gone wrong}"
SEARCH_MENU_NOTIFY_ENABLED="${SEARCH_MENU_NOTIFY_ENABLED:-yes}"
SEARCH_MENU_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SEARCH_MENU_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SEARCH_MENU_NOTIFY_CLIENT_ICON}"

# Colorization settings
SEARCH_MENU_OUTPUT_COLOR="${SEARCH_MENU_OUTPUT_COLOR:-5}"
SEARCH_MENU_OUTPUT_COLOR_GOOD="${SEARCH_MENU_OUTPUT_COLOR_GOOD:-2}"
SEARCH_MENU_OUTPUT_COLOR_ERROR="${SEARCH_MENU_OUTPUT_COLOR_ERROR:-1}"

EOF

  if [ ! -f "$SEARCH_MENU_CONFIG_DIR/searchProviders.conf" ]; then
    cat <<EOF | tee "$SEARCH_MENU_CONFIG_DIR/searchProviders.conf" &>/dev/null
# Declare that this is an array
declare -A searchOptions
# Search Providers: Add additional providers here while
#                   keeping the searchOptions[providerName]="url"
searchOptions[amazon]="https://www.amazon.com/s?k="
searchOptions[archaur]="https://aur.archlinux.org/packages/?O=0&K="
searchOptions[archpkg]="https://archlinux.org/packages/?sort=&q="
searchOptions[archwiki]="https://wiki.archlinux.org/index.php?search="
searchOptions[arxiv]="https://arxiv.org/search/?searchtype=all&source=header&query="
searchOptions[bbcnews]="https://www.bbc.co.uk/search?q="
searchOptions[bing]="https://www.bing.com/search?q="
searchOptions[cliki]="https://www.cliki.net/site/search?query="
searchOptions[cnn]="https://www.cnn.com/search?q="
searchOptions[coinbase]="https://www.coinbase.com/price?query="
searchOptions[debianpkg]="https://packages.debian.org/search?suite=default&section=all&arch=any&searchon=names&keywords="
searchOptions[discogs]="https://www.discogs.com/search/?&type=all&q="
searchOptions[duckduckgo]="https://duckduckgo.com/?q="
searchOptions[ebay]="https://www.ebay.com/sch/i.html?&_nkw="
searchOptions[github]="https://github.com/search?q="
searchOptions[gitlab]="https://gitlab.com/search?search="
searchOptions[imdb]="https://www.imdb.com/find?q="
searchOptions[lbry]="https://lbry.tv/$/search?q="
searchOptions[odysee]="https://odysee.com/$/search?q="
searchOptions[reddit]="https://www.reddit.com/search/?q="
searchOptions[slashdot]="https://slashdot.org/index2.pl?fhfilter="
searchOptions[socialblade]="https://socialblade.com/youtube/user/"
searchOptions[sourceforge]="https://sourceforge.net/directory/?q="
searchOptions[stack]="https://stackoverflow.com/search?q="
searchOptions[startpage]="https://www.startpage.com/do/dsearch?query="
searchOptions[stockquote]="https://finance.yahoo.com/quote/"
searchOptions[thesaurus]="https://www.thesaurus.com/misspelling?term="
searchOptions[translate]="https://translate.google.com/?sl=auto&tl=en&text="
searchOptions[urban]="https://www.urbandictionary.com/define.php?term="
searchOptions[wayback]="https://web.archive.org/web/*/"
searchOptions[webster]="https://www.merriam-webster.com/dictionary/"
searchOptions[wikipedia]="https://en.wikipedia.org/wiki/"
searchOptions[wiktionary]="https://en.wiktionary.org/wiki/"
searchOptions[wolfram]="https://www.wolframalpha.com/input/?i="
searchOptions[youtube]="https://www.youtube.com/results?search_query="
searchOptions[google]="https://www.google.com/search?q="
searchOptions[googleimages]="https://www.google.com/search?hl=en&tbm=isch&q="
searchOptions[googlenews]="https://news.google.com/search?q="
searchOptions[googleSupport]="https://support.google.com/search?q="
searchOptions[googleSupportAdmin]="https://support.google.com/a/search?q="
searchOptions[googleStructuredData]="https://search.google.com/structured-data/testing-tool#url="
searchOptions[googleRichResults]="https://search.google.com/test/rich-results??url="
searchOptions[googlePagespeed]="https://developers.google.com/speed/pagespeed/insights/?url="
searchOptions[googleDevelopers]="https://developers.google.com/s/results?q="
searchOptions[googleOpenSource]="https://opensource.google/projects/search?q="
searchOptions[googleExperimentswithGoogle]="https://experiments.withgoogle.com/search?q="
searchOptions[googleDataset]="https://datasetsearch.research.google.com/search?query="

EOF
  fi

  if [ -f "$SEARCH_MENU_CONFIG_DIR/$SEARCH_MENU_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [ -f "$SEARCH_MENU_CONFIG_DIR/searchProviders.conf" ]; then
      printf_blue "Add additional providers in searchProviders.conf while"
      printf_blue 'keeping the searchOptions[providerName]="url"'
    fi
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__dmenu_run() {
  if cmd_exists rofi; then
    rofi -theme purple -dmenu "$@"
  elif cmd_exist dmenu; then
    dmenu "$@"
  else
    printf_exit "This requires either dmenu or rofi"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
SEARCH_MENU_LOG_DIR="${SEARCH_MENU_LOG_DIR:-$HOME/.local/log/search-menu}"
SEARCH_MENU_CACHE_DIR="${SEARCH_MENU_CACHE_DIR:-$HOME/.cache/search-menu}"
SEARCH_MENU_CONFIG_DIR="${SEARCH_MENU_CONFIG_DIR:-$HOME/.config/myscripts/search-menu}"
SEARCH_MENU_CONFIG_BACKUP_DIR="${SEARCH_MENU_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/search-menu/backups}"
SEARCH_MENU_TEMP_DIR="${SEARCH_MENU_TEMP_DIR:-$HOME/.local/tmp/system_scripts/search-menu}"
SEARCH_MENU_OPTIONS_DIR="${SEARCH_MENU_OPTIONS_DIR:-$HOME/.local/share/myscripts/search-menu/options}"
SEARCH_MENU_CONFIG_FILE="${SEARCH_MENU_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
SEARCH_MENU_OUTPUT_COLOR="${SEARCH_MENU_OUTPUT_COLOR:-4}"
SEARCH_MENU_OUTPUT_COLOR_2="${SEARCH_MENU_OUTPUT_COLOR:-6}"
SEARCH_MENU_OUTPUT_COLOR_GOOD="${SEARCH_MENU_OUTPUT_COLOR_GOOD:-2}"
SEARCH_MENU_OUTPUT_COLOR_ERROR="${SEARCH_MENU_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
SEARCH_MENU_GOOD_MESSAGE="${SEARCH_MENU_GOOD_MESSAGE:-Everything Went OK}"
SEARCH_MENU_ERROR_MESSAGE="${SEARCH_MENU_ERROR_MESSAGE:-Well something seems to have gone wrong}"
SEARCH_MENU_NOTIFY_ENABLED="${SEARCH_MENU_NOTIFY_ENABLED:-yes}"
SEARCH_MENU_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SEARCH_MENU_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SEARCH_MENU_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
SEARCH_MENU_BROWSER="${SEARCH_MENU_BROWSER:-mybrowser}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$SEARCH_MENU_CONFIG_DIR/$SEARCH_MENU_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@} &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SEARCH_MENU_CONFIG_DIR/$SEARCH_MENU_CONFIG_FILE" ] && . "$SEARCH_MENU_CONFIG_DIR/$SEARCH_MENU_CONFIG_FILE"
[ -f "$SEARCH_MENU_CONFIG_DIR/searchProviders.conf" ] && . "$SEARCH_MENU_CONFIG_DIR/searchProviders.conf"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$SEARCH_MENU_LOG_DIR" ] || mkdir -p "$SEARCH_MENU_LOG_DIR" &>/dev/null
[ -d "$SEARCH_MENU_TEMP_DIR" ] || mkdir -p "$SEARCH_MENU_TEMP_DIR" &>/dev/null
[ -d "$SEARCH_MENU_CACHE_DIR" ] || mkdir -p "$SEARCH_MENU_CACHE_DIR" &>/dev/null
SEARCH_MENU_TEMP_FILE="${SEARCH_MENU_TEMP_FILE:-$(mktemp $SEARCH_MENU_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$SEARCH_MENU_TEMP_FILE" ] && [ -f "$SEARCH_MENU_TEMP_FILE" ] && rm -Rf "$SEARCH_MENU_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$SEARCH_MENU_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${SEARCH_MENU_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${SEARCH_MENU_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${SEARCH_MENU_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${SEARCH_MENU_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    SEARCH_MENU_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash dmenu || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
SEARCH_MENU_BROWSER="${SEARCH_MENU_BROWSER:-$BROWSER}"
engine=""
query=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
while [ -z "$engine" ]; do
  engine=$(printf '%s\n' "${!searchOptions[@]}" | sort | __dmenu_run -i -l 20 -p 'Choose search engine:') "$@" || exit
  url="${searchOptions["${engine}"]}" || exit
done
while [ -z "$query" ]; do
  query=$(echo "$engine" | __dmenu_run -p 'Enter search query:') "$@" || exit
done
$SEARCH_MENU_BROWSER "$url""$query"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
