[ -f "$SEARCH_MENU_CONFIG_DIR/searchProviders.conf" ] && . "$SEARCH_MENU_CONFIG_DIR/searchProviders.conf"
[ -f "$SEARCH_MENU_CONFIG_DIR/searchProviders.local.conf" ] && . "$SEARCH_MENU_CONFIG_DIR/searchProviders.local.conf"
