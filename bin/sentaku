#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108190315-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$SENTAKU_TEMP_FILE" ] && rm -Rf "$SENTAKU_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190315-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : sentaku --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 03:15 EDT
# @File          : sentaku
# @Description   : Utility to make sentaku (selection) window with shell command
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-simple.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$SENTAKU_CONFIG_DIR/$SENTAKU_CONFIG_FILE"
  [ -d "$SENTAKU_CONFIG_DIR" ] || mkdir -p "$SENTAKU_CONFIG_DIR"
  [ -d "$SENTAKU_CONFIG_BACKUP_DIR" ] || mkdir -p "$SENTAKU_CONFIG_BACKUP_DIR"
  [ -f "$SENTAKU_CONFIG_DIR/$SENTAKU_CONFIG_FILE" ] &&
    cp -Rf "$SENTAKU_CONFIG_DIR/$SENTAKU_CONFIG_FILE" "$SENTAKU_CONFIG_BACKUP_DIR/$SENTAKU_CONFIG_FILE.$$"
  cat <<EOF >"$SENTAKU_CONFIG_DIR/$SENTAKU_CONFIG_FILE"
# Settings for sentaku
SENTAKU_BIN_DIR="${SENTAKU_BIN_DIR:-$CASJAYSDEVDIR/sources}"

# Notification settings
SENTAKU_GOOD_MESSAGE="${SENTAKU_GOOD_MESSAGE:-Everything Went OK}"
SENTAKU_ERROR_MESSAGE="${SENTAKU_ERROR_MESSAGE:-Well that didn\'t work}"
SENTAKU_NOTIFY_ENABLED="${SENTAKU_NOTIFY_ENABLED:-yes}"
SENTAKU_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SENTAKU_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SENTAKU_NOTIFY_CLIENT_ICON}"

# Colorization settings
SENTAKU_OUTPUT_COLOR="${SENTAKU_OUTPUT_COLOR:-5}"
SENTAKU_OUTPUT_COLOR_GOOD="${SENTAKU_OUTPUT_COLOR_GOOD:-2}"
SENTAKU_OUTPUT_COLOR_ERROR="${SENTAKU_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$SENTAKU_CONFIG_DIR/$SENTAKU_CONFIG_FILE" ]; then
    printf_green "Your config file for sentaku has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
SENTAKU_CACHE_DIR="${SENTAKU_CACHE_DIR:-$HOME/.cache/sentaku}"
SENTAKU_CONFIG_DIR="${SENTAKU_CONFIG_DIR:-$HOME/.config/myscripts/sentaku}"
SENTAKU_OPTIONS_DIR="${SENTAKU_OPTIONS_DIR:-$HOME/.local/share/myscripts/sentaku/options}"
SENTAKU_CONFIG_BACKUP_DIR="${SENTAKU_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/sentaku/backups}"
SENTAKU_TEMP_DIR="${SENTAKU_TEMP_DIR:-$HOME/.local/tmp/system_scripts/sentaku}"
SENTAKU_TEMP_FILE="${SENTAKU_TEMP_FILE:-$(mktemp $SENTAKU_TEMP_DIR/XXXXXX 2>/dev/null)}"
SENTAKU_CONFIG_FILE="${SENTAKU_CONFIG_FILE:-settings.conf}"
SENTAKU_GOOD_MESSAGE="${SENTAKU_GOOD_MESSAGE:-Everything Went OK}"
SENTAKU_ERROR_MESSAGE="${SENTAKU_ERROR_MESSAGE:-Well that didn\'t work}"
SENTAKU_NOTIFY_ENABLED="${SENTAKU_NOTIFY_ENABLED:-yes}"
SENTAKU_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SENTAKU_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SENTAKU_NOTIFY_CLIENT_ICON}"
SENTAKU_OUTPUT_COLOR="${SENTAKU_OUTPUT_COLOR:-5}"
SENTAKU_OUTPUT_COLOR_GOOD="${SENTAKU_OUTPUT_COLOR_GOOD:-2}"
SENTAKU_OUTPUT_COLOR_ERROR="${SENTAKU_OUTPUT_COLOR_ERROR:-1}"
SENTAKU_BIN_DIR="${SENTAKU_BIN_DIR:-$CASJAYSDEVDIR/sources}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$SENTAKU_TEMP_DIR" ] || mkdir -p "$SENTAKU_TEMP_DIR" &>/dev/null
[ -d "$SENTAKU_CACHE_DIR" ] || mkdir -p "$SENTAKU_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$SENTAKU_CONFIG_DIR/$SENTAKU_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SENTAKU_CONFIG_DIR/$SENTAKU_CONFIG_FILE" ] &&
  . "$SENTAKU_CONFIG_DIR/$SENTAKU_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS=""
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$SENTAKU_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${SENTAKU_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${SENTAKU_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${SENTAKU_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${SENTAKU_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
[ -f "$SENTAKU_BIN_DIR/sentaku" ] && bash $SENTAKU_BIN_DIR/sentaku
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
