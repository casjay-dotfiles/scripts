#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : shortenurl --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : shortenurl
# @Description   : URL shortner
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$SHORTENURL_TEMP_FILE" ] && [ -f "$SHORTENURL_TEMP_FILE" ] && rm -Rf "$SHORTENURL_TEMP_FILE" &>/dev/null' EXIT
set -o pipefail

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE"
  [ -d "$SHORTENURL_CONFIG_DIR" ] || mkdir -p "$SHORTENURL_CONFIG_DIR"
  [ -d "$SHORTENURL_CONFIG_BACKUP_DIR" ] || mkdir -p "$SHORTENURL_CONFIG_BACKUP_DIR"
  [ -f "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE" ] &&
    cp -Rf "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE" "$SHORTENURL_CONFIG_BACKUP_DIR/$SHORTENURL_CONFIG_FILE.$$"
  cat <<EOF >"$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE"
# Settings for shortenurl
SHORTENURL_URL="${SHORTENURL_URL:-https://is.gd/create.php?logstats=1&format=simple&url=}"

# Notification settings
SHORTENURL_GOOD_MESSAGE="${SHORTENURL_GOOD_MESSAGE:-Everything Went OK}"
SHORTENURL_ERROR_MESSAGE="${SHORTENURL_ERROR_MESSAGE:-Well that didn\'t work}"
SHORTENURL_NOTIFY_ENABLED="${SHORTENURL_NOTIFY_ENABLED:-yes}"
SHORTENURL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SHORTENURL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SHORTENURL_NOTIFY_CLIENT_ICON}"

# Colorization settings
SHORTENURL_OUTPUT_COLOR="${SHORTENURL_OUTPUT_COLOR:-5}"
SHORTENURL_OUTPUT_COLOR_GOOD="${SHORTENURL_OUTPUT_COLOR_GOOD:-2}"
SHORTENURL_OUTPUT_COLOR_ERROR="${SHORTENURL_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for shortenurl has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__curl() { curl -q --connect-timeout 3 --retry 0 --fail $* 2>/dev/null || return 1; }
__urlencode() { perl -MURI::Escape -e 'print uri_escape($ARGV[0]);' "${1:-$URL}"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
SHORTENURL_LOG_DIR="${SHORTENURL_LOG_DIR:-$HOME/.local/log/shortenurl}"
SHORTENURL_CACHE_DIR="${SHORTENURL_CACHE_DIR:-$HOME/.cache/shortenurl}"
SHORTENURL_CONFIG_DIR="${SHORTENURL_CONFIG_DIR:-$HOME/.config/myscripts/shortenurl}"
SHORTENURL_CONFIG_BACKUP_DIR="${SHORTENURL_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/shortenurl/backups}"
SHORTENURL_TEMP_DIR="${SHORTENURL_TEMP_DIR:-$HOME/.local/tmp/system_scripts/shortenurl}"
SHORTENURL_OPTIONS_DIR="${SHORTENURL_OPTIONS_DIR:-$HOME/.local/share/myscripts/shortenurl/options}"
SHORTENURL_TEMP_FILE="${SHORTENURL_TEMP_FILE:-$(mktemp $SHORTENURL_TEMP_DIR/XXXXXX 2>/dev/null)}"
SHORTENURL_CONFIG_FILE="${SHORTENURL_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
SHORTENURL_OUTPUT_COLOR="${SHORTENURL_OUTPUT_COLOR:-4}"
SHORTENURL_OUTPUT_COLOR_2="${SHORTENURL_OUTPUT_COLOR:-6}"
SHORTENURL_OUTPUT_COLOR_GOOD="${SHORTENURL_OUTPUT_COLOR_GOOD:-2}"
SHORTENURL_OUTPUT_COLOR_ERROR="${SHORTENURL_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
SHORTENURL_GOOD_MESSAGE="${SHORTENURL_GOOD_MESSAGE:-Everything Went OK}"
SHORTENURL_ERROR_MESSAGE="${SHORTENURL_ERROR_MESSAGE:-Well that didn\'t work}"
SHORTENURL_NOTIFY_ENABLED="${SHORTENURL_NOTIFY_ENABLED:-yes}"
SHORTENURL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SHORTENURL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SHORTENURL_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
SHORTENURL_URL="${SHORTENURL_URL:-https://is.gd/create.php?logstats=1&format=simple&url=}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE" ] && . "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$SHORTENURL_LOG_DIR" ] || mkdir -p "$SHORTENURL_LOG_DIR" &>/dev/null
[ -d "$SHORTENURL_TEMP_DIR" ] || mkdir -p "$SHORTENURL_TEMP_DIR" &>/dev/null
[ -d "$SHORTENURL_CACHE_DIR" ] || mkdir -p "$SHORTENURL_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE" ] || [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    SHORTENURL_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$SHORTENURL_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${SHORTENURL_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${SHORTENURL_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${SHORTENURL_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${SHORTENURL_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[ -z "$1" ] && seturl=$(printclip) || seturl="$1"
encoded="$(__urlencode "$seturl" | sed 's| ||g')"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
result="$(__curl "$SHORTENURL_URL$encoded" | grep '^')"
if [[ -n "$result" ]]; then
  echo "$result" | printf_readline $SHORTENURL_OUTPUT_COLOR
  echo "$result" | putclip
else
  printf_return "Something seems to have gone creating the shortened url"
  printf_return "$SHORTENURL_URL$encoded"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
