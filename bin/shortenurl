# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE"
  [ -d "$SHORTENURL_CONFIG_DIR" ] || mkdir -p "$SHORTENURL_CONFIG_DIR"
  [ -d "$SHORTENURL_CONFIG_BACKUP_DIR" ] || mkdir -p "$SHORTENURL_CONFIG_BACKUP_DIR"
  [ -f "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE" ] &&
    cp -Rf "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE" "$SHORTENURL_CONFIG_BACKUP_DIR/$SHORTENURL_CONFIG_FILE.$$"
  cat <<EOF >"$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE"
# Settings for shortenurl
# private, is_gd, tny_im, yourls, github - defaults to yourls
SHORTENURL_DEFAULT="${SHORTENURL_DEFAULT:-yourls}"

# private: See https://github.com/casjay-coffee/casjay.link for self hosted option
SHORTENURL_URL_PRIVATE="${SHORTENURL_URL_PRIVATE:-https://casjay.link}"
SHORTENURL_URL_PRIVATE_API="${SHORTENURL_URL_PRIVATE_API:-$SHORTENURL_URL_PRIVATE/url}"

# yourls: See http://yourls.org for self hosted option
SHORTENURL_URL_YOURLS="${SHORTENURL_URL_YOURLS:-https://t25b.xyz}"
SHORTENURL_URL_YOURLS_API_KEY="${SHORTENURL_URL_YOURLS_API_KEY:-}"
SHORTENURL_URL_YOURLS_API_FORMAT="${SHORTENURL_URL_YOURLS_API_FORMAT:-simple}"
SHORTENURL_URL_YOURLS_API="${SHORTENURL_URL_YOURLS_API:-$SHORTENURL_URL_YOURLS/yourls-api.php}"

# tny_im: See http://tny.im
SHORTENURL_URL_TNY="${SHORTENURL_URL_YOURLS:-https://tny.im}"
SHORTENURL_URL_TNY_API_KEY="${SHORTENURL_URL_TNY_API_KEY:-}"
SHORTENURL_URL_TNY_API_FORMAT="${SHORTENURL_URL_TNY_API_FORMAT:-simple}"
SHORTENURL_URL_TNY_API="${SHORTENURL_URL_YOURLS_API:-$SHORTENURL_URL_YOURLS/yourls-api.php}"

# is_gd: See https://is.gd
SHORTENURL_URL_IS="${SHORTENURL_URL_IS:-https://is.gd}"
SHORTENURL_URL_IS_FORMAT="${SHORTENURL_URL_IS_FORMAT:-simple}"
SHORTENURL_URL_IS_API="${SHORTENURL_URL_IS_API:-$SHORTENURL_URL_IS/create.php}"

# github: See https://git.io
SHORTENURL_URL_GITHUB="${SHORTENURL_URL_GITHUB:-https://git.io}"

# Notification settings
SHORTENURL_GOOD_MESSAGE="${SHORTENURL_GOOD_MESSAGE:-Everything Went OK}"
SHORTENURL_ERROR_MESSAGE="${SHORTENURL_ERROR_MESSAGE:-Well something seems to have gone wrong}"
SHORTENURL_NOTIFY_ENABLED="${SHORTENURL_NOTIFY_ENABLED:-yes}"
SHORTENURL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SHORTENURL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SHORTENURL_NOTIFY_CLIENT_ICON}"

# Colorization settings
SHORTENURL_OUTPUT_COLOR="${SHORTENURL_OUTPUT_COLOR:-5}"
SHORTENURL_OUTPUT_COLOR_GOOD="${SHORTENURL_OUTPUT_COLOR_GOOD:-2}"
SHORTENURL_OUTPUT_COLOR_ERROR="${SHORTENURL_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$SHORTENURL_CONFIG_DIR/$SHORTENURL_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for shortenurl has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__curl() { curl -q --connect-timeout 3 --retry 0 --fail "$*" 2>/dev/null || return 1; }
__urlencode() { perl -MURI::Escape -e 'print uri_escape($ARGV[0]);' "${1:-$URL}"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__private_url() {
  local host="$1"
  local slug="${2:-$(tr -dc 'a-zA-Z' </dev/urandom | head -c 6)}"
  echo "$host" | grep -Eq 'http|https' || { echo "Please enter a valid URL" && return 1; }
  results="$(curl -q -LSs --header "Content-Type: application/json" --request POST --data '{"url":"'$host'","slug":"'$slug'"}' "$SHORTENURL_URL_PRIVATE_API")"
  if echo "$results" | grep -q 'Too many requests'; then
    result="$(echo "You have been rate limited. Please try again later. 🍔")"
    exitCodeTmp=1
  elif echo "$results" | grep -q 'Slug in use.'; then
    result="$(echo "The slug $2 is in use. 🍔")"
    exitCodeTmp=1
  elif echo "$results" | grep -q 'Error:'; then
    result="$(echo "An error has occured. 🍔")"
    exitCodeTmp=1
  elif echo "$results" | jq -r '.url' | sed 's|"||g' | grep -q '^'; then
    result="$(echo "$SHORTENURL_URL_PRIVATE/$slug points to $host" && exitCodeTmp=0)"
  else
    result="$(echo An error has occurred)"
    exitCodeTmp=1
  fi
  exitCode=${exitCodeTmp:-$?}
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__is_gd_url() {
  local host="$1"
  local encoded="$(__urlencode "$1" | sed 's| ||g')"
  local results="$(__curl "$SHORTENURL_URL_IS_API?logstats=1&format=$SHORTENURL_URL_IS_FORMAT&url=$encoded" | grep '^')"
  if [[ -n "$results" ]]; then
    result="$(echo "$results")"
    exitCode=0
  else
    result="$(echo "Something seems to have gone creating the shortened url" && echo "$SHORTENURL_URL_IS_API?logstats=1&format=$SHORTENURL_URL_IS_FORMAT&url=$encoded")"
    exitCodeTmp=1
  fi
  exitCode=${exitCodeTmp:-$?}
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__yourls_url() {
  local host="$1"
  local slug="${2:-$(tr -dc 'a-zA-Z' </dev/urandom | head -c 6)}"
  results="$(wget -q -O - "$SHORTENURL_URL_YOURLS_API?action=shorturl\&format=$SHORTENURL_URL_YOURLS_API_FORMAT\&url=$host\&keyword=$slug")"
  if [[ -n "$result" ]]; then
    result="$(echo "$results")"
    exitCodeTmp=0
  else
    result="$(echo "Something seems to have gone")"
    exitCodeTmp=1
  fi
  exitCode=${exitCodeTmp:-$?}
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tny_url() {
  local host="$1"
  local slug="${2:-$(tr -dc 'a-zA-Z' </dev/urandom | head -c 6)}"
  results="$(wget -q -O - "$SHORTENURL_URL_TNY_API?action=shorturl\&format=$SHORTENURL_URL_TNY_API_FORMAT\&url=$host\&keyword=$slug")"
  if [[ -n "$result" ]]; then
    result="$(echo "$results")"
    exitCodeTmp=0
  else
    result="$(echo "Something seems to have gone")"
    exitCodeTmp=1
  fi
  exitCode=${exitCodeTmp:-$?}
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__github_url() {
  local host="$1"
  local slug="${2:-$(tr -dc 'a-zA-Z' </dev/urandom | head -c 6)}"
  echo "$host" | grep -Eq 'github' || { echo "Please enter a valid github URL" && return 1; }
  results="$(curl -q -LSsi "$SHORTENURL_URL_GITHUB" -F "url=$short_url" -F "code=$slug" 2>/dev/null | grep 'Location: ')"
  if [[ -n "$result" ]]; then
    result="$(echo "$results")"
    exitCodeTmp=0
  else
    result="$(echo "Something seems to have gone creating the github url")"
    exitCodeTmp=1
  fi
  exitCode=${exitCodeTmp:-$?}
  return ${exitCode:-$?}
}
