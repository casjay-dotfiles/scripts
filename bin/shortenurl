  ;;

github)
  shift 1
  if [ ${#} -eq 0 ]; then
    if [ -p "/dev/stdin" ]; then
      seturl="$(</dev/stdin)"
    fi
  else
    seturl="$1"
  fi
  __github_url $seturl $2
  echo "$result" | printf_readline $SHORTENURL_OUTPUT_COLOR
  echo "$result" | putclip
  exit ${exitCode:-$?}
  ;;

is_gd)
  shift 1
  if [ ${#} -eq 0 ]; then
    if [ -p "/dev/stdin" ]; then
      seturl="$(</dev/stdin)"
    fi
  else
    seturl="$1"
  fi
  __is_gd_url $seturl $2
  echo "$result" | printf_readline $SHORTENURL_OUTPUT_COLOR
  echo "$result" | putclip
  exit ${exitCode:-$?}
  ;;

tny_im)
  shift 1
  if [ ${#} -eq 0 ]; then
    if [ -p "/dev/stdin" ]; then
      seturl="$(</dev/stdin)"
    fi
  else
    seturl="$1"
  fi
  __tny_url $seturl $2
