yourls)
  shift 1
  if [ ${#} -eq 0 ]; then
    if [ -p "/dev/stdin" ]; then
      seturl="$(</dev/stdin)"
    fi
  else
    seturl="$1"
  fi
  __yourls_url $seturl $2
  echo "$result" | printf_readline $SHORTENURL_OUTPUT_COLOR
  echo "$result" | putclip
  exit ${exitCode:-$?}
