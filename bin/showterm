#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190117-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : showterm --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:17 EDT
# @File          : showterm
# @Description   : A simple Linux-only pure-shell showterm client for those without Ruby
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$SHOWTERM_TEMP_FILE" ] && [ -f "$SHOWTERM_TEMP_FILE" ] && rm -Rf "$SHOWTERM_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$SHOWTERM_CONFIG_DIR/$SHOWTERM_CONFIG_FILE"
  [ -d "$SHOWTERM_CONFIG_DIR" ] || mkdir -p "$SHOWTERM_CONFIG_DIR"
  [ -d "$SHOWTERM_CONFIG_BACKUP_DIR" ] || mkdir -p "$SHOWTERM_CONFIG_BACKUP_DIR"
  [ -f "$SHOWTERM_CONFIG_DIR/$SHOWTERM_CONFIG_FILE" ] &&
    cp -Rf "$SHOWTERM_CONFIG_DIR/$SHOWTERM_CONFIG_FILE" "$SHOWTERM_CONFIG_BACKUP_DIR/$SHOWTERM_CONFIG_FILE.$$"
  cat <<EOF >"$SHOWTERM_CONFIG_DIR/$SHOWTERM_CONFIG_FILE"
# Settings for showterm
SHOWTERM_URL_RECORD="${SHOWTERM_URL_RECORD:-showterm.io/record}"
SHOWTERM_URL_UPLOAD="${SHOWTERM_URL_UPLOAD:-showterm.io}"
SHOWTERM_SECRET_FILE="${SHOWTERM_SECRET_FILE:-$SHOWTERM_CONFIG_DIR/secret}"

# Notification settings
SHOWTERM_GOOD_MESSAGE="${SHOWTERM_GOOD_MESSAGE:-Everything Went OK}"
SHOWTERM_ERROR_MESSAGE="${SHOWTERM_ERROR_MESSAGE:-Well something seems to have gone wrong}"
SHOWTERM_NOTIFY_ENABLED="${SHOWTERM_NOTIFY_ENABLED:-yes}"
SHOWTERM_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SHOWTERM_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SHOWTERM_NOTIFY_CLIENT_ICON}"

# Colorization settings
SHOWTERM_OUTPUT_COLOR="${SHOWTERM_OUTPUT_COLOR:-5}"
SHOWTERM_OUTPUT_COLOR_GOOD="${SHOWTERM_OUTPUT_COLOR_GOOD:-2}"
SHOWTERM_OUTPUT_COLOR_ERROR="${SHOWTERM_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$SHOWTERM_CONFIG_DIR/$SHOWTERM_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for showterm has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$@"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__delete_recording() {
  if [ "$1" = "-d" ] || [ "$1" = "--delete" ]; then
    url="${2?-Usage showterm --delete <url>}"
    curl --fail "$url" -X "DELETE" --data-urlencode "secret@$SHOWTERM_SECRET_FILE"
    exit
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
SHOWTERM_LOG_DIR="${SHOWTERM_LOG_DIR:-$HOME/.local/log/showterm}"
SHOWTERM_CACHE_DIR="${SHOWTERM_CACHE_DIR:-$HOME/.cache/showterm}"
SHOWTERM_CONFIG_DIR="${SHOWTERM_CONFIG_DIR:-$HOME/.config/myscripts/showterm}"
SHOWTERM_CONFIG_BACKUP_DIR="${SHOWTERM_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/showterm/backups}"
SHOWTERM_TEMP_DIR="${SHOWTERM_TEMP_DIR:-$HOME/.local/tmp/system_scripts/showterm}"
SHOWTERM_OPTIONS_DIR="${SHOWTERM_OPTIONS_DIR:-$HOME/.local/share/myscripts/showterm/options}"
SHOWTERM_TEMP_FILE="${SHOWTERM_TEMP_FILE:-$(mktemp $SHOWTERM_TEMP_DIR/XXXXXX 2>/dev/null)}"
SHOWTERM_CONFIG_FILE="${SHOWTERM_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
SHOWTERM_OUTPUT_COLOR="${SHOWTERM_OUTPUT_COLOR:-4}"
SHOWTERM_OUTPUT_COLOR_2="${SHOWTERM_OUTPUT_COLOR:-6}"
SHOWTERM_OUTPUT_COLOR_GOOD="${SHOWTERM_OUTPUT_COLOR_GOOD:-2}"
SHOWTERM_OUTPUT_COLOR_ERROR="${SHOWTERM_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
SHOWTERM_GOOD_MESSAGE="${SHOWTERM_GOOD_MESSAGE:-Everything Went OK}"
SHOWTERM_ERROR_MESSAGE="${SHOWTERM_ERROR_MESSAGE:-Well something seems to have gone wrong}"
SHOWTERM_NOTIFY_ENABLED="${SHOWTERM_NOTIFY_ENABLED:-yes}"
SHOWTERM_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SHOWTERM_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SHOWTERM_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
SHOWTERM_URL_RECORD="${SHOWTERM_URL_RECORD:-showterm.io/record}"
SHOWTERM_URL_UPLOAD="${SHOWTERM_URL_UPLOAD:-showterm.io}"
SHOWTERM_SECRET_FILE="${SHOWTERM_SECRET_FILE:-$SHOWTERM_CONFIG_DIR/secret}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SHOWTERM_CONFIG_DIR/$SHOWTERM_CONFIG_FILE" ] && . "$SHOWTERM_CONFIG_DIR/$SHOWTERM_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$SHOWTERM_LOG_DIR" ] || mkdir -p "$SHOWTERM_LOG_DIR" &>/dev/null
[ -d "$SHOWTERM_TEMP_DIR" ] || mkdir -p "$SHOWTERM_TEMP_DIR" &>/dev/null
[ -d "$SHOWTERM_CACHE_DIR" ] || mkdir -p "$SHOWTERM_CACHE_DIR" &>/dev/null
[ -f "$SHOWTERM_SECRET_FILE" ] || echo -n "$(openssl rand -hex 16)" >"$SHOWTERM_SECRET_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$SHOWTERM_CONFIG_DIR/$SHOWTERM_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="d:"
LONGOPTS="options,config,version,help,dir:,delete:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    SHOWTERM_CWD="$2"
    shift 2
    ;;
  -d | --delete)
    __delete_recording "$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$SHOWTERM_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${SHOWTERM_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${SHOWTERM_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${SHOWTERM_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${SHOWTERM_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
server="${SHOWTERM_SERVER-$SHOWTERM_URL_UPLOAD}"
url="${server%/}/scripts"
scriptfile="$(mktemp /tmp/XXXXX.script)"
timingfile="$(mktemp /tmp/XXXXX.timing)"
cols="$(tput cols)"
lines="$(tput lines)"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ "$*" ]; then
  echo "$*"
  args=-c "$*"
fi
echo "showterm recording. (Exit shell when done.)"
script $args -q -t"$timingfile" "$scriptfile"
echo "Uploading..."
if curl --fail "$url" --data-urlencode "cols=$cols" --data-urlencode "lines=$lines" --data-urlencode "scriptfile@$scriptfile" --data-urlencode "timingfile@$timingfile" "secret@$SHOWTERM_SECRET_FILE"; then
  echo ""
  rm "$scriptfile" "$timingfile"
  true
else
  echo "Uploading failed, but don't worry! Your work is safe. You can try uploading again with:"
  echo curl "$url" --data-urlencode "cols=$cols" --data-urlencode "lines=$lines" --data-urlencode "scriptfile@$scriptfile" --data-urlencode "timingfile@$timingfile" "secret@$SHOWTERM_SECRET_FILE"
  false
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
