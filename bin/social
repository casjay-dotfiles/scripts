# @File          : social
# @Description   : Social menu written in bash
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190117-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; } && { myterminal -e "$APPNAME $*" && exit || exit 1; }
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$SOCIAL_TEMP_FILE" ] && [ -f "$SOCIAL_TEMP_FILE" ] && rm -Rf "$SOCIAL_TEMP_FILE" &>/dev/null' EXIT
shopt -s extglob
trap '' SIGINT
trap '' SIGQUIT
trap '' SIGTSTP

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$SOCIAL_CONFIG_DIR/$SOCIAL_CONFIG_FILE"
  [ -d "$SOCIAL_CONFIG_DIR" ] || mkdir -p "$SOCIAL_CONFIG_DIR"
  [ -d "$SOCIAL_CONFIG_BACKUP_DIR" ] || mkdir -p "$SOCIAL_CONFIG_BACKUP_DIR"
  [ -f "$SOCIAL_CONFIG_DIR/$SOCIAL_CONFIG_FILE" ] &&
    cp -Rf "$SOCIAL_CONFIG_DIR/$SOCIAL_CONFIG_FILE" "$SOCIAL_CONFIG_BACKUP_DIR/$SOCIAL_CONFIG_FILE.$$"
  cat <<EOF >"$SOCIAL_CONFIG_DIR/$SOCIAL_CONFIG_FILE"
# Settings for social
SOCIAL_COUNTDOWN_TIME="${SOCIAL_COUNTDOWN_TIME:-3}"

# Notification settings
SOCIAL_GOOD_MESSAGE="${SOCIAL_GOOD_MESSAGE:-Everything Went OK}"
SOCIAL_ERROR_MESSAGE="${SOCIAL_ERROR_MESSAGE:-Well something seems to have gone wrong}"
SOCIAL_NOTIFY_ENABLED="${SOCIAL_NOTIFY_ENABLED:-yes}"
SOCIAL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SOCIAL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SOCIAL_NOTIFY_CLIENT_ICON}"

# Colorization settings
SOCIAL_OUTPUT_COLOR="${SOCIAL_OUTPUT_COLOR:-5}"
SOCIAL_OUTPUT_COLOR_GOOD="${SOCIAL_OUTPUT_COLOR_GOOD:-2}"
SOCIAL_OUTPUT_COLOR_ERROR="${SOCIAL_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$SOCIAL_CONFIG_DIR/$SOCIAL_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      unset INIT_CONFIG
      eval bash -c "$APPNAME $*"
      exit
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
post_to_social() {
  printf_newline '\n\n\n'
  local PMESS=
  printf_read_input "5" "What would you like to post? [-q to exit]" "180" "PMESS"
  if [ "$PMESS" = "" ] || [ "$PMESS" = "-q" ] || [ "$PMESS" = "quit" ]; then
    printf_counter 1 3 "Cancelling....." return 1
  else
    am_i_online --error && __devnull post2social "$PMESS" && printf_green "Posting: $PMESS" && sleep 2 ||
      { echo && printf_pause "Failed to post $PMESS \n\t\tPress any key to continue" && return 1; }
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
SOCIAL_LOG_DIR="${SOCIAL_LOG_DIR:-$HOME/.local/log/social}"
SOCIAL_CACHE_DIR="${SOCIAL_CACHE_DIR:-$HOME/.cache/social}"
SOCIAL_CONFIG_DIR="${SOCIAL_CONFIG_DIR:-$HOME/.config/myscripts/social}"
SOCIAL_CONFIG_BACKUP_DIR="${SOCIAL_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/social/backups}"
SOCIAL_TEMP_DIR="${SOCIAL_TEMP_DIR:-$HOME/.local/tmp/system_scripts/social}"
SOCIAL_OPTIONS_DIR="${SOCIAL_OPTIONS_DIR:-$HOME/.local/share/myscripts/social/options}"
SOCIAL_TEMP_FILE="${SOCIAL_TEMP_FILE:-$(mktemp $SOCIAL_TEMP_DIR/XXXXXX 2>/dev/null)}"
SOCIAL_CONFIG_FILE="${SOCIAL_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
SOCIAL_OUTPUT_COLOR="${SOCIAL_OUTPUT_COLOR:-4}"
SOCIAL_OUTPUT_COLOR_2="${SOCIAL_OUTPUT_COLOR:-6}"
SOCIAL_OUTPUT_COLOR_GOOD="${SOCIAL_OUTPUT_COLOR_GOOD:-2}"
SOCIAL_OUTPUT_COLOR_ERROR="${SOCIAL_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
SOCIAL_GOOD_MESSAGE="${SOCIAL_GOOD_MESSAGE:-Everything Went OK}"
SOCIAL_ERROR_MESSAGE="${SOCIAL_ERROR_MESSAGE:-Well something seems to have gone wrong}"
SOCIAL_NOTIFY_ENABLED="${SOCIAL_NOTIFY_ENABLED:-yes}"
SOCIAL_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SOCIAL_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SOCIAL_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
SOCIAL_COUNTDOWN_TIME="${SOCIAL_COUNTDOWN_TIME:-3}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SOCIAL_CONFIG_DIR/$SOCIAL_CONFIG_FILE" ] && . "$SOCIAL_CONFIG_DIR/$SOCIAL_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$SOCIAL_LOG_DIR" ] || mkdir -p "$SOCIAL_LOG_DIR" &>/dev/null
[ -d "$SOCIAL_TEMP_DIR" ] || mkdir -p "$SOCIAL_TEMP_DIR" &>/dev/null
[ -d "$SOCIAL_CACHE_DIR" ] || mkdir -p "$SOCIAL_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$SOCIAL_CONFIG_DIR/$SOCIAL_CONFIG_FILE" ] || __gen_config "$*" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    SOCIAL_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$SOCIAL_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${SOCIAL_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${SOCIAL_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${SOCIAL_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${SOCIAL_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
while :; do
  # show menu
  clear
  printf_newline "\n\n\n\n"
  printf_head "Social Media Menu"
  printf_green "0. open a new window"
  printf_green "a. launch twitter "
  printf_green "b. launch mastodon "
  printf_green "c. launch irssi "
  printf_green "d. launch finch "
  printf_green "x. post to twitter and mastodon "
  printf_green "y. launch custom application"
  printf_green "z. Exit"
  printf_green "---------------------------------"
  printf_read_question_nt "6" "Enter your choice [a-z] : " "1" "main"
  printf_newline

  # take action
  case $main in
  0)
    [ -n "$DISPLAY" ] && myterminal -e "$APPNAME" || printf_error "No display found"
    ;;
  a)
    shift 1
    clear
    cmd_exists rainbowstream && rainbowstream -iot || printf_red "rainbowstream is not installed"
    ;;
  b)
    shift 1
    clear
    cmd_exists tootstream && tootstream || printf_red "tootstream is not installed"
    ;;
  c)
    shift 1
    clear
    cmd_exists irssi && irssi || printf_red "irssi is not installed"
    ;;
  d)
    shift 1
    clear
    cmd_exists finch && finch || printf_red "finch is not installed"
    ;;
  x)
    shift 1
    clear
    post_to_social
    ;;
  y)
    shift 1
    clear
    printf_newline '\n\n\n'
    __custom_menus
    ;;
  $'\E' | $'\e' | z) break ;;
  *) shift ;;
  esac
  clear
  printf_newline "\n\n"
  printf_counter "$SOCIAL_OUTPUT_COLOR" "$SOCIAL_COUNTDOWN_TIME" "Re-loading menu in"
done
clear
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
