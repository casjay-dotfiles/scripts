#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108190105-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$SS_SCREENKEY_TEMP_FILE" ] && rm -Rf "$SS_SCREENKEY_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108190105-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : ss_screenkey --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Aug 19, 2021 01:05 EDT
# @File          : ss_screenkey
# @Description   : screenkey wrapper
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$SS_SCREENKEY_CONFIG_DIR/$SS_SCREENKEY_CONFIG_FILE"
  [ -d "$SS_SCREENKEY_CONFIG_DIR" ] || mkdir -p "$SS_SCREENKEY_CONFIG_DIR"
  [ -d "$SS_SCREENKEY_CONFIG_BACKUP_DIR" ] || mkdir -p "$SS_SCREENKEY_CONFIG_BACKUP_DIR"
  [ -f "$SS_SCREENKEY_CONFIG_DIR/$SS_SCREENKEY_CONFIG_FILE" ] &&
    cp -Rf "$SS_SCREENKEY_CONFIG_DIR/$SS_SCREENKEY_CONFIG_FILE" "$SS_SCREENKEY_CONFIG_BACKUP_DIR/$SS_SCREENKEY_CONFIG_FILE.$$"
  cat <<EOF >"$SS_SCREENKEY_CONFIG_DIR/$SS_SCREENKEY_CONFIG_FILE"
# Settings for ss_screenkey

# Notification settings
SS_SCREENKEY_GOOD_MESSAGE="${SS_SCREENKEY_GOOD_MESSAGE:-Everything Went OK}"
SS_SCREENKEY_ERROR_MESSAGE="${SS_SCREENKEY_ERROR_MESSAGE:-Well that didn\'t work}"
SS_SCREENKEY_NOTIFY_ENABLED="${SS_SCREENKEY_NOTIFY_ENABLED:-yes}"
SS_SCREENKEY_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SS_SCREENKEY_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SS_SCREENKEY_NOTIFY_CLIENT_ICON}"

# Colorization settings
SS_SCREENKEY_OUTPUT_COLOR="${SS_SCREENKEY_OUTPUT_COLOR:-5}"
SS_SCREENKEY_OUTPUT_COLOR_GOOD="${SS_SCREENKEY_OUTPUT_COLOR_GOOD:-2}"
SS_SCREENKEY_OUTPUT_COLOR_ERROR="${SS_SCREENKEY_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$SS_SCREENKEY_CONFIG_DIR/$SS_SCREENKEY_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for ss_screenkey has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
run() {
  __devnull "$1" &
  disown
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__screenkey_start() { run screenkey && notifications "Screenkey" "starting screen key" && return 0 || return 1; }
__screenkey_stop() { __devnull killall screenkey && notifications "Screenkey" "stopping screen key" && return 0 || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
SS_SCREENKEY_LOG_DIR="${SS_SCREENKEY_LOG_DIR:-$HOME/.local/log/ss_screenkey}"
SS_SCREENKEY_CACHE_DIR="${SS_SCREENKEY_CACHE_DIR:-$HOME/.cache/ss_screenkey}"
SS_SCREENKEY_CONFIG_DIR="${SS_SCREENKEY_CONFIG_DIR:-$HOME/.config/myscripts/ss_screenkey}"
SS_SCREENKEY_CONFIG_BACKUP_DIR="${SS_SCREENKEY_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/ss_screenkey/backups}"
SS_SCREENKEY_TEMP_DIR="${SS_SCREENKEY_TEMP_DIR:-$HOME/.local/tmp/system_scripts/ss_screenkey}"
SS_SCREENKEY_OPTIONS_DIR="${SS_SCREENKEY_OPTIONS_DIR:-$HOME/.local/share/myscripts/ss_screenkey/options}"
SS_SCREENKEY_TEMP_FILE="${SS_SCREENKEY_TEMP_FILE:-$(mktemp $SS_SCREENKEY_TEMP_DIR/XXXXXX 2>/dev/null)}"
SS_SCREENKEY_CONFIG_FILE="${SS_SCREENKEY_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
SS_SCREENKEY_OUTPUT_COLOR="${SS_SCREENKEY_OUTPUT_COLOR:-4}"
SS_SCREENKEY_OUTPUT_COLOR_2="${SS_SCREENKEY_OUTPUT_COLOR:-6}"
SS_SCREENKEY_OUTPUT_COLOR_GOOD="${SS_SCREENKEY_OUTPUT_COLOR_GOOD:-2}"
SS_SCREENKEY_OUTPUT_COLOR_ERROR="${SS_SCREENKEY_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
SS_SCREENKEY_GOOD_MESSAGE="${SS_SCREENKEY_GOOD_MESSAGE:-Everything Went OK}"
SS_SCREENKEY_ERROR_MESSAGE="${SS_SCREENKEY_ERROR_MESSAGE:-Well that didn\'t work}"
SS_SCREENKEY_NOTIFY_ENABLED="${SS_SCREENKEY_NOTIFY_ENABLED:-yes}"
SS_SCREENKEY_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SS_SCREENKEY_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SS_SCREENKEY_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SS_SCREENKEY_CONFIG_DIR/$SS_SCREENKEY_CONFIG_FILE" ] && . "$SS_SCREENKEY_CONFIG_DIR/$SS_SCREENKEY_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$SS_SCREENKEY_LOG_DIR" ] || mkdir -p "$SS_SCREENKEY_LOG_DIR" &>/dev/null
[ -d "$SS_SCREENKEY_TEMP_DIR" ] || mkdir -p "$SS_SCREENKEY_TEMP_DIR" &>/dev/null
[ -d "$SS_SCREENKEY_CACHE_DIR" ] || mkdir -p "$SS_SCREENKEY_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$SS_SCREENKEY_CONFIG_DIR/$SS_SCREENKEY_CONFIG_FILE" ] || INIT_CONFIG=TRUE __gen_config "${SETARGS:-$*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    SS_SCREENKEY_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$SS_SCREENKEY_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${SS_SCREENKEY_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${SS_SCREENKEY_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${SS_SCREENKEY_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${SS_SCREENKEY_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check [pmisc=killall]
cmd_exists --error --ask bash screenkey killall || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case $1 in
--help | -h)
  shift 1
  __screenkey_help
  ;;
start)
  shift 1
  __screenkey_start
  ;;
stop)
  shift 1
  __screenkey_stop
  ;;
*)
  shift 0
  __screenkey_stop || __screenkey_start
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
