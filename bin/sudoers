#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108182107-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$SUDOERS_TEMP_FILE" ] && rm -Rf "$SUDOERS_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108182107-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : sudoers --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Aug 18, 2021 21:07 EDT
# @File          : sudoers
# @Description   : add and remove users from sudo
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE"
  [ -d "$SUDOERS_CONFIG_DIR" ] || mkdir -p "$SUDOERS_CONFIG_DIR"
  [ -d "$SUDOERS_CONFIG_BACKUP_DIR" ] || mkdir -p "$SUDOERS_CONFIG_BACKUP_DIR"
  [ -f "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE" ] &&
    cp -Rf "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE" "$SUDOERS_CONFIG_BACKUP_DIR/$SUDOERS_CONFIG_FILE.$$"
  cat <<EOF >"$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE"
# Settings for sudoers

# Notification settings
SUDOERS_GOOD_MESSAGE="${SUDOERS_GOOD_MESSAGE:-Everything Went OK}"
SUDOERS_ERROR_MESSAGE="${SUDOERS_ERROR_MESSAGE:-Well that didn\'t work}"
SUDOERS_NOTIFY_ENABLED="${SUDOERS_NOTIFY_ENABLED:-yes}"
SUDOERS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SUDOERS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SUDOERS_NOTIFY_CLIENT_ICON}"

# Colorization settings
SUDOERS_OUTPUT_COLOR="${SUDOERS_OUTPUT_COLOR:-5}"
SUDOERS_OUTPUT_COLOR_GOOD="${SUDOERS_OUTPUT_COLOR_GOOD:-2}"
SUDOERS_OUTPUT_COLOR_ERROR="${SUDOERS_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE" ]; then
    printf_green "Your config file for sudoers has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
SUDOERS_LOG_DIR="${SUDOERS_LOG_DIR:-$HOME/.local/log/sudoers}"
SUDOERS_CACHE_DIR="${SUDOERS_CACHE_DIR:-$HOME/.cache/sudoers}"
SUDOERS_CONFIG_DIR="${SUDOERS_CONFIG_DIR:-$HOME/.config/myscripts/sudoers}"
SUDOERS_CONFIG_BACKUP_DIR="${SUDOERS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/sudoers/backups}"
SUDOERS_TEMP_DIR="${SUDOERS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/sudoers}"
SUDOERS_OPTIONS_DIR="${SUDOERS_OPTIONS_DIR:-$HOME/.local/share/myscripts/sudoers/options}"
SUDOERS_TEMP_FILE="${SUDOERS_TEMP_FILE:-$(mktemp $SUDOERS_TEMP_DIR/XXXXXX 2>/dev/null)}"
SUDOERS_CONFIG_FILE="${SUDOERS_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
SUDOERS_OUTPUT_COLOR="${SUDOERS_OUTPUT_COLOR:-4}"
SUDOERS_OUTPUT_COLOR_2="${SUDOERS_OUTPUT_COLOR:-6}"
SUDOERS_OUTPUT_COLOR_GOOD="${SUDOERS_OUTPUT_COLOR_GOOD:-2}"
SUDOERS_OUTPUT_COLOR_ERROR="${SUDOERS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
SUDOERS_GOOD_MESSAGE="${SUDOERS_GOOD_MESSAGE:-Everything Went OK}"
SUDOERS_ERROR_MESSAGE="${SUDOERS_ERROR_MESSAGE:-Well that didn\'t work}"
SUDOERS_NOTIFY_ENABLED="${SUDOERS_NOTIFY_ENABLED:-yes}"
SUDOERS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SUDOERS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SUDOERS_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE" ] && . "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$SUDOERS_LOG_DIR" ] || mkdir -p "$SUDOERS_LOG_DIR" &>/dev/null
[ -d "$SUDOERS_TEMP_DIR" ] || mkdir -p "$SUDOERS_TEMP_DIR" &>/dev/null
[ -d "$SUDOERS_CACHE_DIR" ] || mkdir -p "$SUDOERS_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY="remove,pass,remuser,adduser,nopass,insults,status,users"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    SUDOERS_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$SUDOERS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${SUDOERS_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${SUDOERS_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${SUDOERS_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${SUDOERS_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
if ! __can_i_sudo; then
  printf_red "You dont have access to sudo"
  printf_exit "Please contact the syadmin for access"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
MYUSER="${USER:-$(whoami)}"
[ -n "$2" ] && MYUSER="$2" || MYUSER="$USER"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ $# -ne 0 ]; then
  __devnull sudo chmod 750 /etc/sudoers.d
  case "$1" in
  remove)
    shift 1
    printf_read_question "1" "This will remove access to sudo: continue?" "1" "YN"
    if printf_answer_yes "$YN"; then
      printf_read_question "6" "Should we setup/change root password" "1" "ROOTPW"
      printf_answer_yes "$ROOTPW" && __newpasswd root
      __newpasswd "$MYUSER" || exit 1
      printf_green "Removing $MYUSER sudoers file"
      __devnull sudo rm -Rf "/etc/sudoers.d/$MYUSER"
      exit $?
    fi
    ;;
  pass)
    shift 1
    printf_read_question "1" "Would you like to reset your password?" "1" "YN"
    printf_green "Removing $MYUSER from sudoers"
    if printf_answer_yes "$YN"; then __newpasswd "$MYUSER" || exit 1; fi
    __devnull sudo rm -Rf "/etc/sudoers.d/$MYUSER"
    [ -f "/etc/sudoers.d/$MYUSER" ] || printf_red "Your password will now required"
    exit $?
    ;;
  remuser)
    shift 1
    printf_green "Removing $MYUSER from sudoers"
    __newpasswd "$MYUSER" || exit 1
    if __sudo_group "$MYUSER"; then
      __devnull sudo deluser "$MYUSER" sudo
    else
      __devnull sudo deluser "$MYUSER" wheel
    fi
    __devnull sudo rm -Rf "/etc/sudoers.d/$MYUSER"
    exit $?
    ;;
  adduser)
    shift 1
    printf_green "Adding $MYUSER to sudoers"
    if __sudo_group "$MYUSER"; then
      __devnull sudo usermod -aG sudo "$MYUSER"
    else
      __devnull sudo usermod -aG wheel "$MYUSER"
    fi
    echo "$MYUSER ALL=(ALL)   NOPASSWD: ALL" | sudo tee "/etc/sudoers.d/$MYUSER" &>/dev/null
    __devnull sudo chown -f root:root "/etc/sudoers.d/$MYUSER"
    __devnull sudo chmod -f 440 "/etc/sudoers.d/$MYUSER"
    exit $?
    ;;
  nopass)
    shift 1
    printf_green "Adding $MYUSER to sudoers"
    echo "$MYUSER ALL=(ALL)   NOPASSWD: ALL" | sudo tee "/etc/sudoers.d/$MYUSER" &>/dev/null
    __devnull sudo chown -f root:root "/etc/sudoers.d/$MYUSER"
    __devnull sudo chmod -f 440 "/etc/sudoers.d/$MYUSER"
    exit $?
    ;;
  insults)
    shift 1
    printf_green "Adding insults"
    echo "Defaults    insults" | sudo tee "/etc/sudoers.d/insults" &>/dev/null
    __devnull sudo chown -f root:root "/etc/sudoers.d/insults"
    exit $?
    ;;
  status)
    shift 1
    if [ -f "/etc/sudoers.d/$MYUSER" ] || __sudo_group "$MYUSER"; then
      printf_green "You appear to have access to sudo"
    else
      printf_red "You don't seem to be in the sudo file"
    fi
    exit $?
    ;;
  users)
    shift 1
    case $1 in
    add | new)
      shift 1
      printf_blue "Creating user $1 "
      if grep -vsq "$1" /etc/passwd; then
        #sudo groupadd "$1" &>/dev/null
        sudo useradd -m -g "$1" "$1" &>/dev/null
        sudo useradd -g users -G wheel "$1" &>/dev/null
        if grep -sq "$1" /etc/passwd; then
          __newpasswd "$1"
          printf_green "Successfully created user"
          exitCode=0
        else
          printf_red "Failed to create user"
          exitCode=1
        fi
      else
        printf_red "User $1 already exists"
      fi
      exit ${exitCode:-$?}
      ;;
    delete | remove)
      shift 1
      printf_blue "Deleting user $1 "
      if grep -sq "$1" /etc/passwd; then
        sudo groupdel "$1" &>/dev/null
        sudo userdel -f -r "$1" &>/dev/null
        grep -vsq "$1" /etc/groups &&
          printf_exit 2 0 "Successfully delete user" ||
          printf_exit 1 1 "Failed to delete user"
      else
        printf_exit "User $1 does not exist"
      fi
      ;;
    esac
    ;;
  *)
    ARGS="$*"
    sudo "$ARGS" && true || false
    ;;
  esac
else
  __help
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
