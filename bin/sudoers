#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108062113-git"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#set opts
trap 'exitCode=${exitCode:-$?};[ -f "$SUDOERS_TEMP_FILE" ] && rm -Rf "$SUDOERS_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108062113-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : sudoers --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, CasjaysDev
# @Created       : Friday, Aug 06, 2021 21:13 EDT
# @File          : sudoers
# @Description   : add and remove users from sudo
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE"
  [ -d "$SUDOERS_CONFIG_DIR" ] || mkdir -p "$SUDOERS_CONFIG_DIR"
  [ -d "$SUDOERS_CONFIG_BACKUP_DIR" ] || mkdir -p "$SUDOERS_CONFIG_BACKUP_DIR"
  [ -f "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE" ] &&
    cp -Rf "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE" "$SUDOERS_CONFIG_BACKUP_DIR/$SUDOERS_CONFIG_FILE.$$"
  cat <<EOF >"$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE"
# Settings for sudoers
SUDOERS_TEMP_FILE="${TMPDIR:-/tmp}/sudoers"
SUDOERS_NOTIFY_ENABLED="yes"
SUDOERS_NOTIFY_CLIENT_NAME="\${NOTIFY_CLIENT_NAME:-\$APPNAME}"
SUDOERS_NOTIFY_CLIENT_ICON="\${NOTIFY_CLIENT_ICON:-\$SUDOERS_NOTIFY_CLIENT_ICON}"

EOF
  if [ -f "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE" ]; then
    printf_green "Your config file for sudoers has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__list_available() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Defaults
exitCode=""
SUDOERS_CONFIG_FILE="settings.conf"
SUDOERS_CONFIG_DIR="$HOME/.config/myscripts/sudoers"
SUDOERS_CONFIG_BACKUP_DIR="$HOME/.local/share/myscripts/sudoers/backups"
SUDOERS_OPTIONS_DIR="$HOME/.local/share/myscripts/sudoers/options"
SUDOERS_TEMP_FILE="${TMPDIR:-/tmp}/sudoers"
SUDOERS_NOTIFY_ENABLED="yes"
SUDOERS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
SUDOERS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$SUDOERS_NOTIFY_CLIENT_ICON}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h"
LONGOPTS="options,config,version,help"
ARRAY="remove,pass,remuser,adduser,nopass,insults,status,users"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate Files
[ -f "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE" ] && . "$SUDOERS_CONFIG_DIR/$SUDOERS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_available "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_available "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_available "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  -v | --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  -c | --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
export NOTIFY_CLIENT_NAME="${SUDOERS_NOTIFY_CLIENT_NAME}"
export NOTIFY_CLIENT_ICON="${SUDOERS_NOTIFY_CLIENT_ICON}"
if [ "$SUDOERS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash || exit 1 # exit 1 if not found
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables
MYUSER="${USER:-$(whoami)}"
ARRAY="remove remuser adduser pass nopass insults status -c"
[ $# = 0 ] && __help
[ -n "$2" ] && MYUSER="$2" || MYUSER="$USER"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ $# -ne 0 ] && __can_i_sudo; then
  __devnull __sudo chmod 750 /etc/sudoers.d
  case "$1" in
  remove)
    shift 1
    printf_read_question "1" "This will remove access to sudo: continue?" "1" "YN"
    if printf_answer_yes "$YN"; then
      printf_read_question "6" "Should we setup/change root password" "1" "ROOTPW"
      printf_answer_yes "$ROOTPW" && __newpasswd root
      __newpasswd "$MYUSER" || exit 1
      printf_green "Removing $MYUSER sudoers file"
      __devnull __sudo rm -Rf "/etc/sudoers.d/$MYUSER"
      exit $?
    fi
    ;;
  pass)
    shift 1
    printf_read_question "1" "Would you like to reset your password?" "1" "YN"
    printf_green "Removing $MYUSER from sudoers"
    if printf_answer_yes "$YN"; then __newpasswd "$MYUSER" || exit 1; fi
    __devnull __sudo rm -Rf "/etc/sudoers.d/$MYUSER"
    [ -f "/etc/sudoers.d/$MYUSER" ] || printf_red "Your password will now required"
    exit $?
    ;;
  remuser)
    shift 1
    printf_green "Removing $MYUSER from sudoers"
    __newpasswd "$MYUSER" || exit 1
    if __sudo_group "$MYUSER"; then
      __devnull __sudo deluser "$MYUSER" sudo
    else
      __devnull __sudo deluser "$MYUSER" wheel
    fi
    __devnull __sudo rm -Rf "/etc/sudoers.d/$MYUSER"
    exit $?
    ;;
  adduser)
    shift 1
    printf_green "Adding $MYUSER to sudoers"
    if __sudo_group "$MYUSER"; then
      __devnull __sudo usermod -aG sudo "$MYUSER"
    else
      __devnull __sudo usermod -aG wheel "$MYUSER"
    fi
    echo "$MYUSER ALL=(ALL)   NOPASSWD: ALL" | __sudo tee "/etc/sudoers.d/$MYUSER" &>/dev/null
    __devnull __sudo chown -f root:root "/etc/sudoers.d/$MYUSER"
    __devnull __sudo chmod -f 440 "/etc/sudoers.d/$MYUSER"
    exit $?
    ;;
  nopass)
    shift 1
    printf_green "Adding $MYUSER to sudoers"
    echo "$MYUSER ALL=(ALL)   NOPASSWD: ALL" | __sudo tee "/etc/sudoers.d/$MYUSER" &>/dev/null
    __devnull __sudo chown -f root:root "/etc/sudoers.d/$MYUSER"
    __devnull __sudo chmod -f 440 "/etc/sudoers.d/$MYUSER"
    exit $?
    ;;
  insults)
    shift 1
    printf_green "Adding insults"
    echo "Defaults    insults" | __sudo tee "/etc/sudoers.d/insults" &>/dev/null
    __devnull __sudo chown -f root:root "/etc/sudoers.d/insults"
    exit $?
    ;;
  status)
    shift 1
    if [ -f "/etc/sudoers.d/$MYUSER" ] || __sudo_group "$MYUSER"; then
      printf_green "You appear to have access to sudo"
    else
      printf_red "You don't seem to be in the sudo file"
    fi
    exit $?
    ;;
  users)
    shift 1
    case $1 in
    add | new)
      shift 1
      printf_blue "Creating user $1 "
      if grep -vsq "$1" /etc/passwd; then
        __sudo groupadd "$1" &>/dev/null
        __sudo useradd -m -g "$1" "$1" &>/dev/null
        __sudo useradd -g users -G wheel "$1" &>/dev/null
        __sudo passwd "$1" &>/dev/null
        grep -sq "$1" /etc/passwd &&
          printf_exit 2 0 "Successfully created user" ||
          printf_exit 1 1 "Failed to create user"
      else
        printf_exit "User $1 already exists"
      fi
      ;;
    delete | remove)
      shift 1
      printf_blue "Deleting user $1 "
      if grep -sq "$1" /etc/passwd; then
        __sudo groupdel "$1" &>/dev/null
        __sudo userdel -f -r "$1" &>/dev/null
        grep -vsq "$1" /etc/groups &&
          printf_exit 2 0 "Successfully delete user" ||
          printf_exit 1 1 "Failed to delete user"
      else
        printf_exit "User $1 does not exist"
      fi
      ;;
    esac
    ;;
  *)
    ARGS="$*"
    __requiresudo "$ARGS" && true || false
    ;;
  esac
else
  printf_red "You dont have access to sudo"
  printf_red "Please contact the syadmin for access"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
