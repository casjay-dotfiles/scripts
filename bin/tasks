#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108182107-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -f "$TASKS_TEMP_FILE" ] && rm -Rf "$TASKS_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108182107-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : tasks --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Aug 18, 2021 21:07 EDT
# @File          : tasks
# @Description   : wrapper for tash
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Generating the config file in"
  [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "$TASKS_CONFIG_DIR/$TASKS_CONFIG_FILE"
  [ -d "$TASKS_CONFIG_DIR" ] || mkdir -p "$TASKS_CONFIG_DIR"
  [ -d "$TASKS_CONFIG_BACKUP_DIR" ] || mkdir -p "$TASKS_CONFIG_BACKUP_DIR"
  [ -f "$TASKS_CONFIG_DIR/$TASKS_CONFIG_FILE" ] &&
    cp -Rf "$TASKS_CONFIG_DIR/$TASKS_CONFIG_FILE" "$TASKS_CONFIG_BACKUP_DIR/$TASKS_CONFIG_FILE.$$"
  cat <<EOF >"$TASKS_CONFIG_DIR/$TASKS_CONFIG_FILE"
# Settings for tasks
TASKS_START_OF_WEEK="${TASKS_START_OF_WEEK:-monday}"
TASKS_DATABASE="${TASKS_DATABASE:-$TASKS_CONFIG_DIR/tasks.db}"
TASKS_TASH_BIN="${TASKS_TASH_BIN:-$CASJAYSDEVDIR/sources}"

# Notification settings
TASKS_GOOD_MESSAGE="${TASKS_GOOD_MESSAGE:-Everything Went OK}"
TASKS_ERROR_MESSAGE="${TASKS_ERROR_MESSAGE:-Well that didn\'t work}"
TASKS_NOTIFY_ENABLED="${TASKS_NOTIFY_ENABLED:-yes}"
TASKS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TASKS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TASKS_NOTIFY_CLIENT_ICON}"

# Colorization settings
TASKS_OUTPUT_COLOR="${TASKS_OUTPUT_COLOR:-5}"
TASKS_OUTPUT_COLOR_GOOD="${TASKS_OUTPUT_COLOR_GOOD:-2}"
TASKS_OUTPUT_COLOR_ERROR="${TASKS_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$TASKS_CONFIG_DIR/$TASKS_CONFIG_FILE" ]; then
    [[ -n "$SHOW_CONFIG_MESSAGE" ]] || printf_green "Your config file for tasks has been created"
    exitCode=0
    exec $APPNAME "$*"
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__tash() { [[ -f "$TASKS_TASH_BIN/tash" ]] && $TASKS_TASH_BIN/tash "$@" | printf_readline "3"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
TASKS_LOG_DIR="${TASKS_LOG_DIR:-$HOME/.local/log/tasks}"
TASKS_CACHE_DIR="${TASKS_CACHE_DIR:-$HOME/.cache/tasks}"
TASKS_CONFIG_DIR="${TASKS_CONFIG_DIR:-$HOME/.config/myscripts/tasks}"
TASKS_CONFIG_BACKUP_DIR="${TASKS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/tasks/backups}"
TASKS_TEMP_DIR="${TASKS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/tasks}"
TASKS_OPTIONS_DIR="${TASKS_OPTIONS_DIR:-$HOME/.local/share/myscripts/tasks/options}"
TASKS_TEMP_FILE="${TASKS_TEMP_FILE:-$(mktemp $TASKS_TEMP_DIR/XXXXXX 2>/dev/null)}"
TASKS_CONFIG_FILE="${TASKS_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
TASKS_OUTPUT_COLOR="${TASKS_OUTPUT_COLOR:-4}"
TASKS_OUTPUT_COLOR_2="${TASKS_OUTPUT_COLOR:-6}"
TASKS_OUTPUT_COLOR_GOOD="${TASKS_OUTPUT_COLOR_GOOD:-2}"
TASKS_OUTPUT_COLOR_ERROR="${TASKS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
TASKS_GOOD_MESSAGE="${TASKS_GOOD_MESSAGE:-Everything Went OK}"
TASKS_ERROR_MESSAGE="${TASKS_ERROR_MESSAGE:-Well that didn\'t work}"
TASKS_NOTIFY_ENABLED="${TASKS_NOTIFY_ENABLED:-yes}"
TASKS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TASKS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TASKS_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
TASKS_TASH_BIN="${TASKS_TASH_BIN:-$CASJAYSDEVDIR/sources}"
TASKS_START_OF_WEEK="${TASKS_START_OF_WEEK:-monday}"
TASKS_DATABASE="${TASKS_DATABASE:-$TASKS_CONFIG_DIR/tasks.db}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$TASKS_CONFIG_DIR/$TASKS_CONFIG_FILE" ] && . "$TASKS_CONFIG_DIR/$TASKS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$TASKS_LOG_DIR" ] || mkdir -p "$TASKS_LOG_DIR" &>/dev/null
[ -d "$TASKS_TEMP_DIR" ] || mkdir -p "$TASKS_TEMP_DIR" &>/dev/null
[ -d "$TASKS_CACHE_DIR" ] || mkdir -p "$TASKS_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$TASKS_CONFIG_DIR/$TASKS_CONFIG_FILE" ] || SHOW_CONFIG_MESSAGE=NO __gen_config "$*"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    TASKS_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$TASKS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${TASKS_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${TASKS_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${TASKS_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${TASKS_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash sqlite3 || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
export TASH_DATABASE="$TASKS_DATABASE"
export TASH_START_DAY="$TASKS_START_OF_WEEK"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
add)
  shift 1
  if [ $# -ne 0 ]; then
    __tash add "$*"
  else
    printf_read_question "4" "What is the name of your Project?" "120" "PROJECT"
    printf_read_question "4" 'What is your projects description?' "120" "DESC"
    __tash add "@$PROJECT" "$DESC"
  fi
  ;;

delete | remove | rm)
  shift 1
  if [ $# -ne 0 ]; then
    __tash "$*" "delete"
  else
    printf_read_question "4" "What task would you like to delete?" "120" "TASK_NUM"
    echo y | __tash "$TASK_NUM" "delete"
  fi
  ;;

start)
  shift 1
  if [ $# -ne 0 ]; then
    __tash "$*" "start"
  else
    printf_read_question "4" "What task would you like to start?" "120" "TASK_NUM"
    __tash "$TASK_NUM" "start"
  fi
  ;;

stop)
  shift 1
  if [ $# -ne 0 ]; then
    __tash "$*" "stop"
  else
    printf_read_question "4" "What task would you like to stop?" "120" "TASK_NUM"
    __tash "$TASK_NUM" "stop"
  fi
  ;;

switch | sw)
  shift 1
  if [ $# -ne 0 ]; then
    __tash "$*" "switch"
  else
    printf_read_question "4" "What task would you like to switch to?" "120" "TASK_NUM"
    __tash "$TASK_NUM" "switch"
  fi
  ;;

session)
  shift 1
  if [ $# -ne 0 ]; then
    __tash "$*" "session"
  else
    printf_read_question "4" "What is the duration?" "120" "PARAM"
    printf_read_question "4" "What task would you like to set?" "120" "TASK_NUM"
    __tash "$TASK_NUM" "session" "$PARAM"
  fi
  ;;

done)
  shift 1
  if [ $# -ne 0 ]; then
    __tash "$*" "done"
  else
    printf_read_question "4" "What task would you like to mark as done?" "120" "TASK_NUM"
    __tash "$TASK_NUM" "done"
  fi
  ;;

info)
  shift 1
  if [ $# -ne 0 ]; then
    __tash "$*" "info"
  else
    printf_read_question "4" "What task number would you like info on?" "120" "TASK_NUM"
    __tash "$TASK_NUM" "info"
  fi
  ;;

report)
  shift 1
  if [ $# -ne 0 ]; then
    __tash report "$*"
  else
    printf_read_question "4" "What task would you like the report on?" "120" "PARAM"
    __tash report "$PARAM"
  fi
  ;;

list)
  shift 1
  if [ $# -ne 0 ]; then
    __tash list "$*"
  else
    __tash list "$PARAM"
  fi
  ;;

clean | cleanup)
  shift 1
  __tash clean
  ;;

"-?" | -h)
  shift 1
  __tash -h | printf_readline $TASKS_OUTPUT_COLOR
  exit $?
  ;;

*)
  __tash "$@"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
