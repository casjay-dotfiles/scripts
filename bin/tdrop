#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108182107-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$TDROP_TEMP_FILE" ] && rm -Rf "$TDROP_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108182107-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : tdrop --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Aug 18, 2021 21:07 EDT
# @File          : tdrop
# @Description   : A Glorified WM-Independent Dropdown Creator
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$TDROP_CONFIG_DIR/$TDROP_CONFIG_FILE"
  [ -d "$TDROP_CONFIG_DIR" ] || mkdir -p "$TDROP_CONFIG_DIR"
  [ -d "$TDROP_CONFIG_BACKUP_DIR" ] || mkdir -p "$TDROP_CONFIG_BACKUP_DIR"
  [ -f "$TDROP_CONFIG_DIR/$TDROP_CONFIG_FILE" ] &&
    cp -Rf "$TDROP_CONFIG_DIR/$TDROP_CONFIG_FILE" "$TDROP_CONFIG_BACKUP_DIR/$TDROP_CONFIG_FILE.$$"
  cat <<EOF >"$TDROP_CONFIG_DIR/$TDROP_CONFIG_FILE"
# Settings for tdrop
TDROP_BIN_DIR="${TDROP_BIN_DIR:-$CASJAYSDEVDIR/sources}"

# Notification settings
TDROP_GOOD_MESSAGE="${TDROP_GOOD_MESSAGE:-Everything Went OK}"
TDROP_ERROR_MESSAGE="${TDROP_ERROR_MESSAGE:-Well that didn\'t work}"
TDROP_NOTIFY_ENABLED="${TDROP_NOTIFY_ENABLED:-yes}"
TDROP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TDROP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TDROP_NOTIFY_CLIENT_ICON}"

# Colorization settings
TDROP_OUTPUT_COLOR="${TDROP_OUTPUT_COLOR:-5}"
TDROP_OUTPUT_COLOR_GOOD="${TDROP_OUTPUT_COLOR_GOOD:-2}"
TDROP_OUTPUT_COLOR_ERROR="${TDROP_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$TDROP_CONFIG_DIR/$TDROP_CONFIG_FILE" ]; then
    printf_green "Your config file for tdrop has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
TDROP_CACHE_DIR="${TDROP_CACHE_DIR:-$HOME/.cache/tdrop}"
TDROP_CONFIG_DIR="${TDROP_CONFIG_DIR:-$HOME/.config/myscripts/tdrop}"
TDROP_OPTIONS_DIR="${TDROP_OPTIONS_DIR:-$HOME/.local/share/myscripts/tdrop/options}"
TDROP_CONFIG_BACKUP_DIR="${TDROP_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/tdrop/backups}"
TDROP_TEMP_DIR="${TDROP_TEMP_DIR:-$HOME/.local/tmp/system_scripts/tdrop}"
TDROP_TEMP_FILE="${TDROP_TEMP_FILE:-$(mktemp $TDROP_TEMP_DIR/XXXXXX)}"
TDROP_CONFIG_FILE="${TDROP_CONFIG_FILE:-settings.conf}"
TDROP_GOOD_MESSAGE="${TDROP_GOOD_MESSAGE:-Everything Went OK}"
TDROP_ERROR_MESSAGE="${TDROP_ERROR_MESSAGE:-Well that didn\'t work}"
TDROP_NOTIFY_ENABLED="${TDROP_NOTIFY_ENABLED:-yes}"
TDROP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TDROP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TDROP_NOTIFY_CLIENT_ICON}"
TDROP_OUTPUT_COLOR="${TDROP_OUTPUT_COLOR:-5}"
TDROP_OUTPUT_COLOR_GOOD="${TDROP_OUTPUT_COLOR_GOOD:-2}"
TDROP_OUTPUT_COLOR_ERROR="${TDROP_OUTPUT_COLOR_ERROR:-1}"
TDROP_BIN_DIR="${TDROP_BIN_DIR:-$CASJAYSDEVDIR/sources}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$TDROP_TEMP_DIR" ] || mkdir -p "$TDROP_TEMP_DIR" &>/dev/null
[ -d "$TDROP_CACHE_DIR" ] || mkdir -p "$TDROP_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$TDROP_CONFIG_DIR/$TDROP_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$TDROP_CONFIG_DIR/$TDROP_CONFIG_FILE" ] &&
  . "$TDROP_CONFIG_DIR/$TDROP_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    TDROP_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$TDROP_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${TDROP_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${TDROP_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${TDROP_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${TDROP_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ -f "$TDROP_BIN_DIR/tdrop" ]; then
  $TDROP_BIN_DIR/tdrop $SETARGS
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
