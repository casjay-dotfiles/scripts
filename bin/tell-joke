#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108182107-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -euo pipefail
trap 'exitCode=${exitCode:-$?};[ -f "$TELL_JOKE_TEMP_FILE" ] && rm -Rf "$TELL_JOKE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108182107-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : tell-joke --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Aug 18, 2021 21:07 EDT
# @File          : tell-joke
# @Description   : Tell me a random joke from icndb.com
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$TELL_JOKE_CONFIG_DIR/$TELL_JOKE_CONFIG_FILE"
  [ -d "$TELL_JOKE_CONFIG_DIR" ] || mkdir -p "$TELL_JOKE_CONFIG_DIR"
  [ -d "$TELL_JOKE_CONFIG_BACKUP_DIR" ] || mkdir -p "$TELL_JOKE_CONFIG_BACKUP_DIR"
  [ -f "$TELL_JOKE_CONFIG_DIR/$TELL_JOKE_CONFIG_FILE" ] &&
    cp -Rf "$TELL_JOKE_CONFIG_DIR/$TELL_JOKE_CONFIG_FILE" "$TELL_JOKE_CONFIG_BACKUP_DIR/$TELL_JOKE_CONFIG_FILE.$$"
  cat <<EOF >"$TELL_JOKE_CONFIG_DIR/$TELL_JOKE_CONFIG_FILE"
# Settings for tell-joke
TELL_JOKE_API_URL="${TELL_JOKE_API_URL:-https://api.icndb.com/jokes/random}"

# Notification settings
TELL_JOKE_GOOD_MESSAGE="${TELL_JOKE_GOOD_MESSAGE:-Everything Went OK}"
TELL_JOKE_ERROR_MESSAGE="${TELL_JOKE_ERROR_MESSAGE:-Well that didn\'t work}"
TELL_JOKE_NOTIFY_ENABLED="${TELL_JOKE_NOTIFY_ENABLED:-yes}"
TELL_JOKE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TELL_JOKE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TELL_JOKE_NOTIFY_CLIENT_ICON}"

# Colorization settings
TELL_JOKE_OUTPUT_COLOR="${TELL_JOKE_OUTPUT_COLOR:-5}"
TELL_JOKE_OUTPUT_COLOR_GOOD="${TELL_JOKE_OUTPUT_COLOR_GOOD:-2}"
TELL_JOKE_OUTPUT_COLOR_ERROR="${TELL_JOKE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$TELL_JOKE_CONFIG_DIR/$TELL_JOKE_CONFIG_FILE" ]; then
    printf_green "Your config file for tell-joke has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__get_joke() {
  __curl "$TELL_JOKE_API_URL" |
    jq '.value.joke' | sed 's/<[^>]*>//g;s|&quot;||g;s|\.|\.\n|g;s|"||g;s|\?|\?\n|g;/^$/d;s|, |,\n|g' | sed 's/^[ \t]*//'
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
TELL_JOKE_LOG_DIR="${TELL_JOKE_LOG_DIR:-$HOME/.local/log/tell-joke}"
TELL_JOKE_CACHE_DIR="${TELL_JOKE_CACHE_DIR:-$HOME/.cache/tell-joke}"
TELL_JOKE_CONFIG_DIR="${TELL_JOKE_CONFIG_DIR:-$HOME/.config/myscripts/tell-joke}"
TELL_JOKE_CONFIG_BACKUP_DIR="${TELL_JOKE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/tell-joke/backups}"
TELL_JOKE_TEMP_DIR="${TELL_JOKE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/tell-joke}"
TELL_JOKE_OPTIONS_DIR="${TELL_JOKE_OPTIONS_DIR:-$HOME/.local/share/myscripts/tell-joke/options}"
TELL_JOKE_TEMP_FILE="${TELL_JOKE_TEMP_FILE:-$(mktemp $TELL_JOKE_TEMP_DIR/XXXXXX 2>/dev/null)}"
TELL_JOKE_CONFIG_FILE="${TELL_JOKE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
TELL_JOKE_OUTPUT_COLOR="${TELL_JOKE_OUTPUT_COLOR:-4}"
TELL_JOKE_OUTPUT_COLOR_2="${TELL_JOKE_OUTPUT_COLOR:-6}"
TELL_JOKE_OUTPUT_COLOR_GOOD="${TELL_JOKE_OUTPUT_COLOR_GOOD:-2}"
TELL_JOKE_OUTPUT_COLOR_ERROR="${TELL_JOKE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
TELL_JOKE_GOOD_MESSAGE="${TELL_JOKE_GOOD_MESSAGE:-Everything Went OK}"
TELL_JOKE_ERROR_MESSAGE="${TELL_JOKE_ERROR_MESSAGE:-Well that didn\'t work}"
TELL_JOKE_NOTIFY_ENABLED="${TELL_JOKE_NOTIFY_ENABLED:-yes}"
TELL_JOKE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TELL_JOKE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TELL_JOKE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
TELL_JOKE_API_URL="${TELL_JOKE_API_URL:-https://api.icndb.com/jokes/random}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$TELL_JOKE_CONFIG_DIR/$TELL_JOKE_CONFIG_FILE" ] && . "$TELL_JOKE_CONFIG_DIR/$TELL_JOKE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$TELL_JOKE_LOG_DIR" ] || mkdir -p "$TELL_JOKE_LOG_DIR" &>/dev/null
[ -d "$TELL_JOKE_TEMP_DIR" ] || mkdir -p "$TELL_JOKE_TEMP_DIR" &>/dev/null
[ -d "$TELL_JOKE_CACHE_DIR" ] || mkdir -p "$TELL_JOKE_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$TELL_JOKE_CONFIG_DIR/$TELL_JOKE_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    TELL_JOKE_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$TELL_JOKE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${TELL_JOKE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${TELL_JOKE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${TELL_JOKE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${TELL_JOKE_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash jq || exit 1 # exit 1 if not found
am_i_online --error || exit 1              # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
printf "\n"
__get_joke | printf_readline $TELL_JOKE_OUTPUT_COLOR
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
