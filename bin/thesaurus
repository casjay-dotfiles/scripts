#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108181957-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : thesaurus --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Aug 18, 2021 19:57 EDT
# @File          : thesaurus
# @Description   : Thesaurus
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108181957-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$THESAURUS_TEMP_FILE" ] && [ -f "$THESAURUS_TEMP_FILE" ] && rm -Rf "$THESAURUS_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$THESAURUS_CONFIG_DIR/$THESAURUS_CONFIG_FILE"
  [ -d "$THESAURUS_CONFIG_DIR" ] || mkdir -p "$THESAURUS_CONFIG_DIR"
  [ -d "$THESAURUS_CONFIG_BACKUP_DIR" ] || mkdir -p "$THESAURUS_CONFIG_BACKUP_DIR"
  [ -f "$THESAURUS_CONFIG_DIR/$THESAURUS_CONFIG_FILE" ] &&
    cp -Rf "$THESAURUS_CONFIG_DIR/$THESAURUS_CONFIG_FILE" "$THESAURUS_CONFIG_BACKUP_DIR/$THESAURUS_CONFIG_FILE.$$"
  cat <<EOF >"$THESAURUS_CONFIG_DIR/$THESAURUS_CONFIG_FILE"
# Settings for thesaurus
THESAURUS_SERVER_HOST="${THESAURUS_SERVER_HOST:-dict.org}"
THESAURUS_SERVER_PORT="${THESAURUS_SERVER_PORT:-2628}"

# Notification settings
THESAURUS_GOOD_MESSAGE="${THESAURUS_GOOD_MESSAGE:-Everything Went OK}"
THESAURUS_ERROR_MESSAGE="${THESAURUS_ERROR_MESSAGE:-Well that didn\'t work}"
THESAURUS_NOTIFY_ENABLED="${THESAURUS_NOTIFY_ENABLED:-yes}"
THESAURUS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
THESAURUS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$THESAURUS_NOTIFY_CLIENT_ICON}"

# Colorization settings
THESAURUS_OUTPUT_COLOR="${THESAURUS_OUTPUT_COLOR:-5}"
THESAURUS_OUTPUT_COLOR_GOOD="${THESAURUS_OUTPUT_COLOR_GOOD:-2}"
THESAURUS_OUTPUT_COLOR_ERROR="${THESAURUS_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$THESAURUS_CONFIG_DIR/$THESAURUS_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for thesaurus has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      eval $APPNAME "$*"
      exit $?
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
THESAURUS_LOG_DIR="${THESAURUS_LOG_DIR:-$HOME/.local/log/thesaurus}"
THESAURUS_CACHE_DIR="${THESAURUS_CACHE_DIR:-$HOME/.cache/thesaurus}"
THESAURUS_CONFIG_DIR="${THESAURUS_CONFIG_DIR:-$HOME/.config/myscripts/thesaurus}"
THESAURUS_CONFIG_BACKUP_DIR="${THESAURUS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/thesaurus/backups}"
THESAURUS_TEMP_DIR="${THESAURUS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/thesaurus}"
THESAURUS_OPTIONS_DIR="${THESAURUS_OPTIONS_DIR:-$HOME/.local/share/myscripts/thesaurus/options}"
THESAURUS_TEMP_FILE="${THESAURUS_TEMP_FILE:-$(mktemp $THESAURUS_TEMP_DIR/XXXXXX 2>/dev/null)}"
THESAURUS_CONFIG_FILE="${THESAURUS_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
THESAURUS_OUTPUT_COLOR="${THESAURUS_OUTPUT_COLOR:-4}"
THESAURUS_OUTPUT_COLOR_2="${THESAURUS_OUTPUT_COLOR:-6}"
THESAURUS_OUTPUT_COLOR_GOOD="${THESAURUS_OUTPUT_COLOR_GOOD:-2}"
THESAURUS_OUTPUT_COLOR_ERROR="${THESAURUS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
THESAURUS_GOOD_MESSAGE="${THESAURUS_GOOD_MESSAGE:-Everything Went OK}"
THESAURUS_ERROR_MESSAGE="${THESAURUS_ERROR_MESSAGE:-Well that didn\'t work}"
THESAURUS_NOTIFY_ENABLED="${THESAURUS_NOTIFY_ENABLED:-yes}"
THESAURUS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
THESAURUS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$THESAURUS_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
THESAURUS_SERVER_HOST="${THESAURUS_SERVER_HOST:-dict.org}"
THESAURUS_SERVER_PORT="${THESAURUS_SERVER_PORT:-2628}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$THESAURUS_CONFIG_DIR/$THESAURUS_CONFIG_FILE" ] && . "$THESAURUS_CONFIG_DIR/$THESAURUS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$THESAURUS_LOG_DIR" ] || mkdir -p "$THESAURUS_LOG_DIR" &>/dev/null
[ -d "$THESAURUS_TEMP_DIR" ] || mkdir -p "$THESAURUS_TEMP_DIR" &>/dev/null
[ -d "$THESAURUS_CACHE_DIR" ] || mkdir -p "$THESAURUS_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$THESAURUS_CONFIG_DIR/$THESAURUS_CONFIG_FILE" ] && [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    THESAURUS_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$THESAURUS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${THESAURUS_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${THESAURUS_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${THESAURUS_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${THESAURUS_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash dict || exit 1           # exit 1 if not found
am_i_online "$THESAURUS_SERVER_HOST" --error || exit 1 # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
dict -h ${THESAURUS_SERVER_HOST} -p ${THESAURUS_SERVER_PORT} -d moby-thesaurus "$1" 2>/dev/null |
  sed '/^$/d;s/[ \t]*$//' | sed 's#From Moby Thesaurus.*##g;;s/^[ \t]*//' >"$THESAURUS_TEMP_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if grep -svq "No definitions" "$THESAURUS_TEMP_FILE"; then
  THESAURUS="$(grep -sv '^$' "$THESAURUS_TEMP_FILE" | grep -vE 'definition found|words for' | sed 's|,[ ]|\n|g;s|,||g')"
  printf '%s\n' "$(grep -sv '^$' "$THESAURUS_TEMP_FILE" | grep -E 'definition found|words for' | head -n2)" | printf_readline "$THESAURUS_OUTPUT_COLOR_GOOD"
  printf '%s\n' "$THESAURUS" | printf_column "$THESAURUS_OUTPUT_COLOR"
  __notifications "$(<"$THESAURUS_TEMP_FILE")"
else
  printf_custom $THESAURUS_OUTPUT_COLOR_ERROR "No results found for $1"
fi
sleep 1
[ -f "$THESAURUS_TEMP_FILE" ] && rm -Rf "$THESAURUS_TEMP_FILE" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
