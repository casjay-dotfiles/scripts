#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108181418-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$TIMER_TEMP_FILE" ] && rm -Rf "$TIMER_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108181418-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : timer --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Aug 18, 2021 14:18 EDT
# @File          : timer
# @Description   : Set an alarm
# @TODO          : Add linux support
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE"
  [ -d "$TIMER_CONFIG_DIR" ] || mkdir -p "$TIMER_CONFIG_DIR"
  [ -d "$TIMER_CONFIG_BACKUP_DIR" ] || mkdir -p "$TIMER_CONFIG_BACKUP_DIR"
  [ -f "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE" ] &&
    cp -Rf "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE" "$TIMER_CONFIG_BACKUP_DIR/$TIMER_CONFIG_FILE.$$"
  cat <<EOF >"$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE"
# Settings for timer
TIMER_SPEAK_COMMAND="${TIMER_SPEAK_COMMAND}"

# Notification settings
TIMER_GOOD_MESSAGE="${TIMER_GOOD_MESSAGE:-Everything Went OK}"
TIMER_ERROR_MESSAGE="${TIMER_ERROR_MESSAGE:-Well that didn\'t work}"
TIMER_NOTIFY_ENABLED="${TIMER_NOTIFY_ENABLED:-yes}"
TIMER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TIMER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TIMER_NOTIFY_CLIENT_ICON}"

# Colorization settings
TIMER_OUTPUT_COLOR="${TIMER_OUTPUT_COLOR:-5}"
TIMER_OUTPUT_COLOR_GOOD="${TIMER_OUTPUT_COLOR_GOOD:-2}"
TIMER_OUTPUT_COLOR_ERROR="${TIMER_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE" ]; then
    printf_green "Your config file for timer has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__speak() { sleep "$1" && $TIMER_SPEAK_COMMAND "$2" &>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_timer() {
  local length="$1"
  local speech="$2"
  local duration_message="$3"
  shift 2
  printf_yellow "press control-c to cancel"
  __counter "${duration:-$length}" "$TIMER_OUTPUT_COLOR" "Your timer is set for:" " $duration_message"
  while true; do __speak "$length" "$speech" && sleep 1; done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
TIMER_CACHE_DIR="${TIMER_CACHE_DIR:-/$HOME/.cache/timer}"
TIMER_CONFIG_DIR="${TIMER_CONFIG_DIR:-$HOME/.config/myscripts/timer}"
TIMER_OPTIONS_DIR="${TIMER_OPTIONS_DIR:-$HOME/.local/share/myscripts/timer/options}"
TIMER_CONFIG_BACKUP_DIR="${TIMER_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/timer/backups}"
TIMER_TEMP_DIR="${TIMER_TEMP_DIR:-$HOME/.local/tmp/system_scripts/timer}"
TIMER_TEMP_FILE="${TIMER_TEMP_FILE:-$(mktemp $TIMER_TEMP_DIR/XXXXXX 2>/dev/null)}"
TIMER_CONFIG_FILE="${TIMER_CONFIG_FILE:-settings.conf}"
TIMER_GOOD_MESSAGE="${TIMER_GOOD_MESSAGE:-Everything Went OK}"
TIMER_ERROR_MESSAGE="${TIMER_ERROR_MESSAGE:-Well that didn\'t work}"
TIMER_NOTIFY_ENABLED="${TIMER_NOTIFY_ENABLED:-yes}"
TIMER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TIMER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TIMER_NOTIFY_CLIENT_ICON}"
TIMER_OUTPUT_COLOR="${TIMER_OUTPUT_COLOR:-5}"
TIMER_OUTPUT_COLOR_GOOD="${TIMER_OUTPUT_COLOR_GOOD:-2}"
TIMER_OUTPUT_COLOR_ERROR="${TIMER_OUTPUT_COLOR_ERROR:-1}"
TIMER_SPEAK_COMMAND="${TIMER_SPEAK_COMMAND:-$(command -v espeak-ng || command -v espeak || command -v say || command -v speech)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$TIMER_TEMP_DIR" ] || mkdir -p "$TIMER_TEMP_DIR" &>/dev/null
[ -d "$TIMER_CACHE_DIR" ] || mkdir -p "$TIMER_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE" ] &&
  . "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:,m:,s:,h:,d:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "-$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    TIMER_CWD="$2"
    shift 2
    ;;
  -s | --seconds)
    duration="$2"
    duration_message="second[s]"
    shift 2
    ;;
  -m | --minutes)
    duration="(($2*60))"
    duration_message="minute[s]"
    shift 2
    ;;
  -h | --hours)
    duration="(($2*60*60))"
    duration_message="hour[s]"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$TIMER_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${TIMER_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${TIMER_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${TIMER_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${TIMER_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
cmd_exists say || cmd_exists speech || cmd_exists speaker-test || exit 1
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[ -n "$TIMER_SPEAK_COMMAND" ] || TIMER_SPEAK_COMMAND="$(command -v say || command -v speech || command -v speaker-test || return 1)"
[[ "$saycmd" =~ speaker-test ]] && TIMER_SPEAK_COMMAND="speaker-test -t sine -f 1500 -S 70 -p 10000 -l 1 "
length="$1"
shift 1
speech="$*"
shift $#
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__run_timer "$length" "$speech" "${duration_message:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
