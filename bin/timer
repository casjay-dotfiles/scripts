#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108181418-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : timer --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Aug 18, 2021 14:18 EDT
# @File          : timer
# @Description   : Set an alarm
# @TODO          : Add linux support
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108181418-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ -n "$DISPLAY" ]] && [ ! -t 0 ] && { [[ "$1" = *term ]] || [ $# = 0 ]; }; then TERMINAL_APP="TRUE" eval ${TERMINAL:-myterminal} -e "${APPNAME:-bash} ${*:-}" && { exit || exit; }; fi
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'echo ""; exit' INT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE"
  [ -d "$TIMER_CONFIG_DIR" ] || mkdir -p "$TIMER_CONFIG_DIR"
  [ -d "$TIMER_CONFIG_BACKUP_DIR" ] || mkdir -p "$TIMER_CONFIG_BACKUP_DIR"
  [ -f "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE" ] &&
    cp -Rf "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE" "$TIMER_CONFIG_BACKUP_DIR/$TIMER_CONFIG_FILE.$$"
  cat <<EOF >"$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE"
# Settings for timer
TIMER_SPEAK_COMMAND="${TIMER_SPEAK_COMMAND}"
TIMER_SPEAK_MESSAGE="${TIMER_SPEAK_MESSAGE:-Timer is going off}"

# Notification settings
TIMER_GOOD_MESSAGE="${TIMER_GOOD_MESSAGE:-Everything Went OK}"
TIMER_ERROR_MESSAGE="${TIMER_ERROR_MESSAGE:-Well something seems to have gone wrong}"
TIMER_NOTIFY_ENABLED="${TIMER_NOTIFY_ENABLED:-yes}"
TIMER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TIMER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TIMER_NOTIFY_CLIENT_ICON}"

# Colorization settings
TIMER_OUTPUT_COLOR="${TIMER_OUTPUT_COLOR:-5}"
TIMER_OUTPUT_COLOR_GOOD="${TIMER_OUTPUT_COLOR_GOOD:-2}"
TIMER_OUTPUT_COLOR_ERROR="${TIMER_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__speak() {
  local message="${2:-}"
  $TIMER_SPEAK_COMMAND "$message" &>/dev/null
  if cmd_exist zenity; then
    if ! ps -ux | grep [z]enity | grep -qs "$message"; then
      zenity --question --ok-label=OK --cancel-label=Dismiss --width=400 --title="Alarm" --text "Your alarm is going off: $message" &>/dev/null || kill -INT $$ &>/dev/null &
    fi
  else
    printf '\r\t\t%s' "$(echo -en "${BLUE}Your alarm is going off: $message ${NC}")"
  fi
  sleep 3
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_timer() {
  local length="$1"
  local duration="$2"
  local speech="$3"
  local duration_message="$4"
  shift 2
  printf_yellow "press control-c to cancel"
  printf_cyan "Your timer is set for ${duration} ${duration_message} "
  __counter ${length} "${TIMER_OUTPUT_COLOR}" "Time remaining in seconds "
  echo ""
  while true; do
    __speak "$length" "$speech" || exit
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__requires() {
  printf_red "Requires one of:"
  printf_blue "espeak-ng espeak say speech speaker-test"
  printf_red "Could not find a valid speak command"
  exit 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_speak_cmd() {
  if cmd_exists espeak-ng; then
    echo espeak-ng
  elif cmd_exists espeak; then
    echo espeak
  elif cmd_exists say; then
    echo say
  elif cmd_exists speech; then
    echo speech
  elif cmd_exists speaker-test; then
    echo speaker-test -t sine -f 1500 -S 70 -p 10000 -l 1
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
TIMER_LOG_DIR="${TIMER_LOG_DIR:-$HOME/.local/log/timer}"
TIMER_CACHE_DIR="${TIMER_CACHE_DIR:-$HOME/.cache/timer}"
TIMER_CONFIG_DIR="${TIMER_CONFIG_DIR:-$HOME/.config/myscripts/timer}"
TIMER_CONFIG_BACKUP_DIR="${TIMER_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/timer/backups}"
TIMER_TEMP_DIR="${TIMER_TEMP_DIR:-$HOME/.local/tmp/system_scripts/timer}"
TIMER_OPTIONS_DIR="${TIMER_OPTIONS_DIR:-$HOME/.local/share/myscripts/timer/options}"
TIMER_CONFIG_FILE="${TIMER_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
TIMER_OUTPUT_COLOR="${TIMER_OUTPUT_COLOR:-4}"
TIMER_OUTPUT_COLOR_2="${TIMER_OUTPUT_COLOR:-6}"
TIMER_OUTPUT_COLOR_GOOD="${TIMER_OUTPUT_COLOR_GOOD:-2}"
TIMER_OUTPUT_COLOR_ERROR="${TIMER_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
TIMER_GOOD_MESSAGE="${TIMER_GOOD_MESSAGE:-Everything Went OK}"
TIMER_ERROR_MESSAGE="${TIMER_ERROR_MESSAGE:-Well something seems to have gone wrong}"
TIMER_NOTIFY_ENABLED="${TIMER_NOTIFY_ENABLED:-yes}"
TIMER_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TIMER_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TIMER_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
TIMER_SPEAK_COMMAND="${TIMER_SPEAK_COMMAND:-$(__get_speak_cmd)}"
TIMER_SPEAK_MESSAGE="${TIMER_SPEAK_MESSAGE:-Timer is going off}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE" ] && . "$TIMER_CONFIG_DIR/$TIMER_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$TIMER_LOG_DIR" ] || mkdir -p "$TIMER_LOG_DIR" &>/dev/null
[ -d "$TIMER_TEMP_DIR" ] || mkdir -p "$TIMER_TEMP_DIR" &>/dev/null
[ -d "$TIMER_CACHE_DIR" ] || mkdir -p "$TIMER_CACHE_DIR" &>/dev/null
TIMER_TEMP_FILE="${TIMER_TEMP_FILE:-$(mktemp $TIMER_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$TIMER_TEMP_FILE" ] && [ -f "$TIMER_TEMP_FILE" ] && rm -Rf "$TIMER_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$TIMER_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${TIMER_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${TIMER_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${TIMER_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${TIMER_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="m:,s:,h:,d:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "-$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    TIMER_CWD="$2"
    shift 2
    ;;
  -s | --seconds)
    length="$2"
    duration_time="$2"
    duration_message="second[s]"
    shift 2
    ;;
  -m | --minutes)
    length="$(echo $(($2 * 60)))"
    duration_time="$2"
    duration_message="minute[s]"
    shift 2
    ;;
  -h | --hours)
    length="$(echo $(($2 * 60 * 60)))"
    duration_time="$2"
    duration_message="hour[s]"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
__get_speak_cmd &>/dev/null || __requires

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [[ "$TIMER_SPEAK_COMMAND" =~ speaker-test ]] || [ -z "$TIMER_SPEAK_COMMAND" ]; then
  TIMER_SPEAK_COMMAND="$(__get_speak_cmd || return 1)"
fi

if [[ "$1" =~ [0-9]s ]]; then
  set_length=${1//s/}
  length=$set_length
  duration_time="${length}"
  duration_message="second[s]"
  shift 1
elif [[ "$1" =~ [0-9]m ]]; then
  set_length=${1//m/}
  length=$(($set_length * 60))
  duration_time="${set_length}"
  duration_message="minute[s]"
  shift 1
elif [[ "$1" =~ [0-9]h ]]; then
  set_length=${1//h/}
  length=$(($set_length * 60 * 60))
  duration_time="${set_length}"
  duration_message="hour[s]"
  shift 1
elif [[ "$1" =~ [0-9]d ]]; then
  set_length=${1//d/}
  length=$(($set_length * 60 * 60 * 24))
  duration_time="${set_length}"
  duration_message="day[s]"
  shift 1
elif [[ "$1" =~ [0-9]w ]]; then
  set_length=${1//w/}
  length=$(($set_length * 60 * 60 * 24 * 7))
  duration_time="${set_length}"
  duration_message="week[s]"
  shift 1
elif [[ "$1" =~ [0-9]M ]]; then
  set_length=${1//M/}
  length=$(($set_length * 60 * 60 * 24 * 30))
  duration_time="${set_length}"
  duration_message="month[s]"
  shift 1
elif [[ "$1" =~ [0-9]y ]]; then
  set_length=${1//y/}
  length=$(($set_length * 60 * 60 * 24 * 365))
  duration_time="${set_length}"
  duration_message="year[s]"
  shift 1
elif [[ "$1" =~ [0-9] ]]; then
  set_length="$1"
  length="$set_length"
  duration_time="${set_length}"
  duration_message="second[s]"
  shift 1
elif [[ -z "$1" ]]; then
  set_length=60
  length="$set_length"
  duration_time="${set_length}"
  duration_message="second[s]"
  shift 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
speech="${*:-$TIMER_SPEAK_MESSAGE}"
shift $#
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__run_timer "${length}" "${duration_time}" "$speech" "${duration_message:-second[s]}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
