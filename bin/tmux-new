}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -s "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$TMUX_NEW_REQUIRE_SUDO" = "yes" ] && [ -z "$TMUX_NEW_REQUIRE_SUDO_RUN" ]; then
    export TMUX_NEW_REQUIRE_SUDO="no"
    export TMUX_NEW_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "$(basename "$SUDO" 2>/dev/null)" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-0}
  [ -f "$TMUX_NEW_TEMP_FILE" ] && rm -Rf "$TMUX_NEW_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__tmux_kill() {
  local session="$(tmux ls 2>/dev/null)"
  case "$1" in
  pane)
    printf_cyan "Killing $1 $2"
    tmux kill-pane "$2" &>/dev/null
    exitCode=$?
    shift 2
    ;;
  server)
    printf_cyan "Killing $1 $2"
    tmux kill-server "$2" &>/dev/null
    exitCode=$?
    shift 2
    ;;
  session)
    exists="$(echo "$session" | grep ^"$2:" || echo '')"
    [ -n "$exists" ] || printf_exit 1 3 "Session $2 does not exist"
    printf_cyan "Killing $1 $2"
    tmux kill-session -t "$2" &>/dev/null
    exitCode=$?
    shift 2
    ;;
  window)
    printf_cyan "Killing $1 $2"
    tmux kill-window -t "$2" &>/dev/null
    exitCode=$?
    shift 2
    ;;
  *)
    printf_cyan "Usage: [pane/server/session/kill-window] [name]"
    tmux ls
    exitCode=$?
    ;;
  esac
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__create_tmux_conf() {
  [ -d "$TMUX_NEW_CONFIG_DIR" ] || mkdir -p "$TMUX_NEW_CONFIG_DIR"
  if [ -f "$CASJAYSDEVDIR/templates/tmux/new.conf" ] && [ ! -f "$TMUX_NEW_CONFIG_DIR/template" ]; then
    cp -Rf "$CASJAYSDEVDIR/templates/tmux/new.conf" "$TMUX_NEW_CONFIG_DIR/template"
  else
    touch "$TMUX_NEW_CONFIG_DIR/template"
  fi
  [ -f "$TMUX_NEW_CONFIG_DIR/template" ] && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__cd() {
  TMUX_NEW_CWD="${1:-$TMUX_NEW_CWD}"
  [ -d "$TMUX_NEW_CWD" ] || mkdir -p "$TMUX_NEW_CWD"
  builtin cd "$TMUX_NEW_CWD" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__launch_tmux() {
  local name="$1"
  [ -f "$TMUX_NEW_FILE_CONF/$name" ] || printf_exit "No config file found for $name"
  [ -f "$TMUX_NEW_FILE_WINDOWS/$name" ] || printf_exit "No windows config file found for $name"
  # Start tmux
  if [ -z "$TMUX" ]; then
    __cd
    printf_cyan "Starting the tmux enviroment for $name"
    sleep 3
    tmux -f "$TMUX_NEW_FILE_CONF/$name" new-session -D -A -s $name 'tmux source-file '$TMUX_NEW_FILE_WINDOWS/$name'' &>"$TMUX_NEW_LOG_DIR/$APPNAME.log"
    return $?
  else
    printf_exit "You appear to already have tmux running"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_conf() {
  local name="${1:-default}"
  if [ -f "$TMUX_NEW_FILE_CONF/$name" ] && [ -f "$TMUX_NEW_FILE_WINDOWS/$name" ]; then
    return 0
  fi
  # Create main config files
  if [ ! -f "$TMUX_NEW_FILE_CONF/$name" ]; then
    if [ -f "$TMUX_NEW_CONFIG_DIR/template" ]; then
      printf_cyan "Creating $TMUX_NEW_FILE_CONF/$name"
      cp -Rf "$TMUX_NEW_CONFIG_DIR/template" "$TMUX_NEW_FILE_CONF/$name"
      { [ -f "$TMUX_NEW_FILE_CONF/$name" ] && sed -i 's|TMUX_NEW_CONF_FILE_MAIN|'${TMUX_NEW_FILE_CONF}/${name}'|g' "$TMUX_NEW_FILE_CONF/$name" || true; }
      { [ -f "$TMUX_NEW_FILE_CONF/$name" ] && sed -i 's|TMUX_NEW_CONF_FILE_LOCAL|'${TMUX_NEW_FILE_CONF_LOCAL}/${name}'|g' "$TMUX_NEW_FILE_CONF/$name" || true; }
    else
      printf_exit "Can not find $TMUX_NEW_CONFIG_DIR/template"
    fi
  fi
  [ -f "$TMUX_NEW_FILE_CONF/$name" ] &&
    printf_blue "config file has been created" || printf_exit "Failed to create config file"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Create tmux windows config files
__create_windows() {
  if [ ! -f "$TMUX_NEW_FILE_WINDOWS/$name" ]; then
    local name="" win_1_def="" win_2_def="" wname="" wcmd="" add_windows="" wnum="0"
    [ -n "$1" ] && name="$1" && shift 1 || name="default"
    # add more windows
    if [ $# -ne 0 ]; then
      for window in "$@"; do
        wnum=$(($wnum + 1))
        wname="$(echo "$window" | grep ':' | awk -F':' '{print $1}' | grep '^' || printf '%s' "${window:-$wnum}")"
        wcmd="$(echo "$window" | grep ':' | awk -F':' '{print $2}' | grep '^' || printf '%s' "${SHELL:-bash}")"
        add_windows="$(printf '%s\nneww -n %s  %s\n' "$add_windows" "$wname" "$wcmd" && echo '')"
      done
    fi
    printf_green "Creating tmux windows file"
    cat <<EOF >"$TMUX_NEW_FILE_WINDOWS/$name"
# Window config for $name
$(printf '%s\n' "$add_windows" | grep -v '^$')

EOF
    [ -f "$TMUX_NEW_FILE_WINDOWS/$name" ] &&
      printf_blue "tmux windows config file has been created" ||
      printf_exit "Failed to create tmux windows config file"
  fi
  return
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__edit() {
  local name="$1"
  [ -n "$EDITOR" ] || printf_exit "EDITOR is not set"
  [ -f "$TMUX_NEW_FILE_CONF/$name" ] || printf_exit "Missing: $TMUX_NEW_FILE_CONF/$name"
  eval $EDITOR "$TMUX_NEW_FILE_CONF/$name" "$TMUX_NEW_FILE_WINDOWS/$name"
  return $?
}
