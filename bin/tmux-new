# - - - - - - - - - - - - - - - - - - - - - - - - -
# check if arg is a builtin option
__is_an_option() { if [[ "$ARRAY" == *"${1:-^}"* ]]; then return 1; else return 0; fi; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  if { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; }; then return 1; else return 0; fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -sh "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$TMUX_NEW_REQUIRE_SUDO" = "yes" ] && [ -z "$TMUX_NEW_REQUIRE_SUDO_RUN" ]; then
    export TMUX_NEW_REQUIRE_SUDO="no"
    export TMUX_NEW_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "${SUDO##*/}" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-0}
  [ -f "$TMUX_NEW_TEMP_FILE" ] && rm -Rf "$TMUX_NEW_TEMP_FILE" &>/dev/null
  #unset CASJAYSDEV_TITLE_SET && printf '\033]2│;%s\033\\' "${USER}@${HOSTNAME}:${PWD/#$HOME/~} - ${CASJAYSDEV_TITLE_PREV:-$SHELL}"
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
# Wrapper that forwards to tmux, prepending -L when a non-default socket was requested
__tmux() {
  if [ -n "$TMUX_NEW_SOCKET_FILE" ] && [ "$TMUX_NEW_SOCKET_FILE" != "default" ]; then
    command tmux -L "$TMUX_NEW_SOCKET_FILE" "$@"
  else
    command tmux "$@"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Cache helper function
__cache_valid() {
  local cache_file="$1"
  local cache_ttl="$2"
  local current_time cache_time time_diff
  if [ -f "$cache_file" ]; then
    current_time=$(date +%s)
    cache_time=$(stat -c %Y "$cache_file" 2>/dev/null || stat -f %m "$cache_file" 2>/dev/null || echo 0)
    time_diff=$((current_time - cache_time))
    if [ "$time_diff" -lt "$cache_ttl" ]; then
      return 0
    fi
  fi
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Resolve the socket name we should use for socket-scoped cache files.
# Priority: explicit --socket flag, then $TMUX env (status-bar invocations
# inherit it), then "default". Without this the caches were per-PID and
# never reused across invocations.
__current_socket() {
  if [ -n "$TMUX_NEW_SOCKET_FILE" ] && [ "$TMUX_NEW_SOCKET_FILE" != "default" ]; then
    printf '%s' "$TMUX_NEW_SOCKET_FILE"
    return 0
  fi
  if [ -n "$TMUX" ]; then
    local sock_path="${TMUX%%,*}"
    local sock_name="${sock_path##*/}"
    if [ -n "$sock_name" ]; then
      printf '%s' "$sock_name"
      return 0
    fi
  fi
  printf '%s' "default"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Weather function with caching
__exec_weather() {
  local cache_dir="${TMUX_CACHE_DIR:-$HOME/.cache/tmux}"
  local socket="$(__current_socket)"
  local cache_file="$cache_dir/weather-$socket"
  local cache_ttl="${TMUX_WEATHER_INTERVAL:-3600}"
  local weather_server="${TMUX_WEATHER_SERVER:-https://wthr.top}"
  local weather_location="${MYLOCATION_NAME:-${TMUX_WEATHER_LOCATION:-New York, NY}}"
  local weather_url
  weather_url="${weather_location// /%20}"
  [ -d "$cache_dir" ] || mkdir -p "$cache_dir" 2>/dev/null
  if __cache_valid "$cache_file" "$cache_ttl"; then
    printf '%s\n' "$(<"$cache_file")" 2>/dev/null || echo "No Weather"
  else
    local weather
    weather=$(curl -q -LSsf -m 2 "${weather_server}/${weather_url}?u&format=3" 2>/dev/null | sed 's/:/ /g;s/°F/F/g' || echo "No Weather")
    echo "$weather" >"$cache_file" 2>/dev/null
    echo "$weather"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Uptime function with caching
__exec_uptime() {
  local cache_dir="${TMUX_CACHE_DIR:-$HOME/.cache/tmux}"
  local socket="$(__current_socket)"
  local cache_file="$cache_dir/uptime-$socket"
  local cache_ttl="${TMUX_UPTIME_INTERVAL:-60}"
  [ -d "$cache_dir" ] || mkdir -p "$cache_dir" 2>/dev/null
  if __cache_valid "$cache_file" "$cache_ttl"; then
    cat "$cache_file" 2>/dev/null
  else
    local uptime_info raw_uptime
    raw_uptime="$(uptime 2>/dev/null)"
    uptime_info="${raw_uptime#* * * }"
    uptime_info="${uptime_info%%,*}"
    echo "$uptime_info" >"$cache_file" 2>/dev/null
    echo "$uptime_info"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__init() {
  local name="$1"
  name="${name##*/}"
  if [ -f "$TMUX_NEW_FILE_CONF/$name" ]; then
    TMUX_NEW_NAME="$name"
  elif [ -f "$TMUX_NEW_FILE_CONF/$name-$name" ]; then
    TMUX_NEW_NAME="$name-$name"
  elif [ -f "$TMUX_NEW_FILE_CONF/$USER-$name" ]; then
    TMUX_NEW_NAME="$USER-$name"
  elif [ -f "$TMUX_NEW_FILE_CONF/$name-$USER" ]; then
    TMUX_NEW_NAME="$name-$USER"
  else
    TMUX_NEW_NAME="$name"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_kill_all() {
  local exitCode=0
  local session_info=""
  local session_name=""
  local session_path=""
  local session_type=""

  printf_cyan "Capturing session information..."

  # Get all sessions with their paths
  local sessions="$(__tmux list-sessions -F '#{session_name}:#{session_path}' 2>/dev/null)"

  if [ -z "$sessions" ]; then
    printf_yellow "No active sessions to kill"
    return 0
  fi

  # Kill all sessions and capture their info
  while IFS=: read -r session_name session_path; do
    if [ -n "$session_name" ]; then
      printf_cyan "Killing session: $session_name (path: $session_path)"
      __tmux kill-session -t "$session_name" &>/dev/null

      # Clean up resurrect data
      local resurrect_dir="${TMUX_NEW_CONFIG_DIR}/resurrect/${session_name}"
      if [ -d "$resurrect_dir" ]; then
        rm -rf "$resurrect_dir"
      fi

      # Extract session type from name (e.g., "single-scripts" -> "single")
      if [[ "$session_name" =~ ^([a-z]+)- ]]; then
        session_type="${BASH_REMATCH[1]}"
      else
        session_type="single"
      fi

      # Store session info for recreation
      session_info+="${session_type}:${session_path}\n"
    fi
  done <<<"$sessions"

  printf_green "All sessions killed and cleaned"

  # Recreate sessions
  if [ -n "$session_info" ]; then
    printf_cyan "Recreating sessions in background..."
    echo -e "$session_info" | while IFS=: read -r session_type session_path; do
      if [ -n "$session_path" ] && [ -d "$session_path" ]; then
        printf_blue "Recreating $session_type session in: $session_path"
        (cd "$session_path" && "$0" --dir "$session_path" --silent "$session_type" &>/dev/null &)
      fi
    done
    sleep 2
    printf_green "Sessions recreated - use 'tmux-new list' to see them"
  fi

  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_kill() {
  local exitCode=0
  local session="$(__tmux ls 2>/dev/null)"
  case "$1" in
  all)
    shift 1
    __tmux_kill_all
    return $?
    ;;
  pane)
    shift 1
    [ $# -ne 0 ] || printf_cyan "Usage: $APPNAME kill pane [name]"
    for arg in "$@"; do
      local retVal=0
      printf_cyan "Killing pane $arg"
      __tmux kill-pane "$arg" &>/dev/null
      retval=$?
      exitCode=$((exitCode + retval))
    done
    return $exitCode
    ;;
  server)
    shift
    [ $# -ne 0 ] || printf_cyan "Usage: $APPNAME kill server [name]"
    for arg in "$@"; do
      local retVal=0
      printf_cyan "Killing server $arg"
      __tmux kill-server "$arg" &>/dev/null
      retval=$?
      exitCode=$((exitCode + retval))
    done
    return $exitCode
    ;;
  session)
    shift
    [ $# -ne 0 ] || printf_cyan "Usage: $APPNAME kill session [name]"
    for arg in "$@"; do
      local retVal=0
      if __tmux has-session -t "=$arg" 2>/dev/null; then
        printf_cyan "Killing session $arg"
        __tmux kill-session -t "$arg" &>/dev/null
        retval=$?
        exitCode=$((exitCode + retval))
        if [ $retval -eq 0 ]; then
          local resurrect_dir="${TMUX_NEW_CONFIG_DIR}/resurrect/${arg}"
          if [ -d "$resurrect_dir" ]; then
            printf_cyan "Cleaning up resurrect data for $arg"
            rm -rf "$resurrect_dir"
          fi
        fi
      else
        printf_yellow "The session $arg does not exist"
      fi
    done
    return $exitCode
    ;;
  window)
    shift 1
    [ $# -ne 0 ] || printf_cyan "Usage: $APPNAME kill window [name]"
    for arg in "$@"; do
      local retVal=0
      printf_cyan "Killing window $arg"
      __tmux kill-window -t "$arg" &>/dev/null
      retval=$?
      exitCode=$((exitCode + retval))
    done
    return $exitCode
    ;;
  *)
    printf_cyan "Usage: $APPNAME kill [pane/server/session/window] [name]"
    if [ -n "$session" ]; then
      printf '%s\n' "$session"
    fi
    exitCode=$?
    return $exitCode
    ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__cd() {
  TMUX_NEW_CWD="${1:-$TMUX_NEW_CWD}"
  mkdir -p "$TMUX_NEW_CWD" 2>/dev/null
  builtin cd "$TMUX_NEW_CWD" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_get_session_sockets() {
  [ -d "$TMUX_NEW_SOCKET_DIR" ] || return 1
  local socket_sessions="" socket line sess
  for socket in "$TMUX_NEW_SOCKET_DIR"/*; do
    [ -e "$socket" ] || continue
    [ "${socket##*/}" = "default" ] && continue
    socket_sessions+="$(tmux -S "$socket" ls 2>/dev/null)"$'\n'
  done
  [ -n "$socket_sessions" ] || return 1
  while IFS=: read -r sess _; do
    [ -n "$sess" ] && printf '%s\n' "$sess"
  done <<<"$socket_sessions"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_get_all_sessions() {
  local all_sessions="" socket_sessions="" sess
  all_sessions="$(__tmux ls 2>/dev/null || true)"
  socket_sessions="$(__tmux_get_session_sockets 2>/dev/null || true)"
  if [ -n "$all_sessions" ]; then
    while IFS=: read -r sess _; do
      [ -n "$sess" ] && printf '%s\n' "$sess"
    done <<<"$all_sessions"
    [ -n "$socket_sessions" ] && printf '%s\n' "$socket_sessions"
    return 0
  elif [ -n "$socket_sessions" ]; then
    printf '%s\n' "$socket_sessions"
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_list() {
  __tmux_get_all_sessions 2>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__create_tmux_conf() {
  [ -n "$1" ] && [ -n "$TMUX_NEW_NAME" ] || TMUX_NEW_NAME="${1:-${TMUX_NEW_NAME:-default}}"
  mkdir -p "$TMUX_NEW_CONFIG_DIR" 2>/dev/null
  if [ ! -f "$TMUX_NEW_CONFIG_DIR/template" ]; then
    if [ -f "$CASJAYSDEVDIR/templates/tmux/new.conf" ]; then
      cp -Rf "$CASJAYSDEVDIR/templates/tmux/new.conf" "$TMUX_NEW_CONFIG_DIR/template" 2>/dev/null
    else
      touch "$TMUX_NEW_CONFIG_DIR/template" 2>/dev/null
    fi
  fi
  [ -f "$TMUX_NEW_CONFIG_DIR/template" ]
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__launch_tmux() {
  [ -n "$1" ] && [ -n "$TMUX_NEW_NAME" ] || TMUX_NEW_NAME="${1:-${TMUX_NEW_NAME:-default}}"
  [ -f "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" ] || printf_exit "No config file found for $TMUX_NEW_NAME"
  [ -f "$TMUX_NEW_FILE_WINDOWS/$TMUX_NEW_NAME" ] || printf_exit "No windows config file found for $TMUX_NEW_NAME"
  # Start tmux
  if [ -z "$TMUX" ]; then
    __cd
    local restore_script="$TMUX_NEW_PLUGIN_DIR/tmux-resurrect/scripts/restore.sh"
    local resurrect_last="$TMUX_NEW_RESURRECT_DIR/last"
    local server_is_up="false"
    __tmux list-sessions &>/dev/null && server_is_up="true"
    # If the tmux server is down but a saved snapshot exists, restore it before creating our session
    if [ "$server_is_up" = "false" ] && [ -L "$resurrect_last" ] && [ -x "$restore_script" ]; then
      printf_green "Found saved server state for socket '$TMUX_NEW_SOCKET_FILE' - restoring sessions..."
      __tmux -f "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" new-session -d -s "_tmux_new_restore" &>"$TMUX_NEW_LOG_DIR/$APPNAME.log"
      __tmux_apply_resurrect_dir
      "$restore_script" >/dev/null 2>&1 || true
      __tmux kill-session -t "_tmux_new_restore" 2>/dev/null || true
      server_is_up="true"
      __tmux list-sessions &>/dev/null || server_is_up="false"
    fi
    if [ "$server_is_up" = "true" ] && __tmux has-session -t "=$TMUX_NEW_NAME" 2>/dev/null; then
      printf_green "Attaching to existing session $TMUX_NEW_NAME"
      __tmux_apply_resurrect_dir
      __tmux attach -t "$TMUX_NEW_NAME" &>"$TMUX_NEW_LOG_DIR/$APPNAME.log"
    else
      printf_cyan "Starting new tmux environment for $TMUX_NEW_NAME"
      [ "$server_is_up" = "true" ] || sleep 3
      __tmux -f "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" new-session -D -A -s "$TMUX_NEW_NAME" "tmux source-file $TMUX_NEW_FILE_WINDOWS/$TMUX_NEW_NAME" &>"$TMUX_NEW_LOG_DIR/$APPNAME.log"
      __tmux_apply_resurrect_dir
    fi
    __tmux_autosave_start
    return $?
  else
    printf_exit "You appear to already have tmux running"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Point the running tmux server at our per-socket resurrect dir so save/restore stay isolated
# (tmux-resurrect reads the @resurrect-dir global option). Safe to call repeatedly.
__tmux_apply_resurrect_dir() {
  __tmux list-sessions &>/dev/null || return 1
  [ -d "$TMUX_NEW_RESURRECT_DIR" ] || mkdir -p "$TMUX_NEW_RESURRECT_DIR" 2>/dev/null
  __tmux set-option -g @resurrect-dir "$TMUX_NEW_RESURRECT_DIR" &>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Snapshot retention - keep TMUX_NEW_SNAPSHOT_KEEP newest tmux_resurrect_*.txt files in the
# current resurrect dir, delete the rest. Pass "quiet" to suppress the user-facing summary
# (used by the autosave loop). Set TMUX_NEW_SNAPSHOT_KEEP=0 to disable rotation entirely.
__tmux_cleanup_snapshots() {
  local quiet="${1:-}"
  local keep="${TMUX_NEW_SNAPSHOT_KEEP:-30}"
  local dir="$TMUX_NEW_RESURRECT_DIR"
  [ "$keep" -gt 0 ] 2>/dev/null || return 0
  [ -d "$dir" ] || return 0
  local count=0 removed=0 file
  while IFS= read -r file; do
    count=$((count + 1))
    [ "$count" -le "$keep" ] && continue
    rm -f "$dir/$file" 2>/dev/null && removed=$((removed + 1))
  done < <(cd "$dir" 2>/dev/null && ls -1t tmux_resurrect_*.txt 2>/dev/null)
  if [ "$removed" -gt 0 ] && [ "$quiet" != "quiet" ]; then
    printf_cyan "Cleaned up $removed old snapshot(s) in $dir (kept newest $keep)"
  fi
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Background loop that calls tmux-resurrect save.sh every N seconds while the tmux server is alive.
# Writes a PID lockfile to avoid stacking multiple loops across invocations.
__tmux_autosave_start() {
  local save_script="$TMUX_NEW_PLUGIN_DIR/tmux-resurrect/scripts/save.sh"
  local interval="${TMUX_NEW_SAVE_INTERVAL:-300}"
  local lock_file="$TMUX_NEW_TEMP_DIR/autosave.${TMUX_NEW_SOCKET_FILE:-default}.pid"
  [ -x "$save_script" ] || return 0
  if [ -f "$lock_file" ] && kill -0 "$(<"$lock_file")" 2>/dev/null; then
    return 0
  fi
  __tmux_apply_resurrect_dir
  (
    echo "$BASHPID" >"$lock_file" 2>/dev/null
    trap 'rm -f "$lock_file"' EXIT
    while __tmux list-sessions &>/dev/null; do
      sleep "$interval"
      __tmux list-sessions &>/dev/null || break
      __tmux_apply_resurrect_dir
      "$save_script" >/dev/null 2>&1 || true
      __tmux_cleanup_snapshots quiet
    done
  ) &
  disown 2>/dev/null || true
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Manual save trigger (runs tmux-resurrect save.sh against the current server)
__tmux_save() {
  local save_script="$TMUX_NEW_PLUGIN_DIR/tmux-resurrect/scripts/save.sh"
  [ -x "$save_script" ] || printf_exit "Save script not found: $save_script"
  __tmux list-sessions &>/dev/null || printf_exit "No tmux server running on socket '${TMUX_NEW_SOCKET_FILE:-default}'"
  __tmux_apply_resurrect_dir
  if "$save_script" >/dev/null 2>&1; then
    printf_green "Session state saved to $TMUX_NEW_RESURRECT_DIR"
    __tmux_cleanup_snapshots
    return 0
  fi
  printf_red "Save failed"
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Manual restore trigger. Uses a disposable bootstrap session if the server is not already running.
__tmux_restore() {
  local restore_script="$TMUX_NEW_PLUGIN_DIR/tmux-resurrect/scripts/restore.sh"
  local resurrect_last="$TMUX_NEW_RESURRECT_DIR/last"
  [ -x "$restore_script" ] || printf_exit "Restore script not found: $restore_script"
  [ -L "$resurrect_last" ] || printf_exit "No saved state found at $resurrect_last"
  if ! __tmux list-sessions &>/dev/null; then
    __tmux new-session -d -s "_tmux_new_restore" 2>/dev/null || printf_exit "Failed to start bootstrap tmux server"
  fi
  __tmux_apply_resurrect_dir
  if "$restore_script" >/dev/null 2>&1; then
    __tmux kill-session -t "_tmux_new_restore" 2>/dev/null || true
    printf_green "Session state restored from $TMUX_NEW_RESURRECT_DIR"
    return 0
  fi
  __tmux kill-session -t "_tmux_new_restore" 2>/dev/null || true
  printf_red "Restore failed"
  return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Boot-time restore - no-op if server is already running. Safe to call from systemd --user or login hooks.
__tmux_boot() {
  if __tmux list-sessions &>/dev/null; then
    printf_yellow "tmux server already running on socket '${TMUX_NEW_SOCKET_FILE:-default}' - nothing to boot"
    return 0
  fi
  local resurrect_last="$TMUX_NEW_RESURRECT_DIR/last"
  if [ ! -L "$resurrect_last" ]; then
    printf_yellow "No saved state found at $resurrect_last - nothing to boot"
    return 0
  fi
  __tmux_restore
  local rc=$?
  __tmux_autosave_start
  return $rc
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_conf() {
  [ -n "$1" ] && [ -n "$TMUX_NEW_NAME" ] || TMUX_NEW_NAME="${1:-${TMUX_NEW_NAME:-default}}"
  if [ -f "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" ] && [ -f "$TMUX_NEW_FILE_WINDOWS/$TMUX_NEW_NAME" ]; then
    return 0
  fi
  # Create main config files
  if [ ! -f "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" ]; then
    if [ -f "$TMUX_NEW_CONFIG_DIR/template" ]; then
      printf_cyan "Creating $TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME"
      cp -Rf "$TMUX_NEW_CONFIG_DIR/template" "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME"
      { [ -f "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" ] && sed -i 's|TMUX_NEW_CONF_FILE_MAIN|'${TMUX_NEW_FILE_CONF}/${TMUX_NEW_NAME}'|g' "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" || true; }
      { [ -f "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" ] && sed -i 's|TMUX_NEW_CONF_FILE_LOCAL|'${TMUX_NEW_FILE_CONF_LOCAL}/${TMUX_NEW_NAME}'|g' "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" || true; }
    else
      printf_exit "Can not find $TMUX_NEW_CONFIG_DIR/template"
    fi
  fi
  [ -f "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" ] && printf_blue "config file has been created" || printf_exit "Failed to create config file"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Create tmux windows config files
__create_windows() {
  if [ ! -f "$TMUX_NEW_FILE_WINDOWS/$TMUX_NEW_NAME" ]; then
    local win_1_def="" win_2_def="" wname="" wcmd="" add_windows="" wnum="0" && shift 1
    # add more windows
    if [ $# -ne 0 ]; then
      for window in "$@"; do
        wnum=$(($wnum + 1))
        if [[ "$window" == *":"* ]]; then
          wname="${window%%:*}"
          wcmd="${window#*:}"
          [ -n "$wname" ] || wname="${window:-$wnum}"
          [ -n "$wcmd" ] || wcmd="${SHELL:-bash}"
        else
          wname="${window:-$wnum}"
          wcmd="${SHELL:-bash}"
        fi
        add_windows="$(printf '%s\nneww -n %s  %s\n' "$add_windows" "$wname" "$wcmd" && echo '')"
      done
    fi
    printf_green "Creating tmux windows file"
    cat <<EOF >"$TMUX_NEW_FILE_WINDOWS/$TMUX_NEW_NAME"
# Window config for $TMUX_NEW_NAME
$(printf '%s\n' "$add_windows" | grep -v '^$')

EOF
    [ -f "$TMUX_NEW_FILE_WINDOWS/$TMUX_NEW_NAME" ] && printf_blue "tmux windows config file has been created" || printf_exit "Failed to create tmux windows config file"
  fi
  return
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__edit() {
  [ -n "$EDITOR" ] || printf_exit "EDITOR is not set"
  [ -n "$1" ] && [ -n "$TMUX_NEW_NAME" ] || TMUX_NEW_NAME="${1:-${TMUX_NEW_NAME:-default}}"
  [ -f "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" ] || printf_exit "Missing: $TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME"
  eval $EDITOR "$TMUX_NEW_FILE_CONF/$TMUX_NEW_NAME" "$TMUX_NEW_FILE_WINDOWS/$TMUX_NEW_NAME"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__update_template() {
  if [ -f "$CASJAYSDEVDIR/templates/tmux/new.conf" ]; then
    printf_cyan "Updating template from source..."
    cp -f "$CASJAYSDEVDIR/templates/tmux/new.conf" "$TMUX_NEW_CONFIG_DIR/template"
    if [ -f "$TMUX_NEW_CONFIG_DIR/template" ]; then
      printf_green "Template updated successfully"
      return 0
    else
      printf_red "Failed to update template"
      return 1
    fi
  else
    printf_red "Source template not found: $CASJAYSDEVDIR/templates/tmux/new.conf"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__update_all_configs() {
  local updated=0
  local failed=0

  if [ ! -f "$TMUX_NEW_CONFIG_DIR/template" ]; then
    printf_red "Template not found. Run 'tmux-new update-template' first"
    return 1
  fi

  printf_cyan "Updating all session configs from template..."

  if [ -d "$TMUX_NEW_FILE_CONF" ]; then
    for config_file in "$TMUX_NEW_FILE_CONF"/*; do
      [ -f "$config_file" ] || continue
      local session_name="${config_file##*/}"
      printf_blue "Updating config for session: $session_name"
      if cp -f "$TMUX_NEW_CONFIG_DIR/template" "$config_file" 2>/dev/null; then
        sed -i "s|TMUX_NEW_CONF_FILE_MAIN|${TMUX_NEW_FILE_CONF}/${session_name}|g; s|TMUX_NEW_CONF_FILE_LOCAL|${TMUX_NEW_FILE_CONF_LOCAL}/${session_name}|g" "$config_file"
        printf_green "✓ Updated: $session_name"
        updated=$((updated + 1))
      else
        printf_red "✗ Failed: $session_name"
        failed=$((failed + 1))
      fi
    done
  fi

  printf_cyan "Update complete: $updated updated, $failed failed"

  if [ $failed -eq 0 ]; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_attach() {
  local name="${1:-$(__tmux_list | tail -n1)}"
  [ -n "$name" ] || return 1
  __tmux attach -t "$name" 2>/dev/null
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_ssh() {
  tmux -L ssh has-session -t "=ssh" 2>/dev/null || return 1
  tmux -L ssh a -t ssh
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Session management functions
__tmux_switch() {
  local session="${1:-$(__tmux_list | fzf 2>/dev/null || __tmux_list | head -1)}"
  [ -n "$session" ] || {
    printf_red "No session specified or available"
    return 1
  }

  if __tmux has-session -t "$session" 2>/dev/null; then
    [ -n "$TMUX" ] && __tmux switch-client -t "$session" || __tmux attach -t "$session"
    return $?
  else
    printf_red "Session '$session' does not exist"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_rename() {
  local old_name="${1}"
  local new_name="${2}"
  [ -n "$old_name" ] && [ -n "$new_name" ] || {
    printf_red "Usage: tmux-new rename <old_name> <new_name>"
    return 1
  }

  if __tmux has-session -t "$old_name" 2>/dev/null; then
    __tmux rename-session -t "$old_name" "$new_name"
    printf_green "✅ Session '$old_name' renamed to '$new_name'"
    return $?
  else
    printf_red "Session '$old_name' does not exist"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_status() {
  local sessions="$(__tmux_list)"
  if [ -n "$sessions" ]; then
    printf_blue "📊 Active tmux sessions:"
    for session in $sessions; do
      local info="$(__tmux display-message -p -t "$session" '#{session_name}: #{session_windows} windows, #{session_attached} clients' 2>/dev/null)"
      [ -n "$info" ] && printf_green "  $info" || printf_yellow "  $session: (info unavailable)"
    done
  else
    printf_yellow "No active tmux sessions"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Build the exact tmux command needed to attach to a given socket+session.
# Uses -L for sockets in the default tmux tmpdir, -S for absolute socket paths
# elsewhere (e.g. our custom $TMUX_NEW_SOCKET_DIR).
__tmux_attach_command() {
  local socket_ref="$1" session="$2" tmpdir
  tmpdir="${TMUX_TMPDIR:-/tmp}/tmux-$(id -u)"
  if [ "${socket_ref#/}" != "$socket_ref" ]; then
    if [ "${socket_ref%/*}" = "$tmpdir" ]; then
      local sock_name="${socket_ref##*/}"
      if [ "$sock_name" = "default" ]; then
        printf 'tmux attach -t %s' "$session"
      else
        printf 'tmux -L %s attach -t %s' "$sock_name" "$session"
      fi
    else
      printf 'tmux -S %s attach -t %s' "$socket_ref" "$session"
    fi
  else
    if [ "$socket_ref" = "default" ] || [ -z "$socket_ref" ]; then
      printf 'tmux attach -t %s' "$session"
    else
      printf 'tmux -L %s attach -t %s' "$socket_ref" "$session"
    fi
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Print sessions for one socket, indented under its header. Returns 1 if
# the socket had no matching sessions (caller decides whether anything was
# printed). $1 = display label, $2 = socket reference passed to
# __tmux_attach_command, remaining args = tmux invocation flags as a list
# (e.g. -L default, or -S /path/to/sock). The session name filter comes
# from the global TMUX_NEW_SHOW_NAME_FILTER (set by --name).
__tmux_show_socket() {
  local label="$1" socket_ref="$2"
  shift 2
  local filter="${TMUX_NEW_SHOW_NAME_FILTER:-}"
  local sessions session pad cmd max_len=0 matched=()
  sessions="$(command tmux "$@" list-sessions -F '#{session_name}' 2>/dev/null)"
  [ -n "$sessions" ] || return 1
  while IFS= read -r session; do
    [ -n "$session" ] || continue
    if [ -n "$filter" ] && [ "$session" != "$filter" ]; then
      continue
    fi
    matched+=("$session")
    [ "${#session}" -gt "$max_len" ] && max_len=${#session}
  done <<<"$sessions"
  [ "${#matched[@]}" -gt 0 ] || return 1
  printf_blue "[$label]"
  for session in "${matched[@]}"; do
    cmd="$(__tmux_attach_command "$socket_ref" "$session")"
    pad=$((max_len - ${#session}))
    printf "  "
    printf_green "$session:$(printf '%*s' "$pad" '')  $cmd"
  done
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Discover every reachable tmux server (default tmpdir + custom socket dir)
# and print sessions grouped by socket with the attach command for each.
# Honors --socket (filters to one socket name) and --name (filters to one
# session name). Without filters, shows everything.
__tmux_show() {
  local tmpdir uid found=0 sock sock_name
  local socket_filter="${TMUX_NEW_SHOW_SOCKET_FILTER:-}"
  uid="$(id -u)"
  tmpdir="${TMUX_TMPDIR:-/tmp}/tmux-$uid"
  if [ -d "$tmpdir" ]; then
    for sock in "$tmpdir"/*; do
      [ -S "$sock" ] || continue
      sock_name="${sock##*/}"
      if [ -n "$socket_filter" ] && [ "$sock_name" != "$socket_filter" ]; then
        continue
      fi
      if __tmux_show_socket "$sock_name" "$sock_name" -L "$sock_name"; then
        found=1
      fi
    done
  fi
  if [ -d "$TMUX_NEW_SOCKET_DIR" ]; then
    for sock in "$TMUX_NEW_SOCKET_DIR"/*; do
      [ -S "$sock" ] || continue
      sock_name="${sock##*/}"
      if [ -n "$socket_filter" ] && [ "$sock_name" != "$socket_filter" ]; then
        continue
      fi
      if __tmux_show_socket "$sock_name (custom)" "$sock" -S "$sock"; then
        found=1
      fi
    done
  fi
  if [ "$found" -eq 0 ]; then
    if [ -n "$socket_filter" ] || [ -n "$TMUX_NEW_SHOW_NAME_FILTER" ]; then
      printf_yellow "No tmux sessions match the given filters"
    else
      printf_yellow "No active tmux servers found"
    fi
    return 1
  fi
  return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux_clone() {
  local source="$1"
  local target="$2"
  [ -n "$source" ] && [ -n "$target" ] || {
    printf_red "Usage: tmux-new clone <source> <target>"
    return 1
  }

  if ! __tmux has-session -t "$source" 2>/dev/null; then
    printf_red "Source session '$source' does not exist"
    return 1
  fi

  if __tmux has-session -t "$target" 2>/dev/null; then
    printf_red "Target session '$target' already exists"
    return 1
  fi

  # Copy config files if they exist
  if [ -f "$TMUX_NEW_FILE_CONF/$source" ] && [ -f "$TMUX_NEW_FILE_WINDOWS/$source" ]; then
    cp "$TMUX_NEW_FILE_CONF/$source" "$TMUX_NEW_FILE_CONF/$target"
    cp "$TMUX_NEW_FILE_WINDOWS/$source" "$TMUX_NEW_FILE_WINDOWS/$target"
    __launch_tmux "$target"
    printf_green "✅ Session '$source' cloned to '$target'"
  else
    printf_red "Cannot clone - config files not found for '$source'"
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Nested tmux with single status bar
__tmux_nested() {
  local session_name="${1:-nested-${TMUX_NEW_CWD##*/}}"
  local parent_session="${2:-main}"

  # Create nested tmux config with disabled outer status bar
  local nested_config="$TMUX_NEW_CONFIG_DIR/nested.conf"
  cat >"$nested_config" <<EOF
# Nested tmux configuration - single status bar
# Based on template but optimized for nesting

# Use different prefix for nested session
set-option -g prefix C-a
bind-key C-a send-prefix

# Disable status bar for outer session when nested
if-shell 'test -n "\$TMUX"' 'set -g status off' 'set -g status on'

# Status bar configuration (only for inner/active session)
set -g status on
set -g status-position bottom
set -g status-justify left
set -g status-left-length 50
set -g status-right-length 150

# Visual indicators for nested session
set -g status-left '#[fg=green,bold][NESTED: #S] '
set -g status-right '#[fg=blue]#(whoami)@#h #[fg=yellow]%Y-%m-%d %H:%M'

# Window status format
set -g window-status-format '#[fg=white]#I:#W'
set -g window-status-current-format '#[fg=black,bg=green] #I:#W '

# Colors for nested session distinction
set -g status-bg black
set -g status-fg white

# Pane borders
set -g pane-border-style fg=blue
set -g pane-active-border-style fg=green

# Copy mode
setw -g mode-keys vi

# Mouse support with natural scrolling
set -g mouse on

# Natural mouse scrolling for nested sessions
bind-key -n WheelUpPane if-shell -F -t = "#{alternate_on}" "send-keys -M" "select-pane -t =; copy-mode -e; send-keys -M"
bind-key -n WheelDownPane select-pane -t = \\; send-keys -M

# In copy mode, scroll smoothly
bind-key -T copy-mode WheelUpPane send-keys -X -N 3 scroll-up
bind-key -T copy-mode WheelDownPane send-keys -X -N 3 scroll-down
bind-key -T copy-mode-vi WheelUpPane send-keys -X -N 3 scroll-up
bind-key -T copy-mode-vi WheelDownPane send-keys -X -N 3 scroll-down

# Disable mouse drag to prevent accidental selections
unbind-key -n MouseDrag1Pane
EOF

  if [ -n "$TMUX" ]; then
    # We're inside tmux - create nested session
    printf_blue "🔗 Creating nested tmux session: $session_name"

    # Disable status bar on current (outer) session
    __tmux set -g status off

    # Launch nested session with new config
    __tmux new-session -d -s "$session_name" -c "$TMUX_NEW_CWD"
    __tmux send-keys -t "$session_name" "tmux -f '$nested_config' attach" Enter
    __tmux switch-client -t "$session_name"

    printf_green "✅ Nested session created with single status bar"
  else
    # Not in tmux - create normal session that supports nesting
    printf_blue "🚀 Creating tmux session with nested support: $session_name"
    __tmux -f "$nested_config" new-session -D -A -s "$session_name" -c "$TMUX_NEW_CWD"
  fi

  return $?
}
