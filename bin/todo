#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version           :  202207120126-git
# @Author            :  Jason Hempstead
# @Contact           :  jason@casjaysdev.com
# @License           :  WTFPL
# @ReadME            :  todo --help
# @Copyright         :  Copyright: (c) 2022 Jason Hempstead, Casjays Developments
# @Created           :  Tuesday, Jul 12, 2022 01:26 EDT
# @File              :  todo
# @Description       :  Setup a console base todo
# @TODO              :  Add project support
# @Other             :
# @Resource          :
# @sudo/root         :  no
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202207120126-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
system_install && __options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ -z "$NOTIFY_CLIENT_NAME" ]] || NOTIFY_CLIENT_NAME=""
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE"
  [ -d "$TODO_CONFIG_DIR" ] || mkdir -p "$TODO_CONFIG_DIR"
  [ -d "$TODO_CONFIG_BACKUP_DIR" ] || mkdir -p "$TODO_CONFIG_BACKUP_DIR"
  [ -f "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" ] &&
    cp -Rf "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" "$TODO_CONFIG_BACKUP_DIR/$TODO_CONFIG_FILE.$$"
  cat <<EOF >"$TODO_CONFIG_DIR/$TODO_CONFIG_FILE"
# Settings for todo
TODO_GIT_URL="${TODO_GIT_URL:-}"
TODO_HOME="${TODO_HOME:-$HOME/.local/share/editors/todos}"
TODO_PROJECT_DIR="${TODO_PROJECT_DIR:-all}"
TODO_EDITOR="${TODO_EDITOR:-$(builtin type -P nano 2>/dev/null || builtin type -P vi 2>/dev/null || builtin type -P vim 2>/dev/null || builtin type -P nvim 2>/dev/null || $EDITOR)}"

# Notification settings
TODO_GOOD_MESSAGE="${TODO_GOOD_MESSAGE:-Everything Went OK}"
TODO_ERROR_MESSAGE="${TODO_ERROR_MESSAGE:-Well something seems to have gone wrong}"
TODO_NOTIFY_ENABLED="${TODO_NOTIFY_ENABLED:-yes}"
TODO_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TODO_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TODO_NOTIFY_CLIENT_ICON}"

# Colorization settings
TODO_OUTPUT_COLOR="${TODO_OUTPUT_COLOR:-5}"
TODO_OUTPUT_COLOR_GOOD="${TODO_OUTPUT_COLOR_GOOD:-2}"
TODO_OUTPUT_COLOR_ERROR="${TODO_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__make_todo() {
  local file="$TODO_FILE"
  local dir="$TODO_HOME/$TODO_PROJECT_DIR"
  [[ -d "$dir" ]] && mkdir -p "$dir"
  [[ -f "$dir/$file" ]] || { [[ -s "$dir/$file" ]] && printf '# TODO List for "$project"\n' >>"$dir/$file"; }
  if grep -qswF "$*" "$dir/$file"; then
    __notifications "$* is a duplicate in $TODO_PROJECT_DIR/$file"
    return 0
  fi
  printf '[ ] %s  \n' "$*" >>"$dir/$file"
  if grep -qswF "$*" "$dir/$file"; then
    __notifications "added $* to $TODO_PROJECT_DIR/$file"
    __run_git
  fi
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__editor() {
  local file="$TODO_FILE"
  local dir="$TODO_HOME/$TODO_PROJECT_DIR"
  [[ -d "$dir" ]] && mkdir -p "$dir"
  $TODO_EDITOR "$dir/$file"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_git() {
  [[ -d "$TODO_HOME/.git" ]] || return 0
  [[ -f "$TODO_HOME/README.md" ]] ||
    printf '# 👋 My TODO lists 👋  \nThis repo is a backup of my todos  \n\n' >"$TODO_HOME/README.md"
  [[ -f "$TODO_HOME/todo.conf" ]] || cp -Rf "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" "$TODO_HOME/todo.conf"
  __git_status && gitcommit "$TODO_HOME" todo
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_import() {
  [[ -n "$1" ]] || return
  if [[ -d "$TODO_HOME/.git" ]]; then
    gitadmin "$TODO_HOME" pull
  else
    sed -i 's|TODO_GIT_URL=.*$|TODO_GIT_URL="'$TODO_GIT_URL'"|g' "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE"
    gitadmin clone "$1" "$TODO_HOME"
    [[ -f "$TODO_HOME/todo.conf" ]] &&
      cp -Rf "$TODO_HOME/todo.conf" "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" ||
      cp -Rf "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" "$TODO_HOME/todo.conf"
  fi
  sed -i 's|TODO_HOME="/home/jason|TODO_HOME="'$HOME'|g' "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__git_status() {
  git -C "$TODO_HOME" diff-index --name-only HEAD -- 2>/dev/null | grep -q '^' ||
    git -C "$TODO_HOME" s | grep -v '## ' | grep -q '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
TODO_LOG_DIR="${TODO_LOG_DIR:-$HOME/.local/log/todo}"
TODO_CACHE_DIR="${TODO_CACHE_DIR:-$HOME/.cache/todo}"
TODO_CONFIG_DIR="${TODO_CONFIG_DIR:-$HOME/.config/myscripts/todo}"
TODO_OPTIONS_DIR="${TODO_OPTIONS_DIR:-$HOME/.local/share/myscripts/todo/options}"
TODO_CONFIG_BACKUP_DIR="${TODO_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/todo/backups}"
TODO_TEMP_DIR="${TODO_TEMP_DIR:-$HOME/.local/tmp/system_scripts/todo}"
TODO_CONFIG_FILE="${TODO_CONFIG_FILE:-settings.conf}"
TODO_GOOD_MESSAGE="${TODO_GOOD_MESSAGE:-Everything Went OK}"
TODO_ERROR_MESSAGE="${TODO_ERROR_MESSAGE:-Well something seems to have gone wrong}"
TODO_NOTIFY_ENABLED="${TODO_NOTIFY_ENABLED:-yes}"
TODO_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TODO_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TODO_NOTIFY_CLIENT_ICON}"
TODO_OUTPUT_COLOR="${TODO_OUTPUT_COLOR:-5}"
TODO_OUTPUT_COLOR_GOOD="${TODO_OUTPUT_COLOR_GOOD:-2}"
TODO_OUTPUT_COLOR_ERROR="${TODO_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Enviroment overrides
TODO_EDITOR="${TODO_EDITOR:-$(builtin type -P nano 2>/dev/null || builtin type -P vi 2>/dev/null || builtin type -P vim 2>/dev/null || builtin type -P nvim 2>/dev/null || $EDITOR)}"
TODO_HOME="${TODO_HOME:-$HOME/.local/share/editors/todos}"
TODO_FILE="${TODO_FILE:-index.md}"
TODO_GIT_URL="${TODO_GIT_URL:-}"
TODO_PROJECT_DIR="${TODO_PROJECT_DIR:-all}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" ] && . "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$TODO_LOG_DIR" ] || mkdir -p "$TODO_LOG_DIR" &>/dev/null
[ -d "$TODO_TEMP_DIR" ] || mkdir -p "$TODO_TEMP_DIR" &>/dev/null
[ -d "$TODO_CACHE_DIR" ] || mkdir -p "$TODO_CACHE_DIR" &>/dev/null
[[ -d "$TODO_HOME" ]] || mkdir -p "$TODO_HOME" &>/dev/null
TODO_TEMP_FILE="${TODO_TEMP_FILE:-$(mktemp $TODO_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$TODO_TEMP_FILE" ] && [ -f "$TODO_TEMP_FILE" ] && rm -Rf "$TODO_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$TODO_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${TODO_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${TODO_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${TODO_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${TODO_NOTIFY_CLIENT_ICON}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="p:"
LONGOPTS="debug,options,config,version,help,dir:"
ARRAY="complete import list search edit update"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --debug)
    shift 1
    set -xo pipefail
    export SCRIPT_OPTS="--debug"
    export _DEBUG="on"
    ;;
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    TODO_CWD="$2"
    shift 2
    ;;
  -p)
    TODO_PROJECT_DIR="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#__am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
[[ -d "$TODO_HOME/.git" ]] && git -C "$TODO_HOME" pull -q
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
import)
  shift 1
  [[ -d "$TODO_HOME/.git" ]] && printf_exit "TODO is already configured to use git"
  TODO_GIT_URL="${1:-$TODO_GIT_URL}"
  [[ "$(find $TODO_HOME/* 2>/dev/null | wc -l)" = 0 ]] || printf_exit "$TODO_HOME is not empty"
  if [[ -n "$TODO_GIT_URL" ]] || [[ -n "$1" ]]; then
    __git_import "${1:-$TODO_GIT_URL}" || printf_exit "no repo specified"
  elif [[ $# = 0 ]]; then
    printf_read_question 6 "Would you like to import from git" "1" "Yy"
    if printf_answer_yes "$Yy"; then
      printf_read_question "3" "URL is the url to repo ?" "120" "TODO_GIT_URL" ""
      [[ -n "$TODO_GIT_URL" ]] && __git_import "$TODO_GIT_URL" || printf_exit "no repo specified"
    else
      printf_exit "Import cancelled by user"
    fi
  else
    false
  fi
  exit $?
  ;;

update)
  shift 1
  [[ -d "$TODO_HOME/.git" ]] || printf_exit "You have not setup TODOs to use git"
  git -C "$TODO_HOME" pull -q &>/dev/null && printf_cyan "Todos have been updated from remote repo"
  exit $?
  ;;

complete)
  shift 1
  __editor
  grep -isF '^[x] ' "$TODO_HOME/$TODO_PROJECT_DIR/$TODO_FILE" >>"$TODO_HOME/$TODO_PROJECT_DIR/completed.md"
  grep -isF '^[ ] ' "$TODO_HOME/$TODO_PROJECT_DIR/$TODO_FILE" >"$TODO_HOME/tmp.bak"
  if [[ -f "$TODO_HOME/tmp.bak" ]]; then
    mv -f "$TODO_HOME/tmp.bak" "$TODO_HOME/$TODO_PROJECT_DIR/$TODO_FILE"
    rm -Rf "$TODO_HOME/tmp.bak"
  fi
  __run_git
  exit
  ;;

list)
  shift 1
  [[ -f "$TODO_HOME/$TODO_PROJECT_DIR/$TODO_FILE" ]] &&
    cat "$TODO_HOME/$TODO_PROJECT_DIR/$TODO_FILE" | printf_readline | grep '^' ||
    printf_exit "No todos where found"
  ;;

search)
  shift 1
  search_results="$(grep -siF "$1" "$TODO_HOME/$TODO_PROJECT_DIR/$TODO_FILE" 2>/dev/null)"
  if [ -n "$search_results" ]; then
    printf_green "Search results: "
    echo "$search_results" | printf_readline "7"
    exitCode=0
  else
    printf_red "No results found"
    exitCode=1
  fi
  exit $exitCode
  ;;

edit | new)
  shift 1
  __editor
  __run_git
  exit $?
  ;;

-)
  shift 1
  if [ -p "/dev/stdin" ]; then
    message="$(</dev/stdin)"
    __make_todo "$message"
  fi
  ;;

*)
  if [ ${#} -eq 0 ]; then
    if [ -p "/dev/stdin" ]; then
      message="$(</dev/stdin)"
      __make_todo "$message"
    else
      printf_exit "No input was detected"
    fi
  else
    message="$*"
    __make_todo "$message"
  fi
  exit ${exitCode:-$?}
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
