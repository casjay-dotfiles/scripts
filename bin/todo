#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108181418-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -xo pipefail && export DEBUGGING="true"
trap 'exitCode=${exitCode:-$?};[ -f "$TODO_TEMP_FILE" ] && rm -Rf "$TODO_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108181418-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : todo --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Aug 18, 2021 14:18 EDT
# @File          : todo
# @Description   : Setup a console base todo
# @TODO          : Clean up code
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE"
  [ -d "$TODO_CONFIG_DIR" ] || mkdir -p "$TODO_CONFIG_DIR"
  [ -d "$TODO_CONFIG_BACKUP_DIR" ] || mkdir -p "$TODO_CONFIG_BACKUP_DIR"
  [ -f "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" ] &&
    cp -Rf "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" "$TODO_CONFIG_BACKUP_DIR/$TODO_CONFIG_FILE.$$"
  cat <<EOF >"$TODO_CONFIG_DIR/$TODO_CONFIG_FILE"
# Settings for todo
TODO_CWD="${TODO_DIR:-$HOME/.local/share/editors/todos}"
TODO_EDITOR="${TODO_EDITOR:-vim}"
TODO_GIT="${TODO_GIT:-disabled}"
TODO_HOUR_FMT="\$(date +"%H:%M")"
TODO_MONTH_FMT="\$(date +"%m")"
TODO_YEAR_FMT="\$(date +"%Y")"
TODO_DAY_FMT="\$(date +"%d")"
TODO_ARCHIVE_DIR="${TODO_ARCHIVE_DIR:-$TODO_CWD/archives/\$TODO_YEAR_FMT/\$TODO_MONTH_FMT}"
TODO_ARCHIVE_FILE="$TODO_ARCHIVE_DIR/\$TODO_DAY_FMT-\$TODO_HOUR_FMT.md"
TODO_TITLE_FMT="Created on \$(date +"%B") \$(date +"%d"), \$TODO_YEAR_FMT at \$TODO_HOUR_FMT"

# Notification settings
TODO_GOOD_MESSAGE="${TODO_GOOD_MESSAGE:-Everything Went OK}"
TODO_ERROR_MESSAGE="${TODO_ERROR_MESSAGE:-Well that didn\'t work}"
TODO_NOTIFY_ENABLED="${TODO_NOTIFY_ENABLED:-yes}"
TODO_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TODO_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TODO_NOTIFY_CLIENT_ICON}"

# Colorization settings
TODO_OUTPUT_COLOR="${TODO_OUTPUT_COLOR:-5}"
TODO_OUTPUT_COLOR_GOOD="${TODO_OUTPUT_COLOR_GOOD:-2}"
TODO_OUTPUT_COLOR_ERROR="${TODO_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" ]; then
    printf_green "Your config file for todo has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__filename() {
  if [ -n "$1" ]; then
    cleaninput=${*// /\/}
    name="${cleaninput:-all}"
    file="${name//$TODO_CWD/$name}"
  else
    name="all"
    file="$name/index.md"
  fi
  filename="${file//$TODO_CWD/$file}"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_tmux() {
  local name="$name"
  local filename="$filename"
  if [ ! -f "$TODO_CWD/$filename" ] || [ ! -s "$TODO_CWD/$filename" ]; then
    local titleheader="TODO for $name: $TODO_TITLE_FMT  "
    [ -d "$TODO_CWD/all" ] || __mkd "$TODO_CWD/all"
    [ -d "$TODO_CWD/$name" ] || __mkd "$TODO_CWD/$name"
    if [ -d "$TODO_CWD/$filename" ]; then
      filename="$filename/index.md"
    else
      filename="${filename:-}"
    fi
    printf "%s\n\n" "## $titleheader" >"$TODO_CWD/$filename"
  fi
  __tmux "$TODO_CWD/$filename"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__delete() {
  if [ -f "$1" ] || [ -d "$1" ]; then
    __rm_rf "$1" && return 0 || return 1
  else
    MESG="The file $1 doesn't exist" && return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__tmux() {
  unset TMUX
  [ ! -f "$TODO_CWD/tmux.conf" ] && [ -f "$HOME/.config/tmux/others/editors.conf" ] &&
    cp -Rf "$HOME/.config/tmux/others/editors.conf" "$TODO_CWD/tmux.conf" &>/dev/null ||
    cp -Rf "$CASJAYSDEVDIR/templates/tmux.conf" "$TODO_CWD/tmux.conf" &>/dev/null
  tmux -f "$TODO_CWD/tmux.conf" new-session -D -A -s todo "$TODO_EDITOR $1" &>/dev/null
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_git() { [ -d "$TODO_CWD/.git" ] && gitcommit "$TODO_CWD" todo || gitadmin "$TODO_CWD" setup; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
TODO_LOG_DIR="${TODO_LOG_DIR:-$HOME/.local/log/todo}"
TODO_CACHE_DIR="${TODO_CACHE_DIR:-$HOME/.cache/todo}"
TODO_CONFIG_DIR="${TODO_CONFIG_DIR:-$HOME/.config/myscripts/todo}"
TODO_CONFIG_BACKUP_DIR="${TODO_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/todo/backups}"
TODO_TEMP_DIR="${TODO_TEMP_DIR:-$HOME/.local/tmp/system_scripts/todo}"
TODO_OPTIONS_DIR="${TODO_OPTIONS_DIR:-$HOME/.local/share/myscripts/todo/options}"
TODO_TEMP_FILE="${TODO_TEMP_FILE:-$(mktemp $TODO_TEMP_DIR/XXXXXX 2>/dev/null)}"
TODO_CONFIG_FILE="${TODO_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
TODO_OUTPUT_COLOR="${TODO_OUTPUT_COLOR:-4}"
TODO_OUTPUT_COLOR_2="${TODO_OUTPUT_COLOR:-6}"
TODO_OUTPUT_COLOR_GOOD="${TODO_OUTPUT_COLOR_GOOD:-2}"
TODO_OUTPUT_COLOR_ERROR="${TODO_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
TODO_GOOD_MESSAGE="${TODO_GOOD_MESSAGE:-Everything Went OK}"
TODO_ERROR_MESSAGE="${TODO_ERROR_MESSAGE:-Well that didn\'t work}"
TODO_NOTIFY_ENABLED="${TODO_NOTIFY_ENABLED:-yes}"
TODO_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TODO_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TODO_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
TODO_HOUR_FMT="${TODO_HOUR_FMT:-$(date +"%H:%M")}"
TODO_MONTH_FMT="${TODO_MONTH_FMT:-$(date +"%m")}"
TODO_YEAR_FMT="${TODO_YEAR_FMT:-$(date +"%Y")}"
TODO_DAY_FMT="${TODO_DAY_FMT:-$(date +"%d")}"
TODO_EDITOR="${TODO_EDITOR:-vim}"
TODO_CWD="${TODO_DIR:-$HOME/.local/share/editors/todos}"
TODO_ARCHIVE_DIR="${TODO_ARCHIVE_DIR:-$TODO_CWD/archives/$TODO_YEAR_FMT/$TODO_MONTH_FMT}"
TODO_ARCHIVE_FILE="${TODO_ARCHIVE_FILE:-$TODO_ARCHIVE_DIR/$TODO_DAY_FMT-$TODO_HOUR_FMT.md}"
TODO_TITLE_FMT="${TODO_TITLE:-Created on $(date +"%B") $(date +"%d"), $TODO_YEAR_FMT at $TODO_HOUR_FMT}"
TODO_GIT="${TODO_GIT:-disabled}"
TODO_CONFIG_DIR="${TODO_CONFIG_DIR:-/$HOME/.config/todo}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" ] && . "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$TODO_LOG_DIR" ] || mkdir -p "$TODO_LOG_DIR" &>/dev/null
[ -d "$TODO_TEMP_DIR" ] || mkdir -p "$TODO_TEMP_DIR" &>/dev/null
[ -d "$TODO_CACHE_DIR" ] || mkdir -p "$TODO_CACHE_DIR" &>/dev/null
[ -d "$TODO_CWD" ] || mkdir -p "$TODO_CWD" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$TODO_CONFIG_DIR/$TODO_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY="git list archive remove open "
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "-$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    TODO_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$TODO_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${TODO_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${TODO_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${TODO_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${TODO_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash $TODO_EDITOR || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
git)
  shift 1
  __run_git
  ;;

list)
  shift 1
  if [ -d "$TODO_CWD" ] && [ "$(__count_files "$TODO_CWD" "4")" -ne 0 ]; then
    printf_green "Listing the files in $TODO_CWD"
    find -L "$TODO_CWD" -type f,l -iname "*.md" -o -iname "*.txt" | sed 's#'$TODO_CWD/'##g' | printf_column $TODO_OUTPUT_COLOR
  else
    printf_exit "No todos exist in: $TODO_CWD"
  fi
  ;;

archive)
  shift 1
  __filename "$*"
  if [ ! -d "$TODO_ARCHIVE_DIR" ]; then
    printf_green "Creating $TODO_ARCHIVE_DIR directory"
    __mkd "$TODO_ARCHIVE_DIR"
  fi
  if [ -f "$TODO_CWD/$filename" ]; then
    printf_green "Archiving $TODO_CWD/$filename to:"
    printf_green "$TODO_ARCHIVE_FILE"
    mv -f "$TODO_CWD/$filename" "$TODO_ARCHIVE_FILE" &>/dev/null
    [ -f "$TODO_ARCHIVE_FILE" ] && printf_green "File has been archived" || printf_error "Failed to achive file"
  else
    printf_exit "$TODO_CWD/$filename doesn't exist"
  fi
  ;;

remove)
  shift 1
  __filename "$*"
  if __delete "$TODO_CWD/$filename"; then
    printf_green "$TODO_CWD/$filename has been deleted"
    exitCode=0
  elif [ -n "$MESG" ]; then
    printf_error "$MESG"
    exitCode=1
  else
    printf_error "failed to delete $TODO_CWD/$filename"
    exitCode=1
  fi
  exit $exitCode
  ;;

open)
  shift 1
  __filename "$*"
  __run_tmux "$TODO_CWD/$filename"
  ;;

*)
  __filename "$*"
  __run_tmux "$TODO_CWD/$filename"
  ;;
esac
[ "$TODO_GIT" != "enabled" ] || __run_git
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
