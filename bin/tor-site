#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108181057-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : tor-site --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Aug 18, 2021 10:57 EDT
# @File          : tor-site
# @Description   : Run a tor hidden site
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108181057-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$TOR_SITE_TEMP_FILE" ] && [ -f "$TOR_SITE_TEMP_FILE" ] && rm -Rf "$TOR_SITE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$TOR_SITE_CONFIG_DIR/$TOR_SITE_CONFIG_FILE"
  [ -d "$TOR_SITE_CONFIG_DIR" ] || mkdir -p "$TOR_SITE_CONFIG_DIR"
  [ -d "$TOR_SITE_CONFIG_BACKUP_DIR" ] || mkdir -p "$TOR_SITE_CONFIG_BACKUP_DIR"
  [ -f "$TOR_SITE_CONFIG_DIR/$TOR_SITE_CONFIG_FILE" ] &&
    cp -Rf "$TOR_SITE_CONFIG_DIR/$TOR_SITE_CONFIG_FILE" "$TOR_SITE_CONFIG_BACKUP_DIR/$TOR_SITE_CONFIG_FILE.$$"
  cat <<EOF >"$TOR_SITE_CONFIG_DIR/$TOR_SITE_CONFIG_FILE"
# Settings for tor-site
TOR_SITE_CWD="${TOR_SITE_CWD:-$HOME/Public/tor}"
TOR_SITE_PORT="${TOR_SITE_PORT:-8082}"
TOR_SITE_PID_FILE="${TOR_SITE_PID_FILE:-$TOR_SITE_TEMP_DIR/\$TOR_SITE_PORT.pid}"

# Notification settings
TOR_SITE_GOOD_MESSAGE="${TOR_SITE_GOOD_MESSAGE:-Everything Went OK}"
TOR_SITE_ERROR_MESSAGE="${TOR_SITE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
TOR_SITE_NOTIFY_ENABLED="${TOR_SITE_NOTIFY_ENABLED:-yes}"
TOR_SITE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TOR_SITE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TOR_SITE_NOTIFY_CLIENT_ICON}"

# Colorization settings
TOR_SITE_OUTPUT_COLOR="${TOR_SITE_OUTPUT_COLOR:-5}"
TOR_SITE_OUTPUT_COLOR_GOOD="${TOR_SITE_OUTPUT_COLOR_GOOD:-2}"
TOR_SITE_OUTPUT_COLOR_ERROR="${TOR_SITE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$TOR_SITE_CONFIG_DIR/$TOR_SITE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for tor-site has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      exit 1
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__is_root() { { sudo -ll -U ${1:-$USER} 2>/dev/null | grep -q 'ALL' &>/dev/null || sudo -n -u ${1:-$USER} &>/dev/null || [[ "$EUID" = 0 ]]; } && return 0 || return 1; }
__replace() { sed -i 's|'"$1"'|'"$2"'|g' "$3" 2>/dev/null; }
__stop_server() { kill -9 "${1:-$pid}" &>/dev/null && return 0 || return 1; }
__test_server() { netstatg "${1:-$TOR_SITE_PORT}" | grep -q python && return 0 || return 1; }
__cd() { cd "${1:-$TOR_SITE_CWD}" || { echo "Failed to enter ${1:-$TOR_SITE_CWD}" && return 1; }; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_pid() {
  local pid="$(ps -ef | grep $1 | grep python | tr -s ' ' | cut -d ' ' -f2)"
  [[ -n "$pid" ]] && echo "$pid" >"$TOR_SITE_PID_FILE" || __rm_rf "$TOR_SITE_PID_FILE"
  [ -f "$TOR_SITE_PID_FILE" ] && [[ -s "$TOR_SITE_PID_FILE" ]] && cat "$TOR_SITE_PID_FILE"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__server_status() {
  TOR_SITE_PORT="${1:-$TOR_SITE_PORT}"
  pid="$(__get_pid "$TOR_SITE_PORT")"
  if [[ -n "$pid" ]]; then
    echo "Running on http://localhost:$TOR_SITE_PORT with pid: $pid" | printf_readline $TOR_SITE_OUTPUT_COLOR
  else
    printf_red "Not running on http://localhost:$TOR_SITE_PORT"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_server() {
  __cd "$TOR_SITE_CWD"
  { python3 -m http.server --cgi --bind 127.0.0.1 "$TOR_SITE_PORT" &>/dev/null ||
    python2 -m http.server --cgi --bind 127.0.0.1 "$TOR_SITE_PORT" &>/dev/null ||
    python -m SimpleHTTPServer "$TOR_SITE_PORT" &>/dev/null || return 1; } &
  sleep 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__run_service_server() {
  __cd "$TOR_SITE_CWD"
  { python3 -m http.server --cgi --bind 127.0.0.1 "$TOR_SITE_PORT" &>/dev/null ||
    python2 -m http.server --cgi --bind 127.0.0.1 "$TOR_SITE_PORT" &>/dev/null ||
    python -m SimpleHTTPServer "$TOR_SITE_PORT" &>/dev/null || return 1; }
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__start_py_server() {
  local TOR_SITE_CWD="${1:-$TOR_SITE_CWD}"
  local TOR_SITE_PORT="${2:-$TOR_SITE_PORT}"
  local exitCode="0"
  __run_server || return 1
  if __test_server "$TOR_SITE_PORT" &>/dev/null; then
    TOR_SERVER_STATUS="running"
    TOR_SERVER_STATUS_PID="$(__get_pid "$TOR_SITE_PORT")"
    exitCode=0
  else
    TOR_SERVER_STATUS="not_running"
    TOR_SERVER_STATUS_PID="0000"
    echo "Failed"
    exitCode=1
  fi
  export TOR_SERVER_STATUS TOR_SERVER_STATUS_PID
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__create_site() {
  local dir="${1:-$TOR_SITE_CWD}"
  local port="${2:-$TOR_SITE_PORT}"
  printf_blue "Creating your tor site"
  if [[ ! -f "$dir/$port/index.html" ]] && [[ ! -d "$dir/$port" ]]; then
    __mkd "$dir/$port" &>/dev/null
    __cp_rf "$CASJAYSDEVDIR/templates/tor-site/." "$dir/$port" &>/dev/null
    __replace "REPLACE_MYHOSTNAME" "$HOSTNAME" "$dir/$port/index.html" &>/dev/null
    __replace "REPLACE_FOLDER" "$dir/$port" "$dir/$port/index.html" &>/dev/null
    __replace "REPLACE_SYSTEMD" "tor_site_$port.service" "$dir/$port/index.html" &>/dev/null
  fi
  if [[ -f "$dir/$port/index.html" ]]; then
    printf_green "Setup tor-site to listen on port $port"
    printf_green "and to serve $dir/$port"
    exitCode=0
  else
    printf_red "Failed to setup $dir/$port"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__systemd() {
  local dir="${1:-$TOR_SITE_CWD}"
  local port="${2:-$TOR_SITE_PORT}"
  __create_site "$dir" "$port"
  cat <<EOF | sudo tee /etc/systemd/system/tor_site_$port.service &>/dev/null
[Unit]
Description=Tor Hidden Site localhost:$port
Before=tor.service
After=network.target

[Service]
Type=simple
User=$USER
Environment=TOR_SITE_PORT="$port"
Environment=TOR_SITE_CWD="$dir/$port"
WorkingDirectory=$dir/$port
ExecStart=/bin/bash -c "$SRC_DIR/$APPNAME service run $port $dir/$port"
ExecStop=/bin/bash -c "$SRC_DIR/$APPNAME stop $port"
Restart=always
#RestartSec=5
#StartLimitBurst=10
#StartLimitInterval=60s

[Install]
WantedBy=multi-user.target

EOF
}

__service() {
  local dir="${1:-$TOR_SITE_CWD}"
  local port="${2:-$TOR_SITE_PORT}"
  #!/usr/bin/env xdg-open
  cat <<EOF | tee /.config/autostart/tor_site_$port.desktop &>/dev/null
[Desktop Entry]
Version=1.0
Type=Application
Name=Tor-$port
GenericName=Tor-$port
Comment=Tor service on port $port.
Icon=tor
Exec=/bin/bash -c "$SRC_DIR/$APPNAME service run $port $dir/$port"
Terminal=false
Actions=
Categories=Internet;GTK;X-XFCE;GNOME;MyScripts
Keywords=mpd;music;player;my;
StartupNotify=false

EOF
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
TOR_SITE_LOG_DIR="${TOR_SITE_LOG_DIR:-$HOME/.local/log/tor-site}"
TOR_SITE_CACHE_DIR="${TOR_SITE_CACHE_DIR:-$HOME/.cache/tor-site}"
TOR_SITE_CONFIG_DIR="${TOR_SITE_CONFIG_DIR:-$HOME/.config/myscripts/tor-site}"
TOR_SITE_CONFIG_BACKUP_DIR="${TOR_SITE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/tor-site/backups}"
TOR_SITE_TEMP_DIR="${TOR_SITE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/tor-site}"
TOR_SITE_OPTIONS_DIR="${TOR_SITE_OPTIONS_DIR:-$HOME/.local/share/myscripts/tor-site/options}"
TOR_SITE_TEMP_FILE="${TOR_SITE_TEMP_FILE:-$(mktemp $TOR_SITE_TEMP_DIR/XXXXXX 2>/dev/null)}"
TOR_SITE_CONFIG_FILE="${TOR_SITE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
TOR_SITE_OUTPUT_COLOR="${TOR_SITE_OUTPUT_COLOR:-4}"
TOR_SITE_OUTPUT_COLOR_2="${TOR_SITE_OUTPUT_COLOR:-6}"
TOR_SITE_OUTPUT_COLOR_GOOD="${TOR_SITE_OUTPUT_COLOR_GOOD:-2}"
TOR_SITE_OUTPUT_COLOR_ERROR="${TOR_SITE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
TOR_SITE_GOOD_MESSAGE="${TOR_SITE_GOOD_MESSAGE:-Everything Went OK}"
TOR_SITE_ERROR_MESSAGE="${TOR_SITE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
TOR_SITE_NOTIFY_ENABLED="${TOR_SITE_NOTIFY_ENABLED:-yes}"
TOR_SITE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TOR_SITE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TOR_SITE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
TOR_SITE_CWD="${TOR_SITE_CWD:-$HOME/Public/tor}"
TOR_SITE_PORT="${TOR_SITE_PORT:-8082}"
TOR_SITE_PID_FILE="${TOR_SITE_PID_FILE:-$TOR_SITE_TEMP_DIR/\$TOR_SITE_PORT.pid}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$TOR_SITE_CONFIG_DIR/$TOR_SITE_CONFIG_FILE" ] && . "$TOR_SITE_CONFIG_DIR/$TOR_SITE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$TOR_SITE_LOG_DIR" ] || mkdir -p "$TOR_SITE_LOG_DIR" &>/dev/null
[ -d "$TOR_SITE_TEMP_DIR" ] || mkdir -p "$TOR_SITE_TEMP_DIR" &>/dev/null
[ -d "$TOR_SITE_CACHE_DIR" ] || mkdir -p "$TOR_SITE_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$TOR_SITE_CONFIG_DIR/$TOR_SITE_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
__is_root && TOR_SITE_CWD="/usr/local/share/tor-site"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="p:"
LONGOPTS="options,config,version,help,dir:,port:"
ARRAY="status stop service create"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    TOR_SITE_CWD="$2"
    shift 2
    ;;
  -p | --port)
    TOR_SITE_PORT="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$TOR_SITE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${TOR_SITE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${TOR_SITE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${TOR_SITE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${TOR_SITE_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
status)
  shift 1
  TOR_SITE_PORT="${1:-$TOR_SITE_PORT}"
  __server_status "$1"
  exit $?
  ;;

stop)
  shift 1
  TOR_SITE_PORT="${1:-$TOR_SITE_PORT}"
  pid="$(__get_pid "$TOR_SITE_PORT")"
  if [[ -n "$pid" ]]; then
    if __stop_server "$pid" &>/dev/null; then
      printf_green "Server has been stopped"
      exitCode=0
    else
      printf_return "Failed to stop the server: kill -9 $pid"
      exitCode=1
    fi
  else
    printf_red "No sites are running on port $TOR_SITE_PORT"
    exitCode=0
  fi
  exit ${exitCode:-$?}
  ;;

service) # service options
  shift 1
  case "$1" in
  install)
    shift 1
    if __is_root "$USER" &>/dev/null; then
      printf_green "Creating systemd service"
      __systemd ${1:-$TOR_SITE_CWD} ${2:-$TOR_SITE_PORT}
      if [[ -f "/etc/systemd/system/tor_site_$TOR_SITE_PORT.service" ]]; then
        sudo systemctl daemon-reload &>/dev/null
        sudo systemctl enable --now tor_site_$TOR_SITE_PORT.service &>/dev/null
        printf_blue "Systemd service has been created"
      else
        printf_exit "Failed to create tor sevice"
      fi
    else
      printf_red "You need to be root in order to install the systemd service"
      printf_blue "Configuring for a user install instead"
      __create_site ${1:-$TOR_SITE_CWD} ${2:-$TOR_SITE_PORT}
    fi
    ;;

  remove)
    shift 1
    TOR_SITE_PORT="${1:-$TOR_SITE_PORT}"
    TOR_SITE_CWD="${2:-$TOR_SITE_CWD}"
    if [ -f "/etc/systemd/system/tor_site_$TOR_SITE_PORT.service" ]; then
      printf_cyan "Removing tor_site_$TOR_SITE_PORT.service"
      sudo systemctl disable --now tor_site_$TOR_SITE_PORT.service &>/dev/null &&
        sudo rm -Rf /etc/systemd/system/tor_site_$TOR_SITE_PORT.service &>/dev/null &&
        sudo systemctl daemon-reload &>/dev/null
    else
      printf_blue "No systemd service exists for tor-site on $TOR_SITE_PORT"
    fi
    exit $?
    ;;

  create)
    shift 1
    __create_site ${1:-$TOR_SITE_CWD} ${2:-$TOR_SITE_PORT}
    exit $?
    ;;

  run)
    shift 1
    TOR_SITE_PORT="${1:-$TOR_SITE_PORT}"
    TOR_SITE_CWD="${2:-$TOR_SITE_CWD}"
    __run_service_server "$TOR_SITE_CWD" "$TOR_SITE_PORT"
    exit ${exitCode:-$?}
    ;;
  esac
  ;; # end service options

create)
  shift 1
  __create_site ${1:-$TOR_SITE_CWD} ${2:-$TOR_SITE_PORT}
  exit $?
  ;;

*)
  if [ -d "$TOR_SITE_CWD" ]; then
    cd "$TOR_SITE_CWD" || printf_exit 1 1 "Failed to enter $TOR_SITE_CWD"
    if __test_server "$TOR_SITE_PORT" &>/dev/null; then
      printf_exit "Something is already running on port $TOR_SITE_PORT"
    else
      printf_green "Attempting to start development server on http://localhost:$TOR_SITE_PORT"
      __start_py_server "$TOR_SITE_CWD" "$TOR_SITE_PORT"
      printf_cyan "type kill -9 $(__get_pid "$TOR_SITE_PORT") to stop the server"
    fi
  else
    printf_exit 1 "2" "The directory $TOR_SITE_CWD does not exist"
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
