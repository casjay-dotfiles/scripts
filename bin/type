#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108172203-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : type --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Tuesday, Aug 17, 2021 22:03 EDT
# @File          : type
# @Description   : bash builtin type
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108172203-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$TYPE_TEMP_FILE" ] && [ -f "$TYPE_TEMP_FILE" ] && rm -Rf "$TYPE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-simple.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$TYPE_CONFIG_DIR/$TYPE_CONFIG_FILE"
  [ -d "$TYPE_CONFIG_DIR" ] || mkdir -p "$TYPE_CONFIG_DIR"
  [ -d "$TYPE_CONFIG_BACKUP_DIR" ] || mkdir -p "$TYPE_CONFIG_BACKUP_DIR"
  [ -f "$TYPE_CONFIG_DIR/$TYPE_CONFIG_FILE" ] &&
    cp -Rf "$TYPE_CONFIG_DIR/$TYPE_CONFIG_FILE" "$TYPE_CONFIG_BACKUP_DIR/$TYPE_CONFIG_FILE.$$"
  cat <<EOF >"$TYPE_CONFIG_DIR/$TYPE_CONFIG_FILE"
# Settings for type

# Notification settings
TYPE_GOOD_MESSAGE="${TYPE_GOOD_MESSAGE:-Everything Went OK}"
TYPE_ERROR_MESSAGE="${TYPE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
TYPE_NOTIFY_ENABLED="${TYPE_NOTIFY_ENABLED:-yes}"
TYPE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TYPE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TYPE_NOTIFY_CLIENT_ICON}"

# Colorization settings
TYPE_OUTPUT_COLOR="${TYPE_OUTPUT_COLOR:-5}"
TYPE_OUTPUT_COLOR_GOOD="${TYPE_OUTPUT_COLOR_GOOD:-2}"
TYPE_OUTPUT_COLOR_ERROR="${TYPE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$TYPE_CONFIG_DIR/$TYPE_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for type has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      exit 1
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
TYPE_LOG_DIR="${TYPE_LOG_DIR:-$HOME/.local/log/type}"
TYPE_CACHE_DIR="${TYPE_CACHE_DIR:-$HOME/.cache/type}"
TYPE_CONFIG_DIR="${TYPE_CONFIG_DIR:-$HOME/.config/myscripts/type}"
TYPE_CONFIG_BACKUP_DIR="${TYPE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/type/backups}"
TYPE_TEMP_DIR="${TYPE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/type}"
TYPE_OPTIONS_DIR="${TYPE_OPTIONS_DIR:-$HOME/.local/share/myscripts/type/options}"
TYPE_TEMP_FILE="${TYPE_TEMP_FILE:-$(mktemp $TYPE_TEMP_DIR/XXXXXX 2>/dev/null)}"
TYPE_CONFIG_FILE="${TYPE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
TYPE_OUTPUT_COLOR="${TYPE_OUTPUT_COLOR:-4}"
TYPE_OUTPUT_COLOR_2="${TYPE_OUTPUT_COLOR:-6}"
TYPE_OUTPUT_COLOR_GOOD="${TYPE_OUTPUT_COLOR_GOOD:-2}"
TYPE_OUTPUT_COLOR_ERROR="${TYPE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
TYPE_GOOD_MESSAGE="${TYPE_GOOD_MESSAGE:-Everything Went OK}"
TYPE_ERROR_MESSAGE="${TYPE_ERROR_MESSAGE:-Well something seems to have gone wrong}"
TYPE_NOTIFY_ENABLED="${TYPE_NOTIFY_ENABLED:-yes}"
TYPE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
TYPE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$TYPE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$TYPE_CONFIG_DIR/$TYPE_CONFIG_FILE" ] && . "$TYPE_CONFIG_DIR/$TYPE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$TYPE_LOG_DIR" ] || mkdir -p "$TYPE_LOG_DIR" &>/dev/null
[ -d "$TYPE_TEMP_DIR" ] || mkdir -p "$TYPE_TEMP_DIR" &>/dev/null
[ -d "$TYPE_CACHE_DIR" ] || mkdir -p "$TYPE_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$TYPE_CONFIG_DIR/$TYPE_CONFIG_FILE" ] || [[ "$*" = "--config" ]] || INIT_CONFIG=TRUE __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="a,f,p,t,P"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    TYPE_CWD="$2"
    shift 2
    ;;
  -a)
    OPT="$1"
    shift 1
    ;;
  -f)
    OPT="$1"
    shift 1
    ;;
  -p)
    OPT="$1"
    shift 1
    ;;
  -t)
    OPT="$1"
    shift 1
    ;;
  -P)
    OPT="$1"
    shift 1
    ;;
  --)
    shift 1
    ARGS="$1"
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$TYPE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${TYPE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${TYPE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${TYPE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${TYPE_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
builtin type $OPT $ARGS
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
