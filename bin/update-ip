#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108172203-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$UPDATE_IP_TEMP_FILE" ] && rm -Rf "$UPDATE_IP_TEMP_FILE" &>/dev/null' EXIT
PATH="/usr/games:$PATH"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108172203-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : update-ip --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Tuesday, Aug 17, 2021 22:03 EDT
# @File          : update-ip
# @Description   : Updates the ip address for motd and issue files
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$UPDATE_IP_CONFIG_DIR/$UPDATE_IP_CONFIG_FILE"
  [ -d "$UPDATE_IP_CONFIG_DIR" ] || mkdir -p "$UPDATE_IP_CONFIG_DIR"
  [ -d "$UPDATE_IP_CONFIG_BACKUP_DIR" ] || mkdir -p "$UPDATE_IP_CONFIG_BACKUP_DIR"
  [ -f "$UPDATE_IP_CONFIG_DIR/$UPDATE_IP_CONFIG_FILE" ] &&
    cp -Rf "$UPDATE_IP_CONFIG_DIR/$UPDATE_IP_CONFIG_FILE" "$UPDATE_IP_CONFIG_BACKUP_DIR/$UPDATE_IP_CONFIG_FILE.$$"
  cat <<EOF >"$UPDATE_IP_CONFIG_DIR/$UPDATE_IP_CONFIG_FILE"
# Settings for update-ip

# Notification settings
UPDATE_IP_GOOD_MESSAGE="${UPDATE_IP_GOOD_MESSAGE:-Everything Went OK}"
UPDATE_IP_ERROR_MESSAGE="${UPDATE_IP_ERROR_MESSAGE:-Well that didn\'t work}"
UPDATE_IP_NOTIFY_ENABLED="${UPDATE_IP_NOTIFY_ENABLED:-yes}"
UPDATE_IP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
UPDATE_IP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$UPDATE_IP_NOTIFY_CLIENT_ICON}"

# Colorization settings
UPDATE_IP_OUTPUT_COLOR="${UPDATE_IP_OUTPUT_COLOR:-5}"
UPDATE_IP_OUTPUT_COLOR_GOOD="${UPDATE_IP_OUTPUT_COLOR_GOOD:-2}"
UPDATE_IP_OUTPUT_COLOR_ERROR="${UPDATE_IP_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$UPDATE_IP_CONFIG_DIR/$UPDATE_IP_CONFIG_FILE" ]; then
    printf_green "Your config file for update-ip has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
UPDATE_IP_CACHE_DIR="${UPDATE_IP_CACHE_DIR:-/$HOME/.cache/update-ip}"
UPDATE_IP_CONFIG_DIR="${UPDATE_IP_CONFIG_DIR:-$HOME/.config/myscripts/update-ip}"
UPDATE_IP_OPTIONS_DIR="${UPDATE_IP_OPTIONS_DIR:-$HOME/.local/share/myscripts/update-ip/options}"
UPDATE_IP_CONFIG_BACKUP_DIR="${UPDATE_IP_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/update-ip/backups}"
UPDATE_IP_TEMP_DIR="${UPDATE_IP_TEMP_DIR/system_scripts/update-ip:-$HOME/.local/tmp/system_scripts/update-ip}"
UPDATE_IP_TEMP_FILE="${UPDATE_IP_TEMP_DIR:-$HOME/.local/tmp/update-ip}"
UPDATE_IP_CONFIG_FILE="${UPDATE_IP_CONFIG_FILE:-settings.conf}"
UPDATE_IP_GOOD_MESSAGE="${UPDATE_IP_GOOD_MESSAGE:-Everything Went OK}"
UPDATE_IP_ERROR_MESSAGE="${UPDATE_IP_ERROR_MESSAGE:-Well that didn\'t work}"
UPDATE_IP_NOTIFY_ENABLED="${UPDATE_IP_NOTIFY_ENABLED:-yes}"
UPDATE_IP_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
UPDATE_IP_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$UPDATE_IP_NOTIFY_CLIENT_ICON}"
UPDATE_IP_OUTPUT_COLOR="${UPDATE_IP_OUTPUT_COLOR:-5}"
UPDATE_IP_OUTPUT_COLOR_GOOD="${UPDATE_IP_OUTPUT_COLOR_GOOD:-2}"
UPDATE_IP_OUTPUT_COLOR_ERROR="${UPDATE_IP_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$UPDATE_IP_TEMP_DIR" ] || mkdir -p "$UPDATE_IP_TEMP_DIR" &>/dev/null
[ -d "$UPDATE_IP_CACHE_DIR" ] || mkdir -p "$UPDATE_IP_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$UPDATE_IP_CONFIG_DIR/$UPDATE_IP_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$UPDATE_IP_CONFIG_DIR/$UPDATE_IP_CONFIG_FILE" ] &&
  . "$UPDATE_IP_CONFIG_DIR/$UPDATE_IP_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h,z:"
LONGOPTS="options,config,version,help,dir:,force,console"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "-$ARRAY" ',' ''
    exit $?
    ;;
  -v | --version)
    shift 1
    __version
    exit $?
    ;;
  -h | --help)
    shift 1
    __help
    exit $?
    ;;
  -c | --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    shift 1
    UPDATE_IP_CWD="$1"
    ;;
  --force)
    shift 1
    force_delete="true"
    ;;
  --console)
    shift 1
    show_console="true"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$UPDATE_IP_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${UPDATE_IP_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${UPDATE_IP_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${UPDATE_IP_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${UPDATE_IP_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash || exit 1 # exit 1 if not found
#am_i_online --error || exit       # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
__requiresudo true
__getlipaddr
sed="$(command -v gsed 2>/dev/null || command -v sed 2>/dev/null)"
HOSTNAME="$(hostname -f 2>/dev/null)"
HOSTSHORT="$(hostname -s 2>/dev/null)"
CURRIP4=${CURRIP4:-}
CURRIP6=${CURRIP6:-}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ "$force_delete" = "true" ]; then
  shift 1
  __requiresudo rm -Rf /etc/casjaysdev/messages/*/*.txt &>/dev/null
  __requiresudo mkdir -p /etc/casjaysdev/messages/{legal,issue,motd} &>/dev/null
  __requiresudo touch /etc/casjaysdev/messages/{legal,issue,motd}/000.txt &>/dev/null
  if [ -f "$SCRIPTSFUNCTDIR/templates/casjaysdev-legal.txt" ]; then
    __requiresudo cp -Rf "$SCRIPTSFUNCTDIR/templates/casjaysdev-legal.txt" "/etc/casjaysdev/messages/legal/000.txt" &>/dev/null
  fi
fi
if [ -d /etc/postfix ]; then
  __requiresudo find /etc/postfix -type f -exec "$sed" -i 's#MYHOSTNAME#'$HOSTSHORT'#g' {} \; &>/dev/null
fi
if [ -f /etc/crontab ]; then
  __requiresudo find /etc/crontab -type f -exec "$sed" -i 's#$(hostname -s)#'$HOSTSHORT'#g' {} \; &>/dev/null
fi
if [ -d "/etc/casjaysdev/messages/legal" ]; then
  __requiresudo $sed -i 's#MYFULLHOSTNAME#'$HOSTNAME'#g' "/etc/casjaysdev/messages/legal/000.txt" &>/dev/null
  __requiresudo $sed -i 's#MYHOSTNAME#'$HOSTSHORT'#g' "/etc/casjaysdev/messages/legal/000.txt" &>/dev/null
  __requiresudo $sed -i 's#MYHOSTIP#'$CURRIP4'#g' "/etc/casjaysdev/messages/legal/000.txt" &>/dev/null
  __requiresudo $sed -i 's/MYHOSTIP6/'$CURRIP6'/g' "/etc/casjaysdev/messages/legal/000.txt" &>/dev/null
fi
if [ -d "/etc/casjaysdev/messages" ]; then
  __requiresudo find "/etc/casjaysdev/messages" -type f -exec "$sed" -i 's#Welcome to.*#Welcome to '$HOSTNAME'!#g' {} \; &>/dev/null
  __requiresudo find "/etc/casjaysdev/messages" -type f -exec "$sed" -i 's#MY Hostname is.*#MY Hostname is:     '$HOSTSHORT'#g' {} \; &>/dev/null
  __requiresudo find "/etc/casjaysdev/messages" -type f -exec "$sed" -i 's#MY IP Address is.*#MY IP Address is:   '$CURRIP4'#g' {} \; &>/dev/null
  __requiresudo find "/etc/casjaysdev/messages" -type f -exec "$sed" -i 's#MY IP6 Address is.*#MY IP6 Address is: '$CURRIP6'#g' {} \; &>/dev/null
fi
if [ -f "/etc/issue" ]; then
  __requiresudo find "/etc/issue" -type f -exec sed -i 's#MY IP Address is.*#MY IP Address is:   '$CURRIP4'#g' {} \; &>/dev/null
  __requiresudo find "/etc/issue" -type f -exec sed -i 's#MY IP6 Address is.*#MY IP6 Address is: '$CURRIP6'#g' {} \; &>/dev/null
fi
if [ -f "/etc/motd" ]; then
  __requiresudo find "/etc/motd" -type f -exec sed -i 's#MY IP Address is.*#MY IP Address is:   '$CURRIP4'#g' {} \; &>/dev/null
  __requiresudo find "/etc/motd" -type f -exec sed -i 's#MY IP6 Address is.*#MY IP6 Address is: '$CURRIP6'#g' {} \; &>/dev/null
fi
if [ -f "/etc/issue.net" ]; then
  __requiresudo find "/etc/issue.net" -type f -exec sed -i 's#MY IP Address is.*#MY IP Address is:   '$CURRIP4'#g' {} \; &>/dev/null
  __requiresudo find "/etc/issue.net" -type f -exec sed -i 's#MY IP6 Address is.*#MY IP6 Address is: '$CURRIP6'#g' {} \; &>/dev/null
fi
if [ -f "/etc/motd.net" ]; then
  __requiresudo find "/etc/motd.net" -type f -exec sed -i 's#MY IP Address is.*#MY IP Address is:   '$CURRIP4'#g' {} \; &>/dev/null
  __requiresudo find "/etc/motd.net" -type f -exec sed -i 's#MY IP6 Address is.*#MY IP6 Address is: '$CURRIP6'#g' {} \; &>/dev/null
fi
if [ "$show_console" = "true" ]; then
  printf_green "Short Hostname : $HOSTSHORT"
  printf_green "Full Hostname  : $HOSTNAME"
  printf_green "Current IP 4   : $CURRIP4"
  printf_green "Current IP 6   : $CURRIP6"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
