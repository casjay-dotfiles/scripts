# @Created       : Tuesday, Aug 17, 2021 22:03 EDT
# @File          : update-motd
# @Description   : Update the MOTD and ISSUE files
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108172203-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
PATH="/usr/games:$PATH"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$UPDATE_MOTD_CONFIG_DIR/$UPDATE_MOTD_CONFIG_FILE"
  [ -d "$UPDATE_MOTD_CONFIG_DIR" ] || mkdir -p "$UPDATE_MOTD_CONFIG_DIR"
  [ -d "$UPDATE_MOTD_CONFIG_BACKUP_DIR" ] || mkdir -p "$UPDATE_MOTD_CONFIG_BACKUP_DIR"
  [ -f "$UPDATE_MOTD_CONFIG_DIR/$UPDATE_MOTD_CONFIG_FILE" ] &&
    cp -Rf "$UPDATE_MOTD_CONFIG_DIR/$UPDATE_MOTD_CONFIG_FILE" "$UPDATE_MOTD_CONFIG_BACKUP_DIR/$UPDATE_MOTD_CONFIG_FILE.$$"
  cat <<EOF >"$UPDATE_MOTD_CONFIG_DIR/$UPDATE_MOTD_CONFIG_FILE"
# Settings for update-motd
UPDATE_MOTD_MESSAGE_DIR="${UPDATE_MOTD_MESSAGE_DIR:-/etc/casjaysdev/messages}"
UPDATE_MOTD_VERSION_DIR="${UPDATE_MOTD_VERSION_DIR:-/etc/casjaysdev/updates/versions}"
UPDATE_MOTD_GIT_VERSION_FORMAT="${VERSION_DATE_FORMAT:-%Y%m%d%H%M-git}"

# Notification settings
UPDATE_MOTD_GOOD_MESSAGE="${UPDATE_MOTD_GOOD_MESSAGE:-Everything Went OK}"
UPDATE_MOTD_ERROR_MESSAGE="${UPDATE_MOTD_ERROR_MESSAGE:-Well something seems to have gone wrong}"
UPDATE_MOTD_NOTIFY_ENABLED="${UPDATE_MOTD_NOTIFY_ENABLED:-yes}"
UPDATE_MOTD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
UPDATE_MOTD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$UPDATE_MOTD_NOTIFY_CLIENT_ICON}"

# Colorization settings
UPDATE_MOTD_OUTPUT_COLOR="${UPDATE_MOTD_OUTPUT_COLOR:-5}"
UPDATE_MOTD_OUTPUT_COLOR_GOOD="${UPDATE_MOTD_OUTPUT_COLOR_GOOD:-2}"
UPDATE_MOTD_OUTPUT_COLOR_ERROR="${UPDATE_MOTD_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$UPDATE_MOTD_CONFIG_DIR/$UPDATE_MOTD_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__restart_motd_services() {
  local SYSTEMD_MOTD_SERVICES="$(systemctl --all | grep motd | awk '{print $1}' | sort -u | grep -v '^$')"
  for service in $SYSTEMD_MOTD_SERVICES; do
    systemctl restart $service &>/dev/null
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__remove_duplicate_motd() {
  issue_d_dir="/etc/issue.d"
  motd_d_dir="/etc/motd.d"
  for file in $(ls "$motd_d_dir"); do
    motd_file="$motd_d_dir/$file"
    issue_file="$(find "$issue_d_dir/" -iname "$file*" 2>/dev/null | head -n1)"
    [ -f "$issue_file" ] && rm -f "$issue_file"
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
UPDATE_MOTD_LOG_DIR="${UPDATE_MOTD_LOG_DIR:-$HOME/.local/log/update-motd}"
UPDATE_MOTD_CACHE_DIR="${UPDATE_MOTD_CACHE_DIR:-$HOME/.cache/update-motd}"
UPDATE_MOTD_CONFIG_DIR="${UPDATE_MOTD_CONFIG_DIR:-$HOME/.config/myscripts/update-motd}"
UPDATE_MOTD_CONFIG_BACKUP_DIR="${UPDATE_MOTD_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/update-motd/backups}"
UPDATE_MOTD_TEMP_DIR="${UPDATE_MOTD_TEMP_DIR:-$HOME/.local/tmp/system_scripts/update-motd}"
UPDATE_MOTD_OPTIONS_DIR="${UPDATE_MOTD_OPTIONS_DIR:-$HOME/.local/share/myscripts/update-motd/options}"
UPDATE_MOTD_CONFIG_FILE="${UPDATE_MOTD_CONFIG_FILE:-settings.conf}"
UPDATE_MOTD_MESSAGE_DIR="${UPDATE_MOTD_MESSAGE_DIR:-/etc/casjaysdev/messages}"
UPDATE_MOTD_VERSION_DIR="${UPDATE_MOTD_VERSION_DIR:-/etc/casjaysdev/updates/versions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
UPDATE_MOTD_OUTPUT_COLOR="${UPDATE_MOTD_OUTPUT_COLOR:-4}"
UPDATE_MOTD_OUTPUT_COLOR_2="${UPDATE_MOTD_OUTPUT_COLOR:-6}"
UPDATE_MOTD_OUTPUT_COLOR_GOOD="${UPDATE_MOTD_OUTPUT_COLOR_GOOD:-2}"
UPDATE_MOTD_OUTPUT_COLOR_ERROR="${UPDATE_MOTD_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
UPDATE_MOTD_GOOD_MESSAGE="${UPDATE_MOTD_GOOD_MESSAGE:-Everything Went OK}"
UPDATE_MOTD_ERROR_MESSAGE="${UPDATE_MOTD_ERROR_MESSAGE:-Well something seems to have gone wrong}"
UPDATE_MOTD_NOTIFY_ENABLED="${UPDATE_MOTD_NOTIFY_ENABLED:-yes}"
UPDATE_MOTD_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
UPDATE_MOTD_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$UPDATE_MOTD_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
UPDATE_MOTD_GIT_VERSION_FORMAT="${VERSION_DATE_FORMAT:-${UPDATE_MOTD_GIT_VERSION_FORMAT:-%Y%m%d%H%M-git}}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$UPDATE_MOTD_CONFIG_DIR/$UPDATE_MOTD_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$UPDATE_MOTD_CONFIG_DIR/$UPDATE_MOTD_CONFIG_FILE" ] && . "$UPDATE_MOTD_CONFIG_DIR/$UPDATE_MOTD_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$UPDATE_MOTD_LOG_DIR" ] || mkdir -p "$UPDATE_MOTD_LOG_DIR" &>/dev/null
[ -d "$UPDATE_MOTD_TEMP_DIR" ] || mkdir -p "$UPDATE_MOTD_TEMP_DIR" &>/dev/null
[ -d "$UPDATE_MOTD_CACHE_DIR" ] || mkdir -p "$UPDATE_MOTD_CACHE_DIR" &>/dev/null
UPDATE_MOTD_TEMP_FILE="${UPDATE_MOTD_TEMP_FILE:-$(mktemp $UPDATE_MOTD_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$UPDATE_MOTD_TEMP_FILE" ] && [ -f "$UPDATE_MOTD_TEMP_FILE" ] && rm -Rf "$UPDATE_MOTD_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$UPDATE_MOTD_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${UPDATE_MOTD_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${UPDATE_MOTD_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${UPDATE_MOTD_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${UPDATE_MOTD_NOTIFY_CLIENT_ICON}"
    notifications "$@" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing
__requiresudo true || exit 1
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,force,console,debug"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    UPDATE_MOTD_CWD="$2"
    shift 2
    ;;
  --force)
    shift 1
    force_removal="true"
    ;;
  --console)
    shift 1
    show_console="true"
    ;;
  --debug)
    shift 1
    show_debug="true"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
__remove_duplicate_motd
__restart_motd_services
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
__getlipaddr
sed="$(command -v gsed 2>/dev/null || command -v sed 2>/dev/null)"
HOSTNAME="$(hostname -f 2>/dev/null || echo 'localhost.local')"
HOSTSHORT="$(hostname -s 2>/dev/null || echo 'localhost')"
CURRIP4=${CURRIP4:-127.0.0.1}
CURRIP6=${CURRIP6:-::1}
dategit="$(date +"${UPDATE_MOTD_GIT_VERSION_FORMAT:-%Y%m%d%H%M-git}")"
datever="$(date +"%b %d, %Y at %H:%M")"
OS_RELEASE="$(printf '%s: %s\n' "$(__os_name)" "$(__os_version)")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if [ "$force_removal" = "true" ]; then
  __requiresudo rm -Rf $UPDATE_MOTD_MESSAGE_DIR/*/*.txt &>/dev/null
  __requiresudo mkdir -p $UPDATE_MOTD_MESSAGE_DIR/{legal,issue,motd} &>/dev/null
  __requiresudo touch $UPDATE_MOTD_MESSAGE_DIR/{legal,issue,motd}/000.txt &>/dev/null
  if [ -f "$SCRIPTSFUNCTDIR/templates/casjaysdev-legal.txt" ]; then
    __requiresudo cp -Rf "$SCRIPTSFUNCTDIR/templates/casjaysdev-legal.txt" "$UPDATE_MOTD_MESSAGE_DIR/legal/000.txt"
  fi
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__requiresudo rm -Rf /etc/issue /etc/motd &>/dev/null
__requiresudo rm -Rf /etc/issue.net /etc/motd.net &>/dev/null
__requiresudo touch /etc/issue /etc/motd &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$UPDATE_MOTD_VERSION_DIR/scripts.txt" ] && [ -s "$UPDATE_MOTD_VERSION_DIR/scripts.txt" ]; then
  scriptsversion="$(<"$UPDATE_MOTD_VERSION_DIR/scripts.txt")"
else
  scriptsversion="$dategit"
  echo "$scriptsversion" | __requiresudo tee "$UPDATE_MOTD_VERSION_DIR/scripts.txt" &>/dev/null
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$UPDATE_MOTD_VERSION_DIR/configs.txt" ] && [ -s "$UPDATE_MOTD_VERSION_DIR/configs.txt" ]; then
  configsversion="$(<"$UPDATE_MOTD_VERSION_DIR/configs.txt")"
else
  configsversion="$dategit"
  echo "$configsversion" | __requiresudo tee "$UPDATE_MOTD_VERSION_DIR/configs.txt" &>/dev/null
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$UPDATE_MOTD_VERSION_DIR/date.scripts.txt" ] && [ -s "$UPDATE_MOTD_VERSION_DIR/date.scripts.txt" ]; then
  scriptsdate="$(<"$UPDATE_MOTD_VERSION_DIR/date.scripts.txt")"
else
  scriptsdate="$datever"
  echo "$scriptsdate" | __requiresudo tee "$UPDATE_MOTD_VERSION_DIR/date.scripts.txt" &>/dev/null
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$UPDATE_MOTD_VERSION_DIR/date.configs.txt" ] && [ -s "$UPDATE_MOTD_VERSION_DIR/date.configs.txt" ]; then
  configsdate="$(<"$UPDATE_MOTD_VERSION_DIR/date.configs.txt")"
else
  configsdate="$datever"
  echo "$configsdate" | __requiresudo tee "$UPDATE_MOTD_VERSION_DIR/date.configs.txt" &>/dev/null
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
distro_version="${distro_version:-N/A}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
messages=$(find -L "$UPDATE_MOTD_MESSAGE_DIR/legal" -type f -name '*.txt' 2>/dev/null | wc -l)
if [ "$messages" != "0" ]; then
  __requiresudo $sed -i 's#MYFULLHOSTNAME#'$HOSTNAME'#g' "$UPDATE_MOTD_MESSAGE_DIR/legal/000.txt" &>/dev/null
  __requiresudo $sed -i 's#MYHOSTNAME#'$HOSTSHORT'#g' "$UPDATE_MOTD_MESSAGE_DIR/legal/000.txt" &>/dev/null
  __requiresudo $sed -i 's#MYHOSTIP#'$CURRIP4'#g' "$UPDATE_MOTD_MESSAGE_DIR/legal/000.txt" &>/dev/null
  __requiresudo $sed -i 's/MYHOSTIP6/'$CURRIP6'/g' "$UPDATE_MOTD_MESSAGE_DIR/legal/000.txt" &>/dev/null
  __requiresudo find "$UPDATE_MOTD_MESSAGE_DIR" -type f -exec "$sed" -i 's#Welcome to.*#Welcome to '$HOSTNAME'!#g' {} \; &>/dev/null
  __requiresudo find "$UPDATE_MOTD_MESSAGE_DIR" -type f -exec "$sed" -i 's#MY Hostname is.*#MY Hostname is:     '$HOSTSHORT'#g' {} \; &>/dev/null
  __requiresudo find "$UPDATE_MOTD_MESSAGE_DIR" -type f -exec "$sed" -i 's#MY IP Address is.*#MY IP Address is:   '$CURRIP4'#g' {} \; &>/dev/null
  __requiresudo find "$UPDATE_MOTD_MESSAGE_DIR" -type f -exec "$sed" -i 's#MY IP6 Address is.*#MY IP6 Address is: '$CURRIP6'#g' {} \; &>/dev/null
  printf "\n" | __requiresudo tee -a | grep -v '^$' >>/etc/issue
  for f in $UPDATE_MOTD_MESSAGE_DIR/legal/*.txt; do
    cat "$f" 2>/dev/null | "$sed" '/^$/d' | __requiresudo tee -a | grep -v '^$' >>/etc/issue
  done
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
messages=$(find -L "$UPDATE_MOTD_MESSAGE_DIR/issue" -type f -name '*.txt' 2>/dev/null | wc -l)
if [ "$messages" != "0" ]; then
  for f in $UPDATE_MOTD_MESSAGE_DIR/issue/*.txt; do
    cat "$f" 2>/dev/null | "$sed" '/^$/d' | __requiresudo tee -a | grep -v '^$' >>/etc/issue
  done
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
messages=$(find -L "/etc/issue.d" -type f 2>/dev/null | wc -l)
if [ "$messages" != "0" ]; then
  for f in /etc/issue.d/*; do
    cat "$f" 2>/dev/null | "$sed" '/^$/d' | __requiresudo tee -a | grep -v '^$' >>/etc/issue
  done
  printf "\n" | __requiresudo tee -a | grep -v '^$' >>/etc/issue
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
messages=$(find -L "/etc/motd.d" -type f 2>/dev/null | wc -l)
if [ "$messages" != "0" ]; then
  printf "\n" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
  for f in /etc/motd.d/*; do
    cat "$f" 2>/dev/null | "$sed" '/^$/d' | __requiresudo tee -a | grep -v '^$' >>/etc/motd
  done
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
messages=$(find -L "$UPDATE_MOTD_MESSAGE_DIR/motd" -type f -name '*.txt' 2>/dev/null | wc -l)
if [ "$messages" != "0" ]; then
  for f in $UPDATE_MOTD_MESSAGE_DIR/motd/*.txt; do
    cat "$f" 2>/dev/null | "$sed" '/^$/d' | __requiresudo tee -a | grep -v '^$' >>/etc/motd
  done
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$(type -P fortune 2>/dev/null)" ] && [ -f "$(type -P cowsay 2>/dev/null)" ]; then
  fortune | cowsay | __requiresudo tee -a | grep -v '^$' >>/etc/motd
  printf "\n" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if __if_os_id debian; then
  printf "Debian version: %s\n" "$distro_version" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
  printf "Config version: %s\n" "$configsversion" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
elif __if_os_id rhel; then
  printf "RHEL version: %s\n" "$distro_version" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
  printf "Config version: %s\n" "$configsversion" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
elif __if_os_id arch; then
  printf "Arch version: %s\n" "$distro_version" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
  printf "Config version: %s\n" "$configsversion" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
elif __if_os_id mac; then
  printf "Mac version: %s\n" "$distro_version" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
  printf "Config version: %s\n" "$configsversion" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
else
  printf "OS Version: %s\n" "$distro_version" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
  printf "Config Version: %s\n" "$configsversion" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
printf 'Scripts version %s\n' "$scriptsversion" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
printf 'configs were last updated on: %s\n' "$configsdate" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
printf 'scripts package was last updated on: %s\n' "$scriptsdate" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
printf 'Messages were last updated on: %s\n\n' "$(date +"%b %d, %Y at %H:%M")" | __requiresudo tee -a | grep -v '^$' >>/etc/motd
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -n "$OS_RELEASE" ]; then
  printf '%s\n' "$OS_RELEASE" | __requiresudo tee "$UPDATE_MOTD_VERSION_DIR/osversion.txt" &>/dev/null
  __os_fix_name "$UPDATE_MOTD_VERSION_DIR/osversion.txt"
else
  printf 'Unknown OS 1.0\n' | __requiresudo tee "$UPDATE_MOTD_VERSION_DIR/osname.txt" &>/dev/null
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__requiresudo cp -Rf /etc/motd /etc/motd.net &>/dev/null
__requiresudo cp -Rf /etc/issue /etc/issue.net &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
[ -d "/etc/casjaysdev/banners" ] || mkdir -p "/etc/casjaysdev/banners"
cat /etc/issue /etc/motd | __requiresudo tee "/etc/casjaysdev/banners/ssh.txt" &>/dev/null
cat /etc/issue /etc/motd | __requiresudo tee "/etc/casjaysdev/banners/rsync.txt" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ "$show_console" = "true" ] && [ "$show_debug" != "true" ]; then
  cat /etc/issue /etc/motd | printf_readline "$UPDATE_MOTD_OUTPUT_COLOR"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ "$show_debug" = "true" ]; then
  __if_os_id
  cat /etc/issue /etc/motd | printf_readline "$UPDATE_MOTD_OUTPUT_COLOR"
  printf_green "OS Release       :  $OS_RELEASE"
  printf_green "distro name      :  $distro_id"
  printf_green "distro version   :  $distro_version"
  printf_green "scripts version  :  $scriptsversion"
  printf_green "configs version  :  $configsversion"
  printf_green "scripts date     :  $scriptsdate"
  printf_green "configs date     :  $configsdate"
  printf_green "hostname short   :  $HOSTSHORT"
  printf_green "hostname full    :  $HOSTNAME"
  printf_green "current ip4      :  $CURRIP4"
  printf_green "current ip6      :  $CURRIP6"
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
