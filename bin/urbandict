#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108172203-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : urbandict --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Tuesday, Aug 17, 2021 22:03 EDT
# @File          : urbandict
# @Description   : script to lookup words on urbandictionary.com
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108172203-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi
trap 'exitCode=${exitCode:-$?};[ -n "$URBANDICT_TEMP_FILE" ] && [ -f "$URBANDICT_TEMP_FILE" ] && rm -Rf "$URBANDICT_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$URBANDICT_CONFIG_DIR/$URBANDICT_CONFIG_FILE"
  [ -d "$URBANDICT_CONFIG_DIR" ] || mkdir -p "$URBANDICT_CONFIG_DIR"
  [ -d "$URBANDICT_CONFIG_BACKUP_DIR" ] || mkdir -p "$URBANDICT_CONFIG_BACKUP_DIR"
  [ -f "$URBANDICT_CONFIG_DIR/$URBANDICT_CONFIG_FILE" ] &&
    cp -Rf "$URBANDICT_CONFIG_DIR/$URBANDICT_CONFIG_FILE" "$URBANDICT_CONFIG_BACKUP_DIR/$URBANDICT_CONFIG_FILE.$$"
  cat <<EOF >"$URBANDICT_CONFIG_DIR/$URBANDICT_CONFIG_FILE"
# Settings for urbandict
URBANDICT_API_URL="${URBANDICT_API_URL:-https://api.urbandictionary.com/v0/define}"

# Notification settings
URBANDICT_GOOD_MESSAGE="${URBANDICT_GOOD_MESSAGE:-Everything Went OK}"
URBANDICT_ERROR_MESSAGE="${URBANDICT_ERROR_MESSAGE:-Well something seems to have gone wrong}"
URBANDICT_NOTIFY_ENABLED="${URBANDICT_NOTIFY_ENABLED:-yes}"
URBANDICT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
URBANDICT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$URBANDICT_NOTIFY_CLIENT_ICON}"

# Colorization settings
URBANDICT_OUTPUT_COLOR="${URBANDICT_OUTPUT_COLOR:-5}"
URBANDICT_OUTPUT_COLOR_GOOD="${URBANDICT_OUTPUT_COLOR_GOOD:-2}"
URBANDICT_OUTPUT_COLOR_ERROR="${URBANDICT_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$URBANDICT_CONFIG_DIR/$URBANDICT_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for urbandict has been created"
    exitCode=0
    if [[ "$INIT_CONFIG" = "TRUE" ]]; then
      exit 1
    fi
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__python_api() { python3 -c "import sys, json, html; print(html.unescape(json.load(sys.stdin)['string']).split('\n',2)[1])" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
URBANDICT_LOG_DIR="${URBANDICT_LOG_DIR:-$HOME/.local/log/urbandict}"
URBANDICT_CACHE_DIR="${URBANDICT_CACHE_DIR:-$HOME/.cache/urbandict}"
URBANDICT_CONFIG_DIR="${URBANDICT_CONFIG_DIR:-$HOME/.config/myscripts/urbandict}"
URBANDICT_CONFIG_BACKUP_DIR="${URBANDICT_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/urbandict/backups}"
URBANDICT_TEMP_DIR="${URBANDICT_TEMP_DIR:-$HOME/.local/tmp/system_scripts/urbandict}"
URBANDICT_OPTIONS_DIR="${URBANDICT_OPTIONS_DIR:-$HOME/.local/share/myscripts/urbandict/options}"
URBANDICT_TEMP_FILE="${URBANDICT_TEMP_FILE:-$(mktemp $URBANDICT_TEMP_DIR/XXXXXX 2>/dev/null)}"
URBANDICT_CONFIG_FILE="${URBANDICT_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
URBANDICT_OUTPUT_COLOR="${URBANDICT_OUTPUT_COLOR:-4}"
URBANDICT_OUTPUT_COLOR_2="${URBANDICT_OUTPUT_COLOR:-6}"
URBANDICT_OUTPUT_COLOR_GOOD="${URBANDICT_OUTPUT_COLOR_GOOD:-2}"
URBANDICT_OUTPUT_COLOR_ERROR="${URBANDICT_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
URBANDICT_GOOD_MESSAGE="${URBANDICT_GOOD_MESSAGE:-Everything Went OK}"
URBANDICT_ERROR_MESSAGE="${URBANDICT_ERROR_MESSAGE:-Well something seems to have gone wrong}"
URBANDICT_NOTIFY_ENABLED="${URBANDICT_NOTIFY_ENABLED:-yes}"
URBANDICT_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
URBANDICT_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$URBANDICT_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
URBANDICT_API_URL="${URBANDICT_API_URL:-https://api.urbandictionary.com/v0/define}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$URBANDICT_CONFIG_DIR/$URBANDICT_CONFIG_FILE" ] && . "$URBANDICT_CONFIG_DIR/$URBANDICT_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$URBANDICT_LOG_DIR" ] || mkdir -p "$URBANDICT_LOG_DIR" &>/dev/null
[ -d "$URBANDICT_TEMP_DIR" ] || mkdir -p "$URBANDICT_TEMP_DIR" &>/dev/null
[ -d "$URBANDICT_CACHE_DIR" ] || mkdir -p "$URBANDICT_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$URBANDICT_CONFIG_DIR/$URBANDICT_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    URBANDICT_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$URBANDICT_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${URBANDICT_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${URBANDICT_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${URBANDICT_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${URBANDICT_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
am_i_online --error || exit 1           # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
term="$*"
queryString=${term// /+}
result="$(curl -q -LSs "$URBANDICT_API_URL?term=${queryString}" | jq -r '.list[0].definition')"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
printf_green "Definition of $1 is: "
echo "$result" | printf_readline $URBANDICT_OUTPUT_COLOR
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
