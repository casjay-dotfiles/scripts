#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108171810-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$URLCHECK_TEMP_FILE" ] && rm -Rf "$URLCHECK_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108171810-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : urlcheck --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Tuesday, Aug 17, 2021 18:10 EDT
# @File          : urlcheck
# @Description   : Check if an URL is valid
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$URLCHECK_CONFIG_DIR/$URLCHECK_CONFIG_FILE"
  [ -d "$URLCHECK_CONFIG_DIR" ] || mkdir -p "$URLCHECK_CONFIG_DIR"
  [ -d "$URLCHECK_CONFIG_BACKUP_DIR" ] || mkdir -p "$URLCHECK_CONFIG_BACKUP_DIR"
  [ -f "$URLCHECK_CONFIG_DIR/$URLCHECK_CONFIG_FILE" ] &&
    cp -Rf "$URLCHECK_CONFIG_DIR/$URLCHECK_CONFIG_FILE" "$URLCHECK_CONFIG_BACKUP_DIR/$URLCHECK_CONFIG_FILE.$$"
  cat <<EOF >"$URLCHECK_CONFIG_DIR/$URLCHECK_CONFIG_FILE"
# Settings for urlcheck
URLCHECK_HTTP_STATUS="${URLCHECK_HTTP_STATUS:-(200|301|302)}"
URLCHECK_NOTIFY_TIMEOUT="${URLCHECK_NOTIFY_TIMEOUT:-1}"
URLCHECK_CURL_OPTS="${URLCHECK_CURL_OPTS:--q -Ss --insecure --fail --head}"

# Notification settings
URLCHECK_GOOD_MESSAGE="${URLCHECK_GOOD_MESSAGE:-Everything Went OK}"
URLCHECK_ERROR_MESSAGE="${URLCHECK_ERROR_MESSAGE:-Well that did not work}"
URLCHECK_NOTIFY_ENABLED="${URLCHECK_NOTIFY_ENABLED:-yes}"
URLCHECK_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
URLCHECK_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$URLCHECK_NOTIFY_CLIENT_ICON}"

# Colorization settings
URLCHECK_OUTPUT_COLOR="${URLCHECK_OUTPUT_COLOR:-5}"
URLCHECK_OUTPUT_COLOR_GOOD="${URLCHECK_OUTPUT_COLOR_GOOD:-2}"
URLCHECK_OUTPUT_COLOR_ERROR="${URLCHECK_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$URLCHECK_CONFIG_DIR/$URLCHECK_CONFIG_FILE" ]; then
    printf_green "Your config file for urlcheck has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
URLCHECK_CACHE_DIR="${URLCHECK_CACHE_DIR:-$HOME/.cache/urlcheck}"
URLCHECK_CONFIG_DIR="${URLCHECK_CONFIG_DIR:-$HOME/.config/myscripts/urlcheck}"
URLCHECK_OPTIONS_DIR="${URLCHECK_OPTIONS_DIR:-$HOME/.local/share/myscripts/urlcheck/options}"
URLCHECK_CONFIG_BACKUP_DIR="${URLCHECK_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/urlcheck/backups}"
URLCHECK_TEMP_DIR="${URLCHECK_TEMP_DIR:-$HOME/.local/tmp/system_scripts/urlcheck}"
URLCHECK_TEMP_FILE="${URLCHECK_TEMP_FILE:-$HOME/.local/tmp/urlcheck/$(mktemp XXXXXX)}"
URLCHECK_CONFIG_FILE="${URLCHECK_CONFIG_FILE:-settings.conf}"
URLCHECK_GOOD_MESSAGE="${URLCHECK_GOOD_MESSAGE:-Everything Went OK}"
URLCHECK_ERROR_MESSAGE="${URLCHECK_ERROR_MESSAGE:-Well that did not work}"
URLCHECK_NOTIFY_ENABLED="${URLCHECK_NOTIFY_ENABLED:-yes}"
URLCHECK_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
URLCHECK_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$URLCHECK_NOTIFY_CLIENT_ICON}"
URLCHECK_NOTIFY_TIMEOUT="${URLCHECK_NOTIFY_TIMEOUT:-1}"
URLCHECK_CURL_OPTS="${URLCHECK_CURL_OPTS:--q -Ss --insecure --fail --head}"
URLCHECK_HTTP_STATUS="${URLCHECK_HTTP_STATUS:-(200|301|302)}"
URLCHECK_OUTPUT_COLOR="${URLCHECK_OUTPUT_COLOR:-5}"
URLCHECK_OUTPUT_COLOR_GOOD="${URLCHECK_OUTPUT_COLOR_GOOD:-2}"
URLCHECK_OUTPUT_COLOR_ERROR="${URLCHECK_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$URLCHECK_TEMP_DIR" ] || mkdir -p "$URLCHECK_TEMP_DIR" &>/dev/null
[ -d "$URLCHECK_CACHE_DIR" ] || mkdir -p "$URLCHECK_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$URLCHECK_CONFIG_DIR/$URLCHECK_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$URLCHECK_CONFIG_DIR/$URLCHECK_CONFIG_FILE" ] &&
  . "$URLCHECK_CONFIG_DIR/$URLCHECK_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="c,v,h,z:"
LONGOPTS="options,config,version,help,dir:,show"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  -v | --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  -c | --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    shift 1
    URLCHECK_CWD="$1"
    ;;
  --show)
    shift 1
    show_message="true"
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$URLCHECK_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${URLCHECK_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${URLCHECK_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${URLCHECK_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${URLCHECK_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash curl || exit 1 # exit 1 if not found
am_i_online --error || exit 1          # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[ -n "${1:-$URL}" ] || __help
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
result="$(timeout 1 curl -q -Ss --insecure --fail --head ${1:-$URL} 2>/dev/null)"
if [[ "$show_message" == "true" ]]; then
  echo "$result" | grep -E 'HTTP/[0-9]' | grep -qE "$URLCHECK_HTTP_STATUS" && exitCode=0 || exitCode=1
  echo "$result" | printf_readline $URLCHECK_OUTPUT_COLOR
  if [[ "$exitCode" = 0 ]]; then
    printf_custom $URLCHECK_OUTPUT_COLOR_GOOD "$URLCHECK_GOOD_MESSAGE: ${1:-$URL}"
    __notifications "$URLCHECK_GOOD_MESSAGE ${1:-$URL}"
  else
    printf_custom $URLCHECK_OUTPUT_COLOR_ERROR "$URLCHECK_ERROR_MESSAGE: ${1:-$URL}"
    __notifications "$URLCHECK_ERROR_MESSAGE ${1:-$URL}"
  fi
else
  echo "$result" | grep -E 'HTTP/[0-9]' | grep -qE "$URLCHECK_HTTP_STATUS" && exitCode=0 || exitCode=1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
