#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108171810-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -xo pipefail && export DEBUGGING="true"
trap 'exitCode=${exitCode:-$?};[ -f "$URLENCODE_TEMP_FILE" ] && rm -Rf "$URLENCODE_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108171810-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : urlencode --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Tuesday, Aug 17, 2021 18:10 EDT
# @File          : urlencode
# @Description   : encode an url
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$URLENCODE_CONFIG_DIR/$URLENCODE_CONFIG_FILE"
  [ -d "$URLENCODE_CONFIG_DIR" ] || mkdir -p "$URLENCODE_CONFIG_DIR"
  [ -d "$URLENCODE_CONFIG_BACKUP_DIR" ] || mkdir -p "$URLENCODE_CONFIG_BACKUP_DIR"
  [ -f "$URLENCODE_CONFIG_DIR/$URLENCODE_CONFIG_FILE" ] &&
    cp -Rf "$URLENCODE_CONFIG_DIR/$URLENCODE_CONFIG_FILE" "$URLENCODE_CONFIG_BACKUP_DIR/$URLENCODE_CONFIG_FILE.$$"
  cat <<EOF >"$URLENCODE_CONFIG_DIR/$URLENCODE_CONFIG_FILE"
# Settings for urlencode

# Notification settings
URLENCODE_GOOD_MESSAGE="${URLENCODE_GOOD_MESSAGE:-Everything Went OK}"
URLENCODE_ERROR_MESSAGE="${URLENCODE_ERROR_MESSAGE:-Well that didn\'t work}"
URLENCODE_NOTIFY_ENABLED="${URLENCODE_NOTIFY_ENABLED:-yes}"
URLENCODE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
URLENCODE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$URLENCODE_NOTIFY_CLIENT_ICON}"

# Colorization settings
URLENCODE_OUTPUT_COLOR="${URLENCODE_OUTPUT_COLOR:-5}"
URLENCODE_OUTPUT_COLOR_GOOD="${URLENCODE_OUTPUT_COLOR_GOOD:-2}"
URLENCODE_OUTPUT_COLOR_ERROR="${URLENCODE_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$URLENCODE_CONFIG_DIR/$URLENCODE_CONFIG_FILE" ]; then
    printf_green "Your config file for urlencode has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
URLENCODE_LOG_DIR="${URLENCODE_LOG_DIR:-$HOME/.local/log/urlencode}"
URLENCODE_CACHE_DIR="${URLENCODE_CACHE_DIR:-$HOME/.cache/urlencode}"
URLENCODE_CONFIG_DIR="${URLENCODE_CONFIG_DIR:-$HOME/.config/myscripts/urlencode}"
URLENCODE_CONFIG_BACKUP_DIR="${URLENCODE_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/urlencode/backups}"
URLENCODE_TEMP_DIR="${URLENCODE_TEMP_DIR:-$HOME/.local/tmp/system_scripts/urlencode}"
URLENCODE_OPTIONS_DIR="${URLENCODE_OPTIONS_DIR:-$HOME/.local/share/myscripts/urlencode/options}"
URLENCODE_TEMP_FILE="${URLENCODE_TEMP_FILE:-$(mktemp $URLENCODE_TEMP_DIR/XXXXXX 2>/dev/null)}"
URLENCODE_CONFIG_FILE="${URLENCODE_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
URLENCODE_OUTPUT_COLOR="${URLENCODE_OUTPUT_COLOR:-4}"
URLENCODE_OUTPUT_COLOR_2="${URLENCODE_OUTPUT_COLOR:-6}"
URLENCODE_OUTPUT_COLOR_GOOD="${URLENCODE_OUTPUT_COLOR_GOOD:-2}"
URLENCODE_OUTPUT_COLOR_ERROR="${URLENCODE_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
URLENCODE_GOOD_MESSAGE="${URLENCODE_GOOD_MESSAGE:-Everything Went OK}"
URLENCODE_ERROR_MESSAGE="${URLENCODE_ERROR_MESSAGE:-Well that didn\'t work}"
URLENCODE_NOTIFY_ENABLED="${URLENCODE_NOTIFY_ENABLED:-yes}"
URLENCODE_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
URLENCODE_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$URLENCODE_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$URLENCODE_CONFIG_DIR/$URLENCODE_CONFIG_FILE" ] && . "$URLENCODE_CONFIG_DIR/$URLENCODE_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$URLENCODE_LOG_DIR" ] || mkdir -p "$URLENCODE_LOG_DIR" &>/dev/null
[ -d "$URLENCODE_TEMP_DIR" ] || mkdir -p "$URLENCODE_TEMP_DIR" &>/dev/null
[ -d "$URLENCODE_CACHE_DIR" ] || mkdir -p "$URLENCODE_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$URLENCODE_CONFIG_DIR/$URLENCODE_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    URLENCODE_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$URLENCODE_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${URLENCODE_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${URLENCODE_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${URLENCODE_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${URLENCODE_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
[ -n "${1:-$URL}" ] || __help
results="$(perl -MURI::Escape -e 'print uri_escape($ARGV[0]);' "${1:-$URL}")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
printf_custom $URLENCODE_OUTPUT_COLOR "$results"
printf_newline
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
