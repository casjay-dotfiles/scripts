#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202108171810-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
[[ "$1" == "--debug" ]] && shift 1 && set -euo pipefail
trap 'exitCode=${exitCode:-$?};[ -f "$VIDEOS_TEMP_FILE" ] && rm -Rf "$VIDEOS_TEMP_FILE" &>/dev/null' EXIT
[ ! -t 0 ] && { [ "$1" = "--term" ] || [ $# = 0 ]; } && TERMINAL_APP="TRUE" myterminal -e "$APPNAME" "$*" && { exit || exit 1; }

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108171810-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : videos --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Tuesday, Aug 17, 2021 18:10 EDT
# @File          : videos
# @Description   : play videos
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$VIDEOS_CONFIG_DIR/$VIDEOS_CONFIG_FILE"
  [ -d "$VIDEOS_CONFIG_DIR" ] || mkdir -p "$VIDEOS_CONFIG_DIR"
  [ -d "$VIDEOS_CONFIG_BACKUP_DIR" ] || mkdir -p "$VIDEOS_CONFIG_BACKUP_DIR"
  [ -f "$VIDEOS_CONFIG_DIR/$VIDEOS_CONFIG_FILE" ] &&
    cp -Rf "$VIDEOS_CONFIG_DIR/$VIDEOS_CONFIG_FILE" "$VIDEOS_CONFIG_BACKUP_DIR/$VIDEOS_CONFIG_FILE.$$"
  cat <<EOF >"$VIDEOS_CONFIG_DIR/$VIDEOS_CONFIG_FILE"
# Settings for videos
VIDEOS_COUNTDOWN_TIME="${VIDEOS_COUNTDOWN_TIME:-3}"

# Notification settings
VIDEOS_GOOD_MESSAGE="${VIDEOS_GOOD_MESSAGE:-Everything Went OK}"
VIDEOS_ERROR_MESSAGE="${VIDEOS_ERROR_MESSAGE:-Well that didn\'t work}"
VIDEOS_NOTIFY_ENABLED="${VIDEOS_NOTIFY_ENABLED:-yes}"
VIDEOS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
VIDEOS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$VIDEOS_NOTIFY_CLIENT_ICON}"

# Colorization settings
VIDEOS_OUTPUT_COLOR="${VIDEOS_OUTPUT_COLOR:-5}"
VIDEOS_OUTPUT_COLOR_GOOD="${VIDEOS_OUTPUT_COLOR_GOOD:-2}"
VIDEOS_OUTPUT_COLOR_ERROR="${VIDEOS_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$VIDEOS_CONFIG_DIR/$VIDEOS_CONFIG_FILE" ]; then
    printf_green "Your config file for videos has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
VIDEOS_LOG_DIR="${VIDEOS_LOG_DIR:-$HOME/.local/log/videos}"
VIDEOS_CACHE_DIR="${VIDEOS_CACHE_DIR:-$HOME/.cache/videos}"
VIDEOS_CONFIG_DIR="${VIDEOS_CONFIG_DIR:-$HOME/.config/myscripts/videos}"
VIDEOS_CONFIG_BACKUP_DIR="${VIDEOS_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/videos/backups}"
VIDEOS_TEMP_DIR="${VIDEOS_TEMP_DIR:-$HOME/.local/tmp/system_scripts/videos}"
VIDEOS_OPTIONS_DIR="${VIDEOS_OPTIONS_DIR:-$HOME/.local/share/myscripts/videos/options}"
VIDEOS_TEMP_FILE="${VIDEOS_TEMP_FILE:-$(mktemp $VIDEOS_TEMP_DIR/XXXXXX 2>/dev/null)}"
VIDEOS_CONFIG_FILE="${VIDEOS_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
VIDEOS_OUTPUT_COLOR="${VIDEOS_OUTPUT_COLOR:-4}"
VIDEOS_OUTPUT_COLOR_2="${VIDEOS_OUTPUT_COLOR:-6}"
VIDEOS_OUTPUT_COLOR_GOOD="${VIDEOS_OUTPUT_COLOR_GOOD:-2}"
VIDEOS_OUTPUT_COLOR_ERROR="${VIDEOS_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
VIDEOS_GOOD_MESSAGE="${VIDEOS_GOOD_MESSAGE:-Everything Went OK}"
VIDEOS_ERROR_MESSAGE="${VIDEOS_ERROR_MESSAGE:-Well that didn\'t work}"
VIDEOS_NOTIFY_ENABLED="${VIDEOS_NOTIFY_ENABLED:-yes}"
VIDEOS_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
VIDEOS_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$VIDEOS_NOTIFY_CLIENT_ICON}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application overrides
VIDEOS_COUNTDOWN_TIME="${VIDEOS_COUNTDOWN_TIME:-3}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$VIDEOS_CONFIG_DIR/$VIDEOS_CONFIG_FILE" ] && . "$VIDEOS_CONFIG_DIR/$VIDEOS_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$VIDEOS_LOG_DIR" ] || mkdir -p "$VIDEOS_LOG_DIR" &>/dev/null
[ -d "$VIDEOS_TEMP_DIR" ] || mkdir -p "$VIDEOS_TEMP_DIR" &>/dev/null
[ -d "$VIDEOS_CACHE_DIR" ] || mkdir -p "$VIDEOS_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate non-existing config files
[ -f "$VIDEOS_CONFIG_DIR/$VIDEOS_CONFIG_FILE" ] || __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    VIDEOS_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$VIDEOS_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${VIDEOS_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${VIDEOS_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${VIDEOS_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${VIDEOS_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
if [ -z "$DISPLAY" ]; then printf_exit "No display server found.......exiting $(sleep 2)"; fi
xine-ui() { xine || xine-ui || false; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
while :; do
  main=""
  clear
  shift 1
  printf_newline "\n\n\n\n"
  printf_head "Video applications Menu"
  printf_green "a. launch vlc"
  printf_green "b. launch mpv"
  printf_green "c. launch mplayer"
  printf_green "d. launch smtube"
  printf_green "e. launch smplayer"
  printf_green "f. launch xine-ui"
  printf_green "g. launch banshee"
  printf_green "h. launch bomi"
  printf_green "i. launch dragonplayer"
  printf_green "j. launch snappy"
  printf_green "k. launch celluloid"
  printf_green "l. launch parole"
  printf_green "m. launch xmbc"
  printf_green "n. launch kodi"
  printf_green "o. launch totem"
  printf_green "p. launch miro"
  printf_green "q. launch asciinema"
  printf_green "y. launch custom application"
  printf_green "z. or escape to Exit"
  printf_green "---------------------------------"
  printf_read_question_nt "6" "Enter your choice [a-z] : " "1" "main"
  # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  case "$main" in
  a)
    shift 1
    __open_file_menus vlc "$@" &>/dev/null
    ;;
  b)
    shift 1
    __open_file_menus mpv "$@" &>/dev/null
    ;;
  c)
    shift 1
    __open_file_menus mplayer "$@" &>/dev/null
    ;;
  d)
    shift 1
    __open_file_menus smtube "$@" &>/dev/null
    ;;
  e)
    shift 1
    __open_file_menus smplayer "$@" &>/dev/null
    ;;
  f)
    shift 1
    __open_file_menus xine-ui "$@" &>/dev/null
    ;;
  g)
    shift 1
    __open_file_menus banshee "$@" &>/dev/null
    ;;
  h)
    shift 1
    __open_file_menus bomi "$@" &>/dev/null
    ;;
  i)
    shift 1
    __open_file_menus dragonplayer "$@" &>/dev/null
    ;;
  j)
    shift 1
    __open_file_menus snappy "$@" &>/dev/null
    ;;
  k)
    shift 1
    __open_file_menus celluloid "$@" &>/dev/null
    ;;
  l)
    shift 1
    __open_file_menus parole "$@" &>/dev/null
    ;;
  m)
    shift 1
    __open_file_menus xmbc "$@" &>/dev/null
    ;;
  n)
    shift 1
    __open_file_menus kodi "$@" &>/dev/null
    ;;
  o)
    shift 1
    __open_file_menus totem "$@" &>/dev/null
    ;;
  p)
    shift 1
    __open_file_menus miro "$@" &>/dev/null
    ;;
  q)
    shift 1
    __open_file_menus asciinema play "$@"
    ;;
  y)
    shift 1
    __custom_menus
    continue
    ;;
  $'\E' | $'\e' | z)
    clear
    break
    ;;
  *) shift ;;
  esac
  clear
  printf_newline "\n\n"
  printf_counter "$VIDEOS_OUTPUT_COLOR" "$VIDEOS_COUNTDOWN_TIME" "Re-loading menu in"
done
clear
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
