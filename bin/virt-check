#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202112302356-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : virt-check --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Thursday, Dec 30, 2021 23:56 EST
# @File          : virt-check
# @Description   : Check if processor supports virtualization
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202112302356-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-simple.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$VIRT_CHECK_CONFIG_DIR/$VIRT_CHECK_CONFIG_FILE"
  [ -d "$VIRT_CHECK_CONFIG_DIR" ] || mkdir -p "$VIRT_CHECK_CONFIG_DIR"
  [ -d "$VIRT_CHECK_CONFIG_BACKUP_DIR" ] || mkdir -p "$VIRT_CHECK_CONFIG_BACKUP_DIR"
  [ -f "$VIRT_CHECK_CONFIG_DIR/$VIRT_CHECK_CONFIG_FILE" ] &&
    cp -Rf "$VIRT_CHECK_CONFIG_DIR/$VIRT_CHECK_CONFIG_FILE" "$VIRT_CHECK_CONFIG_BACKUP_DIR/$VIRT_CHECK_CONFIG_FILE.$$"
  cat <<EOF >"$VIRT_CHECK_CONFIG_DIR/$VIRT_CHECK_CONFIG_FILE"
# Settings for virt-check

# Notification settings
VIRT_CHECK_GOOD_MESSAGE="${VIRT_CHECK_GOOD_MESSAGE:-Everything Went OK}"
VIRT_CHECK_ERROR_MESSAGE="${VIRT_CHECK_ERROR_MESSAGE:-Well something seems to have gone wrong}"
VIRT_CHECK_NOTIFY_ENABLED="${VIRT_CHECK_NOTIFY_ENABLED:-yes}"
VIRT_CHECK_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
VIRT_CHECK_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$VIRT_CHECK_NOTIFY_CLIENT_ICON}"

# Colorization settings
VIRT_CHECK_OUTPUT_COLOR="${VIRT_CHECK_OUTPUT_COLOR:-5}"
VIRT_CHECK_OUTPUT_COLOR_GOOD="${VIRT_CHECK_OUTPUT_COLOR_GOOD:-2}"
VIRT_CHECK_OUTPUT_COLOR_ERROR="${VIRT_CHECK_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$VIRT_CHECK_CONFIG_DIR/$VIRT_CHECK_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__cpu_info() {
  grep -wo -E 'vmx|lm|aes' /proc/cpuinfo | sort | uniq
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__cpu_64bit() {
  __cpu_info | grep -q 'lm' && printf_green "CPU is 64 bit" || printf_return "CPU is not 64 bit"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__cpu_aes() {
  __cpu_info | grep -q 'aes' && printf_green "CPU supports AES" || printf_return "CPU does not support AES"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__cpu_virt() {
  __cpu_info | grep -q -E 'svm|vmx' && printf_green "CPU supports virtualization" || printf_return "CPU does not support virtualization"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
VIRT_CHECK_LOG_DIR="${VIRT_CHECK_LOG_DIR:-$HOME/.local/log/virt-check}"
VIRT_CHECK_CACHE_DIR="${VIRT_CHECK_CACHE_DIR:-$HOME/.cache/virt-check}"
VIRT_CHECK_CONFIG_DIR="${VIRT_CHECK_CONFIG_DIR:-$HOME/.config/myscripts/virt-check}"
VIRT_CHECK_OPTIONS_DIR="${VIRT_CHECK_OPTIONS_DIR:-$HOME/.local/share/myscripts/virt-check/options}"
VIRT_CHECK_CONFIG_BACKUP_DIR="${VIRT_CHECK_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/virt-check/backups}"
VIRT_CHECK_TEMP_DIR="${VIRT_CHECK_TEMP_DIR:-$HOME/.local/tmp/system_scripts/virt-check}"
VIRT_CHECK_CONFIG_FILE="${VIRT_CHECK_CONFIG_FILE:-settings.conf}"
VIRT_CHECK_GOOD_MESSAGE="${VIRT_CHECK_GOOD_MESSAGE:-Everything Went OK}"
VIRT_CHECK_ERROR_MESSAGE="${VIRT_CHECK_ERROR_MESSAGE:-Well something seems to have gone wrong}"
VIRT_CHECK_NOTIFY_ENABLED="${VIRT_CHECK_NOTIFY_ENABLED:-yes}"
VIRT_CHECK_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
VIRT_CHECK_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$VIRT_CHECK_NOTIFY_CLIENT_ICON}"
VIRT_CHECK_OUTPUT_COLOR="${VIRT_CHECK_OUTPUT_COLOR:-5}"
VIRT_CHECK_OUTPUT_COLOR_GOOD="${VIRT_CHECK_OUTPUT_COLOR_GOOD:-2}"
VIRT_CHECK_OUTPUT_COLOR_ERROR="${VIRT_CHECK_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Enviroment overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$VIRT_CHECK_CONFIG_DIR/$VIRT_CHECK_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$VIRT_CHECK_CONFIG_DIR/$VIRT_CHECK_CONFIG_FILE" ] && . "$VIRT_CHECK_CONFIG_DIR/$VIRT_CHECK_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$VIRT_CHECK_LOG_DIR" ] || mkdir -p "$VIRT_CHECK_LOG_DIR" &>/dev/null
[ -d "$VIRT_CHECK_TEMP_DIR" ] || mkdir -p "$VIRT_CHECK_TEMP_DIR" &>/dev/null
[ -d "$VIRT_CHECK_CACHE_DIR" ] || mkdir -p "$VIRT_CHECK_CACHE_DIR" &>/dev/null
VIRT_CHECK_TEMP_FILE="${VIRT_CHECK_TEMP_FILE:-$(mktemp $VIRT_CHECK_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$VIRT_CHECK_TEMP_FILE" ] && [ -f "$VIRT_CHECK_TEMP_FILE" ] && rm -Rf "$VIRT_CHECK_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$VIRT_CHECK_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${VIRT_CHECK_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${VIRT_CHECK_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${VIRT_CHECK_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${VIRT_CHECK_NOTIFY_CLIENT_ICON}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    __help
    shift 1
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    VIRT_CHECK_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__cpu_64bit
__cpu_aes
__cpu_virt
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
