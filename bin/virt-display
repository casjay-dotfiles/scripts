# Set directory to first argument
# [ -d "$1" ] && VIRT_DISPLAY_CWD="$1" && shift 1 || VIRT_DISPLAY_CWD="${VIRT_DISPLAY_CWD:-$PWD}"
VIRT_DISPLAY_CWD="$(realpath "${VIRT_DISPLAY_CWD:-$PWD}" 2>/dev/null)"
# if [ -d "$VIRT_DISPLAY_CWD" ] && cd "$VIRT_DISPLAY_CWD"; then
# if [ "$VIRT_DISPLAY_SILENT" != "true" ] && [ "$CWD_SILENCE" != "true" ]; then
