# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user root
__user_is_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Is current user not root
__user_is_not_root() {
  { [ $(id -u) -eq 0 ] || [ $EUID -eq 0 ] || [ "$WHOAMI" = "root" ]; } && return 1 || return 0
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check if user is a member of sudo
__sudo_group() {
  grep -s "${1:-$USER}" "/etc/group" | grep -Eq 'wheel|adm|sudo' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# # Get sudo password
__sudoask() {
  ask_for_password sudo true && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run sudo
__sudorun() {
  __sudoif && __cmd_exists sudo && sudo -HE "$@" || { __sudoif && eval "$@"; }
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Test if user has access to sudo
__can_i_sudo() {
  (sudo -vn && sudo -ln) 2>&1 | grep -vq 'may not' >/dev/null && return 0
  __sudo_group "${1:-$USER}" || __sudoif || __sudo true &>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User can run sudo
__sudoif() {
  __user_is_root && return 0
  __can_i_sudo "${RUN_USER:-$USER}" && return 0
  __user_is_not_root && __sudoask && return 0 || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Run command as root
requiresudo() {
  if [ "$VIRT_DISPLAY_REQUIRE_SUDO" = "yes" ] && [ -z "$VIRT_DISPLAY_REQUIRE_SUDO_RUN" ]; then
    export VIRT_DISPLAY_REQUIRE_SUDO="no"
    export VIRT_DISPLAY_REQUIRE_SUDO_RUN="true"
    __sudo "$@"
    exit $?
  else
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Execute sudo
__sudo() {
  CMD="${1:-echo}" && shift 1
  CMD_ARGS="${*:--e "${RUN_USER:-$USER}"}"
  SUDO="$(builtin command -v sudo 2>/dev/null || echo 'eval')"
  [ "$(basename "$SUDO" 2>/dev/null)" = "sudo" ] && OPTS="--preserve-env=PATH -HE"
  if __sudoif; then
    export PATH="$PATH"
    $SUDO ${OPTS:-} $CMD $CMD_ARGS && true || false
    exitCode=$?
  else
    printf '%s\n' "This requires root to run"
    exitCode=1
  fi
  return ${exitCode:-1}
}
# End of sudo functions
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit() {
  exitCode=${exitCode:-$?}
  [ -f "$VIRT_DISPLAY_TEMP_FILE" ] && rm -Rf "$VIRT_DISPLAY_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
__virsh() {
  sudo virsh "$@" 2>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__list_ips() {
  __virsh net-dhcp-leases default 2>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__list_running() {
  __sudo virsh list --all 2>/dev/null | grep -E 'running|shut off' | grep '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__list_vms() {
  __virsh list --all | grep -Ev 'Id.*.Name.*.State|----|^$' 2>/dev/null | awk '{print $2}' | grep '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_pid() {
  __sudo ps aux 2>/dev/null | grep "qemu" | grep "$1" | grep -v 'grep' | awk '{print $2}' | grep '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_port() {
  __
  sudo netstat -apn 2>/dev/null | grep "$(__get_pid "$1")" | grep 'tcp' | awk '{print $4}' | grep '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__viewer() {
  __local_viewer "$1" || __remote_viewer "$1" || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__printf_reset() {
  printf_color "\r$1 " ${2:-1}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__check_vm_args() {
  local running=""
  if [ $# -eq 0 ] || [ $1 = "" ]; then
    running="$(__list_running | grep -w 'running' | awk '{print $2}' | tr '\n' ' ' | grep '^')"
    [ -n "$running" ] && printf_red "Please provide the vm name: ${GREEN}$running${RESET}" || printf_red "Please provide the vm name"
    exit 1
  else
    __list_vms | grep -wq "$1" || printf_exit "Can not find the vm named $1"
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__ssh() {
  local ip="$1"
  local user="${2:-root}"
  local idFile="$3"
  local sshcmd="-l ${user} ${ip} ${VIRT_DISPLAY_SSH_OPTS:-}"
  [ -n "$idFile" ] && ssh -i "$id_file" $sshcmd 2>/dev/null || ssh $sshcmd 2>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__vm_rm() {
  __list_vms | grep -qw "$1" &&
    printf_blue "Removing virtual machine: $1"
  __list_running | grep -qi 'running' && __virsh destroy "$1" &>/dev/null &&
    __list_vms | grep -qw "$1" && __virsh undefine "$1" &>/dev/null &&
    printf_green "The vm has been deleted" ||
    printf_exit "The VM $1 does not exist"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_id_file() {
  local idFile="$1"
  local ipFile="$2"
  if [ -n "$idFile" ] && [ -f "$idFile" ]; then
    echo "$idFile"
  elif [ -n "$idFile" ] && [ -f "$HOME/.ssh/$idFile" ]; then
    echo "$HOME/.ssh/$idFile"
  elif [ -n "$ipFile" ] && [ -f "$HOME/.ssh/$ipFile" ]; then
    echo "$HOME/.ssh/$ipFile"
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_ip() {
  local ip="" mac=""
  local name="$1"
  ip="$(__list_ips | grep -w "$name" | awk '{print $5}' | grep '[0-9]' | awk -F '/' '{print $1}')"
  mac="$(__virsh dumpxml "$name" 2>/dev/null | grep "mac address" | awk -F\' '{ print $2}')"
  [ -n "$ip" ] && printf '%s\n' "$ip" || arp -an 2>/dev/null | grep "$mac" | grep '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__test_connection() {
  local ip="$1" status=""
  status=$({ __cmd_exists nmap && nmap "$ip" -Pn -p 22 | grep -qioE 'open' && echo 'true'; } || { ping -w 1 -c1 "$ip" &>/dev/null && echo 'true'; } || return 1)
  if [ $status == "true" ]; then
    return 0
  elif ssh -q -o BatchMode=yes -o StrictHostKeyChecking=no -o ConnectTimeout=1 $ip 'exit 0' &>/dev/null; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__ssh_viewer() {
  local ip="" idFile="" tries=""
  local name="$1"
  local user="$2"
  local idFile="${3:-$2}"
  ip="$(__get_ip "${name}" | tail -n1)"
  idFile="$(__get_id_file "$idFile")"
  tries=10
  clear
  while [ $tries -gt 0 ]; do
    __printf_reset "Attempting to connect to ${ip}..." 3
    __start "$name" &>/dev/null && sleep 2 || sleep .5
    [ -n "$ip" ] && break || tries=$((tries - 1))
    sleep 1 && ip="$(__get_ip "$ip")"
  done
  echo ''
  id_file="$(__get_id_file "$idFile" || __get_id_file "$ip")"
  if [ -n "$ip" ]; then
    if __test_connection "$ip"; then
      clear
      __ssh "${ip}" "${user}" "${id_file}" && clear
      exit
    else
      printf_red "Failed to ping ${ip} launching local viewer"
      sleep 3
      __local_viewer "$name"
    fi
  else
    printf_exit "Can not find the IP address for $name"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__local_viewer() {
  local running=""
  running="$(__list_running | grep 'running' | grep "$1" | grep '^' || echo '')"
  [ -n "$running" ] || printf_exit "$1 is not running"
  { __cmd_exists virt-viewer && sudo virt-viewer "$1" 2>/dev/null || return 1; } &
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__remote_viewer() {
  local port=""
  port="$(__get_port "$1")"
  [ -n "$port" ] || printf_exit "$1 does not seem to be using a port"
  { __cmd_exists remote-viewer && remote-viewer spice://$port 2>/dev/null || return 1; } &
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__snapshot() {
  domain="$1"
  snapshot="${2:-Default}"
  destroy="$([ "$3" != "no-stop" ] && __virsh destroy --domain "$domain" &>/dev/null || false)"
  snapshot="$(__virsh snapshot-create-as "${snapshot:-Default}" --domain "$domain" &>/dev/null)"
  created="$(snapshot-list --domain $domain 2>&1 | grep -q "$snapshot" || echo 'Failed')"
  [ -z "$created" ] || printf_return "Failed to create snapshot $snapshot"
  start="$(__virsh start --domain "$domain" 2>&1 | grep -qiv ' started')"
  [ -n "$start" ] || printf_return "Failed to start $domain"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__restore() {
  domain="$1"
  snapshot="${2:-Default}"
  printf_green "Restoring snapshot for $domain using $snapshot"
  restore="$(__virsh snapshot-revert --domain $domain $snapshot 2>&1 | grep -Eqi 'error:|failed:' && echo 'Failed')"
  [ -z "$restore" ] && printf_green "Restore was successful" || printf_return "Failed to restore snapshot"
  start="$(__virsh start --domain $domain 2>&1 | grep -qi ' started' || echo 'Failed')"
  [ -z "$start" ] && printf_green "Started $domain" || printf_return "Failed to start $domain"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__start() {
  domain="$1"
  start="$(__virsh start --domain $domain 2>&1 | grep -qiE 'error:|failed:' && echo 'Failed')"
  [ -z "$start" ] && printf_green "$domain has been started" || printf_return "Failed to start $domain"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__vm_new() {
  local ovmf="" disk="" snapshot="" pid="" TPM=""
  local name="$1"
  local cdimage="$2"
  local retries=10
  ovmf="$(dirname $(find /usr/share/edk2* -name 'OVMF_CODE.secboot.fd' | grep -v '32' 2>/dev/null) 2>/dev/null)"
  if [ "$name" = "tails" ] || [ "$name" = "heads" ]; then
    __virsh undefine "$name" &>/dev/null || true &>/dev/null
    disk="--disk none"
    snapshot="true"
  else
    disk="--disk /var/lib/libvirt/images/$name.$VIRT_DISPLAY_VM_DISK_TYPE,device=disk,size=$VIRT_DISPLAY_VM_DISK_SIZE,bus=virtio,format=$VIRT_DISPLAY_VM_DISK_TYPE"
    snapshot="__snapshot $name default no-stop &>/dev/null"
  fi
  if __list_running | grep -w "$name" | grep -qi 'running'; then
    printf_red "The vm is already running"
    printf_cyan "launching the vm viewer for $name"
    __local_viewer "$name" &>/dev/null || __remote_viewer "$name" &>/dev/null
    return 0
  elif __list_vms | grep -qw "$name"; then
    __local_viewer "$name"
    printf_exit "The VM $name Already Exists"
  else
    printf_cyan "Creating $name using ISO: $(basename "$cdimage")"
  fi
  type -P swtpm &>/dev/null && TPM="--tpm backend.type=emulator,backend.version=2.0,model=tpm-tis"
  {
    sudo virt-install \
      --os-variant "linux2020" \
      --name $name ${TPM:-} \
      --ram=$VIRT_DISPLAY_VM_RAM_SIZE \
      --cpu host-passthrough \
      --vcpus=2 ${disk:-} \
      --cdrom "$cdimage" \
      --network $VIRT_DISPLAY_VM_NETWORK,model=virtio \
      --graphics spice \
      --boot hd,cdrom,menu=on | tee "$VIRT_DISPLAY_LOG_DIR/virt-install.log" &>/dev/null &
    pid=$!
    sleep 10
    if grep -iqs 'virt-install: error:' "$VIRT_DISPLAY_LOG_DIR/virt-install.log"; then
      printf_exit "Failed to create vm"
    fi
  } &
  while :; do
    if __list_running | grep -w "$name" | grep -qi 'running'; then
      echo ''
      printf_blue "$name is now running"
      break
    fi
    printf '\rAttempting to create and start %s  ' "$name"
    sleep 10
    ((retries--))
    [ $retries -eq 0 ] && echo '' && printf_exit "Failed to create and start $name"
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined variables/import external variables

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
VIRT_DISPLAY_CONFIG_FILE="${VIRT_DISPLAY_CONFIG_FILE:-settings.conf}"
VIRT_DISPLAY_CONFIG_DIR="${VIRT_DISPLAY_CONFIG_DIR:-$HOME/.config/myscripts/virt-display}"
VIRT_DISPLAY_CONFIG_BACKUP_DIR="${VIRT_DISPLAY_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/virt-display/backups}"
VIRT_DISPLAY_LOG_DIR="${VIRT_DISPLAY_LOG_DIR:-$HOME/.local/log/virt-display}"
VIRT_DISPLAY_TEMP_DIR="${VIRT_DISPLAY_TEMP_DIR:-$HOME/.local/tmp/system_scripts/virt-display}"
VIRT_DISPLAY_CACHE_DIR="${VIRT_DISPLAY_CACHE_DIR:-$HOME/.cache/virt-display}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
VIRT_DISPLAY_OUTPUT_COLOR_1="${VIRT_DISPLAY_OUTPUT_COLOR_1:-33}"
VIRT_DISPLAY_OUTPUT_COLOR_2="${VIRT_DISPLAY_OUTPUT_COLOR_2:-5}"
VIRT_DISPLAY_OUTPUT_COLOR_GOOD="${VIRT_DISPLAY_OUTPUT_COLOR_GOOD:-2}"
VIRT_DISPLAY_OUTPUT_COLOR_ERROR="${VIRT_DISPLAY_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
VIRT_DISPLAY_NOTIFY_ENABLED="${VIRT_DISPLAY_NOTIFY_ENABLED:-yes}"
VIRT_DISPLAY_GOOD_NAME="${VIRT_DISPLAY_GOOD_NAME:-Great:}"
VIRT_DISPLAY_ERROR_NAME="${VIRT_DISPLAY_ERROR_NAME:-Error:}"
VIRT_DISPLAY_GOOD_MESSAGE="${VIRT_DISPLAY_GOOD_MESSAGE:-No errors reported}"
VIRT_DISPLAY_ERROR_MESSAGE="${VIRT_DISPLAY_ERROR_MESSAGE:-Errors were reported}"
VIRT_DISPLAY_NOTIFY_CLIENT_NAME="${VIRT_DISPLAY_NOTIFY_CLIENT_NAME:-$APPNAME}"
VIRT_DISPLAY_NOTIFY_CLIENT_ICON="${VIRT_DISPLAY_NOTIFY_CLIENT_ICON:-notification-new}"
VIRT_DISPLAY_NOTIFY_CLIENT_URGENCY="${VIRT_DISPLAY_NOTIFY_CLIENT_URGENCY:-normal}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional Variables
VIRT_DISPLAY_VM_RAM_SIZE="${VIRT_DISPLAY_VM_RAM_SIZE:-2048}"
VIRT_DISPLAY_VM_NETWORK="${VIRT_DISPLAY_VM_NETWORK:-network=default}"
VIRT_DISPLAY_VM_DISK_TYPE="${VIRT_DISPLAY_VM_DISK_TYPE:-qcow2}"
VIRT_DISPLAY_VM_DISK_SIZE="${VIRT_DISPLAY_VM_DISK_SIZE:-100}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE" ] ||
  [ "$*" = "--config" ] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE" ] &&
  . "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$VIRT_DISPLAY_LOG_DIR" ] ||
  mkdir -p "$VIRT_DISPLAY_LOG_DIR" |& __devnull
[ -d "$VIRT_DISPLAY_TEMP_DIR" ] ||
  mkdir -p "$VIRT_DISPLAY_TEMP_DIR" |& __devnull
[ -d "$VIRT_DISPLAY_CACHE_DIR" ] ||
  mkdir -p "$VIRT_DISPLAY_CACHE_DIR" |& __devnull
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
VIRT_DISPLAY_TEMP_FILE="${VIRT_DISPLAY_TEMP_FILE:-$(mktemp $VIRT_DISPLAY_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap '__trap_exit' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
__notifications() {
  __cmd_exists notifications || return
  [ "$VIRT_DISPLAY_NOTIFY_ENABLED" = "yes" ] || return
  [ "$SEND_NOTIFICATION" = "no" ] && return
  (
    set +x
    export SCRIPT_OPTS="" _DEBUG=""
    export NOTIFY_GOOD_MESSAGE="${NOTIFY_GOOD_MESSAGE:-$VIRT_DISPLAY_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${NOTIFY_ERROR_MESSAGE:-$VIRT_DISPLAY_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$VIRT_DISPLAY_NOTIFY_CLIENT_ICON}"
    export NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$VIRT_DISPLAY_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_URGENCY="${NOTIFY_CLIENT_URGENCY:-$VIRT_DISPLAY_NOTIFY_CLIENT_URGENCY}"
    notifications "$@"
    retval=$?
    return $retval
  ) |& __devnull &
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set custom actions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Argument/Option settings
SETARGS=("$@")
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
SHORTOPTS=""
SHORTOPTS+=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
LONGOPTS="completions:,config,debug,dir:,help,options,raw,version,silent"
LONGOPTS+=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
ARRAY="list start ssh restore create new delete open"
ARRAY+=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
LIST=""
LIST+=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --raw)
    shift 1
    export SHOW_RAW="true"
    printf_column() { tee | grep '^'; }
    printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[ 0-9;]*[a-zA-Z],,g'; }
    ;;
  --debug)
    shift 1
    set -xo pipefail
    export SCRIPT_OPTS="--debug"
    export _DEBUG="on"
    __devnull() { tee || return 1; }
    __devnull2() { eval "$@" |& tee || return 1; }
    ;;
  --completions)
    if [ "$2" = "short" ]; then
      printf '%s\n' "-$SHORTOPTS" | sed 's|"||g;s|:||g;s|,|,-|g' | tr ',' '\n'
    elif [ "$2" = "long" ]; then
      printf '%s\n' "--$LONGOPTS" | sed 's|"||g;s|:||g;s|,|,--|g' | tr ',' '\n'
    elif [ "$2" = "array" ]; then
      printf '%s\n' "$ARRAY" | sed 's|"||g;s|:||g' | tr ',' '\n'
    elif [ "$2" = "list" ]; then
      printf '%s\n' "$LIST" | sed 's|"||g;s|:||g' | tr ',' '\n'
    else
      exit 1
    fi
    shift 2
    exit $?
    ;;
  --options)
    shift 1
    printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "Short Options" "-${SHORTOPTS}" ',' '-' 4
    [ -z "$LONGOPTS" ] || __list_options "Long Options" "--${LONGOPTS}" ',' '--' 4
    [ -z "$ARRAY" ] || __list_options "Base Options" "${ARRAY}" ',' '' 4
    echo ""
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --silent)
    shift 1
    VIRT_DISPLAY_SILENT="true"
    ;;
  --dir)
    CWD_IS_SET="TRUE"
    VIRT_DISPLAY_CWD="$2"
    #[ -d "$VIRT_DISPLAY_CWD" ] || mkdir -p "$VIRT_DISPLAY_CWD" |& __devnull
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
