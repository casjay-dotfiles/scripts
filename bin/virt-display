# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Send all output to /dev/null
__devnull() {
  tee &>/dev/null && exitCode=0 || exitCode=1
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -'
# Send errors to /dev/null
__devnull2() {
  [ -n "$1" ] && local cmd="$1" && shift 1 || return 1
  eval $cmd "$*" 2>/dev/null && exitCode=0 || exitCode=1
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -'
# See if the executable exists
__cmd_exists() {
  exitCode=0
  [ -n "$1" ] && local exitCode="" || return 0
  for cmd in "$@"; do
    builtin command -v "$cmd" &>/dev/null && exitCode+=$(($exitCode + 0)) || exitCode+=$(($exitCode + 1))
  done
  [ $exitCode -eq 0 ] || exitCode=3
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for a valid internet connection
__am_i_online() {
  local exitCode=0
  curl -q -LSsfI --max-time 1 --retry 0 "${1:-http://1.1.1.1}" 2>&1 | grep -qi 'server:.*cloudflare' || exitCode=4
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# colorization
if [ "$SHOW_RAW" = "true" ]; then
  printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[ 0-9;]*[a-zA-Z],,g'; }
else
  printf_color() { printf "%b" "$(tput setaf "${2:-7}" 2>/dev/null)" "$1" "$(tput sgr0 2>/dev/null)"; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional printf_ colors
__printf_head() { printf_blue "$1"; }
__printf_opts() { printf_purple "$1"; }
__printf_line() { printf_cyan "$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# output version
__version() { printf_cyan "$VERSION"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  printf_color "$1: " "$5"
  echo -ne "$2" | sed 's|:||g;s/'$3'/ '$4'/g' | tr '\n' ' '
  printf_newline
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# create the config file
__gen_config() {
  local NOTIFY_CLIENT_NAME="$APPNAME"
  if [ "$INIT_CONFIG" != "TRUE" ]; then
    printf_blue "Generating the config file in"
    printf_cyan "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE"
  fi
  [ -d "$VIRT_DISPLAY_CONFIG_DIR" ] || mkdir -p "$VIRT_DISPLAY_CONFIG_DIR"
  [ -d "$VIRT_DISPLAY_CONFIG_BACKUP_DIR" ] || mkdir -p "$VIRT_DISPLAY_CONFIG_BACKUP_DIR"
  [ -f "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE" ] &&
    cp -Rf "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE" "$VIRT_DISPLAY_CONFIG_BACKUP_DIR/$VIRT_DISPLAY_CONFIG_FILE.$$"
  cat <<EOF >"$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE"
# Settings for virt-display
VIRT_DISPLAY_VM_RAM_SIZE="${VIRT_DISPLAY_VM_RAM_SIZE:-}"
VIRT_DISPLAY_VM_NETWORK="${VIRT_DISPLAY_VM_NETWORK:-}"
VIRT_DISPLAY_VM_DISK_TYPE="${VIRT_DISPLAY_VM_DISK_TYPE:-}"
VIRT_DISPLAY_VM_DISK_SIZE="${VIRT_DISPLAY_VM_DISK_SIZE:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Color Settings
VIRT_DISPLAY_OUTPUT_COLOR_1="${VIRT_DISPLAY_OUTPUT_COLOR_1:-}"
VIRT_DISPLAY_OUTPUT_COLOR_2="${VIRT_DISPLAY_OUTPUT_COLOR_2:-}"
VIRT_DISPLAY_OUTPUT_COLOR_GOOD="${VIRT_DISPLAY_OUTPUT_COLOR_GOOD:-}"
VIRT_DISPLAY_OUTPUT_COLOR_ERROR="${VIRT_DISPLAY_OUTPUT_COLOR_ERROR:-}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Notification Settings
VIRT_DISPLAY_NOTIFY_ENABLED="${VIRT_DISPLAY_NOTIFY_ENABLED:-}"
VIRT_DISPLAY_GOOD_NAME="${VIRT_DISPLAY_GOOD_NAME:-}"
VIRT_DISPLAY_ERROR_NAME="${VIRT_DISPLAY_ERROR_NAME:-}"
VIRT_DISPLAY_GOOD_MESSAGE="${VIRT_DISPLAY_GOOD_MESSAGE:-}"
VIRT_DISPLAY_ERROR_MESSAGE="${VIRT_DISPLAY_ERROR_MESSAGE:-}"
VIRT_DISPLAY_NOTIFY_CLIENT_NAME="${VIRT_DISPLAY_NOTIFY_CLIENT_NAME:-}"
VIRT_DISPLAY_NOTIFY_CLIENT_ICON="${VIRT_DISPLAY_NOTIFY_CLIENT_ICON:-}"
VIRT_DISPLAY_NOTIFY_CLIENT_URGENCY="${VIRT_DISPLAY_NOTIFY_CLIENT_URGENCY:-}"

EOF
  if builtin type -t __gen_config_local | grep -q 'function'; then __gen_config_local; fi
  if [ -f "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE" ]; then
    [ "$INIT_CONFIG" = "TRUE" ] || printf_green "Your config file for $APPNAME has been created"
    . "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
