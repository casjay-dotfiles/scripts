APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202201120610-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE"
  [ -d "$VIRT_DISPLAY_CONFIG_DIR" ] || mkdir -p "$VIRT_DISPLAY_CONFIG_DIR"
  [ -d "$VIRT_DISPLAY_CONFIG_BACKUP_DIR" ] || mkdir -p "$VIRT_DISPLAY_CONFIG_BACKUP_DIR"
  [ -f "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE" ] &&
    cp -Rf "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE" "$VIRT_DISPLAY_CONFIG_BACKUP_DIR/$VIRT_DISPLAY_CONFIG_FILE.$$"
  cat <<EOF >"$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE"
# Settings for virt-display
VIRT_DISPLAY_VM_RAM_SIZE="${VIRT_DISPLAY_VM_RAM_SIZE:-2048}"
VIRT_DISPLAY_VM_NETWORK="${VIRT_DISPLAY_VM_NETWORK:-network=default}"
VIRT_DISPLAY_VM_DISK_TYPE="${VIRT_DISPLAY_VM_DISK_TYPE:-qcow2}"
VIRT_DISPLAY_VM_DISK_SIZE="${VIRT_DISPLAY_VM_DISK_SIZE:-100}"

# Notification settings
VIRT_DISPLAY_GOOD_MESSAGE="${VIRT_DISPLAY_GOOD_MESSAGE:-Everything Went OK}"
VIRT_DISPLAY_ERROR_MESSAGE="${VIRT_DISPLAY_ERROR_MESSAGE:-Well something seems to have gone wrong}"
VIRT_DISPLAY_NOTIFY_ENABLED="${VIRT_DISPLAY_NOTIFY_ENABLED:-yes}"
VIRT_DISPLAY_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
VIRT_DISPLAY_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$VIRT_DISPLAY_NOTIFY_CLIENT_ICON}"

# Colorization settings
VIRT_DISPLAY_OUTPUT_COLOR="${VIRT_DISPLAY_OUTPUT_COLOR:-5}"
VIRT_DISPLAY_OUTPUT_COLOR_GOOD="${VIRT_DISPLAY_OUTPUT_COLOR_GOOD:-2}"
VIRT_DISPLAY_OUTPUT_COLOR_ERROR="${VIRT_DISPLAY_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__virsh() { sudo virsh "$@" 2>/dev/null || return 1; }
__list_ips() { __virsh net-dhcp-leases default 2>/dev/null || return 1; }
__list_running() { sudo virsh list --all 2>/dev/null | grep -E 'running|shut off' | grep '^' || return 1; }
__list_vms() { __virsh list --all | grep -Ev 'Id.*.Name.*.State|----|^$' 2>/dev/null | awk '{print $2}' | grep '^' || return 1; }
__get_pid() { sudo ps aux 2>/dev/null | grep "qemu" | grep "$1" | grep -v 'grep' | awk '{print $2}' | grep '^' || return 1; }
__get_port() { sudo netstat -apn 2>/dev/null | grep "$(__get_pid "$1")" | grep 'tcp' | awk '{print $4}' | grep '^' || return 1; }
__viewer() { __local_viewer "$1" || __remote_viewer "$1" || return 1; }
__printf_reset() { printf_color "\r\t\t$1 " ${2:-1}; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__check_vm_args() {
  if [[ $# -eq 0 ]]; then
    local running="$(__list_running | grep 'running' | awk '{print $2}' | tr '\n' ' ' | grep '^')"
    [[ -n "$running" ]] && printf_red "Please provide the vm name: ${GREEN}$running${RESET}" || printf_red "Please provide the vm name"
    exit 1
  else
    __list_vms | grep -wq "$1" || printf_exit "Can not find the vm named $1"
    return 0
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__ssh() {
  local ip="$1"
  local user="$2"
  local idFile="$3"
  local sshcmd="-l ${user} ${ip} ${VIRT_DISPLAY_SSH_OPTS:-}"
  [[ -n "$idFile" ]] && ssh -i "$id_file" $sshcmd 2>/dev/null || ssh $sshcmd 2>/dev/null || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__vm_rm() {
  __list_vms | grep -qw "$1" &&
    printf_blue "Removing virtual machine: $1"
  __list_running | grep -qi 'running' && __virsh destroy "$1" &>/dev/null &&
    __list_vms | grep -qw "$1" && __virsh undefine "$1" &>/dev/null &&
    printf_green "The vm has been deleted" ||
    printf_exit "The VM $1 does not exist"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_id_file() {
  local idFile="$1"
  local ipFile="$2"
  if [ -n "$idFile" ] && [ -f "$HOME/.ssh/$idFile" ]; then
    echo "$HOME/.ssh/$idFile"
  elif [ -n "$ipFile" ] && [ -f "$HOME/.ssh/$ipFile" ]; then
    echo "$HOME/.ssh/$ipFile"
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_ip() {
  local ip=""
  ip="$(__list_ips | grep "$1" | awk '{print $5}' | grep '[0-9]' | awk -F '/' '{print $1}')"
  mac="$(__virsh dumpxml "$1" 2>/dev/null | grep "mac address" | awk -F\' '{ print $2}')"
  [[ -n "$ip" ]] && printf '%s\n' "$ip" || arp -an 2>/dev/null | grep "$mac" | grep '^' || return 1
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__ssh_viewer() {
  clear
  local ip="" id_file=""
  local tries=10
  ip="$(__get_ip "$1")"
  while [ $tries -gt 0 ]; do
    __printf_reset "Attempting to connect to ${ip:-$1}..." 3
    __start "$1" &>/dev/null && sleep 2 || sleep .5
    [[ -n "$ip" ]] && break || tries=$((tries - 1))
    sleep 1 && ip="$(__get_ip "$1")"
  done
  echo ''
  id_file="$(__get_id_file "$1" || __get_id_file "$ip")"
  if [[ -n "$ip" ]]; then
    if ping -w 1 -c1 "$ip" >/dev/null 2>&1; then
      clear
      __ssh "${ip:-$1}" "${2:-root}" "${id_file:-$3}" && clear
      exit
    else
      printf_red "Failed to ping ${ip:-$1} launching local viewer"
      sleep 3
      __local_viewer "$1"
    fi
  else
    printf_exit "Can not find the IP address for $1"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__local_viewer() {
  local running=""
  running="$(__list_running | grep 'running' | grep "$1" | grep '^' || echo '')"
  [[ -n "$running" ]] || printf_exit "$1 is not running"
  { sudo virt-viewer "$1" 2>/dev/null || return 1; } &
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__remote_viewer() {
  local port=""
  port="$(__get_port "$1")"
  [ -n "$port" ] || printf_exit "$1 does not seem to be using a port"
  { remote-viewer spice://$port 2>/dev/null || return 1; } &
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__snapshot() {
  domain="$1"
  snapshot="${2:-Default}"
  destroy="$([ "$3" != "no-stop" ] && __virsh destroy --domain "$domain" &>/dev/null || false)"
  snapshot="$(__virsh snapshot-create-as "${snapshot:-Default}" --domain "$domain" &>/dev/null)"
  created="$(snapshot-list --domain $domain 2>&1 | grep -q "$snapshot" || echo 'Failed')"
  [[ -z "$created" ]] || printf_return "Failed to create snapshot $snapshot"
  start="$(__virsh start --domain "$domain" 2>&1 | grep -qiv ' started')"
  [[ -n "$start" ]] || printf_return "Failed to start $domain"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__restore() {
  domain="$1"
  snapshot="${2:-Default}"
  printf_green "Restoring snapshot for $domain using $snapshot"
  restore="$(__virsh snapshot-revert --domain $domain $snapshot 2>&1 | grep -Eqi 'error:|failed:' && echo 'Failed')"
  [[ -z "$restore" ]] && printf_green "Restore was successful" || printf_return "Failed to restore snapshot"
  start="$(__virsh start --domain $domain 2>&1 | grep -qi ' started' || echo 'Failed')"
  [[ -z "$start" ]] && printf_green "Started $domain" || printf_return "Failed to start $domain"
  return $?
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__start() {
  domain="$1"
  start="$(__virsh start --domain $domain 2>&1 | grep -qiE 'error:|failed:' && echo 'Failed')"
  [[ -z "$start" ]] && printf_green "$domain has been started" || printf_return "Failed to start $domain"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__vm_new() {
  local name="$1"
  local cdimage="$2"
  local retries=10
  if [[ "$name" = "tails" || "$name" = "heads" ]]; then
    __virsh undefine "$name" &>/dev/null || true &>/dev/null
    local disk="--disk none"
    local snapshot="true"
  else
    local disk="--disk /var/lib/libvirt/images/$name.$VIRT_DISPLAY_VM_DISK_TYPE,device=disk,size=$VIRT_DISPLAY_VM_DISK_SIZE,bus=virtio,format=$VIRT_DISPLAY_VM_DISK_TYPE"
    local snapshot="__snapshot $name default no-stop &>/dev/null"
  fi
  if __list_running | grep -w "$name" | grep -qi 'running'; then
    printf_red "The vm is already running"
    printf_cyan "launching the vm viewer for $name"
    __local_viewer "$name" &>/dev/null || __remote_viewer "$name" &>/dev/null
    return 0
  elif __list_vms | grep -qw "$name"; then
    __local_viewer "$name"
    printf_exit "The VM $name Already Exists"
  else
    printf_cyan "Creating $name using ISO: $(basename "$cdimage")"
  fi
  {
    sudo virt-install \
      --os-variant "generic" \
      --name $name \
      --ram=$VIRT_DISPLAY_VM_RAM_SIZE \
      --cpu host-passthrough \
      --vcpus=2 ${disk:-} \
      --cdrom "$cdimage" \
      --network $VIRT_DISPLAY_VM_NETWORK,model=virtio \
      --graphics spice \
      --boot hd,cdrom,menu=on &>"$VIRT_DISPLAY_LOG_DIR/virt-install.log" &
    local pid=$!
    sleep 10
    if grep -iqs 'virt-install: error:' "$VIRT_DISPLAY_LOG_DIR/virt-install.log"; then
      printf_exit "Failed to create vm"
    fi
  } &
  while :; do
    if __list_running | grep -w "$name" | grep -qi 'running'; then
      echo ''
      printf_blue "$name is now running"
      break
    fi
    printf '\r\t\tAttempting to create and start %s  ' "$name"
    sleep 10
    ((retries--))
    [[ $retries -eq 0 ]] && echo '' && printf_exit "Failed to create and start $name"
  done
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
VIRT_DISPLAY_LOG_DIR="${VIRT_DISPLAY_LOG_DIR:-$HOME/.local/log/virt-display}"
VIRT_DISPLAY_CACHE_DIR="${VIRT_DISPLAY_CACHE_DIR:-$HOME/.cache/virt-display}"
VIRT_DISPLAY_CONFIG_DIR="${VIRT_DISPLAY_CONFIG_DIR:-$HOME/.config/myscripts/virt-display}"
VIRT_DISPLAY_OPTIONS_DIR="${VIRT_DISPLAY_OPTIONS_DIR:-$HOME/.local/share/myscripts/virt-display/options}"
VIRT_DISPLAY_CONFIG_BACKUP_DIR="${VIRT_DISPLAY_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/virt-display/backups}"
VIRT_DISPLAY_TEMP_DIR="${VIRT_DISPLAY_TEMP_DIR:-$HOME/.local/tmp/system_scripts/virt-display}"
VIRT_DISPLAY_CONFIG_FILE="${VIRT_DISPLAY_CONFIG_FILE:-settings.conf}"
VIRT_DISPLAY_GOOD_MESSAGE="${VIRT_DISPLAY_GOOD_MESSAGE:-Everything Went OK}"
VIRT_DISPLAY_ERROR_MESSAGE="${VIRT_DISPLAY_ERROR_MESSAGE:-Well something seems to have gone wrong}"
VIRT_DISPLAY_NOTIFY_ENABLED="${VIRT_DISPLAY_NOTIFY_ENABLED:-yes}"
VIRT_DISPLAY_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
VIRT_DISPLAY_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$VIRT_DISPLAY_NOTIFY_CLIENT_ICON}"
VIRT_DISPLAY_OUTPUT_COLOR="${VIRT_DISPLAY_OUTPUT_COLOR:-5}"
VIRT_DISPLAY_OUTPUT_COLOR_GOOD="${VIRT_DISPLAY_OUTPUT_COLOR_GOOD:-2}"
VIRT_DISPLAY_OUTPUT_COLOR_ERROR="${VIRT_DISPLAY_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Enviroment overrides
VIRT_DISPLAY_VM_RAM_SIZE="${VIRT_DISPLAY_VM_RAM_SIZE:-2048}"
VIRT_DISPLAY_VM_NETWORK="${VIRT_DISPLAY_VM_NETWORK:-network=default}"
VIRT_DISPLAY_VM_DISK_TYPE="${VIRT_DISPLAY_VM_DISK_TYPE:-qcow2}"
VIRT_DISPLAY_VM_DISK_SIZE="${VIRT_DISPLAY_VM_DISK_SIZE:-100}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE" ] && . "$VIRT_DISPLAY_CONFIG_DIR/$VIRT_DISPLAY_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$VIRT_DISPLAY_LOG_DIR" ] || mkdir -p "$VIRT_DISPLAY_LOG_DIR" &>/dev/null
[ -d "$VIRT_DISPLAY_TEMP_DIR" ] || mkdir -p "$VIRT_DISPLAY_TEMP_DIR" &>/dev/null
[ -d "$VIRT_DISPLAY_CACHE_DIR" ] || mkdir -p "$VIRT_DISPLAY_CACHE_DIR" &>/dev/null
VIRT_DISPLAY_TEMP_FILE="${VIRT_DISPLAY_TEMP_FILE:-$(mktemp $VIRT_DISPLAY_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$VIRT_DISPLAY_TEMP_FILE" ] && [ -f "$VIRT_DISPLAY_TEMP_FILE" ] && rm -Rf "$VIRT_DISPLAY_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$VIRT_DISPLAY_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${VIRT_DISPLAY_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${VIRT_DISPLAY_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${VIRT_DISPLAY_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${VIRT_DISPLAY_NOTIFY_CLIENT_ICON}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:"
ARRAY="list start ssh restore create new delete"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    __help
    shift 1
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    VIRT_DISPLAY_CWD="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error --ask bash || exit 1 # exit 1 if not found
#am_i_online --error || exit 1     # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
list)
  shift 1
  paused="$(__list_running | grep 'paused' | awk '{print $2}' | tr '\n' ' ')"
  running="$(__list_running | grep 'running' | awk '{print $2}' | tr '\n' ' ')"
  stopped="$(__list_running | grep 'shut off' | awk '{print $2}' | tr '\n' ' ')"
  if [[ -n "$running" ]]; then
    printf_green "Running: $running"
  fi
  if [[ -n "$stopped" ]]; then
    printf_red "Stopped: $stopped"
  fi
  if [[ -n "$paused" ]]; then
    printf_yellow "Paused: $paused"
  fi
  exit $?
  ;;

start)
  shift 1
  __check_vm_args $1
  __start "$@"
  ;;

restore)
  shift 1
  __check_vm_args $1
  __restore "$@"
  ;;

create)
  shift 1
  __check_vm_args "$1"
  __snapshot "$@"
  ;;

new)
  shift 1
  [[ $# -ne 2 ]] && printf_exit "Usage: $APPNAME new <name> <isoFile>"
  __vm_new "$@"
  exit $?
  ;;

delete)
  shift 1
  __vm_rm "$1"
  exit $?
  ;;

ip)
  shift 1
  if [[ $# -ne 0 ]]; then
    __check_vm_args $1
    ip="$(__get_ip "$1")"
    if [ -n "$ip" ]; then
      printf_green "IP for $1 is: $ip"
    else
      printf_red "No IP found for $1"
    fi
  else
    __list_ips
  fi
  exit
  ;;

ssh)
  shift 1
  __check_vm_args $1
  __ssh_viewer "$1" "$2" "$3"
  ;;

*)
  __check_vm_args $1
  __list_running | grep -q "$1" && __viewer "$1"
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
