export VIRT_DISPLAY_CWD
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set actions based on variables

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
#requiresudo "$0" "$@" || exit 2     # exit 2 if errors
#cmd_exists --error --ask bash || exit 3 # exit 3 if not found
#am_i_online --error || exit 4           # exit 4 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
case "$1" in
list)
  shift 1
  paused="$(__list_running | grep 'paused' | awk '{print $2}' | tr '\n' ' ')"
  running="$(__list_running | grep 'running' | awk '{print $2}' | tr '\n' ' ')"
  stopped="$(__list_running | grep 'shut off' | awk '{print $2}' | tr '\n' ' ')"
  if [ -n "$running" ]; then
    printf_green "Running: $running"
  fi
  if [ -n "$stopped" ]; then
    printf_red "Stopped: $stopped"
  fi
  if [ -n "$paused" ]; then
    printf_yellow "Paused: $paused"
  fi
  exit $?
  ;;

start)
  shift 1
  __check_vm_args $1
  __start "$@"
  exit $?
  ;;

restore)
  shift 1
  __check_vm_args $1
  __restore "$@"
  exit $?
  ;;

create)
  shift 1
  __check_vm_args "$1"
  __snapshot "$@"
  exit $?
  ;;

new)
  shift 1
  [ $# -ne 2 ] && printf_exit "Usage: $APPNAME new <name> <isoFile>"
  __vm_new "$@"
  exit $?
  ;;

delete)
  shift 1
  __vm_rm "$1"
  exit $?
  ;;

ip)
  shift 1
  if [ $# -ne 0 ]; then
    __check_vm_args $1
    ip="$(__get_ip "$1")"
    if [ -n "$ip" ]; then
      printf_green "IP for $1 is: $ip"
    else
      printf_red "No IP found for $1"
    fi
  else
    __list_ips
  fi
  exit $?
  ;;

ssh)
  shift 1
  __check_vm_args $1
  __ssh_viewer "$@"
  exit $?
  ;;

open)
  shift 1
  __check_vm_args $1
  __list_running | grep -q "$1" && __viewer "$1"
  exit $?
  ;;

*)
  if [ $# -ne 0 ]; then
    __check_vm_args $1
    __list_running | grep -q "$1" && __viewer "$1"
  else
    __list_running | printf_column $VIRT_DISPLAY_OUTPUT_COLOR_1 || printf_exit "There are no running vms"
  fi
  ;;
esac
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set exit code
exitCode="${exitCode:-$?}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
