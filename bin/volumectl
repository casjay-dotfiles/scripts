#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version           :  202207151238-git
# @Author            :  Jason Hempstead
# @Contact           :  jason@casjaysdev.com
# @License           :  WTFPL
# @ReadME            :  volume --help
# @Copyright         :  Copyright: (c) 2022 Jason Hempstead, Casjays Developments
# @Created           :  Friday, Jul 15, 2022 12:38 EDT
# @File              :  volume
# @Description       :  control volume in terminal
# @TODO              :  Better documentation
# @Other             :
# @Resource          :  https://coolaj86.com/articles/how-to-control-os-x-system-volume-with-applescript/
# @sudo/root         :  no
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202207151238-git"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -'
# Set functions
__devnull() { tee "${*:-}" &>/dev/null; }
__cmd_exist() { command -v "$1" &>/dev/null || return 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__version() { printf_color "$VERSION"; }
printf_color() { printf '\t\t%s%s%s\n' "${1:-}" "${2:-}" "${NC}"; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__list_options() { printf_color "${1:-$ARRAY}" | sed 's|:||g;s|'$2'| '$3'|g' 2>/dev/null; }
__notifications() {
  [[ -n "$DISPLAY" ]] && [[ -z "$SSH_CONNECTION" ]] &&
    __cmd_exist notifications &>/dev/null && notifications "$@" || echo "$*"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__volume_up() {
  local inc="${1:-5}"
  if __cmd_exist amixer; then
    amixer -q -D pulse sset Master $inc%+ && true || false
  elif __cmd_exist pamixer; then
    pamixer -i $inc && true || false
  elif __cmd_exist pactl; then
    local dev="$(pactl info | grep 'Default Sink' | cut -d':' -f 2 | sed 's|^ ||g')"
    pactl set-sink-volume $dev +$inc% && true || false
  elif __cmd_exist osascript; then
    osascript -e "set Volume 3.5" && true || false
  else
    false
  fi
  [[ "$?" = 0 ]] && __notifications "Volume set to $inc" ||
    __notifications "Failed to set volume to $inc"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__volume_down() {
  local dec="${1:-5}"
  if __cmd_exist amixer; then
    amixer -q -D pulse sset Master $dec%- && true || false
  elif __cmd_exist pamixer; then
    pamixer -d $dec && true || false
  elif __cmd_exist pactl; then
    local dev="$(pactl info | grep 'Default Sink' | cut -d':' -f 2 | sed 's|^ ||g')"
    pactl set-sink-volume $dev -$dec% && true || false
  elif __cmd_exist osascript; then
    osascript -e "set Volume 3.5" && true || false
  else
    false
  fi
  [[ "$?" = 0 ]] && __notifications "Volume set to $dec" ||
    __notifications "Failed to set volume to $dec"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__volume_toggle() {
  local toggle="true"
  if __cmd_exist amixer; then
    amixer -q -D pulse sset Master toggle && true || false
  elif __cmd_exist pactl; then
    local dev="$(pactl info | grep 'Default Sink' | cut -d':' -f 2 | sed 's|^ ||g')"
    pactl set-sink-mute $dev toggle && true || false
  elif __cmd_exist osascript; then
    osascript -e "set Volume 3.5" && true || false
  else
    false
  fi
  [[ "$?" = 0 ]] && __notifications "Volume has been toggled" ||
    __notifications "Failed toggle the volume"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__help() {
  # Help function - Align to 50
  printf_head() { printf_color "$PURPLE" "$*"; }
  printf_opts() { printf_color "$BLUE" "$*"; }
  printf_line() { printf_blue "$BLUE" "$*"; }
  #
  printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  printf_opts "volume: "
  printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  printf_line "Usage: volume [options] [commands]"
  printf_line "volume available                             - list all available packages"
  printf_line "volume list                                  - list installed packages"
  printf_line "volume search    [package]                   - search for a package"
  printf_line "volume version   [package]                   - show the version info"
  printf_line "volume install   [package]                   - install a package"
  printf_line "volume remove    [package]                   - remove a package"
  printf_line "volume update    [package]                   - update a package"
  printf_line "volume download  [package]                   - downloads the source"
  printf_line ""
  printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  printf_opts "Other Options"
  printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  printf_line "volume --debug                               - enable debugging"
  printf_line "volume --config                              - Generate user config file"
  printf_line "volume --version                             - Show script version"
  printf_line "volume --help                                - Shows this message"
  printf_line "volume --options                             - Shows all available options"
  printf_line ""
  printf_head "- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -"
  exit
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for needed applications
type -P bash &>/dev/null || { echo "Missing: bash" && exit 1; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set variables
NC="$(tput sgr0 2>/dev/null)"
RESET="$(tput sgr0 2>/dev/null)"
BLACK="\033[0;30m"
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
BLUE="\033[0;34m"
PURPLE="\033[0;35m"
CYAN="\033[0;36m"
WHITE="\033[0;37m"
ORANGE="\033[0;33m"
LIGHTRED='\033[1;31m'
BG_GREEN="\[$(tput setab 2 2>/dev/null)\]"
BG_RED="\[$(tput setab 9 2>/dev/null)\]"
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set options
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="debug,raw,help,options,version,help"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --help)
    shift 1
    __help
    exit
    ;;
  --version)
    shift 1
    printf_color "$YELLOW" "$APPNAME Version: $VERSION\n"
    exit
    ;;
  --options)
    shift 1
    [ -n "$1" ] || printf "Current options for ${PROG:-$APPNAME}\n"
    [ -z "$SHORTOPTS" ] || __list_options "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --raw)
    export SHOW_RAW="true"
    unset -f printf_color
    printf_color() { printf '%b' "$1" | tr -d '\t\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }

    ;;
  --)
    shift 1
    break
    ;;
  esac
done
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional variables

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Main application
[ "$1" = "up" ] && __volume_up "$2"
[ "$1" = "down" ] && __volume_down "$2"
{ [ "$1" = "" ] || [ "$1" = "toggle" ]; } && __volume_toggle
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
exit ${exitCode:-$?}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# end
