#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0")"
VERSION="202108171344-git"
RUN_USER="${SUDO_USER:-${USER}}"
USER="${SUDO_USER:-${USER}}"
HOME="${USER_HOME:-${HOME}}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
trap 'exitCode=${exitCode:-$?};[ -f "$WIKIPEDIA_TEMP_FILE" ] && rm -Rf "$WIKIPEDIA_TEMP_FILE" &>/dev/null' EXIT

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202108171344-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : wikipedia --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Tuesday, Aug 17, 2021 13:44 EDT
# @File          : wikipedia
# @Description   : Lookup something on wikipedia
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_available() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  printf_green "Generating the config file in"
  printf_green "$WIKIPEDIA_CONFIG_DIR/$WIKIPEDIA_CONFIG_FILE"
  [ -d "$WIKIPEDIA_CONFIG_DIR" ] || mkdir -p "$WIKIPEDIA_CONFIG_DIR"
  [ -d "$WIKIPEDIA_CONFIG_BACKUP_DIR" ] || mkdir -p "$WIKIPEDIA_CONFIG_BACKUP_DIR"
  [ -f "$WIKIPEDIA_CONFIG_DIR/$WIKIPEDIA_CONFIG_FILE" ] &&
    cp -Rf "$WIKIPEDIA_CONFIG_DIR/$WIKIPEDIA_CONFIG_FILE" "$WIKIPEDIA_CONFIG_BACKUP_DIR/$WIKIPEDIA_CONFIG_FILE.$$"
  cat <<EOF >"$WIKIPEDIA_CONFIG_DIR/$WIKIPEDIA_CONFIG_FILE"
# Settings for wikipedia
WIKIPEDIA_API_MAX_CHARS="${WIKIPEDIA_API_MAX_CHARS:-2500}"
WIKIPEDIA_API_URL="${WIKIPEDIA_API_URL:-https://en.wikipedia.org/w/api.php}"
WIKIPEDIA_PING_URL="${WIKIPEDIA_PING_URL:-8.8.8.8}"

# Notification settings
WIKIPEDIA_GOOD_MESSAGE="${WIKIPEDIA_GOOD_MESSAGE:-Everything Went OK}"
WIKIPEDIA_ERROR_MESSAGE="${WIKIPEDIA_ERROR_MESSAGE:-Well that didn\'t work}"
WIKIPEDIA_NOTIFY_ENABLED="${WIKIPEDIA_NOTIFY_ENABLED:-yes}"
WIKIPEDIA_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
WIKIPEDIA_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$WIKIPEDIA_NOTIFY_CLIENT_ICON}"

# Colorization settings
WIKIPEDIA_OUTPUT_COLOR="${WIKIPEDIA_OUTPUT_COLOR:-4}"
WIKIPEDIA_OUTPUT_COLOR_GOOD="${WIKIPEDIA_OUTPUT_COLOR_GOOD:-2}"
WIKIPEDIA_OUTPUT_COLOR_ERROR="${WIKIPEDIA_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$WIKIPEDIA_CONFIG_DIR/$WIKIPEDIA_CONFIG_FILE" ]; then
    printf_green "Your config file for wikipedia has been created"
    true
  else
    printf_red "Failed to create the config file"
    false
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__curl() { curl --disable -LSsfk --connect-timeout 3 --retry 0 --fail "$@" 2>/dev/null || return 1; }
__uri_decode() { echo -e "$*" | perl -MURI::Escape -lne 's/ /_/g;s/"//g;print uri_escape($_);'; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode="0"
WIKIPEDIA_CACHE_DIR="${WIKIPEDIA_CACHE_DIR:-$HOME/.cache/wikipedia}"
WIKIPEDIA_CONFIG_DIR="${WIKIPEDIA_CONFIG_DIR:-$HOME/.config/myscripts/wikipedia}"
WIKIPEDIA_OPTIONS_DIR="${WIKIPEDIA_OPTIONS_DIR:-$HOME/.local/share/myscripts/wikipedia/options}"
WIKIPEDIA_CONFIG_BACKUP_DIR="${WIKIPEDIA_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/wikipedia/backups}"
WIKIPEDIA_TEMP_DIR="${WIKIPEDIA_TEMP_DIR:-$HOME/.local/tmp/system_scripts/wikipedia}"
WIKIPEDIA_TEMP_FILE="${WIKIPEDIA_TEMP_FILE:-$HOME/.local/tmp/wikipedia/$(mktemp XXXXXX)}"
WIKIPEDIA_CONFIG_FILE="${WIKIPEDIA_CONFIG_FILE:-settings.conf}"
WIKIPEDIA_GOOD_MESSAGE="${WIKIPEDIA_GOOD_MESSAGE:-Everything Went OK}"
WIKIPEDIA_ERROR_MESSAGE="${WIKIPEDIA_ERROR_MESSAGE:-Well that didn\'t work}"
WIKIPEDIA_NOTIFY_ENABLED="${WIKIPEDIA_NOTIFY_ENABLED:-yes}"
WIKIPEDIA_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
WIKIPEDIA_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$WIKIPEDIA_NOTIFY_CLIENT_ICON}"
WIKIPEDIA_API_URL="${WIKIPEDIA_API_URL:-https://en.wikipedia.org/w/api.php}"
WIKIPEDIA_PING_URL="${WIKIPEDIA_PING_URL:-8.8.8.8}"
WIKIPEDIA_API_MAX_CHARS="${WIKIPEDIA_API_MAX_CHARS:-2500}"
WIKIPEDIA_OUTPUT_COLOR="${WIKIPEDIA_OUTPUT_COLOR:-5}"
WIKIPEDIA_OUTPUT_COLOR_GOOD="${WIKIPEDIA_OUTPUT_COLOR_GOOD:-2}"
WIKIPEDIA_OUTPUT_COLOR_ERROR="${WIKIPEDIA_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$WIKIPEDIA_TEMP_DIR" ] || mkdir -p "$WIKIPEDIA_TEMP_DIR" &>/dev/null
[ -d "$WIKIPEDIA_CACHE_DIR" ] || mkdir -p "$WIKIPEDIA_CACHE_DIR" &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$WIKIPEDIA_CONFIG_DIR/$WIKIPEDIA_CONFIG_FILE" ] ||
  __gen_config &>/dev/null
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$WIKIPEDIA_CONFIG_DIR/$WIKIPEDIA_CONFIG_FILE" ] &&
  . "$WIKIPEDIA_CONFIG_DIR/$WIKIPEDIA_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS="z:"
LONGOPTS="options,config,version,help,dir:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$PROG" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_available "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_available "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_available "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  -z | --dir)
    WIKIPEDIA_CACHE_DIR="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env
if [ "$WIKIPEDIA_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${WIKIPEDIA_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${WIKIPEDIA_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${WIKIPEDIA_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${WIKIPEDIA_NOTIFY_CLIENT_ICON}"
    notifications "$*" || return 1
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
cmd_exists --error bash curl lynx jq || exit 1 # exit 1 if not found
am_i_online --error || exit 1                  # exit 1 if no internet
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides
QUERY="$(__uri_decode "$*")"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
results="$(curl -q -LSs ''$WIKIPEDIA_API_URL'?action=query&generator=search&gsrsearch='$QUERY'&gsrlimit=2&prop=pageimages|extracts&exchars='$WIKIPEDIA_API_MAX_CHARS'&exintro&explaintext&exlimit=1&format=json&origin=*' | jq '.query.pages | .[].extract' | grep -v ^'null' | grep '^')"
echo -e '\033[8;40;80t' $results | sed 's|\. |\.\n|g' | printf_readline "$WIKIPEDIA_OUTPUT_COLOR"
printf_newline
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
