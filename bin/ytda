[ -n "$OPTS" ] && YTDL_OPTS="$YTDL_OPTS $OPTS"
[ -f "$YTDA_COOKIE_FILE" ] && YTDL_OPTS="$YTDL_OPTS --cookies $YTDA_COOKIE_FILE"
