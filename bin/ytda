# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__grab_file() {
  {
    printf '%s\n' "#### Downloading from $2"
    $1 "$2"
    exitStatus=$?
    printf '\n%s\n\n' "#### Downloading finished with exit code: $exitStatus"
  } &>>"$YTDA_YOUTUBE_DL_LOG_FILE"
  printf '\n'
  return $exitStatus
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__download() {
  local exitCode=0 urls=""
  local action="$1" && shift 1
  urls="$(echo "$@" | tr ',' '\n' | tr ' ' '\n')"
  for url in $urls; do
    if echo "$url" | grep -q 'list='; then
      printf '%b ' "🔻 ${YELLOW}Downloading videos from playlist${NC} 🔻 "
    else
      printf '%b ' "🔻 ${YELLOW}Downloading video from $url${NC} 🔻 "
    fi
    if __is_url "$url"; then
      file_url="$url"
    else
      file_url="${YTDA_DEFAULT_URL}$url"
    fi
    __grab_file "$action" "$file_url" "$message"
    if [ $? -eq 0 ]; then
      rm -Rf "$YTDA_YOUTUBE_DL_LOG_FILE"
      printf_green "😀 Successfully downloaded $file_url 😀 "
      exitCode=$(($exitCode + 0))
    else
      printf_red "😿 Failed to download $file_url 😿 "
      __show_error_log | printf_readline $YTDA_OUTPUT_COLOR_2
      exitCode=$(($exitCode + 1))
    fi
    printf '\n'
  done
  return $exitCode
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__show_error_log() {
  if [ -f "$YTDA_YOUTUBE_DL_LOG_FILE" ]; then
    grep --no-filename -B5 '^ERROR: ' "$YTDA_YOUTUBE_DL_LOG_FILE" && return 1 || return 0
  fi
}
