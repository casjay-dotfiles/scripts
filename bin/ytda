# Ensure Directories exist
[ -d "$YTDA_LOG_DIR" ] ||
  mkdir -p "$YTDA_LOG_DIR" |& __devnull
[ -d "$YTDA_TEMP_DIR" ] ||
  mkdir -p "$YTDA_TEMP_DIR" |& __devnull
[ -d "$YTDA_CACHE_DIR" ] ||
  mkdir -p "$YTDA_CACHE_DIR" |& __devnull
