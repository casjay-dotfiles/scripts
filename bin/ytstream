#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
##@Version       : 202112081033-git
# @Author        : Jason Hempstead
# @Contact       : jason@casjaysdev.com
# @License       : WTFPL
# @ReadME        : ytstream --help
# @Copyright     : Copyright: (c) 2021 Jason Hempstead, Casjays Developments
# @Created       : Wednesday, Dec 08, 2021 10:33 EST
# @File          : ytstream
# @Description   : Open youtube video in media player
# @TODO          :
# @Other         :
# @Resource      :
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="$(basename "$0" 2>/dev/null)"
VERSION="202112081033-git"
HOME="${USER_HOME:-$HOME}"
USER="${SUDO_USER:-$USER}"
RUN_USER="${SUDO_USER:-$USER}"
SRC_DIR="${BASH_SOURCE%/*}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set bash options
if [[ "$1" == "--debug" ]]; then shift 1 && set -xo pipefail && export SCRIPT_OPTS="--debug" && export _DEBUG="on"; fi

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import functions
CASJAYSDEVDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}"
SCRIPTSFUNCTDIR="${CASJAYSDEVDIR:-/usr/local/share/CasjaysDev/scripts}/functions"
SCRIPTSFUNCTFILE="${SCRIPTSAPPFUNCTFILE:-testing.bash}"
SCRIPTSFUNCTURL="${SCRIPTSAPPFUNCTURL:-https://github.com/dfmgr/installer/raw/main/functions}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ -f "$PWD/$SCRIPTSFUNCTFILE" ]; then
  . "$PWD/$SCRIPTSFUNCTFILE"
elif [ -f "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" ]; then
  . "$SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE"
else
  echo "Can not load the functions file: $SCRIPTSFUNCTDIR/$SCRIPTSFUNCTFILE" 1>&2
  exit 1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# user system devenv dfmgr dockermgr fontmgr iconmgr pkmgr systemmgr thememgr wallpapermgr
user_install
__options "$@"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set functions
__list_options() { printf_custom "$1" "$2: $(echo ${3:-$ARRAY} | __sed 's|:||g;s|'$4'| '$5'|g')" 2>/dev/null; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__gen_config() {
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Generating the config file in"
  [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "$YTSTREAM_CONFIG_DIR/$YTSTREAM_CONFIG_FILE"
  [ -d "$YTSTREAM_CONFIG_DIR" ] || mkdir -p "$YTSTREAM_CONFIG_DIR"
  [ -d "$YTSTREAM_CONFIG_BACKUP_DIR" ] || mkdir -p "$YTSTREAM_CONFIG_BACKUP_DIR"
  [ -f "$YTSTREAM_CONFIG_DIR/$YTSTREAM_CONFIG_FILE" ] &&
    cp -Rf "$YTSTREAM_CONFIG_DIR/$YTSTREAM_CONFIG_FILE" "$YTSTREAM_CONFIG_BACKUP_DIR/$YTSTREAM_CONFIG_FILE.$$"
  cat <<EOF >"$YTSTREAM_CONFIG_DIR/$YTSTREAM_CONFIG_FILE"
# Settings for ytstream
YTSTREAM_DEFAULT_PLAYER="${YTSTREAM_DEFAULT_PLAYER:-$(__get_player && __show_vars --player)}"
YTSTREAM_DEFAULT_PLAYER_OPTIONS="${YTSTREAM_DEFAULT_PLAYER_OPTIONS:-$(__get_player && __show_vars --options)}"
YTSTREAM_DEFAULT_PLAYER_CONSOLE="${YTSTREAM_DEFAULT_PLAYER_CONSOLE:-$(__get_player && __show_vars --options)}"

# Notification settings
YTSTREAM_GOOD_MESSAGE="${YTSTREAM_GOOD_MESSAGE:-Everything Went OK}"
YTSTREAM_ERROR_MESSAGE="${YTSTREAM_ERROR_MESSAGE:-Well something seems to have gone wrong}"
YTSTREAM_NOTIFY_ENABLED="${YTSTREAM_NOTIFY_ENABLED:-yes}"
YTSTREAM_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
YTSTREAM_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$YTSTREAM_NOTIFY_CLIENT_ICON}"

# Colorization settings
YTSTREAM_OUTPUT_COLOR="${YTSTREAM_OUTPUT_COLOR:-5}"
YTSTREAM_OUTPUT_COLOR_GOOD="${YTSTREAM_OUTPUT_COLOR_GOOD:-2}"
YTSTREAM_OUTPUT_COLOR_ERROR="${YTSTREAM_OUTPUT_COLOR_ERROR:-1}"

EOF
  if [ -f "$YTSTREAM_CONFIG_DIR/$YTSTREAM_CONFIG_FILE" ]; then
    [[ "$INIT_CONFIG" = "TRUE" ]] || printf_green "Your config file for $APPNAME has been created"
    exitCode=0
  else
    printf_red "Failed to create the config file"
    exitCode=1
  fi
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional functions
__get_player() {
  if [[ -n "$YTSTREAM_DEFAULT_PLAYER" ]] && [ -f "$(builtin type -P "$YTSTREAM_DEFAULT_PLAYER" 2>/dev/null)" ]; then
    return 0
  else
    if cmd_exists vlc; then
      YTSTREAM_DEFAULT_PLAYER="vlc"
      YTSTREAM_DEFAULT_PLAYER_OPTIONS=""
      YTSTREAM_DEFAULT_PLAYER_CONSOLE=""
    elif cmd_exists mplayer; then
      YTSTREAM_DEFAULT_PLAYER="mplayer"
      YTSTREAM_DEFAULT_PLAYER_OPTIONS=""
      YTSTREAM_DEFAULT_PLAYER_CONSOLE=""
    elif cmd_exists mpv; then
      YTSTREAM_DEFAULT_PLAYER="mpv"
      YTSTREAM_DEFAULT_PLAYER_OPTIONS=""
      YTSTREAM_DEFAULT_PLAYER_CONSOLE=""
    elif cmd_exists cvlc; then
      YTSTREAM_DEFAULT_PLAYER="cvlc"
      YTSTREAM_DEFAULT_PLAYER_OPTIONS=""
      YTSTREAM_DEFAULT_PLAYER_CONSOLE="true"
    else
      YTSTREAM_DEFAULT_PLAYER=""
      YTSTREAM_DEFAULT_PLAYER_OPTIONS=""
      YTSTREAM_DEFAULT_PLAYER_CONSOLE=""
    fi
  fi
  if [[ -z "$YTSTREAM_DEFAULT_PLAYER" ]]; then
    printf_red "Can not find a media player"
    printf_yellow "Please install vlc, mplayer, or mpv"
    exit 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__show_vars() {
  if [ "$1" = "--console" ]; then
    echo "$YTSTREAM_DEFAULT_PLAYER_CONSOLE"
  fi
  if [ "$1" = "--options" ]; then
    echo "$YTSTREAM_DEFAULT_PLAYER_OPTIONS"
  fi
  if [ "$1" = "--player" ]; then
    echo "$YTSTREAM_DEFAULT_PLAYER"
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__console_app() {
  if [[ "$YTSTREAM_DEFAULT_PLAYER_CONSOLE" = "true" ]]; then
    return 0
  elif [[ "$YTSTREAM_DEFAULT_PLAYER_CONSOLE" = "yes" ]]; then
    return 0
  elif [[ -n "$YTSTREAM_DEFAULT_PLAYER_CONSOLE" ]]; then
    return 0
  else
    return 1
  fi
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__play_vid() {
  local exitCode=0
  for url in "$@"; do
    check_uri "$url" && set_video_url="$url" || set_video_url="https://youtube.com/watch?v=$url"
    play_url="$(youtube-dl --quiet --no-warnings --get-url --format best "$set_video_url" 2>/dev/null || echo "")"
    if [[ -n "$play_url" ]]; then
      echo "Playing $url" >>"$YTSTREAM_LOG_DIR/play.log"
      date +'%m-%d-Y at %H:%M' >>"$YTSTREAM_LOG_DIR/play.log"
      if $YTSTREAM_DEFAULT_PLAYER "$play_url" 2>>"$YTSTREAM_LOG_DIR/play.log"; then
        exitCode+=0
      else
        echo "Failed to play video from $url" >>"$YTSTREAM_LOG_DIR/play.log"
        exitCode+=1
      fi
    else
      echo "An error has occured: $url" >>"$YTSTREAM_LOG_DIR/play.log"
      exitCode=5
    fi
    date +'%m-%d-Y at %H:%M' >>"$YTSTREAM_LOG_DIR/play.log"
    printf '\n\n' >>"$YTSTREAM_LOG_DIR/play.log"
  done
  return ${exitCode:-$?}
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
__get_youtubeDL() {
  curl -q -LSs "https://yt-dl.org/downloads/latest/youtube-dl" >"$HOME/.local/bin/youtube-dl" 2>/dev/null &&
    chmod a+rx "$HOME/.local/bin/youtube-dl" &>/dev/null ||
    printf_exit "failed to download youtube-dl"
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Default variables
exitCode=
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
YTSTREAM_LOG_DIR="${YTSTREAM_LOG_DIR:-$HOME/.local/log/ytstream}"
YTSTREAM_CACHE_DIR="${YTSTREAM_CACHE_DIR:-$HOME/.cache/ytstream}"
YTSTREAM_CONFIG_DIR="${YTSTREAM_CONFIG_DIR:-$HOME/.config/myscripts/ytstream}"
YTSTREAM_OPTIONS_DIR="${YTSTREAM_OPTIONS_DIR:-$HOME/.local/share/myscripts/ytstream/options}"
YTSTREAM_CONFIG_BACKUP_DIR="${YTSTREAM_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/ytstream/backups}"
YTSTREAM_TEMP_DIR="${YTSTREAM_TEMP_DIR:-$HOME/.local/tmp/system_scripts/ytstream}"
YTSTREAM_CONFIG_FILE="${YTSTREAM_CONFIG_FILE:-settings.conf}"
YTSTREAM_GOOD_MESSAGE="${YTSTREAM_GOOD_MESSAGE:-Everything Went OK}"
YTSTREAM_ERROR_MESSAGE="${YTSTREAM_ERROR_MESSAGE:-Well something seems to have gone wrong}"
YTSTREAM_NOTIFY_ENABLED="${YTSTREAM_NOTIFY_ENABLED:-yes}"
YTSTREAM_NOTIFY_CLIENT_NAME="${NOTIFY_CLIENT_NAME:-$APPNAME}"
YTSTREAM_NOTIFY_CLIENT_ICON="${NOTIFY_CLIENT_ICON:-$YTSTREAM_NOTIFY_CLIENT_ICON}"
YTSTREAM_OUTPUT_COLOR="${YTSTREAM_OUTPUT_COLOR:-5}"
YTSTREAM_OUTPUT_COLOR_GOOD="${YTSTREAM_OUTPUT_COLOR_GOOD:-2}"
YTSTREAM_OUTPUT_COLOR_ERROR="${YTSTREAM_OUTPUT_COLOR_ERROR:-1}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Enviroment overrides
YTSTREAM_DEFAULT_PLAYER="${YTSTREAM_DEFAULT_PLAYER:-$(__get_player && __show_vars --player)}"
YTSTREAM_DEFAULT_PLAYER_OPTIONS="${YTSTREAM_DEFAULT_PLAYER_OPTIONS:-$(__get_player && __show_vars --options)}"
YTSTREAM_DEFAULT_PLAYER_CONSOLE="${YTSTREAM_DEFAULT_PLAYER_CONSOLE:-$(__get_player && __show_vars --options)}"

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$YTSTREAM_CONFIG_DIR/$YTSTREAM_CONFIG_FILE" ] || [[ "$*" = *config ]] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$YTSTREAM_CONFIG_DIR/$YTSTREAM_CONFIG_FILE" ] && . "$YTSTREAM_CONFIG_DIR/$YTSTREAM_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories and files exist
[ -d "$YTSTREAM_LOG_DIR" ] || mkdir -p "$YTSTREAM_LOG_DIR" &>/dev/null
[ -d "$YTSTREAM_TEMP_DIR" ] || mkdir -p "$YTSTREAM_TEMP_DIR" &>/dev/null
[ -d "$YTSTREAM_CACHE_DIR" ] || mkdir -p "$YTSTREAM_CACHE_DIR" &>/dev/null
YTSTREAM_TEMP_FILE="${YTSTREAM_TEMP_FILE:-$(mktemp $YTSTREAM_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap 'exitCode=${exitCode:-$?};[ -n "$YTSTREAM_TEMP_FILE" ] && [ -f "$YTSTREAM_TEMP_FILE" ] && rm -Rf "$YTSTREAM_TEMP_FILE" &>/dev/null' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup notification function
if [ "$YTSTREAM_NOTIFY_ENABLED" = "yes" ]; then
  __notifications() {
    export NOTIFY_GOOD_MESSAGE="${YTSTREAM_GOOD_MESSAGE}"
    export NOTIFY_ERROR_MESSAGE="${YTSTREAM_ERROR_MESSAGE}"
    export NOTIFY_CLIENT_NAME="${YTSTREAM_NOTIFY_CLIENT_NAME}"
    export NOTIFY_CLIENT_ICON="${YTSTREAM_NOTIFY_CLIENT_ICON}"
    notifications "$@" && exitCode=0 || exitCode=1
    unset NOTIFY_CLIENT_NAME NOTIFY_CLIENT_ICON NOTIFY_GOOD_MESSAGE NOTIFY_ERROR_MESSAGE
    return ${exitCode:-$?}
  }
else
  __notifications() { false; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Show warn message if variables are missing

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Set additional variables/Argument/Option settings
SETARGS="$*"
SHORTOPTS=""
LONGOPTS="options,config,version,help,dir:,code:"
ARRAY=""
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -a -n "$(basename "$0" 2>/dev/null)" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case $1 in
  --options)
    shift 1
    [ -n "$1" ] || printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "5" "Short Options" "-$SHORTOPTS" ',' '-'
    [ -z "$LONGOPTS" ] || __list_options "5" "Long Options" "--$LONGOPTS" ',' '--'
    [ -z "$ARRAY" ] || __list_options "5" "Base Options" "$ARRAY" ',' ''
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    __help
    shift 1
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --dir)
    YTSTREAM_CWD="$2"
    shift 2
    ;;
  --code)
    shortcode="$2"
    shift 2
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
#set -- "$SETARGS"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Actions based on env

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# Check for required applications/Network check
am_i_online --error || exit 1                      # exit 1 if no internet
cmd_exists --error --ask bash || exit 1            # exit 1 if no bash
cmd_exists youtube-dl || __get_youtubeDL || exit 1 # exit 1 if no youtube-dl
__get_player
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# APP Variables overrides

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
if __console_app; then
  __play_vid "${shortcode:-$@}" 2>/dev/null
else
  __play_vid "${shortcode:-$@}" &>/dev/null &
fi
if [[ $exitCode -ne 0 ]]; then
  printf_red "Please look in $YTSTREAM_LOG_DIR/play.log"
  exitCode=1
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${exitCode:-$?}
