  #        [[ $? = 0 ]] && __logr "Installed $pkg" || __logr "Warning: Failed to installed $pkg"
  #     done
  #   fi
  # elif cmd_exists dnf; then
  #   if cmd_exists pkmgr; then
  #     for pkg in LIST; do
  #        pkmgr silent install "$pkg" |&__devnull
  #        [[ $? = 0 ]] && __logr "Installed $pkg" || __logr "Warning: Failed to installed $pkg"
