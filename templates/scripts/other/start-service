#!/usr/bin/env bash
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# run trap command on exit
trap -- 'retVal=$?; [ -f "/tmp/$EXEC_CMD.pid" ] && rm -Rf "/tmp/$EXEC_CMD.pid";exit $retVal' SIGINIT SIGTERM ERR EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# https://www.gnu.org/software/bash/manual/html_node/The-Set-Builtin.html
[ "$DEBUGGER" = "on" ] && echo "Enabling debugging" && set -o pipefail -x$DEBUGGER_OPTIONS || set -Eeuo pipefail
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# execute command options
EXEC_CMD="$script_filename" # command to execute
SERVICE_ARGS=""             # command arguments
SERVICE_USER=""             # execute command as another user
PRE_EXEC_MESSAGE=""         # Show message before execute
SERVICE_EXIT_CODE=0         # default exit code
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# function to run before executing
__pre_execute() {
  return
}
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# import variables
[ -f "/root/env.sh" ] && . "/root/env.sh"
[ -f "/config/env.sh" ] && . "/config/env.sh"
[ -f "/config/env/$EXEC_CMD" ] && . "/config/env/$EXEC_CMD"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
# check is process is already running
__pcheck() { [ -n "$(type -P pgrep 2>/dev/null)" ] && pgrep -x "$1" &>/dev/null && return 0 || return 10; }
__pgrep() { __pcheck "${1:-EXEC_CMD}" || __ps aux 2>/dev/null | grep -Fw " ${1:-$EXEC_CMD}" | grep -qv ' grep' | grep '^' && return 0 || return 10; }
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if [ ! -f "$(type -P "$EXEC_CMD")" ] && [ -z "$EXEC_CMD" ]; then
  echo "$EXEC_CMD is not a valid command"
  exit 2
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
if __pgrep "$EXEC_CMD"; then
  echo "$EXEC_CMD is running"
  exit 0
fi
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
echo "Setting up service to run as $SERVICE_USER"
if [ "$SERVICE_USER" = "root" ] || [ -z "$SERVICE_USER" ]; then
  su_cmd() { eval "$@" || return 1; }
elif [ "$(builtin type -P gosu)" ]; then
  su_cmd() { gosu $SERVICE_USER "$@" || return 1; }
elif [ "$(builtin type -P su)" ]; then
  su_cmd() { su -s /bin/sh - $SERVICE_USER -c "$@" || return 1; }
elif [ "$(builtin type -P runuser)" ]; then
  su_cmd() { runuser -u $SERVICE_USER "$@" || return 1; }
elif [ "$(builtin type -P sudo)" ]; then
  su_cmd() { sudo -u $SERVICE_USER "$@" || return 1; }
else
  echo "Can not switch to $SERVICE_USER"
  exit 10
fi
sleep 30
[ -n "$PRE_EXEC_MESSAGE" ] && echo "$PRE_EXEC_MESSAGE"
__pre_execute
echo "Starting service: $EXEC_CMD $CMD_ARGS"
su_cmd "touch /tmp/$EXEC_CMD.pid"
su_cmd "$EXEC_CMD $CMD_ARGS" || echo "Failed to execute: $EXEC_CMD $CMD_ARGS"
[ "$?" -ne 0 ] && SERVICE_EXIT_CODE=10 && rm -Rf "/tmp/$EXEC_CMD.pid"
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
exit $SERVICE_EXIT_CODE
